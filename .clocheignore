# Runtime state — excluded from container copies so agents don't see stale
# prompt files or logs from previous runs.
.cloche/runs/
.cloche/logs/

# Extraction worktrees live on the host (created by cloched and cloche extract).
# Never copy them into the container.
.gitworktrees/

# Unix sockets cannot be archived into containers.
*.sock

# Credentials are baked into the image at build time (see .cloche/Dockerfile).
# Don't also copy them into /workspace at runtime.
.cloche/credentials/
