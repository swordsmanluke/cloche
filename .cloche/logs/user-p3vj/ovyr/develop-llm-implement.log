   150→\n   151→\tstep := &domain.Step{\n   152→\t\tName:    \"build\",\n   153→\t\tType:    domain.StepTypeScript,\n   154→\t\tResults: []string{\"success\", \"fail\"},\n   155→\t\tConfig:  map[string]string{\"run\": \"echo 'line one'; echo 'line two'; echo 'line three'\"},\n   156→\t}\n   157→\n   158→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   159→\trequire.NoError(t, err)\n   160→\tassert.Equal(t, \"success\", result)\n   161→\n   162→\t// Parse status messages and verify log lines were streamed\n   163→\tmsgs, err := protocol.ParseStatusStream(statusBuf.Bytes())\n   164→\trequire.NoError(t, err)\n   165→\n   166→\tvar logMessages []string\n   167→\tfor _, msg := range msgs {\n   168→\t\tif msg.Type == protocol.MsgLog && msg.StepName == \"build\" {\n   169→\t\t\tlogMessages = append(logMessages, msg.Message)\n   170→\t\t}\n   171→\t}\n   172→\n   173→\tassert.Equal(t, []string{\"line one\", \"line two\", \"line three\"}, logMessages)\n   174→\n   175→\t// Verify the log file was still written\n   176→\tlogPath := filepath.Join(dir, \".cloche\", \"output\", \"build.log\")\n   177→\tcontent, err := os.ReadFile(logPath)\n   178→\trequire.NoError(t, err)\n   179→\tassert.Contains(t, string(content), \"line one\")\n   180→\tassert.Contains(t, string(content), \"line two\")\n   181→\tassert.Contains(t, string(content), \"line three\")\n   182→}\n   183→\n   184→func TestGenericAdapter_StreamsStderrViaStatusWriter(t *testing.T) {\n   185→\tdir := t.TempDir()\n   186→\n   187→\tvar statusBuf bytes.Buffer\n   188→\tsw := protocol.NewStatusWriter(&statusBuf)\n   189→\n   190→\tadapter := generic.New()\n   191→\tadapter.StatusWriter = sw\n   192→\n   193→\tstep := &domain.Step{\n   194→\t\tName:    \"lint\",\n   195→\t\tType:    domain.StepTypeScript,\n   196→\t\tResults: []string{\"success\", \"fail\"},\n   197→\t\tConfig:  map[string]string{\"run\": \"echo 'stdout msg'; echo 'stderr msg' >&2\"},\n   198→\t}\n   199→\n   200→\tresult, err := adap