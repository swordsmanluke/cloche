  549→\t\tconditions = append(conditions, domain.WireCondition{Step: stepTok.Literal, Result: resultTok.Literal})\n   550→\t\tif p.current.Type == TokenComma {\n   551→\t\t\tp.advance()\n   552→\t\t}\n   553→\t}\n   554→\n   555→\tif _, err := p.expect(TokenRParen); err != nil {\n   556→\t\treturn domain.Collect{}, err\n   557→\t}\n   558→\tif _, err := p.expect(TokenArrow); err != nil {\n   559→\t\treturn domain.Collect{}, err\n   560→\t}\n   561→\n   562→\ttoTok, err := p.expect(TokenIdent)\n   563→\tif err != nil {\n   564→\t\treturn domain.Collect{}, fmt.Errorf(\"expected target step: %w\", err)\n   565→\t}\n   566→\n   567→\treturn domain.Collect{\n   568→\t\tMode:       mode,\n   569→\t\tConditions: conditions,\n   570→\t\tTo:         toTok.Literal,\n   571→\t}, nil\n   572→}\n   573→"}]},"parent_tool_use_id":"toolu_01LGdRmY1ciiUsiZihXZ1qp4","session_id":"5096be8a-dfc2-4986-a448-2dc8a604d8e8","uuid":"8d19a78e-3e13-47fd-8a64-5300acfe9b03"}
