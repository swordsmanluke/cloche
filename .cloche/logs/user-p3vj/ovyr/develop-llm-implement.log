{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018v93AaNk48aaEwJ6QinEEj","type":"tool_result","content":"     1→package agent\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"io\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n    12→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    15→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    17→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    18→)\n    19→\n    20→type RunnerConfig struct {\n    21→\tWorkflowPath string\n    22→\tWorkDir      string\n    23→\tStatusOutput io.Writer\n    24→\tRunID        string\n    25→}\n    26→\n    27→type Runner struct {\n    28→\tcfg RunnerConfig\n    29→}\n    30→\n    31→func NewRunner(cfg RunnerConfig) *Runner {\n    32→\treturn &Runner{\n    33→\t\tcfg: cfg,\n    34→\t}\n    35→}\n    36→\n    37→func (r *Runner) Run(ctx context.Context) error {\n    38→\tdata, err := os.ReadFile(r.cfg.WorkflowPath)\n    39→\tif err != nil {\n    40→\t\treturn fmt.Errorf(\"reading workflow file: %w\", err)\n    41→\t}\n    42→\n    43→\twf, err := dsl.ParseForContainer(string(data))\n    44→\tif err != nil {\n    45→\t\treturn fmt.Errorf(\"parsing workflow: %w\", err)\n    46→\t}\n    47→\n    48→\tstatusWriter := protocol.NewStatusWriter(r.cfg.StatusOutput)\n    49→\tgenericAdapter := generic.New()\n    50→\tpromptAdapter := prompt.New()\n    51→\tpromptAdapter.RunID = r.cfg.RunID\n    52→\tpromptAdapter.StatusWriter = statusWriter\n    53→\tif cmd, ok := os.LookupEnv(\"CLOCHE_AGENT_COMMAND\"); ok {\n    54→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    55→\t}\n    56→\tif cmd := wf.Config[\"container.agent_command\"]; cmd != \"\" {\n    57→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    58→\t}\n    59→\tif args := wf.Config[\"container.agent_args\"]; args != \"\" {\n    60→\t\tpromptAdapter.ExplicitArgs = strings.Fields(args)\n    61→\t}\n    62→\n    63→\t// Reset per-run state from any previous run\n    64→\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"attempt_count\"))\n    65→\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"output\"))\n    66→\n    67→\t// Create unified log writer\n    68→\tulog, err := logstream.New(r.cfg.WorkDir)\n    69→\tif err != nil {\n    70→\t\treturn fmt.Errorf(\"creating unified log: %w\", err)\n    71→\t}\n    72→\tdefer ulog.Close()\n    73→\n    74→\tgenericAdapter.StatusWriter = statusWriter\n    75→\n    76→\texecutor := &stepExecutor{\n    77→\t\tworkDir:      r.cfg.WorkDir,\n    78→\t\tgeneric:      genericAdapter,\n    79→\t\tprompt:       promptAdapter,\n    80→\t\tlogStream:    ulog,\n    81→\t\tstatusWriter: statusWriter,\n    82→\t}\n    83→\n    84→\teng := engine.New(executor)\n    85→\teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n    86→\n    87→\t// Generate a run title from the prompt if one was not provided by the caller.\n    88→\t// The daemon sets title from --title; if empty, the agent extracts from prompt.\n    89→\tif title := extractTitle(r.cfg.WorkDir, r.cfg.RunID); title != \"\" {\n    90→\t\tstatusWriter.RunTitle(title)\n    91→\t}\n    92→\n    93→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n    94→\n    95→\trun, runErr := eng.Run(ctx, wf)\n    96→\tif runErr != nil {\n    97→\t\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:failed\")\n    98→\t\tulog.Log(logstream.TypeStatus, \"error: \"+runErr.Error())\n    99→\t\tulog.Log(logstream.TypeStatus, \"run_completed: failed\")\n   100→\t\tstatusWriter.Error(\"\", runErr.Error())\n   101→\t\tstatusWriter.RunCompleted(\"failed\")\n   102→\t\treturn runErr\n   103→\t}\n   104→\n   105→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:\"+string(run.State))\n   106→\n   107→\tulog.Log(logstream.TypeStatus, \"run_completed: \"+string(run.State))\n   108→\tstatusWriter.RunCompleted(string(run.State))\n   109→\treturn nil\n   110→}\n   111→\n   112→type stepExecutor struct {\n   113→\tworkDir      string\n   114→\tgeneric      *generic.Adapter\n   115→\tprompt       *prompt.Adapter\n   116→\tlogStream    *logstream.Writer\n   117→\tstatusWriter *protocol.StatusWriter\n   118→}\n   119→\n   120→func (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n   121→\tswitch step.Type {\n   122→\tcase domain.StepTypeScript:\n   123→\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   124→\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   125→\t\treturn result, err\n   126→\tcase domain.StepTypeAgent:\n   127→\t\tif _, ok := step.Config[\"run\"]; ok {\n   128→\t\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   129→\t\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   130→\t\t\treturn result, err\n   131→\t\t}\n   132→\t\tif _, ok := step.Config[\"prompt\"]; ok {\n   133→\t\t\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   134→\t\t\t\te.prompt.Commands = prompt.ParseCommands(cmd)\n   135→\t\t\t}\n   136→\t\t\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   137→\t\t\t\te.prompt.ExplicitArgs = strings.Fields(args)\n   138→\t\t\t}\n   139→\t\t\tresult, err := e.prompt.Execute(ctx, step, e.workDir)\n   140→\t\t\te.copyToLLMLog(step.Name)\n   141→\t\t\te.logStepOutput(step.Name, logstream.TypeLLM)\n   142→\t\t\treturn result, err\n   143→\t\t}\n   144→\t\treturn \"\", fmt.Errorf(\"agent step %q requires either 'run' or 'prompt' config\", step.Name)\n   145→\tdefault:\n   146→\t\treturn \"\", fmt.Errorf(\"unknown step type: %s\", step.Type)\n   147→\t}\n   148→}\n   149→\n   150→// logStepOutput reads the per-step log file and writes its contents to the unified log.\n   151→func (e *stepExecutor) logStepOutput(stepName string, typ logstream.EntryType) {\n   152→\tpath := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   153→\tdata, err := os.ReadFile(path)\n   154→\tif err != nil || len(data) == 0 {\n   155→\t\treturn\n   156→\t}\n   157→\te.logStream.Log(typ, string(data))\n   158→}\n   159→\n   160→// copyToLLMLog copies <step>.log to llm-<step>.log for agent prompt steps.\n   161→func (e *stepExecutor) copyToLLMLog(stepName string) {\n   162→\tsrc := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   163→\tdst := filepath.Join(e.workDir, \".cloche\", \"output\", \"llm-\"+stepName+\".log\")\n   164→\tdata, err := os.ReadFile(src)\n   165→\tif err != nil {\n   166→\t\treturn\n   167→\t}\n   168→\t_ = os.WriteFile(dst, data, 0644)\n   169→}\n   170→\n   171→type statusReporter struct {\n   172→\twriter    *protocol.StatusWriter\n   173→\tlogStream *logstream.Writer\n   174→}\n   175→\n   176→func (s *statusReporter) OnStepStart(_ *domain.Run, step *domain.Step) {\n   177→\ts.writer.StepStarted(step.Name)\n   178→\ts.logStream.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n   179→}\n   180→\n   181→func (s *statusReporter) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   182→\ts.writer.StepCompleted(step.Name, result)\n   183→\ts.logStream.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n   184→}\n   185→\n   186→func (s *statusReporter) OnRunComplete(_ *domain.Run) {}\n   187→\n   188→// extractTitle tries to derive a one-line summary from the run's prompt content.\n   189→// It reads the per-run prompt.txt file (written by the daemon before container start),\n   190→// then returns the first non-empty line, truncated to 100 characters.\n   191→func extractTitle(workDir string, runID string) string {\n   192→\t// Try the per-run prompt file\n   193→\tpromptPath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   194→\tif _, err := os.Stat(promptPath); err != nil {\n   195→\t\t// Fall back to legacy path\n   196→\t\tpromptPath = filepath.Join(workDir, \".cloche\", \"prompt.txt\")\n   197→\t}\n   198→\tdata, err := os.ReadFile(promptPath)\n   199→\tif err != nil || len(data) == 0 {\n   200→\t\treturn \"\"\n   201→\t}\n   202→\n   203→\ttext := strings.TrimSpace(string(data))\n   204→\tif text == \"\" {\n   205→\t\treturn \"\"\n   206→\t}\n   207→\n   208→\t// Take first non-empty line as the title\n   209→\tfor _, line := range strings.Split(text, \"\\n\") {\n   210→\t\tline = strings.TrimSpace(line)\n   211→\t\t// Skip markdown headers, comment markers, and blank lines\n   212→\t\tif line == \"\" || line == \"---\" || line == \"```\" {\n   213→\t\t\tcontinue\n   214→\t\t}\n   215→\t\t// Strip leading markdown header markers\n   216→\t\tline = strings.TrimLeft(line, \"# \")\n   217→\t\tline = strings.TrimSpace(line)\n   218→\t\tif line == \"\" {\n   219→\t\t\tcontinue\n   220→\t\t}\n   221→\t\tif len(line) > 100 {\n   222→\t\t\tline = line[:97] + \"...\"\n   223→\t\t}\n   224→\t\treturn line\n   225→\t}\n   226→\treturn \"\"\n   227→}\n   228→"}]},"parent_tool_use_id":"toolu_01LGdRmY1ciiUsiZihXZ1qp4","session_id":"5096be8a-dfc2-4986-a448-2dc8a604d8e8","uuid":"f223f6b1-94ee-453b-bf7b-0f7961dcd3ca"}
