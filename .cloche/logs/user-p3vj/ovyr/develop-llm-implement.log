PassesProjectDirEnvVar` verify env var propagation\n- **`context_test.go`** — `TestCmdSet_StdinValue` verifies stdin reading with `-`\n\nCLOCHE_RESULT:success"}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":584,"cache_read_input_tokens":110422,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":584},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5096be8a-dfc2-4986-a448-2dc8a604d8e8","uuid":"bf3ad6bc-ca80-497c-be21-5e14473b91be"}
