{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WV1pkH3XLKWLf47T9RWPS9","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# Returns ready, unclaimed tasks from bd as a JSON array.\n     3→# Usage: ready-tasks.sh [max]\n     4→#   max  — maximum number of IDs to return (default: all)\n     5→set -euo pipefail\n     6→\n     7→max=\"${1:-0}\"\n     8→\n     9→limit_args=()\n    10→if [ \"$max\" -gt 0 ] 2>/dev/null; then\n    11→  limit_args=(--limit \"$max\")\n    12→fi\n    13→\n    14→# Filter to open status only — excludes in_progress (already claimed) tasks.\n    15→json=$(bd list -s open --json \"${limit_args[@]}\" 2>/dev/null) || json=\"[]\"\n    16→\n    17→# Empty array means no work — exit non-zero so the workflow takes the fail path\n    18→# instead of trying to resolve output[0] mappings on an empty list.\n    19→if [ \"$json\" = \"[]\" ] || [ -z \"$json\" ]; then\n    20→  echo \"[]\"\n    21→  exit 1\n    22→fi\n    23→\n    24→echo \"$json\"\n    25→"}]},"parent_tool_use_id":null,"session_id":"5096be8a-dfc2-4986-a448-2dc8a604d8e8","uuid":"2056ac16-4271-4dae-8f7a-82ee26561374","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.cloche/scripts/ready-tasks.sh","content":"#!/usr/bin/env bash\n# Returns ready, unclaimed tasks from bd as a JSON array.\n# Usage: ready-tasks.sh [max]\n#   max  — maximum number of IDs to return (default: all)\nset -euo pipefail\n\nmax=\"${1:-0}\"\n\nlimit_args=()\nif [ \"$max\" -gt 0 ] 2>/dev/null; then\n  limit_args=(--limit \"$max\")\nfi\n\n# Filter to open status only — excludes in_progress (already claimed) tasks.\njson=$(bd list -s open --json \"${limit_args[@]}\" 2>/dev/null) || json=\"[]\"\n\n# Empty array means no work — exit non-zero so the workflow takes the fail path\n# instead of trying to resolve output[0] mappings on an empty list.\nif [ \"$json\" = \"[]\" ] || [ -z \"$json\" ]; then\n  echo \"[]\"\n  exit 1\nfi\n\necho \"$json\"\n","numLines":25,"startLine":1,"totalLines":25}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H7nAYqxsxyGCuA38o2YRXg","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# claim-task.sh — Claim a bead task by setting it to in_progress.\n     3→# Expects CLOCHE_TASK_ID env var from the previous step's output mapping.\n     4→set -euo pipefail\n     5→\n     6→if [ -z \"${CLOCHE_TASK_ID:-}\" ]; then\n     7→  echo \"error: CLOCHE_TASK_ID not set\" >&2\n     8→  exit 1\n     9→fi\n    10→\n    11→# Capture bd output separately so it doesn't corrupt our JSON stdout.\n    12→claim_output=$(bd update \"$CLOCHE_TASK_ID\" --claim 2>&1) || true\n    13→\n    14→# bd exits 0 even on failure, so check for error in output.\n    15→if echo \"$claim_output\" | grep -qi \"error\\|already claimed\"; then\n    16→  echo \"claim failed: $claim_output\" >&2\n    17→  exit 1\n    18→fi\n    19→\n    20→# Forward task info as properly escaped JSON so downstream steps can parse it.\n    21→jq -n --arg id \"${CLOCHE_TASK_ID}\" \\\n    22→      --arg title \"${CLOCHE_TASK_TITLE:-}\" \\\n    23→      --arg desc \"${CLOCHE_TASK_BODY:-}\" \\\n    24→      '[{id: $id, title: $title, description: $desc}]'\n    25→"}]},"parent_tool_use_id":null,"session_id":"5096be8a-dfc2-4986-a448-2dc8a604d8e8","uuid":"93ae2b9b-7da4-48de-a27a-17eb68194a19","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.cloche/scripts/claim-task.sh","content":"#!/usr/bin/env bash\n# claim-task.sh — Claim a bead task by setting it to in_progress.\n# Expects CLOCHE_TASK_ID env var from the previous step's output mapping.\nset -euo pipefail\n\nif [ -z \"${CLOCHE_TASK_ID:-}\" ]; then\n  echo \"error: CLOCHE_TASK_ID not set\" >&2\n  exit 1\nfi\n\n# Capture bd output separately so it doesn't corrupt our JSON stdout.\nclaim_output=$(bd update \"$CLOCHE_TASK_ID\" --claim 2>&1) || true\n\n# bd exits 0 even on failure, so check for error in output.\nif echo \"$claim_output\" | grep -qi \"error\\|already claimed\"; then\n  echo \"claim failed: $claim_output\" >&2\n  exit 1\nfi\n\n# Forward task info as properly escaped JSON so downstream steps can parse it.\njq -n --arg id \"${CLOCHE_TASK_ID}\" \\\n      --arg title \"${CLOCHE_TASK_TITLE:-}\" \\\n      --arg desc \"${CLOCHE_TASK_BODY:-}\" \\\n      '[{id: $id, title: $title, description: $desc}]'\n","numLines":25,"startLine":1,"totalLines":25}}}
