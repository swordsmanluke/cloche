{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017ksHWBNSVdvTzCFA74oU3m","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# cleanup-run.sh — Remove the worktree and branch left over from a cloche run.\n     3→# Expects CLOCHE_PREV_OUTPUT to point to a file containing the run ID.\n     4→set -euo pipefail\n     5→\n     6→if [ -z \"${CLOCHE_PREV_OUTPUT:-}\" ] || [ ! -f \"$CLOCHE_PREV_OUTPUT\" ]; then\n     7→  echo \"error: CLOCHE_PREV_OUTPUT not set or file missing\" >&2\n     8→  exit 1\n     9→fi\n    10→\n    11→RUN_ID=$(cat \"$CLOCHE_PREV_OUTPUT\" | tr -d '[:space:]')\n    12→PROJECT_DIR=\"${CLOCHE_PROJECT_DIR:-.}\"\n    13→\n    14→# Try to find the task ID from the ready-tasks output in our run's output directory\n    15→if [ -z \"${CLOCHE_TASK_ID:-}\" ]; then\n    16→  OUTPUT_DIR=\"$(dirname \"$CLOCHE_PREV_OUTPUT\")\"\n    17→  READY_OUT=\"$OUTPUT_DIR/ready-tasks.out\"\n    18→  if [ -f \"$READY_OUT\" ]; then\n    19→    CLOCHE_TASK_ID=$(jq -r '.[0].id // empty' \"$READY_OUT\" 2>/dev/null) || true\n    20→  fi\n    21→fi\n    22→BRANCH=\"cloche/${RUN_ID}\"\n    23→WORKTREE_DIR=\"$PROJECT_DIR/.gitworktrees/cloche/$RUN_ID\"\n    24→\n    25→# Remove the extraction worktree if it still exists\n    26→if [ -d \"$WORKTREE_DIR\" ]; then\n    27→  git -C \"$PROJECT_DIR\" worktree remove --force \"$WORKTREE_DIR\" 2>/dev/null || true\n    28→fi\n    29→\n    30→# Prune any stale worktree bookkeeping\n    31→git -C \"$PROJECT_DIR\" worktree prune 2>/dev/null || true\n    32→\n    33→# Delete the branch if it still exists (merge may have already removed it)\n    34→if git -C \"$PROJECT_DIR\" rev-parse --verify \"$BRANCH\" >/dev/null 2>&1; then\n    35→  git -C \"$PROJECT_DIR\" branch -D \"$BRANCH\" 2>/dev/null || true\n    36→fi\n    37→\n    38→# Close the task if CLOCHE_TASK_ID is set\n    39→if [ -n \"${CLOCHE_TASK_ID:-}\" ]; then\n    40→  bd close \"$CLOCHE_TASK_ID\" 2>/dev/null && echo \"Closed task $CLOCHE_TASK_ID\" || echo \"warning: could not close task $CLOCHE_TASK_ID\" >&2\n    41→fi\n    42→\n    43→echo \"Cleaned up run $RUN_ID\"\n    44→"}]},"parent_tool_use_id":null,"session_id":"5096be8a-dfc2-4986-a448-2dc8a604d8e8","uuid":"7ed579f0-b337-4faf-9832-fee5197a1fae","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.cloche/scripts/cleanup-run.sh","content":"#!/usr/bin/env bash\n# cleanup-run.sh — Remove the worktree and branch left over from a cloche run.\n# Expects CLOCHE_PREV_OUTPUT to point to a file containing the run ID.\nset -euo pipefail\n\nif [ -z \"${CLOCHE_PREV_OUTPUT:-}\" ] || [ ! -f \"$CLOCHE_PREV_OUTPUT\" ]; then\n  echo \"error: CLOCHE_PREV_OUTPUT not set or file missing\" >&2\n  exit 1\nfi\n\nRUN_ID=$(cat \"$CLOCHE_PREV_OUTPUT\" | tr -d '[:space:]')\nPROJECT_DIR=\"${CLOCHE_PROJECT_DIR:-.}\"\n\n# Try to find the task ID from the ready-tasks output in our run's output directory\nif [ -z \"${CLOCHE_TASK_ID:-}\" ]; then\n  OUTPUT_DIR=\"$(dirname \"$CLOCHE_PREV_OUTPUT\")\"\n  READY_OUT=\"$OUTPUT_DIR/ready-tasks.out\"\n  if [ -f \"$READY_OUT\" ]; then\n    CLOCHE_TASK_ID=$(jq -r '.[0].id // empty' \"$READY_OUT\" 2>/dev/null) || true\n  fi\nfi\nBRANCH=\"cloche/${RUN_ID}\"\nWORKTREE_DIR=\"$PROJECT_DIR/.gitworktrees/cloche/$RUN_ID\"\n\n# Remove the extraction worktree if it still exists\nif [ -d \"$WORKTREE_DIR\" ]; then\n  git -C \"$PROJECT_DIR\" worktree remove --force \"$WORKTREE_DIR\" 2>/dev/null || true\nfi\n\n# Prune any stale worktree bookkeeping\ngit -C \"$PROJECT_DIR\" worktree prune 2>/dev/null || true\n\n# Delete the branch if it still exists (merge may have already removed it)\nif git -C \"$PROJECT_DIR\" rev-parse --verify \"$BRANCH\" >/dev/null 2>&1; then\n  git -C \"$PROJECT_DIR\" branch -D \"$BRANCH\" 2>/dev/null || true\nfi\n\n# Close the task if CLOCHE_TASK_ID is set\nif [ -n \"${CLOCHE_TASK_ID:-}\" ]; then\n  bd close \"$CLOCHE_TASK_ID\" 2>/dev/null && echo \"Closed task $CLOCHE_TASK_ID\" || echo \"warning: could not close task $CLOCHE_TASK_ID\" >&2\nfi\n\necho \"Cleaned up run $RUN_ID\"\n","numLines":44,"startLine":1,"totalLines":44}}}
