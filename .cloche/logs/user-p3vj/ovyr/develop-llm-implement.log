{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RUQERbzfEo88h7JXJPkkTA","type":"tool_result","content":"     1→package generic_test\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"context\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"testing\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n    11→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    12→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    13→\t\"github.com/stretchr/testify/assert\"\n    14→\t\"github.com/stretchr/testify/require\"\n    15→)\n    16→\n    17→func TestGenericAdapter_ScriptSuccess(t *testing.T) {\n    18→\tadapter := generic.New()\n    19→\tstep := &domain.Step{\n    20→\t\tName:    \"build\",\n    21→\t\tType:    domain.StepTypeScript,\n    22→\t\tResults: []string{\"success\", \"fail\"},\n    23→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n    24→\t}\n    25→\n    26→\tresult, err := adapter.Execute(context.Background(), step, t.TempDir())\n    27→\trequire.NoError(t, err)\n    28→\tassert.Equal(t, \"success\", result)\n    29→}\n    30→\n    31→func TestGenericAdapter_ScriptFailure(t *testing.T) {\n    32→\tadapter := generic.New()\n    33→\tstep := &domain.Step{\n    34→\t\tName:    \"build\",\n    35→\t\tType:    domain.StepTypeScript,\n    36→\t\tResults: []string{\"success\", \"fail\"},\n    37→\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n    38→\t}\n    39→\n    40→\tresult, err := adapter.Execute(context.Background(), step, t.TempDir())\n    41→\trequire.NoError(t, err)\n    42→\tassert.Equal(t, \"fail\", result)\n    43→}\n    44→\n    45→func TestGenericAdapter_ScriptModifiesFiles(t *testing.T) {\n    46→\tdir := t.TempDir()\n    47→\tadapter := generic.New()\n    48→\tstep := &domain.Step{\n    49→\t\tName:    \"generate\",\n    50→\t\tType:    domain.StepTypeScript,\n    51→\t\tResults: []string{\"success\", \"fail\"},\n    52→\t\tConfig:  map[string]string{\"run\": \"echo 'generated' > output.txt\"},\n    53→\t}\n    54→\n    55→\tresult, err := adapter.Execute(context.Background(), step, dir)\n    56→\trequire.NoError(t, err)\n    57→\tassert.Equal(t, \"success\", result)\n    58→\n    59→\tcontent, err := os.ReadFile(filepath.Join(dir, \"output.txt\"))\n    60→\trequire.NoError(t, err)\n    61→\tassert.Contains(t, string(content), \"generated\")\n    62→}\n    63→\n    64→func TestGenericAdapter_CapturesOutput(t *testing.T) {\n    65→\tdir := t.TempDir()\n    66→\tadapter := generic.New()\n    67→\tstep := &domain.Step{\n    68→\t\tName:    \"test\",\n    69→\t\tType:    domain.StepTypeScript,\n    70→\t\tResults: []string{\"success\", \"fail\"},\n    71→\t\tConfig:  map[string]string{\"run\": \"echo 'hello from test'; echo 'error msg' >&2\"},\n    72→\t}\n    73→\n    74→\tresult, err := adapter.Execute(context.Background(), step, dir)\n    75→\trequire.NoError(t, err)\n    76→\tassert.Equal(t, \"success\", result)\n    77→\n    78→\tlogPath := filepath.Join(dir, \".cloche\", \"output\", \"test.log\")\n    79→\tcontent, err := os.ReadFile(logPath)\n    80→\trequire.NoError(t, err)\n    81→\tassert.Contains(t, string(content), \"hello from test\")\n    82→\tassert.Contains(t, string(content), \"error msg\")\n    83→}\n    84→\n    85→func TestGenericAdapter_CapturesOutputOnFailure(t *testing.T) {\n    86→\tdir := t.TempDir()\n    87→\tadapter := generic.New()\n    88→\tstep := &domain.Step{\n    89→\t\tName:    \"lint\",\n    90→\t\tType:    domain.StepTypeScript,\n    91→\t\tResults: []string{\"success\", \"fail\"},\n    92→\t\tConfig:  map[string]string{\"run\": \"echo 'lint error: bad style'; exit 1\"},\n    93→\t}\n    94→\n    95→\tresult, err := adapter.Execute(context.Background(), step, dir)\n    96→\trequire.NoError(t, err)\n    97→\tassert.Equal(t, \"fail\", result)\n    98→\n    99→\tlogPath := filepath.Join(dir, \".cloche\", \"output\", \"lint.log\")\n   100→\tcontent, err := os.ReadFile(logPath)\n   101