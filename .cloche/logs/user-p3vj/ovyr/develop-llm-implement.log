{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019p48bNxKaLw5eP4fDRcKri","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# Default prompt generator.\n     3→# Writes the task prompt to stdout and to $CLOCHE_STEP_OUTPUT.\n     4→# Expects CLOCHE_TASK_TITLE and CLOCHE_TASK_BODY from wire output mappings.\n     5→set -euo pipefail\n     6→\n     7→task_title=\"${CLOCHE_TASK_TITLE:-}\"\n     8→task_body=\"${CLOCHE_TASK_BODY:-}\"\n     9→\n    10→if [ -z \"$task_title\" ]; then\n    11→  echo \"error: CLOCHE_TASK_TITLE is not set\" >&2\n    12→  exit 1\n    13→fi\n    14→\n    15→prompt=\"## Task: ${task_title}\n    16→\n    17→${task_body}\"\n    18→\n    19→echo \"$prompt\"\n    20→[ -n \"${CLOCHE_STEP_OUTPUT:-}\" ] && echo \"$prompt\" > \"$CLOCHE_STEP_OUTPUT\"\n    21→"}]},"parent_tool_use_id":null,"session_id":"5096be8a-dfc2-4986-a448-2dc8a604d8e8","uuid":"f6e5120f-04e2-4b32-b54f-d0c400c6fb87","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.cloche/scripts/prepare-prompt.sh","content":"#!/usr/bin/env bash\n# Default prompt generator.\n# Writes the task prompt to stdout and to $CLOCHE_STEP_OUTPUT.\n# Expects CLOCHE_TASK_TITLE and CLOCHE_TASK_BODY from wire output mappings.\nset -euo pipefail\n\ntask_title=\"${CLOCHE_TASK_TITLE:-}\"\ntask_body=\"${CLOCHE_TASK_BODY:-}\"\n\nif [ -z \"$task_title\" ]; then\n  echo \"error: CLOCHE_TASK_TITLE is not set\" >&2\n  exit 1\nfi\n\nprompt=\"## Task: ${task_title}\n\n${task_body}\"\n\necho \"$prompt\"\n[ -n \"${CLOCHE_STEP_OUTPUT:-}\" ] && echo \"$prompt\" > \"$CLOCHE_STEP_OUTPUT\"\n","numLines":21,"startLine":1,"totalLines":21}}}
