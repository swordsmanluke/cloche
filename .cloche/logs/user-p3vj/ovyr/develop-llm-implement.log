{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kg7HhqG2cJ3AhuZ1hNCbk6","type":"tool_result","content":"     1→// Package runcontext provides a shared key-value store (context.json) for\n     2→// passing metadata between workflow steps within a single run.\n     3→package runcontext\n     4→\n     5→import (\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"os\"\n     9→\t\"path/filepath\"\n    10→\t\"sync\"\n    11→)\n    12→\n    13→// ContextPath returns the path to context.json for a given project and run ID.\n    14→func ContextPath(projectDir, runID string) string {\n    15→\treturn filepath.Join(projectDir, \".cloche\", runID, \"context.json\")\n    16→}\n    17→\n    18→// mu serialises concurrent reads/writes within the same process.\n    19→var mu sync.Mutex\n    20→\n    21→// Get retrieves a value from the run's context store.\n    22→// Returns (\"\", false, nil) if the key does not exist.\n    23→func Get(projectDir, runID, key string) (string, bool, error) {\n    24→\tmu.Lock()\n    25→\tdefer mu.Unlock()\n    26→\n    27→\tm, err := load(ContextPath(projectDir, runID))\n    28→\tif err != nil {\n    29→\t\treturn \"\", false, err\n    30→\t}\n    31→\tv, ok := m[key]\n    32→\treturn v, ok, nil\n    33→}\n    34→\n    35→// Set writes a key-value pair to the run's context store, creating the file\n    36→// and parent directories if necessary.\n    37→func Set(projectDir, runID, key, value string) error {\n    38→\tmu.Lock()\n    39→\tdefer mu.Unlock()\n    40→\n    41→\tpath := ContextPath(projectDir, runID)\n    42→\n    43→\tif err := os.MkdirAll(filepath.Dir(path), 0755); err != nil {\n    44→\t\treturn fmt.Errorf(\"creating context directory: %w\", err)\n    45→\t}\n    46→\n    47→\tm, err := load(path)\n    48→\tif err != nil {\n    49→\t\treturn err\n    50→\t}\n    51→\tm[key] = value\n    52→\treturn save(path, m)\n    53→}\n    54→\n    55→// load reads the context map from disk. Returns an empty map if the file does\n    56→// not exist.\n    57→func load(path string) (map[string]string, error) {\n    58→\tdata, err := os.ReadFile(path)\n    59→\tif err != nil {\n    60→\t\tif os.IsNotExist(err) {\n    61→\t\t\treturn make(map[string]string), nil\n    62→\t\t}\n    63→\t\treturn nil, fmt.Errorf(\"reading context file: %w\", err)\n    64→\t}\n    65→\tvar m map[string]string\n    66→\tif err := json.Unmarshal(data, &m); err != nil {\n    67→\t\treturn nil, fmt.Errorf(\"parsing context file: %w\", err)\n    68→\t}\n    69→\treturn m, nil\n    70→}\n    71→\n    72→// save writes the context map to disk as indented JSON.\n    73→func save(path string, m map[string]string) error {\n    74→\tdata, err := json.MarshalIndent(m, \"\", \"  \")\n    75→\tif err != nil {\n    76→\t\treturn fmt.Errorf(\"encoding context: %w\", err)\n    77→\t}\n    78→\tdata = append(data, '\\n')\n    79→\tif err := os.WriteFile(path, data, 0644); err != nil {\n    80→\t\treturn fmt.Errorf(\"writing context file: %w\", err)\n    81→\t}\n    82→\treturn nil\n    83→}\n    84→"}]},"parent_tool_use_id":"toolu_01LGdRmY1ciiUsiZihXZ1qp4","session_id":"5096be8a-dfc2-4986-a448-2dc8a604d8e8","uuid":"e1389e8c-ebd7-4cf4-919c-8e2f464f61ee"}
