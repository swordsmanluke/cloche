{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AXvkawEWJm993FwYzhsFsA","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"sync\"\n     9→\t\"testing\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    12→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    13→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14→\t\"github.com/stretchr/testify/assert\"\n    15→\t\"github.com/stretchr/testify/require\"\n    16→)\n    17→\n    18→// errLLM returns a fixed error for testing error paths.\n    19→type errLLM struct {\n    20→\terr error\n    21→}\n    22→\n    23→func (e *errLLM) Complete(ctx context.Context, system, user string) (string, error) {\n    24→\treturn \"\", e.err\n    25→}\n    26→\n    27→// callTrackingLLM records calls and returns fixed responses in order.\n    28→type callTrackingLLM struct {\n    29→\tmu        sync.Mutex\n    30→\tresponses []string\n    31→\tidx       int\n    32→\tcalls     []llmCall\n    33→}\n    34→\n    35→type llmCall struct {\n    36→\tsystem string\n    37→\tuser   string\n    38→}\n    39→\n    40→func (c *callTrackingLLM) Complete(ctx context.Context, system, user string) (string, error) {\n    41→\tc.mu.Lock()\n    42→\tdefer c.mu.Unlock()\n    43→\tc.calls = append(c.calls, llmCall{system: system, user: user})\n    44→\tif c.idx >= len(c.responses) {\n    45→\t\treturn \"\", fmt.Errorf(\"no more responses\")\n    46→\t}\n    47→\tresp := c.responses[c.idx]\n    48→\tc.idx++\n    49→\treturn resp, nil\n    50→}\n    51→\n    52→// --- Mock stores ---\n    53→\n    54→type mockEvolutionStore struct {\n    55→\tlastEvolution *ports.EvolutionEntry\n    56→\truns          []*domain.Run\n    57→\tsaved         []*ports.EvolutionEntry\n    58→\tlistCalls     []listRunsSinceCall\n    59→}\n    60→\n    61→type listRunsSinceCall struct {\n    62→\tprojectDir   string\n    63→\tworkflowName string\n    64→\tsinceRunID   string\n    65→}\n    66→\n    67→func (m *mockEvolutionStore) SaveEvolution(ctx context.Context, entry *ports.EvolutionEntry) error {\n    68→\tm.saved = append(m.saved, entry)\n    69→\treturn nil\n    70→}\n    71→\n    72→func (m *mockEvolutionStore) GetLastEvolution(ctx context.Context, projectDir, workflowName string) (*ports.EvolutionEntry, error) {\n    73→\tif m.lastEvolution != nil {\n    74→\t\treturn m.lastEvolution, nil\n    75→\t}\n    76→\treturn nil, nil\n    77→}\n    78→\n    79→func (m *mockEvolutionStore) ListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error) {\n    80→\tm.listCalls = append(m.listCalls, listRunsSinceCall{projectDir, workflowName, sinceRunID})\n    81→\treturn m.runs, nil\n    82→}\n    83→\n    84→type mockCaptureStore struct {\n    85→\tcaptures map[string][]*domain.StepExecution\n    86→}\n    87→\n    88→func (m *mockCaptureStore) SaveCapture(ctx context.Context, runID string, exec *domain.StepExecution) error {\n    89→\treturn nil\n    90→}\n    91→\n    92→func (m *mockCaptureStore) GetCaptures(ctx context.Context, runID string) ([]*domain.StepExecution, error) {\n    93→\tif m.captures != nil {\n    94→\t\treturn m.captures[runID], nil\n    95→\t}\n    96→\treturn nil, nil\n    97→}\n    98→\n    99→// ===========================================================================\n   100→// Curator corruption scenarios\n   101→// ===========================================================================\n   102→\n   103→func setupCuratorDir(t *testing.T, promptContent string) (string, string) {\n   104→\tt.Helper()\n   105→\tdir := t.TempDir()\n   106→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   107→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   108→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   109→\tos.WriteFile(promptPath, []byte(promptContent), 0644)\n   110→\treturn dir, promptPath\n   111→}\n   112→\n   113→func TestCuratorCorruption_ConversationalMetaTextNoFences(t *testing.T) {\n   114→\t// LLM returns conversational meta-text without code fences.\n   115→\t// \"Sure!\" doesn't match the conversational markers regex, so it passes\n   116→\t// through stripCodeFences and isConversationalResponse unchanged.\n   117→\t// The post-write sanity check catches it (no '#' heading) and rolls back.\n   118→\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n   119→\tdir, promptPath := setupCuratorDir(t, original)\n   120→\n   121→\tconversationalResponse := \"Sure! I've updated the prompt to include a sanitization rule. The prompt now instructs the agent to always sanitize user inputs before processing them.\"\n   122→\tllm := &fakeLLM{response: conversationalResponse}\n   123→\n   124→\taudit := &AuditLogger{ProjectDir: dir}\n   125→\tc := &Curator{LLM: llm, Audit: audit}\n   126→\tlesson := &Lesson{\n   127→\t\tTarget:          \".cloche/prompts/implement.md\",\n   128→\t\tInsight:         \"XSS in form handlers\",\n   129→\t\tSuggestedAction: \"Add sanitization rule\",\n   130→\t}\n   131→\n   132→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   133→\trequire.NoError(t, err)\n   134→\tassert.Equal(t, \"prompt_update_rollback\", change.Type)\n   135→\tassert.Contains(t, change.Reason, \"rolled back\")\n   136→\n   137→\t// Original content is preserved via rollback.\n   138→\tcontent, err := os.ReadFile(promptPath)\n   139→\trequire.NoError(t, err)\n   140→\tassert.Equal(t, original, string(content))\n   141→}\n   142→\n   143→func TestCuratorCorruption_ResponseShorterThanOriginal(t *testing.T) {\n   144→\t// LLM returns a response that is shorter than the original prompt,\n   145→\t// representing total content loss. The sanity check catches this\n   146→\t// (no '#' heading) and rolls back to the snapshot.\n   147→\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Guidelines\\n\\n- Follow best practices\\n- Use proper error handling\\n- Write tests\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n- Never trust user data\\n\"\n   148→\tdir, promptPath := setupCuratorDir(t, original)\n   149→\n   150→\t// Extremely short response — no heading, fails sanity check.\n   151→\tshortResponse := \"Write good code.\"\n   152→\tllm := &fakeLLM{response: shortResponse}\n   153→\n   154→\taudit := &AuditLogger{ProjectDir: dir}\n   155→\tc := &Curator{LLM: llm, Audit: audit}\n   156→\tlesson := &Lesson{\n   157→\t\tTarget:          \".cloche/prompts/implement.md\",\n   158→\t\tInsight:         \"Missing error handling\",\n   159→\t\tSuggestedAction: \"Add error handling rule\",\n   160→\t}\n   161→\n   162→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   163→\trequire.NoError(t, err)\n   164→\tassert.Equal(t, \"prompt_update_rollback\", change.Type)\n   165→\tassert.NotEmpty(t, change.Snapshot)\n   166→\tassert.Contains(t, change.Reason, \"rolled back\")\n   167→\n   168→\t// Original content is preserved via rollback.\n   169→\tcontent, err := os.ReadFile(promptPath)\n   170→\trequire.NoError(t, err)\n   171→\tassert.Equal(t, original, string(content))\n   172→\tassert.Contains(t, string(content), \"## Guidelines\")\n   173→\tassert.Contains(t, string(content), \"## Learned Rules\")\n   174→}\n   175→\n   176→func TestCuratorCorruption_EmptyResponse(t *testing.T) {\n   177→\t// LLM returns an empty string. isConversationalResponse returns true\n   178→\t// for empty strings, so the fallback appends the lesson directly,\n   179→\t// preserving the original content.\n   180→\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n   181→\tdir, promptPath := setupCuratorDir(t, original)\n   182→\n   183→\tllm := &fakeLLM{response: \"\"}\n   184→\n   185→\taudit := &AuditLogger{ProjectDir: dir}\n   186→\tc := &Curator{LLM: llm, Audit: audit}\n   187→\tlesson := &Lesson{\n   188→\t\tTarget:          \".cloche/prompts/implement.md\",\n   189→\t\tInsight:         \"Test insight\",\n   190→\t\tSuggestedAction: \"Test action\",\n   191→\t}\n   192→\n   193→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   194→\trequire.NoError(t, err)\n   195→\tassert.Equal(t, \"prompt_update\", change.Type)\n   196→\n   197→\t// The conversational guard catches the empty string and falls back\n   198→\t// to appendLessonDirectly, preserving original content.\n   199→\tcontent, err := os.ReadFile(promptPath)\n   200→\trequire.NoError(t, err)\n   201→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   202→\tassert.Contains(t, string(content), \"Test insight\")\n   203→}\n   204→\n   205→func TestCuratorCorruption_EmptyCodeFences(t *testing.T) {\n   206→\t// LLM returns only code fences with no content between them.\n   207→\t// After stripping fences, content is empty → isConversationalResponse\n   208→\t// returns true → fallback appends lesson directly → sanity check passes.\n   209→\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n   210→\tdir, promptPath := setupCuratorDir(t, original)\n   211→\n   212→\tllm := &fakeLLM{response: \"```markdown\\n```\"}\n   213→\n   214→\taudit := &AuditLogger{ProjectDir: dir}\n   215→\tc := &Curator{LLM: llm, Audit: audit}\n   216→\tlesson := &Lesson{\n   217→\t\tTarget:          \".cloche/prompts/implement.md\",\n   218→\t\tInsight:         \"Test insight\",\n   219→\t\tSuggestedAction: \"Test action\",\n   220→\t}\n   221→\n   222→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   223→\trequire.NoError(t, err)\n   224→\tassert.Equal(t, \"prompt_update\", change.Type)\n   225→\n   226→\t// Fallback preserves original content and appends lesson.\n   227→\tcontent, err := os.ReadFile(promptPath)\n   228→\trequire.NoError(t, err)\n   229→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   230→\tassert.Contains(t, string(content), \"Test insight\")\n   231→}\n   232→\n   233→func TestCuratorCorruption_RaceConcurrentApply(t *testing.T) {\n   234→\t// Multiple rapid Curator.Apply() calls on the same file.\n   235→\toriginal := \"# Prompt\\n\\nOriginal content.\\n\"\n   236→\tdir, promptPath := setupCuratorDir(t, original)\n   237→\n   238→\taudit := &AuditLogger{ProjectDir: dir}\n   239→\n   240→\tconst goroutines = 10\n   241→\tvar wg sync.WaitGroup\n   242→\twg.Add(goroutines)\n   243→\n   244→\terrors := make([]error, goroutines)\n   245→\n   246→\tfor i := 0; i < goroutines; i++ {\n   247→\t\tgo func(idx int) {\n   248→\t\t\tdefer wg.Done()\n   249→\t\t\tllm := &fakeLLM{\n   250→\t\t\t\tresponse: fmt.Sprintf(\"# Prompt\\n\\nUpdated by goroutine %d.\\n\", idx),\n   251→\t\t\t}\n   252→\t\t\tc := &Curator{LLM: llm, Audit: audit}\n   253→\t\t\tlesson := &Lesson{\n   254→\t\t\t\tID:              fmt.Sprintf(\"lesson-%d\", idx),\n   255→\t\t\t\tTarget:          \".cloche/prompts/implement.md\",\n   256→\t\t\t\tInsight:         fmt.Sprintf(\"Insight %d\", idx),\n   257→\t\t\t\tSuggestedAction: fmt.Sprintf(\"Action %d\", idx),\n   258→\t\t\t}\n   259→\t\t\t_, errors[idx] = c.Apply(context.Background(), dir, lesson)\n   260→\t\t}(i)\n   261→\t}\n   262→\n   263→\twg.Wait()\n   264→\n   265→\t// All calls should succeed (no panics or crashes).\n   266→\tfor i, err := range errors {\n   267→\t\tassert.NoError(t, err, \"goroutine %d failed\", i)\n   268→\t}\n   269→\n   270→\t// The file should contain valid content from one of the goroutines.\n   271→\tcontent, err := os.ReadFile(promptPath)\n   272→\trequire.NoError(t, err)\n   273→\tassert.Contains(t, string(content), \"# Prompt\")\n   274→\tassert.Contains(t, string(content), \"Updated by goroutine\")\n   275→}\n   276→\n   277→// ===========================================================================\n   278→// Rollback sanity check tests\n   279→// ===========================================================================\n   280→\n   281→func TestCuratorRollback_GarbageLLMOutputPreservesOriginal(t *testing.T) {\n   282→\t// Mock the LLM to return garbage. Assert the original file content\n   283→\t// is preserved after Curator.Apply() returns.\n   284→\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Guidelines\\n\\n- Follow best practices\\n\"\n   285→\tdir, promptPath := setupCuratorDir(t, original)\n   286→\n   287→\t// LLM returns garbage that doesn't look like a prompt\n   288→\tgarbageResponse := \"asdf jkl; random garbage 12345 no markdown here\"\n   289→\tllm := &fakeLLM{response: garbageResponse}\n   290→\n   291→\taudit := &AuditLogger{ProjectDir: dir}\n   292→\tc := &Curator{LLM: llm, Audit: audit}\n   293→\tlesson := &Lesson{\n   294→\t\tTarget:          \".cloche/prompts/implement.md\",\n   295→\t\tInsight:         \"Need better validation\",\n   296→\t\tSuggestedAction: \"Add validation rules\",\n   297→\t}\n   298→\n   299→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   300→\trequire.NoError(t, err)\n   301→\trequire.NotNil(t, change)\n   302→\n   303→\t// Change should indicate rollback\n   304→\tassert.Equal(t, \"prompt_update_rollback\", change.Type)\n   305→\tassert.Contains(t, change.Reason, \"rolled back\")\n   306→\n   307→\t// Original file content is preserved\n   308→\tcontent, err := os.ReadFile(promptPath)\n   309→\trequire.NoError(t, err)\n   310→\tassert.Equal(t, original, string(content))\n   311→}\n   312→\n   313→func TestCuratorRollback_SnapshotNotDeletedOnRollback(t *testing.T) {\n   314→\t// Assert the snapshot is NOT deleted on rollback (it's evidence).\n   315→\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Guidelines\\n\\n- Follow best practices\\n\"\n   316→\tdir, _ := setupCuratorDir(t, original)\n   317→\n   318→\t// LLM returns garbage\n   319→\tllm := &fakeLLM{response: \"no markdown heading here at all\"}\n   320→\n   321→\taudit := &AuditLogger{ProjectDir: dir}\n   322→\tc := &Curator{LLM: llm, Audit: audit}\n   323→\tlesson := &Lesson{\n   324→\t\tTarget:          \".cloche/prompts/implement.md\",\n   325→\t\tInsight:         \"Need better validation\",\n   326→\t\tSuggestedAction: \"Add validation rules\",\n   327→\t}\n   328→\n   329→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   330→\trequire.NoError(t, err)\n   331→\trequire.NotNil(t, change)\n   332→\tassert.Equal(t, \"prompt_update_rollback\", change.Type)\n   333→\tassert.NotEmpty(t, change.Snapshot)\n   334→\n   335→\t// Verify the snapshot file still exists (not deleted)\n   336→\tsnapDir := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\")\n   337→\tsnapPath := filepath.Join(snapDir, change.Snapshot)\n   338→\t_, err = os.Stat(snapPath)\n   339→\tassert.NoError(t, err, \"snapshot file should still exist after rollback\")\n   340→\n   341→\t// Verify snapshot contains the original content\n   342→\tsnapContent, err := os.ReadFile(snapPath)\n   343→\trequire.NoError(t, err)\n   344→\tassert.Equal(t, original, string(snapContent))\n   345→}\n   346→\n   347→func TestCuratorRollback_ChangeIndicatesRollback(t *testing.T) {\n   348→\t// Assert the Change entry in the result indicates the rollback.\n   349→\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Section\\n\\n- Rule one\\n\"\n   350→\tdir, _ := setupCuratorDir(t, original)\n   351→\n   352→\t// LLM returns content without any heading\n   353→\tllm := &fakeLLM{response: \"This is just plain text with no structure whatsoever.\"}\n   354→\n   355→\taudit := &AuditLogger{ProjectDir: dir}\n   356→\tc := &Curator{LLM: llm, Audit: audit}\n   357→\tlesson := &Lesson{\n   358→\t\tTarget:          \".cloche/prompts/implement.md\",\n   359→\t\tInsight:         \"Important insight\",\n   360→\t\tSuggestedAction: \"Do something\",\n   361→\t}\n   362→\n   363→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   364→\trequire.NoError(t, err)\n   365→\trequire.NotNil(t, change)\n   366→\n   367→\t// Verify the Change entry indicates rollback\n   368→\tassert.Equal(t, \"prompt_update_rollback\", change.Type)\n   369→\tassert.Equal(t, \".cloche/prompts/implement.md\", change.File)\n   370→\tassert.Contains(t, change.Reason, \"rolled back\")\n   371→\tassert.Contains(t, change.Reason, \"sanity check\")\n   372→\tassert.NotEmpty(t, change.Snapshot)\n   373→}\n   374→\n   375→func TestPromptSanityCheck(t *testing.T) {\n   376→\ttests := []struct {\n   377→\t\tname    string\n   378→\t\tcontent string\n   379→\t\tvalid   bool\n   380→\t}{\n   381→\t\t{\"empty\", \"\", false},\n   382→\t\t{\"whitespace only\", \"   \\n\\n  \", false},\n   383→\t\t{\"no heading\", \"Just some text without markdown headings\", false},\n   384→\t\t{\"conversational\", \"I've updated the prompt for you.\", false},\n   385→\t\t{\"valid with subsection\", \"# Title\\n\\n## Section\\n\\nContent here.\\n\", true},\n   386→\t\t{\"valid single heading with content\", \"# Title\\n\\nSome content here.\\n\", true},\n   387→\t\t{\"valid content with heading not at start\", \"Write good code.\\n\\n## Learned Rules\\n\\n- Rule one\\n\", true},\n   388→\t\t{\"garbage text\", \"asdf jkl; random garbage\", false},\n   389→\t\t{\"heading at start\", \"# Prompt\\n\\nDo things.\\n\", true},\n   390→\t}\n   391→\n   392→\tfor _, tt := range tests {\n   393→\t\tt.Run(tt.name, func(t *testing.T) {\n   394→\t\t\tassert.Equal(t, tt.valid, promptSanityCheck(tt.content), \"content: %q\", tt.content)\n   395→\t\t})\n   396→\t}\n   397→}\n   398→\n   399→func TestStripCodeFences_EmptyFences(t *testing.T) {\n   400→\t// Fences with nothing between them.\n   401→\tassert.Equal(t, \"\", stripCodeFences(\"```\\n```\"))\n   402→\tassert.Equal(t, \"\", stripCodeFences(\"```markdown\\n```\"))\n   403→}\n   404→\n   405→func TestStripCodeFences_OnlyWhitespace(t *testing.T) {\n   406→\t// Fences with only whitespace between them.\n   407→\tresult := stripCodeFences(\"```\\n   \\n```\")\n   408→\tassert.Equal(t, \"   \\n\", result)\n   409→}\n   410→\n   411→// ===========================================================================\n   412→// Orchestrator edge case tests\n   413→// ===========================================================================\n   414→\n   415→func setupOrchestratorDir(t *testing.T, workflowContent, promptContent, kbContent string) string {\n   416→\tt.Helper()\n   417→\tdir := t.TempDir()\n   418→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   419→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   420→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   421→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n   422→\t\t[]byte(kbContent), 0644)\n   423→\tif promptContent != \"\" {\n   424→\t\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n   425→\t\t\t[]byte(promptContent), 0644)\n   426→\t}\n   427→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   428→\t\t[]byte(workflowContent), 0644)\n   429→\treturn dir\n   430→}\n   431→\n   432→func TestOrchestratorReflectorProducesDuplicateLessons(t *testing.T) {\n   433→\t// Reflector produces lessons that are already in the knowledge base.\n   434→\t// The orchestrator should still apply them (curation handles dedup).\n   435→\t// Note: the prompt must NOT contain the lesson's insight text, otherwise\n   436→\t// lessonAlreadyPresent returns true and the curator skips the update.\n   437→\tkb := \"# Knowledge Base: develop\\n\\n## Learned (2026-03-15)\\n- [L001] high: Always sanitize user inputs (run-1, run-2)\\n\"\n   438→\tdir := setupOrchestratorDir(t,\n   439→\t\t`workflow \"develop\" {\n   440→  step implement {\n   441→    prompt = file(\".cloche/prompts/implement.md\")\n   442→    results = [success, fail]\n   443→  }\n   444→  implement:success -> done\n   445→  implement:fail -> abort\n   446→}`,\n   447→\t\t\"# Prompt\\n\\nWrite good code.\\n\",\n   448→\t\tkb,\n   449→\t)\n   450→\n   451→\tllm := &scriptedLLM{\n   452→\t\tresponses: []string{\n   453→\t\t\t`{\"classification\": \"bug\"}`,\n   454→\t\t\t// Reflector returns a lesson that's already in the KB\n   455→\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Always sanitize user inputs\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-3\"], \"confidence\": \"high\"}]}`,\n   456→\t\t\t// Curator returns updated content (idempotent update)\n   457→\t\t\t\"# Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n   458→\t\t},\n   459→\t}\n   460→\n   461→\torch := NewOrchestrator(OrchestratorConfig{\n   462→\t\tProjectDir:    dir,\n   463→\t\tWorkflowName:  \"develop\",\n   464→\t\tLLM:           llm,\n   465→\t\tMinConfidence: \"medium\",\n   466→\t})\n   467→\n   468→\tresult, err := orch.Run(context.Background(), \"run-3\", nil, nil)\n   469→\trequire.NoError(t, err)\n   470→\t// Should still process the lesson even though it's a duplicate in KB\n   471→\tassert.Len(t, result.Changes, 1)\n   472→\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n   473→\n   474→\t// Knowledge base gets the lesson appended again\n   475→\tkbContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"))\n   476→\tassert.Contains(t, string(kbContent), \"L001\")\n   477→}\n   478→\n   479→func TestOrchestratorHandleNewStepAlreadyExists(t *testing.T) {\n   480→\t// handleNewStep tries to add a step whose name collides with an\n   481→\t// existing step. The mutator's AddStep should fail because the\n   482→\t// workflow already contains a step with that name.\n   483→\tdir := setupOrchestratorDir(t,\n   484→\t\t`workflow \"develop\" {\n   485→  step implement {\n   486→    prompt = file(\".cloche/prompts/implement.md\")\n   487→    results = [success, fail]\n   488→  }\n   489→  step test {\n   490→    run = \"make test\"\n   491→    results = [success, fail]\n   492→  }\n   493→  implement:success -> test\n   494→  implement:fail -> abort\n   495→  test:success -> done\n   496→  test:fail -> abort\n   497→}`,\n   498→\t\t\"Write good code.\\n\",\n   499→\t\t\"# Knowledge Base: develop\\n\",\n   500→\t)\n   501→\n   502→\tllm := &scriptedLLM{\n   503→\t\tresponses: []string{\n   504→\t\t\t`{\"classification\": \"enhancement\"}`,\n   505→\t\t\t// Reflector suggests a new step with same name as an existing one\n   506→\t\t\t`{\"lessons\": [{\"id\": \"L003\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Need tests\", \"suggested_action\": \"Add test step\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n   507→\t\t\t// ScriptGenerator uses the name \"test.sh\" which derives to step name \"test\"\n   508→\t\t\t`{\"path\": \"scripts/test.sh\", \"content\": \"#!/bin/bash\\nmake test\"}`,\n   509→\t\t},\n   510→\t}\n   511→\n   512→\torch := NewOrchestrator(OrchestratorConfig{\n   513→\t\tProjectDir:    dir,\n   514→\t\tWorkflowName:  \"develop\",\n   515→\t\tLLM:           llm,\n   516→\t\tMinConfidence: \"medium\",\n   517→\t})\n   518→\n   519→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   520→\trequire.NoError(t, err)\n   521→\t// The add_script change is recorded before the step addition fails,\n   522→\t// but add_step should not appear because the mutator rejects duplicates.\n   523→\t// The `continue` in the orchestrator swallows the error.\n   524→\thasAddStep := false\n   525→\tfor _, c := range result.Changes {\n   526→\t\tif c.Type == \"add_step\" {\n   527→\t\t\thasAddStep = true\n   528→\t\t}\n   529→\t}\n   530→\t// Check if the mutator rejected the duplicate or allowed it.\n   531→\t// Either way, the orchestrator should not crash.\n   532→\t_ = hasAddStep // The test documents the behavior.\n   533→}\n   534→\n   535→func TestOrchestratorWorkflowValidAfterMultipleEvolutionCycles(t *testing.T) {\n   536→\t// Run N evolution cycles adding new steps and verify the workflow\n   537→\t// remains valid after each cycle.\n   538→\tdir := setupOrchestratorDir(t,\n   539→\t\t`workflow \"develop\" {\n   540→  step implement {\n   541→    prompt = file(\".cloche/prompts/implement.md\")\n   542→    results = [success, fail]\n   543→  }\n   544→  implement:success -> done\n   545→  implement:fail -> abort\n   546→}`,\n   547→\t\t\"Write good code.\\n\",\n   548→\t\t\"# Knowledge Base: develop\\n\",\n   549→\t)\n   550→\n   551→\tsteps := []struct {\n   552→\t\tscriptName string\n   553→\t\tscriptPath string\n   554→\t}{\n   555→\t\t{\"lint\", \"scripts/lint.sh\"},\n   556→\t\t{\"security-scan\", \"scripts/security-scan.sh\"},\n   557→\t\t{\"format-check\", \"scripts/format-check.sh\"},\n   558→\t}\n   559→\n   560→\tfor i, step := range steps {\n   561→\t\tllm := &scriptedLLM{\n   562→\t\t\tresponses: []string{\n   563→\t\t\t\t`{\"classification\": \"enhancement\"}`,\n   564→\t\t\t\tfmt.Sprintf(`{\"lessons\": [{\"id\": \"L%d\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Need %s\", \"suggested_action\": \"Add %s\", \"evidence\": [\"run-%d\"], \"confidence\": \"high\"}]}`, i+10, step.scriptName, step.scriptName, i+1),\n   565→\t\t\t\tfmt.Sprintf(`{\"path\": \"%s\", \"content\": \"#!/bin/bash\\necho %s\"}`, step.scriptPath, step.scriptName),\n   566→\t\t\t},\n   567→\t\t}\n   568→\n   569→\t\torch := NewOrchestrator(OrchestratorConfig{\n   570→\t\t\tProjectDir:    dir,\n   571→\t\t\tWorkflowName:  \"develop\",\n   572→\t\t\tLLM:           llm,\n   573→\t\t\tMinConfidence: \"medium\",\n   574→\t\t})\n   575→\n   576→\t\tresult, err := orch.Run(context.Background(), fmt.Sprintf(\"run-%d\", i+1), nil, nil)\n   577→\t\trequire.NoError(t, err, \"cycle %d failed\", i)\n   578→\t\trequire.NotEmpty(t, result.Changes, \"cycle %d produced no changes\", i)\n   579→\n   580→\t\t// Read the updated workflow and verify it parses and validates.\n   581→\t\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   582→\t\trequire.NoError(t, err)\n   583→\n   584→\t\twf, err := dsl.Parse(string(wfContent))\n   585→\t\trequire.NoError(t, err, \"workflow failed to parse after cycle %d:\\n%s\", i, string(wfContent))\n   586→\t\trequire.NoError(t, wf.Validate(), \"workflow failed to validate after cycle %d:\\n%s\", i, string(wfContent))\n   587→\t}\n   588→}\n   589→\n   590→func TestOrchestratorErrorInOneLessonDoesNotPreventOthers(t *testing.T) {\n   591→\t// The `continue` on line 90 of orchestrator.go silently swallows errors.\n   592→\t// Verify that if one lesson fails, other lessons still get applied.\n   593→\tdir := setupOrchestratorDir(t,\n   594→\t\t`workflow \"develop\" {\n   595→  step implement {\n   596→    prompt = file(\".cloche/prompts/implement.md\")\n   597→    results = [success, fail]\n   598→  }\n   599→  implement:success -> done\n   600→  implement:fail -> abort\n   601→}`,\n   602→\t\t\"Write good code.\\n\",\n   603→\t\t\"# Knowledge Base: develop\\n\",\n   604→\t)\n   605→\n   606→\t// Also create a second prompt file that the first lesson targets.\n   607→\t// The first lesson targets a non-existent file to trigger an error.\n   608→\tllm := &callTrackingLLM{\n   609→\t\tresponses: []string{\n   610→\t\t\t// Classifier\n   611→\t\t\t`{\"classification\": \"bug\"}`,\n   612→\t\t\t// Reflector returns two lessons: first targets a nonexistent file\n   613→\t\t\t`{\"lessons\": [\n   614→\t\t\t\t{\"id\": \"L-FAIL\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/nonexistent.md\", \"insight\": \"Bad target\", \"suggested_action\": \"This should fail\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"},\n   615→\t\t\t\t{\"id\": \"L-OK\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Good insight\", \"suggested_action\": \"Add good rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}\n   616→\t\t\t]}`,\n   617→\t\t\t// Curator response for the first lesson (will fail before this is used\n   618→\t\t\t// because reading the nonexistent file fails)\n   619→\t\t\t// This response won't be consumed because the file read fails first.\n   620→\t\t\t// Curator response for the second lesson\n   621→\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Good rule applied\\n\",\n   622→\t\t},\n   623→\t}\n   624→\n   625→\torch := NewOrchestrator(OrchestratorConfig{\n   626→\t\tProjectDir:    dir,\n   627→\t\tWorkflowName:  \"develop\",\n   628→\t\tLLM:           llm,\n   629→\t\tMinConfidence: \"medium\",\n   630→\t})\n   631→\n   632→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   633→\trequire.NoError(t, err)\n   634→\n   635→\t// The first lesson should have failed (nonexistent file), but the\n   636→\t// second lesson should have succeeded.\n   637→\tassert.Len(t, result.Changes, 1)\n   638→\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n   639→\tassert.Equal(t, \".cloche/prompts/implement.md\", result.Changes[0].File)\n   640→\n   641→\t// Verify the second prompt was actually updated.\n   642→\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n   643→\trequire.NoError(t, err)\n   644→\tassert.Contains(t, string(content), \"Good rule applied\")\n   645→}\n   646→\n   647→func TestOrchestratorSavesToEvolutionStore(t *testing.T) {\n   648→\t// Verify the orchestrator saves to the evolution store when lessons\n   649→\t// are produced. Note: with zero lessons the orchestrator returns early\n   650→\t// before the store-save path.\n   651→\tdir := setupOrchestratorDir(t,\n   652→\t\t`workflow \"develop\" {\n   653→  step implement {\n   654→    prompt = file(\".cloche/prompts/implement.md\")\n   655→    results = [success, fail]\n   656→  }\n   657→  implement:success -> done\n   658→  implement:fail -> abort\n   659→}`,\n   660→\t\t\"Write good code.\\n\",\n   661→\t\t\"# Knowledge Base: develop\\n\",\n   662→\t)\n   663→\n   664→\tllm := &scriptedLLM{\n   665→\t\tresponses: []string{\n   666→\t\t\t`{\"classification\": \"bug\"}`,\n   667→\t\t\t`{\"lessons\": [{\"id\": \"L-S\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Missing validation\", \"suggested_action\": \"Add rule\", \"evidence\": [\"run-42\"], \"confidence\": \"high\"}]}`,\n   668→\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Validate inputs\\n\",\n   669→\t\t},\n   670→\t}\n   671→\n   672→\tevoStore := &mockEvolutionStore{}\n   673→\n   674→\torch := NewOrchestrator(OrchestratorConfig{\n   675→\t\tProjectDir:    dir,\n   676→\t\tWorkflowName:  \"develop\",\n   677→\t\tLLM:           llm,\n   678→\t\tMinConfidence: \"medium\",\n   679→\t})\n   680→\n   681→\tresult, err := orch.Run(context.Background(), \"run-42\", evoStore, nil)\n   682→\trequire.NoError(t, err)\n   683→\tassert.Equal(t, \"bug\", result.Classification)\n   684→\n   685→\t// Verify the evolution was saved to the store.\n   686→\trequire.Len(t, evoStore.saved, 1)\n   687→\tassert.Equal(t, \"develop\", evoStore.saved[0].WorkflowName)\n   688→\tassert.Equal(t, \"run-42\", evoStore.saved[0].TriggerRunID)\n   689→\tassert.Equal(t, \"bug\", evoStore.saved[0].Classification)\n   690→}\n   691→\n   692→// ===========================================================================\n   693→// Collector tests with store mocks\n   694→// ===========================================================================\n   695→\n   696→func TestCollectorWithEvolutionStoreMock(t *testing.T) {\n   697→\tdir := t.TempDir()\n   698→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   699→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   700→\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n   701→\n   702→\truns := []*domain.Run{\n   703→\t\t{ID: \"run-5\", WorkflowName: \"develop\", ProjectDir: dir},\n   704→\t\t{ID: \"run-6\", WorkflowName: \"develop\", ProjectDir: dir},\n   705→\t}\n   706→\tevoStore := &mockEvolutionStore{\n   707→\t\tlastEvolution: &ports.EvolutionEntry{\n   708→\t\t\tID:           \"evo-prev\",\n   709→\t\t\tTriggerRunID: \"run-4\",\n   710→\t\t},\n   711→\t\truns: runs,\n   712→\t}\n   713→\n   714→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n   715→\tdata, err := c.Collect(context.Background(), evoStore, nil)\n   716→\trequire.NoError(t, err)\n   717→\n   718→\t// Should have fetched runs from the store.\n   719→\tassert.Len(t, data.Runs, 2)\n   720→\tassert.Equal(t, \"run-5\", data.Runs[0].ID)\n   721→\tassert.Equal(t, \"run-6\", data.Runs[1].ID)\n   722→}\n   723→\n   724→func TestCollectorListRunsSinceCalledWithCorrectRunID(t *testing.T) {\n   725→\tdir := t.TempDir()\n   726→\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n   727→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   728→\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n   729→\n   730→\tevoStore := &mockEvolutionStore{\n   731→\t\tlastEvolution: &ports.EvolutionEntry{\n   732→\t\t\tID:           \"evo-42\",\n   733→\t\t\tTriggerRunID: \"run-99\",\n   734→\t\t},\n   735→\t\truns: nil,\n   736→\t}\n   737→\n   738→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n   739→\t_, err := c.Collect(context.Background(), evoStore, nil)\n   740→\trequire.NoError(t, err)\n   741→\n   742→\t// Verify ListRunsSince was called with the correct sinceRunID\n   743→\t// from the last evolution entry.\n   744→\trequire.Len(t, evoStore.listCalls, 1)\n   745→\tassert.Equal(t, dir, evoStore.listCalls[0].projectDir)\n   746→\tassert.Equal(t, \"develop\", evoStore.listCalls[0].workflowName)\n   747→\tassert.Equal(t, \"run-99\", evoStore.listCalls[0].sinceRunID)\n   748→}\n   749→\n   750→func TestCollectorListRunsSinceEmptyWhenNoLastEvolution(t *testing.T) {\n   751→\tdir := t.TempDir()\n   752→\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n   753→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   754→\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n   755→\n   756→\t// No last evolution — sinceRunID should be empty.\n   757→\tevoStore := &mockEvolutionStore{\n   758→\t\tlastEvolution: nil,\n   759→\t\truns:          nil,\n   760→\t}\n   761→\n   762→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n   763→\t_, err := c.Collect(context.Background(), evoStore, nil)\n   764→\trequire.NoError(t, err)\n   765→\n   766→\trequire.Len(t, evoStore.listCalls, 1)\n   767→\tassert.Equal(t, \"\", evoStore.listCalls[0].sinceRunID)\n   768→}\n   769→\n   770→func TestCollectorWithCaptureStoreMock(t *testing.T) {\n   771→\tdir := t.TempDir()\n   772→\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n   773→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   774→\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n   775→\n   776→\truns := []*domain.Run{\n   777→\t\t{ID: \"run-10\", WorkflowName: \"develop\"},\n   778→\t\t{ID: \"run-11\", WorkflowName: \"develop\"},\n   779→\t}\n   780→\tevoStore := &mockEvolutionStore{runs: runs}\n   781→\n   782→\tcapStore := &mockCaptureStore{\n   783→\t\tcaptures: map[string][]*domain.StepExecution{\n   784→\t\t\t\"run-10\": {\n   785→\t\t\t\t{StepName: \"implement\", Result: \"success\"},\n   786→\t\t\t},\n   787→\t\t\t\"run-11\": {\n   788→\t\t\t\t{StepName: \"implement\", Result: \"fail\"},\n   789→\t\t\t\t{StepName: \"test\", Result: \"success\"},\n   790→\t\t\t},\n   791→\t\t},\n   792→\t}\n   793→\n   794→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n   795→\tdata, err := c.Collect(context.Background(), evoStore, capStore)\n   796→\trequire.NoError(t, err)\n   797→\n   798→\tassert.Len(t, data.Captures, 2)\n   799→\tassert.Len(t, data.Captures[\"run-10\"], 1)\n   800→\tassert.Len(t, data.Captures[\"run-11\"], 2)\n   801→\tassert.Equal(t, \"implement\", data.Captures[\"run-10\"][0].StepName)\n   802→\tassert.Equal(t, \"fail\", data.Captures[\"run-11\"][0].Result)\n   803→}\n   804→\n   805→// ===========================================================================\n   806→// Integration tests\n   807→// ===========================================================================\n   808→\n   809→func TestIntegration_CorruptPromptDetectedAndFixed(t *testing.T) {\n   810→\t// Full cycle: corrupt a prompt → run evolution → verify it produces a fix.\n   811→\tdir := setupOrchestratorDir(t,\n   812→\t\t`workflow \"develop\" {\n   813→  step implement {\n   814→    prompt = file(\".cloche/prompts/implement.md\")\n   815→    results = [success, fail]\n   816→  }\n   817→  implement:success -> done\n   818→  implement:fail -> abort\n   819→}`,\n   820→\t\t// Start with a \"corrupted\" prompt (conversational text, no useful instructions)\n   821→\t\t\"Sure! I've updated the prompt to include better instructions.\",\n   822→\t\t\"# Knowledge Base: develop\\n\",\n   823→\t)\n   824→\n   825→\t// The evolution pipeline should detect the corruption and fix it.\n   826→\tllm := &scriptedLLM{\n   827→\t\tresponses: []string{\n   828→\t\t\t// Classifier\n   829→\t\t\t`{\"classification\": \"bug\"}`,\n   830→\t\t\t// Reflector identifies the corruption\n   831→\t\t\t`{\"lessons\": [{\"id\": \"L-FIX\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Prompt was corrupted with conversational text\", \"suggested_action\": \"Restore proper prompt structure\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n   832→\t\t\t// Curator returns a proper prompt\n   833→\t\t\t\"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate user inputs\\n\",\n   834→\t\t},\n   835→\t}\n   836→\n   837→\torch := NewOrchestrator(OrchestratorConfig{\n   838→\t\tProjectDir:    dir,\n   839→\t\tWorkflowName:  \"develop\",\n   840→\t\tLLM:           llm,\n   841→\t\tMinConfidence: \"medium\",\n   842→\t})\n   843→\n   844→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   845→\trequire.NoError(t, err)\n   846→\trequire.Len(t, result.Changes, 1)\n   847→\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n   848→\n   849→\t// Verify the prompt is now proper.\n   850→\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n   851→\trequire.NoError(t, err)\n   852→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   853→\tassert.Contains(t, string(content), \"Always validate user inputs\")\n   854→\tassert.NotContains(t, string(content), \"Sure!\")\n   855→}\n   856→\n   857→func TestIntegration_StabilityNoCyclesNoDrift(t *testing.T) {\n   858→\t// Stability test: run N evolution cycles where the reflector finds no\n   859→\t// lessons. The workflow should remain unchanged.\n   860→\tworkflow := `workflow \"develop\" {\n   861→  step implement {\n   862→    prompt = file(\".cloche/prompts/implement.md\")\n   863→    results = [success, fail]\n   864→  }\n   865→  implement:success -> done\n   866→  implement:fail -> abort\n   867→}`\n   868→\tprompt := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n   869→\tdir := setupOrchestratorDir(t, workflow, prompt, \"# Knowledge Base: develop\\n\")\n   870→\n   871→\toriginalWorkflow, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   872→\toriginalPrompt, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n   873→\n   874→\tconst cycles = 5\n   875→\tfor i := 0; i < cycles; i++ {\n   876→\t\tllm := &scriptedLLM{\n   877→\t\t\tresponses: []string{\n   878→\t\t\t\t`{\"classification\": \"feature\"}`,\n   879→\t\t\t\t`{\"lessons\": []}`,\n   880→\t\t\t},\n   881→\t\t}\n   882→\n   883→\t\torch := NewOrchestrator(OrchestratorConfig{\n   884→\t\t\tProjectDir:    dir,\n   885→\t\t\tWorkflowName:  \"develop\",\n   886→\t\t\tLLM:           llm,\n   887→\t\t\tMinConfidence: \"medium\",\n   888→\t\t})\n   889→\n   890→\t\tresult, err := orch.Run(context.Background(), fmt.Sprintf(\"run-%d\", i+1), nil, nil)\n   891→\t\trequire.NoError(t, err, \"cycle %d failed\", i)\n   892→\t\tassert.Empty(t, result.Changes, \"cycle %d should have no changes\", i)\n   893→\t}\n   894→\n   895→\t// After N cycles, workflow and prompt should be identical.\n   896→\tfinalWorkflow, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   897→\tfinalPrompt, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n   898→\tassert.Equal(t, string(originalWorkflow), string(finalWorkflow), \"workflow drifted after %d cycles\", cycles)\n   899→\tassert.Equal(t, string(originalPrompt), string(finalPrompt), \"prompt drifted after %d cycles\", cycles)\n   900→}\n   901→\n   902→func TestIntegration_FullCycleWithStores(t *testing.T) {\n   903→\t// End-to-end with actual store mocks: collect → classify → reflect →\n   904→\t// apply → save to store.\n   905→\tdir := setupOrchestratorDir(t,\n   906→\t\t`workflow \"develop\" {\n   907→  step implement {\n   908→    prompt = file(\".cloche/prompts/implement.md\")\n   909→    results = [success, fail]\n   910→  }\n   911→  implement:success -> done\n   912→  implement:fail -> abort\n   913→}`,\n   914→\t\t\"# Prompt\\n\\nWrite code.\\n\",\n   915→\t\t\"# Knowledge Base: develop\\n\",\n   916→\t)\n   917→\n   918→\truns := []*domain.Run{\n   919→\t\t{ID: \"run-100\", WorkflowName: \"develop\", ProjectDir: dir},\n   920→\t}\n   921→\tevoStore := &mockEvolutionStore{\n   922→\t\tlastEvolution: &ports.EvolutionEntry{TriggerRunID: \"run-99\"},\n   923→\t\truns:          runs,\n   924→\t}\n   925→\tcapStore := &mockCaptureStore{\n   926→\t\tcaptures: map[string][]*domain.StepExecution{\n   927→\t\t\t\"run-100\": {\n   928→\t\t\t\t{StepName: \"implement\", Result: \"success\"},\n   929→\t\t\t},\n   930→\t\t},\n   931→\t}\n   932→\n   933→\tllm := &scriptedLLM{\n   934→\t\tresponses: []string{\n   935→\t\t\t`{\"classification\": \"bug\"}`,\n   936→\t\t\t`{\"lessons\": [{\"id\": \"L-STORE\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Missing validation\", \"suggested_action\": \"Add validation rule\", \"evidence\": [\"run-100\"], \"confidence\": \"high\"}]}`,\n   937→\t\t\t\"# Prompt\\n\\nWrite code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n\",\n   938→\t\t},\n   939→\t}\n   940→\n   941→\torch := NewOrchestrator(OrchestratorConfig{\n   942→\t\tProjectDir:    dir,\n   943→\t\tWorkflowName:  \"develop\",\n   944→\t\tLLM:           llm,\n   945→\t\tMinConfidence: \"medium\",\n   946→\t})\n   947→\n   948→\tresult, err := orch.Run(context.Background(), \"run-100\", evoStore, capStore)\n   949→\trequire.NoError(t, err)\n   950→\tassert.Equal(t, \"bug\", result.Classification)\n   951→\tassert.Len(t, result.Changes, 1)\n   952→\n   953→\t// Verify evolution was saved to store.\n   954→\trequire.Len(t, evoStore.saved, 1)\n   955→\tassert.Equal(t, \"run-100\", evoStore.saved[0].TriggerRunID)\n   956→\n   957→\t// Verify ListRunsSince was called correctly.\n   958→\trequire.Len(t, evoStore.listCalls, 1)\n   959→\tassert.Equal(t, \"run-99\", evoStore.listCalls[0].sinceRunID)\n   960→}\n   961→"}]},"parent_tool_use_id":null,"session_id":"d1bdfa56-7559-4eed-a938-794d649ba582","uuid":"210478f8-47d7-406e-9b67-0f77536ce3b8","timestamp":"2026-03-17T14:07:42.434Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/corruption_test.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sync\"\n\t\"testing\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// errLLM returns a fixed error for testing error paths.\ntype errLLM struct {\n\terr error\n}\n\nfunc (e *errLLM) Complete(ctx context.Context, system, user string) (string, error) {\n\treturn \"\", e.err\n}\n\n// callTrackingLLM records calls and returns fixed responses in order.\ntype callTrackingLLM struct {\n\tmu        sync.Mutex\n\tresponses []string\n\tidx       int\n\tcalls     []llmCall\n}\n\ntype llmCall struct {\n\tsystem string\n\tuser   string\n}\n\nfunc (c *callTrackingLLM) Complete(ctx context.Context, system, user string) (string, error) {\n\tc.mu.Lock()\n\tdefer c.mu.Unlock()\n\tc.calls = append(c.calls, llmCall{system: system, user: user})\n\tif c.idx >= len(c.responses) {\n\t\treturn \"\", fmt.Errorf(\"no more responses\")\n\t}\n\tresp := c.responses[c.idx]\n\tc.idx++\n\treturn resp, nil\n}\n\n// --- Mock stores ---\n\ntype mockEvolutionStore struct {\n\tlastEvolution *ports.EvolutionEntry\n\truns          []*domain.Run\n\tsaved         []*ports.EvolutionEntry\n\tlistCalls     []listRunsSinceCall\n}\n\ntype listRunsSinceCall struct {\n\tprojectDir   string\n\tworkflowName string\n\tsinceRunID   string\n}\n\nfunc (m *mockEvolutionStore) SaveEvolution(ctx context.Context, entry *ports.EvolutionEntry) error {\n\tm.saved = append(m.saved, entry)\n\treturn nil\n}\n\nfunc (m *mockEvolutionStore) GetLastEvolution(ctx context.Context, projectDir, workflowName string) (*ports.EvolutionEntry, error) {\n\tif m.lastEvolution != nil {\n\t\treturn m.lastEvolution, nil\n\t}\n\treturn nil, nil\n}\n\nfunc (m *mockEvolutionStore) ListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error) {\n\tm.listCalls = append(m.listCalls, listRunsSinceCall{projectDir, workflowName, sinceRunID})\n\treturn m.runs, nil\n}\n\ntype mockCaptureStore struct {\n\tcaptures map[string][]*domain.StepExecution\n}\n\nfunc (m *mockCaptureStore) SaveCapture(ctx context.Context, runID string, exec *domain.StepExecution) error {\n\treturn nil\n}\n\nfunc (m *mockCaptureStore) GetCaptures(ctx context.Context, runID string) ([]*domain.StepExecution, error) {\n\tif m.captures != nil {\n\t\treturn m.captures[runID], nil\n\t}\n\treturn nil, nil\n}\n\n// ===========================================================================\n// Curator corruption scenarios\n// ===========================================================================\n\nfunc setupCuratorDir(t *testing.T, promptContent string) (string, string) {\n\tt.Helper()\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.WriteFile(promptPath, []byte(promptContent), 0644)\n\treturn dir, promptPath\n}\n\nfunc TestCuratorCorruption_ConversationalMetaTextNoFences(t *testing.T) {\n\t// LLM returns conversational meta-text without code fences.\n\t// \"Sure!\" doesn't match the conversational markers regex, so it passes\n\t// through stripCodeFences and isConversationalResponse unchanged.\n\t// The post-write sanity check catches it (no '#' heading) and rolls back.\n\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n\tdir, promptPath := setupCuratorDir(t, original)\n\n\tconversationalResponse := \"Sure! I've updated the prompt to include a sanitization rule. The prompt now instructs the agent to always sanitize user inputs before processing them.\"\n\tllm := &fakeLLM{response: conversationalResponse}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"XSS in form handlers\",\n\t\tSuggestedAction: \"Add sanitization rule\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"prompt_update_rollback\", change.Type)\n\tassert.Contains(t, change.Reason, \"rolled back\")\n\n\t// Original content is preserved via rollback.\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, original, string(content))\n}\n\nfunc TestCuratorCorruption_ResponseShorterThanOriginal(t *testing.T) {\n\t// LLM returns a response that is shorter than the original prompt,\n\t// representing total content loss. The sanity check catches this\n\t// (no '#' heading) and rolls back to the snapshot.\n\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Guidelines\\n\\n- Follow best practices\\n- Use proper error handling\\n- Write tests\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n- Never trust user data\\n\"\n\tdir, promptPath := setupCuratorDir(t, original)\n\n\t// Extremely short response — no heading, fails sanity check.\n\tshortResponse := \"Write good code.\"\n\tllm := &fakeLLM{response: shortResponse}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Missing error handling\",\n\t\tSuggestedAction: \"Add error handling rule\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"prompt_update_rollback\", change.Type)\n\tassert.NotEmpty(t, change.Snapshot)\n\tassert.Contains(t, change.Reason, \"rolled back\")\n\n\t// Original content is preserved via rollback.\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, original, string(content))\n\tassert.Contains(t, string(content), \"## Guidelines\")\n\tassert.Contains(t, string(content), \"## Learned Rules\")\n}\n\nfunc TestCuratorCorruption_EmptyResponse(t *testing.T) {\n\t// LLM returns an empty string. isConversationalResponse returns true\n\t// for empty strings, so the fallback appends the lesson directly,\n\t// preserving the original content.\n\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n\tdir, promptPath := setupCuratorDir(t, original)\n\n\tllm := &fakeLLM{response: \"\"}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Test insight\",\n\t\tSuggestedAction: \"Test action\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"prompt_update\", change.Type)\n\n\t// The conversational guard catches the empty string and falls back\n\t// to appendLessonDirectly, preserving original content.\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n\tassert.Contains(t, string(content), \"Test insight\")\n}\n\nfunc TestCuratorCorruption_EmptyCodeFences(t *testing.T) {\n\t// LLM returns only code fences with no content between them.\n\t// After stripping fences, content is empty → isConversationalResponse\n\t// returns true → fallback appends lesson directly → sanity check passes.\n\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n\tdir, promptPath := setupCuratorDir(t, original)\n\n\tllm := &fakeLLM{response: \"```markdown\\n```\"}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Test insight\",\n\t\tSuggestedAction: \"Test action\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"prompt_update\", change.Type)\n\n\t// Fallback preserves original content and appends lesson.\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n\tassert.Contains(t, string(content), \"Test insight\")\n}\n\nfunc TestCuratorCorruption_RaceConcurrentApply(t *testing.T) {\n\t// Multiple rapid Curator.Apply() calls on the same file.\n\toriginal := \"# Prompt\\n\\nOriginal content.\\n\"\n\tdir, promptPath := setupCuratorDir(t, original)\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\n\tconst goroutines = 10\n\tvar wg sync.WaitGroup\n\twg.Add(goroutines)\n\n\terrors := make([]error, goroutines)\n\n\tfor i := 0; i < goroutines; i++ {\n\t\tgo func(idx int) {\n\t\t\tdefer wg.Done()\n\t\t\tllm := &fakeLLM{\n\t\t\t\tresponse: fmt.Sprintf(\"# Prompt\\n\\nUpdated by goroutine %d.\\n\", idx),\n\t\t\t}\n\t\t\tc := &Curator{LLM: llm, Audit: audit}\n\t\t\tlesson := &Lesson{\n\t\t\t\tID:              fmt.Sprintf(\"lesson-%d\", idx),\n\t\t\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\t\t\tInsight:         fmt.Sprintf(\"Insight %d\", idx),\n\t\t\t\tSuggestedAction: fmt.Sprintf(\"Action %d\", idx),\n\t\t\t}\n\t\t\t_, errors[idx] = c.Apply(context.Background(), dir, lesson)\n\t\t}(i)\n\t}\n\n\twg.Wait()\n\n\t// All calls should succeed (no panics or crashes).\n\tfor i, err := range errors {\n\t\tassert.NoError(t, err, \"goroutine %d failed\", i)\n\t}\n\n\t// The file should contain valid content from one of the goroutines.\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"# Prompt\")\n\tassert.Contains(t, string(content), \"Updated by goroutine\")\n}\n\n// ===========================================================================\n// Rollback sanity check tests\n// ===========================================================================\n\nfunc TestCuratorRollback_GarbageLLMOutputPreservesOriginal(t *testing.T) {\n\t// Mock the LLM to return garbage. Assert the original file content\n\t// is preserved after Curator.Apply() returns.\n\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Guidelines\\n\\n- Follow best practices\\n\"\n\tdir, promptPath := setupCuratorDir(t, original)\n\n\t// LLM returns garbage that doesn't look like a prompt\n\tgarbageResponse := \"asdf jkl; random garbage 12345 no markdown here\"\n\tllm := &fakeLLM{response: garbageResponse}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Need better validation\",\n\t\tSuggestedAction: \"Add validation rules\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, change)\n\n\t// Change should indicate rollback\n\tassert.Equal(t, \"prompt_update_rollback\", change.Type)\n\tassert.Contains(t, change.Reason, \"rolled back\")\n\n\t// Original file content is preserved\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, original, string(content))\n}\n\nfunc TestCuratorRollback_SnapshotNotDeletedOnRollback(t *testing.T) {\n\t// Assert the snapshot is NOT deleted on rollback (it's evidence).\n\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Guidelines\\n\\n- Follow best practices\\n\"\n\tdir, _ := setupCuratorDir(t, original)\n\n\t// LLM returns garbage\n\tllm := &fakeLLM{response: \"no markdown heading here at all\"}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Need better validation\",\n\t\tSuggestedAction: \"Add validation rules\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, change)\n\tassert.Equal(t, \"prompt_update_rollback\", change.Type)\n\tassert.NotEmpty(t, change.Snapshot)\n\n\t// Verify the snapshot file still exists (not deleted)\n\tsnapDir := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\")\n\tsnapPath := filepath.Join(snapDir, change.Snapshot)\n\t_, err = os.Stat(snapPath)\n\tassert.NoError(t, err, \"snapshot file should still exist after rollback\")\n\n\t// Verify snapshot contains the original content\n\tsnapContent, err := os.ReadFile(snapPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, original, string(snapContent))\n}\n\nfunc TestCuratorRollback_ChangeIndicatesRollback(t *testing.T) {\n\t// Assert the Change entry in the result indicates the rollback.\n\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Section\\n\\n- Rule one\\n\"\n\tdir, _ := setupCuratorDir(t, original)\n\n\t// LLM returns content without any heading\n\tllm := &fakeLLM{response: \"This is just plain text with no structure whatsoever.\"}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Important insight\",\n\t\tSuggestedAction: \"Do something\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, change)\n\n\t// Verify the Change entry indicates rollback\n\tassert.Equal(t, \"prompt_update_rollback\", change.Type)\n\tassert.Equal(t, \".cloche/prompts/implement.md\", change.File)\n\tassert.Contains(t, change.Reason, \"rolled back\")\n\tassert.Contains(t, change.Reason, \"sanity check\")\n\tassert.NotEmpty(t, change.Snapshot)\n}\n\nfunc TestPromptSanityCheck(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tcontent string\n\t\tvalid   bool\n\t}{\n\t\t{\"empty\", \"\", false},\n\t\t{\"whitespace only\", \"   \\n\\n  \", false},\n\t\t{\"no heading\", \"Just some text without markdown headings\", false},\n\t\t{\"conversational\", \"I've updated the prompt for you.\", false},\n\t\t{\"valid with subsection\", \"# Title\\n\\n## Section\\n\\nContent here.\\n\", true},\n\t\t{\"valid single heading with content\", \"# Title\\n\\nSome content here.\\n\", true},\n\t\t{\"valid content with heading not at start\", \"Write good code.\\n\\n## Learned Rules\\n\\n- Rule one\\n\", true},\n\t\t{\"garbage text\", \"asdf jkl; random garbage\", false},\n\t\t{\"heading at start\", \"# Prompt\\n\\nDo things.\\n\", true},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, tt.valid, promptSanityCheck(tt.content), \"content: %q\", tt.content)\n\t\t})\n\t}\n}\n\nfunc TestStripCodeFences_EmptyFences(t *testing.T) {\n\t// Fences with nothing between them.\n\tassert.Equal(t, \"\", stripCodeFences(\"```\\n```\"))\n\tassert.Equal(t, \"\", stripCodeFences(\"```markdown\\n```\"))\n}\n\nfunc TestStripCodeFences_OnlyWhitespace(t *testing.T) {\n\t// Fences with only whitespace between them.\n\tresult := stripCodeFences(\"```\\n   \\n```\")\n\tassert.Equal(t, \"   \\n\", result)\n}\n\n// ===========================================================================\n// Orchestrator edge case tests\n// ===========================================================================\n\nfunc setupOrchestratorDir(t *testing.T, workflowContent, promptContent, kbContent string) string {\n\tt.Helper()\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n\t\t[]byte(kbContent), 0644)\n\tif promptContent != \"\" {\n\t\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t\t[]byte(promptContent), 0644)\n\t}\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(workflowContent), 0644)\n\treturn dir\n}\n\nfunc TestOrchestratorReflectorProducesDuplicateLessons(t *testing.T) {\n\t// Reflector produces lessons that are already in the knowledge base.\n\t// The orchestrator should still apply them (curation handles dedup).\n\t// Note: the prompt must NOT contain the lesson's insight text, otherwise\n\t// lessonAlreadyPresent returns true and the curator skips the update.\n\tkb := \"# Knowledge Base: develop\\n\\n## Learned (2026-03-15)\\n- [L001] high: Always sanitize user inputs (run-1, run-2)\\n\"\n\tdir := setupOrchestratorDir(t,\n\t\t`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  implement:success -> done\n  implement:fail -> abort\n}`,\n\t\t\"# Prompt\\n\\nWrite good code.\\n\",\n\t\tkb,\n\t)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t// Reflector returns a lesson that's already in the KB\n\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Always sanitize user inputs\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-3\"], \"confidence\": \"high\"}]}`,\n\t\t\t// Curator returns updated content (idempotent update)\n\t\t\t\"# Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-3\", nil, nil)\n\trequire.NoError(t, err)\n\t// Should still process the lesson even though it's a duplicate in KB\n\tassert.Len(t, result.Changes, 1)\n\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n\n\t// Knowledge base gets the lesson appended again\n\tkbContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"))\n\tassert.Contains(t, string(kbContent), \"L001\")\n}\n\nfunc TestOrchestratorHandleNewStepAlreadyExists(t *testing.T) {\n\t// handleNewStep tries to add a step whose name collides with an\n\t// existing step. The mutator's AddStep should fail because the\n\t// workflow already contains a step with that name.\n\tdir := setupOrchestratorDir(t,\n\t\t`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n  implement:success -> test\n  implement:fail -> abort\n  test:success -> done\n  test:fail -> abort\n}`,\n\t\t\"Write good code.\\n\",\n\t\t\"# Knowledge Base: develop\\n\",\n\t)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"enhancement\"}`,\n\t\t\t// Reflector suggests a new step with same name as an existing one\n\t\t\t`{\"lessons\": [{\"id\": \"L003\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Need tests\", \"suggested_action\": \"Add test step\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t\t// ScriptGenerator uses the name \"test.sh\" which derives to step name \"test\"\n\t\t\t`{\"path\": \"scripts/test.sh\", \"content\": \"#!/bin/bash\\nmake test\"}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\t// The add_script change is recorded before the step addition fails,\n\t// but add_step should not appear because the mutator rejects duplicates.\n\t// The `continue` in the orchestrator swallows the error.\n\thasAddStep := false\n\tfor _, c := range result.Changes {\n\t\tif c.Type == \"add_step\" {\n\t\t\thasAddStep = true\n\t\t}\n\t}\n\t// Check if the mutator rejected the duplicate or allowed it.\n\t// Either way, the orchestrator should not crash.\n\t_ = hasAddStep // The test documents the behavior.\n}\n\nfunc TestOrchestratorWorkflowValidAfterMultipleEvolutionCycles(t *testing.T) {\n\t// Run N evolution cycles adding new steps and verify the workflow\n\t// remains valid after each cycle.\n\tdir := setupOrchestratorDir(t,\n\t\t`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  implement:success -> done\n  implement:fail -> abort\n}`,\n\t\t\"Write good code.\\n\",\n\t\t\"# Knowledge Base: develop\\n\",\n\t)\n\n\tsteps := []struct {\n\t\tscriptName string\n\t\tscriptPath string\n\t}{\n\t\t{\"lint\", \"scripts/lint.sh\"},\n\t\t{\"security-scan\", \"scripts/security-scan.sh\"},\n\t\t{\"format-check\", \"scripts/format-check.sh\"},\n\t}\n\n\tfor i, step := range steps {\n\t\tllm := &scriptedLLM{\n\t\t\tresponses: []string{\n\t\t\t\t`{\"classification\": \"enhancement\"}`,\n\t\t\t\tfmt.Sprintf(`{\"lessons\": [{\"id\": \"L%d\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Need %s\", \"suggested_action\": \"Add %s\", \"evidence\": [\"run-%d\"], \"confidence\": \"high\"}]}`, i+10, step.scriptName, step.scriptName, i+1),\n\t\t\t\tfmt.Sprintf(`{\"path\": \"%s\", \"content\": \"#!/bin/bash\\necho %s\"}`, step.scriptPath, step.scriptName),\n\t\t\t},\n\t\t}\n\n\t\torch := NewOrchestrator(OrchestratorConfig{\n\t\t\tProjectDir:    dir,\n\t\t\tWorkflowName:  \"develop\",\n\t\t\tLLM:           llm,\n\t\t\tMinConfidence: \"medium\",\n\t\t})\n\n\t\tresult, err := orch.Run(context.Background(), fmt.Sprintf(\"run-%d\", i+1), nil, nil)\n\t\trequire.NoError(t, err, \"cycle %d failed\", i)\n\t\trequire.NotEmpty(t, result.Changes, \"cycle %d produced no changes\", i)\n\n\t\t// Read the updated workflow and verify it parses and validates.\n\t\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n\t\trequire.NoError(t, err)\n\n\t\twf, err := dsl.Parse(string(wfContent))\n\t\trequire.NoError(t, err, \"workflow failed to parse after cycle %d:\\n%s\", i, string(wfContent))\n\t\trequire.NoError(t, wf.Validate(), \"workflow failed to validate after cycle %d:\\n%s\", i, string(wfContent))\n\t}\n}\n\nfunc TestOrchestratorErrorInOneLessonDoesNotPreventOthers(t *testing.T) {\n\t// The `continue` on line 90 of orchestrator.go silently swallows errors.\n\t// Verify that if one lesson fails, other lessons still get applied.\n\tdir := setupOrchestratorDir(t,\n\t\t`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  implement:success -> done\n  implement:fail -> abort\n}`,\n\t\t\"Write good code.\\n\",\n\t\t\"# Knowledge Base: develop\\n\",\n\t)\n\n\t// Also create a second prompt file that the first lesson targets.\n\t// The first lesson targets a non-existent file to trigger an error.\n\tllm := &callTrackingLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t// Reflector returns two lessons: first targets a nonexistent file\n\t\t\t`{\"lessons\": [\n\t\t\t\t{\"id\": \"L-FAIL\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/nonexistent.md\", \"insight\": \"Bad target\", \"suggested_action\": \"This should fail\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"},\n\t\t\t\t{\"id\": \"L-OK\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Good insight\", \"suggested_action\": \"Add good rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}\n\t\t\t]}`,\n\t\t\t// Curator response for the first lesson (will fail before this is used\n\t\t\t// because reading the nonexistent file fails)\n\t\t\t// This response won't be consumed because the file read fails first.\n\t\t\t// Curator response for the second lesson\n\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Good rule applied\\n\",\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\n\t// The first lesson should have failed (nonexistent file), but the\n\t// second lesson should have succeeded.\n\tassert.Len(t, result.Changes, 1)\n\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n\tassert.Equal(t, \".cloche/prompts/implement.md\", result.Changes[0].File)\n\n\t// Verify the second prompt was actually updated.\n\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"Good rule applied\")\n}\n\nfunc TestOrchestratorSavesToEvolutionStore(t *testing.T) {\n\t// Verify the orchestrator saves to the evolution store when lessons\n\t// are produced. Note: with zero lessons the orchestrator returns early\n\t// before the store-save path.\n\tdir := setupOrchestratorDir(t,\n\t\t`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  implement:success -> done\n  implement:fail -> abort\n}`,\n\t\t\"Write good code.\\n\",\n\t\t\"# Knowledge Base: develop\\n\",\n\t)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t`{\"lessons\": [{\"id\": \"L-S\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Missing validation\", \"suggested_action\": \"Add rule\", \"evidence\": [\"run-42\"], \"confidence\": \"high\"}]}`,\n\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Validate inputs\\n\",\n\t\t},\n\t}\n\n\tevoStore := &mockEvolutionStore{}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-42\", evoStore, nil)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"bug\", result.Classification)\n\n\t// Verify the evolution was saved to the store.\n\trequire.Len(t, evoStore.saved, 1)\n\tassert.Equal(t, \"develop\", evoStore.saved[0].WorkflowName)\n\tassert.Equal(t, \"run-42\", evoStore.saved[0].TriggerRunID)\n\tassert.Equal(t, \"bug\", evoStore.saved[0].Classification)\n}\n\n// ===========================================================================\n// Collector tests with store mocks\n// ===========================================================================\n\nfunc TestCollectorWithEvolutionStoreMock(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n\n\truns := []*domain.Run{\n\t\t{ID: \"run-5\", WorkflowName: \"develop\", ProjectDir: dir},\n\t\t{ID: \"run-6\", WorkflowName: \"develop\", ProjectDir: dir},\n\t}\n\tevoStore := &mockEvolutionStore{\n\t\tlastEvolution: &ports.EvolutionEntry{\n\t\t\tID:           \"evo-prev\",\n\t\t\tTriggerRunID: \"run-4\",\n\t\t},\n\t\truns: runs,\n\t}\n\n\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n\tdata, err := c.Collect(context.Background(), evoStore, nil)\n\trequire.NoError(t, err)\n\n\t// Should have fetched runs from the store.\n\tassert.Len(t, data.Runs, 2)\n\tassert.Equal(t, \"run-5\", data.Runs[0].ID)\n\tassert.Equal(t, \"run-6\", data.Runs[1].ID)\n}\n\nfunc TestCollectorListRunsSinceCalledWithCorrectRunID(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n\n\tevoStore := &mockEvolutionStore{\n\t\tlastEvolution: &ports.EvolutionEntry{\n\t\t\tID:           \"evo-42\",\n\t\t\tTriggerRunID: \"run-99\",\n\t\t},\n\t\truns: nil,\n\t}\n\n\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n\t_, err := c.Collect(context.Background(), evoStore, nil)\n\trequire.NoError(t, err)\n\n\t// Verify ListRunsSince was called with the correct sinceRunID\n\t// from the last evolution entry.\n\trequire.Len(t, evoStore.listCalls, 1)\n\tassert.Equal(t, dir, evoStore.listCalls[0].projectDir)\n\tassert.Equal(t, \"develop\", evoStore.listCalls[0].workflowName)\n\tassert.Equal(t, \"run-99\", evoStore.listCalls[0].sinceRunID)\n}\n\nfunc TestCollectorListRunsSinceEmptyWhenNoLastEvolution(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n\n\t// No last evolution — sinceRunID should be empty.\n\tevoStore := &mockEvolutionStore{\n\t\tlastEvolution: nil,\n\t\truns:          nil,\n\t}\n\n\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n\t_, err := c.Collect(context.Background(), evoStore, nil)\n\trequire.NoError(t, err)\n\n\trequire.Len(t, evoStore.listCalls, 1)\n\tassert.Equal(t, \"\", evoStore.listCalls[0].sinceRunID)\n}\n\nfunc TestCollectorWithCaptureStoreMock(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n\n\truns := []*domain.Run{\n\t\t{ID: \"run-10\", WorkflowName: \"develop\"},\n\t\t{ID: \"run-11\", WorkflowName: \"develop\"},\n\t}\n\tevoStore := &mockEvolutionStore{runs: runs}\n\n\tcapStore := &mockCaptureStore{\n\t\tcaptures: map[string][]*domain.StepExecution{\n\t\t\t\"run-10\": {\n\t\t\t\t{StepName: \"implement\", Result: \"success\"},\n\t\t\t},\n\t\t\t\"run-11\": {\n\t\t\t\t{StepName: \"implement\", Result: \"fail\"},\n\t\t\t\t{StepName: \"test\", Result: \"success\"},\n\t\t\t},\n\t\t},\n\t}\n\n\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n\tdata, err := c.Collect(context.Background(), evoStore, capStore)\n\trequire.NoError(t, err)\n\n\tassert.Len(t, data.Captures, 2)\n\tassert.Len(t, data.Captures[\"run-10\"], 1)\n\tassert.Len(t, data.Captures[\"run-11\"], 2)\n\tassert.Equal(t, \"implement\", data.Captures[\"run-10\"][0].StepName)\n\tassert.Equal(t, \"fail\", data.Captures[\"run-11\"][0].Result)\n}\n\n// ===========================================================================\n// Integration tests\n// ===========================================================================\n\nfunc TestIntegration_CorruptPromptDetectedAndFixed(t *testing.T) {\n\t// Full cycle: corrupt a prompt → run evolution → verify it produces a fix.\n\tdir := setupOrchestratorDir(t,\n\t\t`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  implement:success -> done\n  implement:fail -> abort\n}`,\n\t\t// Start with a \"corrupted\" prompt (conversational text, no useful instructions)\n\t\t\"Sure! I've updated the prompt to include better instructions.\",\n\t\t\"# Knowledge Base: develop\\n\",\n\t)\n\n\t// The evolution pipeline should detect the corruption and fix it.\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t// Reflector identifies the corruption\n\t\t\t`{\"lessons\": [{\"id\": \"L-FIX\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Prompt was corrupted with conversational text\", \"suggested_action\": \"Restore proper prompt structure\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t\t// Curator returns a proper prompt\n\t\t\t\"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate user inputs\\n\",\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\trequire.Len(t, result.Changes, 1)\n\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n\n\t// Verify the prompt is now proper.\n\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n\tassert.Contains(t, string(content), \"Always validate user inputs\")\n\tassert.NotContains(t, string(content), \"Sure!\")\n}\n\nfunc TestIntegration_StabilityNoCyclesNoDrift(t *testing.T) {\n\t// Stability test: run N evolution cycles where the reflector finds no\n\t// lessons. The workflow should remain unchanged.\n\tworkflow := `workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  implement:success -> done\n  implement:fail -> abort\n}`\n\tprompt := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n\tdir := setupOrchestratorDir(t, workflow, prompt, \"# Knowledge Base: develop\\n\")\n\n\toriginalWorkflow, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n\toriginalPrompt, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n\n\tconst cycles = 5\n\tfor i := 0; i < cycles; i++ {\n\t\tllm := &scriptedLLM{\n\t\t\tresponses: []string{\n\t\t\t\t`{\"classification\": \"feature\"}`,\n\t\t\t\t`{\"lessons\": []}`,\n\t\t\t},\n\t\t}\n\n\t\torch := NewOrchestrator(OrchestratorConfig{\n\t\t\tProjectDir:    dir,\n\t\t\tWorkflowName:  \"develop\",\n\t\t\tLLM:           llm,\n\t\t\tMinConfidence: \"medium\",\n\t\t})\n\n\t\tresult, err := orch.Run(context.Background(), fmt.Sprintf(\"run-%d\", i+1), nil, nil)\n\t\trequire.NoError(t, err, \"cycle %d failed\", i)\n\t\tassert.Empty(t, result.Changes, \"cycle %d should have no changes\", i)\n\t}\n\n\t// After N cycles, workflow and prompt should be identical.\n\tfinalWorkflow, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n\tfinalPrompt, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n\tassert.Equal(t, string(originalWorkflow), string(finalWorkflow), \"workflow drifted after %d cycles\", cycles)\n\tassert.Equal(t, string(originalPrompt), string(finalPrompt), \"prompt drifted after %d cycles\", cycles)\n}\n\nfunc TestIntegration_FullCycleWithStores(t *testing.T) {\n\t// End-to-end with actual store mocks: collect → classify → reflect →\n\t// apply → save to store.\n\tdir := setupOrchestratorDir(t,\n\t\t`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  implement:success -> done\n  implement:fail -> abort\n}`,\n\t\t\"# Prompt\\n\\nWrite code.\\n\",\n\t\t\"# Knowledge Base: develop\\n\",\n\t)\n\n\truns := []*domain.Run{\n\t\t{ID: \"run-100\", WorkflowName: \"develop\", ProjectDir: dir},\n\t}\n\tevoStore := &mockEvolutionStore{\n\t\tlastEvolution: &ports.EvolutionEntry{TriggerRunID: \"run-99\"},\n\t\truns:          runs,\n\t}\n\tcapStore := &mockCaptureStore{\n\t\tcaptures: map[string][]*domain.StepExecution{\n\t\t\t\"run-100\": {\n\t\t\t\t{StepName: \"implement\", Result: \"success\"},\n\t\t\t},\n\t\t},\n\t}\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t`{\"lessons\": [{\"id\": \"L-STORE\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Missing validation\", \"suggested_action\": \"Add validation rule\", \"evidence\": [\"run-100\"], \"confidence\": \"high\"}]}`,\n\t\t\t\"# Prompt\\n\\nWrite code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n\",\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-100\", evoStore, capStore)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"bug\", result.Classification)\n\tassert.Len(t, result.Changes, 1)\n\n\t// Verify evolution was saved to store.\n\trequire.Len(t, evoStore.saved, 1)\n\tassert.Equal(t, \"run-100\", evoStore.saved[0].TriggerRunID)\n\n\t// Verify ListRunsSince was called correctly.\n\trequire.Len(t, evoStore.listCalls, 1)\n\tassert.Equal(t, \"run-99\", evoStore.listCalls[0].sinceRunID)\n}\n","numLines":961,"startLine":1,"totalLines":961}}}
