``\\n\\nI added the validation rule.\"\n   380→\tllm := &fakeLLM{response: fencedResponse}\n   381→\n   382→\taudit := &AuditLogger{ProjectDir: dir}\n   383→\tc := &Curator{LLM: llm, Audit: audit}\n   384→\tlesson := &Lesson{\n   385→\t\tTarget:          \".cloche/prompts/implement.md\",\n   386→\t\tInsight:         \"Missing input validation\",\n   387→\t\tSuggestedAction: \"Add validation rule\",\n   388→\t}\n   389→\n   390→\t_, err := c.Apply(context.Background(), dir, lesson)\n   391→\trequire.NoError(t, err)\n   392→\n   393→\tcontent, err := os.ReadFile(promptPath)\n   394→\trequire.NoError(t, err)\n   395→\n   396→\t// Should contain the actual prompt content, not the commentary\n   397→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   398→\tassert.Contains(t, string(content), \"Always validate inputs\")\n   399→\tassert.NotContains(t, string(content), \"Here is the updated prompt\")\n   400→\tassert.NotContains(t, string(content), \"I added the validation rule\")\n   401→\tassert.NotContains(t, string(content), \"```\")\n   402→}\n   403→\n   404→func TestCuratorRejectsConversationalMetaText(t *testing.T) {\n   405→\tdir := t.TempDir()\n   406→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"fix.md\")\n   407→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   408→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   409→\toriginal := \"# Fix Prompt\\n\\nFix bugs carefully.\\n\"\n   410→\tos.WriteFile(promptPath, []byte(original), 0644)\n   411→\n   412→\t// LLM returns conversational meta-text\n   413→\tllm := &fakeLLM{response: \"I need write permission to update the file. Could you grant access to .cloche/prompts/fix.md?\"}\n   414→\taudit := &AuditLogger{ProjectDir: dir}\n   415→\tc := &Curator{LLM: llm, Audit: audit}\n   416→\tlesson := &Lesson{\n   417→\t\tTarget:          \".cloche/prompts/fix.md\",\n   418→\t\tInsight:         \"Missing error context\",\n   419→\t\