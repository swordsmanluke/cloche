lementSibling;\n    if (existing && existing.classList.contains('diff-block')) {\n        existing.remove();\n        return;\n    }\n    var file = el.getAttribute('data-file');\n    var sha = el.getAttribute('data-sha');\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n        .then(function(r) { return r.text(); })\n        .then(function(text) {\n            var pre = document.createElement('pre');\n            pre.className = 'diff-block';\n            pre.textContent = text || '(no diff available)';\n            el.parentNode.insertBefore(pre, el.nextSibling);\n        });\n}\n```\n\n---\n\n### Backend API Handlers:\n\n#### 1. **handleAPIProjectInfo** (handler.go, lines 939-1025):\nFetches project information including prompt files and their git history:\n- Reads Docker image from `Dockerfile`\n- Reads version number\n- **Scans `.cloche/prompts/` directory** for all prompt files\n- **Executes git log** for each file to retrieve commit history:\n  ```go\n  cmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n  ```\n- Returns JSON with: docker_image, version, and prompt_files array containing path + commit history\n\n#### 2. **handleAPIPromptDiff** (handler.go, lines 1027-1056):\nRetrieves the actual git diff for a specific commit:\n- Takes `file` and `sha` query parameters\n- Executes: `git diff <sha>^..<sha> -- <file>`\n- Returns plain text diff output\n- Includes SHA validation to prevent injection\n\n---\n\n### CSS Styling for Expandable Sections (style.css):\n\n#### Details Element Styling (lines 197-221):\n```css\ndetails {\n    margin: 0.5rem 0;\n}\n\ndetails summary {\n    cursor: pointer;\n    font-weight: 600;\n    font-size: 0.85rem;\n    color: var(--text-muted);\n}\n\ndetails pre {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 0