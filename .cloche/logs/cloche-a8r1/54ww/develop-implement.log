{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FXStxas7wvJknRqPnXr2Cg","type":"tool_result","content":"  1601→func formatTime(t time.Time) string {\n  1602→\tif t.IsZero() {\n  1603→\t\treturn \"\"\n  1604→\t}\n  1605→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1606→}\n  1607→\n  1608→func formatDuration(start, end time.Time) string {\n  1609→\tif start.IsZero() || end.IsZero() {\n  1610→\t\treturn \"\"\n  1611→\t}\n  1612→\td := end.Sub(start)\n  1613→\tif d < time.Second {\n  1614→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1615→\t}\n  1616→\tif d < time.Minute {\n  1617→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1618→\t}\n  1619→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1620→}\n  1621→\n  1622→// formatSmartDuration formats a duration into a human-friendly short string.\n  1623→// Examples: \"3s\", \"2m\", \"1h20m\", \"3h\".\n  1624→func formatSmartDuration(d time.Duration) string {\n  1625→\tif d < time.Minute {\n  1626→\t\treturn fmt.Sprintf(\"%ds\", int(d.Seconds()))\n  1627→\t}\n  1628→\th := int(d.Hours())\n  1629→\tm := int(d.Minutes()) % 60\n  1630→\tif h == 0 {\n  1631→\t\treturn fmt.Sprintf(\"%dm\", m)\n  1632→\t}\n  1633→\tif m == 0 {\n  1634→\t\treturn fmt.Sprintf(\"%dh\", h)\n  1635→\t}\n  1636→\treturn fmt.Sprintf(\"%dh%dm\", h, m)\n  1637→}\n  1638→\n  1639→// roundRelativeTime rounds a duration to neat display units:\n  1640→// <1m -> \"<1m ago\", then 1m,5m,10m,15m,30m,45m,1h,2h,3h,...24h,\n  1641→// then days.\n  1642→func roundRelativeTime(d time.Duration) string {\n  1643→\tif d < time.Minute {\n  1644→\t\treturn \"<1m ago\"\n  1645→\t}\n  1646→\tmins := int(d.Minutes())\n  1647→\thours := int(d.Hours())\n  1648→\tdays := hours / 24\n  1649→\n  1650→\tif days > 0 {\n  1651→\t\tif days == 1 {\n  1652→\t\t\treturn \"1 day ago\"\n  1653→\t\t}\n  1654→\t\treturn fmt.Sprintf(\"%d days ago\", days)\n  1655→\t}\n  1656→\tif hours >= 1 {\n  1657→\t\tif hours == 1 {\n  1658→\t\t\treturn \"1 hour ago\"\n  1659→\t\t}\n  1660→\t\treturn fmt.Sprintf(\"%d hours ago\", hours)\n  1661→\t}\n  1662→\t// Round minutes to neat breakpoints\n  1663→\tswitch {\n  1664→\tcase mins < 3:\n  1665→\t\treturn \"1m ago\"\n  1666→\tcase mins < 8:\n  1667→\t\treturn \"5m ago\"\n  1668→\tcase mins < 13:\n  1669→\t\treturn \"10m ago\"\n  1670→\tcase mins < 20:\n  1671→\t\treturn \"15m ago\"\n  1672→\tcase mins < 38:\n  1673→\t\treturn \"30m ago\"\n  1674→\tcase mins < 53:\n  1675→\t\treturn \"45m ago\"\n  1676→\tdefault:\n  1677→\t\treturn \"1 hour ago\"\n  1678→\t}\n  1679→}\n  1680→\n  1681→// formatRunTiming returns a smart timing string for display on the Runs page.\n  1682→// Running: \"5m\" (just duration so far)\n  1683→// Completed: \"20m, 1 hour ago\"\n  1684→// Pending: \"\"\n  1685→func formatRunTiming(state domain.RunState, startedAt, completedAt time.Time) string {\n  1686→\treturn formatRunTimingAt(state, startedAt, completedAt, time.Now())\n  1687→}\n  1688→\n  1689→// formatRunTimingAt is the testable version of formatRunTiming with an explicit \"now\".\n  1690→func formatRunTimingAt(state domain.RunState, startedAt, completedAt, now time.Time) string {\n  1691→\tif startedAt.IsZero() {\n  1692→\t\treturn \"\"\n  1693→\t}\n  1694→\tswitch state {\n  1695→\tcase domain.RunStateRunning:\n  1696→\t\td := now.Sub(startedAt)\n  1697→\t\treturn formatSmartDuration(d)\n  1698→\tdefault:\n  1699→\t\tif completedAt.IsZero() {\n  1700→\t\t\treturn \"\"\n  1701→\t\t}\n  1702→\t\td := completedAt.Sub(startedAt)\n  1703→\t\tago := now.Sub(completedAt)\n  1704→\t\treturn formatSmartDuration(d) + \", \" + roundRelativeTime(ago)\n  1705→\t}\n  1706→}\n  1707→\n  1708→func truncate(s string, n int) string {\n  1709→\tif len(s) <= n {\n  1710→\t\treturn s\n  1711→\t}\n  1712→\treturn s[:n] + \"...\"\n  1713→}\n  1714→\n  1715→func shortContainerID(id string) string {\n  1716→\tif len(id) > 12 {\n  1717→\t\treturn id[:12]\n  1718→\t}\n  1719→\treturn id\n  1720→}\n  1721→\n  1722→// projectLabels builds a mapping from full project directory paths to short\n  1723→// display labels. Each label is the final directory component (e.g.\n  1724→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1725→// the same final name, the parent directory is prepended to disambiguate\n  1726→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1727→func projectLabels(dirs []string) map[string]string {\n  1728→\tlabels := make(map[string]string, len(dirs))\n  1729→\t// Group dirs by their base name to detect conflicts.\n  1730→\tbyBase := map[string][]string{}\n  1731→\tfor _, d := range dirs {\n  1732→\t\tbase := filepath.Base(d)\n  1733→\t\tbyBase[base] = append(byBase[base], d)\n  1734→\t}\n  1735→\tfor base, paths := range byBase {\n  1736→\t\tif len(paths) == 1 {\n  1737→\t\t\tlabels[paths[0]] = base\n  1738→\t\t} else {\n  1739→\t\t\tfor _, p := range paths {\n  1740→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1741→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1742→\t\t\t}\n  1743→\t\t}\n  1744→\t}\n  1745→\treturn labels\n  1746→}\n  1747→\n  1748→type projectEntry struct {\n  1749→\tDir            string\n  1750→\tLabel          string"}]},"parent_tool_use_id":"toolu_01W2hdAPWRtb8iwNr2VUPxQ9","session_id":"2f5b3a10-2c53-4a3a-a212-5498e6e5d993","uuid":"392e9688-fd94-45ce-ad7b-9e83419280f8"}
