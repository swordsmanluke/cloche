o the live broadcaster.\n1063-// For completed runs, it serves the archived full.log then closes.\n1064:func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n1065-\tid := r.PathValue(\"id\")\n1066-\n1067-\trun, err := h.store.GetRun(r.Context(), id)"}]},"parent_tool_use_id":"toolu_01HjMkovk1RuozHnFnZS9pvt","session_id":"143fc353-8adb-4cb0-8d24-a68ddf79996d","uuid":"6ab69568-0729-4885-aeb8-d993e1468ac7"}
