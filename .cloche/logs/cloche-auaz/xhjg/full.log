[2026-03-13T20:04:01Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PjystFz75fJyrYJRFNtkqw","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"net/http\"\n     8→\t\"net/http/httptest\"\n     9→\t\"os\"\n    10→\t\"path/filepath\"\n    11→\t\"strings\"\n    12→\t\"testing\"\n    13→\t\"time\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    16→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    17→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    18→\t\"github.com/stretchr/testify/assert\"\n    19→\t\"github.com/stretchr/testify/require\"\n    20→)\n    21→\n    22→func setupHandlerWithBroadcaster(t *testing.T) (*Handler, *sqlite.Store, *logstream.Broadcaster) {\n    23→\tt.Helper()\n    24→\tstore, err := sqlite.NewStore(\":memory:\")\n    25→\trequire.NoError(t, err)\n    26→\tt.Cleanup(func() { store.Close() })\n    27→\n    28→\tb := logstream.NewBroadcaster()\n    29→\th, err := NewHandler(store, store, WithLogBroadcaster(b))\n    30→\trequire.NoError(t, err)\n    31→\treturn h, store, b\n    32→}\n    33→\n    34→func TestSSE_CompletedRun_ServesFullLog(t *testing.T) {\n    35→\th, store, _ := setupHandlerWithBroadcaster(t)\n    36→\n    37→\tdir := t.TempDir()\n    38→\n    39→\t// Create a completed run\n    40→\tctx := context.Background()\n    41→\trun := domain.NewRun(\"sse-test-1\", \"develop\")\n    42→\trun.ProjectDir = dir\n    43→\trun.Start()\n    44→\trun.ContainerID = \"abc123\"\n    45→\trun.Complete(domain.RunStateSucceeded)\n    46→\trequire.NoError(t, store.CreateRun(ctx, run))\n    47→\n    48→\t// Write full.log\n    49→\toutputDir := filepath.Join(dir, \".cloche\", \"sse-test-1\", \"output\")\n    50→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n    51→\tlogContent := \"[2026-03-03T10:15:00Z] [status] step_started: build\\n\" +\n    52→\t\t\"[2026-03-03T10:15:01Z] [script] npm run build\\n\" +\n    53→\t\t\"[2026-03-03T10:15:02Z] [llm] Claude: Starting analysis\\n\"\n    54→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"full.log\"), []byte(logContent), 0644))\n    55→\n    56→\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-test-1/stream\", nil)\n    57→\tw := httptest.NewRecorder()\n    58→\th.ServeHTTP(w, req)\n    59→\n    60→\tassert.Equal(t, http.StatusOK, w.Code)\n    61→\tassert.Equal(t, \"text/event-stream\", w.Header().Get(\"Content-Type\"))\n    62→\n    63→\t// Parse SSE events\n    64→\tbody := w.Body.String()\n    65→\tlines := strings.Split(body, \"\\n\")\n    66→\n    67→\tvar events []logstream.LogLine\n    68→\tfor _, line := range lines {\n    69→\t\tif strings.HasPrefix(line, \"data: \") {\n    70→\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n    71→\t\t\tvar ll logstream.LogLine\n    72→\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n    73→\t\t\t\tevents = append(events, ll)\n    74→\t\t\t}\n    75→\t\t}\n    76→\t}\n    77→\n    78→\trequire.Len(t, events, 3)\n    79→\tassert.Equal(t, \"status\", events[0].Type)\n    80→\tassert.Equal(t, \"step_started: build\", events[0].Content)\n    81→\tassert.Equal(t, \"script\", events[1].Type)\n    82→\tassert.Equal(t, \"npm run build\", events[1].Content)\n    83→\tassert.Equal(t, \"llm\", events[2].Type)\n    84→\tassert.Equal(t, \"Claude: Starting analysis\", events[2].Content)\n    85→\n    86→\t// Should contain done event\n    87→\tassert.Contains(t, body, \"event: done\")\n    88→}\n    89→\n    90→func TestSSE_ActiveRun_StreamsLive(t *testing.T) {\n    91→\th, store, b := setupHandlerWithBroadcaster(t)\n    92→\n    93→\t// Create a running run\n    94→\tctx := context.Background()\n    95→\trun := domain.NewRun(\"sse-live-1\", \"develop\")\n    96→\trun.ProjectDir = t.TempDir()\n    97→\trun.Start()\n    98→\trun.ContainerID = \"abc123\"\n    99→\trequire.NoError(t, store.CreateRun(ctx, run))\n   100→\n   101→\t// Start a subscriber to simulate an active broadcast\n   102→\tb.Subscribe(\"sse-live-1\")\n   103→\n   104→\t// Use a real HTTP server for streaming\n   105→\tsrv := httptest.NewServer(h)\n   106→\tdefer srv.Close()\n   107→\n   108→\t// Publish some lines in a goroutine\n   109→\tgo func() {\n   110→\t\ttime.Sleep(50 * time.Millisecond)\n   111→\t\tb.Publish(\"sse-live-1\", logstream.LogLine{\n   112→\t\t\tTimestamp: \"2026-03-03T10:15:00Z\",\n   113→\t\t\tType:      \"status\",\n   114→\t\t\tContent:   \"step_started: build\",\n   115→\t\t})\n   116→\t\ttime.Sleep(50 * time.Millisecond)\n   117→\t\tb.Publish(\"sse-live-1\", logstream.LogLine{\n   118→\t\t\tTimestamp: \"2026-03-03T10:15:01Z\",\n   119→\t\t\tType:      \"script\",\n   120→\t\t\tContent:   \"compiling...\",\n   121→\t\t})\n   122→\t\ttime.Sleep(50 * time.Millisecond)\n   123→\t\tb.Finish(\"sse-live-1\")\n   124→\t}()\n   125→\n   126→\tresp, err := http.Get(srv.URL + \"/api/runs/sse-live-1/stream\")\n   127→\trequire.NoError(t, err)\n   128→\tdefer resp.Body.Close()\n   129→\n   130→\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n   131→\tassert.Equal(t, \"text/event-stream\", resp.Header.Get(\"Content-Type\"))\n   132→\n   133→\tvar events []logstream.LogLine\n   134→\tscanner := bufio.NewScanner(resp.Body)\n   135→\tfor scanner.Scan() {\n   136→\t\tline := scanner.Text()\n   137→\t\tif strings.HasPrefix(line, \"data: \") {\n   138→\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n   139→\t\t\tvar ll logstream.LogLine\n   140→\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n   141→\t\t\t\tevents = append(events, ll)\n   142→\t\t\t}\n   143→\t\t}\n   144→\t\tif strings.HasPrefix(line, \"event: done\") {\n   145→\t\t\tbreak\n   146→\t\t}\n   147→\t}\n   148→\n   149→\trequire.Len(t, events, 2)\n   150→\tassert.Equal(t, \"status\", events[0].Type)\n   151→\tassert.Equal(t, \"step_started: build\", events[0].Content)\n   152→\tassert.Equal(t, \"script\", events[1].Type)\n   153→\tassert.Equal(t, \"compiling...\", events[1].Content)\n   154→}\n   155→\n   156→func TestSSE_RunNotFound(t *testing.T) {\n   157→\th, _, _ := setupHandlerWithBroadcaster(t)\n   158→\n   159→\treq := httptest.NewRequest(\"GET\", \"/api/runs/nonexistent/stream\", nil)\n   160→\tw := httptest.NewRecorder()\n   161→\th.ServeHTTP(w, req)\n   162→\n   163→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   164→}\n   165→\n   166→func TestSSE_NoBroadcaster_ActiveRun(t *testing.T) {\n   167→\tstore, err := sqlite.NewStore(\":memory:\")\n   168→\trequire.NoError(t, err)\n   169→\tdefer store.Close()\n   170→\n   171→\t// Handler without broadcaster\n   172→\th, err := NewHandler(store, store)\n   173→\trequire.NoError(t, err)\n   174→\n   175→\tctx := context.Background()\n   176→\trun := domain.NewRun(\"no-bc-1\", \"develop\")\n   177→\trun.Start()\n   178→\trun.ContainerID = \"abc123\"\n   179→\trequire.NoError(t, store.CreateRun(ctx, run))\n   180→\n   181→\treq := httptest.NewRequest(\"GET\", \"/api/runs/no-bc-1/stream\", nil)\n   182→\tw := httptest.NewRecorder()\n   183→\th.ServeHTTP(w, req)\n   184→\n   185→\tassert.Equal(t, http.StatusServiceUnavailable, w.Code)\n   186→}\n   187→\n   188→func TestParseFullLogLine(t *testing.T) {\n   189→\ttests := []struct {\n   190→\t\tinput    string\n   191→\t\texpected logstream.LogLine\n   192→\t}{\n   193→\t\t{\n   194→\t\t\tinput: \"[2026-03-03T10:15:00Z] [status] step_started: build\",\n   195→\t\t\texpected: logstream.LogLine{\n   196→\t\t\t\tTimestamp: \"2026-03-03T10:15:00Z\",\n   197→\t\t\t\tType:      \"status\",\n   198→\t\t\t\tContent:   \"step_started: build\",\n   199→\t\t\t},\n   200→\t\t},\n   201→\t\t{\n   202→\t\t\tinput: \"[2026-03-03T10:15:01Z] [script] npm run build\",\n   203→\t\t\texpected: logstream.LogLine{\n   204→\t\t\t\tTimestamp: \"2026-03-03T10:15:01Z\",\n   205→\t\t\t\tType:      \"script\",\n   206→\t\t\t\tContent:   \"npm run build\",\n   207→\t\t\t},\n   208→\t\t},\n   209→\t\t{\n   210→\t\t\tinput: \"[2026-03-03T10:15:02Z] [llm] Claude: Reading files...\",\n   211→\t\t\texpected: logstream.LogLine{\n   212→\t\t\t\tTimestamp: \"2026-03-03T10:15:02Z\",\n   213→\t\t\t\tType:      \"llm\",\n   214→\t\t\t\tContent:   \"Claude: Reading files...\",\n   215→\t\t\t},\n   216→\t\t},\n   217→\t\t{\n   218→\t\t\tinput: \"unstructured line\",\n   219→\t\t\texpected: logstream.LogLine{\n   220→\t\t\t\tType:    \"script\",\n   221→\t\t\t\tContent: \"unstructured line\",\n   222→\t\t\t},\n   223→\t\t},\n   224→\t}\n   225→\n   226→\tfor _, tt := range tests {\n   227→\t\tt.Run(tt.input, func(t *testing.T) {\n   228→\t\t\tresult := parseFullLogLine(tt.input)\n   229→\t\t\tassert.Equal(t, tt.expected.Type, result.Type)\n   230→\t\t\tassert.Equal(t, tt.expected.Content, result.Content)\n   231→\t\t\tif tt.expected.Timestamp != \"\" {\n   232→\t\t\t\tassert.Equal(t, tt.expected.Timestamp, result.Timestamp)\n   233→\t\t\t}\n   234→\t\t})\n   235→\t}\n   236→}\n   237→\n   238→func TestSSE_CompletedRun_LargeJSONLines(t *testing.T) {\n   239→\th, store, _ := setupHandlerWithBroadcaster(t)\n   240→\n   241→\tdir := t.TempDir()\n   242→\n   243→\tctx := context.Background()\n   244→\trun := domain.NewRun(\"sse-large-1\", \"develop\")\n   245→\trun.ProjectDir = dir\n   246→\trun.Start()\n   247→\trun.ContainerID = \"abc123\"\n   248→\trun.Complete(domain.RunStateSucceeded)\n   249→\trequire.NoError(t, store.CreateRun(ctx, run))\n   250→\n   251→\t// Build a large assistant event (>64KB) to simulate real Claude Code output.\n   252→\t// Default bufio.Scanner buffer is 64KB; this verifies we handle larger lines.\n   253→\tlargeText := strings.Repeat(\"x\", 100*1024) // 100KB of text\n   254→\tassistantJSON := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"` + largeText + `\"}]}}`\n   255→\n   256→\toutputDir := filepath.Join(dir, \".cloche\", \"sse-large-1\", \"output\")\n   257→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   258→\tlogContent := \"[2026-03-03T10:15:00Z] [status] step_started: build\\n\" +\n   259→\t\t\"[2026-03-03T10:15:01Z] [llm] \" + assistantJSON + \"\\n\" +\n   260→\t\t\"[2026-03-03T10:15:02Z] [status] step_completed: build -> success\\n\"\n   261→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"full.log\"), []byte(logContent), 0644))\n   262→\n   263→\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-large-1/stream\", nil)\n   264→\tw := httptest.NewRecorder()\n   265→\th.ServeHTTP(w, req)\n   266→\n   267→\tassert.Equal(t, http.StatusOK, w.Code)\n   268→\n   269→\tbody := w.Body.String()\n   270→\tvar events []logstream.LogLine\n   271→\tfor _, line := range strings.Split(body, \"\\n\") {\n   272→\t\tif strings.HasPrefix(line, \"data: \") {\n   273→\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n   274→\t\t\tvar ll logstream.LogLine\n   275→\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n   276→\t\t\t\tevents = append(events, ll)\n   277→\t\t\t}\n   278→\t\t}\n   279→\t}\n   280→\n   281→\t// All three lines should be present: status, llm (parsed from large JSON), status\n   282→\trequire.Len(t, events, 3, \"expected all log lines including those after large JSON line\")\n   283→\tassert.Equal(t, \"status\", events[0].Type)\n   284→\tassert.Equal(t, \"step_started: build\", events[0].Content)\n   285→\tassert.Equal(t, \"llm\", events[1].Type)\n   286→\tassert.Contains(t, events[1].Content, largeText)\n   287→\tassert.Equal(t, \"status\", events[2].Type)\n   288→\tassert.Equal(t, \"step_completed: build -> success\", events[2].Content)\n   289→\n   290→\tassert.Contains(t, body, \"event: done\")\n   291→}\n   292→\n   293→func TestSSE_CompletedRun_NoFullLog(t *testing.T) {\n   294→\th, store, _ := setupHandlerWithBroadcaster(t)\n   295→\n   296→\t// Create a completed run with no full.log\n   297→\tctx := context.Background()\n   298→\trun := domain.NewRun(\"sse-nolog-1\", \"develop\")\n   299→\trun.ProjectDir = t.TempDir()\n   300→\trun.Start()\n   301→\trun.ContainerID = \"abc123\"\n   302→\trun.Complete(domain.RunStateSucceeded)\n   303→\trequire.NoError(t, store.CreateRun(ctx, run))\n   304→\n   305→\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-nolog-1/stream\", nil)\n   306→\tw := httptest.NewRecorder()\n   307→\th.ServeHTTP(w, req)\n   308→\n   309→\tassert.Equal(t, http.StatusOK, w.Code)\n   310→\tassert.Contains(t, w.Body.String(), \"event: done\")\n   311→}\n   312→"}]},"parent_tool_use_id":null,"session_id":"143fc353-8adb-4cb0-8d24-a68ddf79996d","uuid":"79d0863c-5857-4956-ab20-bae1e440199e","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler_stream_test.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc setupHandlerWithBroadcaster(t *testing.T) (*Handler, *sqlite.Store, *logstream.Broadcaster) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\tb := logstream.NewBroadcaster()\n\th, err := NewHandler(store, store, WithLogBroadcaster(b))\n\trequire.NoError(t, err)\n\treturn h, store, b\n}\n\nfunc TestSSE_CompletedRun_ServesFullLog(t *testing.T) {\n\th, store, _ := setupHandlerWithBroadcaster(t)\n\n\tdir := t.TempDir()\n\n\t// Create a completed run\n\tctx := context.Background()\n\trun := domain.NewRun(\"sse-test-1\", \"develop\")\n\trun.ProjectDir = dir\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\t// Write full.log\n\toutputDir := filepath.Join(dir, \".cloche\", \"sse-test-1\", \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\tlogContent := \"[2026-03-03T10:15:00Z] [status] step_started: build\\n\" +\n\t\t\"[2026-03-03T10:15:01Z] [script] npm run build\\n\" +\n\t\t\"[2026-03-03T10:15:02Z] [llm] Claude: Starting analysis\\n\"\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"full.log\"), []byte(logContent), 0644))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-test-1/stream\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Equal(t, \"text/event-stream\", w.Header().Get(\"Content-Type\"))\n\n\t// Parse SSE events\n\tbody := w.Body.String()\n\tlines := strings.Split(body, \"\\n\")\n\n\tvar events []logstream.LogLine\n\tfor _, line := range lines {\n\t\tif strings.HasPrefix(line, \"data: \") {\n\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n\t\t\tvar ll logstream.LogLine\n\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n\t\t\t\tevents = append(events, ll)\n\t\t\t}\n\t\t}\n\t}\n\n\trequire.Len(t, events, 3)\n\tassert.Equal(t, \"status\", events[0].Type)\n\tassert.Equal(t, \"step_started: build\", events[0].Content)\n\tassert.Equal(t, \"script\", events[1].Type)\n\tassert.Equal(t, \"npm run build\", events[1].Content)\n\tassert.Equal(t, \"llm\", events[2].Type)\n\tassert.Equal(t, \"Claude: Starting analysis\", events[2].Content)\n\n\t// Should contain done event\n\tassert.Contains(t, body, \"event: done\")\n}\n\nfunc TestSSE_ActiveRun_StreamsLive(t *testing.T) {\n\th, store, b := setupHandlerWithBroadcaster(t)\n\n\t// Create a running run\n\tctx := context.Background()\n\trun := domain.NewRun(\"sse-live-1\", \"develop\")\n\trun.ProjectDir = t.TempDir()\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\t// Start a subscriber to simulate an active broadcast\n\tb.Subscribe(\"sse-live-1\")\n\n\t// Use a real HTTP server for streaming\n\tsrv := httptest.NewServer(h)\n\tdefer srv.Close()\n\n\t// Publish some lines in a goroutine\n\tgo func() {\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\tb.Publish(\"sse-live-1\", logstream.LogLine{\n\t\t\tTimestamp: \"2026-03-03T10:15:00Z\",\n\t\t\tType:      \"status\",\n\t\t\tContent:   \"step_started: build\",\n\t\t})\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\tb.Publish(\"sse-live-1\", logstream.LogLine{\n\t\t\tTimestamp: \"2026-03-03T10:15:01Z\",\n\t\t\tType:      \"script\",\n\t\t\tContent:   \"compiling...\",\n\t\t})\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\tb.Finish(\"sse-live-1\")\n\t}()\n\n\tresp, err := http.Get(srv.URL + \"/api/runs/sse-live-1/stream\")\n\trequire.NoError(t, err)\n\tdefer resp.Body.Close()\n\n\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n\tassert.Equal(t, \"text/event-stream\", resp.Header.Get(\"Content-Type\"))\n\n\tvar events []logstream.LogLine\n\tscanner := bufio.NewScanner(resp.Body)\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"data: \") {\n\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n\t\t\tvar ll logstream.LogLine\n\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n\t\t\t\tevents = append(events, ll)\n\t\t\t}\n\t\t}\n\t\tif strings.HasPrefix(line, \"event: done\") {\n\t\t\tbreak\n\t\t}\n\t}\n\n\trequire.Len(t, events, 2)\n\tassert.Equal(t, \"status\", events[0].Type)\n\tassert.Equal(t, \"step_started: build\", events[0].Content)\n\tassert.Equal(t, \"script\", events[1].Type)\n\tassert.Equal(t, \"compiling...\", events[1].Content)\n}\n\nfunc TestSSE_RunNotFound(t *testing.T) {\n\th, _, _ := setupHandlerWithBroadcaster(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/nonexistent/stream\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestSSE_NoBroadcaster_ActiveRun(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\t// Handler without broadcaster\n\th, err := NewHandler(store, store)\n\trequire.NoError(t, err)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"no-bc-1\", \"develop\")\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/no-bc-1/stream\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusServiceUnavailable, w.Code)\n}\n\nfunc TestParseFullLogLine(t *testing.T) {\n\ttests := []struct {\n\t\tinput    string\n\t\texpected logstream.LogLine\n\t}{\n\t\t{\n\t\t\tinput: \"[2026-03-03T10:15:00Z] [status] step_started: build\",\n\t\t\texpected: logstream.LogLine{\n\t\t\t\tTimestamp: \"2026-03-03T10:15:00Z\",\n\t\t\t\tType:      \"status\",\n\t\t\t\tContent:   \"step_started: build\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tinput: \"[2026-03-03T10:15:01Z] [script] npm run build\",\n\t\t\texpected: logstream.LogLine{\n\t\t\t\tTimestamp: \"2026-03-03T10:15:01Z\",\n\t\t\t\tType:      \"script\",\n\t\t\t\tContent:   \"npm run build\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tinput: \"[2026-03-03T10:15:02Z] [llm] Claude: Reading files...\",\n\t\t\texpected: logstream.LogLine{\n\t\t\t\tTimestamp: \"2026-03-03T10:15:02Z\",\n\t\t\t\tType:      \"llm\",\n\t\t\t\tContent:   \"Claude: Reading files...\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tinput: \"unstructured line\",\n\t\t\texpected: logstream.LogLine{\n\t\t\t\tType:    \"script\",\n\t\t\t\tContent: \"unstructured line\",\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.input, func(t *testing.T) {\n\t\t\tresult := parseFullLogLine(tt.input)\n\t\t\tassert.Equal(t, tt.expected.Type, result.Type)\n\t\t\tassert.Equal(t, tt.expected.Content, result.Content)\n\t\t\tif tt.expected.Timestamp != \"\" {\n\t\t\t\tassert.Equal(t, tt.expected.Timestamp, result.Timestamp)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestSSE_CompletedRun_LargeJSONLines(t *testing.T) {\n\th, store, _ := setupHandlerWithBroadcaster(t)\n\n\tdir := t.TempDir()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"sse-large-1\", \"develop\")\n\trun.ProjectDir = dir\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\t// Build a large assistant event (>64KB) to simulate real Claude Code output.\n\t// Default bufio.Scanner buffer is 64KB; this verifies we handle larger lines.\n\tlargeText := strings.Repeat(\"x\", 100*1024) // 100KB of text\n\tassistantJSON := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"` + largeText + `\"}]}}`\n\n\toutputDir := filepath.Join(dir, \".cloche\", \"sse-large-1\", \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\tlogContent := \"[2026-03-03T10:15:00Z] [status] step_started: build\\n\" +\n\t\t\"[2026-03-03T10:15:01Z] [llm] \" + assistantJSON + \"\\n\" +\n\t\t\"[2026-03-03T10:15:02Z] [status] step_completed: build -> success\\n\"\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"full.log\"), []byte(logContent), 0644))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-large-1/stream\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tbody := w.Body.String()\n\tvar events []logstream.LogLine\n\tfor _, line := range strings.Split(body, \"\\n\") {\n\t\tif strings.HasPrefix(line, \"data: \") {\n\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n\t\t\tvar ll logstream.LogLine\n\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n\t\t\t\tevents = append(events, ll)\n\t\t\t}\n\t\t}\n\t}\n\n\t// All three lines should be present: status, llm (parsed from large JSON), status\n\trequire.Len(t, events, 3, \"expected all log lines including those after large JSON line\")\n\tassert.Equal(t, \"status\", events[0].Type)\n\tassert.Equal(t, \"step_started: build\", events[0].Content)\n\tassert.Equal(t, \"llm\", events[1].Type)\n\tassert.Contains(t, events[1].Content, largeText)\n\tassert.Equal(t, \"status\", events[2].Type)\n\tassert.Equal(t, \"step_completed: build -> success\", events[2].Content)\n\n\tassert.Contains(t, body, \"event: done\")\n}\n\nfunc TestSSE_CompletedRun_NoFullLog(t *testing.T) {\n\th, store, _ := setupHandlerWithBroadcaster(t)\n\n\t// Create a completed run with no full.log\n\tctx := context.Background()\n\trun := domain.NewRun(\"sse-nolog-1\", \"develop\")\n\trun.ProjectDir = t.TempDir()\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-nolog-1/stream\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"event: done\")\n}\n","numLines":312,"startLine":1,"totalLines":312}}}
