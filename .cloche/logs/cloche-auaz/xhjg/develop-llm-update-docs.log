{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J46mChpRKWYfXJtsrtryQx","type":"tool_result","content":"diff --git a/internal/adapters/web/templates/run_detail.html b/internal/adapters/web/templates/run_detail.html\nindex 6d8773f..9cf87ca 100644\n--- a/internal/adapters/web/templates/run_detail.html\n+++ b/internal/adapters/web/templates/run_detail.html\n@@ -102,7 +102,10 @@\n     Log\n     <span id=\"log-status\" class=\"badge badge-running\" style=\"font-size:0.7rem; margin-left:0.5rem;\">Live</span>\n </h2>\n-<div id=\"log-viewer\" class=\"log-viewer\"><pre id=\"log-content\"></pre></div>\n+<div id=\"log-viewer\" class=\"log-viewer\">\n+    <button id=\"load-earlier-btn\" class=\"load-earlier-btn\" style=\"display:none\" onclick=\"loadEarlierLogs()\">Load earlier (<span id=\"load-earlier-count\">0</span> more lines)</button>\n+    <pre id=\"log-content\"></pre>\n+</div>\n {{end}}\n \n {{define \"scripts\"}}\n@@ -115,6 +118,10 @@\n     var logContent = document.getElementById('log-content');\n     var logViewer = document.getElementById('log-viewer');\n     var logStatus = document.getElementById('log-status');\n+    var loadEarlierBtn = document.getElementById('load-earlier-btn');\n+    var loadEarlierCount = document.getElementById('load-earlier-count');\n+    var skippedLines = 0;\n+\n     function appendLogLine(line) {\n         var span = document.createElement('span');\n         span.className = 'log-line log-type-' + (line.type || 'script');\n@@ -148,6 +155,16 @@\n             appendLogLine(line);\n         } catch(err) {}\n     };\n+    source.addEventListener('meta', function(e) {\n+        try {\n+            var meta = JSON.parse(e.data);\n+            skippedLines = meta.skipped || 0;\n+            if (skippedLines > 0) {\n+                loadEarlierCount.textContent = skippedLines;\n+                loadEarlierBtn.style.display = '';\n+            }\n+        } catch(err) {}\n+    });\n     source.addEventListener('done', function(e) {\n         markComplete();\n         source.close();\n@@ -284,6 +301,53 @@\n     }\n })();\n \n+// Load earlier log lines\n+    window.loadEarlierLogs = function() {\n+        var btn = document.getElementById('load-earlier-btn');\n+        var countEl = document.getElementById('load-earlier-count');\n+        btn.disabled = true;\n+        var prevText = btn.textContent;\n+        btn.textContent = 'Loading...';\n+\n+        var limit = 1000;\n+        var end = skippedLines;\n+\n+        fetch('/api/runs/' + runID + '/logs?end=' + end + '&limit=' + limit)\n+            .then(function(r) { return r.json(); })\n+            .then(function(data) {\n+                if (data.lines && data.lines.length > 0) {\n+                    var fragment = document.createDocumentFragment();\n+                    for (var i = 0; i < data.lines.length; i++) {\n+                        var line = data.lines[i];\n+                        var span = document.createElement('span');\n+                        span.className = 'log-line log-type-' + (line.type || 'script');\n+                        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';\n+                        fragment.appendChild(span);\n+                    }\n+                    // Preserve scroll position relative to existing content\n+                    var prevScrollHeight = logViewer.scrollHeight;\n+                    logContent.insertBefore(fragment, logContent.firstChild);\n+                    logViewer.scrollTop += logViewer.scrollHeight - prevScrollHeight;\n+                }\n+\n+                skippedLines = data.start || 0;\n+                if (skippedLines > 0) {\n+                    btn.disabled = false;\n+                    countEl.textContent = skippedLines;\n+                    btn.textContent = '';\n+                    btn.appendChild(document.createTextNode('Load earlier ('));\n+                    btn.appendChild(countEl);\n+                    btn.appendChild(document.createTextNode(' more lines)'));\n+                } else {\n+                    btn.style.display = 'none';\n+                }\n+            })\n+            .catch(function() {\n+                btn.disabled = false;\n+                btn.textContent = prevText;\n+            });\n+    };\n+\n // Cancel run\n     window.cancelRun = function(runID) {\n         var btn = document.getElementById('cancel-run-btn');","is_error":false}]},"parent_tool_use_id":"toolu_01FW1G2xTb2zHJawU3KSSB6C","session_id":"8530080f-5bbb-4b36-9913-140e127b35d2","uuid":"d4f257c8-f8ae-4417-929f-1568562dd0e2"}
