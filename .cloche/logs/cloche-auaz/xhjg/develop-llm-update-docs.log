{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hb52wmjMzBCGB3aDvWdCHj","type":"tool_result","content":"/workspace/internal/adapters/web/handler.go:\ttext, ok := logstream.ParseClaudeLine([]byte(line.Content))\n/workspace/internal/logstream/broadcaster.go:type LogLine struct {\n/workspace/internal/logstream/broadcaster.go:type Broadcaster struct {\n/workspace/internal/logstream/parse_test.go:func TestParseClaudeLine_AssistantText(t *testing.T) {\n/workspace/internal/logstream/parse_test.go:\ttext, ok := ParseClaudeLine([]byte(line))\n/workspace/internal/logstream/parse_test.go:func TestParseClaudeLine_AssistantToolUse(t *testing.T) {\n/workspace/internal/logstream/parse_test.go:\ttext, ok := ParseClaudeLine([]byte(line))\n/workspace/internal/logstream/parse_test.go:func TestParseClaudeLine_AssistantToolOnly(t *testing.T) {\n/workspace/internal/logstream/parse_test.go:\ttext, ok := ParseClaudeLine([]byte(line))\n/workspace/internal/logstream/parse_test.go:func TestParseClaudeLine_AssistantToolNoInput(t *testing.T) {\n/workspace/internal/logstream/parse_test.go:\ttext, ok := ParseClaudeLine([]byte(line))\n/workspace/internal/logstream/parse_test.go:func TestParseClaudeLine_AssistantEmptyContent(t *testing.T) {\n/workspace/internal/logstream/parse_test.go:\t_, ok := ParseClaudeLine([]byte(line))\n/workspace/internal/logstream/parse_test.go:func TestParseClaudeLine_SystemEvent(t *testing.T) {\n/workspace/internal/logstream/parse_test.go:\t_, ok := ParseClaudeLine([]byte(line))\n/workspace/internal/logstream/parse_test.go:func TestParseClaudeLine_UserEvent(t *testing.T) {\n/workspace/internal/logstream/parse_test.go:\t_, ok := ParseClaudeLine([]byte(line))\n/workspace/internal/logstream/parse_test.go:func TestParseClaudeLine_TextDelta(t *testing.T) {\n/workspace/internal/logstream/parse_test.go:\ttext, ok := ParseClaudeLine([]byte(line))\n/workspace/internal/logstream/parse_test.go:func TestParseClaudeLine_ToolUseBlockStart(t *testing.T) {","is