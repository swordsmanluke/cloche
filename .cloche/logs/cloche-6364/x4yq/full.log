[2026-03-18T18:32:33Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015LKtwGYjmC9ve4Zog31HpX","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"sync\"\n    10→\t\"time\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14→)\n    15→\n    16→const (\n    17→\tdefaultMaxConcurrent          = 1\n    18→\tdefaultDedupTimeout           = 5 * time.Minute\n    19→\tdefaultMaxConsecutiveFailures = 3\n    20→\tidlePollInterval              = 2 * time.Minute\n    21→\tcapacityPollInterval          = 30 * time.Second\n    22→)\n    23→\n    24→// LoopConfig holds configuration for an orchestration loop.\n    25→type LoopConfig struct {\n    26→\tProjectDir             string\n    27→\tMaxConcurrent          int\n    28→\tStaggerDelay           time.Duration // delay between launching consecutive runs\n    29→\tDedupTimeout           time.Duration // how long to suppress reassignment of the same task ID\n    30→\tStopOnError            bool          // halt loop on unrecovered error (allow in-flight work to finish)\n    31→\tMaxConsecutiveFailures int           // halt loop after N consecutive failures (default: 3, must be > 0)\n    32→}\n    33→\n    34→// ListTasksFunc is called to discover available tasks. It should run the\n    35→// list-tasks workflow (or equivalent) and return the parsed tasks.\n    36→type ListTasksFunc func(ctx context.Context, projectDir string) ([]Task, error)\n    37→\n    38→// MainFunc is called to execute the main workflow for a given task.\n    39→type MainFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n    40→\n    41→// FinalizeFunc is called after the main workflow completes (both success and\n    42→// failure). It receives the task ID and the outcome of the main phase.\n    43→type FinalizeFunc func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error)\n    44→\n    45→// RunFunc is the legacy function signature for launching a host workflow run.\n    46→// When taskID is non-empty, the runner should propagate it as CLOCHE_TASK_ID.\n    47→type RunFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n    48→\n    49→// TaskAssignment tracks the assignment state of a task.\n    50→type TaskAssignment struct {\n    51→\tAssignedAt time.Time\n    52→\tRunID      string // run ID handling this task (set after main completes)\n    53→}\n    54→\n    55→// TaskStateEntry combines a task with its assignment state.\n    56→type TaskStateEntry struct {\n    57→\tTask       Task\n    58→\tAssigned   bool\n    59→\tAssignedAt time.Time\n    60→\tRunID      string // empty if not yet known\n    61→}\n    62→\n    63→// Loop manages a continuous orchestration loop for a project, keeping up to\n    64→// MaxConcurrent host workflow runs active at all times when work is available.\n    65→//\n    66→// When configured with three-phase functions (list-tasks, main, finalize), the\n    67→// loop discovers tasks via list-tasks, picks open ones, runs main for each, and\n    68→// then runs finalize on completion. When configured with a legacy RunFunc, it\n    69→// falls back to the single-function approach.\n    70→type Loop struct {\n    71→\tconfig     LoopConfig\n    72→\tlistTasks  ListTasksFunc\n    73→\tmainFn     MainFunc\n    74→\tfinalizeFn FinalizeFunc // optional; skipped if nil\n    75→\trunner     RunFunc      // legacy single-function mode\n    76→\tstore      ports.RunStore\n    77→\tassigner   TaskAssigner // optional; legacy task assignment\n    78→\tstopCh     chan struct{}\n    79→\tresumeCh   chan struct{} // signaled by Resume() to wake the loop\n    80→\tmu         sync.Mutex\n    81→\trunning    bool\n    82→\thaltedMu            sync.RWMutex\n    83→\thalted              bool   // true when loop is halted due to an unrecovered error\n    84→\thaltError           string // the error message that caused the halt\n    85→\tconsecutiveFailures int    // number of consecutive failed runs\n    86→\tdedupMu             sync.Mutex\n    87→\tdedup      map[string]time.Time // task ID -> last assignment time\n    88→\ttasksMu    sync.RWMutex\n    89→\tlastTasks  []Task                    // most recently fetched tasks\n    90→\ttaskRuns   map[string]TaskAssignment // task ID -> assignment info\n    91→}\n    92→\n    93→// NewLoop creates an orchestration loop using a single run function (legacy mode).\n    94→// For three-phase orchestration, use NewPhaseLoop instead.\n    95→func NewLoop(cfg LoopConfig, store ports.RunStore, runFn RunFunc) *Loop {\n    96→\tif cfg.MaxConcurrent <= 0 {\n    97→\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n    98→\t}\n    99→\tif cfg.DedupTimeout <= 0 {\n   100→\t\tcfg.DedupTimeout = defaultDedupTimeout\n   101→\t}\n   102→\tif cfg.MaxConsecutiveFailures <= 0 {\n   103→\t\tcfg.MaxConsecutiveFailures = defaultMaxConsecutiveFailures\n   104→\t}\n   105→\treturn &Loop{\n   106→\t\tconfig:   cfg,\n   107→\t\trunner:   runFn,\n   108→\t\tstore:    store,\n   109→\t\tresumeCh: make(chan struct{}, 1),\n   110→\t\tdedup:    make(map[string]time.Time),\n   111→\t\ttaskRuns: make(map[string]TaskAssignment),\n   112→\t}\n   113→}\n   114→\n   115→// NewPhaseLoop creates a three-phase orchestration loop. The listTasksFn\n   116→// discovers available tasks, mainFn executes the main workflow for a task,\n   117→// and finalizeFn (optional) runs cleanup after main completes.\n   118→func NewPhaseLoop(cfg LoopConfig, store ports.RunStore, listTasksFn ListTasksFunc, mainFn MainFunc, finalizeFn FinalizeFunc) *Loop {\n   119→\tif cfg.MaxConcurrent <= 0 {\n   120→\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n   121→\t}\n   122→\tif cfg.DedupTimeout <= 0 {\n   123→\t\tcfg.DedupTimeout = defaultDedupTimeout\n   124→\t}\n   125→\tif cfg.MaxConsecutiveFailures <= 0 {\n   126→\t\tcfg.MaxConsecutiveFailures = defaultMaxConsecutiveFailures\n   127→\t}\n   128→\treturn &Loop{\n   129→\t\tconfig:     cfg,\n   130→\t\tlistTasks:  listTasksFn,\n   131→\t\tmainFn:     mainFn,\n   132→\t\tfinalizeFn: finalizeFn,\n   133→\t\tstore:      store,\n   134→\t\tresumeCh:   make(chan struct{}, 1),\n   135→\t\tdedup:      make(map[string]time.Time),\n   136→\t\ttaskRuns:   make(map[string]TaskAssignment),\n   137→\t}\n   138→}\n   139→\n   140→// SetTaskAssigner configures a TaskAssigner for daemon-managed task assignment.\n   141→// Only used in legacy (single RunFunc) mode when no list-tasks function is set.\n   142→func (l *Loop) SetTaskAssigner(a TaskAssigner) {\n   143→\tl.assigner = a\n   144→}\n   145→\n   146→// Start begins the orchestration loop. No-op if already running.\n   147→func (l *Loop) Start() {\n   148→\tl.mu.Lock()\n   149→\tdefer l.mu.Unlock()\n   150→\tif l.running {\n   151→\t\treturn\n   152→\t}\n   153→\tl.running = true\n   154→\tl.stopCh = make(chan struct{})\n   155→\tgo l.run()\n   156→\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n   157→}\n   158→\n   159→// Stop signals the loop to stop. Active runs continue to completion.\n   160→func (l *Loop) Stop() {\n   161→\tl.mu.Lock()\n   162→\tdefer l.mu.Unlock()\n   163→\tif !l.running {\n   164→\t\treturn\n   165→\t}\n   166→\tl.running = false\n   167→\tclose(l.stopCh)\n   168→\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n   169→}\n   170→\n   171→// Running returns whether the loop is currently active.\n   172→func (l *Loop) Running() bool {\n   173→\tl.mu.Lock()\n   174→\tdefer l.mu.Unlock()\n   175→\treturn l.running\n   176→}\n   177→\n   178→// Halted returns whether the loop is halted due to an unrecovered error,\n   179→// along with the error message that caused the halt. When halted, the loop\n   180→// is still running but will not pick up new work.\n   181→func (l *Loop) Halted() (bool, string) {\n   182→\tl.haltedMu.RLock()\n   183→\tdefer l.haltedMu.RUnlock()\n   184→\treturn l.halted, l.haltError\n   185→}\n   186→\n   187→// Resume clears the halted state so the loop resumes picking up new work.\n   188→func (l *Loop) Resume() {\n   189→\tl.haltedMu.Lock()\n   190→\tdefer l.haltedMu.Unlock()\n   191→\tif l.halted {\n   192→\t\tlog.Printf(\"orchestration loop: resumed for %s (was halted: %s)\", l.config.ProjectDir, l.haltError)\n   193→\t\tl.halted = false\n   194→\t\tl.haltError = \"\"\n   195→\t\tl.consecutiveFailures = 0\n   196→\t\t// Wake the loop from any sleep so it picks up work immediately.\n   197→\t\tselect {\n   198→\t\tcase l.resumeCh <- struct{}{}:\n   199→\t\tdefault:\n   200→\t\t}\n   201→\t}\n   202→}\n   203→\n   204→// halt sets the loop into halted state with the given error message.\n   205→func (l *Loop) halt(errMsg string) {\n   206→\tl.haltedMu.Lock()\n   207→\tdefer l.haltedMu.Unlock()\n   208→\tl.halted = true\n   209→\tl.haltError = errMsg\n   210→\tlog.Printf(\"orchestration loop: halted for %s (stop_on_error): %s\", l.config.ProjectDir, errMsg)\n   211→}\n   212→\n   213→// recordConsecutiveFailure increments the consecutive failure counter and\n   214→// returns true if the threshold has been reached.\n   215→func (l *Loop) recordConsecutiveFailure() bool {\n   216→\tl.haltedMu.Lock()\n   217→\tdefer l.haltedMu.Unlock()\n   218→\tif l.halted {\n   219→\t\treturn false // already halted (e.g. by StopOnError)\n   220→\t}\n   221→\tl.consecutiveFailures++\n   222→\treturn l.consecutiveFailures >= l.config.MaxConsecutiveFailures\n   223→}\n   224→\n   225→// resetConsecutiveFailures resets the consecutive failure counter to zero.\n   226→func (l *Loop) resetConsecutiveFailures() {\n   227→\tl.haltedMu.Lock()\n   228→\tdefer l.haltedMu.Unlock()\n   229→\tl.consecutiveFailures = 0\n   230→}\n   231→\n   232→// isHalted returns true if the loop is currently halted.\n   233→func (l *Loop) isHalted() bool {\n   234→\tl.haltedMu.RLock()\n   235→\tdefer l.haltedMu.RUnlock()\n   236→\treturn l.halted\n   237→}\n   238→\n   239→func (l *Loop) run() {\n   240→\tif l.listTasks != nil && l.mainFn != nil {\n   241→\t\tl.runPhased()\n   242→\t} else {\n   243→\t\tl.runLegacy()\n   244→\t}\n   245→}\n   246→\n   247→// runPhased implements the three-phase orchestration loop:\n   248→// 1. list-tasks → discover available work\n   249→// 2. main → execute work for each open task (up to MaxConcurrent)\n   250→// 3. finalize → cleanup after main completes (on both success and failure)\n   251→func (l *Loop) runPhased() {\n   252→\ttype result struct {\n   253→\t\tstate  domain.RunState\n   254→\t\terrMsg string\n   255→\t}\n   256→\n   257→\tcompletions := make(chan result, l.config.MaxConcurrent)\n   258→\tinFlight := 0\n   259→\n   260→\tfor {\n   261→\t\t// Fill up to max concurrent slots.\n   262→\t\tlaunched := 0\n   263→\t\tfor inFlight < l.config.MaxConcurrent {\n   264→\t\t\tselect {\n   265→\t\t\tcase <-l.stopCh:\n   266→\t\t\t\treturn\n   267→\t\t\tdefault:\n   268→\t\t\t}\n   269→\n   270→\t\t\t// If halted, don't pick up new work.\n   271→\t\t\tif l.isHalted() {\n   272→\t\t\t\tbreak\n   273→\t\t\t}\n   274→\n   275→\t\t\t// Check how many host runs are active for this project.\n   276→\t\t\tactive := l.countActiveHostRuns()\n   277→\t\t\tif active >= l.config.MaxConcurrent {\n   278→\t\t\t\tbreak\n   279→\t\t\t}\n   280→\n   281→\t\t\t// Stagger consecutive launches.\n   282→\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   283→\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   284→\t\t\t\t\treturn\n   285→\t\t\t\t}\n   286→\t\t\t}\n   287→\n   288→\t\t\t// Phase 1: list-tasks — discover available work.\n   289→\t\t\ttaskID, taskTitle, ok := l.pickTaskFromPhase()\n   290→\t\t\tif !ok {\n   291→\t\t\t\tbreak // no assignable tasks\n   292→\t\t\t}\n   293→\n   294→\t\t\t// Launch main + finalize in a goroutine.\n   295→\t\t\tinFlight++\n   296→\t\t\tlaunched++\n   297→\t\t\ttid := taskID\n   298→\t\t\tttitle := taskTitle\n   299→\t\t\tgo func() {\n   300→\t\t\t\t// Phase 2: main — do the work.\n   301→\t\t\t\tmainResult, err := l.mainFn(context.Background(), l.config.ProjectDir, tid)\n   302→\t\t\t\tif err != nil {\n   303→\t\t\t\t\tlog.Printf(\"orchestration loop: main failed for %s task %s: %v\", l.config.ProjectDir, tid, err)\n   304→\t\t\t\t\tif mainResult == nil {\n   305→\t\t\t\t\t\tmainResult = &RunResult{State: domain.RunStateFailed}\n   306→\t\t\t\t\t}\n   307→\t\t\t\t}\n   308→\n   309→\t\t\t\t// Track the run ID for this task and persist the task title.\n   310→\t\t\t\tif mainResult != nil && mainResult.RunID != \"\" {\n   311→\t\t\t\t\tl.tasksMu.Lock()\n   312→\t\t\t\t\tl.taskRuns[tid] = TaskAssignment{\n   313→\t\t\t\t\t\tAssignedAt: time.Now(),\n   314→\t\t\t\t\t\tRunID:      mainResult.RunID,\n   315→\t\t\t\t\t}\n   316→\t\t\t\t\tl.tasksMu.Unlock()\n   317→\n   318→\t\t\t\t\tif ttitle != \"\" {\n   319→\t\t\t\t\t\tif r, err := l.store.GetRun(context.Background(), mainResult.RunID); err == nil && r.TaskTitle == \"\" {\n   320→\t\t\t\t\t\t\tr.TaskTitle = ttitle\n   321→\t\t\t\t\t\t\t_ = l.store.UpdateRun(context.Background(), r)\n   322→\t\t\t\t\t\t}\n   323→\t\t\t\t\t}\n   324→\t\t\t\t}\n   325→\n   326→\t\t\t\t// Phase 3: finalize — cleanup (runs on both success and failure).\n   327→\t\t\t\t// The overall state is the worst of main and finalize outcomes.\n   328→\t\t\t\toverallState := mainResult.State\n   329→\t\t\t\tif l.finalizeFn != nil {\n   330→\t\t\t\t\tfinalizeResult, finalizeErr := l.finalizeFn(context.Background(), l.config.ProjectDir, tid, mainResult)\n   331→\t\t\t\t\tif finalizeErr != nil {\n   332→\t\t\t\t\t\tlog.Printf(\"orchestration loop: finalize failed for %s task %s: %v\", l.config.ProjectDir, tid, finalizeErr)\n   333→\t\t\t\t\t\toverallState = domain.WorseState(overallState, domain.RunStateFailed)\n   334→\t\t\t\t\t} else if finalizeResult != nil {\n   335→\t\t\t\t\t\toverallState = domain.WorseState(overallState, finalizeResult.State)\n   336→\t\t\t\t\t}\n   337→\t\t\t\t}\n   338→\n   339→\t\t\t\tcompletions <- result{state: overallState, errMsg: fmt.Sprintf(\"task %s failed\", tid)}\n   340→\t\t\t}()\n   341→\t\t}\n   342→\n   343→\t\tif inFlight == 0 {\n   344→\t\t\t// Nothing in flight and couldn't launch anything — wait before checking again.\n   345→\t\t\tif !l.sleep(capacityPollInterval) {\n   346→\t\t\t\treturn\n   347→\t\t\t}\n   348→\t\t\tcontinue\n   349→\t\t}\n   350→\n   351→\t\t// Wait for any run to complete.\n   352→\t\tselect {\n   353→\t\tcase r := <-completions:\n   354→\t\t\tinFlight--\n   355→\t\t\tif r.state == domain.RunStateSucceeded {\n   356→\t\t\t\tl.resetConsecutiveFailures()\n   357→\t\t\t\t// Work was done — try to fill slots immediately.\n   358→\t\t\t\tcontinue\n   359→\t\t\t}\n   360→\t\t\t// Run failed or aborted.\n   361→\t\t\tif l.config.StopOnError {\n   362→\t\t\t\tl.halt(r.errMsg)\n   363→\t\t\t}\n   364→\t\t\tif l.recordConsecutiveFailure() {\n   365→\t\t\t\tl.halt(fmt.Sprintf(\"halted after %d consecutive failures: %s\", l.config.MaxConsecutiveFailures, r.errMsg))\n   366→\t\t\t}\n   367→\t\t\t// Back off.\n   368→\t\t\tif !l.sleep(idlePollInterval) {\n   369→\t\t\t\treturn\n   370→\t\t\t}\n   371→\t\tcase <-l.stopCh:\n   372→\t\t\treturn\n   373→\t\t}\n   374→\t}\n   375→}\n   376→\n   377→// GetTaskSnapshot returns the current task pipeline state: the most recently\n   378→// fetched tasks with their assignment information.\n   379→func (l *Loop) GetTaskSnapshot() []TaskStateEntry {\n   380→\tl.tasksMu.RLock()\n   381→\ttasks := make([]Task, len(l.lastTasks))\n   382→\tcopy(tasks, l.lastTasks)\n   383→\tl.tasksMu.RUnlock()\n   384→\n   385→\tl.dedupMu.Lock()\n   386→\tdefer l.dedupMu.Unlock()\n   387→\n   388→\tnow := time.Now()\n   389→\tvar entries []TaskStateEntry\n   390→\tfor _, task := range tasks {\n   391→\t\tentry := TaskStateEntry{Task: task}\n   392→\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   393→\t\t\tentry.Assigned = true\n   394→\t\t\tentry.AssignedAt = ts\n   395→\t\t}\n   396→\n   397→\t\tl.tasksMu.RLock()\n   398→\t\tif a, ok := l.taskRuns[task.ID]; ok {\n   399→\t\t\tentry.RunID = a.RunID\n   400→\t\t\tif !entry.Assigned {\n   401→\t\t\t\tentry.AssignedAt = a.AssignedAt\n   402→\t\t\t}\n   403→\t\t}\n   404→\t\tl.tasksMu.RUnlock()\n   405→\n   406→\t\tentries = append(entries, entry)\n   407→\t}\n   408→\treturn entries\n   409→}\n   410→\n   411→// pickTaskFromPhase runs the list-tasks function and picks the first open,\n   412→// non-deduped task. Returns the task ID, title, and whether a task was found.\n   413→func (l *Loop) pickTaskFromPhase() (string, string, bool) {\n   414→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   415→\tdefer cancel()\n   416→\n   417→\ttasks, err := l.listTasks(ctx, l.config.ProjectDir)\n   418→\tif err != nil {\n   419→\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n   420→\t\treturn \"\", \"\", false\n   421→\t}\n   422→\n   423→\t// Cache the latest tasks for snapshot queries.\n   424→\tl.tasksMu.Lock()\n   425→\tl.lastTasks = tasks\n   426→\tl.tasksMu.Unlock()\n   427→\n   428→\tnow := time.Now()\n   429→\tl.dedupMu.Lock()\n   430→\tdefer l.dedupMu.Unlock()\n   431→\n   432→\t// Expire old dedup entries.\n   433→\tfor id, ts := range l.dedup {\n   434→\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n   435→\t\t\tdelete(l.dedup, id)\n   436→\t\t}\n   437→\t}\n   438→\n   439→\tfor _, task := range tasks {\n   440→\t\tif task.ID == \"\" {\n   441→\t\t\tcontinue\n   442→\t\t}\n   443→\t\tif !task.IsOpen() {\n   444→\t\t\tcontinue\n   445→\t\t}\n   446→\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   447→\t\t\tcontinue\n   448→\t\t}\n   449→\t\tl.dedup[task.ID] = now\n   450→\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n   451→\t\treturn task.ID, task.Title, true\n   452→\t}\n   453→\n   454→\treturn \"\", \"\", false\n   455→}\n   456→\n   457→// runLegacy implements the original single-function orchestration loop.\n   458→func (l *Loop) runLegacy() {\n   459→\ttype result struct {\n   460→\t\tstate  domain.RunState\n   461→\t\terrMsg string\n   462→\t}\n   463→\n   464→\tcompletions := make(chan result, l.config.MaxConcurrent)\n   465→\tinFlight := 0\n   466→\n   467→\tfor {\n   468→\t\t// Fill up to max concurrent slots.\n   469→\t\tlaunched := 0\n   470→\t\tfor inFlight < l.config.MaxConcurrent {\n   471→\t\t\tselect {\n   472→\t\t\tcase <-l.stopCh:\n   473→\t\t\t\treturn\n   474→\t\t\tdefault:\n   475→\t\t\t}\n   476→\n   477→\t\t\t// If halted, don't pick up new work.\n   478→\t\t\tif l.isHalted() {\n   479→\t\t\t\tbreak\n   480→\t\t\t}\n   481→\n   482→\t\t\t// Check how many host runs are active for this project (in case of\n   483→\t\t\t// leftover runs from previous loops).\n   484→\t\t\tactive := l.countActiveHostRuns()\n   485→\t\t\tif active >= l.config.MaxConcurrent {\n   486→\t\t\t\tbreak\n   487→\t\t\t}\n   488→\n   489→\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n   490→\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   491→\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   492→\t\t\t\t\treturn\n   493→\t\t\t\t}\n   494→\t\t\t}\n   495→\n   496→\t\t\t// Determine task ID (if task assigner is configured).\n   497→\t\t\ttaskID := \"\"\n   498→\t\t\tif l.assigner != nil {\n   499→\t\t\t\tvar ok bool\n   500→\t\t\t\ttaskID, ok = l.pickTask()\n   501→\t\t\t\tif !ok {\n   502→\t\t\t\t\t// No assignable tasks available.\n   503→\t\t\t\t\tbreak\n   504→\t\t\t\t}\n   505→\t\t\t}\n   506→\n   507→\t\t\t// Launch a new orchestration run in a goroutine.\n   508→\t\t\tinFlight++\n   509→\t\t\tlaunched++\n   510→\t\t\ttid := taskID // capture for goroutine\n   511→\t\t\tgo func() {\n   512→\t\t\t\tres, err := l.runner(context.Background(), l.config.ProjectDir, tid)\n   513→\t\t\t\tif err != nil {\n   514→\t\t\t\t\tlog.Printf(\"orchestration loop: run failed for %s: %v\", l.config.ProjectDir, err)\n   515→\t\t\t\t\tcompletions <- result{state: domain.RunStateFailed, errMsg: err.Error()}\n   516→\t\t\t\t\treturn\n   517→\t\t\t\t}\n   518→\t\t\t\tif res.State != domain.RunStateSucceeded {\n   519→\t\t\t\t\tcompletions <- result{state: res.State, errMsg: \"run failed with state \" + string(res.State)}\n   520→\t\t\t\t\treturn\n   521→\t\t\t\t}\n   522→\t\t\t\tcompletions <- result{state: res.State}\n   523→\t\t\t}()\n   524→\t\t}\n   525→\n   526→\t\tif inFlight == 0 {\n   527→\t\t\t// Nothing in flight and at capacity — wait before checking again.\n   528→\t\t\tif !l.sleep(capacityPollInterval) {\n   529→\t\t\t\treturn\n   530→\t\t\t}\n   531→\t\t\tcontinue\n   532→\t\t}\n   533→\n   534→\t\t// Wait for any run to complete.\n   535→\t\tselect {\n   536→\t\tcase r := <-completions:\n   537→\t\t\tinFlight--\n   538→\t\t\tif r.state == domain.RunStateSucceeded {\n   539→\t\t\t\tl.resetConsecutiveFailures()\n   540→\t\t\t\t// Work was done — try to fill slots immediately.\n   541→\t\t\t\tcontinue\n   542→\t\t\t}\n   543→\t\t\t// Run failed or aborted (no tasks available).\n   544→\t\t\tif l.config.StopOnError {\n   545→\t\t\t\tl.halt(r.errMsg)\n   546→\t\t\t}\n   547→\t\t\tif l.recordConsecutiveFailure() {\n   548→\t\t\t\tl.halt(fmt.Sprintf(\"halted after %d consecutive failures: %s\", l.config.MaxConsecutiveFailures, r.errMsg))\n   549→\t\t\t}\n   550→\t\t\t// Back off.\n   551→\t\t\tif !l.sleep(idlePollInterval) {\n   552→\t\t\t\treturn\n   553→\t\t\t}\n   554→\t\tcase <-l.stopCh:\n   555→\t\t\treturn\n   556→\t\t}\n   557→\t}\n   558→}\n   559→\n   560→// pickTask queries the task assigner for available tasks, filters out those\n   561→// within the dedup timeout window, and returns the first assignable task ID.\n   562→// It records the assignment time so the same task won't be picked again until\n   563→// the dedup timeout expires. Returns (\"\", false) if no tasks are available.\n   564→func (l *Loop) pickTask() (string, bool) {\n   565→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   566→\tdefer cancel()\n   567→\n   568→\ttasks, err := l.assigner.ListTasks(ctx, l.config.ProjectDir)\n   569→\tif err != nil {\n   570→\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n   571→\t\treturn \"\", false\n   572→\t}\n   573→\n   574→\t// Cache the latest tasks for snapshot queries.\n   575→\tl.tasksMu.Lock()\n   576→\tl.lastTasks = tasks\n   577→\tl.tasksMu.Unlock()\n   578→\n   579→\tnow := time.Now()\n   580→\tl.dedupMu.Lock()\n   581→\tdefer l.dedupMu.Unlock()\n   582→\n   583→\t// Expire old dedup entries while we're here.\n   584→\tfor id, ts := range l.dedup {\n   585→\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n   586→\t\t\tdelete(l.dedup, id)\n   587→\t\t}\n   588→\t}\n   589→\n   590→\tfor _, task := range tasks {\n   591→\t\tif task.ID == \"\" {\n   592→\t\t\tcontinue\n   593→\t\t}\n   594→\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   595→\t\t\tcontinue // still within dedup window\n   596→\t\t}\n   597→\t\t// Assign this task.\n   598→\t\tl.dedup[task.ID] = now\n   599→\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n   600→\t\treturn task.ID, true\n   601→\t}\n   602→\n   603→\treturn \"\", false\n   604→}\n   605→\n   606→// countActiveHostRuns counts running or pending host runs for the project.\n   607→func (l *Loop) countActiveHostRuns() int {\n   608→\tctx := context.Background()\n   609→\truns, err := l.store.ListRunsByProject(ctx, l.config.ProjectDir, time.Time{})\n   610→\tif err != nil {\n   611→\t\treturn 0\n   612→\t}\n   613→\tcount := 0\n   614→\tfor _, r := range runs {\n   615→\t\tif r.IsHost && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n   616→\t\t\tcount++\n   617→\t\t}\n   618→\t}\n   619→\treturn count\n   620→}\n   621→\n   622→// sleep waits for the given duration or until the loop is stopped or resumed.\n   623→// Returns false if the loop was stopped.\n   624→func (l *Loop) sleep(d time.Duration) bool {\n   625→\tselect {\n   626→\tcase <-time.After(d):\n   627→\t\treturn true\n   628→\tcase <-l.resumeCh:\n   629→\t\treturn true\n   630→\tcase <-l.stopCh:\n   631→\t\treturn false\n   632→\t}\n   633→}\n   634→\n   635→// ReadListTasksOutput reads the output directory from a list-tasks workflow run\n   636→// and parses JSONL task output from the last step's output file.\n   637→func ReadListTasksOutput(outputDir string) ([]Task, error) {\n   638→\tentries, err := os.ReadDir(outputDir)\n   639→\tif err != nil {\n   640→\t\treturn nil, fmt.Errorf(\"reading list-tasks output dir: %w\", err)\n   641→\t}\n   642→\n   643→\t// Find the most recently modified .out file.\n   644→\tvar latest string\n   645→\tvar latestMod time.Time\n   646→\tfor _, e := range entries {\n   647→\t\tif e.IsDir() || filepath.Ext(e.Name()) != \".out\" {\n   648→\t\t\tcontinue\n   649→\t\t}\n   650→\t\tinfo, err := e.Info()\n   651→\t\tif err != nil {\n   652→\t\t\tcontinue\n   653→\t\t}\n   654→\t\tif latest == \"\" || info.ModTime().After(latestMod) {\n   655→\t\t\tlatest = e.Name()\n   656→\t\t\tlatestMod = info.ModTime()\n   657→\t\t}\n   658→\t}\n   659→\n   660→\tif latest == \"\" {\n   661→\t\treturn nil, fmt.Errorf(\"no output files found in %s\", outputDir)\n   662→\t}\n   663→\n   664→\tdata, err := os.ReadFile(filepath.Join(outputDir, latest))\n   665→\tif err != nil {\n   666→\t\treturn nil, fmt.Errorf(\"reading output file %s: %w\", latest, err)\n   667→\t}\n   668→\n   669→\treturn ParseTasksJSONL(string(data))\n   670→}\n   671→"}]},"parent_tool_use_id":null,"session_id":"5b6d5b63-f59f-4a0e-aae3-0d9f743fb182","uuid":"875a49f8-10c5-4cad-bb42-c185d39ff70e","timestamp":"2026-03-18T18:32:23.780Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/loop.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\nconst (\n\tdefaultMaxConcurrent          = 1\n\tdefaultDedupTimeout           = 5 * time.Minute\n\tdefaultMaxConsecutiveFailures = 3\n\tidlePollInterval              = 2 * time.Minute\n\tcapacityPollInterval          = 30 * time.Second\n)\n\n// LoopConfig holds configuration for an orchestration loop.\ntype LoopConfig struct {\n\tProjectDir             string\n\tMaxConcurrent          int\n\tStaggerDelay           time.Duration // delay between launching consecutive runs\n\tDedupTimeout           time.Duration // how long to suppress reassignment of the same task ID\n\tStopOnError            bool          // halt loop on unrecovered error (allow in-flight work to finish)\n\tMaxConsecutiveFailures int           // halt loop after N consecutive failures (default: 3, must be > 0)\n}\n\n// ListTasksFunc is called to discover available tasks. It should run the\n// list-tasks workflow (or equivalent) and return the parsed tasks.\ntype ListTasksFunc func(ctx context.Context, projectDir string) ([]Task, error)\n\n// MainFunc is called to execute the main workflow for a given task.\ntype MainFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n\n// FinalizeFunc is called after the main workflow completes (both success and\n// failure). It receives the task ID and the outcome of the main phase.\ntype FinalizeFunc func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error)\n\n// RunFunc is the legacy function signature for launching a host workflow run.\n// When taskID is non-empty, the runner should propagate it as CLOCHE_TASK_ID.\ntype RunFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n\n// TaskAssignment tracks the assignment state of a task.\ntype TaskAssignment struct {\n\tAssignedAt time.Time\n\tRunID      string // run ID handling this task (set after main completes)\n}\n\n// TaskStateEntry combines a task with its assignment state.\ntype TaskStateEntry struct {\n\tTask       Task\n\tAssigned   bool\n\tAssignedAt time.Time\n\tRunID      string // empty if not yet known\n}\n\n// Loop manages a continuous orchestration loop for a project, keeping up to\n// MaxConcurrent host workflow runs active at all times when work is available.\n//\n// When configured with three-phase functions (list-tasks, main, finalize), the\n// loop discovers tasks via list-tasks, picks open ones, runs main for each, and\n// then runs finalize on completion. When configured with a legacy RunFunc, it\n// falls back to the single-function approach.\ntype Loop struct {\n\tconfig     LoopConfig\n\tlistTasks  ListTasksFunc\n\tmainFn     MainFunc\n\tfinalizeFn FinalizeFunc // optional; skipped if nil\n\trunner     RunFunc      // legacy single-function mode\n\tstore      ports.RunStore\n\tassigner   TaskAssigner // optional; legacy task assignment\n\tstopCh     chan struct{}\n\tresumeCh   chan struct{} // signaled by Resume() to wake the loop\n\tmu         sync.Mutex\n\trunning    bool\n\thaltedMu            sync.RWMutex\n\thalted              bool   // true when loop is halted due to an unrecovered error\n\thaltError           string // the error message that caused the halt\n\tconsecutiveFailures int    // number of consecutive failed runs\n\tdedupMu             sync.Mutex\n\tdedup      map[string]time.Time // task ID -> last assignment time\n\ttasksMu    sync.RWMutex\n\tlastTasks  []Task                    // most recently fetched tasks\n\ttaskRuns   map[string]TaskAssignment // task ID -> assignment info\n}\n\n// NewLoop creates an orchestration loop using a single run function (legacy mode).\n// For three-phase orchestration, use NewPhaseLoop instead.\nfunc NewLoop(cfg LoopConfig, store ports.RunStore, runFn RunFunc) *Loop {\n\tif cfg.MaxConcurrent <= 0 {\n\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n\t}\n\tif cfg.DedupTimeout <= 0 {\n\t\tcfg.DedupTimeout = defaultDedupTimeout\n\t}\n\tif cfg.MaxConsecutiveFailures <= 0 {\n\t\tcfg.MaxConsecutiveFailures = defaultMaxConsecutiveFailures\n\t}\n\treturn &Loop{\n\t\tconfig:   cfg,\n\t\trunner:   runFn,\n\t\tstore:    store,\n\t\tresumeCh: make(chan struct{}, 1),\n\t\tdedup:    make(map[string]time.Time),\n\t\ttaskRuns: make(map[string]TaskAssignment),\n\t}\n}\n\n// NewPhaseLoop creates a three-phase orchestration loop. The listTasksFn\n// discovers available tasks, mainFn executes the main workflow for a task,\n// and finalizeFn (optional) runs cleanup after main completes.\nfunc NewPhaseLoop(cfg LoopConfig, store ports.RunStore, listTasksFn ListTasksFunc, mainFn MainFunc, finalizeFn FinalizeFunc) *Loop {\n\tif cfg.MaxConcurrent <= 0 {\n\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n\t}\n\tif cfg.DedupTimeout <= 0 {\n\t\tcfg.DedupTimeout = defaultDedupTimeout\n\t}\n\tif cfg.MaxConsecutiveFailures <= 0 {\n\t\tcfg.MaxConsecutiveFailures = defaultMaxConsecutiveFailures\n\t}\n\treturn &Loop{\n\t\tconfig:     cfg,\n\t\tlistTasks:  listTasksFn,\n\t\tmainFn:     mainFn,\n\t\tfinalizeFn: finalizeFn,\n\t\tstore:      store,\n\t\tresumeCh:   make(chan struct{}, 1),\n\t\tdedup:      make(map[string]time.Time),\n\t\ttaskRuns:   make(map[string]TaskAssignment),\n\t}\n}\n\n// SetTaskAssigner configures a TaskAssigner for daemon-managed task assignment.\n// Only used in legacy (single RunFunc) mode when no list-tasks function is set.\nfunc (l *Loop) SetTaskAssigner(a TaskAssigner) {\n\tl.assigner = a\n}\n\n// Start begins the orchestration loop. No-op if already running.\nfunc (l *Loop) Start() {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\tif l.running {\n\t\treturn\n\t}\n\tl.running = true\n\tl.stopCh = make(chan struct{})\n\tgo l.run()\n\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n}\n\n// Stop signals the loop to stop. Active runs continue to completion.\nfunc (l *Loop) Stop() {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\tif !l.running {\n\t\treturn\n\t}\n\tl.running = false\n\tclose(l.stopCh)\n\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n}\n\n// Running returns whether the loop is currently active.\nfunc (l *Loop) Running() bool {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\treturn l.running\n}\n\n// Halted returns whether the loop is halted due to an unrecovered error,\n// along with the error message that caused the halt. When halted, the loop\n// is still running but will not pick up new work.\nfunc (l *Loop) Halted() (bool, string) {\n\tl.haltedMu.RLock()\n\tdefer l.haltedMu.RUnlock()\n\treturn l.halted, l.haltError\n}\n\n// Resume clears the halted state so the loop resumes picking up new work.\nfunc (l *Loop) Resume() {\n\tl.haltedMu.Lock()\n\tdefer l.haltedMu.Unlock()\n\tif l.halted {\n\t\tlog.Printf(\"orchestration loop: resumed for %s (was halted: %s)\", l.config.ProjectDir, l.haltError)\n\t\tl.halted = false\n\t\tl.haltError = \"\"\n\t\tl.consecutiveFailures = 0\n\t\t// Wake the loop from any sleep so it picks up work immediately.\n\t\tselect {\n\t\tcase l.resumeCh <- struct{}{}:\n\t\tdefault:\n\t\t}\n\t}\n}\n\n// halt sets the loop into halted state with the given error message.\nfunc (l *Loop) halt(errMsg string) {\n\tl.haltedMu.Lock()\n\tdefer l.haltedMu.Unlock()\n\tl.halted = true\n\tl.haltError = errMsg\n\tlog.Printf(\"orchestration loop: halted for %s (stop_on_error): %s\", l.config.ProjectDir, errMsg)\n}\n\n// recordConsecutiveFailure increments the consecutive failure counter and\n// returns true if the threshold has been reached.\nfunc (l *Loop) recordConsecutiveFailure() bool {\n\tl.haltedMu.Lock()\n\tdefer l.haltedMu.Unlock()\n\tif l.halted {\n\t\treturn false // already halted (e.g. by StopOnError)\n\t}\n\tl.consecutiveFailures++\n\treturn l.consecutiveFailures >= l.config.MaxConsecutiveFailures\n}\n\n// resetConsecutiveFailures resets the consecutive failure counter to zero.\nfunc (l *Loop) resetConsecutiveFailures() {\n\tl.haltedMu.Lock()\n\tdefer l.haltedMu.Unlock()\n\tl.consecutiveFailures = 0\n}\n\n// isHalted returns true if the loop is currently halted.\nfunc (l *Loop) isHalted() bool {\n\tl.haltedMu.RLock()\n\tdefer l.haltedMu.RUnlock()\n\treturn l.halted\n}\n\nfunc (l *Loop) run() {\n\tif l.listTasks != nil && l.mainFn != nil {\n\t\tl.runPhased()\n\t} else {\n\t\tl.runLegacy()\n\t}\n}\n\n// runPhased implements the three-phase orchestration loop:\n// 1. list-tasks → discover available work\n// 2. main → execute work for each open task (up to MaxConcurrent)\n// 3. finalize → cleanup after main completes (on both success and failure)\nfunc (l *Loop) runPhased() {\n\ttype result struct {\n\t\tstate  domain.RunState\n\t\terrMsg string\n\t}\n\n\tcompletions := make(chan result, l.config.MaxConcurrent)\n\tinFlight := 0\n\n\tfor {\n\t\t// Fill up to max concurrent slots.\n\t\tlaunched := 0\n\t\tfor inFlight < l.config.MaxConcurrent {\n\t\t\tselect {\n\t\t\tcase <-l.stopCh:\n\t\t\t\treturn\n\t\t\tdefault:\n\t\t\t}\n\n\t\t\t// If halted, don't pick up new work.\n\t\t\tif l.isHalted() {\n\t\t\t\tbreak\n\t\t\t}\n\n\t\t\t// Check how many host runs are active for this project.\n\t\t\tactive := l.countActiveHostRuns()\n\t\t\tif active >= l.config.MaxConcurrent {\n\t\t\t\tbreak\n\t\t\t}\n\n\t\t\t// Stagger consecutive launches.\n\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// Phase 1: list-tasks — discover available work.\n\t\t\ttaskID, taskTitle, ok := l.pickTaskFromPhase()\n\t\t\tif !ok {\n\t\t\t\tbreak // no assignable tasks\n\t\t\t}\n\n\t\t\t// Launch main + finalize in a goroutine.\n\t\t\tinFlight++\n\t\t\tlaunched++\n\t\t\ttid := taskID\n\t\t\tttitle := taskTitle\n\t\t\tgo func() {\n\t\t\t\t// Phase 2: main — do the work.\n\t\t\t\tmainResult, err := l.mainFn(context.Background(), l.config.ProjectDir, tid)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlog.Printf(\"orchestration loop: main failed for %s task %s: %v\", l.config.ProjectDir, tid, err)\n\t\t\t\t\tif mainResult == nil {\n\t\t\t\t\t\tmainResult = &RunResult{State: domain.RunStateFailed}\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\t// Track the run ID for this task and persist the task title.\n\t\t\t\tif mainResult != nil && mainResult.RunID != \"\" {\n\t\t\t\t\tl.tasksMu.Lock()\n\t\t\t\t\tl.taskRuns[tid] = TaskAssignment{\n\t\t\t\t\t\tAssignedAt: time.Now(),\n\t\t\t\t\t\tRunID:      mainResult.RunID,\n\t\t\t\t\t}\n\t\t\t\t\tl.tasksMu.Unlock()\n\n\t\t\t\t\tif ttitle != \"\" {\n\t\t\t\t\t\tif r, err := l.store.GetRun(context.Background(), mainResult.RunID); err == nil && r.TaskTitle == \"\" {\n\t\t\t\t\t\t\tr.TaskTitle = ttitle\n\t\t\t\t\t\t\t_ = l.store.UpdateRun(context.Background(), r)\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\t// Phase 3: finalize — cleanup (runs on both success and failure).\n\t\t\t\t// The overall state is the worst of main and finalize outcomes.\n\t\t\t\toverallState := mainResult.State\n\t\t\t\tif l.finalizeFn != nil {\n\t\t\t\t\tfinalizeResult, finalizeErr := l.finalizeFn(context.Background(), l.config.ProjectDir, tid, mainResult)\n\t\t\t\t\tif finalizeErr != nil {\n\t\t\t\t\t\tlog.Printf(\"orchestration loop: finalize failed for %s task %s: %v\", l.config.ProjectDir, tid, finalizeErr)\n\t\t\t\t\t\toverallState = domain.WorseState(overallState, domain.RunStateFailed)\n\t\t\t\t\t} else if finalizeResult != nil {\n\t\t\t\t\t\toverallState = domain.WorseState(overallState, finalizeResult.State)\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tcompletions <- result{state: overallState, errMsg: fmt.Sprintf(\"task %s failed\", tid)}\n\t\t\t}()\n\t\t}\n\n\t\tif inFlight == 0 {\n\t\t\t// Nothing in flight and couldn't launch anything — wait before checking again.\n\t\t\tif !l.sleep(capacityPollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t// Wait for any run to complete.\n\t\tselect {\n\t\tcase r := <-completions:\n\t\t\tinFlight--\n\t\t\tif r.state == domain.RunStateSucceeded {\n\t\t\t\tl.resetConsecutiveFailures()\n\t\t\t\t// Work was done — try to fill slots immediately.\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\t// Run failed or aborted.\n\t\t\tif l.config.StopOnError {\n\t\t\t\tl.halt(r.errMsg)\n\t\t\t}\n\t\t\tif l.recordConsecutiveFailure() {\n\t\t\t\tl.halt(fmt.Sprintf(\"halted after %d consecutive failures: %s\", l.config.MaxConsecutiveFailures, r.errMsg))\n\t\t\t}\n\t\t\t// Back off.\n\t\t\tif !l.sleep(idlePollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\tcase <-l.stopCh:\n\t\t\treturn\n\t\t}\n\t}\n}\n\n// GetTaskSnapshot returns the current task pipeline state: the most recently\n// fetched tasks with their assignment information.\nfunc (l *Loop) GetTaskSnapshot() []TaskStateEntry {\n\tl.tasksMu.RLock()\n\ttasks := make([]Task, len(l.lastTasks))\n\tcopy(tasks, l.lastTasks)\n\tl.tasksMu.RUnlock()\n\n\tl.dedupMu.Lock()\n\tdefer l.dedupMu.Unlock()\n\n\tnow := time.Now()\n\tvar entries []TaskStateEntry\n\tfor _, task := range tasks {\n\t\tentry := TaskStateEntry{Task: task}\n\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n\t\t\tentry.Assigned = true\n\t\t\tentry.AssignedAt = ts\n\t\t}\n\n\t\tl.tasksMu.RLock()\n\t\tif a, ok := l.taskRuns[task.ID]; ok {\n\t\t\tentry.RunID = a.RunID\n\t\t\tif !entry.Assigned {\n\t\t\t\tentry.AssignedAt = a.AssignedAt\n\t\t\t}\n\t\t}\n\t\tl.tasksMu.RUnlock()\n\n\t\tentries = append(entries, entry)\n\t}\n\treturn entries\n}\n\n// pickTaskFromPhase runs the list-tasks function and picks the first open,\n// non-deduped task. Returns the task ID, title, and whether a task was found.\nfunc (l *Loop) pickTaskFromPhase() (string, string, bool) {\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\ttasks, err := l.listTasks(ctx, l.config.ProjectDir)\n\tif err != nil {\n\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n\t\treturn \"\", \"\", false\n\t}\n\n\t// Cache the latest tasks for snapshot queries.\n\tl.tasksMu.Lock()\n\tl.lastTasks = tasks\n\tl.tasksMu.Unlock()\n\n\tnow := time.Now()\n\tl.dedupMu.Lock()\n\tdefer l.dedupMu.Unlock()\n\n\t// Expire old dedup entries.\n\tfor id, ts := range l.dedup {\n\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n\t\t\tdelete(l.dedup, id)\n\t\t}\n\t}\n\n\tfor _, task := range tasks {\n\t\tif task.ID == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif !task.IsOpen() {\n\t\t\tcontinue\n\t\t}\n\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n\t\t\tcontinue\n\t\t}\n\t\tl.dedup[task.ID] = now\n\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n\t\treturn task.ID, task.Title, true\n\t}\n\n\treturn \"\", \"\", false\n}\n\n// runLegacy implements the original single-function orchestration loop.\nfunc (l *Loop) runLegacy() {\n\ttype result struct {\n\t\tstate  domain.RunState\n\t\terrMsg string\n\t}\n\n\tcompletions := make(chan result, l.config.MaxConcurrent)\n\tinFlight := 0\n\n\tfor {\n\t\t// Fill up to max concurrent slots.\n\t\tlaunched := 0\n\t\tfor inFlight < l.config.MaxConcurrent {\n\t\t\tselect {\n\t\t\tcase <-l.stopCh:\n\t\t\t\treturn\n\t\t\tdefault:\n\t\t\t}\n\n\t\t\t// If halted, don't pick up new work.\n\t\t\tif l.isHalted() {\n\t\t\t\tbreak\n\t\t\t}\n\n\t\t\t// Check how many host runs are active for this project (in case of\n\t\t\t// leftover runs from previous loops).\n\t\t\tactive := l.countActiveHostRuns()\n\t\t\tif active >= l.config.MaxConcurrent {\n\t\t\t\tbreak\n\t\t\t}\n\n\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// Determine task ID (if task assigner is configured).\n\t\t\ttaskID := \"\"\n\t\t\tif l.assigner != nil {\n\t\t\t\tvar ok bool\n\t\t\t\ttaskID, ok = l.pickTask()\n\t\t\t\tif !ok {\n\t\t\t\t\t// No assignable tasks available.\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// Launch a new orchestration run in a goroutine.\n\t\t\tinFlight++\n\t\t\tlaunched++\n\t\t\ttid := taskID // capture for goroutine\n\t\t\tgo func() {\n\t\t\t\tres, err := l.runner(context.Background(), l.config.ProjectDir, tid)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlog.Printf(\"orchestration loop: run failed for %s: %v\", l.config.ProjectDir, err)\n\t\t\t\t\tcompletions <- result{state: domain.RunStateFailed, errMsg: err.Error()}\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t\tif res.State != domain.RunStateSucceeded {\n\t\t\t\t\tcompletions <- result{state: res.State, errMsg: \"run failed with state \" + string(res.State)}\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t\tcompletions <- result{state: res.State}\n\t\t\t}()\n\t\t}\n\n\t\tif inFlight == 0 {\n\t\t\t// Nothing in flight and at capacity — wait before checking again.\n\t\t\tif !l.sleep(capacityPollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t// Wait for any run to complete.\n\t\tselect {\n\t\tcase r := <-completions:\n\t\t\tinFlight--\n\t\t\tif r.state == domain.RunStateSucceeded {\n\t\t\t\tl.resetConsecutiveFailures()\n\t\t\t\t// Work was done — try to fill slots immediately.\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\t// Run failed or aborted (no tasks available).\n\t\t\tif l.config.StopOnError {\n\t\t\t\tl.halt(r.errMsg)\n\t\t\t}\n\t\t\tif l.recordConsecutiveFailure() {\n\t\t\t\tl.halt(fmt.Sprintf(\"halted after %d consecutive failures: %s\", l.config.MaxConsecutiveFailures, r.errMsg))\n\t\t\t}\n\t\t\t// Back off.\n\t\t\tif !l.sleep(idlePollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\tcase <-l.stopCh:\n\t\t\treturn\n\t\t}\n\t}\n}\n\n// pickTask queries the task assigner for available tasks, filters out those\n// within the dedup timeout window, and returns the first assignable task ID.\n// It records the assignment time so the same task won't be picked again until\n// the dedup timeout expires. Returns (\"\", false) if no tasks are available.\nfunc (l *Loop) pickTask() (string, bool) {\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\ttasks, err := l.assigner.ListTasks(ctx, l.config.ProjectDir)\n\tif err != nil {\n\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n\t\treturn \"\", false\n\t}\n\n\t// Cache the latest tasks for snapshot queries.\n\tl.tasksMu.Lock()\n\tl.lastTasks = tasks\n\tl.tasksMu.Unlock()\n\n\tnow := time.Now()\n\tl.dedupMu.Lock()\n\tdefer l.dedupMu.Unlock()\n\n\t// Expire old dedup entries while we're here.\n\tfor id, ts := range l.dedup {\n\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n\t\t\tdelete(l.dedup, id)\n\t\t}\n\t}\n\n\tfor _, task := range tasks {\n\t\tif task.ID == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n\t\t\tcontinue // still within dedup window\n\t\t}\n\t\t// Assign this task.\n\t\tl.dedup[task.ID] = now\n\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n\t\treturn task.ID, true\n\t}\n\n\treturn \"\", false\n}\n\n// countActiveHostRuns counts running or pending host runs for the project.\nfunc (l *Loop) countActiveHostRuns() int {\n\tctx := context.Background()\n\truns, err := l.store.ListRunsByProject(ctx, l.config.ProjectDir, time.Time{})\n\tif err != nil {\n\t\treturn 0\n\t}\n\tcount := 0\n\tfor _, r := range runs {\n\t\tif r.IsHost && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n\t\t\tcount++\n\t\t}\n\t}\n\treturn count\n}\n\n// sleep waits for the given duration or until the loop is stopped or resumed.\n// Returns false if the loop was stopped.\nfunc (l *Loop) sleep(d time.Duration) bool {\n\tselect {\n\tcase <-time.After(d):\n\t\treturn true\n\tcase <-l.resumeCh:\n\t\treturn true\n\tcase <-l.stopCh:\n\t\treturn false\n\t}\n}\n\n// ReadListTasksOutput reads the output directory from a list-tasks workflow run\n// and parses JSONL task output from the last step's output file.\nfunc ReadListTasksOutput(outputDir string) ([]Task, error) {\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading list-tasks output dir: %w\", err)\n\t}\n\n\t// Find the most recently modified .out file.\n\tvar latest string\n\tvar latestMod time.Time\n\tfor _, e := range entries {\n\t\tif e.IsDir() || filepath.Ext(e.Name()) != \".out\" {\n\t\t\tcontinue\n\t\t}\n\t\tinfo, err := e.Info()\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif latest == \"\" || info.ModTime().After(latestMod) {\n\t\t\tlatest = e.Name()\n\t\t\tlatestMod = info.ModTime()\n\t\t}\n\t}\n\n\tif latest == \"\" {\n\t\treturn nil, fmt.Errorf(\"no output files found in %s\", outputDir)\n\t}\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, latest))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading output file %s: %w\", latest, err)\n\t}\n\n\treturn ParseTasksJSONL(string(data))\n}\n","numLines":671,"startLine":1,"totalLines":671}}}
