    62→\t\t\tprintSubcommandHelp(\"health\")\n    63→\t\t\treturn\n    64→\t\t}\n    65→\t\tcmdHealth(os.Args[2:])\n    66→\t\treturn\n    67→\tcase \"get\":\n    68→\t\tif hasHelpFlag(os.Args[2:]) {\n    69→\t\t\tprintSubcommandHelp(\"get\")\n    70→\t\t\treturn\n    71→\t\t}\n    72→\t\tcmdGet(os.Args[2:])\n    73→\t\treturn\n    74→\tcase \"set\":\n    75→\t\tif hasHelpFlag(os.Args[2:]) {\n    76→\t\t\tprintSubcommandHelp(\"set\")\n    77→\t\t\treturn\n    78→\t\t}\n    79→\t\tcmdSet(os.Args[2:])\n    80→\t\treturn\n    81→\tcase \"tasks\":\n    82→\t\tif hasHelpFlag(os.Args[2:]) {\n    83→\t\t\tprintSubcommandHelp(\"tasks\")\n    84→\t\t\treturn\n    85→\t\t}\n    86→\t\tcmdTasks(os.Args[2:])\n    87→\t\treturn\n    88→\tcase \"workflow\":\n    89→\t\tif hasHelpFlag(os.Args[2:]) {\n    90→\t\t\tprintSubcommandHelp(\"workflow\")\n    91→\t\t\treturn\n    92→\t\t}\n    93→\t\tcmdWorkflow(os.Args[2:])\n    94→\t\treturn\n    95→\tcase \"project\":\n    96→\t\tif hasHelpFlag(os.Args[2:]) {\n    97→\t\t\tprintSubcommandHelp(\"project\")\n    98→\t\t\treturn\n    99→\t\t}\n   100→\t\tcmdProject(os.Args[2:])\n   101→\t\treturn\n   102→\tcase \"validate\":\n   103→\t\tif hasHelpFlag(os.Args[2:]) {\n   104→\t\t\tprintSubcommandHelp(\"validate\")\n   105→\t\t\treturn\n   106→\t\t}\n   107→\t\tcmdValidate(os.Args[2:])\n   108→\t\treturn\n   109→\t}\n   110→\n   111→\t// Handle --help for daemon commands before connecting\n   112→\tdaemonCmds := map[string]bool{\n   113→\t\t\"run\": true, \"resume\": true, \"status\": true, \"logs\": true, \"poll\": true,\n   114→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n   115→\t}\n   116→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n   117→\t\tprintSubcommandHelp(os.Args[1])\n   118→\t\treturn\n   119→\t}\n   120→\n   121→\t// Commands that need a daemon connection\n   122→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   123→\tif addr == \"\" {\n   124→\t\taddr = config.DefaultSocketAddr()\n   125→\t}\n   126→\n   127→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   128→\tif err != nil {\n   129→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   130→\t\tos.Exit(1)\n   131→\t}\n   132→\tdefer conn.Close()\n   133→\n   134→\tclient := pb.NewClocheServiceClient(conn)\n   135→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   136→\tdefer cancel()\n   137→\n   138→\tswitch os.Args[1] {\n   139→\tcase \"run\":\n   140→\t\tcmdRun(ctx, client, os.Args[2:])\n   141→\tcase \"resume\":\n   142→\t\tcmdResume(ctx, client, os.Args[2:])\n   143→\tcase \"status\":\n   144→\t\tcmdStatus(ctx, client, os.Args[2:])\n   145→\tcase \"logs\":\n   146→\t\tcmdLogs(client, os.Args[2:])\n   147→\tcase \"poll\":\n   148→\t\tcmdPoll(client, os.Args[2:])\n   149→\tcase \"list\":\n   150→\t\tcmdList(ctx, client, os.Args[2:])\n   151→\tcase \"stop\":\n   152→\t\tcmdStop(ctx, client, os.Args[2:])\n   153→\tcase \"delete\":\n   154→\t\tcmdDelete(ctx, client, os.Args[2:])\n   155→\tcase \"loop\":\n   156→\t\tcmdLoop(ctx, client, os.Args[2:])\n   157→\tcase \"shutdown\":\n   158→\t\tcmdShutdown(ctx, client, os.Args[2:])\n   159→\tdefault:\n   160→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   161→\t\tprintTopLevelHelp()\n   162→\t\tos.Exit(1)\n   163→\t}\n   164→}\n   165→\n   166→\n   167→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   168→\tvar workflow, prompt, title, issueID string\n   169→\tvar keepContainer bool\n   170→\n   171→\tfor i := 0; i < len(args); i++ {\n   172→\t\tswitch args[i] {\n   173→\t\tcase \"--workflow\":\n   174→\t\t\tif i+1 < len(args) {\n   175→\t\t\t\ti++\n   176→\t\t\t\tworkflow = args[i]\n   177→\t\t\t}\n   178→\t\tcase \"--prompt\", \"-p\":\n   179→\t\t\tif i+1 < len(args) {\n   180→\t\t\t\ti++\n   181→\t\t\t\tprompt = args[i]\n   182→\t\t\t}\n   183→\t\tcase \"--title\":\n   184→\t\t\tif i+1 < len(args) {\n   185→\t\t\t\ti++\n   186→\t\t\t\ttitle = args[i]\n   187→\t\t\t}\n   188→\t\tcase \"--issue\", \"-i\":\n   189→\t\t\tif i+1 < len(args) {\n   190→\t\t\t\ti++\n   191→\t\t\t\tissueID = args[i]\n   192→\t\t\t}\n   193→\t\tcase \"--keep-container\":\n   194→\t\t\tkeepContainer = true\n   195→\t\tdefault:\n   196→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   197→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   198→\t\t\t\tworkflow = args[i]\n   199→\t\t\t}\n   200→\t\t}\n   201→\t}\n   202→\n   203→\tif workflow == \"\" {\n   204→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"] [--issue ID]\\n\")\n   205→\t\tos.Exit(1)\n   206→\t}\n   207→\n   208→\tcwd, _ := os.Getwd()\n   209→\n   210→\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n   211→\t// Try loading from any .cloche file; only extract image for container workflows.\n   212→\tvar image string\n   213→\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n   214→\t\timage = wf.Config[\"container.image\"]\n   215→\t}\n   216→\n   217→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   218→\t\tWorkflowName:  workflow,\n   219→\t\tProjectDir:    cwd,\n   220→\t\tImage:         image,\n   221→\t\tPrompt:        prompt,\n   222→\t\tKeepContainer: keepContainer,\n   223→\t\tTitle:         title,\n   224→\t\tIssueId:       issueID,\n   225→\t})\n   226→\tif err != nil {\n   227→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   228→\t\tos.Exit(1)\n   229→\t}\n   230→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   231→}\n   232→\n   233→func cmdResume(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   234→\tif len(args) < 1 {\n   235→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche resume <run-id> [step-name]\\n\")\n   236→\t\tos.Exit(1)\n   237→\t}\n   238→\n   239→\trunID := args[0]\n   240→\tstepName := \"\"\n   241→\tif len(args) > 1 {\n   242→\t\tstepName = args[1]\n   243→\t}\n   244→\n   245→\t// Send resume via gRPC metadata on a RunWorkflow call\n   246→\tmd := metadata.Pairs(\n   247→\t\t\"x-cloche-resume-run-id\", runID,\n   248→\t\t\"x-cloche-resume-step\", stepName,\n   249→\t)\n   250→\tctx = metadata.NewOutgoingContext(ctx, md)\n   251→\n   252→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{})\n   253→\tif err != nil {\n   254→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   255→\t\tos.Exit(1)\n   256→\t}\n   257→\tfmt.Printf(\"Resumed run: %s\\n\", resp.RunId)\n   258→}\n   259→\n   260→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   261→\t// Parse flags to detect --all before checking positional args.\n   262→\tvar all bool\n   263→\tvar positional []string\n   264→\tfor _, arg := range args {\n   265→\t\tif arg == \"--all\" {\n   266→\t\t\tall = true\n   267→\t\t} else {\n   268→\t\t\tpositional = append(positional, arg)\n   269→\t\t}\n   270→\t}\n   271→\n   272→\t// If a run ID is provided, show single-run status.\n   273→\tif len(positional) > 0 {\n   274→\t\tcmdStatusRun(ctx, client, positional[0])\n   275→\t\treturn\n   276→\t}\n   277→\n   278→\t// No run ID: show daemon status overview.\n   279→\tcmdStatusOverview(ctx, client, os.Stdout, all)\n   280→}\n   281→\n   282→func cmdStatusRun(ctx context.Context, client pb.ClocheServiceClient, runID string) {\n   283→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: runID})\n   284→\tif err != nil {\n   285→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   286→\t\tos.Exit(1)\n   287→\t}\n   288→\n   289→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   290→\tif resp.Title != \"\" {\n   291→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   292→\t}\n   293→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   294→\tif resp.IsHost {\n   295→\t\tfmt.Printf(\"Type:      host\\n\")\n   296→\t} else {\n   297→\t\tfmt.Printf(\"Type:      container\\n\")\n   298→\t}\n   299→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   300→\tif resp.ContainerId != \"\" {\n   301→\t\tcid := resp.ContainerId\n   302→\t\tif len(cid) > 12 {\n   303→\t\t\tcid = cid[:12]\n   304→\t\t}\n   305→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   306→\t}\n   307→\tif resp.ErrorMessage != \"\" {\n   308→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   309→\t}\n   310→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   311→\tfor _, exec := range resp.StepExecutions {\n   312→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   313→\t}\n   314→}\n   315→\n   316→func cmdStatusOverview(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, all bool) {\n   317→\t// Get daemon version.\n   318→\tverResp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   319→\tif err != nil {\n   320→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   321→\t\tos.Exit(1)\n   322→\t}\n   323→\tfmt.Fprintf(w, \"Daemon version: %s\\n\", verResp.Version)\n   324→\n   325→\tcwd, _ := os.Getwd()\n   326→\t_, hasClocheDir := os.Stat(filepath.Join(cwd, \".cloche\"))\n   327→\n   328→\tif !all && hasClocheDir == nil {\n   329→\t\t// In a project directory: show project-specific info.\n   330→\t\tcmdStatusProject(ctx, client, w, cwd)\n   331→\t} else {\n   332→\t\t// Not in a project directory or --all: show global overview.\n   333→\t\tcmdStatusGlobal(ctx, client, w)\n   334→\t}\n   335→}\n   336→\n   337→func cmdStatusProject(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, projectDir string) {\n   338→\tinfo, err := client.GetProjectInfo(ctx, &pb.GetProjectInfoRequest{ProjectDir: projectDir})\n   339→\tif err != nil {\n   340→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   341→\t\tos.Exit(1)\n   342→\t}\n   343→\n   344→\tfmt.Fprintf(w, \"Project: %s\\n\", info.Name)\n   345→\tfmt.Fprintf(w, \"Concurrency: %d\\n\", info.Concurrency)\n   346→\n   347→\tloopStatus := \"stopped\"\n   348→\tif info.LoopRunning {\n   349→\t\tif info.ErrorHalted {\n   350→\t\t\tloopStatus = \"halted\"\n   351→\t\t} else {\n   352→\t\t\tloopStatus = \"running\"\n   353→\t\t}\n   354→\t}\n   355→\tfmt.Fprintf(w, \"Orchestration loop: %s\\n\", loopStatus)\n   356→\n   357→\t// Fetch runs for the past hour to compute success rate.\n   358→\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: projectDir})\n   359→\tif err != nil {\n   360→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   361→\t\tos.Exit(1)\n   362→\t}\n   363→\n   364→\tvar succeeded int\n   365→\tfor _, run := range listResp.Runs {\n   366→\t\tif run.State == \"succeeded\" {\n   367→\t\t\tsucceeded++\n   368→\t\t}\n   369→\t}\n   370→\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n   371→\n   372→\t// Active runs from project info.\n   373→\tfmt.Fprintf(w, \"Active runs: %d\\n\", len(info.ActiveRuns))\n   374→\tfor _, run := range info.ActiveRuns {\n   375→\t\tdur := formatDuration(run.StartedAt)\n   376→\t\tfmt.Fprintf(w, \"  %s: %s\\n\", run.RunId, dur)\n   377→\t}\n   378→}\n   379→\n   380→func cmdStatusGlobal(ctx context.Context, client pb.ClocheServiceClient, w io.Writer) {\n   381→\t// Server filters to past hour when All is not set.\n   382→\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{})\n   383→\tif err != nil {\n   384→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   385→\t\tos.Exit(1)\n   386→\t}\n   387→\n   388→\tvar succeeded, activeCount int\n   389→\ttype activeRun struct {\n   390→\t\tid        string\n   391→\t\tstartedAt string\n   392→\t}\n   393→\tvar actives []activeRun\n   394→\n   395→\tfor _, run := range listResp.Runs {\n   396→\t\tif run.State == \"succeeded\" {\n   397→\t\t\tsucceeded++\n   398→\t\t}\n   399→\t\tif run.State == \"running\" || run.State == \"pending\" {\n   400→\t\t\tactiveCount++\n   401→\t\t\tactives = append(actives, activeRun{id: run.RunId, startedAt: run.StartedAt})\n   402→\t\t}\n   403→\t}\n   404→\n   405→\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n   406→\tfmt.Fprintf(w, \"Active runs: %d\\n\", activeCount)\n   407→\tfor _, a := range actives {\n   408→\t\tdur := formatDuration(a.startedAt)\n   409→\t\tfmt.Fprintf(w, \"  %s: %s\\n\", a.id, dur)\n   410→\t}\n   411→}\n   412→\n   413→// formatDuration parses a Go time string and returns a human-readable duration since then.\n   414→func formatDuration(startedAt string) string {\n   415→\tparsed, err := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", startedAt)\n   416→\tif err != nil {\n   417→\t\treturn startedAt\n   418→\t}\n   419→\td := time.Since(parsed)\n   420→\tif d < time.Minute {\n   421→\t\treturn fmt.Sprintf(\"%ds\", int(d.Seconds()))\n   422→\t}\n   423→\tif d < time.Hour {\n   424→\t\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n   425→\t}\n   426→\treturn fmt.Sprintf(\"%dh%dm\", int(d.Hours()), int(d.Minutes())%60)\n   427→}\n   428→\n   429→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   430→\tvar all bool\n   431→\tvar projectDir, stateFilter, issueFilter string\n   432→\tvar limit int32\n   433→\n   434→\tfor i := 0; i < len(args); i++ {\n   435→\t\tswitch args[i] {\n   436→\t\tcase \"--all\":\n   437→\t\t\tall = true\n   438→\t\tcase \"--project\", \"-p\":\n   439→\t\t\tif i+1 < len(args) {\n   440→\t\t\t\ti++\n   441→\t\t\t\tprojectDir = args[i]\n   442→\t\t\t}\n   443→\t\tcase \"--state\", \"-s\":\n   444→\t\t\tif i+1 < len(args) {\n   445→\t\t\t\ti++\n   446→\t\t\t\tstateFilter = args[i]\n   447→\t\t\t}\n   448→\t\tcase \"--limit\", \"-n\":\n   449→\t\t\tif i+1 < len(args) {\n   450→\t\t\t\ti++\n   451→\t\t\t\tn, err := strconv.Atoi(args[i])\n   452→\t\t\t\tif err != nil {\n   453→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   454→\t\t\t\t\tos.Exit(1)\n   455→\t\t\t\t}\n   456→\t\t\t\tlimit = int32(n)\n   457→\t\t\t}\n   458→\t\tcase \"--issue\", \"-i\":\n   459→\t\t\tif i+1 < len(args) {\n   460→\t\t\t\ti++\n   461→\t\t\t\tissueFilter = args[i]\n   462→\t\t\t}\n   463→\t\t}\n   464→\t}\n   465→\n   466→\treq := &pb.ListRunsRequest{\n   467→\t\tState:  stateFilter,\n   468→\t\tLimit:  limit,\n   469→\t\tTaskId: issueFilter,\n   470→\t}\n   471→\tif projectDir != \"\" {\n   472→\t\treq.ProjectDir = projectDir\n   473→\t} else if all {\n   474→\t\treq.All = true\n   475→\t} else {\n   476→\t\t// Default: filter to current project\n   477→\t\tcwd, _ := os.Getwd()\n   478→\t\treq.ProjectDir = cwd\n   479→\t}\n   480→\n   481→\tresp, err := client.ListRuns(ctx, req)\n   482→\tif err != nil {\n   483→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   484→\t\tos.Exit(1)\n   485→\t}\n   486→\n   487→\tif len(resp.Runs) == 0 {\n   488→\t\tfmt.Println(\"No runs found.\")\n   489→\t\treturn\n   490→\t}\n   491→\n   492→\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n   493→\tfmt.Fprintln(w, \"RUN ID\\tWORKFLOW\\tSTATE\\tTYPE\\tTASK ID\\tTITLE\\tCONTAINER\\tERROR\")\n   494→\tfor _, run := range resp.Runs {\n   495→\t\trunType := \"container\"\n   496→\t\tif run.IsHost {\n   497→\t\t\trunType = \"host\"\n   498→\t\t}\n   499→\t\ttitle := run.Title\n   500→\t\tif len(title) > 40 {\n   501→\t\t\ttitle = title[:37] + \"...\"\n   502→\t\t}\n   503→\t\terrMsg := run.ErrorMessage\n   504→\t\tif len(errMsg) > 60 {\n   505→\t\t\terrMsg = errMsg[:57] + \"...\"\n   506→\t\t}\n   507→\t\tfmt.Fprintf(w, \"%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\n\",\n   508→\t\t\trun.RunId, run.WorkflowName, run.State, runType,\n   509→\t\t\trun.TaskId, title, run.ContainerId, errMsg)\n   510→\t}\n   511→\tw.Flush()\n   512→}\n   513→\n   514→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   515→\tif len(args) < 1 {\n   516→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n   517→\t\tos.Exit(1)\n   518→\t}\n   519→\n   520→\tvar stepFilter, typeFilter string\n   521→\tvar follow bool\n   522→\tvar limit int\n   523→\trunID := args[0]\n   524→\n   525→\tfor i := 1; i < len(args); i++ {\n   526→\t\tswitch args[i] {\n   527→\t\tcase \"--step\", \"-s\":\n   528→\t\t\tif i+1 < len(args) {\n   529→\t\t\t\ti++\n   530→\t\t\t\tstepFilter = args[i]\n   531→\t\t\t}\n   532→\t\tcase \"--type\":\n   533→\t\t\tif i+1 < len(args) {\n   534→\t\t\t\ti++\n   535→\t\t\t\ttypeFilter = args[i]\n   536→\t\t\t}\n   537→\t\tcase \"--follow\", \"-f\":\n   538→\t\t\tfollow = true\n   539→\t\tcase \"--limit\", \"-l\":\n   540→\t\t\tif i+1 < len(args) {\n   541→\t\t\t\ti++\n   542→\t\t\t\tn, err := strconv.Atoi(args[i])\n   543→\t\t\t\tif err != nil || n < 0 {\n   544→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n   545→\t\t\t\t\tos.Exit(1)\n   546→\t\t\t\t}\n   547→\t\t\t\tlimit = n\n   548→\t\t\t}\n   549→\t\t}\n   550→\t}\n   551→\n   552→\t// Use background context — log output can be large and follow mode blocks.\n   553→\tctx := context.Background()\n   554→\tvar mdPairs []string\n   555→\tif follow {\n   556→\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n   557→\t}\n   558→\tif limit > 0 {\n   559→\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n   560→\t}\n   561→\tif len(mdPairs) > 0 {\n   562→\t\tmd := metadata.Pairs(mdPairs...)\n   563→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   564→\t}\n   565→\n   566→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   567→\t\tRunId:    runID,\n   568→\t\tStepName: stepFilter,\n   569→\t\tLogType:  typeFilter,\n   570→\t})\n   571→\tif err != nil {\n   572→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   573→\t\tos.Exit(1)\n   574→\t}\n   575→\n   576→\tfor {\n   577→\t\tentry, err := stream.Recv()\n   578→\t\tif err != nil {\n   579→\t\t\tif errors.Is(err, io.EOF) {\n   580→\t\t\t\tbreak\n   581→\t\t\t}\n   582→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   583→\t\t\tos.Exit(1)\n   584→\t\t}\n   585→\n   586→\t\tswitch entry.Type {\n   587→\t\tcase \"step_started\":\n   588→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   589→\t\t\tif entry.Message != \"\" {\n   590→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   591→\t\t\t}\n   592→\t\tcase \"step_completed\":\n   593→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   594→\t\t\tif entry.Message != \"\" {\n   595→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   596→\t\t\t}\n   597→\t\tcase \"run_completed\":\n   598→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   599→\t\t\tif entry.Message != \"\" {\n   600→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   601→\t\t\t}\n   602→\t\tcase \"full_log\":\n   603→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   604→\t\tcase \"log\":\n   605→\t\t\t// Live-streamed log line from an active run.\n   606→\t\t\tfmt.Println(entry.Message)\n   607→\t\tdefault:\n   608→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   609→\t\t\tif entry.StepName != \"\" {\n   610→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   611→\t\t\t}\n   612→\t\t\tif entry.Message != \"\" {\n   613→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   614→\t\t\t}\n   615→\t\t}\n   616→\t}\n   617→}\n   618→\n   619→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   620→\tif len(args) < 1 {\n   621→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   622→\t\tos.Exit(1)\n   623→\t}\n   624→\n   625→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   626→\tif err != nil {\n   627→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   628→\t\tos.Exit(1)\n   629→\t}\n   630→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   631→}\n   632→\n   633→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   634→\tif len(args) < 1 {\n   635→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   636→\t\tos.Exit(1)\n   637→\t}\n   638→\n   639→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   640→\tif err != nil {\n   641→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   642→\t\tos.Exit(1)\n   643→\t}\n   644→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   645→}\n   646→\n   647→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   648→\tcwd, _ := os.Getwd()\n   649→\n   650→\t// Check for \"stop\" subcommand\n   651→\tif len(args) > 0 && args[0] == \"stop\" {\n   652→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   653→\t\tif err != nil {\n   654→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   655→\t\t\tos.Exit(1)\n   656→\t\t}\n   657→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   658→\t\treturn\n   659→\t}\n   660→\n   661→\t// Check for \"resume\" subcommand\n   662→\tif len(args) > 0 && args[0] == \"resume\" {\n   663→\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n   664→\t\tif err != nil {\n   665→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   666→\t\t\tos.Exit(1)\n   667→\t\t}\n   668→\t\tfmt.Println(\"Orchestration loop resumed.\")\n   669→\t\treturn\n   670→\t}\n   671→\n   672→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   673→\tvar maxConcurrent int32\n   674→\tfor i := 0; i < len(args); i++ {\n   675→\t\tswitch args[i] {\n   676→\t\tcase \"--max\":\n   677→\t\t\tif i+1 < len(args) {\n   678→\t\t\t\ti++\n   679→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   680→\t\t\t\tif n != 1 || err != nil {\n   681→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   682→\t\t\t\t\tos.Exit(1)\n   683→\t\t\t\t}\n   684→\t\t\t}\n   685→\t\t}\n   686→\t}\n   687→\n   688→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   689→\t\tProjectDir:    cwd,\n   690→\t\tMaxConcurrent: maxConcurrent,\n   691→\t})\n   692→\tif err != nil {\n   693→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   694→\t\tos.Exit(1)\n   695→\t}\n   696→\tif maxConcurrent > 0 {\n   697→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   698→\t} else {\n   699→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   700→\t}\n   701→}\n   702→\n   703→func cmdTasks(args []string) {\n   704→\t// Determine HTTP address from env\n   705→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   706→\tif httpAddr == \"\" {\n   707→\t\thttpAddr = \"localhost:8080\"\n   708→\t}\n   709→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   710→\n   711→\t// Determine project label from --project flag or current directory\n   712→\tprojectDir := \"\"\n   713→\tfor i := 0; i < len(args); i++ {\n   714→\t\tswitch args[i] {\n   715→\t\tcase \"--project\":\n   716→\t\t\tif i+1 < len(args) {\n   717→\t\t\t\ti++\n   718→\t\t\t\tprojectDir = args[i]\n   719→\t\t\t}\n   720→\t\t}\n   721→\t}\n   722→\n   723→\tif projectDir == \"\" {\n   724→\t\tcwd, _ := os.Getwd()\n   725→\t\tprojectDir = filepath.Base(cwd)\n   726→\t}\n   727→\n   728→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   729→\tresp, err := http.Get(tasksURL)\n   730→\tif err != nil {\n   731→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   732→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   733→\t\tos.Exit(1)\n   734→\t}\n   735→\tdefer resp.Body.Close()\n   736→\n   737→\tif resp.StatusCode != 200 {\n   738→\t\tbody, _ := io.ReadAll(resp.Body)\n   739→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   740→\t\tos.Exit(1)\n   741→\t}\n   742→\n   743→\ttype taskEntry struct {\n   744→\t\tID          string `json:\"id\"`\n   745→\t\tStatus      string `json:\"status\"`\n   746→\t\tTitle       string `json:\"title\"`\n   747→\t\tDescription string `json:\"description\"`\n   748→\t\tAssigned    bool   `json:\"assigned\"`\n   749→\t\tAssignedAt  string `json:\"assigned_at\"`\n   750→\t\tRunID       string `json:\"run_id\"`\n   751→\t}\n   752→\n   753→\tvar tasks []taskEntry\n   754→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   755→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   756→\t\tos.Exit(1)\n   757→\t}\n   758→\n   759→\tif len(tasks) == 0 {\n   760→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   761→\t\treturn\n   762→\t}\n   763→\n   764→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   765→\tfor _, t := range tasks {\n   766→\t\tstatus := t.Status\n   767→\t\tif status == \"\" {\n   768→\t\t\tstatus = \"open\"\n   769→\t\t}\n   770→\t\tassigned := \"-\"\n   771→\t\tif t.Assigned {\n   772→\t\t\tassigned = \"yes\"\n   773→\t\t}\n   774→\t\trunID := \"\"\n   775→\t\tif t.RunID != \"\" {\n   776→\t\t\trunID = t.RunID\n   777→\t\t\tif len(runID) > 30 {\n   778→\t\t\t\trunID = runID[:27] + \"...\"\n   779→\t\t\t}\n   780→\t\t}\n   781→\t\ttitle := t.Title\n   782→\t\tif len(title) > 40 {\n   783→\t\t\ttitle = title[:37] + \"...\"\n   784→\t\t}\n   785→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   786→\t}\n   787→}\n   788→\n   789→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   790→\tvar force bool\n   791→\tfor _, a := range args {\n   792→\t\tif a == \"-f\" || a == \"--force\" {\n   793→\t\t\tforce = true\n   794→\t\t}\n   795→\t}\n   796→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n   797→\tif err != nil {\n   798→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   799→\t\tos.Exit(1)\n   800→\t}\n   801→\tfmt.Println(\"Daemon shutting down.\")\n   802→}\n   803→\n   804→// resolveRunContext returns the project directory and run ID for context\n   805→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   806→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   807→func resolveRunContext() (projectDir, runID string, err error) {\n   808→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   809→\tif runID == \"\" {\n   810→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   811→\t}\n   812→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   813→\tif projectDir == \"\" {\n   814→\t\tprojectDir, err = os.Getwd()\n   815→\t\tif err != nil {\n   816→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   817→\t\t}\n   818→\t}\n   819→\treturn projectDir, runID, nil\n   820→}\n   821→\n   822→func cmdGet(args []string) {\n   823→\tif len(args) < 1 {\n   824→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   825→\t\tos.Exit(1)\n   826→\t}\n   827→\n   828→\tprojectDir, runID, err := resolveRunContext()\n   829→\tif err != nil {\n   830→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   831→\t\tos.Exit(1)\n   832→\t}\n   833→\n   834→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   835→\tif err != nil {\n   836→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   837→\t\tos.Exit(1)\n   838→\t}\n   839→\tif !ok {\n   840→\t\tos.Exit(1)\n   841→\t}\n   842→\tfmt.Println(val)\n   843→}\n   844→\n   845→func cmdSet(args []string) {\n   846→\tif len(args) < 2 {\n   847→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   848→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   849→\t\tos.Exit(1)\n   850→\t}\n   851→\n   852→\tprojectDir, runID, err := resolveRunContext()\n   853→\tif err != nil {\n   854→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   855→\t\tos.Exit(1)\n   856→\t}\n   857→\n   858→\tvalue := args[1]\n   859→\tif value == \"-\" {\n   860→\t\tdata, err := io.ReadAll(os.Stdin)\n   861→\t\tif err != nil {\n   862→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   863→\t\t\tos.Exit(1)\n   864→\t\t}\n   865→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   866→\t}\n   867→\n   868→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   869→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   870→\t\tos.Exit(1)\n   871→\t}\n   872→}\n   873→\n   874→func cmdVersion() {\n   875→\tcliVersion := version.Version()\n   876→\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   877→\n   878→\t// Try to get daemon version via gRPC\n   879→\tdaemonVersion := \"<unavailable>\"\n   880→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   881→\tif addr == \"\" {\n   882→\t\taddr = config.DefaultSocketAddr()\n   883→\t}\n   884→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   885→\tif err == nil {\n   886→\t\tdefer conn.Close()\n   887→\t\tclient := pb.NewClocheServiceClient(conn)\n   888→\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   889→\t\tdefer cancel()\n   890→\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   891→\t\tif err == nil {\n   892→\t\t\tdaemonVersion = resp.Version\n   893→\t\t}\n   894→\t}\n   895→\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   896→\n   897→\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   898→\tagentVersion := \"<unavailable>\"\n   899→\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   900→\tif image == \"\" {\n   901→\t\timage = \"cloche-agent:latest\"\n   902→\t}\n   903→\tout, err := exec.CommandContext(\n   904→\t\tcontext.Background(),\n   905→\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   906→\t).Output()\n   907→\tif err == nil {\n   908→\t\tagentVersion = strings.TrimSpace(string(out))\n   909→\t\t// Strip \"cloche-agent \" prefix if present\n   910→\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n   911→\t}\n   912→\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n   913→\n   914→\t// Warn about version mismatches\n   915→\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n   916→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n   917→\t}\n   918→\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n   919→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n   920→\t}\n   921→}\n   922→"}]},"parent_tool_use_id":null,"session_id":"3ce95e97-6dbe-466e-9cea-9a2f04871e38","uuid":"7abb7dce-24b5-48be-9a7b-63e8604ab88f","timestamp":"2026-03-18T18:35:49.397Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\t\"text/tabwriter\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n\t\"github.com/cloche-dev/cloche/internal/version\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n\n\t// Handle version flags before anything else\n\tif os.Args[1] == \"-v\" || os.Args[1] == \"--version\" {\n\t\tcmdVersion()\n\t\treturn\n\t}\n\n\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n\tswitch os.Args[1] {\n\tcase \"help\":\n\t\tprintHelp(os.Args[2:])\n\t\treturn\n\tcase \"--help\", \"-h\":\n\t\tprintTopLevelHelp()\n\t\treturn\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"init\")\n\t\t\treturn\n\t\t}\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"health\")\n\t\t\treturn\n\t\t}\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\tcase \"get\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"get\")\n\t\t\treturn\n\t\t}\n\t\tcmdGet(os.Args[2:])\n\t\treturn\n\tcase \"set\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"set\")\n\t\t\treturn\n\t\t}\n\t\tcmdSet(os.Args[2:])\n\t\treturn\n\tcase \"tasks\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"tasks\")\n\t\t\treturn\n\t\t}\n\t\tcmdTasks(os.Args[2:])\n\t\treturn\n\tcase \"workflow\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"workflow\")\n\t\t\treturn\n\t\t}\n\t\tcmdWorkflow(os.Args[2:])\n\t\treturn\n\tcase \"project\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"project\")\n\t\t\treturn\n\t\t}\n\t\tcmdProject(os.Args[2:])\n\t\treturn\n\tcase \"validate\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"validate\")\n\t\t\treturn\n\t\t}\n\t\tcmdValidate(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Handle --help for daemon commands before connecting\n\tdaemonCmds := map[string]bool{\n\t\t\"run\": true, \"resume\": true, \"status\": true, \"logs\": true, \"poll\": true,\n\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n\t}\n\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n\t\tprintSubcommandHelp(os.Args[1])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = config.DefaultSocketAddr()\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"resume\":\n\t\tcmdResume(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client, os.Args[2:])\n\tdefault:\n\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n}\n\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title, issueID string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--issue\", \"-i\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tissueID = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"] [--issue ID]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n\t// Try loading from any .cloche file; only extract image for container workflows.\n\tvar image string\n\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n\t\timage = wf.Config[\"container.image\"]\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t\tIssueId:       issueID,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdResume(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche resume <run-id> [step-name]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\trunID := args[0]\n\tstepName := \"\"\n\tif len(args) > 1 {\n\t\tstepName = args[1]\n\t}\n\n\t// Send resume via gRPC metadata on a RunWorkflow call\n\tmd := metadata.Pairs(\n\t\t\"x-cloche-resume-run-id\", runID,\n\t\t\"x-cloche-resume-step\", stepName,\n\t)\n\tctx = metadata.NewOutgoingContext(ctx, md)\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Resumed run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\t// Parse flags to detect --all before checking positional args.\n\tvar all bool\n\tvar positional []string\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t} else {\n\t\t\tpositional = append(positional, arg)\n\t\t}\n\t}\n\n\t// If a run ID is provided, show single-run status.\n\tif len(positional) > 0 {\n\t\tcmdStatusRun(ctx, client, positional[0])\n\t\treturn\n\t}\n\n\t// No run ID: show daemon status overview.\n\tcmdStatusOverview(ctx, client, os.Stdout, all)\n}\n\nfunc cmdStatusRun(ctx context.Context, client pb.ClocheServiceClient, runID string) {\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: runID})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdStatusOverview(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, all bool) {\n\t// Get daemon version.\n\tverResp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Fprintf(w, \"Daemon version: %s\\n\", verResp.Version)\n\n\tcwd, _ := os.Getwd()\n\t_, hasClocheDir := os.Stat(filepath.Join(cwd, \".cloche\"))\n\n\tif !all && hasClocheDir == nil {\n\t\t// In a project directory: show project-specific info.\n\t\tcmdStatusProject(ctx, client, w, cwd)\n\t} else {\n\t\t// Not in a project directory or --all: show global overview.\n\t\tcmdStatusGlobal(ctx, client, w)\n\t}\n}\n\nfunc cmdStatusProject(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, projectDir string) {\n\tinfo, err := client.GetProjectInfo(ctx, &pb.GetProjectInfoRequest{ProjectDir: projectDir})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Fprintf(w, \"Project: %s\\n\", info.Name)\n\tfmt.Fprintf(w, \"Concurrency: %d\\n\", info.Concurrency)\n\n\tloopStatus := \"stopped\"\n\tif info.LoopRunning {\n\t\tif info.ErrorHalted {\n\t\t\tloopStatus = \"halted\"\n\t\t} else {\n\t\t\tloopStatus = \"running\"\n\t\t}\n\t}\n\tfmt.Fprintf(w, \"Orchestration loop: %s\\n\", loopStatus)\n\n\t// Fetch runs for the past hour to compute success rate.\n\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: projectDir})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvar succeeded int\n\tfor _, run := range listResp.Runs {\n\t\tif run.State == \"succeeded\" {\n\t\t\tsucceeded++\n\t\t}\n\t}\n\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n\n\t// Active runs from project info.\n\tfmt.Fprintf(w, \"Active runs: %d\\n\", len(info.ActiveRuns))\n\tfor _, run := range info.ActiveRuns {\n\t\tdur := formatDuration(run.StartedAt)\n\t\tfmt.Fprintf(w, \"  %s: %s\\n\", run.RunId, dur)\n\t}\n}\n\nfunc cmdStatusGlobal(ctx context.Context, client pb.ClocheServiceClient, w io.Writer) {\n\t// Server filters to past hour when All is not set.\n\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvar succeeded, activeCount int\n\ttype activeRun struct {\n\t\tid        string\n\t\tstartedAt string\n\t}\n\tvar actives []activeRun\n\n\tfor _, run := range listResp.Runs {\n\t\tif run.State == \"succeeded\" {\n\t\t\tsucceeded++\n\t\t}\n\t\tif run.State == \"running\" || run.State == \"pending\" {\n\t\t\tactiveCount++\n\t\t\tactives = append(actives, activeRun{id: run.RunId, startedAt: run.StartedAt})\n\t\t}\n\t}\n\n\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n\tfmt.Fprintf(w, \"Active runs: %d\\n\", activeCount)\n\tfor _, a := range actives {\n\t\tdur := formatDuration(a.startedAt)\n\t\tfmt.Fprintf(w, \"  %s: %s\\n\", a.id, dur)\n\t}\n}\n\n// formatDuration parses a Go time string and returns a human-readable duration since then.\nfunc formatDuration(startedAt string) string {\n\tparsed, err := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", startedAt)\n\tif err != nil {\n\t\treturn startedAt\n\t}\n\td := time.Since(parsed)\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%ds\", int(d.Seconds()))\n\t}\n\tif d < time.Hour {\n\t\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n\t}\n\treturn fmt.Sprintf(\"%dh%dm\", int(d.Hours()), int(d.Minutes())%60)\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tvar projectDir, stateFilter, issueFilter string\n\tvar limit int32\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--all\":\n\t\t\tall = true\n\t\tcase \"--project\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\tcase \"--state\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstateFilter = args[i]\n\t\t\t}\n\t\tcase \"--limit\", \"-n\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = int32(n)\n\t\t\t}\n\t\tcase \"--issue\", \"-i\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tissueFilter = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\treq := &pb.ListRunsRequest{\n\t\tState:  stateFilter,\n\t\tLimit:  limit,\n\t\tTaskId: issueFilter,\n\t}\n\tif projectDir != \"\" {\n\t\treq.ProjectDir = projectDir\n\t} else if all {\n\t\treq.All = true\n\t} else {\n\t\t// Default: filter to current project\n\t\tcwd, _ := os.Getwd()\n\t\treq.ProjectDir = cwd\n\t}\n\n\tresp, err := client.ListRuns(ctx, req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n\tfmt.Fprintln(w, \"RUN ID\\tWORKFLOW\\tSTATE\\tTYPE\\tTASK ID\\tTITLE\\tCONTAINER\\tERROR\")\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\ttitle := run.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\terrMsg := run.ErrorMessage\n\t\tif len(errMsg) > 60 {\n\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t}\n\t\tfmt.Fprintf(w, \"%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\n\",\n\t\t\trun.RunId, run.WorkflowName, run.State, runType,\n\t\t\trun.TaskId, title, run.ContainerId, errMsg)\n\t}\n\tw.Flush()\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\tvar limit int\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\tcase \"--limit\", \"-l\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil || n < 0 {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = n\n\t\t\t}\n\t\t}\n\t}\n\n\t// Use background context — log output can be large and follow mode blocks.\n\tctx := context.Background()\n\tvar mdPairs []string\n\tif follow {\n\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n\t}\n\tif limit > 0 {\n\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n\t}\n\tif len(mdPairs) > 0 {\n\t\tmd := metadata.Pairs(mdPairs...)\n\t\tctx = metadata.NewOutgoingContext(ctx, md)\n\t}\n\n\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Check for \"resume\" subcommand\n\tif len(args) > 0 && args[0] == \"resume\" {\n\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop resumed.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdTasks(args []string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\t// Determine project label from --project flag or current directory\n\tprojectDir := \"\"\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tcwd, _ := os.Getwd()\n\t\tprojectDir = filepath.Base(cwd)\n\t}\n\n\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n\tresp, err := http.Get(tasksURL)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\ttype taskEntry struct {\n\t\tID          string `json:\"id\"`\n\t\tStatus      string `json:\"status\"`\n\t\tTitle       string `json:\"title\"`\n\t\tDescription string `json:\"description\"`\n\t\tAssigned    bool   `json:\"assigned\"`\n\t\tAssignedAt  string `json:\"assigned_at\"`\n\t\tRunID       string `json:\"run_id\"`\n\t}\n\n\tvar tasks []taskEntry\n\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(tasks) == 0 {\n\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n\t\treturn\n\t}\n\n\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n\tfor _, t := range tasks {\n\t\tstatus := t.Status\n\t\tif status == \"\" {\n\t\t\tstatus = \"open\"\n\t\t}\n\t\tassigned := \"-\"\n\t\tif t.Assigned {\n\t\t\tassigned = \"yes\"\n\t\t}\n\t\trunID := \"\"\n\t\tif t.RunID != \"\" {\n\t\t\trunID = t.RunID\n\t\t\tif len(runID) > 30 {\n\t\t\t\trunID = runID[:27] + \"...\"\n\t\t\t}\n\t\t}\n\t\ttitle := t.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar force bool\n\tfor _, a := range args {\n\t\tif a == \"-f\" || a == \"--force\" {\n\t\t\tforce = true\n\t\t}\n\t}\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n\n// resolveRunContext returns the project directory and run ID for context\n// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n// from CLOCHE_PROJECT_DIR (falling back to cwd).\nfunc resolveRunContext() (projectDir, runID string, err error) {\n\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n\tif runID == \"\" {\n\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n\t}\n\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n\tif projectDir == \"\" {\n\t\tprojectDir, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n\t\t}\n\t}\n\treturn projectDir, runID, nil\n}\n\nfunc cmdGet(args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif !ok {\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(val)\n}\n\nfunc cmdSet(args []string) {\n\tif len(args) < 2 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvalue := args[1]\n\tif value == \"-\" {\n\t\tdata, err := io.ReadAll(os.Stdin)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n\t}\n\n\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n\nfunc cmdVersion() {\n\tcliVersion := version.Version()\n\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n\n\t// Try to get daemon version via gRPC\n\tdaemonVersion := \"<unavailable>\"\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = config.DefaultSocketAddr()\n\t}\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err == nil {\n\t\tdefer conn.Close()\n\t\tclient := pb.NewClocheServiceClient(conn)\n\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n\t\tdefer cancel()\n\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n\t\tif err == nil {\n\t\t\tdaemonVersion = resp.Version\n\t\t}\n\t}\n\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n\n\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n\tagentVersion := \"<unavailable>\"\n\timage := os.Getenv(\"CLOCHE_IMAGE\")\n\tif image == \"\" {\n\t\timage = \"cloche-agent:latest\"\n\t}\n\tout, err := exec.CommandContext(\n\t\tcontext.Background(),\n\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n\t).Output()\n\tif err == nil {\n\t\tagentVersion = strings.TrimSpace(string(out))\n\t\t// Strip \"cloche-agent \" prefix if present\n\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n\t}\n\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n\n\t// Warn about version mismatches\n\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n\t}\n\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n\t}\n}\n","numLines":922,"startLine":1,"totalLines":922}}}
[2026-03-18T18:36:07Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GFE1Yi2WWz3qJDRKfC8Zby","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"sync\"\n     7→\t\"sync/atomic\"\n     8→\t\"testing\"\n     9→\t\"time\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    12→\t\"github.com/stretchr/testify/assert\"\n    13→)\n    14→\n    15→func TestLoop_StartStop(t *testing.T) {\n    16→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    17→\tvar called atomic.Int32\n    18→\n    19→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    20→\t\tcalled.Add(1)\n    21→\t\t// Simulate a run that finds no work (failed = aborted).\n    22→\t\ttime.Sleep(50 * time.Millisecond)\n    23→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    24→\t}\n    25→\n    26→\tloop := NewLoop(LoopConfig{\n    27→\t\tProjectDir:    \"/tmp/test-project\",\n    28→\t\tMaxConcurrent: 1,\n    29→\t}, store, runFn)\n    30→\n    31→\tif loop.Running() {\n    32→\t\tt.Fatal(\"loop should not be running before Start\")\n    33→\t}\n    34→\n    35→\tloop.Start()\n    36→\tif !loop.Running() {\n    37→\t\tt.Fatal(\"loop should be running after Start\")\n    38→\t}\n    39→\n    40→\t// Wait enough time for at least one run to happen.\n    41→\ttime.Sleep(200 * time.Millisecond)\n    42→\tloop.Stop()\n    43→\n    44→\tif loop.Running() {\n    45→\t\tt.Fatal(\"loop should not be running after Stop\")\n    46→\t}\n    47→\n    48→\tif called.Load() < 1 {\n    49→\t\tt.Fatal(\"expected at least one run to be launched\")\n    50→\t}\n    51→}\n    52→\n    53→func TestLoop_RampsUpOnSuccess(t *testing.T) {\n    54→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    55→\tvar called atomic.Int32\n    56→\n    57→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    58→\t\tn := called.Add(1)\n    59→\t\ttime.Sleep(20 * time.Millisecond)\n    60→\t\t// First 3 succeed, then fail (no more work).\n    61→\t\tif n <= 3 {\n    62→\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n    63→\t\t}\n    64→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    65→\t}\n    66→\n    67→\tloop := NewLoop(LoopConfig{\n    68→\t\tProjectDir:    \"/tmp/test-project\",\n    69→\t\tMaxConcurrent: 1,\n    70→\t}, store, runFn)\n    71→\n    72→\tloop.Start()\n    73→\t// With no backoff between successes, 3 successful + 1 failed should happen fast.\n    74→\ttime.Sleep(300 * time.Millisecond)\n    75→\tloop.Stop()\n    76→\n    77→\tif called.Load() < 4 {\n    78→\t\tt.Fatalf(\"expected at least 4 runs, got %d\", called.Load())\n    79→\t}\n    80→}\n    81→\n    82→func TestLoop_DoubleStartIsNoop(t *testing.T) {\n    83→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    84→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    85→\t\ttime.Sleep(100 * time.Millisecond)\n    86→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    87→\t}\n    88→\n    89→\tloop := NewLoop(LoopConfig{\n    90→\t\tProjectDir:    \"/tmp/test-project\",\n    91→\t\tMaxConcurrent: 1,\n    92→\t}, store, runFn)\n    93→\n    94→\tloop.Start()\n    95→\tloop.Start() // Should be a no-op.\n    96→\tloop.Stop()\n    97→}\n    98→\n    99→// fakeTaskAssigner implements TaskAssigner for testing.\n   100→type fakeTaskAssigner struct {\n   101→\tmu    sync.Mutex\n   102→\ttasks []Task\n   103→\tcalls int\n   104→}\n   105→\n   106→func (f *fakeTaskAssigner) ListTasks(_ context.Context, _ string) ([]Task, error) {\n   107→\tf.mu.Lock()\n   108→\tdefer f.mu.Unlock()\n   109→\tf.calls++\n   110→\tresult := make([]Task, len(f.tasks))\n   111→\tcopy(result, f.tasks)\n   112→\treturn result, nil\n   113→}\n   114→\n   115→func TestLoop_TaskAssigner_PassesTaskID(t *testing.T) {\n   116→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   117→\n   118→\tassigner := &fakeTaskAssigner{\n   119→\t\ttasks: []Task{\n   120→\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n   121→\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n   122→\t\t},\n   123→\t}\n   124→\n   125→\tvar receivedTaskIDs []string\n   126→\tvar mu sync.Mutex\n   127→\n   128→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   129→\t\tmu.Lock()\n   130→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   131→\t\tmu.Unlock()\n   132→\t\ttime.Sleep(20 * time.Millisecond)\n   133→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   134→\t}\n   135→\n   136→\tloop := NewLoop(LoopConfig{\n   137→\t\tProjectDir:    \"/tmp/test-project\",\n   138→\t\tMaxConcurrent: 1,\n   139→\t\tDedupTimeout:  1 * time.Second,\n   140→\t}, store, runFn)\n   141→\tloop.SetTaskAssigner(assigner)\n   142→\n   143→\tloop.Start()\n   144→\ttime.Sleep(200 * time.Millisecond)\n   145→\tloop.Stop()\n   146→\n   147→\tmu.Lock()\n   148→\tdefer mu.Unlock()\n   149→\t// Should have received task-1 first, then task-2 (task-1 is deduped).\n   150→\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2)\n   151→\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   152→\tassert.Equal(t, \"task-2\", receivedTaskIDs[1])\n   153→}\n   154→\n   155→func TestLoop_TaskAssigner_DedupPreventsReassignment(t *testing.T) {\n   156→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   157→\n   158→\tassigner := &fakeTaskAssigner{\n   159→\t\ttasks: []Task{{ID: \"task-1\"}},\n   160→\t}\n   161→\n   162→\tvar receivedTaskIDs []string\n   163→\tvar mu sync.Mutex\n   164→\n   165→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   166→\t\tmu.Lock()\n   167→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   168→\t\tmu.Unlock()\n   169→\t\ttime.Sleep(20 * time.Millisecond)\n   170→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   171→\t}\n   172→\n   173→\tloop := NewLoop(LoopConfig{\n   174→\t\tProjectDir:    \"/tmp/test-project\",\n   175→\t\tMaxConcurrent: 1,\n   176→\t\tDedupTimeout:  2 * time.Second, // long enough that task-1 won't be reassigned during test\n   177→\t}, store, runFn)\n   178→\tloop.SetTaskAssigner(assigner)\n   179→\n   180→\tloop.Start()\n   181→\ttime.Sleep(200 * time.Millisecond)\n   182→\tloop.Stop()\n   183→\n   184→\tmu.Lock()\n   185→\tdefer mu.Unlock()\n   186→\t// Only one run should have been launched since task-1 is deduped after first assignment.\n   187→\tassert.Equal(t, 1, len(receivedTaskIDs))\n   188→\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   189→}\n   190→\n   191→func TestLoop_TaskAssigner_DedupExpires(t *testing.T) {\n   192→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   193→\n   194→\tassigner := &fakeTaskAssigner{\n   195→\t\ttasks: []Task{{ID: \"task-1\"}},\n   196→\t}\n   197→\n   198→\tvar receivedTaskIDs []string\n   199→\tvar mu sync.Mutex\n   200→\n   201→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   202→\t\tmu.Lock()\n   203→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   204→\t\tmu.Unlock()\n   205→\t\t// Run takes longer than dedup timeout, so by the time the run\n   206→\t\t// completes the dedup window has already expired and pickTask\n   207→\t\t// can re-assign immediately without hitting capacityPollInterval.\n   208→\t\ttime.Sleep(100 * time.Millisecond)\n   209→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   210→\t}\n   211→\n   212→\tloop := NewLoop(LoopConfig{\n   213→\t\tProjectDir:    \"/tmp/test-project\",\n   214→\t\tMaxConcurrent: 1,\n   215→\t\tDedupTimeout:  50 * time.Millisecond,\n   216→\t}, store, runFn)\n   217→\tloop.SetTaskAssigner(assigner)\n   218→\n   219→\tloop.Start()\n   220→\ttime.Sleep(500 * time.Millisecond)\n   221→\tloop.Stop()\n   222→\n   223→\tmu.Lock()\n   224→\tdefer mu.Unlock()\n   225→\t// With 50ms dedup and 100ms run time, dedup expires before run completes,\n   226→\t// so task-1 should be assigned multiple times.\n   227→\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2, \"dedup should have expired, allowing reassignment\")\n   228→\tfor _, id := range receivedTaskIDs {\n   229→\t\tassert.Equal(t, \"task-1\", id)\n   230→\t}\n   231→}\n   232→\n   233→func TestLoop_TaskAssigner_NoTasks_BacksOff(t *testing.T) {\n   234→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   235→\n   236→\tassigner := &fakeTaskAssigner{\n   237→\t\ttasks: nil, // no tasks available\n   238→\t}\n   239→\n   240→\tvar called atomic.Int32\n   241→\n   242→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   243→\t\tcalled.Add(1)\n   244→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   245→\t}\n   246→\n   247→\tloop := NewLoop(LoopConfig{\n   248→\t\tProjectDir:    \"/tmp/test-project\",\n   249→\t\tMaxConcurrent: 1,\n   250→\t}, store, runFn)\n   251→\tloop.SetTaskAssigner(assigner)\n   252→\n   253→\tloop.Start()\n   254→\ttime.Sleep(200 * time.Millisecond)\n   255→\tloop.Stop()\n   256→\n   257→\t// With no tasks, no runs should have been launched.\n   258→\tassert.Equal(t, int32(0), called.Load())\n   259→}\n   260→\n   261→func TestLoop_NoTaskAssigner_EmptyTaskID(t *testing.T) {\n   262→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   263→\n   264→\tvar receivedTaskID string\n   265→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   266→\t\treceivedTaskID = taskID\n   267→\t\ttime.Sleep(20 * time.Millisecond)\n   268→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   269→\t}\n   270→\n   271→\tloop := NewLoop(LoopConfig{\n   272→\t\tProjectDir:    \"/tmp/test-project\",\n   273→\t\tMaxConcurrent: 1,\n   274→\t}, store, runFn)\n   275→\t// No SetTaskAssigner call — backward compatible mode.\n   276→\n   277→\tloop.Start()\n   278→\ttime.Sleep(200 * time.Millisecond)\n   279→\tloop.Stop()\n   280→\n   281→\t// Without a task assigner, taskID should be empty.\n   282→\tassert.Empty(t, receivedTaskID)\n   283→}\n   284→\n   285→// --- Three-phase (NewPhaseLoop) tests ---\n   286→\n   287→func TestPhaseLoop_BasicFlow(t *testing.T) {\n   288→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   289→\n   290→\tvar mainCalls, finalizeCalls atomic.Int32\n   291→\tvar receivedTaskIDs []string\n   292→\tvar mu sync.Mutex\n   293→\n   294→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   295→\t\treturn []Task{\n   296→\t\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n   297→\t\t\t{ID: \"task-2\", Status: \"closed\", Title: \"Done task\"},\n   298→\t\t}, nil\n   299→\t}\n   300→\n   301→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   302→\t\tmainCalls.Add(1)\n   303→\t\tmu.Lock()\n   304→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   305→\t\tmu.Unlock()\n   306→\t\ttime.Sleep(20 * time.Millisecond)\n   307→\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n   308→\t}\n   309→\n   310→\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n   311→\t\tfinalizeCalls.Add(1)\n   312→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   313→\t}\n   314→\n   315→\tloop := NewPhaseLoop(LoopConfig{\n   316→\t\tProjectDir:    \"/tmp/test-project\",\n   317→\t\tMaxConcurrent: 1,\n   318→\t\tDedupTimeout:  2 * time.Second,\n   319→\t}, store, listTasksFn, mainFn, finalizeFn)\n   320→\n   321→\tloop.Start()\n   322→\ttime.Sleep(300 * time.Millisecond)\n   323→\tloop.Stop()\n   324→\n   325→\t// Should have picked task-1 (open) and skipped task-2 (closed).\n   326→\tmu.Lock()\n   327→\tdefer mu.Unlock()\n   328→\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n   329→\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   330→\n   331→\t// Finalize should have run for each main completion.\n   332→\tassert.Equal(t, mainCalls.Load(), finalizeCalls.Load())\n   333→}\n   334→\n   335→func TestPhaseLoop_SkipsClosedTasks(t *testing.T) {\n   336→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   337→\n   338→\tvar mainCalls atomic.Int32\n   339→\n   340→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   341→\t\treturn []Task{\n   342→\t\t\t{ID: \"task-1\", Status: \"closed\"},\n   343→\t\t\t{ID: \"task-2\", Status: \"in-progress\"},\n   344→\t\t}, nil\n   345→\t}\n   346→\n   347→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   348→\t\tmainCalls.Add(1)\n   349→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   350→\t}\n   351→\n   352→\tloop := NewPhaseLoop(LoopConfig{\n   353→\t\tProjectDir:    \"/tmp/test-project\",\n   354→\t\tMaxConcurrent: 1,\n   355→\t}, store, listTasksFn, mainFn, nil)\n   356→\n   357→\tloop.Start()\n   358→\ttime.Sleep(200 * time.Millisecond)\n   359→\tloop.Stop()\n   360→\n   361→\t// No open tasks → no main runs.\n   362→\tassert.Equal(t, int32(0), mainCalls.Load())\n   363→}\n   364→\n   365→func TestPhaseLoop_FinalizeRunsOnFailure(t *testing.T) {\n   366→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   367→\n   368→\tvar finalizeOutcome string\n   369→\tvar mu sync.Mutex\n   370→\n   371→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   372→\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n   373→\t}\n   374→\n   375→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   376→\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateFailed}, nil\n   377→\t}\n   378→\n   379→\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n   380→\t\tmu.Lock()\n   381→\t\tfinalizeOutcome = string(mainResult.State)\n   382→\t\tmu.Unlock()\n   383→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   384→\t}\n   385→\n   386→\tloop := NewPhaseLoop(LoopConfig{\n   387→\t\tProjectDir:    \"/tmp/test-project\",\n   388→\t\tMaxConcurrent: 1,\n   389→\t\tDedupTimeout:  2 * time.Second,\n   390→\t}, store, listTasksFn, mainFn, finalizeFn)\n   391→\n   392→\tloop.Start()\n   393→\ttime.Sleep(300 * time.Millisecond)\n   394→\tloop.Stop()\n   395→\n   396→\t// Finalize should have received the failed state.\n   397→\tmu.Lock()\n   398→\tdefer mu.Unlock()\n   399→\tassert.Equal(t, \"failed\", finalizeOutcome)\n   400→}\n   401→\n   402→func TestPhaseLoop_FinalizeFailureOverridesMainSuccess(t *testing.T) {\n   403→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   404→\n   405→\tvar completionStates []domain.RunState\n   406→\tvar mu sync.Mutex\n   407→\n   408→\tlistCallCount := 0\n   409→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   410→\t\tlistCallCount++\n   411→\t\tif listCallCount <= 1 {\n   412→\t\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n   413→\t\t}\n   414→\t\treturn nil, nil // no more tasks after first round\n   415→\t}\n   416→\n   417→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   418→\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n   419→\t}\n   420→\n   421→\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n   422→\t\t// Finalize fails (e.g., merge step failed).\n   423→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   424→\t}\n   425→\n   426→\tloop := NewPhaseLoop(LoopConfig{\n   427→\t\tProjectDir:    \"/tmp/test-project\",\n   428→\t\tMaxConcurrent: 1,\n   429→\t\tDedupTimeout:  2 * time.Second,\n   430→\t}, store, listTasksFn, mainFn, finalizeFn)\n   431→\n   432→\t// Intercept completions by observing backoff behavior:\n   433→\t// If finalize failure is correctly reported, the loop should back off\n   434→\t// (not immediately try to fill slots).\n   435→\tloop.Start()\n   436→\ttime.Sleep(300 * time.Millisecond)\n   437→\tloop.Stop()\n   438→\n   439→\t// Verify through a more direct test: run the phases manually and check\n   440→\t// that the overall state reflects the finalize failure.\n   441→\t_ = completionStates\n   442→\t_ = mu\n   443→\n   444→\t// The key assertion is that main succeeded but finalize failed,\n   445→\t// so WorseState(succeeded, failed) = failed.\n   446→\tgot := domain.WorseState(domain.RunStateSucceeded, domain.RunStateFailed)\n   447→\tassert.Equal(t, domain.RunStateFailed, got)\n   448→}\n   449→\n   450→func TestPhaseLoop_FinalizeErrorOverridesMainSuccess(t *testing.T) {\n   451→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   452→\n   453→\tvar mainCalls atomic.Int32\n   454→\n   455→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   456→\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n   457→\t}\n   458→\n   459→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   460→\t\tmainCalls.Add(1)\n   461→\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n   462→\t}\n   463→\n   464→\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n   465→\t\t// Finalize returns an error (infra failure).\n   466→\t\treturn nil, fmt.Errorf(\"finalize infra error\")\n   467→\t}\n   468→\n   469→\tloop := NewPhaseLoop(LoopConfig{\n   470→\t\tProjectDir:    \"/tmp/test-project\",\n   471→\t\tMaxConcurrent: 1,\n   472→\t\tDedupTimeout:  2 * time.Second,\n   473→\t}, store, listTasksFn, mainFn, finalizeFn)\n   474→\n   475→\tloop.Start()\n   476→\ttime.Sleep(300 * time.Millisecond)\n   477→\tloop.Stop()\n   478→\n   479→\t// Main should have run at least once.\n   480→\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n   481→}\n   482→\n   483→func TestPhaseLoop_NoFinalize(t *testing.T) {\n   484→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   485→\n   486→\tvar mainCalls atomic.Int32\n   487→\n   488→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   489→\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n   490→\t}\n   491→\n   492→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   493→\t\tmainCalls.Add(1)\n   494→\t\ttime.Sleep(20 * time.Millisecond)\n   495→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   496→\t}\n   497→\n   498→\t// nil finalize — should be skipped without error\n   499→\tloop := NewPhaseLoop(LoopConfig{\n   500→\t\tProjectDir:    \"/tmp/test-project\",\n   501→\t\tMaxConcurrent: 1,\n   502→\t\tDedupTimeout:  2 * time.Second,\n   503→\t}, store, listTasksFn, mainFn, nil)\n   504→\n   505→\tloop.Start()\n   506→\ttime.Sleep(200 * time.Millisecond)\n   507→\tloop.Stop()\n   508→\n   509→\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n   510→}\n   511→\n   512→func TestPhaseLoop_DedupFiltersOpenTasks(t *testing.T) {\n   513→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   514→\n   515→\tvar receivedTaskIDs []string\n   516→\tvar mu sync.Mutex\n   517→\n   518→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   519→\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n   520→\t}\n   521→\n   522→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   523→\t\tmu.Lock()\n   524→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   525→\t\tmu.Unlock()\n   526→\t\ttime.Sleep(20 * time.Millisecond)\n   527→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   528→\t}\n   529→\n   530→\tloop := NewPhaseLoop(LoopConfig{\n   531→\t\tProjectDir:    \"/tmp/test-project\",\n   532→\t\tMaxConcurrent: 1,\n   533→\t\tDedupTimeout:  2 * time.Second,\n   534→\t}, store, listTasksFn, mainFn, nil)\n   535→\n   536→\tloop.Start()\n   537→\ttime.Sleep(200 * time.Millisecond)\n   538→\tloop.Stop()\n   539→\n   540→\tmu.Lock()\n   541→\tdefer mu.Unlock()\n   542→\t// With 2s dedup, task-1 should only be assigned once.\n   543→\tassert.Equal(t, 1, len(receivedTaskIDs))\n   544→}\n   545→\n   546→// --- GetTaskSnapshot tests ---\n   547→\n   548→func TestLoop_GetTaskSnapshot_Empty(t *testing.T) {\n   549→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   550→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   551→\t\ttime.Sleep(100 * time.Millisecond)\n   552→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   553→\t}\n   554→\n   555→\tloop := NewLoop(LoopConfig{\n   556→\t\tProjectDir:    \"/tmp/test-project\",\n   557→\t\tMaxConcurrent: 1,\n   558→\t}, store, runFn)\n   559→\n   560→\tsnapshot := loop.GetTaskSnapshot()\n   561→\tassert.Empty(t, snapshot, \"snapshot should be empty when no tasks fetched\")\n   562→}\n   563→\n   564→func TestLoop_GetTaskSnapshot_ReturnsLastTasks(t *testing.T) {\n   565→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   566→\n   567→\ttasks := []Task{\n   568→\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n   569→\t\t{ID: \"task-2\", Status: \"closed\", Title: \"Done task\"},\n   570→\t\t{ID: \"task-3\", Status: \"open\", Title: \"Add feature\"},\n   571→\t}\n   572→\n   573→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   574→\t\treturn tasks, nil\n   575→\t}\n   576→\n   577→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   578→\t\ttime.Sleep(50 * time.Millisecond)\n   579→\t\treturn &RunResult{RunID: \"run-\" + taskID, State: domain.RunStateSucceeded}, nil\n   580→\t}\n   581→\n   582→\tloop := NewPhaseLoop(LoopConfig{\n   583→\t\tProjectDir:    \"/tmp/test-project\",\n   584→\t\tMaxConcurrent: 1,\n   585→\t\tDedupTimeout:  2 * time.Second,\n   586→\t}, store, listTasksFn, mainFn, nil)\n   587→\n   588→\tloop.Start()\n   589→\ttime.Sleep(300 * time.Millisecond)\n   590→\tloop.Stop()\n   591→\n   592→\tsnapshot := loop.GetTaskSnapshot()\n   593→\tassert.Len(t, snapshot, 3, \"should return all 3 tasks\")\n   594→\n   595→\t// task-1 should be assigned (it's open and was picked).\n   596→\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n   597→\tassert.True(t, snapshot[0].Assigned, \"task-1 should be assigned\")\n   598→\tassert.NotEmpty(t, snapshot[0].RunID, \"task-1 should have a run ID\")\n   599→\n   600→\t// task-2 is closed — should not be assigned.\n   601→\tassert.Equal(t, \"task-2\", snapshot[1].Task.ID)\n   602→\tassert.False(t, snapshot[1].Assigned, \"task-2 (closed) should not be assigned\")\n   603→\n   604→\t// task-3 should be assigned (it's open and would be picked after task-1).\n   605→\tassert.Equal(t, \"task-3\", snapshot[2].Task.ID)\n   606→\tassert.True(t, snapshot[2].Assigned, \"task-3 should be assigned\")\n   607→}\n   608→\n   609→func TestLoop_GetTaskSnapshot_LegacyWithAssigner(t *testing.T) {\n   610→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   611→\n   612→\tassigner := &fakeTaskAssigner{\n   613→\t\ttasks: []Task{\n   614→\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n   615→\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n   616→\t\t},\n   617→\t}\n   618→\n   619→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   620→\t\ttime.Sleep(20 * time.Millisecond)\n   621→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   622→\t}\n   623→\n   624→\tloop := NewLoop(LoopConfig{\n   625→\t\tProjectDir:    \"/tmp/test-project\",\n   626→\t\tMaxConcurrent: 1,\n   627→\t\tDedupTimeout:  2 * time.Second,\n   628→\t}, store, runFn)\n   629→\tloop.SetTaskAssigner(assigner)\n   630→\n   631→\tloop.Start()\n   632→\ttime.Sleep(200 * time.Millisecond)\n   633→\tloop.Stop()\n   634→\n   635→\tsnapshot := loop.GetTaskSnapshot()\n   636→\tassert.Len(t, snapshot, 2, \"should return tasks from assigner\")\n   637→\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n   638→\tassert.True(t, snapshot[0].Assigned, \"task-1 should be assigned\")\n   639→\tassert.Equal(t, \"task-2\", snapshot[1].Task.ID)\n   640→\tassert.True(t, snapshot[1].Assigned, \"task-2 should be assigned\")\n   641→}\n   642→\n   643→func TestLoop_GetTaskSnapshot_DedupExpired(t *testing.T) {\n   644→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   645→\n   646→\ttasks := []Task{\n   647→\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n   648→\t}\n   649→\n   650→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   651→\t\treturn tasks, nil\n   652→\t}\n   653→\n   654→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   655→\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n   656→\t}\n   657→\n   658→\tloop := NewPhaseLoop(LoopConfig{\n   659→\t\tProjectDir:    \"/tmp/test-project\",\n   660→\t\tMaxConcurrent: 1,\n   661→\t\tDedupTimeout:  10 * time.Millisecond, // very short dedup\n   662→\t}, store, listTasksFn, mainFn, nil)\n   663→\n   664→\tloop.Start()\n   665→\ttime.Sleep(200 * time.Millisecond)\n   666→\tloop.Stop()\n   667→\n   668→\tsnapshot := loop.GetTaskSnapshot()\n   669→\tassert.Len(t, snapshot, 1)\n   670→\t// After dedup expires, the task should show as unassigned in the snapshot\n   671→\t// (the dedup check in GetTaskSnapshot uses current time).\n   672→\t// But the run ID may still be recorded from a previous assignment.\n   673→\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n   674→}\n   675→\n   676→// --- StopOnError tests ---\n   677→\n   678→func TestLoop_StopOnError_HaltsOnFailure(t *testing.T) {\n   679→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   680→\tvar called atomic.Int32\n   681→\n   682→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   683→\t\tn := called.Add(1)\n   684→\t\ttime.Sleep(20 * time.Millisecond)\n   685→\t\tif n == 1 {\n   686→\t\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   687→\t\t}\n   688→\t\t// Subsequent calls should not happen while halted.\n   689→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   690→\t}\n   691→\n   692→\tloop := NewLoop(LoopConfig{\n   693→\t\tProjectDir:    \"/tmp/test-project\",\n   694→\t\tMaxConcurrent: 1,\n   695→\t\tStopOnError:   true,\n   696→\t}, store, runFn)\n   697→\n   698→\tloop.Start()\n   699→\t// Wait for the first run to fail and halt.\n   700→\ttime.Sleep(300 * time.Millisecond)\n   701→\n   702→\thalted, haltErr := loop.Halted()\n   703→\tassert.True(t, halted, \"loop should be halted after failure\")\n   704→\tassert.NotEmpty(t, haltErr, \"halt error should be set\")\n   705→\tassert.True(t, loop.Running(), \"loop should still be running (not stopped)\")\n   706→\n   707→\t// Only 1 run should have been launched since the loop halts after.\n   708→\tassert.Equal(t, int32(1), called.Load(), \"only one run should have been launched before halt\")\n   709→\n   710→\tloop.Stop()\n   711→}\n   712→\n   713→func TestLoop_StopOnError_ResumeAllowsNewWork(t *testing.T) {\n   714→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   715→\tvar called atomic.Int32\n   716→\tvar resumeReady atomic.Bool\n   717→\n   718→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   719→\t\tn := called.Add(1)\n   720→\t\ttime.Sleep(20 * time.Millisecond)\n   721→\t\tif n == 1 {\n   722→\t\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   723→\t\t}\n   724→\t\tresumeReady.Store(true)\n   725→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   726→\t}\n   727→\n   728→\tloop := NewLoop(LoopConfig{\n   729→\t\tProjectDir:    \"/tmp/test-project\",\n   730→\t\tMaxConcurrent: 1,\n   731→\t\tStopOnError:   true,\n   732→\t}, store, runFn)\n   733→\n   734→\tloop.Start()\n   735→\t// Wait for the first run to fail and halt.\n   736→\ttime.Sleep(300 * time.Millisecond)\n   737→\n   738→\thalted, _ := loop.Halted()\n   739→\tassert.True(t, halted, \"loop should be halted after failure\")\n   740→\tassert.Equal(t, int32(1), called.Load())\n   741→\n   742→\t// Resume the loop.\n   743→\tloop.Resume()\n   744→\n   745→\thalted, _ = loop.Halted()\n   746→\tassert.False(t, halted, \"loop should no longer be halted after resume\")\n   747→\n   748→\t// Resume() signals the loop to wake from its sleep, so new work should\n   749→\t// be picked up quickly.\n   750→\tdeadline := time.After(2 * time.Second)\n   751→\tfor !resumeReady.Load() {\n   752→\t\tselect {\n   753→\t\tcase <-deadline:\n   754→\t\t\tt.Fatal(\"timed out waiting for resumed run\")\n   755→\t\tcase <-time.After(50 * time.Millisecond):\n   756→\t\t}\n   757→\t}\n   758→\tloop.Stop()\n   759→\n   760→\t// After resume, at least one more run should have been launched.\n   761→\tassert.GreaterOrEqual(t, called.Load(), int32(2), \"resume should allow new runs\")\n   762→}\n   763→\n   764→func TestLoop_StopOnError_Disabled_ContinuesOnFailure(t *testing.T) {\n   765→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   766→\tvar called atomic.Int32\n   767→\n   768→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   769→\t\tcalled.Add(1)\n   770→\t\ttime.Sleep(20 * time.Millisecond)\n   771→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   772→\t}\n   773→\n   774→\tloop := NewLoop(LoopConfig{\n   775→\t\tProjectDir:    \"/tmp/test-project\",\n   776→\t\tMaxConcurrent: 1,\n   777→\t\tStopOnError:   false, // disabled\n   778→\t}, store, runFn)\n   779→\n   780→\tloop.Start()\n   781→\t// After first failure, loop backs off for idlePollInterval (2 min), so\n   782→\t// we can't easily wait for multiple runs. Instead, verify state after\n   783→\t// the first run: loop should not be halted and should still be running.\n   784→\ttime.Sleep(300 * time.Millisecond)\n   785→\tloop.Stop()\n   786→\n   787→\thalted, _ := loop.Halted()\n   788→\tassert.False(t, halted, \"loop should not be halted when stop_on_error is disabled\")\n   789→\tassert.GreaterOrEqual(t, called.Load(), int32(1), \"at least one run should have been launched\")\n   790→}\n   791→\n   792→func TestPhaseLoop_StopOnError_HaltsOnFailure(t *testing.T) {\n   793→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   794→\tvar mainCalls atomic.Int32\n   795→\n   796→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   797→\t\treturn []Task{\n   798→\t\t\t{ID: \"task-1\", Status: \"open\"},\n   799→\t\t\t{ID: \"task-2\", Status: \"open\"},\n   800→\t\t}, nil\n   801→\t}\n   802→\n   803→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   804→\t\tmainCalls.Add(1)\n   805→\t\ttime.Sleep(20 * time.Millisecond)\n   806→\t\treturn &RunResult{RunID: \"run-\" + taskID, State: domain.RunStateFailed}, nil\n   807→\t}\n   808→\n   809→\tloop := NewPhaseLoop(LoopConfig{\n   810→\t\tProjectDir:    \"/tmp/test-project\",\n   811→\t\tMaxConcurrent: 1,\n   812→\t\tDedupTimeout:  2 * time.Second,\n   813→\t\tStopOnError:   true,\n   814→\t}, store, listTasksFn, mainFn, nil)\n   815→\n   816→\tloop.Start()\n   817→\ttime.Sleep(300 * time.Millisecond)\n   818→\n   819→\thalted, haltErr := loop.Halted()\n   820→\tassert.True(t, halted, \"phased loop should be halted after failure\")\n   821→\tassert.Contains(t, haltErr, \"task-1\", \"halt error should reference the failed task\")\n   822→\n   823→\t// Only task-1 should have been attempted.\n   824→\tassert.Equal(t, int32(1), mainCalls.Load())\n   825→\n   826→\tloop.Stop()\n   827→}\n   828→\n   829→// --- MaxConsecutiveFailures tests ---\n   830→\n   831→func TestLoop_ConsecutiveFailures_RecordAndReset(t *testing.T) {\n   832→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   833→\tloop := NewLoop(LoopConfig{\n   834→\t\tProjectDir:             \"/tmp/test-project\",\n   835→\t\tMaxConcurrent:          1,\n   836→\t\tMaxConsecutiveFailures: 3,\n   837→\t}, store, func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   838→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   839→\t})\n   840→\n   841→\t// Below threshold — not halted.\n   842→\tassert.False(t, loop.recordConsecutiveFailure())\n   843→\tassert.False(t, loop.recordConsecutiveFailure())\n   844→\n   845→\t// Third failure reaches threshold.\n   846→\tassert.True(t, loop.recordConsecutiveFailure())\n   847→\n   848→\t// Reset clears the counter.\n   849→\tloop.resetConsecutiveFailures()\n   850→\tassert.False(t, loop.recordConsecutiveFailure()) // back to 1\n   851→}\n   852→\n   853→func TestLoop_ConsecutiveFailures_HaltsLoopOnThreshold(t *testing.T) {\n   854→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   855→\tvar called atomic.Int32\n   856→\n   857→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   858→\t\tn := called.Add(1)\n   859→\t\ttime.Sleep(20 * time.Millisecond)\n   860→\t\tif n == 1 {\n   861→\t\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   862→\t\t}\n   863→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   864→\t}\n   865→\n   866→\t// With MaxConsecutiveFailures=1, behaves like stop_on_error.\n   867→\tloop := NewLoop(LoopConfig{\n   868→\t\tProjectDir:             \"/tmp/test-project\",\n   869→\t\tMaxConcurrent:          1,\n   870→\t\tMaxConsecutiveFailures: 1,\n   871→\t}, store, runFn)\n   872→\n   873→\tloop.Start()\n   874→\ttime.Sleep(300 * time.Millisecond)\n   875→\n   876→\thalted, haltErr := loop.Halted()\n   877→\tassert.True(t, halted, \"loop should be halted after 1 consecutive failure\")\n   878→\tassert.Contains(t, haltErr, \"consecutive failures\")\n   879→\tassert.Equal(t, int32(1), called.Load())\n   880→\n   881→\tloop.Stop()\n   882→}\n   883→\n   884→func TestLoop_ConsecutiveFailures_ResumeResetsCounter(t *testing.T) {\n   885→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   886→\tvar called atomic.Int32\n   887→\n   888→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   889→\t\tcalled.Add(1)\n   890→\t\ttime.Sleep(20 * time.Millisecond)\n   891→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   892→\t}\n   893→\n   894→\tloop := NewLoop(LoopConfig{\n   895→\t\tProjectDir:             \"/tmp/test-project\",\n   896→\t\tMaxConcurrent:          1,\n   897→\t\tMaxConsecutiveFailures: 1,\n   898→\t}, store, runFn)\n   899→\n   900→\tloop.Start()\n   901→\ttime.Sleep(300 * time.Millisecond)\n   902→\n   903→\thalted, _ := loop.Halted()\n   904→\tassert.True(t, halted, \"loop should halt after 1 consecutive failure\")\n   905→\tassert.Equal(t, int32(1), called.Load())\n   906→\n   907→\t// Resume clears the counter so it takes another failure to halt.\n   908→\tloop.Resume()\n   909→\ttime.Sleep(300 * time.Millisecond)\n   910→\n   911→\thalted, _ = loop.Halted()\n   912→\tassert.True(t, halted, \"loop should halt again after resume\")\n   913→\tassert.Equal(t, int32(2), called.Load())\n   914→\n   915→\tloop.Stop()\n   916→}\n   917→\n   918→func TestLoop_ConsecutiveFailures_DefaultThreshold(t *testing.T) {\n   919→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   920→\n   921→\t// MaxConsecutiveFailures=0 should default to 3.\n   922→\tloop := NewLoop(LoopConfig{\n   923→\t\tProjectDir:             \"/tmp/test-project\",\n   924→\t\tMaxConcurrent:          1,\n   925→\t\tMaxConsecutiveFailures: 0,\n   926→\t}, store, func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   927→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   928→\t})\n   929→\n   930→\tassert.Equal(t, defaultMaxConsecutiveFailures, loop.config.MaxConsecutiveFailures)\n   931→}\n   932→\n   933→func TestLoop_ConsecutiveFailures_SuccessResetsInLoop(t *testing.T) {\n   934→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   935→\tvar called atomic.Int32\n   936→\n   937→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   938→\t\tn := called.Add(1)\n   939→\t\ttime.Sleep(20 * time.Millisecond)\n   940→\t\t// First succeeds (resets counter), second fails and halts (threshold=1).\n   941→\t\tif n == 1 {\n   942→\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   943→\t\t}\n   944→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   945→\t}\n   946→\n   947→\tloop := NewLoop(LoopConfig{\n   948→\t\tProjectDir:             \"/tmp/test-project\",\n   949→\t\tMaxConcurrent:          1,\n   950→\t\tMaxConsecutiveFailures: 1,\n   951→\t}, store, runFn)\n   952→\n   953→\tloop.Start()\n   954→\ttime.Sleep(300 * time.Millisecond)\n   955→\n   956→\thalted, _ := loop.Halted()\n   957→\tassert.True(t, halted, \"loop should halt on second run (first failure after success)\")\n   958→\tassert.Equal(t, int32(2), called.Load(), \"two runs: one success, one failure\")\n   959→\n   960→\tloop.Stop()\n   961→}\n   962→\n   963→func TestPhaseLoop_ConsecutiveFailures_HaltsAfterThreshold(t *testing.T) {\n   964→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   965→\tvar mainCalls atomic.Int32\n   966→\n   967→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   968→\t\treturn []Task{{ID: fmt.Sprintf(\"task-%d\", mainCalls.Load()+1), Status: \"open\"}}, nil\n   969→\t}\n   970→\n   971→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   972→\t\tmainCalls.Add(1)\n   973→\t\ttime.Sleep(20 * time.Millisecond)\n   974→\t\treturn &RunResult{RunID: \"run-\" + taskID, State: domain.RunStateFailed}, nil\n   975→\t}\n   976→\n   977→\tloop := NewPhaseLoop(LoopConfig{\n   978→\t\tProjectDir:             \"/tmp/test-project\",\n   979→\t\tMaxConcurrent:          1,\n   980→\t\tDedupTimeout:           50 * time.Millisecond,\n   981→\t\tMaxConsecutiveFailures: 1,\n   982→\t}, store, listTasksFn, mainFn, nil)\n   983→\n   984→\tloop.Start()\n   985→\ttime.Sleep(300 * time.Millisecond)\n   986→\n   987→\thalted, haltErr := loop.Halted()\n   988→\tassert.True(t, halted, \"phased loop should be halted after consecutive failures\")\n   989→\tassert.Contains(t, haltErr, \"consecutive failures\")\n   990→\tassert.Equal(t, int32(1), mainCalls.Load())\n   991→\n   992→\tloop.Stop()\n   993→}\n   994→\n   995→func TestLoop_Halted_DefaultFalse(t *testing.T) {\n   996→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   997→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   998→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   999→\t}\n  1000→\n  1001→\tloop := NewLoop(LoopConfig{\n  1002→\t\tProjectDir:    \"/tmp/test-project\",\n  1003→\t\tMaxConcurrent: 1,\n  1004→\t}, store, runFn)\n  1005→\n  1006→\thalted, haltErr := loop.Halted()\n  1007→\tassert.False(t, halted)\n  1008→\tassert.Empty(t, haltErr)\n  1009→}\n  1010→\n  1011→func TestLoop_Resume_NopWhenNotHalted(t *testing.T) {\n  1012→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n  1013→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n  1014→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n  1015→\t}\n  1016→\n  1017→\tloop := NewLoop(LoopConfig{\n  1018→\t\tProjectDir:    \"/tmp/test-project\",\n  1019→\t\tMaxConcurrent: 1,\n  1020→\t}, store, runFn)\n  1021→\n  1022→\t// Resume when not halted should be a no-op (no panic).\n  1023→\tloop.Resume()\n  1024→\thalted, _ := loop.Halted()\n  1025→\tassert.False(t, halted)\n  1026→}\n  1027→"}]},"parent_tool_use_id":null,"session_id":"3ce95e97-6dbe-466e-9cea-9a2f04871e38","uuid":"5782c8f5-fc2c-4ead-a115-1226eeba7485","timestamp":"2026-03-18T18:35:54.371Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/loop_test.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\t\"sync/atomic\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/stretchr/testify/assert\"\n)\n\nfunc TestLoop_StartStop(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tcalled.Add(1)\n\t\t// Simulate a run that finds no work (failed = aborted).\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\tif loop.Running() {\n\t\tt.Fatal(\"loop should not be running before Start\")\n\t}\n\n\tloop.Start()\n\tif !loop.Running() {\n\t\tt.Fatal(\"loop should be running after Start\")\n\t}\n\n\t// Wait enough time for at least one run to happen.\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tif loop.Running() {\n\t\tt.Fatal(\"loop should not be running after Stop\")\n\t}\n\n\tif called.Load() < 1 {\n\t\tt.Fatal(\"expected at least one run to be launched\")\n\t}\n}\n\nfunc TestLoop_RampsUpOnSuccess(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tn := called.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\t// First 3 succeed, then fail (no more work).\n\t\tif n <= 3 {\n\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t\t}\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\t// With no backoff between successes, 3 successful + 1 failed should happen fast.\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\tif called.Load() < 4 {\n\t\tt.Fatalf(\"expected at least 4 runs, got %d\", called.Load())\n\t}\n}\n\nfunc TestLoop_DoubleStartIsNoop(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\tloop.Start() // Should be a no-op.\n\tloop.Stop()\n}\n\n// fakeTaskAssigner implements TaskAssigner for testing.\ntype fakeTaskAssigner struct {\n\tmu    sync.Mutex\n\ttasks []Task\n\tcalls int\n}\n\nfunc (f *fakeTaskAssigner) ListTasks(_ context.Context, _ string) ([]Task, error) {\n\tf.mu.Lock()\n\tdefer f.mu.Unlock()\n\tf.calls++\n\tresult := make([]Task, len(f.tasks))\n\tcopy(result, f.tasks)\n\treturn result, nil\n}\n\nfunc TestLoop_TaskAssigner_PassesTaskID(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tassigner := &fakeTaskAssigner{\n\t\ttasks: []Task{\n\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n\t\t},\n\t}\n\n\tvar receivedTaskIDs []string\n\tvar mu sync.Mutex\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmu.Lock()\n\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n\t\tmu.Unlock()\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  1 * time.Second,\n\t}, store, runFn)\n\tloop.SetTaskAssigner(assigner)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tmu.Lock()\n\tdefer mu.Unlock()\n\t// Should have received task-1 first, then task-2 (task-1 is deduped).\n\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2)\n\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n\tassert.Equal(t, \"task-2\", receivedTaskIDs[1])\n}\n\nfunc TestLoop_TaskAssigner_DedupPreventsReassignment(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tassigner := &fakeTaskAssigner{\n\t\ttasks: []Task{{ID: \"task-1\"}},\n\t}\n\n\tvar receivedTaskIDs []string\n\tvar mu sync.Mutex\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmu.Lock()\n\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n\t\tmu.Unlock()\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second, // long enough that task-1 won't be reassigned during test\n\t}, store, runFn)\n\tloop.SetTaskAssigner(assigner)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tmu.Lock()\n\tdefer mu.Unlock()\n\t// Only one run should have been launched since task-1 is deduped after first assignment.\n\tassert.Equal(t, 1, len(receivedTaskIDs))\n\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n}\n\nfunc TestLoop_TaskAssigner_DedupExpires(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tassigner := &fakeTaskAssigner{\n\t\ttasks: []Task{{ID: \"task-1\"}},\n\t}\n\n\tvar receivedTaskIDs []string\n\tvar mu sync.Mutex\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmu.Lock()\n\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n\t\tmu.Unlock()\n\t\t// Run takes longer than dedup timeout, so by the time the run\n\t\t// completes the dedup window has already expired and pickTask\n\t\t// can re-assign immediately without hitting capacityPollInterval.\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  50 * time.Millisecond,\n\t}, store, runFn)\n\tloop.SetTaskAssigner(assigner)\n\n\tloop.Start()\n\ttime.Sleep(500 * time.Millisecond)\n\tloop.Stop()\n\n\tmu.Lock()\n\tdefer mu.Unlock()\n\t// With 50ms dedup and 100ms run time, dedup expires before run completes,\n\t// so task-1 should be assigned multiple times.\n\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2, \"dedup should have expired, allowing reassignment\")\n\tfor _, id := range receivedTaskIDs {\n\t\tassert.Equal(t, \"task-1\", id)\n\t}\n}\n\nfunc TestLoop_TaskAssigner_NoTasks_BacksOff(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tassigner := &fakeTaskAssigner{\n\t\ttasks: nil, // no tasks available\n\t}\n\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tcalled.Add(1)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\tloop.SetTaskAssigner(assigner)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\t// With no tasks, no runs should have been launched.\n\tassert.Equal(t, int32(0), called.Load())\n}\n\nfunc TestLoop_NoTaskAssigner_EmptyTaskID(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar receivedTaskID string\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treceivedTaskID = taskID\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\t// No SetTaskAssigner call — backward compatible mode.\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\t// Without a task assigner, taskID should be empty.\n\tassert.Empty(t, receivedTaskID)\n}\n\n// --- Three-phase (NewPhaseLoop) tests ---\n\nfunc TestPhaseLoop_BasicFlow(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar mainCalls, finalizeCalls atomic.Int32\n\tvar receivedTaskIDs []string\n\tvar mu sync.Mutex\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{\n\t\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n\t\t\t{ID: \"task-2\", Status: \"closed\", Title: \"Done task\"},\n\t\t}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\tmu.Lock()\n\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n\t\tmu.Unlock()\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n\t}\n\n\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n\t\tfinalizeCalls.Add(1)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, finalizeFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\t// Should have picked task-1 (open) and skipped task-2 (closed).\n\tmu.Lock()\n\tdefer mu.Unlock()\n\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n\n\t// Finalize should have run for each main completion.\n\tassert.Equal(t, mainCalls.Load(), finalizeCalls.Load())\n}\n\nfunc TestPhaseLoop_SkipsClosedTasks(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar mainCalls atomic.Int32\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{\n\t\t\t{ID: \"task-1\", Status: \"closed\"},\n\t\t\t{ID: \"task-2\", Status: \"in-progress\"},\n\t\t}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\t// No open tasks → no main runs.\n\tassert.Equal(t, int32(0), mainCalls.Load())\n}\n\nfunc TestPhaseLoop_FinalizeRunsOnFailure(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar finalizeOutcome string\n\tvar mu sync.Mutex\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateFailed}, nil\n\t}\n\n\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n\t\tmu.Lock()\n\t\tfinalizeOutcome = string(mainResult.State)\n\t\tmu.Unlock()\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, finalizeFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\t// Finalize should have received the failed state.\n\tmu.Lock()\n\tdefer mu.Unlock()\n\tassert.Equal(t, \"failed\", finalizeOutcome)\n}\n\nfunc TestPhaseLoop_FinalizeFailureOverridesMainSuccess(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar completionStates []domain.RunState\n\tvar mu sync.Mutex\n\n\tlistCallCount := 0\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\tlistCallCount++\n\t\tif listCallCount <= 1 {\n\t\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n\t\t}\n\t\treturn nil, nil // no more tasks after first round\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n\t}\n\n\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n\t\t// Finalize fails (e.g., merge step failed).\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, finalizeFn)\n\n\t// Intercept completions by observing backoff behavior:\n\t// If finalize failure is correctly reported, the loop should back off\n\t// (not immediately try to fill slots).\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\t// Verify through a more direct test: run the phases manually and check\n\t// that the overall state reflects the finalize failure.\n\t_ = completionStates\n\t_ = mu\n\n\t// The key assertion is that main succeeded but finalize failed,\n\t// so WorseState(succeeded, failed) = failed.\n\tgot := domain.WorseState(domain.RunStateSucceeded, domain.RunStateFailed)\n\tassert.Equal(t, domain.RunStateFailed, got)\n}\n\nfunc TestPhaseLoop_FinalizeErrorOverridesMainSuccess(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar mainCalls atomic.Int32\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n\t}\n\n\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n\t\t// Finalize returns an error (infra failure).\n\t\treturn nil, fmt.Errorf(\"finalize infra error\")\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, finalizeFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\t// Main should have run at least once.\n\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n}\n\nfunc TestPhaseLoop_NoFinalize(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar mainCalls atomic.Int32\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\t// nil finalize — should be skipped without error\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n}\n\nfunc TestPhaseLoop_DedupFiltersOpenTasks(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar receivedTaskIDs []string\n\tvar mu sync.Mutex\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmu.Lock()\n\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n\t\tmu.Unlock()\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tmu.Lock()\n\tdefer mu.Unlock()\n\t// With 2s dedup, task-1 should only be assigned once.\n\tassert.Equal(t, 1, len(receivedTaskIDs))\n}\n\n// --- GetTaskSnapshot tests ---\n\nfunc TestLoop_GetTaskSnapshot_Empty(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\tsnapshot := loop.GetTaskSnapshot()\n\tassert.Empty(t, snapshot, \"snapshot should be empty when no tasks fetched\")\n}\n\nfunc TestLoop_GetTaskSnapshot_ReturnsLastTasks(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\ttasks := []Task{\n\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n\t\t{ID: \"task-2\", Status: \"closed\", Title: \"Done task\"},\n\t\t{ID: \"task-3\", Status: \"open\", Title: \"Add feature\"},\n\t}\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn tasks, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\treturn &RunResult{RunID: \"run-\" + taskID, State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\tsnapshot := loop.GetTaskSnapshot()\n\tassert.Len(t, snapshot, 3, \"should return all 3 tasks\")\n\n\t// task-1 should be assigned (it's open and was picked).\n\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n\tassert.True(t, snapshot[0].Assigned, \"task-1 should be assigned\")\n\tassert.NotEmpty(t, snapshot[0].RunID, \"task-1 should have a run ID\")\n\n\t// task-2 is closed — should not be assigned.\n\tassert.Equal(t, \"task-2\", snapshot[1].Task.ID)\n\tassert.False(t, snapshot[1].Assigned, \"task-2 (closed) should not be assigned\")\n\n\t// task-3 should be assigned (it's open and would be picked after task-1).\n\tassert.Equal(t, \"task-3\", snapshot[2].Task.ID)\n\tassert.True(t, snapshot[2].Assigned, \"task-3 should be assigned\")\n}\n\nfunc TestLoop_GetTaskSnapshot_LegacyWithAssigner(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tassigner := &fakeTaskAssigner{\n\t\ttasks: []Task{\n\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n\t\t},\n\t}\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, runFn)\n\tloop.SetTaskAssigner(assigner)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tsnapshot := loop.GetTaskSnapshot()\n\tassert.Len(t, snapshot, 2, \"should return tasks from assigner\")\n\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n\tassert.True(t, snapshot[0].Assigned, \"task-1 should be assigned\")\n\tassert.Equal(t, \"task-2\", snapshot[1].Task.ID)\n\tassert.True(t, snapshot[1].Assigned, \"task-2 should be assigned\")\n}\n\nfunc TestLoop_GetTaskSnapshot_DedupExpired(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\ttasks := []Task{\n\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n\t}\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn tasks, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  10 * time.Millisecond, // very short dedup\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tsnapshot := loop.GetTaskSnapshot()\n\tassert.Len(t, snapshot, 1)\n\t// After dedup expires, the task should show as unassigned in the snapshot\n\t// (the dedup check in GetTaskSnapshot uses current time).\n\t// But the run ID may still be recorded from a previous assignment.\n\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n}\n\n// --- StopOnError tests ---\n\nfunc TestLoop_StopOnError_HaltsOnFailure(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tn := called.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\tif n == 1 {\n\t\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t\t}\n\t\t// Subsequent calls should not happen while halted.\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tStopOnError:   true,\n\t}, store, runFn)\n\n\tloop.Start()\n\t// Wait for the first run to fail and halt.\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, haltErr := loop.Halted()\n\tassert.True(t, halted, \"loop should be halted after failure\")\n\tassert.NotEmpty(t, haltErr, \"halt error should be set\")\n\tassert.True(t, loop.Running(), \"loop should still be running (not stopped)\")\n\n\t// Only 1 run should have been launched since the loop halts after.\n\tassert.Equal(t, int32(1), called.Load(), \"only one run should have been launched before halt\")\n\n\tloop.Stop()\n}\n\nfunc TestLoop_StopOnError_ResumeAllowsNewWork(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\tvar resumeReady atomic.Bool\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tn := called.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\tif n == 1 {\n\t\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t\t}\n\t\tresumeReady.Store(true)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tStopOnError:   true,\n\t}, store, runFn)\n\n\tloop.Start()\n\t// Wait for the first run to fail and halt.\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, _ := loop.Halted()\n\tassert.True(t, halted, \"loop should be halted after failure\")\n\tassert.Equal(t, int32(1), called.Load())\n\n\t// Resume the loop.\n\tloop.Resume()\n\n\thalted, _ = loop.Halted()\n\tassert.False(t, halted, \"loop should no longer be halted after resume\")\n\n\t// Resume() signals the loop to wake from its sleep, so new work should\n\t// be picked up quickly.\n\tdeadline := time.After(2 * time.Second)\n\tfor !resumeReady.Load() {\n\t\tselect {\n\t\tcase <-deadline:\n\t\t\tt.Fatal(\"timed out waiting for resumed run\")\n\t\tcase <-time.After(50 * time.Millisecond):\n\t\t}\n\t}\n\tloop.Stop()\n\n\t// After resume, at least one more run should have been launched.\n\tassert.GreaterOrEqual(t, called.Load(), int32(2), \"resume should allow new runs\")\n}\n\nfunc TestLoop_StopOnError_Disabled_ContinuesOnFailure(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tcalled.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tStopOnError:   false, // disabled\n\t}, store, runFn)\n\n\tloop.Start()\n\t// After first failure, loop backs off for idlePollInterval (2 min), so\n\t// we can't easily wait for multiple runs. Instead, verify state after\n\t// the first run: loop should not be halted and should still be running.\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\thalted, _ := loop.Halted()\n\tassert.False(t, halted, \"loop should not be halted when stop_on_error is disabled\")\n\tassert.GreaterOrEqual(t, called.Load(), int32(1), \"at least one run should have been launched\")\n}\n\nfunc TestPhaseLoop_StopOnError_HaltsOnFailure(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar mainCalls atomic.Int32\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{\n\t\t\t{ID: \"task-1\", Status: \"open\"},\n\t\t\t{ID: \"task-2\", Status: \"open\"},\n\t\t}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{RunID: \"run-\" + taskID, State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t\tStopOnError:   true,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, haltErr := loop.Halted()\n\tassert.True(t, halted, \"phased loop should be halted after failure\")\n\tassert.Contains(t, haltErr, \"task-1\", \"halt error should reference the failed task\")\n\n\t// Only task-1 should have been attempted.\n\tassert.Equal(t, int32(1), mainCalls.Load())\n\n\tloop.Stop()\n}\n\n// --- MaxConsecutiveFailures tests ---\n\nfunc TestLoop_ConsecutiveFailures_RecordAndReset(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 3,\n\t}, store, func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t})\n\n\t// Below threshold — not halted.\n\tassert.False(t, loop.recordConsecutiveFailure())\n\tassert.False(t, loop.recordConsecutiveFailure())\n\n\t// Third failure reaches threshold.\n\tassert.True(t, loop.recordConsecutiveFailure())\n\n\t// Reset clears the counter.\n\tloop.resetConsecutiveFailures()\n\tassert.False(t, loop.recordConsecutiveFailure()) // back to 1\n}\n\nfunc TestLoop_ConsecutiveFailures_HaltsLoopOnThreshold(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tn := called.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\tif n == 1 {\n\t\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t\t}\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\t// With MaxConsecutiveFailures=1, behaves like stop_on_error.\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, haltErr := loop.Halted()\n\tassert.True(t, halted, \"loop should be halted after 1 consecutive failure\")\n\tassert.Contains(t, haltErr, \"consecutive failures\")\n\tassert.Equal(t, int32(1), called.Load())\n\n\tloop.Stop()\n}\n\nfunc TestLoop_ConsecutiveFailures_ResumeResetsCounter(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tcalled.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, _ := loop.Halted()\n\tassert.True(t, halted, \"loop should halt after 1 consecutive failure\")\n\tassert.Equal(t, int32(1), called.Load())\n\n\t// Resume clears the counter so it takes another failure to halt.\n\tloop.Resume()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, _ = loop.Halted()\n\tassert.True(t, halted, \"loop should halt again after resume\")\n\tassert.Equal(t, int32(2), called.Load())\n\n\tloop.Stop()\n}\n\nfunc TestLoop_ConsecutiveFailures_DefaultThreshold(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\t// MaxConsecutiveFailures=0 should default to 3.\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 0,\n\t}, store, func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t})\n\n\tassert.Equal(t, defaultMaxConsecutiveFailures, loop.config.MaxConsecutiveFailures)\n}\n\nfunc TestLoop_ConsecutiveFailures_SuccessResetsInLoop(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tn := called.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\t// First succeeds (resets counter), second fails and halts (threshold=1).\n\t\tif n == 1 {\n\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t\t}\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, _ := loop.Halted()\n\tassert.True(t, halted, \"loop should halt on second run (first failure after success)\")\n\tassert.Equal(t, int32(2), called.Load(), \"two runs: one success, one failure\")\n\n\tloop.Stop()\n}\n\nfunc TestPhaseLoop_ConsecutiveFailures_HaltsAfterThreshold(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar mainCalls atomic.Int32\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{{ID: fmt.Sprintf(\"task-%d\", mainCalls.Load()+1), Status: \"open\"}}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{RunID: \"run-\" + taskID, State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tDedupTimeout:           50 * time.Millisecond,\n\t\tMaxConsecutiveFailures: 1,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, haltErr := loop.Halted()\n\tassert.True(t, halted, \"phased loop should be halted after consecutive failures\")\n\tassert.Contains(t, haltErr, \"consecutive failures\")\n\tassert.Equal(t, int32(1), mainCalls.Load())\n\n\tloop.Stop()\n}\n\nfunc TestLoop_Halted_DefaultFalse(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\thalted, haltErr := loop.Halted()\n\tassert.False(t, halted)\n\tassert.Empty(t, haltErr)\n}\n\nfunc TestLoop_Resume_NopWhenNotHalted(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\t// Resume when not halted should be a no-op (no panic).\n\tloop.Resume()\n\thalted, _ := loop.Halted()\n\tassert.False(t, halted)\n}\n","numLines":1027,"startLine":1,"totalLines":1027}}}
