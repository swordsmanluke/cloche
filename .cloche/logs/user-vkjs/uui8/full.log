[2026-03-13T14:41:40Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G3h49VLMNQFaG1vz7nEDq6","type":"tool_result","content":"     1→package docker\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"context\"\n     6→\t\"fmt\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"strings\"\n    11→)\n    12→\n    13→// ExtractResults copies the container workspace to a git branch using worktrees.\n    14→// It creates branch cloche/<runID> based on baseSHA, copies the container's\n    15→// /workspace into the worktree's cloche/ directory, commits, and cleans up.\n    16→func ExtractResults(ctx context.Context, containerID, projectDir, runID, baseSHA, workflowName, result string) error {\n    17→\tif baseSHA == \"\" {\n    18→\t\treturn fmt.Errorf(\"no base SHA recorded for run %s\", runID)\n    19→\t}\n    20→\n    21→\t// 1. Copy container workspace to temp dir\n    22→\ttmpDir, err := os.MkdirTemp(\"\", \"cloche-extract-\"+runID+\"-\")\n    23→\tif err != nil {\n    24→\t\treturn fmt.Errorf(\"creating temp dir: %w\", err)\n    25→\t}\n    26→\tdefer os.RemoveAll(tmpDir)\n    27→\n    28→\tcpCmd := exec.CommandContext(ctx, \"docker\", \"cp\", containerID+\":/workspace/.\", tmpDir+\"/\")\n    29→\tvar cpStderr bytes.Buffer\n    30→\tcpCmd.Stderr = &cpStderr\n    31→\tif err := cpCmd.Run(); err != nil {\n    32→\t\treturn fmt.Errorf(\"docker cp from container: %s: %w\", cpStderr.String(), err)\n    33→\t}\n    34→\n    35→\t// 2. Create git worktree\n    36→\tworktreeDir := filepath.Join(projectDir, \".gitworktrees\", \"cloche\", runID)\n    37→\tif err := os.MkdirAll(filepath.Dir(worktreeDir), 0755); err != nil {\n    38→\t\treturn fmt.Errorf(\"creating worktree parent: %w\", err)\n    39→\t}\n    40→\n    41→\taddCmd := exec.CommandContext(ctx, \"git\", \"worktree\", \"add\", \"--detach\", worktreeDir, baseSHA)\n    42→\taddCmd.Dir = projectDir\n    43→\tif out, err := addCmd.CombinedOutput(); err != nil {\n    44→\t\treturn fmt.Errorf(\"git worktree add: %s: %w\", out, err)\n    45→\t}\n    46→\tdefer func() {\n    47→\t\trmCmd := exec.CommandContext(ctx, \"git\", \"worktree\", \"remove\", \"--force\", worktreeDir)\n    48→\t\trmCmd.Dir = projectDir\n    49→\t\trmCmd.Run()\n    50→\t}()\n    51→\n    52→\t// 3. Copy temp dir contents into worktree root, excluding .git\n    53→\t// The container includes .git/ as a full directory, but the worktree has a\n    54→\t// .git file pointing back to the main repo. We must not overwrite it.\n    55→\tos.RemoveAll(filepath.Join(tmpDir, \".git\"))\n    56→\tcpLocalCmd := exec.CommandContext(ctx, \"cp\", \"-a\", tmpDir+\"/.\", worktreeDir+\"/\")\n    57→\tif out, err := cpLocalCmd.CombinedOutput(); err != nil {\n    58→\t\treturn fmt.Errorf(\"copying to worktree: %s: %w\", out, err)\n    59→\t}\n    60→\n    61→\t// 4. Create branch, add, commit\n    62→\tgitEnv := append(os.Environ(),\n    63→\t\t\"GIT_AUTHOR_NAME=cloche\", \"GIT_AUTHOR_EMAIL=cloche@local\",\n    64→\t\t\"GIT_COMMITTER_NAME=cloche\", \"GIT_COMMITTER_EMAIL=cloche@local\",\n    65→\t)\n    66→\n    67→\tbranch := \"cloche/\" + runID\n    68→\n    69→\tcheckoutCmd := exec.CommandContext(ctx, \"git\", \"checkout\", \"-b\", branch)\n    70→\tcheckoutCmd.Dir = worktreeDir\n    71→\tcheckoutCmd.Env = gitEnv\n    72→\tif out, err := checkoutCmd.CombinedOutput(); err != nil {\n    73→\t\treturn fmt.Errorf(\"git checkout -b: %s: %w\", out, err)\n    74→\t}\n    75→\n    76→\taddFilesCmd := exec.CommandContext(ctx, \"git\", \"add\", \"-A\")\n    77→\taddFilesCmd.Dir = worktreeDir\n    78→\taddFilesCmd.Env = gitEnv\n    79→\tif out, err := addFilesCmd.CombinedOutput(); err != nil {\n    80→\t\treturn fmt.Errorf(\"git add: %s: %w\", out, err)\n    81→\t}\n    82→\n    83→\tcommitMsg := buildCommitMessage(ctx, worktreeDir, gitEnv, runID, workflowName, result)\n    84→\tcommitCmd := exec.CommandContext(ctx, \"git\", \"commit\", \"-F\", \"-\", \"--allow-empty\")\n    85→\tcommitCmd.Dir = worktreeDir\n    86→\tcommitCmd.Env = gitEnv\n    87→\tcommitCmd.Stdin = strings.NewReader(commitMsg)\n    88→\tif out, err := commitCmd.CombinedOutput(); err != nil {\n    89→\t\treturn fmt.Errorf(\"git commit: %s: %w\", out, err)\n    90→\t}\n    91→\n    92→\treturn nil\n    93→}\n    94→\n    95→// buildCommitMessage generates a descriptive commit message by inspecting the\n    96→// staged diff in the worktree. The title summarizes the workflow result, and\n    97→// the body lists file-level changes grouped by operation (added, modified,\n    98→// deleted, renamed).\n    99→func buildCommitMessage(ctx context.Context, worktreeDir string, gitEnv []string, runID, workflowName, result string) string {\n   100→\ttitle := fmt.Sprintf(\"cloche run %s: %s (%s)\", runID, workflowName, result)\n   101→\n   102→\t// Get name-status of staged changes relative to parent\n   103→\tnsCmd := exec.CommandContext(ctx, \"git\", \"diff\", \"--cached\", \"--name-status\")\n   104→\tnsCmd.Dir = worktreeDir\n   105→\tnsCmd.Env = gitEnv\n   106→\tnsOut, err := nsCmd.Output()\n   107→\tif err != nil || len(bytes.TrimSpace(nsOut)) == 0 {\n   108→\t\treturn title\n   109→\t}\n   110→\n   111→\tadded, modified, deleted, renamed := classifyChanges(string(nsOut))\n   112→\n   113→\t// Get diffstat summary line (e.g. \"5 files changed, 100 insertions(+), 20 deletions(-)\")\n   114→\tstatCmd := exec.CommandContext(ctx, \"git\", \"diff\", \"--cached\", \"--stat\", \"--stat-width=72\")\n   115→\tstatCmd.Dir = worktreeDir\n   116→\tstatCmd.Env = gitEnv\n   117→\tstatOut, _ := statCmd.Output()\n   118→\tstatSummary := extractStatSummary(string(statOut))\n   119→\n   120→\tvar body strings.Builder\n   121→\tif statSummary != \"\" {\n   122→\t\tbody.WriteString(statSummary)\n   123→\t\tbody.WriteString(\"\\n\\n\")\n   124→\t}\n   125→\twriteChangeSection(&body, \"Added\", added)\n   126→\twriteChangeSection(&body, \"Modified\", modified)\n   127→\twriteChangeSection(&body, \"Deleted\", deleted)\n   128→\twriteChangeSection(&body, \"Renamed\", renamed)\n   129→\n   130→\tif body.Len() == 0 {\n   131→\t\treturn title\n   132→\t}\n   133→\n   134→\treturn title + \"\\n\\n\" + strings.TrimRight(body.String(), \"\\n\")\n   135→}\n   136→\n   137→// classifyChanges parses git diff --name-status output into categorized file lists.\n   138→func classifyChanges(nameStatus string) (added, modified, deleted, renamed []string) {\n   139→\tfor _, line := range strings.Split(strings.TrimSpace(nameStatus), \"\\n\") {\n   140→\t\tif line == \"\" {\n   141→\t\t\tcontinue\n   142→\t\t}\n   143→\t\tfields := strings.Fields(line)\n   144→\t\tif len(fields) < 2 {\n   145→\t\t\tcontinue\n   146→\t\t}\n   147→\t\tstatus := fields[0]\n   148→\t\tswitch {\n   149→\t\tcase status == \"A\":\n   150→\t\t\tadded = append(added, fields[1])\n   151→\t\tcase status == \"M\":\n   152→\t\t\tmodified = append(modified, fields[1])\n   153→\t\tcase status == \"D\":\n   154→\t\t\tdeleted = append(deleted, fields[1])\n   155→\t\tcase strings.HasPrefix(status, \"R\"):\n   156→\t\t\tif len(fields) >= 3 {\n   157→\t\t\t\trenamed = append(renamed, fields[1]+\" -> \"+fields[2])\n   158→\t\t\t}\n   159→\t\t}\n   160→\t}\n   161→\treturn\n   162→}\n   163→\n   164→// extractStatSummary returns the last line of git diff --stat output, which\n   165→// contains the summary (e.g. \"3 files changed, 10 insertions(+), 2 deletions(-)\").\n   166→func extractStatSummary(stat string) string {\n   167→\tlines := strings.Split(strings.TrimSpace(stat), \"\\n\")\n   168→\tif len(lines) == 0 {\n   169→\t\treturn \"\"\n   170→\t}\n   171→\tlast := strings.TrimSpace(lines[len(lines)-1])\n   172→\tif strings.Contains(last, \"changed\") {\n   173→\t\treturn last\n   174→\t}\n   175→\treturn \"\"\n   176→}\n   177→\n   178→// writeChangeSection writes a labeled list of files to the builder if the list is non-empty.\n   179→func writeChangeSection(b *strings.Builder, label string, files []string) {\n   180→\tif len(files) == 0 {\n   181→\t\treturn\n   182→\t}\n   183→\tb.WriteString(label)\n   184→\tb.WriteString(\":\\n\")\n   185→\tfor _, f := range files {\n   186→\t\tb.WriteString(\"  \")\n   187→\t\tb.WriteString(f)\n   188→\t\tb.WriteString(\"\\n\")\n   189→\t}\n   190→}\n   191→"}]},"parent_tool_use_id":"toolu_01DYUGkaDmeivE9DdDR2ug9Z","session_id":"dbf10f22-a7e0-4657-b5f4-9a1bc4f6ad20","uuid":"dd1f75f1-bb8a-4d26-86d8-6d6a84512647"}
