[2026-03-13T14:37:10Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016DUwe349s2TfsTvDSxcNVL","type":"tool_result","content":"     1→package docker\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"context\"\n     6→\t\"fmt\"\n     7→\t\"io\"\n     8→\t\"os\"\n     9→\t\"os/exec\"\n    10→\t\"path/filepath\"\n    11→\t\"strconv\"\n    12→\t\"strings\"\n    13→\t\"time\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    16→)\n    17→\n    18→type Runtime struct{}\n    19→\n    20→func NewRuntime() (*Runtime, error) {\n    21→\tif _, err := exec.LookPath(\"docker\"); err != nil {\n    22→\t\treturn nil, fmt.Errorf(\"docker not found in PATH: %w\", err)\n    23→\t}\n    24→\treturn &Runtime{}, nil\n    25→}\n    26→\n    27→func (r *Runtime) Start(ctx context.Context, cfg ports.ContainerConfig) (string, error) {\n    28→\t// Build docker create args\n    29→\tcontainerCmd := cfg.Cmd\n    30→\tuseDefaultCmd := len(containerCmd) == 0\n    31→\tif useDefaultCmd {\n    32→\t\tcontainerCmd = []string{\"cloche-agent\", \".cloche/\" + cfg.WorkflowName + \".cloche\"}\n    33→\t}\n    34→\n    35→\targs := []string{\n    36→\t\t\"create\",\n    37→\t\t\"--workdir\", \"/workspace\",\n    38→\t\t\"--add-host=host.docker.internal:host-gateway\",\n    39→\t}\n    40→\n    41→\t// When using the default command, run as root and wrap with chown + su agent\n    42→\t// so the workspace is owned by the agent user. Custom Cmd runs as-is.\n    43→\tif useDefaultCmd {\n    44→\t\targs = append(args, \"--user\", \"root\")\n    45→\t}\n    46→\n    47→\t// Pass run ID into container\n    48→\tif cfg.RunID != \"\" {\n    49→\t\targs = append(args, \"-e\", \"CLOCHE_RUN_ID=\"+cfg.RunID)\n    50→\t}\n    51→\t// Pass ANTHROPIC_API_KEY into container if set\n    52→\tif key := os.Getenv(\"ANTHROPIC_API_KEY\"); key != \"\" {\n    53→\t\targs = append(args, \"-e\", \"ANTHROPIC_API_KEY\")\n    54→\t}\n    55→\n    56→\t// Claude auth files are copied (not mounted) after docker create so each\n    57→\t// container gets its own copy — avoids concurrent write conflicts.\n    58→\n    59→\t// Support extra volume mounts via CLOCHE_EXTRA_MOUNTS (comma-separated host:container pairs)\n    60→\tif mounts := os.Getenv(\"CLOCHE_EXTRA_MOUNTS\"); mounts != \"\" {\n    61→\t\tfor _, m := range strings.Split(mounts, \",\") {\n    62→\t\t\tif strings.Contains(m, \":\") {\n    63→\t\t\t\targs = append(args, \"-v\", m)\n    64→\t\t\t}\n    65→\t\t}\n    66→\t}\n    67→\n    68→\t// Support extra env vars via CLOCHE_EXTRA_ENV (comma-separated KEY=VALUE pairs)\n    69→\tif extraEnv := os.Getenv(\"CLOCHE_EXTRA_ENV\"); extraEnv != \"\" {\n    70→\t\tfor _, e := range strings.Split(extraEnv, \",\") {\n    71→\t\t\tif strings.Contains(e, \"=\") {\n    72→\t\t\t\targs = append(args, \"-e\", e)\n    73→\t\t\t}\n    74→\t\t}\n    75→\t}\n    76→\n    77→\t// No --network none: agent needs network for git push and API access\n    78→\n    79→\tif useDefaultCmd {\n    80→\t\t// Wrap: chown workspace, strip host-side tools (e.g. Serena MCP) that\n    81→\t\t// cause the agent to waste time on onboarding, then exec as agent.\n    82→\t\twrappedCmd := fmt.Sprintf(\n    83→\t\t\t\"chown -R agent:agent /workspace\"+\n    84→\t\t\t\t\" && chown -R agent:agent /home/agent/.claude /home/agent/.claude.json 2>/dev/null\"+\n    85→\t\t\t\t\" && rm -rf /workspace/.serena\"+\n    86→\t\t\t\t\" && f=/home/agent/.claude/settings.json\"+\n    87→\t\t\t\t` && [ -f \"$f\" ] && sed -i '/\"enabledPlugins\"/,/}/d' \"$f\"`+\n    88→\t\t\t\t\"; exec su agent -s /bin/sh -c %q\",\n    89→\t\t\tstrings.Join(containerCmd, \" \"),\n    90→\t\t)\n    91→\t\targs = append(args, cfg.Image, \"sh\", \"-c\", wrappedCmd)\n    92→\t} else {\n    93→\t\targs = append(args, cfg.Image)\n    94→\t\targs = append(args, containerCmd...)\n    95→\t}\n    96→\n    97→\t// docker create\n    98→\tcreateCmd := exec.CommandContext(ctx, \"docker\", args...)\n    99→\tvar stdout, stderr bytes.Buffer\n   100→\tcreateCmd.Stdout = &stdout\n   101→\tcreateCmd.Stderr = &stderr\n   102→\tif err := createCmd.Run(); err != nil {\n   103→\t\treturn \"\", fmt.Errorf(\"creating container: %s: %w\", stderr.String(), err)\n   104→\t}\n   105→\tcontainerID := strings.TrimSpace(stdout.String())\n   106→\n   107→\t// 3. Copy project files into container (no bind mount)\n   108→\tif cfg.ProjectDir != \"\" {\n   109→\t\tcpCmd := exec.CommandContext(ctx, \"docker\", \"cp\", cfg.ProjectDir+\"/.\", containerID+\":/workspace/\")\n   110→\t\tvar cpStderr bytes.Buffer\n   111→\t\tcpCmd.Stderr = &cpStderr\n   112→\t\tif err := cpCmd.Run(); err != nil {\n   113→\t\t\t// Cleanup on failure\n   114→\t\t\texec.CommandContext(ctx, \"docker\", \"rm\", \"-f\", containerID).Run()\n   115→\t\t\treturn \"\", fmt.Errorf(\"copying files to container: %s: %w\", cpStderr.String(), err)\n   116→\t\t}\n   117→\n   118→\t\t// Apply override files from .cloche/overrides/ on top of workspace\n   119→\t\toverridesDir := filepath.Join(cfg.ProjectDir, \".cloche\", \"overrides\")\n   120→\t\tif _, err := os.Stat(overridesDir); err == nil {\n   121→\t\t\toverrideCmd := exec.CommandContext(ctx, \"docker\", \"cp\", overridesDir+\"/.\", containerID+\":/workspace/\")\n   122→\t\t\toverrideCmd.Stderr = &cpStderr\n   123→\t\t\tif err := overrideCmd.Run(); err != nil {\n   124→\t\t\t\t// Non-fatal: log but don't fail the run\n   125→\t\t\t\tfmt.Fprintf(os.Stderr, \"warning: copying overrides: %s\\n\", cpStderr.String())\n   126→\t\t\t}\n   127→\t\t}\n   128→\t}\n   129→\n   130→\t// 4. Copy Claude auth files into container (each gets its own copy)\n   131→\tif home, err := os.UserHomeDir(); err == nil {\n   132→\t\tclaudeDir := home + \"/.claude\"\n   133→\t\tif _, err := os.Stat(claudeDir); err == nil {\n   134→\t\t\texec.CommandContext(ctx, \"docker\", \"cp\", claudeDir, containerID+\":/home/agent/.claude\").Run()\n   135→\t\t}\n   136→\t\tclaudeJSON := home + \"/.claude.json\"\n   137→\t\tif _, err := os.Stat(claudeJSON); err == nil {\n   138→\t\t\texec.CommandContext(ctx, \"docker\", \"cp\", claudeJSON, containerID+\":/home/agent/.claude.json\").Run()\n   139→\t\t}\n   140→\t}\n   141→\n   142→\t// 5. Start the container\n   143→\tstartCmd := exec.CommandContext(ctx, \"docker\", \"start\", containerID)\n   144→\tvar startStderr bytes.Buffer\n   145→\tstartCmd.Stderr = &startStderr\n   146→\tif err := startCmd.Run(); err != nil {\n   147→\t\texec.CommandContext(ctx, \"docker\", \"rm\", \"-f\", containerID).Run()\n   148→\t\treturn \"\", fmt.Errorf(\"starting container: %s: %w\", startStderr.String(), err)\n   149→\t}\n   150→\n   151→\treturn containerID, nil\n   152→}\n   153→\n   154→func (r *Runtime) Stop(ctx context.Context, containerID string) error {\n   155→\tcmd := exec.CommandContext(ctx, \"docker\", \"stop\", containerID)\n   156→\tvar stderr bytes.Buffer\n   157→\tcmd.Stderr = &stderr\n   158→\n   159→\tif err := cmd.Run(); err != nil {\n   160→\t\treturn fmt.Errorf(\"stopping container: %s: %w\", stderr.String(), err)\n   161→\t}\n   162→\treturn nil\n   163→}\n   164→\n   165→func (r *Runtime) AttachOutput(ctx context.Context, containerID string) (io.ReadCloser, error) {\n   166→\tcmd := exec.CommandContext(ctx, \"docker\", \"logs\", \"-f\", containerID)\n   167→\tstdout, err := cmd.StdoutPipe()\n   168→\tif err != nil {\n   169→\t\treturn nil, fmt.Errorf(\"creating stdout pipe: %w\", err)\n   170→\t}\n   171→\n   172→\tif err := cmd.Start(); err != nil {\n   173→\t\treturn nil, fmt.Errorf(\"attaching to container output: %w\", err)\n   174→\t}\n   175→\n   176→\treturn &cmdReadCloser{ReadCloser: stdout, cmd: cmd}, nil\n   177→}\n   178→\n   179→func (r *Runtime) Wait(ctx context.Context, containerID string) (int, error) {\n   180→\tcmd := exec.CommandContext(ctx, \"docker\", \"wait\", containerID)\n   181→\tvar stdout, stderr bytes.Buffer\n   182→\tcmd.Stdout = &stdout\n   183→\tcmd.Stderr = &stderr\n   184→\n   185→\tif err := cmd.Run(); err != nil {\n   186→\t\treturn -1, fmt.Errorf(\"waiting for container: %s: %w\", stderr.String(), err)\n   187→\t}\n   188→\n   189→\tcode, err := strconv.Atoi(strings.TrimSpace(stdout.String()))\n   190→\tif err != nil {\n   191→\t\treturn -1, fmt.Errorf(\"parsing exit code %q: %w\", stdout.String(), err)\n   192→\t}\n   193→\treturn code, nil\n   194→}\n   195→\n   196→func (r *Runtime) CopyFrom(ctx context.Context, containerID string, srcPath, dstPath string) error {\n   197→\tcmd := exec.CommandContext(ctx, \"docker\", \"cp\", containerID+\":\"+srcPath, dstPath)\n   198→\tvar stderr bytes.Buffer\n   199→\tcmd.Stderr = &stderr\n   200→\tif err := cmd.Run(); err != nil {\n   201→\t\treturn fmt.Errorf(\"copying from container: %s: %w\", stderr.String(), err)\n   202→\t}\n   203→\treturn nil\n   204→}\n   205→\n   206→func (r *Runtime) Logs(ctx context.Context, containerID string) (string, error) {\n   207→\tcmd := exec.CommandContext(ctx, \"docker\", \"logs\", containerID)\n   208→\tvar stdout, stderr bytes.Buffer\n   209→\tcmd.Stdout = &stdout\n   210→\tcmd.Stderr = &stderr\n   211→\tif err := cmd.Run(); err != nil {\n   212→\t\treturn \"\", fmt.Errorf(\"getting container logs: %s: %w\", stderr.String(), err)\n   213→\t}\n   214→\t// Combine stdout and stderr\n   215→\tcombined := stdout.String() + stderr.String()\n   216→\treturn combined, nil\n   217→}\n   218→\n   219→func (r *Runtime) Remove(ctx context.Context, containerID string) error {\n   220→\tcmd := exec.CommandContext(ctx, \"docker\", \"rm\", containerID)\n   221→\tvar stderr bytes.Buffer\n   222→\tcmd.Stderr = &stderr\n   223→\tif err := cmd.Run(); err != nil {\n   224→\t\treturn fmt.Errorf(\"removing container: %s: %w\", stderr.String(), err)\n   225→\t}\n   226→\treturn nil\n   227→}\n   228→\n   229→func (r *Runtime) Inspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error) {\n   230→\tcmd := exec.CommandContext(ctx, \"docker\", \"inspect\",\n   231→\t\t\"--format\", \"{{.State.Running}} {{.State.ExitCode}} {{.State.FinishedAt}}\",\n   232→\t\tcontainerID)\n   233→\tvar stdout, stderr bytes.Buffer\n   234→\tcmd.Stdout = &stdout\n   235→\tcmd.Stderr = &stderr\n   236→\tif err := cmd.Run(); err != nil {\n   237→\t\treturn nil, fmt.Errorf(\"inspecting container: %s: %w\", stderr.String(), err)\n   238→\t}\n   239→\n   240→\tparts := strings.SplitN(strings.TrimSpace(stdout.String()), \" \", 3)\n   241→\tif len(parts) < 3 {\n   242→\t\treturn nil, fmt.Errorf(\"unexpected inspect output: %s\", stdout.String())\n   243→\t}\n   244→\n   245→\trunning := parts[0] == \"true\"\n   246→\texitCode := 0\n   247→\tfmt.Sscanf(parts[1], \"%d\", &exitCode)\n   248→\tfinishedAt, _ := time.Parse(time.RFC3339Nano, parts[2])\n   249→\n   250→\treturn &ports.ContainerStatus{\n   251→\t\tRunning:    running,\n   252→\t\tExitCode:   exitCode,\n   253→\t\tFinishedAt: finishedAt,\n   254→\t}, nil\n   255→}\n   256→\n   257→type cmdReadCloser struct {\n   258→\tio.ReadCloser\n   259→\tcmd *exec.Cmd\n   260→}\n   261→\n   262→func (c *cmdReadCloser) Close() error {\n   263→\terr := c.ReadCloser.Close()\n   264→\tc.cmd.Wait()\n   265→\treturn err\n   266→}"}]},"parent_tool_use_id":"toolu_01JL8mFVY8Rhg22KuPsWEiLJ","session_id":"6b861655-1988-46e5-92b9-f0a2db90f2de","uuid":"41e67953-d7d6-4e1f-a1b0-4234c5f08146"}
[2026-03-13T14:37:10Z] [llm] {"type":"system","subtype":"task_progress","task_id":"a03c0cf2f52866738","tool_use_id":"toolu_01JL8mFVY8Rhg22KuPsWEiLJ","description":"Reading docs/plans/2026-03-06-host-workflow-design.md","usage":{"total_tokens":37586,"tool_uses":17,"duration_ms":20344},"last_tool_name":"Read","uuid":"e7662d67-bf09-4105-990a-3e9c23aebec0","session_id":"6b861655-1988-46e5-92b9-f0a2db90f2de"}
[2026-03-13T14:37:10Z] [llm] {"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_017UqL4NiHLzYwegAymzmbhb","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01RitHXdqymKDUBoX7Qy2cFC","name":"Read","input":{"file_path":"/workspace/docs/plans/2026-03-06-host-workflow-design.md"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":7,"cache_creation_input_tokens":3457,"cache_read_input_tokens":34082,"cache_creation":{"ephemeral_5m_input_tokens":3457,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01JL8mFVY8Rhg22KuPsWEiLJ","session_id":"6b861655-1988-46e5-92b9-f0a2db90f2de","uuid":"7d1671c9-5cba-42b2-88ca-02d1afdbcc72"}
[2026-03-13T14:37:10Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RitHXdqymKDUBoX7Qy2cFC","type":"tool_result","content":"     1→# Host Workflow Design (`host.cloche`)\n     2→\n     3→**Date:** 2026-03-06\n     4→**Status:** Design\n     5→\n     6→## Problem\n     7→\n     8→The orchestrator's intake → process → output loop is hard-coded in Go\n     9→(`internal/orchestrator/orchestrator.go`). Every project must follow the same flow:\n    10→pull task → generate prompt → dispatch `develop` container run. This can't be changed\n    11→without modifying Cloche itself. Projects that need different orchestration strategies\n    12→(push to GitHub for review, group tickets into feature branches, stacked commits, etc.)\n    13→have no extension point.\n    14→\n    15→## Solution: `host.cloche`\n    16→\n    17→A special workflow file at `.cloche/host.cloche`. It uses the same DSL as container\n    18→workflow files, with one additional step type (`workflow`). Steps in this file execute\n    19→on the **host machine**, not inside a container.\n    20→\n    21→The workflow named `main` in this file becomes the per-task orchestration loop\n    22→for that project. The Go daemon becomes the executor of this workflow rather than the\n    23→hard-coded logic holder.\n    24→\n    25→### File location\n    26→\n    27→```\n    28→.cloche/host.cloche\n    29→```\n    30→\n    31→If the file does not exist, the daemon falls back to the current hard-coded behavior\n    32→(pull task → LLM prompt generation → dispatch container workflow).\n    33→\n    34→---\n    35→\n    36→## DSL additions\n    37→\n    38→### New step type: `workflow`\n    39→\n    40→A step with `workflow_name` config key is a workflow-dispatch step. It dispatches a\n    41→named container workflow run and blocks until that run completes.\n    42→\n    43→```\n    44→step develop {\n    45→  workflow_name = \"develop\"\n    46→  results = [success, fail]\n    47→}\n    48→```\n    49→\n    50→`workflow_name` is added to `knownStepConfigKeys` in `domain/workflow.go`.\n    51→\n    52→`StepTypeWorkflow` is added to the `StepType` enum in `domain/workflow.go`.\n    53→\n    54→The parser (`dsl/parser.go`) infers `StepTypeWorkflow` when `workflow_name` is present\n    55→(same pattern as `run` → script, `prompt` → agent).\n    56→\n    57→### Prompt input for `workflow` steps\n    58→\n    59→The container workflow needs a prompt. By convention, a `workflow` step reads the\n    60→previous step's captured output file as the prompt. This is the primary data-passing\n    61→mechanism.\n    62→\n    63→An optional config key `prompt_step` overrides which step's output to read:\n    64→```\n    65→step develop {\n    66→  workflow_name = \"develop\"\n    67→  prompt_step   = \"prepare-prompt\"\n    68→  results       = [success, fail]\n    69→}\n    70→```\n    71→\n    72→---\n    73→\n    74→## Step output capture\n    75→\n    76→Every step in a host workflow execution writes its output (stdout of `run` steps,\n    77→final response of `prompt` steps) to a file:\n    78→\n    79→```\n    80→.cloche/<orch-run-id>/main/<step_name>.out\n    81→```\n    82→\n    83→`<orch-run-id>` is a unique ID for this orchestration invocation, formatted the same\n    84→way as workflow run IDs (e.g. `main-bold-hawk`).\n    85→\n    86→The daemon tracks the most recently completed step's output path and passes it to the\n    87→next step as `CLOCHE_PREV_OUTPUT`.\n    88→\n    89→---\n    90→\n    91→## Environment variables injected into host steps\n    92→\n    93→All `run` and `prompt` steps receive:\n    94→\n    95→| Variable | Value |\n    96→|----------|-------|\n    97→| `CLOCHE_TASK_ID` | Task ID being processed |\n    98→| `CLOCHE_TASK_TITLE` | Task summary/title |\n    99→| `CLOCHE_TASK_BODY` | Task full body/description |\n   100→| `CLOCHE_PROJECT_DIR` | Absolute path to the project directory |\n   101→| `CLOCHE_STEP_OUTPUT` | Path where this step should write its output |\n   102→| `CLOCHE_PREV_OUTPUT` | Path to the previous step's output file |\n   103→\n   104→For `workflow` steps, `CLOCHE_PREV_OUTPUT` is read automatically (unless `prompt_step`\n   105→overrides it).\n   106→\n   107→---\n   108→\n   109→## Executor: `internal/orchestrator/hostrunner.go`\n   110→\n   111→New file. Implements the host workflow execution loop.\n   112→\n   113→```go\n   114→type HostRunner struct {\n   115→    Dispatch  RunDispatcher      // existing: dispatches a container workflow run\n   116→    WaitRun   RunWaiter          // new: blocks until a run ID completes, returns final state\n   117→    AgentCmd  string             // command to invoke for prompt steps on host\n   118→}\n   119→\n   120→// RunWorkflow executes the named workflow from a parsed host.cloche Workflow\n   121→// for a single task. Returns the final result (\"done\" or \"abort\").\n   122→func (r *HostRunner) RunWorkflow(ctx context.Context, wf *domain.Workflow, task ports.Task, orchRunID string) (string, error)\n   123→```\n   124→\n   125→Step execution:\n   126→\n   127→- **`script` step** (`run` key): `exec.Command` with env vars, stdout captured to\n   128→  `<step>.out`, stderr to `<step>.err`. Exit 0 → `success`, non-zero → `fail`.\n   129→- **`agent` step** (`prompt` key): invoke `AgentCmd` on host with the prompt file\n   130→  contents injected. Capture output. Exit 0 → `success`, non-zero → `fail`.\n   131→- **`workflow` step** (`workflow_name` key): read prompt from prev step's `.out` file\n   132→  (or `prompt_step` override), call `Dispatch`, then call `WaitRun` to block until\n   133→  the container run completes. Map `succeeded` → `success`, `failed`/`cancelled` →\n   134→  `fail`.\n   135→\n   136→`WaitRun` is a new port interface:\n   137→\n   138→```go\n   139→// RunWaiter blocks until the run with the given ID reaches a terminal state.\n   140→type RunWaiter interface {\n   141→    WaitRun(ctx context.Context, runID string) (domain.RunState, error)\n   142→}\n   143→```\n   144→\n   145→The gRPC server / store already has `GetRun`; the waiter can poll it with backoff or\n   146→subscribe to the `OnRunComplete` event. A simple polling implementation (1s interval)\n   147→is sufficient initially.\n   148→\n   149→---\n   150→\n   151→## Refactored `orchestrator.Orchestrator`\n   152→\n   153→`Orchestrator.Run()` is updated:\n   154→\n   155→**Current flow (hardcoded):**\n   156→1. Pull ready tasks\n   157→2. Claim task\n   158→3. Call `promptGen.Generate(task)`\n   159→4. Call `dispatch(workflow, projectDir, prompt)` → runID\n   160→5. (In-flight counter managed, `OnRunComplete` decrements it)\n   161→\n   162→**New flow (when `host.cloche` exists):**\n   163→1. Pull ready tasks\n   164→2. Claim task\n   165→3. Parse `.cloche/host.cloche` → find `main` workflow\n   166→4. Generate an `orchRunID` (`main-<namegen>`)\n   167→5. Spin up a goroutine: call `hostRunner.RunWorkflow(ctx, orch wf, task, orchRunID)`\n   168→6. On goroutine return: decrement in-flight, update task state (success/fail)\n   169→\n   170→The old `promptGen` and `dispatch` are still used as the **fallback** when\n   171→`host.cloche` is absent (no breaking change for existing projects).\n   172→\n   173→`WaitRun` needs access to the run store. Wire it in `initOrchestrator` in\n   174→`cmd/cloched/main.go`.\n   175→\n   176→---\n   177→\n   178→## Default `host.cloche` (from `cloche init`)\n   179→\n   180→```\n   181→# host.cloche — orchestration workflow (runs on host, not in container)\n   182→# Steps here execute as the daemon user. Keep operations simple and safe.\n   183→\n   184→workflow \"main\" {\n   185→  step prepare-prompt {\n   186→    run     = \"bash .cloche/scripts/prepare-prompt.sh\"\n   187→    results = [success, fail]\n   188→  }\n   189→\n   190→  step develop {\n   191→    workflow_name = \"develop\"\n   192→    results       = [success, fail]\n   193→  }\n   194→\n   195→  prepare-prompt:success -> develop\n   196→  prepare-prompt:fail    -> abort\n   197→  develop:success        -> done\n   198→  develop:fail           -> done\n   199→}\n   200→```\n   201→\n   202→And `.cloche/scripts/prepare-prompt.sh` (created by init, chmod +x):\n   203→\n   204→```bash\n   205→#!/usr/bin/env bash\n   206→# Default prompt generator. Uses task env vars injected by cloched.\n   207→# Write the prompt to $CLOCHE_STEP_OUTPUT (also echoed to stdout).\n   208→set -euo pipefail\n   209→\n   210→prompt=\"## Task: ${CLOCHE_TASK_TITLE}\n   211→\n   212→${CLOCHE_TASK_BODY}\"\n   213→\n   214→echo \"$prompt\"\n   215→[ -n \"${CLOCHE_STEP_OUTPUT:-}\" ] && echo \"$prompt\" > \"$CLOCHE_STEP_OUTPUT\"\n   216→```\n   217→\n   218→---\n   219→\n   220→## `.gitignore` update\n   221→\n   222→`cloche init` adds `.cloche/scripts/` is NOT gitignored (scripts are project config).\n   223→The orchestration run output dirs follow the same pattern as container run dirs:\n   224→`.cloche/main-*/` is gitignored via the existing `.cloche/*/` rule.\n   225→\n   226→---\n   227→\n   228→## Safety notes\n   229→\n   230→- Host steps run with the same OS privileges as the `cloched` process.\n   231→- No network isolation.\n   232→- `host.cloche` should only reference scripts that are committed to the project.\n   233→- Document that `prompt` steps in `host.cloche` invoke an LLM agent with full host\n   234→  filesystem access — use judiciously.\n   235→\n   236→---\n   237→\n   238→## Changes required\n   239→\n   240→| File | Change |\n   241→|------|--------|\n   242→| `internal/domain/workflow.go` | Add `StepTypeWorkflow`, add `workflow_name`/`prompt_step` to `knownStepConfigKeys` |\n   243→| `internal/dsl/parser.go` | Infer `StepTypeWorkflow` when `workflow_name` key is present |\n   244→| `internal/orchestrator/hostrunner.go` | New: host workflow executor |\n   245→| `internal/orchestrator/orchestrator.go` | Refactor `Run()` to use `HostRunner` when `host.cloche` exists; fall back to current behavior otherwise |\n   246→| `internal/ports/container.go` | Add `RunWaiter` interface |\n   247→| `cmd/cloched/main.go` | Wire `HostRunner` into orchestrator init |\n   248→| `cmd/cloche/init.go` | Create `host.cloche` and `scripts/prepare-prompt.sh` |\n   249→"}]},"parent_tool_use_id":"toolu_01JL8mFVY8Rhg22KuPsWEiLJ","session_id":"6b861655-1988-46e5-92b9-f0a2db90f2de","uuid":"9b7b64ab-77d4-4688-aad7-44744c249e66"}
