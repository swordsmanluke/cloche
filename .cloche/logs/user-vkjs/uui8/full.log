[2026-03-13T14:41:40Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RPB2LvQW1iSd7hfmNnGu2W","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    19→\t\"github.com/cloche-dev/cloche/internal/config\"\n    20→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    21→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    22→\t\"github.com/cloche-dev/cloche/internal/host\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    26→\trpcgrpc \"google.golang.org/grpc\"\n    27→\t\"google.golang.org/grpc/metadata\"\n    28→)\n    29→\n    30→type ClocheServer struct {\n    31→\tpb.UnimplementedClocheServiceServer\n    32→\tstore        ports.RunStore\n    33→\tcaptures     ports.CaptureStore\n    34→\tlogStore     ports.LogStore\n    35→\tcontainer    ports.ContainerRuntime\n    36→\tdefaultImage string\n    37→\tevolution    *evolution.Trigger\n    38→\tlogBroadcast *logstream.Broadcaster\n    39→\tshutdownFn   func()\n    40→\tmu           sync.Mutex\n    41→\trunIDs       map[string]string      // run_id -> container_id\n    42→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    43→}\n    44→\n    45→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    46→\treturn &ClocheServer{\n    47→\t\tstore:     store,\n    48→\t\tcontainer: container,\n    49→\t\trunIDs:    make(map[string]string),\n    50→\t\tloops:     make(map[string]*host.Loop),\n    51→\t}\n    52→}\n    53→\n    54→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    55→\treturn &ClocheServer{\n    56→\t\tstore:        store,\n    57→\t\tcaptures:     captures,\n    58→\t\tcontainer:    container,\n    59→\t\tdefaultImage: defaultImage,\n    60→\t\trunIDs:       make(map[string]string),\n    61→\t\tloops:        make(map[string]*host.Loop),\n    62→\t}\n    63→}\n    64→\n    65→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    66→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    67→\ts.logStore = ls\n    68→}\n    69→\n    70→\n    71→// SetEvolution attaches an evolution trigger to the server.\n    72→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    73→\ts.evolution = trigger\n    74→}\n    75→\n    76→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    77→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    78→\ts.logBroadcast = b\n    79→}\n    80→\n    81→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    82→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    83→\ts.shutdownFn = fn\n    84→}\n    85→\n    86→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    87→\tif s.container == nil {\n    88→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    89→\t}\n    90→\n    91→\t// Generate a unique run ID, retrying on collision\n    92→\tvar runID string\n    93→\tfor attempts := 0; attempts < 10; attempts++ {\n    94→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    95→\t\texisting, err := s.store.GetRun(ctx, runID)\n    96→\t\tif err != nil {\n    97→\t\t\tbreak // ID is free\n    98→\t\t}\n    99→\t\t// Reuse if completed more than 1 hour ago\n   100→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   101→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   102→\t\t\tbreak\n   103→\t\t}\n   104→\t}\n   105→\n   106→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   107→\tif req.Prompt != \"\" {\n   108→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   109→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   110→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   111→\t\t}\n   112→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   113→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   114→\t\t}\n   115→\t}\n   116→\trun := domain.NewRun(runID, req.WorkflowName)\n   117→\trun.ProjectDir = req.ProjectDir\n   118→\trun.Title = req.Title\n   119→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   120→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   121→\t}\n   122→\n   123→\t// Resolve image: request-level override, then server default\n   124→\timage := req.Image\n   125→\tif image == \"\" {\n   126→\t\timage = s.defaultImage\n   127→\t}\n   128→\n   129→\t// Launch container start + tracking in background so the RPC returns immediately.\n   130→\t// The run stays in \"pending\" state until the container is up.\n   131→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   132→\n   133→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   134→}\n   135→\n   136→// launchAndTrack starts the container and then tracks it to completion.\n   137→// It runs in a background goroutine with its own context, independent of the\n   138→// RPC context which may be cancelled after RunWorkflow returns.\n   139→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   140→\tctx := context.Background()\n   141→\n   142→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   143→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   144→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   145→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   146→\t\t\tif run != nil {\n   147→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   148→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   149→\t\t\t}\n   150→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   151→\t\t\t\treturn\n   152→\t\t}\n   153→\t}\n   154→\n   155→\tbaseSHA := gitHEAD(req.ProjectDir)\n   156→\n   157→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   158→\t\tImage:        image,\n   159→\t\tWorkflowName: req.WorkflowName,\n   160→\t\tProjectDir:   req.ProjectDir,\n   161→\t\tRunID:        runID,\n   162→\t\tNetworkAllow: []string{\"*\"},\n   163→\t})\n   164→\tif err != nil {\n   165→\t\trun, _ := s.store.GetRun(ctx, runID)\n   166→\t\tif run != nil {\n   167→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   168→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   169→\t\t}\n   170→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   171→\t\treturn\n   172→\t}\n   173→\n   174→\ts.mu.Lock()\n   175→\ts.runIDs[runID] = containerID\n   176→\ts.mu.Unlock()\n   177→\n   178→\trun, _ := s.store.GetRun(ctx, runID)\n   179→\tif run != nil {\n   180→\t\trun.Start()\n   181→\t\trun.ContainerID = containerID\n   182→\t\trun.BaseSHA = baseSHA\n   183→\t\t_ = s.store.UpdateRun(ctx, run)\n   184→\t}\n   185→\n   186→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   187→}\n   188→\n   189→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   190→\tctx := context.Background()\n   191→\n   192→\t// Attach to agent output\n   193→\treader, err := s.container.AttachOutput(ctx, containerID)\n   194→\tif err != nil {\n   195→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   196→\t\t\treturn\n   197→\t}\n   198→\n   199→\t// Parse JSON-lines status messages\n   200→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction"}]},"parent_tool_use_id":"toolu_01DYUGkaDmeivE9DdDR2ug9Z","session_id":"dbf10f22-a7e0-4657-b5f4-9a1bc4f6ad20","uuid":"da23154e-7d4b-4d8a-a7f1-5ea25e9d60f3"}
