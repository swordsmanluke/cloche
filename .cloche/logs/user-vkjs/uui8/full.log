[2026-03-13T14:37:10Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DbvaGBXXiFJgJw2WxZofVc","type":"tool_result","content":"     1→# Cloche MVP Implementation Plan\n     2→\n     3→> **For Claude:** REQUIRED SUB-SKILL: Use superpowers:executing-plans to implement this plan task-by-task.\n     4→\n     5→**Goal:** Build a working Cloche MVP — parse workflow DSL, execute steps in Docker containers, report status via gRPC.\n     6→\n     7→**Architecture:** Three Go binaries (cloche, cloched, cloche-agent) with hexagonal architecture. Domain types and DSL parser are the foundation. Build bottom-up: domain -> DSL -> engine -> agent binary -> daemon -> CLI.\n     8→\n     9→**Tech Stack:** Go 1.22+, protobuf/gRPC, Docker SDK, SQLite (via modernc.org/sqlite — pure Go), testify for assertions.\n    10→\n    11→---\n    12→\n    13→## Phase 1: Foundation\n    14→\n    15→### Task 1: Initialize Go Module and Directory Structure\n    16→\n    17→**Files:**\n    18→- Create: `go.mod`\n    19→- Create: `Makefile`\n    20→- Create: `cmd/cloche/main.go`\n    21→- Create: `cmd/cloched/main.go`\n    22→- Create: `cmd/cloche-agent/main.go`\n    23→\n    24→**Step 1: Initialize Go module**\n    25→\n    26→```bash\n    27→cd /home/lucas/workspace/cloche\n    28→go mod init github.com/cloche-dev/cloche\n    29→```\n    30→\n    31→**Step 2: Create directory structure**\n    32→\n    33→```bash\n    34→mkdir -p cmd/cloche cmd/cloched cmd/cloche-agent\n    35→mkdir -p internal/domain internal/ports\n    36→mkdir -p internal/adapters/docker internal/adapters/sqlite\n    37→mkdir -p internal/adapters/grpc internal/adapters/agents/generic\n    38→mkdir -p internal/adapters/agents/claudecode\n    39→mkdir -p internal/dsl internal/engine internal/protocol\n    40→```\n    41→\n    42→**Step 3: Create placeholder mains**\n    43→\n    44→`cmd/cloche/main.go`:\n    45→```go\n    46→package main\n    47→\n    48→func main() {}\n    49→```\n    50→\n    51→`cmd/cloched/main.go`:\n    52→```go\n    53→package main\n    54→\n    55→func main() {}\n    56→```\n    57→\n    58→`cmd/cloche-agent/main.go`:\n    59→```go\n    60→package main\n    61→\n    62→func main() {}\n    63→```\n    64→\n    65→**Step 4: Create Makefile**\n    66→\n    67→```makefile\n    68→.PHONY: build test lint clean\n    69→\n    70→build:\n    71→\tgo build -o bin/cloche ./cmd/cloche\n    72→\tgo build -o bin/cloched ./cmd/cloched\n    73→\tgo build -o bin/cloche-agent ./cmd/cloche-agent\n    74→\n    75→test:\n    76→\tgo test ./... -v\n    77→\n    78→test-short:\n    79→\tgo test ./... -short\n    80→\n    81→lint:\n    82→\tgo vet ./...\n    83→\n    84→clean:\n    85→\trm -rf bin/\n    86→```\n    87→\n    88→**Step 5: Verify build**\n    89→\n    90→```bash\n    91→make build\n    92→```\n    93→Expected: three binaries in `bin/`\n    94→\n    95→**Step 6: Commit**\n    96→\n    97→```bash\n    98→git add -A && git commit -m \"feat: initialize Go module and project structure\"\n    99→```\n   100→\n   101→---\n   102→\n   103→## Phase 2: Domain Types\n   104→\n   105→### Task 2: Workflow Domain Types\n   106→\n   107→**Files:**\n   108→- Create: `internal/domain/workflow.go`\n   109→- Create: `internal/domain/workflow_test.go`\n   110→\n   111→**Step 1: Write tests for workflow types**\n   112→\n   113→`internal/domain/workflow_test.go`:\n   114→```go\n   115→package domain_test\n   116→\n   117→import (\n   118→\t\"testing\"\n   119→\n   120→\t\"github.com/cloche-dev/cloche/internal/domain\"\n   121→\t\"github.com/stretchr/testify/assert\"\n   122→\t\"github.com/stretchr/testify/require\"\n   123→)\n   124→\n   125→func TestWorkflow_Validate_ValidGraph(t *testing.T) {\n   126→\twf := &domain.Workflow{\n   127→\t\tName: \"test-workflow\",\n   128→\t\tSteps: map[string]*domain.Step{\n   129→\t\t\t\"code\": {\n   130→\t\t\t\tName:    \"code\",\n   131→\t\t\t\tType:    domain.StepTypeAgent,\n   132→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   133→\t\t\t},\n   134→\t\t\t\"check\": {\n   135→\t\t\t\tName:    \"check\",\n   136→\t\t\t\tType:    domain.StepTypeScript,\n   137→\t\t\t\tResults: []string{\"pass\", \"fail\"},\n   138→\t\t\t},\n   139→\t\t},\n   140→\t\tWiring: []domain.Wire{\n   141→\t\t\t{From: \"code\", Result: \"success\", To: \"check\"},\n   142→\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n   143→\t\t\t{From: \"check\", Result: \"pass\", To: domain.StepDone},\n   144→\t\t\t{From: \"check\", Result: \"fail\", To: \"code\"},\n   145→\t\t},\n   146→\t\tEntryStep: \"code\",\n   147→\t}\n   148→\n   149→\terr := wf.Validate()\n   150→\tassert.NoError(t, err)\n   151→}\n   152→\n   153→func TestWorkflow_Validate_UnwiredResult(t *testing.T) {\n   154→\twf := &domain.Workflow{\n   155→\t\tName: \"test-workflow\",\n   156→\t\tSteps: map[string]*domain.Step{\n   157→\t\t\t\"code\": {\n   158→\t\t\t\tName:    \"code\",\n   159→\t\t\t\tType:    domain.StepTypeAgent,\n   160→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   161→\t\t\t},\n   162→\t\t},\n   163→\t\tWiring: []domain.Wire{\n   164→\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n   165→\t\t\t// \"fail\" is not wired\n   166→\t\t},\n   167→\t\tEntryStep: \"code\",\n   168→\t}\n   169→\n   170→\terr := wf.Validate()\n   171→\trequire.Error(t, err)\n   172→\tassert.Contains(t, err.Error(), \"fail\")\n   173→}\n   174→\n   175→func TestWorkflow_Validate_OrphanStep(t *testing.T) {\n   176→\twf := &domain.Workflow{\n   177→\t\tName: \"test-workflow\",\n   178→\t\tSteps: map[string]*domain.Step{\n   179→\t\t\t\"code\": {\n   180→\t\t\t\tName:    \"code\",\n   181→\t\t\t\tType:    domain.StepTypeAgent,\n   182→\t\t\t\tResults: []string{\"success\"},\n   183→\t\t\t},\n   184→\t\t\t\"orphan\": {\n   185→\t\t\t\tName:    \"orphan\",\n   186→\t\t\t\tType:    domain.StepTypeScript,\n   187→\t\t\t\tResults: []string{\"done\"},\n   188→\t\t\t},\n   189→\t\t},\n   190→\t\tWiring: []domain.Wire{\n   191→\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n   192→\t\t\t{From: \"orphan\", Result: \"done\", To: domain.StepDone},\n   193→\t\t},\n   194→\t\tEntryStep: \"code\",\n   195→\t}\n   196→\n   197→\terr := wf.Validate()\n   198→\trequire.Error(t, err)\n   199→\tassert.Contains(t, err.Error(), \"orphan\")\n   200→}\n   201→\n   202→func TestWorkflow_Validate_NoEntryStep(t *testing.T) {\n   203→\twf := &domain.Workflow{\n   204→\t\tName:      \"test-workflow\",\n   205→\t\tSteps:     map[string]*domain.Step{},\n   206→\t\tWiring:    []domain.Wire{},\n   207→\t\tEntryStep: \"\",\n   208→\t}\n   209→\n   210→\terr := wf.Validate()\n   211→\trequire.Error(t, err)\n   212→\tassert.Contains(t, err.Error(), \"entry\")\n   213→}\n   214→\n   215→func TestWorkflow_NextStep(t *testing.T) {\n   216→\twf := &domain.Workflow{\n   217→\t\tName: \"test-workflow\",\n   218→\t\tSteps: map[string]*domain.Step{\n   219→\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   220→\t\t\t\"check\": {Name: \"check\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n   221→\t\t},\n   222→\t\tWiring: []domain.Wire{\n   223→\t\t\t{From: \"code\", Result: \"success\", To: \"check\"},\n   224→\t\t\t{From: \"check\", Result: \"pass\", To: domain.StepDone},\n   225→\t\t},\n   226→\t\tEntryStep: \"code\",\n   227→\t}\n   228→\n   229→\tnext, err := wf.NextStep(\"code\", \"success\")\n   230→\trequire.NoError(t, err)\n   231→\tassert.Equal(t, \"check\", next)\n   232→\n   233→\tnext, err = wf.NextStep(\"check\", \"pass\")\n   234→\trequire.NoError(t, err)\n   235→\tassert.Equal(t, domain.StepDone, next)\n   236→\n   237→\t_, err = wf.NextStep(\"code\", \"nonexistent\")\n   238→\tassert.Error(t, err)\n   239→}\n   240→```\n   241→\n   242→**Step 2: Run tests to verify they fail**\n   243→\n   244→```bash\n   245→go test ./internal/domain/ -v\n   246→```\n   247→Expected: compilation errors (types don't exist yet)\n   248→\n   249→**Step 3: Implement domain types**\n   250→\n   251→`internal/domain/workflow.go`:\n   252→```go\n   253→package domain\n   254→\n   255→import \"fmt\"\n   256→\n   257→const (\n   258→\tStepDone  = \"done\"\n   259→\tStepAbort = \"abort\"\n   260→)\n   261→\n   262→type StepType string\n   263→\n   264→const (\n   265→\tStepTypeAgent  StepType = \"agent\"\n   266→\tStepTypeScript StepType = \"script\"\n   267→)\n   268→\n   269→type Step struct {\n   270→\tName    string\n   271→\tType    StepType\n   272→\tResults []string\n   273→\tConfig  map[string]string // prompt, run, image, etc.\n   274→}\n   275→\n   276→type Wire struct {\n   277→\tFrom   string\n   278→\tResult string\n   279→\tTo     string\n   280→}\n   281→\n   282→type Workflow struct {\n   283→\tName      string\n   284→\tSteps     map[string]*Step\n   285→\tWiring    []Wire\n   286→\tEntryStep string\n   287→}\n   288→\n   289→func (w *Workflow) Validate() error {\n   290→\tif w.EntryStep == \"\" {\n   291→\t\treturn fmt.Errorf(\"workflow %q: no entry step defined\", w.Name)\n   292→\t}\n   293→\tif _, ok := w.Steps[w.EntryStep]; !ok {\n   294→\t\treturn fmt.Errorf(\"workflow %q: entry step %q not found\", w.Name, w.EntryStep)\n   295→\t}\n   296→\n   297→\t// Check all results are wired\n   298→\twired := make(map[string]map[string]bool)\n   299→\treachable := map[string]bool{w.EntryStep: true}\n   300→\tfor _, wire := range w.Wiring {\n   301→\t\tif wired[wire.From] == nil {\n   302→\t\t\twired[wire.From] = make(map[string]bool)\n   303→\t\t}\n   304→\t\twired[wire.From][wire.Result] = true\n   305→\t\tif wire.To != StepDone && wire.To != StepAbort {\n   306→\t\t\treachable[wire.To] = true\n   307→\t\t}\n   308→\t}\n   309→\n   310→\tfor name, step := range w.Steps {\n   311→\t\tfor _, result := range step.Results {\n   312→\t\t\tif !wired[name][result] {\n   313→\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q result %q is not wired\", w.Name, name, result)\n   314→\t\t\t}\n   315→\t\t}\n   316→\t}\n   317→\n   318→\t// Check for orphan steps (unreachable from any wiring)\n   319→\tfor name := range w.Steps {\n   320→\t\tif !reachable[name] {\n   321→\t\t\treturn fmt.Errorf(\"workflow %q: step %q is orphaned (unreachable)\", w.Name, name)\n   322→\t\t}\n   323→\t}\n   324→\n   325→\treturn nil\n   326→}\n   327→\n   328→func (w *Workflow) NextStep(stepName, result string) (string, error) {\n   329→\tfor _, wire := range w.Wiring {\n   330→\t\tif wire.From == stepName && wire.Result == result {\n   331→\t\t\treturn wire.To, nil\n   332→\t\t}\n   333→\t}\n   334→\treturn \"\", fmt.Errorf(\"workflow %q: no wiring for step %q result %q\", w.Name, stepName, result)\n   335→}\n   336→```\n   337→\n   338→**Step 4: Install testify and run tests**\n   339→\n   340→```bash\n   341→go get github.com/stretchr/testify\n   342→go test ./internal/domain/ -v\n   343→```\n   344→Expected: all tests PASS\n   345→\n   346→**Step 5: Commit**\n   347→\n   348→```bash\n   349→git add -A && git commit -m \"feat: add workflow domain types with validation\"\n   350→```\n   351→\n   352→### Task 3: Run and Capture Domain Types\n   353→\n   354→**Files:**\n   355→- Create: `internal/domain/run.go`\n   356→- Create: `internal/domain/run_test.go`\n   357→\n   358→**Step 1: Write tests**\n   359→\n   360→`internal/domain/run_test.go`:\n   361→```go\n   362→package domain_test\n   363→\n   364→import (\n   365→\t\"testing\"\n   366→\t\"time\"\n   367→\n   368→\t\"github.com/cloche-dev/cloche/internal/domain\"\n   369→\t\"github.com/stretchr/testify/assert\"\n   370→)\n   371→\n   372→func TestRun_Lifecycle(t *testing.T) {\n   373→\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n   374→\tassert.Equal(t, domain.RunStatePending, run.State)\n   375→\n   376→\trun.Start()\n   377→\tassert.Equal(t, domain.RunStateRunning, run.State)\n   378→\tassert.False(t, run.StartedAt.IsZero())\n   379→\n   380→\trun.RecordStepStart(\"code\")\n   381→\tassert.Equal(t, \"code\", run.CurrentStep)\n   382→\tassert.Len(t, run.StepExecutions, 1)\n   383→\n   384→\trun.RecordStepComplete(\"code\", \"success\")\n   385→\tassert.Equal(t, \"success\", run.StepExecutions[0].Result)\n   386→\tassert.False(t, run.StepExecutions[0].CompletedAt.IsZero())\n   387→\n   388→\trun.Complete(domain.RunStateSucceeded)\n   389→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   390→\tassert.False(t, run.CompletedAt.IsZero())\n   391→}\n   392→\n   393→func TestRun_StepExecution_Duration(t *testing.T) {\n   394→\texec := &domain.StepExecution{\n   395→\t\tStepName:    \"code\",\n   396→\t\tStartedAt:   time.Now().Add(-5 * time.Second),\n   397→\t\tCompletedAt: time.Now(),\n   398→\t}\n   399→\tassert.InDelta(t, 5.0, exec.Duration().Seconds(), 0.1)\n   400→}"}]},"parent_tool_use_id":"toolu_01JL8mFVY8Rhg22KuPsWEiLJ","session_id":"6b861655-1988-46e5-92b9-f0a2db90f2de","uuid":"d3ac47d9-2c5c-445e-82c7-b669d85999c5"}
