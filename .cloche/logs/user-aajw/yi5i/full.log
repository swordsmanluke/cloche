[2026-03-12T15:46:26Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FPSyaP3XdjMnA14bQfhJ2a","type":"tool_result","content":"     1Ôćĺpackage main\n     2Ôćĺ\n     3Ôćĺimport (\n     4Ôćĺ\t\"context\"\n     5Ôćĺ\t\"encoding/json\"\n     6Ôćĺ\t\"errors\"\n     7Ôćĺ\t\"fmt\"\n     8Ôćĺ\t\"io\"\n     9Ôćĺ\t\"net/http\"\n    10Ôćĺ\t\"os\"\n    11Ôćĺ\t\"path/filepath\"\n    12Ôćĺ\t\"strings\"\n    13Ôćĺ\t\"time\"\n    14Ôćĺ\n    15Ôćĺ\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    16Ôćĺ\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    17Ôćĺ\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    18Ôćĺ\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    19Ôćĺ\t\"google.golang.org/grpc\"\n    20Ôćĺ\t\"google.golang.org/grpc/credentials/insecure\"\n    21Ôćĺ\t\"google.golang.org/grpc/metadata\"\n    22Ôćĺ)\n    23Ôćĺ\n    24Ôćĺfunc main() {\n    25Ôćĺ\tif len(os.Args) < 2 {\n    26Ôćĺ\t\tusage()\n    27Ôćĺ\t\tos.Exit(1)\n    28Ôćĺ\t}\n    29Ôćĺ\n    30Ôćĺ\t// Commands that don't need a daemon connection\n    31Ôćĺ\tswitch os.Args[1] {\n    32Ôćĺ\tcase \"init\":\n    33Ôćĺ\t\tcmdInit(os.Args[2:])\n    34Ôćĺ\t\treturn\n    35Ôćĺ\tcase \"health\":\n    36Ôćĺ\t\tcmdHealth(os.Args[2:])\n    37Ôćĺ\t\treturn\n    38Ôćĺ\tcase \"get\":\n    39Ôćĺ\t\tcmdGet(os.Args[2:])\n    40Ôćĺ\t\treturn\n    41Ôćĺ\tcase \"set\":\n    42Ôćĺ\t\tcmdSet(os.Args[2:])\n    43Ôćĺ\t\treturn\n    44Ôćĺ\tcase \"tasks\":\n    45Ôćĺ\t\tcmdTasks(os.Args[2:])\n    46Ôćĺ\t\treturn\n    47Ôćĺ\t}\n    48Ôćĺ\n    49Ôćĺ\t// Commands that need a daemon connection\n    50Ôćĺ\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    51Ôćĺ\tif addr == \"\" {\n    52Ôćĺ\t\taddr = \"unix:///tmp/cloche.sock\"\n    53Ôćĺ\t}\n    54Ôćĺ\n    55Ôćĺ\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n    56Ôćĺ\tif err != nil {\n    57Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n    58Ôćĺ\t\tos.Exit(1)\n    59Ôćĺ\t}\n    60Ôćĺ\tdefer conn.Close()\n    61Ôćĺ\n    62Ôćĺ\tclient := pb.NewClocheServiceClient(conn)\n    63Ôćĺ\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n    64Ôćĺ\tdefer cancel()\n    65Ôćĺ\n    66Ôćĺ\tswitch os.Args[1] {\n    67Ôćĺ\tcase \"run\":\n    68Ôćĺ\t\tcmdRun(ctx, client, os.Args[2:])\n    69Ôćĺ\tcase \"status\":\n    70Ôćĺ\t\tcmdStatus(ctx, client, os.Args[2:])\n    71Ôćĺ\tcase \"logs\":\n    72Ôćĺ\t\tcmdLogs(client, os.Args[2:])\n    73Ôćĺ\tcase \"poll\":\n    74Ôćĺ\t\tcmdPoll(client, os.Args[2:])\n    75Ôćĺ\tcase \"list\":\n    76Ôćĺ\t\tcmdList(ctx, client, os.Args[2:])\n    77Ôćĺ\tcase \"stop\":\n    78Ôćĺ\t\tcmdStop(ctx, client, os.Args[2:])\n    79Ôćĺ\tcase \"delete\":\n    80Ôćĺ\t\tcmdDelete(ctx, client, os.Args[2:])\n    81Ôćĺ\tcase \"loop\":\n    82Ôćĺ\t\tcmdLoop(ctx, client, os.Args[2:])\n    83Ôćĺ\tcase \"shutdown\":\n    84Ôćĺ\t\tcmdShutdown(ctx, client)\n    85Ôćĺ\tdefault:\n    86Ôćĺ\t\tusage()\n    87Ôćĺ\t\tos.Exit(1)\n    88Ôćĺ\t}\n    89Ôćĺ}\n    90Ôćĺ\n    91Ôćĺfunc usage() {\n    92Ôćĺ\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n    93Ôćĺ\n    94ÔćĺCommands:\n    95Ôćĺ  init [--workflow <name>] [--base-image <image>]\n    96Ôćĺ                                             Initialize a Cloche project\n    97Ôćĺ  health                                   Show project health summary\n    98Ôćĺ  run --workflow <name> [--prompt \"...\"] [--title \"...\"] [--keep-container]\n    99Ôćĺ                                             Launch a workflow run\n   100Ôćĺ  status <run-id>                            Check run status\n   101Ôćĺ  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n   102Ôćĺ                                             Show logs for a run\n   103Ôćĺ  poll <run-id>                              Wait for a run to finish\n   104Ôćĺ  list [--all]                                List runs (last hour by default)\n   105Ôćĺ  stop <run-id>                              Stop a running workflow\n   106Ôćĺ  delete <container-or-run-id>               Delete a retained container\n   107Ôćĺ  tasks [--project <dir>]                     Show task pipeline and assignment state\n   108Ôćĺ  loop [--max <n>]                            Start orchestration loop (default max=1)\n   109Ôćĺ  loop stop                                  Stop orchestration loop\n   110Ôćĺ  get <key>                                  Get a value from the run context store\n   111Ôćĺ  set <key> <value>                          Set a value in the run context store\n   112Ôćĺ  shutdown                                   Shut down the daemon\n   113Ôćĺ`)\n   114Ôćĺ}\n   115Ôćĺ\n   116Ôćĺfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   117Ôćĺ\tvar workflow, prompt, title string\n   118Ôćĺ\tvar keepContainer bool\n   119Ôćĺ\n   120Ôćĺ\tfor i := 0; i < len(args); i++ {\n   121Ôćĺ\t\tswitch args[i] {\n   122Ôćĺ\t\tcase \"--workflow\":\n   123Ôćĺ\t\t\tif i+1 < len(args) {\n   124Ôćĺ\t\t\t\ti++\n   125Ôćĺ\t\t\t\tworkflow = args[i]\n   126Ôćĺ\t\t\t}\n   127Ôćĺ\t\tcase \"--prompt\", \"-p\":\n   128Ôćĺ\t\t\tif i+1 < len(args) {\n   129Ôćĺ\t\t\t\ti++\n   130Ôćĺ\t\t\t\tprompt = args[i]\n   131Ôćĺ\t\t\t}\n   132Ôćĺ\t\tcase \"--title\":\n   133Ôćĺ\t\t\tif i+1 < len(args) {\n   134Ôćĺ\t\t\t\ti++\n   135Ôćĺ\t\t\t\ttitle = args[i]\n   136Ôćĺ\t\t\t}\n   137Ôćĺ\t\tcase \"--keep-container\":\n   138Ôćĺ\t\t\tkeepContainer = true\n   139Ôćĺ\t\tdefault:\n   140Ôćĺ\t\t\t// Support bare positional arg as workflow name for backwards compat\n   141Ôćĺ\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   142Ôćĺ\t\t\t\tworkflow = args[i]\n   143Ôćĺ\t\t\t}\n   144Ôćĺ\t\t}\n   145Ôćĺ\t}\n   146Ôćĺ\n   147Ôćĺ\tif workflow == \"\" {\n   148Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   149Ôćĺ\t\tos.Exit(1)\n   150Ôćĺ\t}\n   151Ôćĺ\n   152Ôćĺ\tcwd, _ := os.Getwd()\n   153Ôćĺ\n   154Ôćĺ\t// Resolve image from workflow file (soft failure ÔÇö fall back to daemon default)\n   155Ôćĺ\tvar image string\n   156Ôćĺ\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   157Ôćĺ\tif data, err := os.ReadFile(wfPath); err == nil {\n   158Ôćĺ\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   159Ôćĺ\t\t\timage = wf.Config[\"container.image\"]\n   160Ôćĺ\t\t}\n   161Ôćĺ\t}\n   162Ôćĺ\n   163Ôćĺ\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   164Ôćĺ\t\tWorkflowName:  workflow,\n   165Ôćĺ\t\tProjectDir:    cwd,\n   166Ôćĺ\t\tImage:         image,\n   167Ôćĺ\t\tPrompt:        prompt,\n   168Ôćĺ\t\tKeepContainer: keepContainer,\n   169Ôćĺ\t\tTitle:         title,\n   170Ôćĺ\t})\n   171Ôćĺ\tif err != nil {\n   172Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   173Ôćĺ\t\tos.Exit(1)\n   174Ôćĺ\t}\n   175Ôćĺ\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   176Ôćĺ}\n   177Ôćĺ\n   178Ôćĺfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   179Ôćĺ\tif len(args) < 1 {\n   180Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   181Ôćĺ\t\tos.Exit(1)\n   182Ôćĺ\t}\n   183Ôćĺ\n   184Ôćĺ\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   185Ôćĺ\tif err != nil {\n   186Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   187Ôćĺ\t\tos.Exit(1)\n   188Ôćĺ\t}\n   189Ôćĺ\n   190Ôćĺ\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   191Ôćĺ\tif resp.Title != \"\" {\n   192Ôćĺ\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   193Ôćĺ\t}\n   194Ôćĺ\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   195Ôćĺ\tif resp.IsHost {\n   196Ôćĺ\t\tfmt.Printf(\"Type:      host\\n\")\n   197Ôćĺ\t} else {\n   198Ôćĺ\t\tfmt.Printf(\"Type:      container\\n\")\n   199Ôćĺ\t}\n   200Ôćĺ\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   201Ôćĺ\tif resp.ContainerId != \"\" {\n   202Ôćĺ\t\tcid := resp.ContainerId\n   203Ôćĺ\t\tif len(cid) > 12 {\n   204Ôćĺ\t\t\tcid = cid[:12]\n   205Ôćĺ\t\t}\n   206Ôćĺ\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   207Ôćĺ\t}\n   208Ôćĺ\tif resp.ErrorMessage != \"\" {\n   209Ôćĺ\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   210Ôćĺ\t}\n   211Ôćĺ\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   212Ôćĺ\tfor _, exec := range resp.StepExecutions {\n   213Ôćĺ\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   214Ôćĺ\t}\n   215Ôćĺ}\n   216Ôćĺ\n   217Ôćĺfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   218Ôćĺ\tvar all bool\n   219Ôćĺ\tfor _, arg := range args {\n   220Ôćĺ\t\tif arg == \"--all\" {\n   221Ôćĺ\t\t\tall = true\n   222Ôćĺ\t\t}\n   223Ôćĺ\t}\n   224Ôćĺ\n   225Ôćĺ\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n   226Ôćĺ\tif err != nil {\n   227Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   228Ôćĺ\t\tos.Exit(1)\n   229Ôćĺ\t}\n   230Ôćĺ\n   231Ôćĺ\tif len(resp.Runs) == 0 {\n   232Ôćĺ\t\tfmt.Println(\"No runs found.\")\n   233Ôćĺ\t\treturn\n   234Ôćĺ\t}\n   235Ôćĺ\n   236Ôćĺ\tfor _, run := range resp.Runs {\n   237Ôćĺ\t\trunType := \"container\"\n   238Ôćĺ\t\tif run.IsHost {\n   239Ôćĺ\t\t\trunType = \"host\"\n   240Ôćĺ\t\t}\n   241Ôćĺ\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   242Ôćĺ\t\tif run.Title != \"\" {\n   243Ôćĺ\t\t\tt := run.Title\n   244Ôćĺ\t\t\tif len(t) > 40 {\n   245Ôćĺ\t\t\t\tt = t[:37] + \"...\"\n   246Ôćĺ\t\t\t}\n   247Ôćĺ\t\t\tline += \"  \" + t\n   248Ôćĺ\t\t}\n   249Ôćĺ\t\tif run.ContainerId != \"\" {\n   250Ôćĺ\t\t\tline += \"  \" + run.ContainerId\n   251Ôćĺ\t\t}\n   252Ôćĺ\t\tif run.ErrorMessage != \"\" {\n   253Ôćĺ\t\t\terrMsg := run.ErrorMessage\n   254Ôćĺ\t\t\tif len(errMsg) > 60 {\n   255Ôćĺ\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   256Ôćĺ\t\t\t}\n   257Ôćĺ\t\t\tline += \"  \" + errMsg\n   258Ôćĺ\t\t}\n   259Ôćĺ\t\tfmt.Println(line)\n   260Ôćĺ\t}\n   261Ôćĺ}\n   262Ôćĺ\n   263Ôćĺfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n   264Ôćĺ\tif len(args) < 1 {\n   265Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n   266Ôćĺ\t\tos.Exit(1)\n   267Ôćĺ\t}\n   268Ôćĺ\n   269Ôćĺ\tvar stepFilter, typeFilter string\n   270Ôćĺ\tvar follow bool\n   271Ôćĺ\trunID := args[0]\n   272Ôćĺ\n   273Ôćĺ\tfor i := 1; i < len(args); i++ {\n   274Ôćĺ\t\tswitch args[i] {\n   275Ôćĺ\t\tcase \"--step\":\n   276Ôćĺ\t\t\tif i+1 < len(args) {\n   277Ôćĺ\t\t\t\ti++\n   278Ôćĺ\t\t\t\tstepFilter = args[i]\n   279Ôćĺ\t\t\t}\n   280Ôćĺ\t\tcase \"--type\":\n   281Ôćĺ\t\t\tif i+1 < len(args) {\n   282Ôćĺ\t\t\t\ti++\n   283Ôćĺ\t\t\t\ttypeFilter = args[i]\n   284Ôćĺ\t\t\t}\n   285Ôćĺ\t\tcase \"--follow\", \"-f\":\n   286Ôćĺ\t\t\tfollow = true\n   287Ôćĺ\t\t}\n   288Ôćĺ\t}\n   289Ôćĺ\n   290Ôćĺ\t// Use background context ÔÇö log output can be large and follow mode blocks.\n   291Ôćĺ\tctx := context.Background()\n   292Ôćĺ\tif follow {\n   293Ôćĺ\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n   294Ôćĺ\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   295Ôćĺ\t}\n   296Ôćĺ\n   297Ôćĺ\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   298Ôćĺ\t\tRunId:    runID,\n   299Ôćĺ\t\tStepName: stepFilter,\n   300Ôćĺ\t\tLogType:  typeFilter,\n   301Ôćĺ\t})\n   302Ôćĺ\tif err != nil {\n   303Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   304Ôćĺ\t\tos.Exit(1)\n   305Ôćĺ\t}\n   306Ôćĺ\n   307Ôćĺ\tfor {\n   308Ôćĺ\t\tentry, err := stream.Recv()\n   309Ôćĺ\t\tif err != nil {\n   310Ôćĺ\t\t\tif errors.Is(err, io.EOF) {\n   311Ôćĺ\t\t\t\tbreak\n   312Ôćĺ\t\t\t}\n   313Ôćĺ\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   314Ôćĺ\t\t\tos.Exit(1)\n   315Ôćĺ\t\t}\n   316Ôćĺ\n   317Ôćĺ\t\tswitch entry.Type {\n   318Ôćĺ\t\tcase \"step_started\":\n   319Ôćĺ\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   320Ôćĺ\t\t\tif entry.Message != \"\" {\n   321Ôćĺ\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   322Ôćĺ\t\t\t}\n   323Ôćĺ\t\tcase \"step_completed\":\n   324Ôćĺ\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   325Ôćĺ\t\t\tif entry.Message != \"\" {\n   326Ôćĺ\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   327Ôćĺ\t\t\t}\n   328Ôćĺ\t\tcase \"run_completed\":\n   329Ôćĺ\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   330Ôćĺ\t\t\tif entry.Message != \"\" {\n   331Ôćĺ\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   332Ôćĺ\t\t\t}\n   333Ôćĺ\t\tcase \"full_log\":\n   334Ôćĺ\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   335Ôćĺ\t\tcase \"log\":\n   336Ôćĺ\t\t\t// Live-streamed log line from an active run.\n   337Ôćĺ\t\t\tfmt.Println(entry.Message)\n   338Ôćĺ\t\tdefault:\n   339Ôćĺ\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   340Ôćĺ\t\t\tif entry.StepName != \"\" {\n   341Ôćĺ\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   342Ôćĺ\t\t\t}\n   343Ôćĺ\t\t\tif entry.Message != \"\" {\n   344Ôćĺ\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   345Ôćĺ\t\t\t}\n   346Ôćĺ\t\t}\n   347Ôćĺ\t}\n   348Ôćĺ}\n   349Ôćĺ\n   350Ôćĺfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   351Ôćĺ\tif len(args) < 1 {\n   352Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   353Ôćĺ\t\tos.Exit(1)\n   354Ôćĺ\t}\n   355Ôćĺ\n   356Ôćĺ\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   357Ôćĺ\tif err != nil {\n   358Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   359Ôćĺ\t\tos.Exit(1)\n   360Ôćĺ\t}\n   361Ôćĺ\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   362Ôćĺ}\n   363Ôćĺ\n   364Ôćĺfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   365Ôćĺ\tif len(args) < 1 {\n   366Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   367Ôćĺ\t\tos.Exit(1)\n   368Ôćĺ\t}\n   369Ôćĺ\n   370Ôćĺ\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   371Ôćĺ\tif err != nil {\n   372Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   373Ôćĺ\t\tos.Exit(1)\n   374Ôćĺ\t}\n   375Ôćĺ\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   376Ôćĺ}\n   377Ôćĺ\n   378Ôćĺfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   379Ôćĺ\tcwd, _ := os.Getwd()\n   380Ôćĺ\n   381Ôćĺ\t// Check for \"stop\" subcommand\n   382Ôćĺ\tif len(args) > 0 && args[0] == \"stop\" {\n   383Ôćĺ\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   384Ôćĺ\t\tif err != nil {\n   385Ôćĺ\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   386Ôćĺ\t\t\tos.Exit(1)\n   387Ôćĺ\t\t}\n   388Ôćĺ\t\tfmt.Println(\"Orchestration loop stopped.\")\n   389Ôćĺ\t\treturn\n   390Ôćĺ\t}\n   391Ôćĺ\n   392Ôćĺ\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   393Ôćĺ\tvar maxConcurrent int32\n   394Ôćĺ\tfor i := 0; i < len(args); i++ {\n   395Ôćĺ\t\tswitch args[i] {\n   396Ôćĺ\t\tcase \"--max\":\n   397Ôćĺ\t\t\tif i+1 < len(args) {\n   398Ôćĺ\t\t\t\ti++\n   399Ôćĺ\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   400Ôćĺ\t\t\t\tif n != 1 || err != nil {\n   401Ôćĺ\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   402Ôćĺ\t\t\t\t\tos.Exit(1)\n   403Ôćĺ\t\t\t\t}\n   404Ôćĺ\t\t\t}\n   405Ôćĺ\t\t}\n   406Ôćĺ\t}\n   407Ôćĺ\n   408Ôćĺ\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   409Ôćĺ\t\tProjectDir:    cwd,\n   410Ôćĺ\t\tMaxConcurrent: maxConcurrent,\n   411Ôćĺ\t})\n   412Ôćĺ\tif err != nil {\n   413Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   414Ôćĺ\t\tos.Exit(1)\n   415Ôćĺ\t}\n   416Ôćĺ\tif maxConcurrent > 0 {\n   417Ôćĺ\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   418Ôćĺ\t} else {\n   419Ôćĺ\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   420Ôćĺ\t}\n   421Ôćĺ}\n   422Ôćĺ\n   423Ôćĺfunc cmdTasks(args []string) {\n   424Ôćĺ\t// Determine HTTP address from env\n   425Ôćĺ\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   426Ôćĺ\tif httpAddr == \"\" {\n   427Ôćĺ\t\thttpAddr = \"localhost:8080\"\n   428Ôćĺ\t}\n   429Ôćĺ\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   430Ôćĺ\n   431Ôćĺ\t// Determine project label from --project flag or current directory\n   432Ôćĺ\tprojectDir := \"\"\n   433Ôćĺ\tfor i := 0; i < len(args); i++ {\n   434Ôćĺ\t\tswitch args[i] {\n   435Ôćĺ\t\tcase \"--project\":\n   436Ôćĺ\t\t\tif i+1 < len(args) {\n   437Ôćĺ\t\t\t\ti++\n   438Ôćĺ\t\t\t\tprojectDir = args[i]\n   439Ôćĺ\t\t\t}\n   440Ôćĺ\t\t}\n   441Ôćĺ\t}\n   442Ôćĺ\n   443Ôćĺ\tif projectDir == \"\" {\n   444Ôćĺ\t\tcwd, _ := os.Getwd()\n   445Ôćĺ\t\tprojectDir = filepath.Base(cwd)\n   446Ôćĺ\t}\n   447Ôćĺ\n   448Ôćĺ\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   449Ôćĺ\tresp, err := http.Get(tasksURL)\n   450Ôćĺ\tif err != nil {\n   451Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   452Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   453Ôćĺ\t\tos.Exit(1)\n   454Ôćĺ\t}\n   455Ôćĺ\tdefer resp.Body.Close()\n   456Ôćĺ\n   457Ôćĺ\tif resp.StatusCode != 200 {\n   458Ôćĺ\t\tbody, _ := io.ReadAll(resp.Body)\n   459Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   460Ôćĺ\t\tos.Exit(1)\n   461Ôćĺ\t}\n   462Ôćĺ\n   463Ôćĺ\ttype taskEntry struct {\n   464Ôćĺ\t\tID          string `json:\"id\"`\n   465Ôćĺ\t\tStatus      string `json:\"status\"`\n   466Ôćĺ\t\tTitle       string `json:\"title\"`\n   467Ôćĺ\t\tDescription string `json:\"description\"`\n   468Ôćĺ\t\tAssigned    bool   `json:\"assigned\"`\n   469Ôćĺ\t\tAssignedAt  string `json:\"assigned_at\"`\n   470Ôćĺ\t\tRunID       string `json:\"run_id\"`\n   471Ôćĺ\t}\n   472Ôćĺ\n   473Ôćĺ\tvar tasks []taskEntry\n   474Ôćĺ\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   475Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   476Ôćĺ\t\tos.Exit(1)\n   477Ôćĺ\t}\n   478Ôćĺ\n   479Ôćĺ\tif len(tasks) == 0 {\n   480Ôćĺ\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   481Ôćĺ\t\treturn\n   482Ôćĺ\t}\n   483Ôćĺ\n   484Ôćĺ\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   485Ôćĺ\tfor _, t := range tasks {\n   486Ôćĺ\t\tstatus := t.Status\n   487Ôćĺ\t\tif status == \"\" {\n   488Ôćĺ\t\t\tstatus = \"open\"\n   489Ôćĺ\t\t}\n   490Ôćĺ\t\tassigned := \"-\"\n   491Ôćĺ\t\tif t.Assigned {\n   492Ôćĺ\t\t\tassigned = \"yes\"\n   493Ôćĺ\t\t}\n   494Ôćĺ\t\trunID := \"\"\n   495Ôćĺ\t\tif t.RunID != \"\" {\n   496Ôćĺ\t\t\trunID = t.RunID\n   497Ôćĺ\t\t\tif len(runID) > 30 {\n   498Ôćĺ\t\t\t\trunID = runID[:27] + \"...\"\n   499Ôćĺ\t\t\t}\n   500Ôćĺ\t\t}\n   501Ôćĺ\t\ttitle := t.Title\n   502Ôćĺ\t\tif len(title) > 40 {\n   503Ôćĺ\t\t\ttitle = title[:37] + \"...\"\n   504Ôćĺ\t\t}\n   505Ôćĺ\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   506Ôćĺ\t}\n   507Ôćĺ}\n   508Ôćĺ\n   509Ôćĺfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   510Ôćĺ\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   511Ôćĺ\tif err != nil {\n   512Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   513Ôćĺ\t\tos.Exit(1)\n   514Ôćĺ\t}\n   515Ôćĺ\tfmt.Println(\"Daemon shutting down.\")\n   516Ôćĺ}\n   517Ôćĺ\n   518Ôćĺ// resolveRunContext returns the project directory and run ID for context\n   519Ôćĺ// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   520Ôćĺ// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   521Ôćĺfunc resolveRunContext() (projectDir, runID string, err error) {\n   522Ôćĺ\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   523Ôćĺ\tif runID == \"\" {\n   524Ôćĺ\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   525Ôćĺ\t}\n   526Ôćĺ\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   527Ôćĺ\tif projectDir == \"\" {\n   528Ôćĺ\t\tprojectDir, err = os.Getwd()\n   529Ôćĺ\t\tif err != nil {\n   530Ôćĺ\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   531Ôćĺ\t\t}\n   532Ôćĺ\t}\n   533Ôćĺ\treturn projectDir, runID, nil\n   534Ôćĺ}\n   535Ôćĺ\n   536Ôćĺfunc cmdGet(args []string) {\n   537Ôćĺ\tif len(args) < 1 {\n   538Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   539Ôćĺ\t\tos.Exit(1)\n   540Ôćĺ\t}\n   541Ôćĺ\n   542Ôćĺ\tprojectDir, runID, err := resolveRunContext()\n   543Ôćĺ\tif err != nil {\n   544Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   545Ôćĺ\t\tos.Exit(1)\n   546Ôćĺ\t}\n   547Ôćĺ\n   548Ôćĺ\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   549Ôćĺ\tif err != nil {\n   550Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   551Ôćĺ\t\tos.Exit(1)\n   552Ôćĺ\t}\n   553Ôćĺ\tif !ok {\n   554Ôćĺ\t\tos.Exit(1)\n   555Ôćĺ\t}\n   556Ôćĺ\tfmt.Println(val)\n   557Ôćĺ}\n   558Ôćĺ\n   559Ôćĺfunc cmdSet(args []string) {\n   560Ôćĺ\tif len(args) < 2 {\n   561Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   562Ôćĺ\t\tos.Exit(1)\n   563Ôćĺ\t}\n   564Ôćĺ\n   565Ôćĺ\tprojectDir, runID, err := resolveRunContext()\n   566Ôćĺ\tif err != nil {\n   567Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   568Ôćĺ\t\tos.Exit(1)\n   569Ôćĺ\t}\n   570Ôćĺ\n   571Ôćĺ\tif err := runcontext.Set(projectDir, runID, args[0], args[1]); err != nil {\n   572Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   573Ôćĺ\t\tos.Exit(1)\n   574Ôćĺ\t}\n   575Ôćĺ}\n   576Ôćĺ"}]},"parent_tool_use_id":"toolu_01Kwo4Gqf8Kyz3LgA9JjACuj","session_id":"caefa047-41e4-4a64-a92e-dbea2379cd5a","uuid":"ffd83225-f7b5-4a9d-a404-a0c7ca7ffc87"}
