70/30 split.\n\tif rand.Float64() < 0.7 {\n\t\tpicked := front[rand.Intn(len(front))]\n\t\treturn &picked\n\t}\n\tpicked := nonFront[rand.Intn(len(nonFront))]\n\treturn &picked\n}\n","numLines":62,"startLine":1,"totalLines":62}}}
