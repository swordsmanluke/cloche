[2026-03-17T14:15:44Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QryG5t9muVGRmaHgpjgacd","type":"tool_result","content":"     1→package config\n     2→\n     3→import (\n     4→\t\"os\"\n     5→\t\"path/filepath\"\n     6→\t\"testing\"\n     7→\n     8→\t\"github.com/stretchr/testify/assert\"\n     9→\t\"github.com/stretchr/testify/require\"\n    10→)\n    11→\n    12→func TestLoadEvolutionConfig(t *testing.T) {\n    13→\tdir := t.TempDir()\n    14→\tclocheDir := filepath.Join(dir, \".cloche\")\n    15→\tos.MkdirAll(clocheDir, 0755)\n    16→\n    17→\tos.WriteFile(filepath.Join(clocheDir, \"config.toml\"), []byte(`\n    18→[evolution]\n    19→enabled = true\n    20→debounce_seconds = 45\n    21→min_confidence = \"high\"\n    22→max_prompt_bullets = 30\n    23→`), 0644)\n    24→\n    25→\tcfg, err := Load(dir)\n    26→\trequire.NoError(t, err)\n    27→\tassert.True(t, cfg.Evolution.Enabled)\n    28→\tassert.Equal(t, 45, cfg.Evolution.DebounceSeconds)\n    29→\tassert.Equal(t, \"high\", cfg.Evolution.MinConfidence)\n    30→\tassert.Equal(t, 30, cfg.Evolution.MaxPromptBullets)\n    31→}\n    32→\n    33→func TestLoadEvolutionConfigDefaults(t *testing.T) {\n    34→\tdir := t.TempDir()\n    35→\n    36→\tcfg, err := Load(dir)\n    37→\trequire.NoError(t, err)\n    38→\tassert.True(t, cfg.Evolution.Enabled)\n    39→\tassert.Equal(t, 30, cfg.Evolution.DebounceSeconds)\n    40→\tassert.Equal(t, \"medium\", cfg.Evolution.MinConfidence)\n    41→\tassert.Equal(t, 50, cfg.Evolution.MaxPromptBullets)\n    42→}\n    43→\n    44→func TestLoadDaemonConfig(t *testing.T) {\n    45→\tdir := t.TempDir()\n    46→\tclocheDir := filepath.Join(dir, \".cloche\")\n    47→\tos.MkdirAll(clocheDir, 0755)\n    48→\n    49→\tos.WriteFile(filepath.Join(clocheDir, \"config.toml\"), []byte(`\n    50→[daemon]\n    51→listen = \"localhost:9090\"\n    52→http = \"localhost:8080\"\n    53→image = \"my-agent:v2\"\n    54→db = \"/var/lib/cloche/data.db\"\n    55→runtime = \"local\"\n    56→agent_path = \"/usr/local/bin/cloche-agent\"\n    57→llm_command = \"claude\"\n    58→`), 0644)\n    59→\n    60→\tcfg, err := Load(dir)\n    61→\trequire.NoError(t, err)\n    62→\tassert.Equal(t, \"localhost:9090\", cfg.Daemon.Listen)\n    63→\tassert.Equal(t, \"localhost:8080\", cfg.Daemon.HTTP)\n    64→\tassert.Equal(t, \"my-agent:v2\", cfg.Daemon.Image)\n    65→\tassert.Equal(t, \"/var/lib/cloche/data.db\", cfg.Daemon.DB)\n    66→\tassert.Equal(t, \"local\", cfg.Daemon.Runtime)\n    67→\tassert.Equal(t, \"/usr/local/bin/cloche-agent\", cfg.Daemon.AgentPath)\n    68→\tassert.Equal(t, \"claude\", cfg.Daemon.LLMCommand)\n    69→}\n    70→\n    71→func TestLoadDaemonConfigDefaults(t *testing.T) {\n    72→\tdir := t.TempDir()\n    73→\n    74→\tcfg, err := Load(dir)\n    75→\trequire.NoError(t, err)\n    76→\t// All daemon fields default to zero values (empty strings)\n    77→\tassert.Equal(t, \"\", cfg.Daemon.Listen)\n    78→\tassert.Equal(t, \"\", cfg.Daemon.HTTP)\n    79→\tassert.Equal(t, \"\", cfg.Daemon.Image)\n    80→\tassert.Equal(t, \"\", cfg.Daemon.DB)\n    81→\tassert.Equal(t, \"\", cfg.Daemon.Runtime)\n    82→}\n    83→\n    84→func TestLoadGlobalFrom(t *testing.T) {\n    85→\tdir := t.TempDir()\n    86→\tconfigPath := filepath.Join(dir, \"config\")\n    87→\n    88→\tos.WriteFile(configPath, []byte(`\n    89→[daemon]\n    90→http = \"0.0.0.0:3000\"\n    91→image = \"custom:latest\"\n    92→`), 0644)\n    93→\n    94→\tcfg, err := LoadGlobalFrom(configPath)\n    95→\trequire.NoError(t, err)\n    96→\tassert.Equal(t, \"0.0.0.0:3000\", cfg.Daemon.HTTP)\n    97→\tassert.Equal(t, \"custom:latest\", cfg.Daemon.Image)\n    98→\tassert.Equal(t, \"\", cfg.Daemon.Listen) // unset stays empty\n    99→}\n   100→\n   101→func TestLoadActiveFlag(t *testing.T) {\n   102→\tdir := t.TempDir()\n   103→\tclocheDir := filepath.Join(dir, \".cloche\")\n   104→\tos.MkdirAll(clocheDir, 0755)\n   105→\n   106→\tos.WriteFile(filepath.Join(clocheDir, \"confi