tion\"`\n    41→}\n    42→\n    43→func defaults() Config {\n    44→\treturn Config{\n    45→\t\tEvolution: EvolutionConfig{\n    46→\t\t\tEnabled:          true,\n    47→\t\t\tDebounceSeconds:  30,\n    48→\t\t\tMinConfidence:    \"medium\",\n    49→\t\t\tMaxPromptBullets: 50,\n    50→\t\t},\n    51→\t\tOrchestration: OrchestrationConfig{\n    52→\t\t\tConcurrency:            1,\n    53→\t\t\tStaggerSeconds:         1.0,\n    54→\t\t\tMaxConsecutiveFailures: 3,\n    55→\t\t},\n    56→\t}\n    57→}\n    58→\n    59→// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    60→func Load(projectDir string) (*Config, error) {\n    61→\tcfg := defaults()\n    62→\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    63→\n    64→\tdata, err := os.ReadFile(path)\n    65→\tif os.IsNotExist(err) {\n    66→\t\treturn &cfg, nil\n    67→\t}\n    68→\tif err != nil {\n    69→\t\treturn nil, err\n    70→\t}\n    71→\n    72→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    73→\t\treturn nil, err\n    74→\t}\n    75→\treturn &cfg, nil\n    76→}\n    77→\n    78→// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n    79→// Returns defaults if the file does not exist.\n    80→func LoadGlobal() (*Config, error) {\n    81→\tcfg := defaults()\n    82→\n    83→\thome, err := os.UserHomeDir()\n    84→\tif err != nil {\n    85→\t\treturn &cfg, nil\n    86→\t}\n    87→\n    88→\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n    89→\tdata, err := os.ReadFile(path)\n    90→\tif os.IsNotExist(err) {\n    91→\t\treturn &cfg, nil\n    92→\t}\n    93→\tif err != nil {\n    94→\t\treturn nil, err\n    95→\t}\n    96→\n    97→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    98→\t\treturn nil, err\n    99→\t}\n   100→\treturn &cfg, nil\n   101→}\n   102→\n   103→// StateDir returns the path to ~/.config/cloche/ and ensures it exists.\n   104→// Falls back to a temp directory if the home