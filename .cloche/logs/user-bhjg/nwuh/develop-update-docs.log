{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AgdE4AM7K5oCTszqk2SGPD","type":"tool_result","content":"     1→package domain_test\n     2→\n     3→import (\n     4→\t\"testing\"\n     5→\n     6→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     7→\t\"github.com/stretchr/testify/assert\"\n     8→\t\"github.com/stretchr/testify/require\"\n     9→)\n    10→\n    11→func TestWorkflow_Validate_ValidGraph(t *testing.T) {\n    12→\twf := &domain.Workflow{\n    13→\t\tName: \"test-workflow\",\n    14→\t\tSteps: map[string]*domain.Step{\n    15→\t\t\t\"code\": {\n    16→\t\t\t\tName:    \"code\",\n    17→\t\t\t\tType:    domain.StepTypeAgent,\n    18→\t\t\t\tResults: []string{\"success\", \"fail\"},\n    19→\t\t\t},\n    20→\t\t\t\"check\": {\n    21→\t\t\t\tName:    \"check\",\n    22→\t\t\t\tType:    domain.StepTypeScript,\n    23→\t\t\t\tResults: []string{\"pass\", \"fail\"},\n    24→\t\t\t},\n    25→\t\t},\n    26→\t\tWiring: []domain.Wire{\n    27→\t\t\t{From: \"code\", Result: \"success\", To: \"check\"},\n    28→\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n    29→\t\t\t{From: \"check\", Result: \"pass\", To: domain.StepDone},\n    30→\t\t\t{From: \"check\", Result: \"fail\", To: \"code\"},\n    31→\t\t},\n    32→\t\tEntryStep: \"code\",\n    33→\t}\n    34→\n    35→\terr := wf.Validate()\n    36→\tassert.NoError(t, err)\n    37→}\n    38→\n    39→func TestWorkflow_Validate_UnwiredResult(t *testing.T) {\n    40→\twf := &domain.Workflow{\n    41→\t\tName: \"test-workflow\",\n    42→\t\tSteps: map[string]*domain.Step{\n    43→\t\t\t\"code\": {\n    44→\t\t\t\tName:    \"code\",\n    45→\t\t\t\tType:    domain.StepTypeAgent,\n    46→\t\t\t\tResults: []string{\"success\", \"fail\"},\n    47→\t\t\t},\n    48→\t\t},\n    49→\t\tWiring: []domain.Wire{\n    50→\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n    51→\t\t},\n    52→\t\tEntryStep: \"code\",\n    53→\t}\n    54→\n    55→\terr := wf.Validate()\n    56→\trequire.Error(t, err)\n    57→\tassert.Contains(t, err.Error(), \"fail\")\n    58→}\n    59→\n    60→func TestWorkflow_Validate_OrphanStep(t *testing.T) {\n    61→\twf := &domain.Workflow{\n    62→\t\tName: \"test-workflow\",\n    63→\t\tSteps: map[string]*domain.Step{\n    64→\t\t\t\"code\": {\n    65→\t\t\t\tName:    \"code\",\n    66→\t\t\t\tType:    domain.StepTypeAgent,\n    67→\t\t\t\tResults: []string{\"success\"},\n    68→\t\t\t},\n    69→\t\t\t\"orphan\": {\n    70→\t\t\t\tName:    \"orphan\",\n    71→\t\t\t\tType:    domain.StepTypeScript,\n    72→\t\t\t\tResults: []string{\"done\"},\n    73→\t\t\t},\n    74→\t\t},\n    75→\t\tWiring: []domain.Wire{\n    76→\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n    77→\t\t\t{From: \"orphan\", Result: \"done\", To: domain.StepDone},\n    78→\t\t},\n    79→\t\tEntryStep: \"code\",\n    80→\t}\n    81→\n    82→\terr := wf.Validate()\n    83→\trequire.Error(t, err)\n    84→\tassert.Contains(t, err.Error(), \"orphan\")\n    85→}\n    86→\n    87→func TestWorkflow_Validate_NoEntryStep(t *testing.T) {\n    88→\twf := &domain.Workflow{\n    89→\t\tName:      \"test-workflow\",\n    90→\t\tSteps:     map[string]*domain.Step{},\n    91→\t\tWiring:    []domain.Wire{},\n    92→\t\tEntryStep: \"\",\n    93→\t}\n    94→\n    95→\terr := wf.Validate()\n    96→\trequire.Error(t, err)\n    97→\tassert.Contains(t, err.Error(), \"entry\")\n    98→}\n    99→\n   100→func TestWorkflow_NextSteps(t *testing.T) {\n   101→\twf := &domain.Workflow{\n   102→\t\tName: \"test-workflow\",\n   103→\t\tSteps: map[string]*domain.Step{\n   104→\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   105→\t\t\t\"check\": {Name: \"check\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n   106→\t\t},\n   107→\t\tWiring: []domain.Wire{\n   108→\t\t\t{From: \"code\", Result: \"success\", To: \"check\"},\n   109→\t\t\t{From: \"check\", Result: \"pass\", To: domain.StepDone},\n   110→\t\t},\n   111→\t\tEntryStep: \"code\",\n   112→\t}\n   113→\n   114→\tnext, err := wf.NextSteps(\"code\", \"success\")\n   115→\trequire.NoError(t, err)\n   116→\tassert.Equal(t, []string{\"check\"}, next)\n   117→\n   118→\tnext, err = wf.NextSteps(\"check\", \"pass\")\n   119→\trequire.NoError(t, err)\n   120→\tassert.Equal(t, []string{domain.StepDone}, next)\n   121→\n   122→\tnext, err = wf.NextSteps(\"code\", \"nonexistent\")\n   123→\tassert.Error(t, err)\n   124→\tassert.Nil(t, next)\n   125→}\n   126→\n   127→func TestWorkflow_NextSteps_Fanout(t *testing.T) {\n   128→\twf := &domain.Workflow{\n   129→\t\tName: \"fanout\",\n   130→\t\tSteps: map[string]*domain.Step{\n   131→\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   132→\t\t\t\"test\": {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n   133→\t\t\t\"lint\": {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n   134→\t\t},\n   135→\t\tWiring: []domain.Wire{\n   136→\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n   137→\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n   138→\t\t\t{From: \"test\", Result: \"pass\", To: domain.StepDone},\n   139→\t\t\t{From: \"lint\", Result: \"pass\", To: domain.StepDone},\n   140→\t\t},\n   141→\t\tEntryStep: \"code\",\n   142→\t}\n   143→\n   144→\tnext, err := wf.NextSteps(\"code\", \"success\")\n   145→\trequire.NoError(t, err)\n   146→\tassert.Equal(t, []string{\"test\", \"lint\"}, next)\n   147→}\n   148→\n   149→func TestWorkflow_Validate_CollectValid(t *testing.T) {\n   150→\twf := &domain.Workflow{\n   151→\t\tName: \"parallel\",\n   152→\t\tSteps: map[string]*domain.Step{\n   153→\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   154→\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n   155→\t\t\t\"lint\":  {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n   156→\t\t\t\"merge\": {Name: \"merge\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   157→\t\t},\n   158→\t\tWiring: []domain.Wire{\n   159→\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n   160→\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n   161→\t\t\t{From: \"test\", Result: \"fail\", To: domain.StepAbort},\n   162→\t\t\t{From: \"lint\", Result: \"fail\", To: domain.StepAbort},\n   163→\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n   164→\t\t},\n   165→\t\tCollects: []domain.Collect{\n   166→\t\t\t{\n   167→\t\t\t\tMode: domain.CollectAll,\n   168→\t\t\t\tConditions: []domain.WireCondition{\n   169→\t\t\t\t\t{Step: \"test\", Result: \"success\"},\n   170→\t\t\t\t\t{Step: \"lint\", Result: \"success\"},\n   171→\t\t\t\t},\n   172→\t\t\t\tTo: \"merge\",\n   173→\t\t\t},\n   174→\t\t},\n   175→\t\tEntryStep: \"code\",\n   176→\t}\n   177→\n   178→\terr := wf.Validate()\n   179→\tassert.NoError(t, err)\n   180→}\n   181→\n   182→func TestWorkflow_Validate_CollectBadStep(t *testing.T) {\n   183→\twf := &domain.Workflow{\n   184→\t\tName: \"bad-collect\",\n   185→\t\tSteps: map[string]*domain.Step{\n   186→\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   187→\t\t},\n   188→\t\tWiring: []domain.Wire{\n   189→\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n   190→\t\t},\n   191→\t\tCollects: []domain.Collect{\n   192→\t\t\t{\n   193→\t\t\t\tMode:       domain.CollectAll,\n   194→\t\t\t\tConditions: []domain.WireCondition{{Step: \"nonexistent\", Result: \"success\"}},\n   195→\t\t\t\tTo:         \"code\",\n   196→\t\t\t},\n   197→\t\t},\n   198→\t\tEntryStep: \"code\",\n   199→\t}\n   200→\n   201→\terr := wf.Validate()\n   202→\trequire.Error(t, err)\n   203→\tassert.Contains(t, err.Error(), \"nonexistent\")\n   204→}\n   205→\n   206→func TestWorkflow_Validate_CollectBadTarget(t *testing.T) {\n   207→\twf := &domain.Workflow{\n   208→\t\tName: \"bad-target\",\n   209→\t\tSteps: map[string]*domain.Step{\n   210→\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   211→\t\t},\n   212→\t\tWiring: []domain.Wire{\n   213→\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n   214→\t\t},\n   215→\t\tCollects: []domain.Collect{\n   216→\t\t\t{\n   217→\t\t\t\tMode:       domain.CollectAll,\n   218→\t\t\t\tConditions: []domain.WireCondition{{Step: \"code\", Result: \"success\"}},\n   219→\t\t\t\tTo:         \"nonexistent\",\n   220→\t\t\t},\n   221→\t\t},\n   222→\t\tEntryStep: \"code\",\n   223→\t}\n   224→\n   225→\terr := wf.Validate()\n   226→\trequire.Error(t, err)\n   227→\tassert.Contains(t, err.Error(), \"nonexistent\")\n   228→}\n   229→\n   230→func TestWorkflow_ValidateConfig_KnownKeys(t *testing.T) {\n   231→\twf := &domain.Workflow{\n   232→\t\tName: \"known-keys\",\n   233→\t\tSteps: map[string]*domain.Step{\n   234→\t\t\t\"code\": {\n   235→\t\t\t\tName:    \"code\",\n   236→\t\t\t\tResults: []string{\"success\"},\n   237→\t\t\t\tConfig: map[string]string{\n   238→\t\t\t\t\t\"prompt\":       \"do stuff\",\n   239→\t\t\t\t\t\"timeout\":      \"30m\",\n   240→\t\t\t\t\t\"max_attempts\": \"3\",\n   241→\t\t\t\t},\n   242→\t\t\t},\n   243→\t\t},\n   244→\t}\n   245→\twarnings := wf.ValidateConfig()\n   246→\tassert.Empty(t, warnings)\n   247→}\n   248→\n   249→func TestWorkflow_ValidateConfig_UnknownKey(t *testing.T) {\n   250→\twf := &domain.Workflow{\n   251→\t\tName: \"unknown-key\",\n   252→\t\tSteps: map[string]*domain.Step{\n   253→\t\t\t\"code\": {\n   254→\t\t\t\tName:    \"code\",\n   255→\t\t\t\tResults: []string{\"success\"},\n   256→\t\t\t\tConfig: map[string]string{\n   257→\t\t\t\t\t\"prompt\":  \"do stuff\",\n   258→\t\t\t\t\t\"tiemout\": \"30m\", // typo\n   259→\t\t\t\t},\n   260→\t\t\t},\n   261→\t\t},\n   262→\t}\n   263→\twarnings := wf.ValidateConfig()\n   264→\trequire.Len(t, warnings, 1)\n   265→\tassert.Contains(t, warnings[0], \"tiemout\")\n   266→\tassert.Contains(t, warnings[0], \"unrecognized\")\n   267→}\n   268→\n   269→func TestWorkflow_ValidateLocation_ContainerRejectsWorkflowStep(t *testing.T) {\n   270→\twf := &domain.Workflow{\n   271→\t\tName:     \"develop\",\n   272→\t\tLocation: domain.LocationContainer,\n   273→\t\tSteps: map[string]*domain.Step{\n   274→\t\t\t\"dispatch\": {\n   275→\t\t\t\tName:    \"dispatch\",\n   276→\t\t\t\tType:    domain.StepTypeWorkflow,\n   277→\t\t\t\tResults: []string{\"success\"},\n   278→\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"implement\"},\n   279→\t\t\t},\n   280→\t\t},\n   281→\t\tEntryStep: \"dispatch\",\n   282→\t}\n   283→\terr := wf.ValidateLocation()\n   284→\trequire.Error(t, err)\n   285→\tassert.Contains(t, err.Error(), \"workflow_name\")\n   286→\tassert.Contains(t, err.Error(), \"host workflows\")\n   287→}\n   288→\n   289→func TestWorkflow_ValidateLocation_HostAllowsWorkflowStep(t *testing.T) {\n   290→\twf := &domain.Workflow{\n   291→\t\tName:     \"main\",\n   292→\t\tLocation: domain.LocationHost,\n   293→\t\tSteps: map[string]*domain.Step{\n   294→\t\t\t\"develop\": {\n   295→\t\t\t\tName:    \"develop\",\n   296→\t\t\t\tType:    domain.StepTypeWorkflow,\n   297→\t\t\t\tResults: []string{\"success\"},\n   298→\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   299→\t\t\t},\n   300→\t\t},\n   301→\t\tEntryStep: \"develop\",\n   302→\t}\n   303→\terr := wf.ValidateLocation()\n   304→\tassert.NoError(t, err)\n   305→}\n   306→\n   307→func TestWorkflow_ValidateLocation_ContainerAllowsAgentAndScript(t *testing.T) {\n   308→\twf := &domain.Workflow{\n   309→\t\tName:     \"develop\",\n   310→\t\tLocation: domain.LocationContainer,\n   311→\t\tSteps: map[string]*domain.Step{\n   312→\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   313→\t\t\t\"check\": {Name: \"check\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n   314→\t\t},\n   315→\t\tEntryStep: \"code\",\n   316→\t}\n   317→\terr := wf.ValidateLocation()\n   318→\tassert.NoError(t, err)\n   319→}\n   320→\n   321→func TestWorkflow_ValidateLocation_EmptyLocationNoEnforcement(t *testing.T) {\n   322→\twf := &domain.Workflow{\n   323→\t\tName: \"any\",\n   324→\t\tSteps: map[string]*domain.Step{\n   325→\t\t\t\"dispatch\": {\n   326→\t\t\t\tName:    \"dispatch\",\n   327→\t\t\t\tType:    domain.StepTypeWorkflow,\n   328→\t\t\t\tResults: []string{\"success\"},\n   329→\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   330→\t\t\t},\n   331→\t\t},\n   332→\t\tEntryStep: \"dispatch\",\n   333→\t}\n   334→\t// No Location set — should not enforce\n   335→\terr := wf.ValidateLocation()\n   336→\tassert.NoError(t, err)\n   337→}\n   338→\n   339→func TestWorkflow_Validate_DuplicateOutputMapping_DifferentKeys(t *testing.T) {\n   340→\twf := &domain.Workflow{\n   341→\t\tName: \"test\",\n   342→\t\tSteps: map[string]*domain.Step{\n   343→\t\t\t\"src\": {Name: \"src\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n   344→\t\t\t\"a\":   {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n   345→\t\t\t\"b\":   {Name: \"b\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n   346→\t\t\t\"c\":   {Name: \"c\", Type: domain.StepTypeAgent, Results: []string{\"done\"}},\n   347→\t\t},\n   348→\t\tWiring: []domain.Wire{\n   349→\t\t\t{From: \"src\", Result: \"ok\", To: \"a\"},\n   350→\t\t\t{From: \"src\", Result: \"ok\", To: \"b\"},\n   351→\t\t\t{From: \"a\", Result: \"ok\", To: \"c\", OutputMap: []domain.OutputMapping{\n   352→\t\t\t\t{EnvVar: \"FOO\", Path: domain.OutputPath{}},\n   353→\t\t\t}},\n   354→\t\t\t{From: \"b\", Result: \"ok\", To: \"c\", OutputMap: []domain.OutputMapping{\n   355→\t\t\t\t{EnvVar: \"BAR\", Path: domain.OutputPath{}},\n   356→\t\t\t}},\n   357→\t\t\t{From: \"c\", Result: \"done\", To: domain.StepDone},\n   358→\t\t},\n   359→\t\tEntryStep: \"src\",\n   360→\t\tCollects: []domain.Collect{\n   361→\t\t\t{\n   362→\t\t\t\tMode:       domain.CollectAll,\n   363→\t\t\t\tConditions: []domain.WireCondition{{Step: \"a\", Result: \"ok\"}, {Step: \"b\", Result: \"ok\"}},\n   364→\t\t\t\tTo:         \"c\",\n   365→\t\t\t},\n   366→\t\t},\n   367→\t}\n   368→\terr := wf.Validate()\n   369→\tassert.NoError(t, err, \"different env var keys on wires to same step should be valid\")\n   370→}\n   371→\n   372→func TestWorkflow_Validate_DuplicateOutputMapping_SameKey(t *testing.T) {\n   373→\twf := &domain.Workflow{\n   374→\t\tName: \"test\",\n   375→\t\tSteps: map[string]*domain.Step{\n   376→\t\t\t\"src\": {Name: \"src\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n   377→\t\t\t\"a\":   {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n   378→\t\t\t\"b\":   {Name: \"b\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n   379→\t\t\t\"c\":   {Name: \"c\", Type: domain.StepTypeAgent, Results: []string{\"done\"}},\n   380→\t\t},\n   381→\t\tWiring: []domain.Wire{\n   382→\t\t\t{From: \"src\", Result: \"ok\", To: \"a\"},\n   383→\t\t\t{From: \"src\", Result: \"ok\", To: \"b\"},\n   384→\t\t\t{From: \"a\", Result: \"ok\", To: \"c\", OutputMap: []domain.OutputMapping{\n   385→\t\t\t\t{EnvVar: \"FOO\", Path: domain.OutputPath{}},\n   386→\t\t\t}},\n   387→\t\t\t{From: \"b\", Result: \"ok\", To: \"c\", OutputMap: []domain.OutputMapping{\n   388→\t\t\t\t{EnvVar: \"FOO\", Path: domain.OutputPath{}},\n   389→\t\t\t}},\n   390→\t\t\t{From: \"c\", Result: \"done\", To: domain.StepDone},\n   391→\t\t},\n   392→\t\tEntryStep: \"src\",\n   393→\t\tCollects: []domain.Collect{\n   394→\t\t\t{\n   395→\t\t\t\tMode:       domain.CollectAll,\n   396→\t\t\t\tConditions: []domain.WireCondition{{Step: \"a\", Result: \"ok\"}, {Step: \"b\", Result: \"ok\"}},\n   397→\t\t\t\tTo:         \"c\",\n   398→\t\t\t},\n   399→\t\t},\n   400→\t}\n   401→\terr := wf.Validate()\n   402→\trequire.Error(t, err)\n   403→\tassert.Contains(t, err.Error(), \"duplicate output mapping\")\n   404→\tassert.Contains(t, err.Error(), \"FOO\")\n   405→\tassert.Contains(t, err.Error(), \"c\")\n   406→}\n   407→\n   408→func TestWorkflow_Validate_DuplicateOutputMapping_SameKeyDifferentSteps(t *testing.T) {\n   409→\twf := &domain.Workflow{\n   410→\t\tName: \"test\",\n   411→\t\tSteps: map[string]*domain.Step{\n   412→\t\t\t\"a\": {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n   413→\t\t\t\"b\": {Name: \"b\", Type: domain.StepTypeAgent, Results: []string{\"done\"}},\n   414→\t\t\t\"c\": {Name: \"c\", Type: domain.StepTypeAgent, Results: []string{\"done\"}},\n   415→\t\t},\n   416→\t\tWiring: []domain.Wire{\n   417→\t\t\t{From: \"a\", Result: \"ok\", To: \"b\", OutputMap: []domain.OutputMapping{\n   418→\t\t\t\t{EnvVar: \"FOO\", Path: domain.OutputPath{}},\n   419→\t\t\t}},\n   420→\t\t\t{From: \"a\", Result: \"ok\", To: \"c\", OutputMap: []domain.OutputMapping{\n   421→\t\t\t\t{EnvVar: \"FOO\", Path: domain.OutputPath{}},\n   422→\t\t\t}},\n   423→\t\t\t{From: \"b\", Result: \"done\", To: domain.StepDone},\n   424→\t\t\t{From: \"c\", Result: \"done\", To: domain.StepDone},\n   425→\t\t},\n   426→\t\tEntryStep: \"a\",\n   427→\t}\n   428→\terr := wf.Validate()\n   429→\tassert.NoError(t, err, \"same env var key on wires to different steps should be valid\")\n   430→}\n   431→\n   432→func TestWorkflow_Validate_DuplicateOutputMapping_NoMappings(t *testing.T) {\n   433→\twf := &domain.Workflow{\n   434→\t\tName: \"test\",\n   435→\t\tSteps: map[string]*domain.Step{\n   436→\t\t\t\"a\": {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n   437→\t\t\t\"b\": {Name: \"b\", Type: domain.StepTypeAgent, Results: []string{\"done\"}},\n   438→\t\t},\n   439→\t\tWiring: []domain.Wire{\n   440→\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n   441→\t\t\t{From: \"b\", Result: \"done\", To: domain.StepDone},\n   442→\t\t},\n   443→\t\tEntryStep: \"a\",\n   444→\t}\n   445→\terr := wf.Validate()\n   446→\tassert.NoError(t, err, \"wires with no output mappings should be valid\")\n   447→}\n   448→\n   449→func TestWorkflow_ValidateConfig_ContainerPrefix(t *testing.T) {\n   450→\twf := &domain.Workflow{\n   451→\t\tName: \"container-keys\",\n   452→\t\tSteps: map[string]*domain.Step{\n   453→\t\t\t\"code\": {\n   454→\t\t\t\tName:    \"code\",\n   455→\t\t\t\tResults: []string{\"success\"},\n   456→\t\t\t\tConfig: map[string]string{\n   457→\t\t\t\t\t\"prompt\":           \"do stuff\",\n   458→\t\t\t\t\t\"container.image\":  \"myimage:v1\",\n   459→\t\t\t\t\t\"container.memory\": \"4g\",\n   460→\t\t\t\t},\n   461→\t\t\t},\n   462→\t\t},\n   463→\t}\n   464→\twarnings := wf.ValidateConfig()\n   465→\tassert.Empty(t, warnings)\n   466→}\n   467→"}]},"parent_tool_use_id":null,"session_id":"b5cb00e3-b191-4d07-96b7-3f5680038ecb","uuid":"6a1a7e43-284b-49d3-9b7c-68a819c06228","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/domain/workflow_test.go","content":"package domain_test\n\nimport (\n\t\"testing\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestWorkflow_Validate_ValidGraph(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"test-workflow\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\": {\n\t\t\t\tName:    \"code\",\n\t\t\t\tType:    domain.StepTypeAgent,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t},\n\t\t\t\"check\": {\n\t\t\t\tName:    \"check\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"pass\", \"fail\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: \"check\"},\n\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"check\", Result: \"pass\", To: domain.StepDone},\n\t\t\t{From: \"check\", Result: \"fail\", To: \"code\"},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\terr := wf.Validate()\n\tassert.NoError(t, err)\n}\n\nfunc TestWorkflow_Validate_UnwiredResult(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"test-workflow\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\": {\n\t\t\t\tName:    \"code\",\n\t\t\t\tType:    domain.StepTypeAgent,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\terr := wf.Validate()\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"fail\")\n}\n\nfunc TestWorkflow_Validate_OrphanStep(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"test-workflow\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\": {\n\t\t\t\tName:    \"code\",\n\t\t\t\tType:    domain.StepTypeAgent,\n\t\t\t\tResults: []string{\"success\"},\n\t\t\t},\n\t\t\t\"orphan\": {\n\t\t\t\tName:    \"orphan\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"done\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"orphan\", Result: \"done\", To: domain.StepDone},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\terr := wf.Validate()\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"orphan\")\n}\n\nfunc TestWorkflow_Validate_NoEntryStep(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"test-workflow\",\n\t\tSteps:     map[string]*domain.Step{},\n\t\tWiring:    []domain.Wire{},\n\t\tEntryStep: \"\",\n\t}\n\n\terr := wf.Validate()\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"entry\")\n}\n\nfunc TestWorkflow_NextSteps(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"test-workflow\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n\t\t\t\"check\": {Name: \"check\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: \"check\"},\n\t\t\t{From: \"check\", Result: \"pass\", To: domain.StepDone},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\tnext, err := wf.NextSteps(\"code\", \"success\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, []string{\"check\"}, next)\n\n\tnext, err = wf.NextSteps(\"check\", \"pass\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, []string{domain.StepDone}, next)\n\n\tnext, err = wf.NextSteps(\"code\", \"nonexistent\")\n\tassert.Error(t, err)\n\tassert.Nil(t, next)\n}\n\nfunc TestWorkflow_NextSteps_Fanout(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"fanout\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n\t\t\t\"test\": {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n\t\t\t\"lint\": {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n\t\t\t{From: \"test\", Result: \"pass\", To: domain.StepDone},\n\t\t\t{From: \"lint\", Result: \"pass\", To: domain.StepDone},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\tnext, err := wf.NextSteps(\"code\", \"success\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, []string{\"test\", \"lint\"}, next)\n}\n\nfunc TestWorkflow_Validate_CollectValid(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"parallel\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n\t\t\t\"lint\":  {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n\t\t\t\"merge\": {Name: \"merge\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n\t\t\t{From: \"test\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"lint\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n\t\t},\n\t\tCollects: []domain.Collect{\n\t\t\t{\n\t\t\t\tMode: domain.CollectAll,\n\t\t\t\tConditions: []domain.WireCondition{\n\t\t\t\t\t{Step: \"test\", Result: \"success\"},\n\t\t\t\t\t{Step: \"lint\", Result: \"success\"},\n\t\t\t\t},\n\t\t\t\tTo: \"merge\",\n\t\t\t},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\terr := wf.Validate()\n\tassert.NoError(t, err)\n}\n\nfunc TestWorkflow_Validate_CollectBadStep(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"bad-collect\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n\t\t},\n\t\tCollects: []domain.Collect{\n\t\t\t{\n\t\t\t\tMode:       domain.CollectAll,\n\t\t\t\tConditions: []domain.WireCondition{{Step: \"nonexistent\", Result: \"success\"}},\n\t\t\t\tTo:         \"code\",\n\t\t\t},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\terr := wf.Validate()\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"nonexistent\")\n}\n\nfunc TestWorkflow_Validate_CollectBadTarget(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"bad-target\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n\t\t},\n\t\tCollects: []domain.Collect{\n\t\t\t{\n\t\t\t\tMode:       domain.CollectAll,\n\t\t\t\tConditions: []domain.WireCondition{{Step: \"code\", Result: \"success\"}},\n\t\t\t\tTo:         \"nonexistent\",\n\t\t\t},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\terr := wf.Validate()\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"nonexistent\")\n}\n\nfunc TestWorkflow_ValidateConfig_KnownKeys(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"known-keys\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\": {\n\t\t\t\tName:    \"code\",\n\t\t\t\tResults: []string{\"success\"},\n\t\t\t\tConfig: map[string]string{\n\t\t\t\t\t\"prompt\":       \"do stuff\",\n\t\t\t\t\t\"timeout\":      \"30m\",\n\t\t\t\t\t\"max_attempts\": \"3\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\twarnings := wf.ValidateConfig()\n\tassert.Empty(t, warnings)\n}\n\nfunc TestWorkflow_ValidateConfig_UnknownKey(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"unknown-key\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\": {\n\t\t\t\tName:    \"code\",\n\t\t\t\tResults: []string{\"success\"},\n\t\t\t\tConfig: map[string]string{\n\t\t\t\t\t\"prompt\":  \"do stuff\",\n\t\t\t\t\t\"tiemout\": \"30m\", // typo\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\twarnings := wf.ValidateConfig()\n\trequire.Len(t, warnings, 1)\n\tassert.Contains(t, warnings[0], \"tiemout\")\n\tassert.Contains(t, warnings[0], \"unrecognized\")\n}\n\nfunc TestWorkflow_ValidateLocation_ContainerRejectsWorkflowStep(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:     \"develop\",\n\t\tLocation: domain.LocationContainer,\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"dispatch\": {\n\t\t\t\tName:    \"dispatch\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"implement\"},\n\t\t\t},\n\t\t},\n\t\tEntryStep: \"dispatch\",\n\t}\n\terr := wf.ValidateLocation()\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"workflow_name\")\n\tassert.Contains(t, err.Error(), \"host workflows\")\n}\n\nfunc TestWorkflow_ValidateLocation_HostAllowsWorkflowStep(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:     \"main\",\n\t\tLocation: domain.LocationHost,\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"develop\": {\n\t\t\t\tName:    \"develop\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t},\n\t\tEntryStep: \"develop\",\n\t}\n\terr := wf.ValidateLocation()\n\tassert.NoError(t, err)\n}\n\nfunc TestWorkflow_ValidateLocation_ContainerAllowsAgentAndScript(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:     \"develop\",\n\t\tLocation: domain.LocationContainer,\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n\t\t\t\"check\": {Name: \"check\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\terr := wf.ValidateLocation()\n\tassert.NoError(t, err)\n}\n\nfunc TestWorkflow_ValidateLocation_EmptyLocationNoEnforcement(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"any\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"dispatch\": {\n\t\t\t\tName:    \"dispatch\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t},\n\t\tEntryStep: \"dispatch\",\n\t}\n\t// No Location set — should not enforce\n\terr := wf.ValidateLocation()\n\tassert.NoError(t, err)\n}\n\nfunc TestWorkflow_Validate_DuplicateOutputMapping_DifferentKeys(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"test\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"src\": {Name: \"src\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n\t\t\t\"a\":   {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n\t\t\t\"b\":   {Name: \"b\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n\t\t\t\"c\":   {Name: \"c\", Type: domain.StepTypeAgent, Results: []string{\"done\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"src\", Result: \"ok\", To: \"a\"},\n\t\t\t{From: \"src\", Result: \"ok\", To: \"b\"},\n\t\t\t{From: \"a\", Result: \"ok\", To: \"c\", OutputMap: []domain.OutputMapping{\n\t\t\t\t{EnvVar: \"FOO\", Path: domain.OutputPath{}},\n\t\t\t}},\n\t\t\t{From: \"b\", Result: \"ok\", To: \"c\", OutputMap: []domain.OutputMapping{\n\t\t\t\t{EnvVar: \"BAR\", Path: domain.OutputPath{}},\n\t\t\t}},\n\t\t\t{From: \"c\", Result: \"done\", To: domain.StepDone},\n\t\t},\n\t\tEntryStep: \"src\",\n\t\tCollects: []domain.Collect{\n\t\t\t{\n\t\t\t\tMode:       domain.CollectAll,\n\t\t\t\tConditions: []domain.WireCondition{{Step: \"a\", Result: \"ok\"}, {Step: \"b\", Result: \"ok\"}},\n\t\t\t\tTo:         \"c\",\n\t\t\t},\n\t\t},\n\t}\n\terr := wf.Validate()\n\tassert.NoError(t, err, \"different env var keys on wires to same step should be valid\")\n}\n\nfunc TestWorkflow_Validate_DuplicateOutputMapping_SameKey(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"test\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"src\": {Name: \"src\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n\t\t\t\"a\":   {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n\t\t\t\"b\":   {Name: \"b\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n\t\t\t\"c\":   {Name: \"c\", Type: domain.StepTypeAgent, Results: []string{\"done\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"src\", Result: \"ok\", To: \"a\"},\n\t\t\t{From: \"src\", Result: \"ok\", To: \"b\"},\n\t\t\t{From: \"a\", Result: \"ok\", To: \"c\", OutputMap: []domain.OutputMapping{\n\t\t\t\t{EnvVar: \"FOO\", Path: domain.OutputPath{}},\n\t\t\t}},\n\t\t\t{From: \"b\", Result: \"ok\", To: \"c\", OutputMap: []domain.OutputMapping{\n\t\t\t\t{EnvVar: \"FOO\", Path: domain.OutputPath{}},\n\t\t\t}},\n\t\t\t{From: \"c\", Result: \"done\", To: domain.StepDone},\n\t\t},\n\t\tEntryStep: \"src\",\n\t\tCollects: []domain.Collect{\n\t\t\t{\n\t\t\t\tMode:       domain.CollectAll,\n\t\t\t\tConditions: []domain.WireCondition{{Step: \"a\", Result: \"ok\"}, {Step: \"b\", Result: \"ok\"}},\n\t\t\t\tTo:         \"c\",\n\t\t\t},\n\t\t},\n\t}\n\terr := wf.Validate()\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"duplicate output mapping\")\n\tassert.Contains(t, err.Error(), \"FOO\")\n\tassert.Contains(t, err.Error(), \"c\")\n}\n\nfunc TestWorkflow_Validate_DuplicateOutputMapping_SameKeyDifferentSteps(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"test\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"a\": {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n\t\t\t\"b\": {Name: \"b\", Type: domain.StepTypeAgent, Results: []string{\"done\"}},\n\t\t\t\"c\": {Name: \"c\", Type: domain.StepTypeAgent, Results: []string{\"done\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"a\", Result: \"ok\", To: \"b\", OutputMap: []domain.OutputMapping{\n\t\t\t\t{EnvVar: \"FOO\", Path: domain.OutputPath{}},\n\t\t\t}},\n\t\t\t{From: \"a\", Result: \"ok\", To: \"c\", OutputMap: []domain.OutputMapping{\n\t\t\t\t{EnvVar: \"FOO\", Path: domain.OutputPath{}},\n\t\t\t}},\n\t\t\t{From: \"b\", Result: \"done\", To: domain.StepDone},\n\t\t\t{From: \"c\", Result: \"done\", To: domain.StepDone},\n\t\t},\n\t\tEntryStep: \"a\",\n\t}\n\terr := wf.Validate()\n\tassert.NoError(t, err, \"same env var key on wires to different steps should be valid\")\n}\n\nfunc TestWorkflow_Validate_DuplicateOutputMapping_NoMappings(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"test\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"a\": {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n\t\t\t\"b\": {Name: \"b\", Type: domain.StepTypeAgent, Results: []string{\"done\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n\t\t\t{From: \"b\", Result: \"done\", To: domain.StepDone},\n\t\t},\n\t\tEntryStep: \"a\",\n\t}\n\terr := wf.Validate()\n\tassert.NoError(t, err, \"wires with no output mappings should be valid\")\n}\n\nfunc TestWorkflow_ValidateConfig_ContainerPrefix(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"container-keys\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\": {\n\t\t\t\tName:    \"code\",\n\t\t\t\tResults: []string{\"success\"},\n\t\t\t\tConfig: map[string]string{\n\t\t\t\t\t\"prompt\":           \"do stuff\",\n\t\t\t\t\t\"container.image\":  \"myimage:v1\",\n\t\t\t\t\t\"container.memory\": \"4g\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\twarnings := wf.ValidateConfig()\n\tassert.Empty(t, warnings)\n}\n","numLines":467,"startLine":1,"totalLines":467}}}
