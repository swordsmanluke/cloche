ing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"test\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"a\": {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n\t\t\t\"b\": {Name: \"b\", Type: domain.StepTypeAgent, Results: []string{\"done\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n\t\t\t{From: \"b\", Result: \"done\", To: domain.StepDone},\n\t\t},\n\t\tEntryStep: \"a\",\n\t}\n\terr := wf.Validate()\n\tassert.NoError(t, err, \"wires with no output mappings should be valid\")\n}\n\nfunc TestWorkflow_ValidateConfig_ContainerPrefix(t *testing.T) {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":526,"cache_read_input_tokens":23260,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":526},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"31500fb7-bcea-4a12-98bf-e53c6518965d","uuid":"37c8492a-071a-4817-a558-15d82801b53e"}
