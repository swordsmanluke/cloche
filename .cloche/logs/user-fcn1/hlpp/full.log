promptFile struct {\n   977→\t\tPath    string        `json:\"path\"`\n   978→\t\tHistory []commitEntry `json:\"history\"`\n   979→\t}\n   980→\n   981→\tvar promptFiles []promptFile\n   982→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   983→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n   984→\t\tfor _, e := range entries {\n   985→\t\t\tif e.IsDir() {\n   986→\t\t\t\tcontinue\n   987→\t\t\t}\n   988→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n   989→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n   990→\t\t\tcmd.Dir = dir\n   991→\t\t\tout, err := cmd.Output()\n   992→\t\t\tif err != nil {\n   993→\t\t\t\tcontinue\n   994→\t\t\t}\n   995→\t\t\tvar history []commitEntry\n   996→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n   997→\t\t\t\tif line == \"\" {\n   998→\t\t\t\t\tcontinue\n   999→\t\t\t\t}\n  1000→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1001→\t\t\t\tif len(parts) < 3 {\n  1002→\t\t\t\t\tcontinue\n  1003→\t\t\t\t}\n  1004→\t\t\t\t// Parse date to short form\n  1005→\t\t\t\tdateStr := parts[1]\n  1006→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1007→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1008→\t\t\t\t}\n  1009→\t\t\t\thistory = append(history, commitEntry{\n  1010→\t\t\t\t\tSHA:     parts[0][:7],\n  1011→\t\t\t\t\tDate:    dateStr,\n  1012→\t\t\t\t\tMessage: parts[2],\n  1013→\t\t\t\t})\n  1014→\t\t\t}\n  1015→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1016→\t\t}\n  1017→\t}\n  1018→\n  1019→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1020→\tjson.NewEncoder(w).Encode(map[string]any{\n  1021→\t\t\"docker_image\": dockerImage,\n  1022→\t\t\"version\":      version,\n  1023→\t\t\"prompt_files\": promptFiles,\n  1024→\t})\n  1025→}\n  1026→\n  1027→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r