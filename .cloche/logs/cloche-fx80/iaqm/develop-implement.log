as workflow name for backwards compat\n   188→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   189→\t\t\t\tworkflow = args[i]\n   190→\t\t\t}\n   191→\t\t}\n   192→\t}\n   193→\n   194→\tif workflow == \"\" {\n   195→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   196→\t\tos.Exit(1)\n   197→\t}\n   198→\n   199→\tcwd, _ := os.Getwd()\n   200→\n   201→\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n   202→\t// Try loading from any .cloche file; only extract image for container workflows.\n   203→\tvar image string\n   204→\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n   205→\t\timage = wf.Config[\"container.image\"]\n   206→\t}\n   207→\n   208→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   209→\t\tWorkflowName:  workflow,\n   210→\t\tProjectDir:    cwd,\n   211→\t\tImage:         image,\n   212→\t\tPrompt:        prompt,\n   213→\t\tKeepContainer: keepContainer,\n   214→\t\tTitle:         title,\n   215→\t})\n   216→\tif err != nil {\n   217→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   218→\t\tos.Exit(1)\n   219→\t}\n   220→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   221→}\n   222→\n   223→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   224→\tif len(args) < 1 {\n   225→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   226→\t\tos.Exit(1)\n   227→\t}\n   228→\n   229→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   230→\tif err != nil {\n   231→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   232→\t\tos.Exit(1)\n   233→\t}\n   234→\n   235→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   236→\tif resp.Title != \"\" {\n   237→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   238→\t}\n   239→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   240→\tif resp.IsHost {\n   241→\t\tfmt.Printf(\"Type:      host\\n\")\n   242→\t} else {\n   243→\t\tfmt.Printf(\"Type:      container\\n\")\n   244→\t}\n   245→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   246→\tif resp.ContainerId != \"\" {\n   247→\t\tcid := resp.ContainerId\n   248→\t\tif len(cid) > 12 {\n   249→\t\t\tcid = cid[:12]\n   250→\t\t}\n   251→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   252→\t}\n   253→\tif resp.ErrorMessage != \"\" {\n   254→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   255→\t}\n   256→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   257→\tfor _, exec := range resp.StepExecutions {\n   258→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   259→\t}\n   260→}\n   261→\n   262→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   263→\tvar all bool\n   264→\tvar projectDir, stateFilter, issueFilter string\n   265→\tvar limit int32\n   266→\n   267→\tfor i := 0; i < len(args); i++ {\n   268→\t\tswitch args[i] {\n   269→\t\tcase \"--all\":\n   270→\t\t\tall = true\n   271→\t\tcase \"--project\", \"-p\":\n   272→\t\t\tif i+1 < len(args) {\n   273→\t\t\t\ti++\n   274→\t\t\t\tprojectDir = args[i]\n   275→\t\t\t}\n   276→\t\tcase \"--state\", \"-s\":\n   277→\t\t\tif i+1 < len(args) {\n   278→\t\t\t\ti++\n   279→\t\t\t\tstateFilter = args[i]\n   280→\t\t\t}\n   281→\t\tcase \"--limit\", \"-n\":\n   282→\t\t\tif i+1 < len(args) {\n   283→\t\t\t\ti++\n   284→\t\t\t\tn, err := strconv.Atoi(args[i])\n   285→\t\t\t\tif err != nil {\n   286→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   287→\t\t\t\t\tos.Exit(1)\n   288→\t\t\t\t}\n   289→\t\t\t\tlimit = int32(n)\n   290→\t\t\t}\n   291→\t\tcase \"--issue\", \"-i\":\n   292→\t\t\tif i+1 < len(args) {\n   293→\t\t\t\ti++\n   294→\t\t\t\tissueFilter = args[i]\n   295→\t\t\t}\n   296→\t\t}\n   297→\t}\n   298→\n   299→\treq := &pb.ListRunsRequest{\n   300→\t\tState:  stateFilter,\n   301→\t\tLimit:  limit,\n   302→\t\tTaskId: issueFilter,\n   303→\t}\n   304→\tif projectDir != \"\" {\n   305→\t\treq.ProjectDir = projectDir\n   306→\t} else if all {\n   307→\t\treq.All = true\n   308→\t} else {\n   309→\t\t// Default: filter to current project\n   310→\t\tcwd, _ := os.Getwd()\n   311→\t\treq.ProjectDir = cwd\n   312→\t}\n   313→\n   314→\tresp, err := client.ListRuns(ctx, req)\n   315→\tif err != nil {\n   316→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   317→\t\tos.Exit(1)\n   318→\t}\n   319→\n   320→\tif len(resp.Runs) == 0 {\n   321→\t\tfmt.Println(\"No runs found.\")\n   322→\t\treturn\n   323→\t}\n   324→\n   325→\tfor _, run := range resp.Runs {\n   326→\t\trunType := \"container\"\n   327→\t\tif run.IsHost {\n   328→\t\t\trunType = \"host\"\n   329→\t\t}\n   330→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   331→\t\tif run.Title != \"\" {\n   332→\t\t\tt := run.Title\n   333→\t\t\tif len(t) > 40 {\n   334→\t\t\t\tt = t[:37] + \"...\"\n   335→\t\t\t}\n   336→\t\t\tline += \"  \" + t\n   337→\t\t}\n   338→\t\tif run.ContainerId != \"\" {\n   339→\t\t\tline += \"  \" + run.ContainerId\n   340→\t\t}\n   341→\t\tif run.ErrorMessage != \"\" {\n   342→\t\t\terrMsg := run.ErrorMessage\n   343→\t\t\tif len(errMsg) > 60 {\n   344→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   345→\t\t\t}\n   346→\t\t\tline += \"  \" + errMsg\n   347→\t\t}\n   348→\t\tfmt.Println(line)\n   349→\t}\n   350→}\n   351→\n   352→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   353→\tif len(args) < 1 {\n   354→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n   355→\t\tos.Exit(1)\n   356→\t}\n   357→\n   358→\tvar stepFilter, typeFilter string\n   359→\tvar follow bool\n   360→\tvar limit int\n   361→\trunID := args[0]\n   362→\n   363→\tfor i := 1; i < len(args); i++ {\n   364→\t\tswitch args[i] {\n   365→\t\tcase \"--step\", \"-s\":\n   366→\t\t\tif i+1 < len(args) {\n   367→\t\t\t\ti++\n   368→\t\t\t\tstepFilter = args[i]\n   369→\t\t\t}\n   370→\t\tcase \"--type\":\n   371→\t\t\tif i+1 < len(args) {\n   372→\t\t\t\ti++\n   373→\t\t\t\ttypeFilter = args[i]\n   374→\t\t\t}\n   375→\t\tcase \"--follow\", \"-f\":\n   376→\t\t\tfollow = true\n   377→\t\tcase \"--limit\", \"-l\":\n   378→\t\t\tif i+1 < len(args) {\n   379→\t\t\t\ti++\n   380→\t\t\t\tn, err := strconv.Atoi(args[i])\n   381→\t\t\t\tif err != nil || n < 0 {\n   382→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n   383→\t\t\t\t\tos.Exit(1)\n   384→\t\t\t\t}\n   385→\t\t\t\tlimit = n\n   386→\t\t\t}\n   387→\t\t}\n   388→\t}\n   389→\n   390→\t// Use background context — log output can be large and follow mode blocks.\n   391→\tctx := context.Background()\n   392→\tvar mdPairs []string\n   393→\tif follow {\n   394→\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n   395→\t}\n   396→\tif limit > 0 {\n   397→\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n   398→\t}\n   399→\tif len(mdPairs) > 0 {\n   400→\t\tmd := metadata.Pairs(mdPairs...)\n   401→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   402→\t}\n   403→\n   404→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   405→\t\tRunId:    runID,\n   406→\t\tStepName: stepFilter,\n   407→\t\tLogType:  typeFilter,\n   408→\t})\n   409→\tif err != nil {\n   410→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   411→\t\tos.Exit(1)\n   412→\t}\n   413→\n   414→\tfor {\n   415→\t\tentry, err := stream.Recv()\n   416→\t\tif err != nil {\n   417→\t\t\tif errors.Is(err, io.EOF) {\n   418→\t\t\t\tbreak\n   419→\t\t\t}\n   420→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   421→\t\t\tos.Exit(1)\n   422→\t\t}\n   423→\n   424→\t\tswitch entry.Type {\n   425→\t\tcase \"step_started\":\n   426→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   427→\t\t\tif entry.Message != \"\" {\n   428→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   429→\t\t\t}\n   430→\t\tcase \"step_completed\":\n   431→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   432→\t\t\tif entry.Message != \"\" {\n   433→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   434→\t\t\t}\n   435→\t\tcase \"run_completed\":\n   436→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   437→\t\t\tif entry.Message != \"\" {\n   438→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   439→\t\t\t}\n   440→\t\tcase \"full_log\":\n   441→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   442→\t\tcase \"log\":\n   443→\t\t\t// Live-streamed log line from an active run.\n   444→\t\t\tfmt.Println(entry.Message)\n   445→\t\tdefault:\n   446→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   447→\t\t\tif entry.StepName != \"\" {\n   448→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   449→\t\t\t}\n   450→\t\t\tif entry.Message != \"\" {\n   451→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   452→\t\t\t}\n   453→\t\t}\n   454→\t}\n   455→}\n   456→\n   457→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   458→\tif len(args) < 1 {\n   459→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   460→\t\tos.Exit(1)\n   461→\t}\n   462→\n   463→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   464→\tif err != nil {\n   465→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   466→\t\tos.Exit(1)\n   467→\t}\n   468→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   469→}\n   470→\n   471→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   472→\tif len(args) < 1 {\n   473→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   474→\t\tos.Exit(1)\n   475→\t}\n   476→\n   477→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   478→\tif err != nil {\n   479→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   480→\t\tos.Exit(1)\n   481→\t}\n   482→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   483→}\n   484→\n   485→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   486→\tcwd, _ := os.Getwd()\n   487→\n   488→\t// Check for \"stop\" subcommand\n   489→\tif len(args) > 0 && args[0] == \"stop\" {\n   490→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   491→\t\tif err != nil {\n   492→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   493→\t\t\tos.Exit(1)\n   494→\t\t}\n   495→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   496→\t\treturn\n   497→\t}\n   498→\n   499→\t// Check for \"resume\" subcommand\n   500→\tif len(args) > 0 && args[0] == \"resume\" {\n   501→\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n   502→\t\tif err != nil {\n   503→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   504→\t\t\tos.Exit(1)\n   505→\t\t}\n   506→\t\tfmt.Println(\"Orchestration loop resumed.\")\n   507→\t\treturn\n   508→\t}\n   509→\n   510→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   511→\tvar maxConcurrent int32\n   512→\tfor i := 0; i < len(args); i++ {\n   513→\t\tswitch args[i] {\n   514→\t\tcase \"--max\":\n   515→\t\t\tif i+1 < len(args) {\n   516→\t\t\t\ti++\n   517→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   518→\t\t\t\tif n != 1 || err != nil {\n   519→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   520→\t\t\t\t\tos.Exit(1)\n   521→\t\t\t\t}\n   522→\t\t\t}\n   523→\t\t}\n   524→\t}\n   525→\n   526→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   527→\t\tProjectDir:    cwd,\n   528→\t\tMaxConcurrent: maxConcurrent,\n   529→\t})\n   530→\tif err != nil {\n   531→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   532→\t\tos.Exit(1)\n   533→\t}\n   534→\tif maxConcurrent > 0 {\n   535→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   536→\t} else {\n   537→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   538→\t}\n   539→}\n   540→\n   541→func cmdTasks(args []string) {\n   542→\t// Determine HTTP address from env\n   543→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   544→\tif httpAddr == \"\" {\n   545→\t\thttpAddr = \"localhost:8080\"\n   546→\t}\n   547→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   548→\n   549→\t// Determine project label from --project flag or current directory\n   550→\tprojectDir := \"\"\n   551→\tfor i := 0; i < len(args); i++ {\n   552→\t\tswitch args[i] {\n   553→\t\tcase \"--project\":\n   554→\t\t\tif i+1 < len(args) {\n   555→\t\t\t\ti++\n   556→\t\t\t\tprojectDir = args[i]\n   557→\t\t\t}\n   558→\t\t}\n   559→\t}\n   560→\n   561→\tif projectDir == \"\" {\n   562→\t\tcwd, _ := os.Getwd()\n   563→\t\tprojectDir = filepath.Base(cwd)\n   564→\t}\n   565→\n   566→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   567→\tresp, err := http.Get(tasksURL)\n   568→\tif err != nil {\n   569→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   570→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   571→\t\tos.Exit(1)\n   572→\t}\n   573→\tdefer resp.Body.Close()\n   574→\n   575→\tif resp.StatusCode != 200 {\n   576→\t\tbody, _ := io.ReadAll(resp.Body)\n   577→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   578→\t\tos.Exit(1)\n   579→\t}\n   580→\n   581→\ttype taskEntry struct {\n   582→\t\tID          string `json:\"id\"`\n   583→\t\tStatus      string `json:\"status\"`\n   584→\t\tTitle       string `json:\"title\"`\n   585→\t\tDescription string `json:\"description\"`\n   586→\t\tAssigned    bool   `json:\"assigned\"`\n   587→\t\tAssignedAt  string `json:\"assigned_at\"`\n   588→\t\tRunID       string `json:\"run_id\"`\n   589→\t}\n   590→\n   591→\tvar tasks []taskEntry\n   592→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   593→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   594→\t\tos.Exit(1)\n   595→\t}\n   596→\n   597→\tif len(tasks) == 0 {\n   598→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   599→\t\treturn\n   600→\t}\n   601→\n   602→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   603→\tfor _, t := range tasks {\n   604→\t\tstatus := t.Status\n   605→\t\tif status == \"\" {\n   606→\t\t\tstatus = \"open\"\n   607→\t\t}\n   608→\t\tassigned := \"-\"\n   609→\t\tif t.Assigned {\n   610→\t\t\tassigned = \"yes\"\n   611→\t\t}\n   612→\t\trunID := \"\"\n   613→\t\tif t.RunID != \"\" {\n   614→\t\t\trunID = t.RunID\n   615→\t\t\tif len(runID) > 30 {\n   616→\t\t\t\trunID = runID[:27] + \"...\"\n   617→\t\t\t}\n   618→\t\t}\n   619→\t\ttitle := t.Title\n   620→\t\tif len(title) > 40 {\n   621→\t\t\ttitle = title[:37] + \"...\"\n   622→\t\t}\n   623→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   624→\t}\n   625→}\n   626→\n   627→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   628→\tvar force bool\n   629→\tfor _, a := range args {\n   630→\t\tif a == \"-f\" || a == \"--force\" {\n   631→\t\t\tforce = true\n   632→\t\t}\n   633→\t}\n   634→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n   635→\tif err != nil {\n   636→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   637→\t\tos.Exit(1)\n   638→\t}\n   639→\tfmt.Println(\"Daemon shutting down.\")\n   640→}\n   641→\n   642→// resolveRunContext returns the project directory and run ID for context\n   643→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   644→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   645→func resolveRunContext() (projectDir, runID string, err error) {\n   646→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   647→\tif runID == \"\" {\n   648→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   649→\t}\n   650→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   651→\tif projectDir == \"\" {\n   652→\t\tprojectDir, err = os.Getwd()\n   653→\t\tif err != nil {\n   654→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   655→\t\t}\n   656→\t}\n   657→\treturn projectDir, runID, nil\n   658→}\n   659→\n   660→func cmdGet(args []string) {\n   661→\tif len(args) < 1 {\n   662→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   663→\t\tos.Exit(1)\n   664→\t}\n   665→\n   666→\tprojectDir, runID, err := resolveRunContext()\n   667→\tif err != nil {\n   668→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   669→\t\tos.Exit(1)\n   670→\t}\n   671→\n   672→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   673→\tif err != nil {\n   674→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   675→\t\tos.Exit(1)\n   676→\t}\n   677→\tif !ok {\n   678→\t\tos.Exit(1)\n   679→\t}\n   680→\tfmt.Println(val)\n   681→}\n   682→\n   683→func cmdSet(args []string) {\n   684→\tif len(args) < 2 {\n   685→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   686→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   687→\t\tos.Exit(1)\n   688→\t}\n   689→\n   690→\tprojectDir, runID, err := resolveRunContext()\n   691→\tif err != nil {\n   692→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   693→\t\tos.Exit(1)\n   694→\t}\n   695→\n   696→\tvalue := args[1]\n   697→\tif value == \"-\" {\n   698→\t\tdata, err := io.ReadAll(os.Stdin)\n   699→\t\tif err != nil {\n   700→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   701→\t\t\tos.Exit(1)\n   702→\t\t}\n   703→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   704→\t}\n   705→\n   706→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   707→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   708→\t\tos.Exit(1)\n   709→\t}\n   710→}\n   711→\n   712→func cmdVersion() {\n   713→\tcliVersion := version.Version()\n   714→\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   715→\n   716→\t// Try to get daemon version via gRPC\n   717→\tdaemonVersion := \"<unavailable>\"\n   718→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   719→\tif addr == \"\" {\n   720→\t\taddr = \"unix:///tmp/cloche.sock\"\n   721→\t}\n   722→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   723→\tif err == nil {\n   724→\t\tdefer conn.Close()\n   725→\t\tclient := pb.NewClocheServiceClient(conn)\n   726→\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   727→\t\tdefer cancel()\n   728→\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   729→\t\tif err == nil {\n   730→\t\t\tdaemonVersion = resp.Version\n   731→\t\t}\n   732→\t}\n   733→\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   734→\n   735→\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   736→\tagentVersion := \"<unavailable>\"\n   737→\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   738→\tif image == \"\" {\n   739→\t\timage = \"cloche-agent:latest\"\n   740→\t}\n   741→\tout, err := exec.CommandContext(\n   742→\t\tcontext.Background(),\n   743→\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   744→\t).Output()\n   745→\tif err == nil {\n   746→\t\tagentVersion = strings.TrimSpace(string(out))\n   747→\t\t// Strip \"cloche-agent \" prefix if present\n   748→\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n   749→\t}\n   750→\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n   751→\n   752→\t// Warn about version mismatches\n   753→\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n   754→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n   755→\t}\n   756→\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n   757→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n   758→\t}\n   759→}\n   760→"}]},"parent_tool_use_id":null,"session_id":"0fd95967-c19b-48b1-b504-9ad5f3e0a46b","uuid":"0de7d5f7-a1bf-4baf-a47b-851209bf8f8d","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n\t\"github.com/cloche-dev/cloche/internal/version\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n\n\t// Handle version flags before anything else\n\tif os.Args[1] == \"-v\" || os.Args[1] == \"--version\" {\n\t\tcmdVersion()\n\t\treturn\n\t}\n\n\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n\tswitch os.Args[1] {\n\tcase \"help\":\n\t\tprintHelp(os.Args[2:])\n\t\treturn\n\tcase \"--help\", \"-h\":\n\t\tprintTopLevelHelp()\n\t\treturn\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"init\")\n\t\t\treturn\n\t\t}\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"health\")\n\t\t\treturn\n\t\t}\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\tcase \"get\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"get\")\n\t\t\treturn\n\t\t}\n\t\tcmdGet(os.Args[2:])\n\t\treturn\n\tcase \"set\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"set\")\n\t\t\treturn\n\t\t}\n\t\tcmdSet(os.Args[2:])\n\t\treturn\n\tcase \"tasks\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"tasks\")\n\t\t\treturn\n\t\t}\n\t\tcmdTasks(os.Args[2:])\n\t\treturn\n\tcase \"workflow\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"workflow\")\n\t\t\treturn\n\t\t}\n\t\tcmdWorkflow(os.Args[2:])\n\t\treturn\n\tcase \"project\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"project\")\n\t\t\treturn\n\t\t}\n\t\tcmdProject(os.Args[2:])\n\t\treturn\n\tcase \"validate\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"validate\")\n\t\t\treturn\n\t\t}\n\t\tcmdValidate(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Handle --help for daemon commands before connecting\n\tdaemonCmds := map[string]bool{\n\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n\t}\n\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n\t\tprintSubcommandHelp(os.Args[1])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client, os.Args[2:])\n\tdefault:\n\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n}\n\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n\t// Try loading from any .cloche file; only extract image for container workflows.\n\tvar image string\n\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n\t\timage = wf.Config[\"container.image\"]\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tvar projectDir, stateFilter, issueFilter string\n\tvar limit int32\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--all\":\n\t\t\tall = true\n\t\tcase \"--project\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\tcase \"--state\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstateFilter = args[i]\n\t\t\t}\n\t\tcase \"--limit\", \"-n\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = int32(n)\n\t\t\t}\n\t\tcase \"--issue\", \"-i\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tissueFilter = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\treq := &pb.ListRunsRequest{\n\t\tState:  stateFilter,\n\t\tLimit:  limit,\n\t\tTaskId: issueFilter,\n\t}\n\tif projectDir != \"\" {\n\t\treq.ProjectDir = projectDir\n\t} else if all {\n\t\treq.All = true\n\t} else {\n\t\t// Default: filter to current project\n\t\tcwd, _ := os.Getwd()\n\t\treq.ProjectDir = cwd\n\t}\n\n\tresp, err := client.ListRuns(ctx, req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n\t\tif run.Title != \"\" {\n\t\t\tt := run.Title\n\t\t\tif len(t) > 40 {\n\t\t\t\tt = t[:37] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + t\n\t\t}\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\tvar limit int\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\tcase \"--limit\", \"-l\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil || n < 0 {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = n\n\t\t\t}\n\t\t}\n\t}\n\n\t// Use background context — log output can be large and follow mode blocks.\n\tctx := context.Background()\n\tvar mdPairs []string\n\tif follow {\n\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n\t}\n\tif limit > 0 {\n\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n\t}\n\tif len(mdPairs) > 0 {\n\t\tmd := metadata.Pairs(mdPairs...)\n\t\tctx = metadata.NewOutgoingContext(ctx, md)\n\t}\n\n\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Check for \"resume\" subcommand\n\tif len(args) > 0 && args[0] == \"resume\" {\n\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop resumed.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdTasks(args []string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\t// Determine project label from --project flag or current directory\n\tprojectDir := \"\"\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tcwd, _ := os.Getwd()\n\t\tprojectDir = filepath.Base(cwd)\n\t}\n\n\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n\tresp, err := http.Get(tasksURL)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\ttype taskEntry struct {\n\t\tID          string `json:\"id\"`\n\t\tStatus      string `json:\"status\"`\n\t\tTitle       string `json:\"title\"`\n\t\tDescription string `json:\"description\"`\n\t\tAssigned    bool   `json:\"assigned\"`\n\t\tAssignedAt  string `json:\"assigned_at\"`\n\t\tRunID       string `json:\"run_id\"`\n\t}\n\n\tvar tasks []taskEntry\n\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(tasks) == 0 {\n\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n\t\treturn\n\t}\n\n\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n\tfor _, t := range tasks {\n\t\tstatus := t.Status\n\t\tif status == \"\" {\n\t\t\tstatus = \"open\"\n\t\t}\n\t\tassigned := \"-\"\n\t\tif t.Assigned {\n\t\t\tassigned = \"yes\"\n\t\t}\n\t\trunID := \"\"\n\t\tif t.RunID != \"\" {\n\t\t\trunID = t.RunID\n\t\t\tif len(runID) > 30 {\n\t\t\t\trunID = runID[:27] + \"...\"\n\t\t\t}\n\t\t}\n\t\ttitle := t.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar force bool\n\tfor _, a := range args {\n\t\tif a == \"-f\" || a == \"--force\" {\n\t\t\tforce = true\n\t\t}\n\t}\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n\n// resolveRunContext returns the project directory and run ID for context\n// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n// from CLOCHE_PROJECT_DIR (falling back to cwd).\nfunc resolveRunContext() (projectDir, runID string, err error) {\n\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n\tif runID == \"\" {\n\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n\t}\n\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n\tif projectDir == \"\" {\n\t\tprojectDir, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n\t\t}\n\t}\n\treturn projectDir, runID, nil\n}\n\nfunc cmdGet(args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif !ok {\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(val)\n}\n\nfunc cmdSet(args []string) {\n\tif len(args) < 2 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvalue := args[1]\n\tif value == \"-\" {\n\t\tdata, err := io.ReadAll(os.Stdin)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n\t}\n\n\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n\nfunc cmdVersion() {\n\tcliVersion := version.Version()\n\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n\n\t// Try to get daemon version via gRPC\n\tdaemonVersion := \"<unavailable>\"\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err == nil {\n\t\tdefer conn.Close()\n\t\tclient := pb.NewClocheServiceClient(conn)\n\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n\t\tdefer cancel()\n\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n\t\tif err == nil {\n\t\t\tdaemonVersion = resp.Version\n\t\t}\n\t}\n\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n\n\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n\tagentVersion := \"<unavailable>\"\n\timage := os.Getenv(\"CLOCHE_IMAGE\")\n\tif image == \"\" {\n\t\timage = \"cloche-agent:latest\"\n\t}\n\tout, err := exec.CommandContext(\n\t\tcontext.Background(),\n\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n\t).Output()\n\tif err == nil {\n\t\tagentVersion = strings.TrimSpace(string(out))\n\t\t// Strip \"cloche-agent \" prefix if present\n\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n\t}\n\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n\n\t// Warn about version mismatches\n\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n\t}\n\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n\t}\n}\n","numLines":760,"startLine":1,"totalLines":760}}}
