{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012PTxfgyjVZWf4XxneZxSBr","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"io\"\n     7→\t\"os\"\n     8→\t\"time\"\n     9→\n    10→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    11→)\n    12→\n    13→func cmdPoll(client pb.ClocheServiceClient, args []string) {\n    14→\tif len(args) < 1 {\n    15→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche poll <run-id> [run-id...]\\n\")\n    16→\t\tos.Exit(1)\n    17→\t}\n    18→\n    19→\tif len(args) == 1 {\n    20→\t\tcmdPollSingle(client, args[0])\n    21→\t} else {\n    22→\t\texitCode := cmdPollMulti(client, args, os.Stdout, os.Stderr)\n    23→\t\tos.Exit(exitCode)\n    24→\t}\n    25→}\n    26→\n    27→func cmdPollSingle(client pb.ClocheServiceClient, runID string) {\n    28→\tpollInterval := 2 * time.Second\n    29→\tcontainerDeadThreshold := 1 * time.Minute\n    30→\n    31→\tvar lastStepCount int\n    32→\tvar lastState string\n    33→\n    34→\tfor {\n    35→\t\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n    36→\t\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: runID})\n    37→\t\tcancel()\n    38→\n    39→\t\tif err != nil {\n    40→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    41→\t\t\tos.Exit(1)\n    42→\t\t}\n    43→\n    44→\t\t// Print new step events\n    45→\t\tfor i := lastStepCount; i < len(resp.StepExecutions); i++ {\n    46→\t\t\texec := resp.StepExecutions[i]\n    47→\t\t\tts := time.Now().Format(\"15:04:05\")\n    48→\t\t\tif exec.Result == \"\" {\n    49→\t\t\t\tfmt.Printf(\"[%s] Step %q started\\n\", ts, exec.StepName)\n    50→\t\t\t} else {\n    51→\t\t\t\tfmt.Printf(\"[%s] Step %q completed: %s\\n\", ts, exec.StepName, exec.Result)\n    52→\t\t\t}\n    53→\t\t}\n    54→\t\tlastStepCount = len(resp.StepExecutions)\n    55→\n    56→\t\t// Print state changes\n    57→\t\tif resp.State != lastState {\n    58→\t\t\tts := time.Now().Format(\"15:04:05\")\n    59→\t\t\tfmt.Printf(\"[%s] Run %s is %s\\n\", ts, runID, resp.State)\n    60→\t\t\tlastState = resp.State\n    61→\t\t}\n    62→\n    63→\t\t// Check terminal states\n    64→\t\tswitch resp.State {\n    65→\t\tcase \"succeeded\":\n    66→\t\t\tos.Exit(0)\n    67→\t\tcase \"failed\", \"cancelled\":\n    68→\t\t\tif resp.ErrorMessage != \"\" {\n    69→\t\t\t\tfmt.Fprintf(os.Stderr, \"Error: %s\\n\", resp.ErrorMessage)\n    70→\t\t\t}\n    71→\t\t\tos.Exit(1)\n    72→\t\t}\n    73→\n    74→\t\t// Check container death\n    75→\t\tif !resp.ContainerAlive && resp.ContainerDeadSince != \"\" {\n    76→\t\t\tdeadSince, err := time.Parse(time.RFC3339Nano, resp.ContainerDeadSince)\n    77→\t\t\tif err == nil && time.Since(deadSince) > containerDeadThreshold {\n    78→\t\t\t\tfmt.Fprintf(os.Stderr, \"[%s] Container has been dead for >1 minute (since %s)\\n\",\n    79→\t\t\t\t\ttime.Now().Format(\"15:04:05\"), deadSince.Format(\"15:04:05\"))\n    80→\t\t\t\tos.Exit(1)\n    81→\t\t\t}\n    82→\t\t}\n    83→\n    84→\t\ttime.Sleep(pollInterval)\n    85→\t}\n    86→}\n    87→\n    88→// isTerminalState returns true if the run state is a terminal state.\n    89→func isTerminalState(state string) bool {\n    90→\tswitch state {\n    91→\tcase \"succeeded\", \"failed\", \"cancelled\":\n    92→\t\treturn true\n    93→\t}\n    94→\treturn false\n    95→}\n    96→\n    97→// cmdPollMulti polls multiple runs and displays a compact status summary.\n    98→// Returns 0 if all runs succeeded, 1 if any failed or were cancelled.\n    99→func cmdPollMulti(client pb.ClocheServiceClient, runIDs []string, stdout, stderr io.Writer) int {\n   100→\tpollInterval := 2 * time.Second\n   101→\tstates := make(map[string]string, len(runIDs))\n   102→\n   103→\tfor {\n   104→\t\tchanged := false\n   105→\t\tfor _, id := range runIDs {\n   106→\t\t\tif isTerminalState(states[id]) {\n   107→\t\t\t\tcontinue\n   108→\t\t\t}\n   109→\n   110→\t\t\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n   111→\t\t\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: id})\n   112→\t\t\tcancel()\n   113→\n   114→\t\t\tif err != nil {\n   115→\t\t\t\tfmt.Fprintf(stderr, \"error polling %s: %v\\n\", id, err)\n   116→\t\t\t\tstates[id] = \"error\"\n   117→\t\t\t\tchanged = true\n   118→\t\t\t\tcontinue\n   119→\t\t\t}\n   120→\n   121→\t\t\tif resp.State != states[id] {\n   122→\t\t\t\tstates[id] = resp.State\n   123→\t\t\t\tchanged = true\n   124→\t\t\t}\n   125→\t\t}\n   126→\n   127→\t\tif changed {\n   128→\t\t\tfor _, id := range runIDs {\n   129→\t\t\t\tfmt.Fprintf(stdout, \"%s: %s\\n\", id, states[id])\n   130→\t\t\t}\n   131→\t\t\tfmt.Fprintln(stdout)\n   132→\t\t}\n   133→\n   134→\t\t// Check if all runs are in terminal states\n   135→\t\tallDone := true\n   136→\t\tfor _, id := range runIDs {\n   137→\t\t\tif !isTerminalState(states[id]) && states[id] != \"error\" {\n   138→\t\t\t\tallDone = false\n   139→\t\t\t\tbreak\n   140→\t\t\t}\n   141→\t\t}\n   142→\n   143→\t\tif allDone {\n   144→\t\t\tfor _, id := range runIDs {\n   145→\t\t\t\ts := states[id]\n   146→\t\t\t\tif s != \"succeeded\" {\n   147→\t\t\t\t\treturn 1\n   148→\t\t\t\t}\n   149→\t\t\t}\n   150→\t\t\treturn 0\n   151→\t\t}\n   152→\n   153→\t\ttime.Sleep(pollInterval)\n   154→\t}\n   155→}\n   156→"}]},"parent_tool_use_id":"toolu_01467VxunbiGscnpFJ4w3NNG","session_id":"0fd95967-c19b-48b1-b504-9ad5f3e0a46b","uuid":"a4195947-1cb5-42d1-8a48-607cc5dca797"}
