r)","+    os.Exit(1)","+  }","+","+  oneHourAgo := time.Now().Add(-1 * time.Hour)","+  var succeeded, total int","+  var activeRuns []*pb.RunSummary","+  for _, run := range resp.Runs {","+    if run.State == string(domain.RunStatePending) || run.State == string(domain.RunStateRunning) {","+      activeRuns = append(activeRuns, run)","+    }","+    startedAt, parseErr := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", run.StartedAt)","+    if parseErr != nil {","+      continue","+    }","+    if startedAt.Before(oneHourAgo) {","+      continue","+    }","+    total++","+    if run.State == string(domain.RunStateSucceeded) {","+      succeeded++","+    }","+  }","+  fmt.Printf(\"Runs (1h): %d / %d succeeded\\n\", succeeded, total)","+","+  fmt.Printf(\"Active runs: %d\\n\", len(activeRuns))","+  for _, run := range activeRuns {","+    duration := \"\"","+    if startedAt, parseErr := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", run.StartedAt); parseErr == nil {","+      duration = time.Since(startedAt).Truncate(time.Second).String()","+    }","+    fmt.Printf(\"  %s: %s\\n\", run.RunId, duration)","+  }","+}","+"," func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {","   var all bool","   var projectDir, stateFilter, issueFilter string"]}],"userModified":false,"replaceAll":false}}
