n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdStatusOverview(ctx context.Context, client pb.ClocheServiceClient, showAll bool) {\n\t// Get daemon version.\n\tver, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Version:   %s\\n\", ver.Version)\n\n\tcwd, _ := os.Getwd()\n\t_, clocheErr := os.Stat(filepath.Join(cwd, \".cloche\"))\n\tinProject := clocheErr == nil\n\n\tif inProject && !showAll {\n\t\tcmdStatusProject(ctx, client, cwd)\n\t} else {\n\t\tcmdStatusGlobal(ctx, client)\n\t}\n}\n\nfunc cmdStatusProject(ctx context.Context, client pb.ClocheServiceClient, projectDir string) {\n\t// Get project info for name, concurrency, and loop status.\n\tinfo, err := client.GetProjectInfo(ctx, &pb.GetProjectInfoRequest{ProjectDir: projectDir})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Project:   %s\\n\", info.Name)\n\tfmt.Printf(\"Concurrency: %d\\n\", info.Concurrency)\n\n\tloopState := \"stopped\"\n\tif info.LoopRunning {\n\t\tif info.ErrorHalted {\n\t\t\tloopState = \"halted\"\n\t\t} else {\n\t\t\tloopState = \"running\"\n\t\t}\n\t}\n\tfmt.Printf(\"Loop:      %s\\n\", loopState)\n\n\t// Get runs for past hour to compute success stats.\n\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: projectDir})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\toneHourAgo := time.Now().Add(-1 * time.Hour)\n\tvar succeeded, total int\n\tfor _, run := range resp.Runs {\n\t\tstartedAt, parseErr := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", run.StartedAt)\n\t\tif parseErr != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif startedAt.Before(oneHourAgo) {\n\t\t\tcontinue\n\t\t}\n\t\ttotal++\n\t\tif run.State == string(domain.RunStateSucceeded) {\n\t\t\tsucceeded++\n\t\t}\n\t}\n\tfmt.Printf(\"Runs (1h): %d / %d succeeded\\n\", succeeded, total)\n\n\t// Active runs.\n\tfmt.Printf(\"Active runs: %d\\n\", len(info.ActiveRuns))\n\tfor _, run := range info.ActiveRuns {\n\t\tduration := \"\"\n\t\tif startedAt, parseErr := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", run.StartedAt); parseErr == nil {\n\t\t\tduration = time.Since(startedAt).Truncate(time.Second).String()\n\t\t}","numLines":130,"startLine":223,"totalLines":894}}}
