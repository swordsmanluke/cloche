{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DMZtFGKtGDZ8YnvomXZ6TB","type":"tool_result","content":"     1→package grpc_test\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"sync/atomic\"\n    10→\t\"testing\"\n    11→\t\"time\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\tserver \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    15→\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    16→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    17→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    18→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    19→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    20→\t\"github.com/stretchr/testify/assert\"\n    21→\t\"github.com/stretchr/testify/require\"\n    22→\tgrpclib \"google.golang.org/grpc\"\n    23→\t\"google.golang.org/grpc/metadata\"\n    24→)\n    25→\n    26→func TestServer_ListRuns_Empty(t *testing.T) {\n    27→\tstore, err := sqlite.NewStore(\":memory:\")\n    28→\trequire.NoError(t, err)\n    29→\tdefer store.Close()\n    30→\n    31→\tsrv := server.NewClocheServer(store, nil)\n    32→\tresp, err := srv.ListRuns(context.Background(), &pb.ListRunsRequest{All: true})\n    33→\trequire.NoError(t, err)\n    34→\tassert.Empty(t, resp.Runs)\n    35→}\n    36→\n    37→func TestServer_ListRuns_FilterByProject(t *testing.T) {\n    38→\tstore, err := sqlite.NewStore(\":memory:\")\n    39→\trequire.NoError(t, err)\n    40→\tdefer store.Close()\n    41→\n    42→\tctx := context.Background()\n    43→\n    44→\t// Create runs for two different projects\n    45→\trunA := domain.NewRun(\"run-proj-a\", \"wf\")\n    46→\trunA.ProjectDir = \"/home/user/project-a\"\n    47→\trequire.NoError(t, store.CreateRun(ctx, runA))\n    48→\n    49→\trunB := domain.NewRun(\"run-proj-b\", \"wf\")\n    50→\trunB.ProjectDir = \"/home