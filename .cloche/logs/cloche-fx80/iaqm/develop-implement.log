   64→\t\treturn\n    65→\tcase \"get\":\n    66→\t\tif hasHelpFlag(os.Args[2:]) {\n    67→\t\t\tprintSubcommandHelp(\"get\")\n    68→\t\t\treturn\n    69→\t\t}\n    70→\t\tcmdGet(os.Args[2:])\n    71→\t\treturn\n    72→\tcase \"set\":\n    73→\t\tif hasHelpFlag(os.Args[2:]) {\n    74→\t\t\tprintSubcommandHelp(\"set\")\n    75→\t\t\treturn\n    76→\t\t}\n    77→\t\tcmdSet(os.Args[2:])\n    78→\t\treturn\n    79→\tcase \"tasks\":\n    80→\t\tif hasHelpFlag(os.Args[2:]) {\n    81→\t\t\tprintSubcommandHelp(\"tasks\")\n    82→\t\t\treturn\n    83→\t\t}\n    84→\t\tcmdTasks(os.Args[2:])\n    85→\t\treturn\n    86→\tcase \"workflow\":\n    87→\t\tif hasHelpFlag(os.Args[2:]) {\n    88→\t\t\tprintSubcommandHelp(\"workflow\")\n    89→\t\t\treturn\n    90→\t\t}\n    91→\t\tcmdWorkflow(os.Args[2:])\n    92→\t\treturn\n    93→\tcase \"project\":\n    94→\t\tif hasHelpFlag(os.Args[2:]) {\n    95→\t\t\tprintSubcommandHelp(\"project\")\n    96→\t\t\treturn\n    97→\t\t}\n    98→\t\tcmdProject(os.Args[2:])\n    99→\t\treturn\n   100→\tcase \"validate\":\n   101→\t\tif hasHelpFlag(os.Args[2:]) {\n   102→\t\t\tprintSubcommandHelp(\"validate\")\n   103→\t\t\treturn\n   104→\t\t}\n   105→\t\tcmdValidate(os.Args[2:])\n   106→\t\treturn\n   107→\t}\n   108→\n   109→\t// Handle --help for daemon commands before connecting\n   110→\tdaemonCmds := map[string]bool{\n   111→\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n   112→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n   113→\t}\n   114→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n   115→\t\tprintSubcommandHelp(os.Args[1])\n   116→\t\treturn\n   117→\t}\n   118→\n   119→\t// Commands that need a daemon connection\n   120→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   121→\tif addr == \"\" {\n   122→\t\taddr = \"unix:///tmp/cloche.sock\"\n   123→\t}\n   124→\n   125→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   126→\tif err != nil {\n   127→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   128→\t\tos.Exit(1)\n   129→\t}\n   130→\tdefer conn.Close()\n   131→\n   132→\tclient := pb.NewClocheServiceClient(conn)\n   133→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   134→\tdefer cancel()\n   135→\n   136→\tswitch os.Args[1] {\n   137→\tcase \"run\":\n   138→\t\tcmdRun(ctx, client, os.Args[2:])\n   139→\tcase \"status\":\n   140→\t\tcmdStatus(ctx, client, os.Args[2:])\n   141→\tcase \"logs\":\n   142→\t\tcmdLogs(client, os.Args[2:])\n   143→\tcase \"poll\":\n   144→\t\tcmdPoll(client, os.Args[2:])\n   145→\tcase \"list\":\n   146→\t\tcmdList(ctx, client, os.Args[2:])\n   147→\tcase \"stop\":\n   148→\t\tcmdStop(ctx, client, os.Args[2:])\n   149→\tcase \"delete\":\n   150→\t\tcmdDelete(ctx, client, os.Args[2:])\n   151→\tcase \"loop\":\n   152→\t\tcmdLoop(ctx, client, os.Args[2:])\n   153→\tcase \"shutdown\":\n   154→\t\tcmdShutdown(ctx, client, os.Args[2:])\n   155→\tdefault:\n   156→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   157→\t\tprintTopLevelHelp()\n   158→\t\tos.Exit(1)\n   159→\t}\n   160→}\n   161→\n   162→\n   163→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   164→\tvar workflow, prompt, title string\n   165→\tvar keepContainer bool\n   166→\n   167→\tfor i := 0; i < len(args); i++ {\n   168→\t\tswitch args[i] {\n   169→\t\tcase \"--workflow\":\n   170→\t\t\tif i+1 < len(args) {\n   171→\t\t\t\ti++\n   172→\t\t\t\tworkflow = args[i]\n   173→\t\t\t}\n   174→\t\tcase \"--prompt\", \"-p\":\n   175→\t\t\tif i+1 < len(args) {\n   176→\t\t\t\ti++\n   177→\t\t\t\tprompt = args[i]\n   178→\t\t\t}\n   179→\t\tcase \"--title\":\n   180→\t\t\tif i+1 < len(args) {\n   181→\t\t\t\ti++\n   182→\t\t\t\ttitle = args[i]\n   183→\t\t\t}\n   184→\t\tcase \"--keep-container\":\n   185→\t\t\tkeepContainer = true\n   186→\t\tdefault:\n   187→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   188→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   189→\t\t\t\tworkflow = args[i]\n   190→\t\t\t}\n   191→\t\t}\n   192→\t}\n   193→\n   194→\tif workflow == \"\" {\n   195→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   196→\t\tos.Exit(1)\n   197→\t}\n   198→\n   199→\tcwd, _ := os.Getwd()\n   200→\n   201→\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n   202→\t// Try loading from any .cloche file; only extract image for container workflows.\n   203→\tvar image string\n   204→\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n   205→\t\timage = wf.Config[\"container.image\"]\n   206→\t}\n   207→\n   208→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   209→\t\tWorkflowName:  workflow,\n   210→\t\tProjectDir:    cwd,\n   211→\t\tImage:         image,\n   212→\t\tPrompt:        prompt,\n   213→\t\tKeepContainer: keepContainer,\n   214→\t\tTitle:         title,\n   215→\t})\n   216→\tif err != nil {\n   217→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   218→\t\tos.Exit(1)\n   219→\t}\n   220→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   221→}\n   222→\n   223→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   224→\tif len(args) < 1 {\n   225→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   226→\t\tos.Exit(1)\n   227→\t}\n   228→\n   229→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   230→\tif err != nil {\n   231→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   232→\t\tos.Exit(1)\n   233→\t}\n   234→\n   235→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   236→\tif resp.Title != \"\" {\n   237→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   238→\t}\n   239→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   240→\tif resp.IsHost {\n   241→\t\tfmt.Printf(\"Type:      host\\n\")\n   242→\t} else {\n   243→\t\tfmt.Printf(\"Type:      container\\n\")\n   244→\t}\n   245→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   246→\tif resp.ContainerId != \"\" {\n   247→\t\tcid := resp.ContainerId\n   248→\t\tif len(cid) > 12 {\n   249→\t\t\tcid = cid[:12]\n   250→\t\t}\n   251→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   252→\t}\n   253→\tif resp.ErrorMessage != \"\" {\n   254→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   255→\t}\n   256→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   257→\tfor _, exec := range resp.StepExecutions {\n   258→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   259→\t}\n   260→}\n   261→\n   262→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   263→\tvar all bool\n   264→\tvar projectDir, stateFilter, issueFilter string\n   265→\tvar limit int32\n   266→\n   267→\tfor i := 0; i < len(args); i++ {\n   268→\t\tswitch args[i] {\n   269→\t\tcase \"--all\":\n   270→\t\t\tall = true\n   271→\t\tcase \"--project\", \"-p\":\n   272→\t\t\tif i+1 < len(args) {\n   273→\t\t\t\ti++\n   274→\t\t\t\tprojectDir = args[i]\n   275→\t\t\t}\n   276→\t\tcase \"--state\", \"-s\":\n   277→\t\t\tif i+1 < len(args) {\n   278→\t\t\t\ti++\n   279→\t\t\t\tstateFilter = args[i]\n   280→\t\t\t}\n   281→\t\tcase \"--limit\", \"-n\":\n   282→\t\t\tif i+1 < len(args) {\n   283→\t\t\t\ti++\n   284→\t\t\t\tn, err := strconv.Atoi(args[i])\n   285→\t\t\t\tif err != nil {\n   286→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   287→\t\t\t\t\tos.Exit(1)\n   288→\t\t\t\t}\n   289→\t\t\t\tlimit = int32(n)\n   290→\t\t\t}\n   291→\t\tcase \"--issue\", \"-i\":\n   292→\t\t\tif i+1 < len(args) {\n   293→\t\t\t\ti++\n   294→\t\t\t\tissueFilter = args[i]\n   295→\t\t\t}\n   296→\t\t}\n   297→\t}\n   298→\n   299→\treq := &pb.ListRunsRequest{\n   300→\t\tState:  stateFilter,\n   301→\t\tLimit:  limit,\n   302→\t\tTaskId: issueFilter,\n   303→\t}\n   304→\tif projectDir != \"\" {\n   305→\t\treq.ProjectDir = projectDir\n   306→\t} else if all {\n   307→\t\treq.All = true\n   308→\t} else {\n   309→\t\t// Default: filter to current project\n   310→\t\tcwd, _ := os.Getwd()\n   311→\t\treq.ProjectDir = cwd\n   312→\t}\n   313→\n   314→\tresp, err := client.ListRuns(ctx, req)\n   315→\tif err != nil {\n   316→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   317→\t\tos.Exit(1)\n   318→\t}\n   319→\n   320→\tif len(resp.Runs) == 0 {\n   321→\t\tfmt.Println(\"No runs found.\")\n   322→\t\treturn\n   323→\t}\n   324→\n   325→\tfor _, run := range resp.Runs {\n   326→\t\trunType := \"container\"\n   327→\t\tif run.IsHost {\n   328→\t\t\trunType = \"host\"\n   329→\t\t}\n   330→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   331→\t\tif run.Title != \"\" {\n   332→\t\t\tt := run.Title\n   333→\t\t\tif len(t) > 40 {\n   334→\t\t\t\tt = t[:37] + \"...\"\n   335→\t\t\t}\n   336→\t\t\tline += \"  \" + t\n   337→\t\t}\n   338→\t\tif run.ContainerId != \"\" {\n   339→\t\t\tline += \"  \" + run.ContainerId\n   340→\t\t}\n   341→\t\tif run.ErrorMessage != \"\" {\n   342→\t\t\terrMsg := run.ErrorMessage\n   343→\t\t\tif len(errMsg) > 60 {\n   344→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   345→\t\t\t}\n   346→\t\t\tline += \"  \" + errMsg\n   347→\t\t}\n   348→\t\tfmt.Println(line)\n   349→\t}\n   350→}\n   351→\n   352→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   353→\tif len(args) < 1 {\n   354→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n   355→\t\tos.Exit(1)\n   356→\t}\n   357→\n   358→\tvar stepFilter, typeFilter string\n   359→\tvar follow bool\n   360→\tvar limit int\n   361→\trunID := args[0]\n   362→\n   363→\tfor i := 1; i < len(args); i++ {\n   364→\t\tswitch args[i] {\n   365→\t\tcase \"--step\", \"-s\":\n   366→\t\t\tif i+1 < len(args) {\n   367→\t\t\t\ti++\n   368→\t\t\t\tstepFilter = args[i]\n   369→\t\t\t}\n   370→\t\tcase \"--type\":\n   371→\t\t\tif i+1 < len(args) {\n   372→\t\t\t\ti++\n   373→\t\t\t\ttypeFilter = args[i]\n   374→\t\t\t}\n   375→\t\tcase \"--follow\", \"-f\":\n   376→\t\t\tfollow = true\n   377→\t\tcase \"--limit\", \"-l\":\n   378→\t\t\tif i+1 < len(args) {\n   379→\t\t\t\ti++\n   380→\t\t\t\tn, err := strconv.Atoi(args[i])\n   381→\t\t\t\tif err != nil || n < 0 {\n   382→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n   383→\t\t\t\t\tos.Exit(1)\n   384→\t\t\t\t}\n   385→\t\t\t\tlimit = n\n   386→\t\t\t}\n   387→\t\t}\n   388→\t}\n   389→\n   390→\t// Use background context — log output can be large and follow mode blocks.\n   391→\tctx := context.Background()\n   392→\tvar mdPairs []string\n   393→\tif follow {\n   394→\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n   395→\t}\n   396→\tif limit > 0 {\n   397→\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n   398→\t}\n   399→\tif len(mdPairs) > 0 {\n   400→\t\tmd := metadata.Pairs(mdPairs...)\n   401→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   402→\t}\n   403→\n   404→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   405→\t\tRunId:    runID,\n   406→\t\tStepName: stepFilter,\n   407→\t\tLogType:  typeFilter,\n   408→\t})\n   409→\tif err != nil {\n   410→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   411→\t\tos.Exit(1)\n   412→\t}\n   413→\n   414→\tfor {\n   415→\t\tentry, err := stream.Recv()\n   416→\t\tif err != nil {\n   417→\t\t\tif errors.Is(err, io.EOF) {\n   418→\t\t\t\tbreak\n   419→\t\t\t}\n   420→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   421→\t\t\tos.Exit(1)\n   422→\t\t}\n   423→\n   424→\t\tswitch entry.Type {\n   425→\t\tcase \"step_started\":\n   426→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   427→\t\t\tif entry.Message != \"\" {\n   428→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   429→\t\t\t}\n   430→\t\tcase \"step_completed\":\n   431→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   432→\t\t\tif entry.Message != \"\" {\n   433→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   434→\t\t\t}\n   435→\t\tcase \"run_completed\":\n   436→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   437→\t\t\tif entry.Message != \"\" {\n   438→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   439→\t\t\t}\n   440→\t\tcase \"full_log\":\n   441→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   442→\t\tcase \"log\":\n   443→\t\t\t// Live-streamed log line from an active run.\n   444→\t\t\tfmt.Println(entry.Message)\n   445→\t\tdefault:\n   446→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   447→\t\t\tif entry.StepName != \"\" {\n   448→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   449→\t\t\t}\n   450→\t\t\tif entry.Message != \"\" {\n   451→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   452→\t\t\t}\n   453→\t\t}\n   454→\t}\n   455→}\n   456→\n   457→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   458→\tif len(args) < 1 {\n   459→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   460→\t\tos.Exit(1)\n   461→\t}\n   462→\n   463→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   464→\tif err != nil {\n   465→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   466→\t\tos.Exit(1)\n   467→\t}\n   468→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   469→}\n   470→\n   471→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   472→\tif len(args) < 1 {\n   473→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   474→\t\tos.Exit(1)\n   475→\t}\n   476→\n   477→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   478→\tif err != nil {\n   479→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   480→\t\tos.Exit(1)\n   481→\t}\n   482→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   483→}\n   484→\n   485→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   486→\tcwd, _ := os.Getwd()\n   487→\n   488→\t// Check for \"stop\" subcommand\n   489→\tif len(args) > 0 && args[0] == \"stop\" {\n   490→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   491→\t\tif err != nil {\n   492→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   493→\t\t\tos.Exit(1)\n   494→\t\t}\n   495→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   496→\t\treturn\n   497→\t}\n   498→\n   499→\t// Check for \"resume\" subcommand\n   500→\tif len(args) > 0 && args[0] == \"resume\" {\n   501→\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n   502→\t\tif err != nil {\n   503→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   504→\t\t\tos.Exit(1)\n   505→\t\t}\n   506→\t\tfmt.Println(\"Orchestration loop resumed.\")\n   507→\t\treturn\n   508→\t}\n   509→\n   510→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   511→\tvar maxConcurrent int32\n   512→\tfor i := 0; i < len(args); i++ {\n   513→\t\tswitch args[i] {\n   514→\t\tcase \"--max\":\n   515→\t\t\tif i+1 < len(args) {\n   516→\t\t\t\ti++\n   517→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   518→\t\t\t\tif n != 1 || err != nil {\n   519→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   520→\t\t\t\t\tos.Exit(1)\n   521→\t\t\t\t}\n   522→\t\t\t}\n   523→\t\t}\n   524→\t}\n   525→\n   526→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   527→\t\tProjectDir:    cwd,\n   528→\t\tMaxConcurrent: maxConcurrent,\n   529→\t})\n   530→\tif err != nil {\n   531→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   532→\t\tos.Exit(1)\n   533→\t}\n   534→\tif maxConcurrent > 0 {\n   535→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   536→\t} else {\n   537→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   538→\t}\n   539→}\n   540→\n   541→func cmdTasks(args []string) {\n   542→\t// Determine HTTP address from env\n   543→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   544→\tif httpAddr == \"\" {\n   545→\t\thttpAddr = \"localhost:8080\"\n   546→\t}\n   547→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   548→\n   549→\t// Determine project label from --project flag or current directory\n   550→\tprojectDir := \"\"\n   551→\tfor i := 0; i < len(args); i++ {\n   552→\t\tswitch args[i] {\n   553→\t\tcase \"--project\":\n   554→\t\t\tif i+1 < len(args) {\n   555→\t\t\t\ti++\n   556→\t\t\t\tprojectDir = args[i]\n   557→\t\t\t}\n   558→\t\t}\n   559→\t}\n   560→\n   561→\tif projectDir == \"\" {\n   562→\t\tcwd, _ := os.Getwd()\n   563→\t\tprojectDir = filepath.Base(cwd)\n   564→\t}\n   565→\n   566→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   567→\tresp, err := http.Get(tasksURL)\n   568→\tif err != nil {\n   569→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   570→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   571→\t\tos.Exit(1)\n   572→\t}\n   573→\tdefer resp.Body.Close()\n   574→\n   575→\tif resp.StatusCode != 200 {\n   576→\t\tbody, _ := io.ReadAll(resp.Body)\n   577→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   578→\t\tos.Exit(1)\n   579→\t}\n   580→\n   581→\ttype taskEntry struct {\n   582→\t\tID          string `json:\"id\"`\n   583→\t\tStatus      string `json:\"status\"`\n   584→\t\tTitle       string `json:\"title\"`\n   585→\t\tDescription string `json:\"description\"`\n   586→\t\tAssigned    bool   `json:\"assigned\"`\n   587→\t\tAssignedAt  string `json:\"assigned_at\"`\n   588→\t\tRunID       string `json:\"run_id\"`\n   589→\t}\n   590→\n   591→\tvar tasks []taskEntry\n   592→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   593→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   594→\t\tos.Exit(1)\n   595→\t}\n   596→\n   597→\tif len(tasks) == 0 {\n   598→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   599→\t\treturn\n   600→\t}\n   601→\n   602→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   603→\tfor _, t := range tasks {\n   604→\t\tstatus := t.Status\n   605→\t\tif status == \"\" {\n   606→\t\t\tstatus = \"open\"\n   607→\t\t}\n   608→\t\tassigned := \"-\"\n   609→\t\tif t.Assigned {\n   610→\t\t\tassigned = \"yes\"\n   611→\t\t}\n   612→\t\trunID := \"\"\n   613→\t\tif t.RunID != \"\" {\n   614→\t\t\trunID = t.RunID\n   615→\t\t\tif len(runID) > 30 {\n   616→\t\t\t\trunID = runID[:27] + \"...\"\n   617→\t\t\t}\n   618→\t\t}\n   619→\t\ttitle := t.Title\n   620→\t\tif len(title) > 40 {\n   621→\t\t\ttitle = title[:37] + \"...\"\n   622→\t\t}\n   623→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   624→\t}\n   625→}\n   626→\n   627→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   628→\tvar force bool\n   629→\tfor _, a := range args {\n   630→\t\tif a == \"-f\" || a == \"--force\" {\n   631→\t\t\tforce = true\n   632→\t\t}\n   633→\t}\n   634→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n   635→\tif err != nil {\n   636→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   637→\t\tos.Exit(1)\n   638→\t}\n   639→\tfmt.Println(\"Daemon shutting down.\")\n   640→}\n   641→\n   642→// resolveRunContext returns the project directory and run ID for context\n   643→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   644→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   645→func resolveRunContext() (projectDir, runID string, err error) {\n   646→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   647→\tif runID == \"\" {\n   648→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   649→\t}\n   650→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   651→\tif projectDir == \"\" {\n   652→\t\tprojectDir, err = os.Getwd()\n   653→\t\tif err != nil {\n   654→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   655→\t\t}\n   656→\t}\n   657→\treturn projectDir, runID, nil\n   658→}\n   659→\n   660→func cmdGet(args []string) {\n   661→\tif len(args) < 1 {\n   662→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   663→\t\tos.Exit(1)\n   664→\t}\n   665→\n   666→\tprojectDir, runID, err := resolveRunContext()\n   667→\tif err != nil {\n   668→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   669→\t\tos.Exit(1)\n   670→\t}\n   671→\n   672→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   673→\tif err != nil {\n   674→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   675→\t\tos.Exit(1)\n   676→\t}\n   677→\tif !ok {\n   678→\t\tos.Exit(1)\n   679→\t}\n   680→\tfmt.Println(val)\n   681→}\n   682→\n   683→func cmdSet(args []string) {\n   684→\tif len(args) < 2 {\n   685→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   686→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   687→\t\tos.Exit(1)\n   688→\t}\n   689→\n   690→\tprojectDir, runID, err := resolveRunContext()\n   691→\tif err != nil {\n   692→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   693→\t\tos.Exit(1)\n   694→\t}\n   695→\n   696→\tvalue := args[1]\n   697→\tif value == \"-\" {\n   698→\t\tdata, err := io.ReadAll(os.Stdin)\n   699→\t\tif err != nil {\n   700→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   701→\t\t\tos.Exit(1)\n   702→\t\t}\n   703→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   704→\t}\n   705→\n   706→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   707→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   708→\t\tos.Exit(1)\n   709→\t}\n   710→}\n   711→\n   712→func cmdVersion() {\n   713→\tcliVersion := version.Version()\n   714→\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   715→\n   716→\t// Try to get daemon version via gRPC\n   717→\tdaemonVersion := \"<unavailable>\"\n   718→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   719→\tif addr == \"\" {\n   720→\t\taddr = \"unix:///tmp/cloche.sock\"\n   721→\t}\n   722→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   723→\tif err == nil {\n   724→\t\tdefer conn.Close()\n   725→\t\tclient := pb.NewClocheServiceClient(conn)\n   726→\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   727→\t\tdefer cancel()\n   728→\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   729→\t\tif err == nil {\n   730→\t\t\tdaemonVersion = resp.Version\n   731→\t\t}\n   732→\t}\n   733→\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   734→\n   735→\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   736→\tagentVersion := \"<unavailable>\"\n   737→\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   738→\tif image == \"\" {\n   739→\t\timage = \"cloche-agent:latest\"\n   740→\t}\n   741→\tout, err := exec.CommandContext(\n   742→\t\tcontext.Background(),\n   743→\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   744→\t).Output()\n   745→\tif err == nil {\n   746→\t\tagentVersion = strings.TrimSpace(string(out))\n   747→\t\t// Strip \"cloche-agent \" prefix if present\n   748→\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n   749→\t}\n   750→\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n   751→\n   752→\t// Warn about version mismatches\n   753→\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n   754→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n   755→\t}\n   756→\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n   757→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n   758→\t}\n   759→}\n   760→"}]},"parent_tool_use_id":"toolu_01467VxunbiGscnpFJ4w3NNG","session_id":"0fd95967-c19b-48b1-b504-9ad5f3e0a46b","uuid":"e6a4c614-4751-40c7-9110-0aeff04ca78f"}
