{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V4zyznyS5XCGCJoJHJtrVc","type":"tool_result","content":"   300→\t\t\tcontinue // Don't persist; used during finalization\n   301→\t\tcase protocol.MsgRunCompleted:\n   302→\t\t\treportedResult = msg.Result\n   303→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   304→\t\t}\n   305→\n   306→\t\t_ = s.store.UpdateRun(ctx, run)\n   307→\t}\n   308→\treader.Close()\n   309→\n   310→\t// Signal live-stream subscribers that this run is done.\n   311→\tif s.logBroadcast != nil {\n   312→\t\ts.logBroadcast.Finish(runID)\n   313→\t}\n   314→\n   315→\t// Wait for process exit\n   316→\texitCode, err := s.container.Wait(ctx, containerID)\n   317→\tif err != nil {\n   318→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   319→\t}\n   320→\n   321→\t// Extract step output files from container before it's removed\n   322→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   323→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   324→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   325→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   326→\t\t}\n   327→\t}\n   328→\n   329→\t// Capture full container stdout/stderr before the container is removed\n   330→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   331→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   332→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   333→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   334→\t\t}\n   335→\t}\n   336→\n   337→\t// Index extracted log files in the log store\n   338→\tif s.logStore != nil {\n   339→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   340→\t}\n   341→\n   342→\t// Extract results to git branch BEFORE finalizing state, so that\n   343→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   344→\t// before the run is marked complete.\n   345→\tresultLabel := reportedResult\n   346→\tif resultLabel == \"\" {\n   347→\t\tif exitCode == 0 {\n   348→\t\t\tresultLabel = \"succeeded\"\n   349→\t\t} else {\n   350→\t\t\tresultLabel = \"failed\"\n   351→\t\t}\n   352→\t}\n   353→\t{\n   354→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   355→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   356→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   357→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   358→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   359→\t\t\t} else {\n   360→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   361→\t\t\t}\n   362→\t\t} else {\n   363→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   364→\t\t}\n   365→\t}\n   366→\n   367→\t// Now finalize run state\n   368→\trun, err := s.store.GetRun(ctx, runID)\n   369→\tif err != nil {\n   370→\t\treturn\n   371→\t}\n   372→\tif run.State == domain.RunStateRunning {\n   373→\t\tif reportedResult == \"succeeded\" {\n   374→\t\t\trun.Complete(domain.RunStateSucceeded)\n   375→\t\t} else if reportedResult != \"\" {\n   376→\t\t\tif reportedError != \"\" {\n   377→\t\t\t\trun.Fail(reportedError)\n   378→\t\t\t} else {\n   379→\t\t\t\trun.Complete(domain.RunStateFailed)\n   380→\t\t\t}\n   381→\t\t} else if exitCode == 0 {\n   382→\t\t\trun.Complete(domain.RunStateSucceeded)\n   383→\t\t} else {\n   384→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   385→\t\t}\n   386→\t\t_ = s.store.UpdateRun(ctx, run)\n   387→\t}\n   388→\n   389→\t// Fire evolution trigger if configured\n   390→\tif s.evolution != nil {\n   391→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   392→\t}\n   393→\n   394→\t// Merge is handled as a workflow step in host.cloche, not here.\n   395→\n   396→\t// Container retention policy:\n   397→\t// - Failed runs: always keep the container for debugging\n   398→\t// - Successful runs + --keep-container: keep the container\n   399→\t// - Successful runs without --keep-container: remove the container\n   400→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   401→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   402→\n   403→\tif keepContainer || runFailed {\n   404→\t\treason := \"--keep-container\"\n   405→\t\tif runFailed {\n   406→\t\t\treason = \"run failed\"\n   407→\t\t}\n   408→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   409→\t\tif runFinal != nil {\n   410→\t\t\trunFinal.ContainerKept = true\n   411→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   412→\t\t}\n   413→\t} else {\n   414→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   415→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   416→\t\t} else {\n   417→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   418→\t\t}\n   419→\t}\n   420→\n   421→\t// Cleanup mapping\n   422→\ts.mu.Lock()\n   423→\tdelete(s.runIDs, runID)\n   424→\ts.mu.Unlock()\n   425→}\n   426→\n   427→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   428→\tfilter := domain.RunListFilter{\n   429→\t\tProjectDir: req.ProjectDir,\n   430→\t\tState:      domain.RunState(req.State),\n   431→\t\tTaskID:     req.TaskId,\n   432→\t\tLimit:      int(req.Limit),\n   433→\t}\n   434→\n   435→\t// When no project filter and not --all, default to last hour\n   436→\tif filter.ProjectDir == \"\" && !req.All {\n   437→\t\tfilter.Since = time.Now().Add(-1 * time.Hour)\n   438→\t}\n   439→\n   440→\truns, err := s.store.ListRunsFiltered(ctx, filter)\n   441→\tif err != nil {\n   442→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   443→\t}\n   444→\n   445→\tresp := &pb.ListRunsResponse{}\n   446→\tfor _, run := range runs {\n   447→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   448→\t\t\tRunId:        run.ID,\n   449→\t\t\tWorkflowName: run.WorkflowName,\n   450→\t\t\tState:        string(run.State),\n   451→\t\t\tStartedAt:    run.StartedAt.String(),\n   452→\t\t\tErrorMessage: run.ErrorMessage,\n   453→\t\t\tContainerId:  run.ContainerID,\n   454→\t\t\tTitle:        run.Title,\n   455→\t\t\tIsHost:       run.IsHost,\n   456→\t\t\tProjectDir:   run.ProjectDir,\n   457→\t\t\tTaskId:       run.TaskID,\n   458→\t\t})\n   459→\t}\n   460→\treturn resp, nil\n   461→}\n   462→\n   463→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   464→\trun, err := s.store.GetRun(ctx, req.RunId)\n   465→\tif err != nil {\n   466→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   467→\t}\n   468→\n   469→\tresp := &pb.GetStatusResponse{\n   470→\t\tRunId:        run.ID,\n   471→\t\tWorkflowName: run.WorkflowName,\n   472→\t\tState:        string(run.State),\n   473→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   474→\t\tErrorMessage: run.ErrorMessage,\n   475→\t\tContainerId:  run.ContainerID,\n   476→\t\tTitle:        run.Title,\n   477→\t\tIsHost:       run.IsHost,\n   478→\t}\n   479→\n   480→\t// Check container liveness\n   481→\tif run.ContainerID != \"\" && s.container != nil {\n   482→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   483→\t\t\tresp.ContainerAlive = cs.Running\n   484→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   485→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   486→\t\t\t}\n   487→\t\t}\n   488→\t}\n   489→\n   490→\t// Load step executions from captures store if available\n   491→\tif s.captures != nil {\n   492→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   493→\t\tif err == nil {\n   494→\t\t\tfor _, exec := range captures {\n   495→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   496→\t\t\t\t\tStepName:    exec.StepName,\n   497→\t\t\t\t\tResult:      exec.Result,\n   498→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   499→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   500→\t\t\t\t})\n   501→\t\t\t}\n   502→\t\t}\n   503→\t} else {\n   504→\t\tfor _, exec := range run.StepExecutions {\n   505→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   506→\t\t\t\tStepName:    exec.StepName,\n   507→\t\t\t\tResult:      exec.Result,\n   508→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   509→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   510→\t\t\t})\n   511→\t\t}\n   512→\t}\n   513→\n   514→\treturn resp, nil\n   515→}\n   516→\n   517→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   518→\tctx := stream.Context()\n   519→\n   520→\t_ = followFromContext(ctx) // follow is implicit for active runs\n   521→\tlimit := limitFromContext(ctx)\n   522→\n   523→\t// Verify run exists\n   524→\trun, err := s.store.GetRun(ctx, req.RunId)\n   525→\tif err != nil {\n   526→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   527→\t}\n   528→\n   529→\t// If step_name or log_type filter is set, serve content directly from the log index\n   530→\tif req.StepName != \"\" || req.LogType != \"\" {\n   531→\t\treturn s.streamFilteredLogs(ctx, req, run, stream, limit)\n   532→\t}\n   533→\n   534→\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n   535→\n   536→\t// Active runs always stream live output (follow mode is implicit).\n   537→\t// The -f flag is accepted but redundant for active runs.\n   538→\tif isActive && s.logBroadcast != nil {\n   539→\t\treturn s.streamFollowLogs(req.RunId, run, stream, limit)\n   540→\t}\n   541→\n   542→\t// Check for full.log first — if it exists, serve it as the unified log\n   543→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   544→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   545→\t\tmsg := applyLimit(string(data), limit)\n   546→\t\tif err := stream.Send(&pb.LogEntry{\n   547→\t\t\tType:    \"full_log\",\n   548→\t\t\tMessage: msg,\n   549→\t\t}); err != nil {\n   550→\t\t\treturn err\n   551→\t\t}\n   552→\t\tif !isActive {\n   553→\t\t\tif err := stream.Send(&pb.LogEntry{\n   554→\t\t\t\tType:      \"run_completed\",\n   555→\t\t\t\tResult:    string(run.State),\n   556→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   557→\t\t\t\tMessage:   run.ErrorMessage,\n   558→\t\t\t}); err != nil {\n   559→\t\t\t\treturn err\n   560→\t\t\t}\n   561→\t\t}\n   562→\t\treturn nil\n   563→\t}\n   564→\n   565→\tif s.captures == nil {\n   566→\t\treturn fmt.Errorf(\"captures store not configured\")\n   567→\t}\n   568→\n   569→\t// Fall back to capture-based streaming\n   570→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   571→\tif err != nil {\n   572→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   573→\t}\n   574→\n   575→\tfor _, exec := range captures {\n   576→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   577→\t\t// and one for step_completed (has Result).\n   578→\t\tif exec.Result == \"\" {\n   579→\t\t\tentry := &pb.LogEntry{\n   580→\t\t\t\tType:      \"step_started\",\n   581→\t\t\t\tStepName:  exec.StepName,\n   582→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   583→\t\t\t}\n   584→\t\t\tif err := stream.Send(entry); err != nil {\n   585→\t\t\t\treturn err\n   586→\t\t\t}\n   587→\t\t} else {\n   588→\t\t\t// Read step output from per-step output file.\n   589→\t\t\t// Container runs write .log, host runs write .out — try both.\n   590→\t\t\tvar output string\n   591→\t\t\tfor _, ext := range []string{\".log\", \".out\"} {\n   592→\t\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+ext)\n   593→\t\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   594→\t\t\t\t\toutput = string(data)\n   595→\t\t\t\t\tbreak\n   596→\t\t\t\t}\n   597→\t\t\t}\n   598→\t\t\tentry := &pb.LogEntry{\n   599→\t\t\t\tType:      \"step_completed\","}]},"parent_tool_use_id":"toolu_01SyKs3xQqMBueW7mcyz65pv","session_id":"85615324-ec9e-4511-9465-2c631732f71f","uuid":"f9641c8a-57fd-4a07-af5e-5b65d8962942"}
