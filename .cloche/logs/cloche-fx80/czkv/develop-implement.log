 64→\t// Config settings.\n    65→\tfmt.Println(\"Config:\")\n    66→\tfmt.Printf(\"  active:             %v\\n\", resp.Active)\n    67→\tfmt.Printf(\"  concurrency:        %d\\n\", resp.Concurrency)\n    68→\tif resp.StaggerSeconds > 0 {\n    69→\t\tfmt.Printf(\"  stagger_seconds:    %.1f\\n\", resp.StaggerSeconds)\n    70→\t}\n    71→\tif resp.DedupSeconds > 0 {\n    72→\t\tfmt.Printf(\"  dedup_seconds:      %.0f\\n\", resp.DedupSeconds)\n    73→\t}\n    74→\tfmt.Printf(\"  stop_on_error:      %v\\n\", resp.StopOnError)\n    75→\tfmt.Printf(\"  evolution:          %v\\n\", resp.EvolutionEnabled)\n    76→\tfmt.Println()\n    77→\n    78→\t// Orchestrator loop state.\n    79→\tloopState := \"stopped\"\n    80→\tif resp.LoopRunning {\n    81→\t\tif resp.ErrorHalted {\n    82→\t\t\tloopState = \"halted\"\n    83→\t\t} else {\n    84→\t\t\tloopState = \"running\"\n    85→\t\t}\n    86→\t}\n    87→\tfmt.Printf(\"Loop:        %s\\n\", loopState)\n    88→\tif resp.ErrorHalted {\n    89→\t\tfmt.Printf(\"Halt error:  %s\\n\", resp.HaltError)\n    90→\t}\n    91→\tfmt.Println()\n    92→\n    93→\t// Active runs.\n    94→\tif len(resp.ActiveRuns) > 0 {\n    95→\t\tfmt.Printf(\"Active runs: %d\\n\", len(resp.ActiveRuns))\n    96→\t\tfor _, run := range resp.ActiveRuns {\n    97→\t\t\trunType := \"container\"\n    98→\t\t\tif run.IsHost {\n    99→\t\t\t\trunType = \"host\"\n   100→\t\t\t}\n   101→\t\t\tline := fmt.Sprintf(\"  %s  %-20s  %-10s  %s\", run.RunId, run.WorkflowName, run.State, runType)\n   102→\t\t\tif run.Title != \"\" {\n   103→\t\t\t\tt := run.Title\n   104→\t\t\t\tif len(t) > 40 {\n   105→\t\t\t\t\tt = t[:37] + \"...\"\n   106→\t\t\t\t}\n   107→\t\t\t\tline += \"  \" + t\n   108→\t\t\t}\n   109→\t\t\tfmt.Println(line)\n   110→\t\t}\n   111→\t} else {\n   112→\t\tfmt.Println(\"Active runs: none\")\n   113→\t}\n   114→\tfmt.Println()\n   115→\n   116→\t// Workflows.\n   117→\tif len(resp.ContainerWorkflows) > 0 {\n   118→\t\tfmt.Println(\"Container workflows:\")\n