t.want {\n    65→\t\t\tt.Errorf(\"isTerminalState(%q) = %v, want %v\", tt.state, got, tt.want)\n    66→\t\t}\n    67→\t}\n    68→}\n    69→\n    70→func TestCmdPollMulti_AllSucceeded(t *testing.T) {\n    71→\tclient := newMockClient()\n    72→\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n    73→\t\t{RunId: \"run1\", State: \"running\"},\n    74→\t\t{RunId: \"run1\", State: \"succeeded\"},\n    75→\t}\n    76→\tclient.statuses[\"run2\"] = []*pb.GetStatusResponse{\n    77→\t\t{RunId: \"run2\", State: \"running\"},\n    78→\t\t{RunId: \"run2\", State: \"running\"},\n    79→\t\t{RunId: \"run2\", State: \"succeeded\"},\n    80→\t}\n    81→\n    82→\tvar stdout, stderr bytes.Buffer\n    83→\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n    84→\n    85→\tif exitCode != 0 {\n    86→\t\tt.Errorf(\"expected exit code 0, got %d\", exitCode)\n    87→\t}\n    88→\n    89→\toutput := stdout.String()\n    90→\tif !strings.Contains(output, \"run1: \") {\n    91→\t\tt.Error(\"output should contain status for run1\")\n    92→\t}\n    93→\tif !strings.Contains(output, \"run2: \") {\n    94→\t\tt.Error(\"output should contain status for run2\")\n    95→\t}\n    96→\tif !strings.Contains(output, \"succeeded\") {\n    97→\t\tt.Error(\"output should show succeeded state\")\n    98→\t}\n    99→}\n   100→\n   101→func TestCmdPollMulti_OneFailed(t *testing.T) {\n   102→\tclient := newMockClient()\n   103→\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n   104→\t\t{RunId: \"run1\", State: \"succeeded\"},\n   105→\t}\n   106→\tclient.statuses[\"run2\"] = []*pb.GetStatusResponse{\n   107→\t\t{RunId: \"run2\", State: \"failed\"},\n   108→\t}\n   109→\n   110→\tvar stdout, stderr bytes.Buffer\n   111→\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n   112→\n   113→\tif exitCode != 1 {\n   114→\t\tt.Errorf(\"expected exit code 1 when a run failed, got %d\", exitCode)\n   115→\t}\n   116→}\n   117→\n   118→func