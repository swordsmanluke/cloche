{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DXBPmbahE9rqKTTdFsFVzy","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"os/exec\"\n     9→\t\"strings\"\n    10→)\n    11→\n    12→// TaskStatus represents the state of a task from a task tracker.\n    13→type TaskStatus string\n    14→\n    15→const (\n    16→\tTaskStatusOpen       TaskStatus = \"open\"\n    17→\tTaskStatusClosed     TaskStatus = \"closed\"\n    18→\tTaskStatusInProgress TaskStatus = \"in-progress\"\n    19→)\n    20→\n    21→// Task represents a work item from an external task tracker.\n    22→type Task struct {\n    23→\tID          string            `json:\"id\"`\n    24→\tStatus      string            `json:\"status\"`\n    25→\tTitle       string            `json:\"title\"`\n    26→\tDescription string            `json:\"description\"`\n    27→\tMetadata    map[string]string `json:\"metadata,omitempty\"`\n    28→}\n    29→\n    30→// IsOpen returns true if the task status is \"open\" or empty (for backward compatibility).\n    31→func (t Task) IsOpen() bool {\n    32→\treturn t.Status == \"\" || TaskStatus(t.Status) == TaskStatusOpen\n    33→}\n    34→\n    35→// TaskAssigner lists available tasks for the daemon to assign to workflow runs.\n    36→type TaskAssigner interface {\n    37→\tListTasks(ctx context.Context, projectDir string) ([]Task, error)\n    38→}\n    39→\n    40→// ScriptTaskAssigner runs a shell command to list tasks and parses the JSON output.\n    41→// The command should output a JSON array of objects with at least an \"id\" field.\n    42→type ScriptTaskAssigner struct {\n    43→\tCommand string // shell command to run (e.g., \"bash .cloche/scripts/ready-tasks.sh\")\n    44→}\n    45→\n    46→// ListTasks executes the configured command from the project directory and\n    47→// parses its stdout as a JSON array of Task objects.\n    48→func (s *ScriptTaskAssigner) ListTasks(ctx context.Context, projectDir string) ([]Task, error) {\n    49→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", s.Command)\n    50→\tcmd.Dir = MainWorktreeDir(projectDir)\n    51→\n    52→\tout, err := cmd.Output()\n    53→\tif err != nil {\n    54→\t\treturn nil, fmt.Errorf(\"running list-tasks command: %w\", err)\n    55→\t}\n    56→\n    57→\toutput := strings.TrimSpace(string(out))\n    58→\tif output == \"\" || output == \"[]\" {\n    59→\t\treturn nil, nil\n    60→\t}\n    61→\n    62→\tvar tasks []Task\n    63→\tif err := json.Unmarshal([]byte(output), &tasks); err != nil {\n    64→\t\treturn nil, fmt.Errorf(\"parsing list-tasks output: %w\", err)\n    65→\t}\n    66→\treturn tasks, nil\n    67→}\n    68→\n    69→// ParseTasksJSONL parses JSONL-formatted task output (one JSON object per line).\n    70→// Each line should have at least an \"id\" field. Lines that are empty or fail to\n    71→// parse are skipped.\n    72→func ParseTasksJSONL(data string) ([]Task, error) {\n    73→\tvar tasks []Task\n    74→\tscanner := bufio.NewScanner(strings.NewReader(data))\n    75→\tlineNum := 0\n    76→\tfor scanner.Scan() {\n    77→\t\tlineNum++\n    78→\t\tline := strings.TrimSpace(scanner.Text())\n    79→\t\tif line == \"\" {\n    80→\t\t\tcontinue\n    81→\t\t}\n    82→\t\tvar task Task\n    83→\t\tif err := json.Unmarshal([]byte(line), &task); err != nil {\n    84→\t\t\treturn nil, fmt.Errorf(\"parsing JSONL line %d: %w\", lineNum, err)\n    85→\t\t}\n    86→\t\ttasks = append(tasks, task)\n    87→\t}\n    88→\treturn tasks, nil\n    89→}\n    90→"}]},"parent_tool_use_id":"toolu_01SyKs3xQqMBueW7mcyz65pv","session_id":"85615324-ec9e-4511-9465-2c631732f71f","uuid":"00570ca1-416a-4d55-9314-2a6489df2c2d"}
