elp(\"health\")\n    63→\t\t\treturn\n    64→\t\t}\n    65→\t\tcmdHealth(os.Args[2:])\n    66→\t\treturn\n    67→\tcase \"get\":\n    68→\t\tif hasHelpFlag(os.Args[2:]) {\n    69→\t\t\tprintSubcommandHelp(\"get\")\n    70→\t\t\treturn\n    71→\t\t}\n    72→\t\tcmdGet(os.Args[2:])\n    73→\t\treturn\n    74→\tcase \"set\":\n    75→\t\tif hasHelpFlag(os.Args[2:]) {\n    76→\t\t\tprintSubcommandHelp(\"set\")\n    77→\t\t\treturn\n    78→\t\t}\n    79→\t\tcmdSet(os.Args[2:])\n    80→\t\treturn\n    81→\tcase \"tasks\":\n    82→\t\tif hasHelpFlag(os.Args[2:]) {\n    83→\t\t\tprintSubcommandHelp(\"tasks\")\n    84→\t\t\treturn\n    85→\t\t}\n    86→\t\tcmdTasks(os.Args[2:])\n    87→\t\treturn\n    88→\tcase \"workflow\":\n    89→\t\tif hasHelpFlag(os.Args[2:]) {\n    90→\t\t\tprintSubcommandHelp(\"workflow\")\n    91→\t\t\treturn\n    92→\t\t}\n    93→\t\tcmdWorkflow(os.Args[2:])\n    94→\t\treturn\n    95→\tcase \"project\":\n    96→\t\tif hasHelpFlag(os.Args[2:]) {\n    97→\t\t\tprintSubcommandHelp(\"project\")\n    98→\t\t\treturn\n    99→\t\t}\n   100→\t\tcmdProject(os.Args[2:])\n   101→\t\treturn\n   102→\tcase \"validate\":\n   103→\t\tif hasHelpFlag(os.Args[2:]) {\n   104→\t\t\tprintSubcommandHelp(\"validate\")\n   105→\t\t\treturn\n   106→\t\t}\n   107→\t\tcmdValidate(os.Args[2:])\n   108→\t\treturn\n   109→\t}\n   110→\n   111→\t// Handle --help for daemon commands before connecting\n   112→\tdaemonCmds := map[string]bool{\n   113→\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n   114→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n   115→\t}\n   116→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n   117→\t\tprintSubcommandHelp(os.Args[1])\n   118→\t\treturn\n   119→\t}\n   120→\n   121→\t// Commands that need a daemon connection\n   122→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   123→\tif addr == \"\" {\n   124→\t\taddr = config.DefaultSocketAddr()\n   125→\t}\n   126→\n   127→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   128→\tif err != nil {\n   129→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   130→\t\tos.Exit(1)\n   131→\t}\n   132→\tdefer conn.Close()\n   133→\n   134→\tclient := pb.NewClocheServiceClient(conn)\n   135→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   136→\tdefer cancel()\n   137→\n   138→\tswitch os.Args[1] {\n   139→\tcase \"run\":\n   140→\t\tcmdRun(ctx, client, os.Args[2:])\n   141→\tcase \"status\":\n   142→\t\tcmdStatus(ctx, client, os.Args[2:])\n   143→\tcase \"logs\":\n   144→\t\tcmdLogs(client, os.Args[2:])\n   145→\tcase \"poll\":\n   146→\t\tcmdPoll(client, os.Args[2:])\n   147→\tcase \"list\":\n   148→\t\tcmdList(ctx, client, os.Args[2:])\n   149→\tcase \"stop\":\n   150→\t\tcmdStop(ctx, client, os.Args[2:])\n   151→\tcase \"delete\":\n   152→\t\tcmdDelete(ctx, client, os.Args[2:])\n   153→\tcase \"loop\":\n   154→\t\tcmdLoop(ctx, client, os.Args[2:])\n   155→\tcase \"shutdown\":\n   156→\t\tcmdShutdown(ctx, client, os.Args[2:])\n   157→\tdefault:\n   158→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   159→\t\tprintTopLevelHelp()\n   160→\t\tos.Exit(1)\n   161→\t}\n   162→}\n   163→\n   164→\n   165→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   166→\tvar workflow, prompt, title, issueID string\n   167→\tvar keepContainer bool\n   168→\n   169→\tfor i := 0; i < len(args); i++ {\n   170→\t\tswitch args[i] {\n   171→\t\tcase \"--workflow\":\n   172→\t\t\tif i+1 < len(args) {\n   173→\t\t\t\ti++\n   174→\t\t\t\tworkflow = args[i]\n   175→\t\t\t}\n   176→\t\tcase \"--prompt\", \"-p\":\n   177→\t\t\tif i+1 < len(args) {\n   178→\t\t\t\ti++\n   179→\t\t\t\tprompt = args[i]\n   180→\t\t\t}\n   181→\t\tcase \"--title\":\n   182→\t\t\tif i+1 < len(args) {\n   183→\t\t\t\ti++\n   184→\t\t\t\ttitle = args[i]\n   185→\t\t\t}\n   186→\t\tcase \"--issue\", \"-i\":\n   187→\t\t\tif i+1 < len(args) {\n   188→\t\t\t\ti++\n   189→\t\t\t\tissueID = args[i]\n   190→\t\t\t}\n   191→\t\tcase \"--keep-container\":\n   192→\t\t\tkeepContainer = true\n   193→\t\tdefault:\n   194→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   195→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   196→\t\t\t\tworkflow = args[i]\n   197→\t\t\t}\n   198→\t\t}\n   199→\t}\n   200→\n   201→\tif workflow == \"\" {\n   202→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"] [--issue ID]\\n\")\n   203→\t\tos.Exit(1)\n   204→\t}\n   205→\n   206→\tcwd, _ := os.Getwd()\n   207→\n   208→\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n   209→\t// Try loading from any .cloche file; only extract image for container workflows.\n   210→\tvar image string\n   211→\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n   212→\t\timage = wf.Config[\"container.image\"]\n   213→\t}\n   214→\n   215→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   216→\t\tWorkflowName:  workflow,\n   217→\t\tProjectDir:    cwd,\n   218→\t\tImage:         image,\n   219→\t\tPrompt:        prompt,\n   220→\t\tKeepContainer: keepContainer,\n   221→\t\tTitle:         title,\n   222→\t\tIssueId:       issueID,\n   223→\t})\n   224→\tif err != nil {\n   225→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   226→\t\tos.Exit(1)\n   227→\t}\n   228→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   229→}\n   230→\n   231→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   232→\tif len(args) < 1 {\n   233→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   234→\t\tos.Exit(1)\n   235→\t}\n   236→\n   237→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   238→\tif err != nil {\n   239→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   240→\t\tos.Exit(1)\n   241→\t}\n   242→\n   243→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   244→\tif resp.Title != \"\" {\n   245→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   246→\t}\n   247→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   248→\tif resp.IsHost {\n   249→\t\tfmt.Printf(\"Type:      host\\n\")\n   250→\t} else {\n   251→\t\tfmt.Printf(\"Type:      container\\n\")\n   252→\t}\n   253→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   254→\tif resp.ContainerId != \"\" {\n   255→\t\tcid := resp.ContainerId\n   256→\t\tif len(cid) > 12 {\n   257→\t\t\tcid = cid[:12]\n   258→\t\t}\n   259→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   260→\t}\n   261→\tif resp.ErrorMessage != \"\" {\n   262→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   263→\t}\n   264→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   265→\tfor _, exec := range resp.StepExecutions {\n   266→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   267→\t}\n   268→}\n   269→\n   270→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   271→\tvar all bool\n   272→\tvar projectDir, stateFilter, issueFilter string\n   273→\tvar limit int32\n   274→\n   275→\tfor i := 0; i < len(args); i++ {\n   276→\t\tswitch args[i] {\n   277→\t\tcase \"--all\":\n   278→\t\t\tall = true\n   279→\t\tcase \"--project\", \"-p\":\n   280→\t\t\tif i+1 < len(args) {\n   281→\t\t\t\ti++\n   282→\t\t\t\tprojectDir = args[i]\n   283→\t\t\t}\n   284→\t\tcase \"--state\", \"-s\":\n   285→\t\t\tif i+1 < len(args) {\n   286→\t\t\t\ti++\n   287→\t\t\t\tstateFilter = args[i]\n   288→\t\t\t}\n   289→\t\tcase \"--limit\", \"-n\":\n   290→\t\t\tif i+1 < len(args) {\n   291→\t\t\t\ti++\n   292→\t\t\t\tn, err := strconv.Atoi(args[i])\n   293→\t\t\t\tif err != nil {\n   294→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   295→\t\t\t\t\tos.Exit(1)\n   296→\t\t\t\t}\n   297→\t\t\t\tlimit = int32(n)\n   298→\t\t\t}\n   299→\t\tcase \"--issue\", \"-i\":\n   300→\t\t\tif i+1 < len(args) {\n   301→\t\t\t\ti++\n   302→\t\t\t\tissueFilter = args[i]\n   303→\t\t\t}\n   304→\t\t}\n   305→\t}\n   306→\n   307→\treq := &pb.ListRunsRequest{\n   308→\t\tState:  stateFilter,\n   309→\t\tLimit:  limit,\n   310→\t\tTaskId: issueFilter,\n   311→\t}\n   312→\tif projectDir != \"\" {\n   313→\t\treq.ProjectDir = projectDir\n   314→\t} else if all {\n   315→\t\treq.All = true\n   316→\t} else {\n   317→\t\t// Default: filter to current project\n   318→\t\tcwd, _ := os.Getwd()\n   319→\t\treq.ProjectDir = cwd\n   320→\t}\n   321→\n   322→\tresp, err := client.ListRuns(ctx, req)\n   323→\tif err != nil {\n   324→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   325→\t\tos.Exit(1)\n   326→\t}\n   327→\n   328→\tif len(resp.Runs) == 0 {\n   329→\t\tfmt.Println(\"No runs found.\")\n   330→\t\treturn\n   331→\t}\n   332→\n   333→\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n   334→\tfmt.Fprintln(w, \"RUN ID\\tWORKFLOW\\tSTATE\\tTYPE\\tTASK ID\\tTITLE\\tCONTAINER\\tERROR\")\n   335→\tfor _, run := range resp.Runs {\n   336→\t\trunType := \"container\"\n   337→\t\tif run.IsHost {\n   338→\t\t\trunType = \"host\"\n   339→\t\t}\n   340→\t\ttitle := run.Title\n   341→\t\tif len(title) > 40 {\n   342→\t\t\ttitle = title[:37] + \"...\"\n   343→\t\t}\n   344→\t\terrMsg := run.ErrorMessage\n   345→\t\tif len(errMsg) > 60 {\n   346→\t\t\terrMsg = errMsg[:57] + \"...\"\n   347→\t\t}\n   348→\t\tfmt.Fprintf(w, \"%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\n\",\n   349→\t\t\trun.RunId, run.WorkflowName, run.State, runType,\n   350→\t\t\trun.TaskId, title, run.ContainerId, errMsg)\n   351→\t}\n   352→\tw.Flush()\n   353→}\n   354→\n   355→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   356→\tif len(args) < 1 {\n   357→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n   358→\t\tos.Exit(1)\n   359→\t}\n   360→\n   361→\tvar stepFilter, typeFilter string\n   362→\tvar follow bool\n   363→\tvar limit int\n   364→\trunID := args[0]\n   365→\n   366→\tfor i := 1; i < len(args); i++ {\n   367→\t\tswitch args[i] {\n   368→\t\tcase \"--step\", \"-s\":\n   369→\t\t\tif i+1 < len(args) {\n   370→\t\t\t\ti++\n   371→\t\t\t\tstepFilter = args[i]\n   372→\t\t\t}\n   373→\t\tcase \"--type\":\n   374→\t\t\tif i+1 < len(args) {\n   375→\t\t\t\ti++\n   376→\t\t\t\ttypeFilter = args[i]\n   377→\t\t\t}\n   378→\t\tcase \"--follow\", \"-f\":\n   379→\t\t\tfollow = true\n   380→\t\tcase \"--limit\", \"-l\":\n   381→\t\t\tif i+1 < len(args) {\n   382→\t\t\t\ti++\n   383→\t\t\t\tn, err := strconv.Atoi(args[i])\n   384→\t\t\t\tif err != nil || n < 0 {\n   385→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n   386→\t\t\t\t\tos.Exit(1)\n   387→\t\t\t\t}\n   388→\t\t\t\tlimit = n\n   389→\t\t\t}\n   390→\t\t}\n   391→\t}\n   392→\n   393→\t// Use background context — log output can be large and follow mode blocks.\n   394→\tctx := context.Background()\n   395→\tvar mdPairs []string\n   396→\tif follow {\n   397→\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n   398→\t}\n   399→\tif limit > 0 {\n   400→\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n   401→\t}\n   402→\tif len(mdPairs) > 0 {\n   403→\t\tmd := metadata.Pairs(mdPairs...)\n   404→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   405→\t}\n   406→\n   407→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   408→\t\tRunId:    runID,\n   409→\t\tStepName: stepFilter,\n   410→\t\tLogType:  typeFilter,\n   411→\t})\n   412→\tif err != nil {\n   413→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   414→\t\tos.Exit(1)\n   415→\t}\n   416→\n   417→\tfor {\n   418→\t\tentry, err := stream.Recv()\n   419→\t\tif err != nil {\n   420→\t\t\tif errors.Is(err, io.EOF) {\n   421→\t\t\t\tbreak\n   422→\t\t\t}\n   423→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   424→\t\t\tos.Exit(1)\n   425→\t\t}\n   426→\n   427→\t\tswitch entry.Type {\n   428→\t\tcase \"step_started\":\n   429→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   430→\t\t\tif entry.Message != \"\" {\n   431→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   432→\t\t\t}\n   433→\t\tcase \"step_completed\":\n   434→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   435→\t\t\tif entry.Message != \"\" {\n   436→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   437→\t\t\t}\n   438→\t\tcase \"run_completed\":\n   439→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   440→\t\t\tif entry.Message != \"\" {\n   441→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   442→\t\t\t}\n   443→\t\tcase \"full_log\":\n   444→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   445→\t\tcase \"log\":\n   446→\t\t\t// Live-streamed log line from an active run.\n   447→\t\t\tfmt.Println(entry.Message)\n   448→\t\tdefault:\n   449→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   450→\t\t\tif entry.StepName != \"\" {\n   451→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   452→\t\t\t}\n   453→\t\t\tif entry.Message != \"\" {\n   454→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   455→\t\t\t}\n   456→\t\t}\n   457→\t}\n   458→}\n   459→\n   460→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   461→\tif len(args) < 1 {\n   462→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   463→\t\tos.Exit(1)\n   464→\t}\n   465→\n   466→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   467→\tif err != nil {\n   468→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   469→\t\tos.Exit(1)\n   470→\t}\n   471→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   472→}\n   473→\n   474→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   475→\tif len(args) < 1 {\n   476→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   477→\t\tos.Exit(1)\n   478→\t}\n   479→\n   480→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   481→\tif err != nil {\n   482→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   483→\t\tos.Exit(1)\n   484→\t}\n   485→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   486→}\n   487→\n   488→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   489→\tcwd, _ := os.Getwd()\n   490→\n   491→\t// Check for \"stop\" subcommand\n   492→\tif len(args) > 0 && args[0] == \"stop\" {\n   493→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   494→\t\tif err != nil {\n   495→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   496→\t\t\tos.Exit(1)\n   497→\t\t}\n   498→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   499→\t\treturn\n   500→\t}\n   501→\n   502→\t// Check for \"resume\" subcommand\n   503→\tif len(args) > 0 && args[0] == \"resume\" {\n   504→\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n   505→\t\tif err != nil {\n   506→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   507→\t\t\tos.Exit(1)\n   508→\t\t}\n   509→\t\tfmt.Println(\"Orchestration loop resumed.\")\n   510→\t\treturn\n   511→\t}\n   512→\n   513→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   514→\tvar maxConcurrent int32\n   515→\tfor i := 0; i < len(args); i++ {\n   516→\t\tswitch args[i] {\n   517→\t\tcase \"--max\":\n   518→\t\t\tif i+1 < len(args) {\n   519→\t\t\t\ti++\n   520→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   521→\t\t\t\tif n != 1 || err != nil {\n   522→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   523→\t\t\t\t\tos.Exit(1)\n   524→\t\t\t\t}\n   525→\t\t\t}\n   526→\t\t}\n   527→\t}\n   528→\n   529→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   530→\t\tProjectDir:    cwd,\n   531→\t\tMaxConcurrent: maxConcurrent,\n   532→\t})\n   533→\tif err != nil {\n   534→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   535→\t\tos.Exit(1)\n   536→\t}\n   537→\tif maxConcurrent > 0 {\n   538→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   539→\t} else {\n   540→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   541→\t}\n   542→}\n   543→\n   544→func cmdTasks(args []string) {\n   545→\t// Determine HTTP address from env\n   546→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   547→\tif httpAddr == \"\" {\n   548→\t\thttpAddr = \"localhost:8080\"\n   549→\t}\n   550→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   551→\n   552→\t// Determine project label from --project flag or current directory\n   553→\tprojectDir := \"\"\n   554→\tfor i := 0; i < len(args); i++ {\n   555→\t\tswitch args[i] {\n   556→\t\tcase \"--project\":\n   557→\t\t\tif i+1 < len(args) {\n   558→\t\t\t\ti++\n   559→\t\t\t\tprojectDir = args[i]\n   560→\t\t\t}\n   561→\t\t}\n   562→\t}\n   563→\n   564→\tif projectDir == \"\" {\n   565→\t\tcwd, _ := os.Getwd()\n   566→\t\tprojectDir = filepath.Base(cwd)\n   567→\t}\n   568→\n   569→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   570→\tresp, err := http.Get(tasksURL)\n   571→\tif err != nil {\n   572→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   573→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   574→\t\tos.Exit(1)\n   575→\t}\n   576→\tdefer resp.Body.Close()\n   577→\n   578→\tif resp.StatusCode != 200 {\n   579→\t\tbody, _ := io.ReadAll(resp.Body)\n   580→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   581→\t\tos.Exit(1)\n   582→\t}\n   583→\n   584→\ttype taskEntry struct {\n   585→\t\tID          string `json:\"id\"`\n   586→\t\tStatus      string `json:\"status\"`\n   587→\t\tTitle       string `json:\"title\"`\n   588→\t\tDescription string `json:\"description\"`\n   589→\t\tAssigned    bool   `json:\"assigned\"`\n   590→\t\tAssignedAt  string `json:\"assigned_at\"`\n   591→\t\tRunID       string `json:\"run_id\"`\n   592→\t}\n   593→\n   594→\tvar tasks []taskEntry\n   595→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   596→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   597→\t\tos.Exit(1)\n   598→\t}\n   599→\n   600→\tif len(tasks) == 0 {\n   601→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   602→\t\treturn\n   603→\t}\n   604→\n   605→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   606→\tfor _, t := range tasks {\n   607→\t\tstatus := t.Status\n   608→\t\tif status == \"\" {\n   609→\t\t\tstatus = \"open\"\n   610→\t\t}\n   611→\t\tassigned := \"-\"\n   612→\t\tif t.Assigned {\n   613→\t\t\tassigned = \"yes\"\n   614→\t\t}\n   615→\t\trunID := \"\"\n   616→\t\tif t.RunID != \"\" {\n   617→\t\t\trunID = t.RunID\n   618→\t\t\tif len(runID) > 30 {\n   619→\t\t\t\trunID = runID[:27] + \"...\"\n   620→\t\t\t}\n   621→\t\t}\n   622→\t\ttitle := t.Title\n   623→\t\tif len(title) > 40 {\n   624→\t\t\ttitle = title[:37] + \"...\"\n   625→\t\t}\n   626→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   627→\t}\n   628→}\n   629→\n   630→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   631→\tvar force bool\n   632→\tfor _, a := range args {\n   633→\t\tif a == \"-f\" || a == \"--force\" {\n   634→\t\t\tforce = true\n   635→\t\t}\n   636→\t}\n   637→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n   638→\tif err != nil {\n   639→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   640→\t\tos.Exit(1)\n   641→\t}\n   642→\tfmt.Println(\"Daemon shutting down.\")\n   643→}\n   644→\n   645→// resolveRunContext returns the project directory and run ID for context\n   646→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   647→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   648→func resolveRunContext() (projectDir, runID string, err error) {\n   649→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   650→\tif runID == \"\" {\n   651→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   652→\t}\n   653→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   654→\tif projectDir == \"\" {\n   655→\t\tprojectDir, err = os.Getwd()\n   656→\t\tif err != nil {\n   657→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   658→\t\t}\n   659→\t}\n   660→\treturn projectDir, runID, nil\n   661→}\n   662→\n   663→func cmdGet(args []string) {\n   664→\tif len(args) < 1 {\n   665→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   666→\t\tos.Exit(1)\n   667→\t}\n   668→\n   669→\tprojectDir, runID, err := resolveRunContext()\n   670→\tif err != nil {\n   671→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   672→\t\tos.Exit(1)\n   673→\t}\n   674→\n   675→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   676→\tif err != nil {\n   677→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   678→\t\tos.Exit(1)\n   679→\t}\n   680→\tif !ok {\n   681→\t\tos.Exit(1)\n   682→\t}\n   683→\tfmt.Println(val)\n   684→}\n   685→\n   686→func cmdSet(args []string) {\n   687→\tif len(args) < 2 {\n   688→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   689→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   690→\t\tos.Exit(1)\n   691→\t}\n   692→\n   693→\tprojectDir, runID, err := resolveRunContext()\n   694→\tif err != nil {\n   695→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   696→\t\tos.Exit(1)\n   697→\t}\n   698→\n   699→\tvalue := args[1]\n   700→\tif value == \"-\" {\n   701→\t\tdata, err := io.ReadAll(os.Stdin)\n   702→\t\tif err != nil {\n   703→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   704→\t\t\tos.Exit(1)\n   705→\t\t}\n   706→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   707→\t}\n   708→\n   709→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   710→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   711→\t\tos.Exit(1)\n   712→\t}\n   713→}\n   714→\n   715→func cmdVersion() {\n   716→\tcliVersion := version.Version()\n   717→\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   718→\n   719→\t// Try to get daemon version via gRPC\n   720→\tdaemonVersion := \"<unavailable>\"\n   721→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   722→\tif addr == \"\" {\n   723→\t\taddr = config.DefaultSocketAddr()\n   724→\t}\n   725→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   726→\tif err == nil {\n   727→\t\tdefer conn.Close()\n   728→\t\tclient := pb.NewClocheServiceClient(conn)\n   729→\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   730→\t\tdefer cancel()\n   731→\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   732→\t\tif err == nil {\n   733→\t\t\tdaemonVersion = resp.Version\n   734→\t\t}\n   735→\t}\n   736→\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   737→\n   738→\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   739→\tagentVersion := \"<unavailable>\"\n   740→\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   741→\tif image == \"\" {\n   742→\t\timage = \"cloche-agent:latest\"\n   743→\t}\n   744→\tout, err := exec.CommandContext(\n   745→\t\tcontext.Background(),\n   746→\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   747→\t).Output()\n   748→\tif err == nil {\n   749→\t\tagentVersion = strings.TrimSpace(string(out))\n   750→\t\t// Strip \"cloche-agent \" prefix if present\n   751→\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n   752→\t}\n   753→\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n   754→\n   755→\t// Warn about version mismatches\n   756→\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n   757→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n   758→\t}\n   759→\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n   760→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n   761→\t}\n   762→}\n   763→"}]},"parent_tool_use_id":null,"session_id":"85615324-ec9e-4511-9465-2c631732f71f","uuid":"4cdabfcd-56d7-497a-bfdc-287d879c14b2","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\t\"text/tabwriter\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n\t\"github.com/cloche-dev/cloche/internal/version\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n\n\t// Handle version flags before anything else\n\tif os.Args[1] == \"-v\" || os.Args[1] == \"--version\" {\n\t\tcmdVersion()\n\t\treturn\n\t}\n\n\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n\tswitch os.Args[1] {\n\tcase \"help\":\n\t\tprintHelp(os.Args[2:])\n\t\treturn\n\tcase \"--help\", \"-h\":\n\t\tprintTopLevelHelp()\n\t\treturn\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"init\")\n\t\t\treturn\n\t\t}\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"health\")\n\t\t\treturn\n\t\t}\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\tcase \"get\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"get\")\n\t\t\treturn\n\t\t}\n\t\tcmdGet(os.Args[2:])\n\t\treturn\n\tcase \"set\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"set\")\n\t\t\treturn\n\t\t}\n\t\tcmdSet(os.Args[2:])\n\t\treturn\n\tcase \"tasks\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"tasks\")\n\t\t\treturn\n\t\t}\n\t\tcmdTasks(os.Args[2:])\n\t\treturn\n\tcase \"workflow\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"workflow\")\n\t\t\treturn\n\t\t}\n\t\tcmdWorkflow(os.Args[2:])\n\t\treturn\n\tcase \"project\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"project\")\n\t\t\treturn\n\t\t}\n\t\tcmdProject(os.Args[2:])\n\t\treturn\n\tcase \"validate\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"validate\")\n\t\t\treturn\n\t\t}\n\t\tcmdValidate(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Handle --help for daemon commands before connecting\n\tdaemonCmds := map[string]bool{\n\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n\t}\n\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n\t\tprintSubcommandHelp(os.Args[1])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = config.DefaultSocketAddr()\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client, os.Args[2:])\n\tdefault:\n\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n}\n\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title, issueID string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--issue\", \"-i\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tissueID = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"] [--issue ID]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n\t// Try loading from any .cloche file; only extract image for container workflows.\n\tvar image string\n\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n\t\timage = wf.Config[\"container.image\"]\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t\tIssueId:       issueID,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tvar projectDir, stateFilter, issueFilter string\n\tvar limit int32\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--all\":\n\t\t\tall = true\n\t\tcase \"--project\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\tcase \"--state\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstateFilter = args[i]\n\t\t\t}\n\t\tcase \"--limit\", \"-n\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = int32(n)\n\t\t\t}\n\t\tcase \"--issue\", \"-i\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tissueFilter = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\treq := &pb.ListRunsRequest{\n\t\tState:  stateFilter,\n\t\tLimit:  limit,\n\t\tTaskId: issueFilter,\n\t}\n\tif projectDir != \"\" {\n\t\treq.ProjectDir = projectDir\n\t} else if all {\n\t\treq.All = true\n\t} else {\n\t\t// Default: filter to current project\n\t\tcwd, _ := os.Getwd()\n\t\treq.ProjectDir = cwd\n\t}\n\n\tresp, err := client.ListRuns(ctx, req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n\tfmt.Fprintln(w, \"RUN ID\\tWORKFLOW\\tSTATE\\tTYPE\\tTASK ID\\tTITLE\\tCONTAINER\\tERROR\")\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\ttitle := run.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\terrMsg := run.ErrorMessage\n\t\tif len(errMsg) > 60 {\n\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t}\n\t\tfmt.Fprintf(w, \"%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\n\",\n\t\t\trun.RunId, run.WorkflowName, run.State, runType,\n\t\t\trun.TaskId, title, run.ContainerId, errMsg)\n\t}\n\tw.Flush()\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\tvar limit int\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\tcase \"--limit\", \"-l\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil || n < 0 {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = n\n\t\t\t}\n\t\t}\n\t}\n\n\t// Use background context — log output can be large and follow mode blocks.\n\tctx := context.Background()\n\tvar mdPairs []string\n\tif follow {\n\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n\t}\n\tif limit > 0 {\n\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n\t}\n\tif len(mdPairs) > 0 {\n\t\tmd := metadata.Pairs(mdPairs...)\n\t\tctx = metadata.NewOutgoingContext(ctx, md)\n\t}\n\n\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Check for \"resume\" subcommand\n\tif len(args) > 0 && args[0] == \"resume\" {\n\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop resumed.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdTasks(args []string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\t// Determine project label from --project flag or current directory\n\tprojectDir := \"\"\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tcwd, _ := os.Getwd()\n\t\tprojectDir = filepath.Base(cwd)\n\t}\n\n\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n\tresp, err := http.Get(tasksURL)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\ttype taskEntry struct {\n\t\tID          string `json:\"id\"`\n\t\tStatus      string `json:\"status\"`\n\t\tTitle       string `json:\"title\"`\n\t\tDescription string `json:\"description\"`\n\t\tAssigned    bool   `json:\"assigned\"`\n\t\tAssignedAt  string `json:\"assigned_at\"`\n\t\tRunID       string `json:\"run_id\"`\n\t}\n\n\tvar tasks []taskEntry\n\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(tasks) == 0 {\n\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n\t\treturn\n\t}\n\n\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n\tfor _, t := range tasks {\n\t\tstatus := t.Status\n\t\tif status == \"\" {\n\t\t\tstatus = \"open\"\n\t\t}\n\t\tassigned := \"-\"\n\t\tif t.Assigned {\n\t\t\tassigned = \"yes\"\n\t\t}\n\t\trunID := \"\"\n\t\tif t.RunID != \"\" {\n\t\t\trunID = t.RunID\n\t\t\tif len(runID) > 30 {\n\t\t\t\trunID = runID[:27] + \"...\"\n\t\t\t}\n\t\t}\n\t\ttitle := t.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar force bool\n\tfor _, a := range args {\n\t\tif a == \"-f\" || a == \"--force\" {\n\t\t\tforce = true\n\t\t}\n\t}\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n\n// resolveRunContext returns the project directory and run ID for context\n// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n// from CLOCHE_PROJECT_DIR (falling back to cwd).\nfunc resolveRunContext() (projectDir, runID string, err error) {\n\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n\tif runID == \"\" {\n\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n\t}\n\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n\tif projectDir == \"\" {\n\t\tprojectDir, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n\t\t}\n\t}\n\treturn projectDir, runID, nil\n}\n\nfunc cmdGet(args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif !ok {\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(val)\n}\n\nfunc cmdSet(args []string) {\n\tif len(args) < 2 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvalue := args[1]\n\tif value == \"-\" {\n\t\tdata, err := io.ReadAll(os.Stdin)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n\t}\n\n\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n\nfunc cmdVersion() {\n\tcliVersion := version.Version()\n\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n\n\t// Try to get daemon version via gRPC\n\tdaemonVersion := \"<unavailable>\"\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = config.DefaultSocketAddr()\n\t}\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err == nil {\n\t\tdefer conn.Close()\n\t\tclient := pb.NewClocheServiceClient(conn)\n\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n\t\tdefer cancel()\n\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n\t\tif err == nil {\n\t\t\tdaemonVersion = resp.Version\n\t\t}\n\t}\n\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n\n\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n\tagentVersion := \"<unavailable>\"\n\timage := os.Getenv(\"CLOCHE_IMAGE\")\n\tif image == \"\" {\n\t\timage = \"cloche-agent:latest\"\n\t}\n\tout, err := exec.CommandContext(\n\t\tcontext.Background(),\n\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n\t).Output()\n\tif err == nil {\n\t\tagentVersion = strings.TrimSpace(string(out))\n\t\t// Strip \"cloche-agent \" prefix if present\n\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n\t}\n\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n\n\t// Warn about version mismatches\n\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n\t}\n\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n\t}\n}\n","numLines":763,"startLine":1,"totalLines":763}}}
