{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VN8PgfWcWv1zrws9aJM6v1","type":"tool_result","content":"   250→\t\t\t}\n   251→\n   252→\t\t\t// Stagger consecutive launches.\n   253→\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   254→\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   255→\t\t\t\t\treturn\n   256→\t\t\t\t}\n   257→\t\t\t}\n   258→\n   259→\t\t\t// Phase 1: list-tasks — discover available work.\n   260→\t\t\ttaskID, ok := l.pickTaskFromPhase()\n   261→\t\t\tif !ok {\n   262→\t\t\t\tbreak // no assignable tasks\n   263→\t\t\t}\n   264→\n   265→\t\t\t// Launch main + finalize in a goroutine.\n   266→\t\t\tinFlight++\n   267→\t\t\tlaunched++\n   268→\t\t\ttid := taskID\n   269→\t\t\tgo func() {\n   270→\t\t\t\t// Phase 2: main — do the work.\n   271→\t\t\t\tmainResult, err := l.mainFn(context.Background(), l.config.ProjectDir, tid)\n   272→\t\t\t\tif err != nil {\n   273→\t\t\t\t\tlog.Printf(\"orchestration loop: main failed for %s task %s: %v\", l.config.ProjectDir, tid, err)\n   274→\t\t\t\t\tif mainResult == nil {\n   275→\t\t\t\t\t\tmainResult = &RunResult{State: domain.RunStateFailed}\n   276→\t\t\t\t\t}\n   277→\t\t\t\t}\n   278→\n   279→\t\t\t\t// Track the run ID for this task.\n   280→\t\t\t\tif mainResult != nil && mainResult.RunID != \"\" {\n   281→\t\t\t\t\tl.tasksMu.Lock()\n   282→\t\t\t\t\tl.taskRuns[tid] = TaskAssignment{\n   283→\t\t\t\t\t\tAssignedAt: time.Now(),\n   284→\t\t\t\t\t\tRunID:      mainResult.RunID,\n   285→\t\t\t\t\t}\n   286→\t\t\t\t\tl.tasksMu.Unlock()\n   287→\t\t\t\t}\n   288→\n   289→\t\t\t\t// Phase 3: finalize — cleanup (runs on both success and failure).\n   290→\t\t\t\t// The overall state is the worst of main and finalize outcomes.\n   291→\t\t\t\toverallState := mainResult.State\n   292→\t\t\t\tif l.finalizeFn != nil {\n   293→\t\t\t\t\tfinalizeResult, finalizeErr := l.finalizeFn(context.Background(), l.config.ProjectDir, tid, mainResult)\n   294→\t\t\t\t\tif finalizeErr != nil {\n   295→\t\t\t\t\t\tlog.Printf(\"orchestration loop: finalize failed for %s task %s: %v\", l.config.ProjectDir, tid, finalizeErr)\n   296→\t\t\t\t\t\toverallState = domain.WorseState(overallState, domain.RunStateFailed)\n   297→\t\t\t\t\t} else if finalizeResult != nil {\n   298→\t\t\t\t\t\toverallState = domain.WorseState(overallState, finalizeResult.State)\n   299→\t\t\t\t\t}\n   300→\t\t\t\t}\n   301→\n   302→\t\t\t\tcompletions <- result{state: overallState, errMsg: fmt.Sprintf(\"task %s failed\", tid)}\n   303→\t\t\t}()\n   304→\t\t}\n   305→\n   306→\t\tif inFlight == 0 {\n   307→\t\t\t// Nothing in flight and couldn't launch anything — wait before checking again.\n   308→\t\t\tif !l.sleep(capacityPollInterval) {\n   309→\t\t\t\treturn\n   310→\t\t\t}\n   311→\t\t\tcontinue\n   312→\t\t}\n   313→\n   314→\t\t// Wait for any run to complete.\n   315→\t\tselect {\n   316→\t\tcase r := <-completions:\n   317→\t\t\tinFlight--\n   318→\t\t\tif r.state == domain.RunStateSucceeded {\n   319→\t\t\t\t// Work was done — try to fill slots immediately.\n   320→\t\t\t\tcontinue\n   321→\t\t\t}\n   322→\t\t\t// Run failed or aborted.\n   323→\t\t\tif l.config.StopOnError {\n   324→\t\t\t\tl.halt(r.errMsg)\n   325→\t\t\t}\n   326→\t\t\t// Back off.\n   327→\t\t\tif !l.sleep(idlePollInterval) {\n   328→\t\t\t\treturn\n   329→\t\t\t}\n   330→\t\tcase <-l.stopCh:\n   331→\t\t\treturn\n   332→\t\t}\n   333→\t}\n   334→}\n   335→\n   336→// GetTaskSnapshot returns the current task pipeline state: the most recently\n   337→// fetched tasks with their assignment information.\n   338→func (l *Loop) GetTaskSnapshot() []TaskStateEntry {\n   339→\tl.tasksMu.RLock()\n   340→\ttasks := make([]Task, len(l.lastTasks))\n   341→\tcopy(tasks, l.lastTasks)\n   342→\tl.tasksMu.RUnlock()\n   343→\n   344→\tl.dedupMu.Lock()\n   345→\tdefer l.dedupMu.Unlock()\n   346→\n   347→\tnow := time.Now()\n   348→\tvar entries []TaskStateEntry\n   349→\tfor _, task := range tasks {\n   350→\t\tentry := TaskStateEntry{Task: task}\n   351→\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   352→\t\t\tentry.Assigned = true\n   353→\t\t\tentry.AssignedAt = ts\n   354→\t\t}\n   355→\n   356→\t\tl.tasksMu.RLock()\n   357→\t\tif a, ok := l.taskRuns[task.ID]; ok {\n   358→\t\t\tentry.RunID = a.RunID\n   359→\t\t\tif !entry.Assigned {\n   360→\t\t\t\tentry.AssignedAt = a.AssignedAt\n   361→\t\t\t}\n   362→\t\t}\n   363→\t\tl.tasksMu.RUnlock()\n   364→\n   365→\t\tentries = append(entries, entry)\n   366→\t}\n   367→\treturn entries\n   368→}\n   369→\n   370→// pickTaskFromPhase runs the list-tasks function and picks the first open,\n   371→// non-deduped task.\n   372→func (l *Loop) pickTaskFromPhase() (string, bool) {\n   373→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   374→\tdefer cancel()\n   375→\n   376→\ttasks, err := l.listTasks(ctx, l.config.ProjectDir)\n   377→\tif err != nil {\n   378→\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n   379→\t\treturn \"\", false\n   380→\t}\n   381→\n   382→\t// Cache the latest tasks for snapshot queries.\n   383→\tl.tasksMu.Lock()\n   384→\tl.lastTasks = tasks\n   385→\tl.tasksMu.Unlock()\n   386→\n   387→\tnow := time.Now()\n   388→\tl.dedupMu.Lock()\n   389→\tdefer l.dedupMu.Unlock()\n   390→\n   391→\t// Expire old dedup entries.\n   392→\tfor id, ts := range l.dedup {\n   393→\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n   394→\t\t\tdelete(l.dedup, id)\n   395→\t\t}\n   396→\t}\n   397→\n   398→\tfor _, task := range tasks {\n   399→\t\tif task.ID == \"\" {\n   400→\t\t\tcontinue\n   401→\t\t}\n   402→\t\tif !task.IsOpen() {\n   403→\t\t\tcontinue\n   404→\t\t}\n   405→\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   406→\t\t\tcontinue\n   407→\t\t}\n   408→\t\tl.dedup[task.ID] = now\n   409→\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n   410→\t\treturn task.ID, true\n   411→\t}\n   412→\n   413→\treturn \"\", false\n   414→}\n   415→\n   416→// runLegacy implements the original single-function orchestration loop.\n   417→func (l *Loop) runLegacy() {\n   418→\ttype result struct {\n   419→\t\tstate  domain.RunState\n   420→\t\terrMsg string\n   421→\t}\n   422→\n   423→\tcompletions := make(chan result, l.config.MaxConcurrent)\n   424→\tinFlight := 0\n   425→\n   426→\tfor {\n   427→\t\t// Fill up to max concurrent slots.\n   428→\t\tlaunched := 0\n   429→\t\tfor inFlight < l.config.MaxConcurrent {\n   430→\t\t\tselect {\n   431→\t\t\tcase <-l.stopCh:\n   432→\t\t\t\treturn\n   433→\t\t\tdefault:\n   434→\t\t\t}\n   435→\n   436→\t\t\t// If halted, don't pick up new work.\n   437→\t\t\tif l.isHalted() {\n   438→\t\t\t\tbreak\n   439→\t\t\t}\n   440→\n   441→\t\t\t// Check how many host runs are active for this project (in case of\n   442→\t\t\t// leftover runs from previous loops).\n   443→\t\t\tactive := l.countActiveHostRuns()\n   444→\t\t\tif active >= l.config.MaxConcurrent {\n   445→\t\t\t\tbreak\n   446→\t\t\t}\n   447→\n   448→\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n   449→\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {"}]},"parent_tool_use_id":"toolu_01SyKs3xQqMBueW7mcyz65pv","session_id":"85615324-ec9e-4511-9465-2c631732f71f","uuid":"ca8c495d-5c69-4797-a396-0e5966d7dffe"}
