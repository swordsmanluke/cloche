{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vhv7j9yGDmdKNfo1SioAGW","type":"tool_result","content":"   887→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   888→\tprojectDir := req.ProjectDir\n   889→\tif projectDir == \"\" {\n   890→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   891→\t}\n   892→\n   893→\t// Verify at least one host workflow exists in the project.\n   894→\thostWorkflows, err := host.FindHostWorkflows(projectDir)\n   895→\tif err != nil || len(hostWorkflows) == 0 {\n   896→\t\treturn nil, fmt.Errorf(\"no host workflows found in %s/.cloche/\", projectDir)\n   897→\t}\n   898→\n   899→\t// Load project config for defaults.\n   900→\tprojCfg, _ := config.Load(projectDir)\n   901→\n   902→\tmaxConc := int(req.MaxConcurrent)\n   903→\tif maxConc <= 0 {\n   904→\t\tmaxConc = projCfg.Orchestration.Concurrency\n   905→\t}\n   906→\tif maxConc <= 0 {\n   907→\t\tmaxConc = 1\n   908→\t}\n   909→\n   910→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   911→\n   912→\t// Compute dedup timeout from config (default 5 minutes).\n   913→\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n   914→\n   915→\tloopCfg := host.LoopConfig{\n   916→\t\tProjectDir:    projectDir,\n   917→\t\tMaxConcurrent: maxConc,\n   918→\t\tStaggerDelay:  stagger,\n   919→\t\tDedupTimeout:  dedupTimeout,\n   920→\t\tStopOnError:   projCfg.Orchestration.StopOnError,\n   921→\t}\n   922→\n   923→\ts.mu.Lock()\n   924→\tdefer s.mu.Unlock()\n   925→\n   926→\t// Stop existing loop if running.\n   927→\tif existing, ok := s.loops[projectDir]; ok {\n   928→\t\texisting.Stop()\n   929→\t}\n   930→\n   931→\t// Check if project defines a list-tasks workflow for three-phase mode.\n   932→\tvar loop *host.Loop\n   933→\tif _, hasListTasks := hostWorkflows[\"list-tasks\"]; hasListTasks {\n   934→\t\tloop = s.createPhaseLoop(loopCfg, projectDir, dedupTimeout)\n   935→\t} else {\n   936→\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n   937→\t}\n   938→\n   939→\ts.loops[projectDir] = loop\n   940→\tloop.Start()\n   941→\n   942→\treturn &pb.EnableLoopResponse{}, nil\n   943→}\n   944→\n   945→// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n   946→// main, and finalize host workflows from any .cloche file.\n   947→func (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir string, dedupTimeout time.Duration) *host.Loop {\n   948→\t// Phase 1: list-tasks function\n   949→\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n   950→\t\trunner := &host.Runner{\n   951→\t\t\tDispatcher: s,\n   952→\t\t\tStore:      s.store,\n   953→\t\t}\n   954→\t\ttasks, _, err := host.RunListTasksWorkflow(ctx, runner, projDir)\n   955→\t\treturn tasks, err\n   956→\t}\n   957→\n   958→\t// Phase 2: main function\n   959→\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   960→\t\trunner := &host.Runner{\n   961→\t\t\tDispatcher:   s,\n   962→\t\t\tStore:        s.store,\n   963→\t\t\tCaptures:     s.captures,\n   964→\t\t\tLogBroadcast: s.logBroadcast,\n   965→\t\t\tTaskID:       taskID,\n   966→\t\t}\n   967→\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n   968→\t}\n   969→\n   970→\t// Phase 3: finalize function (optional — only if a finalize host workflow exists)\n   971→\tvar finalizeFn host.FinalizeFunc\n   972→\tif hostWFs, err := host.FindHostWorkflows(projectDir); err == nil {\n   973→\t\tif _, hasFinalize := hostWFs[\"finalize\"]; hasFinalize {\n   974→\t\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n   975→\t\t\t\tmainRunID := \"\"\n   976→\t\t\t\tmainOutcome := \"failed\"\n   977→\t\t\t\tif mainResult != nil {\n   978→\t\t\t\t\tmainRunID = mainResult.RunID\n   979→\t\t\t\t\tmainOutcome = string(mainResult.State)\n   980→\t\t\t\t}\n   981→\t\t\t\trunner := &host.Runner{\n   982→\t\t\t\t\tDispatcher:   s,\n   983→\t\t\t\t\tStore:        s.store,\n   984→\t\t\t\t\tCaptures:     s.captures,\n   985→\t\t\t\t\tLogBroadcast: s.logBroadcast,\n   986→\t\t\t\t\tTaskID:       taskID,\n   987→\t\t\t\t\tExtraEnv: []string{\n   988→\t\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n   989→\t\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n   990→\t\t\t\t\t},\n   991→\t\t\t\t}\n   992→\t\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n   993→\t\t\t}\n   994→\t\t}\n   995→\t}\n   996→\n   997→\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n   998→\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n   999→}\n  1000→\n  1001→// createLegacyLoop creates a legacy single-function orchestration loop.\n  1002→func (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n  1003→\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n  1004→\t\trunner := &host.Runner{\n  1005→\t\t\tDispatcher:   s,\n  1006→\t\t\tStore:        s.store,\n  1007→\t\t\tCaptures:     s.captures,\n  1008→\t\t\tLogBroadcast: s.logBroadcast,\n  1009→\t\t\tTaskID:       taskID,\n  1010→\t\t}\n  1011→\t\treturn runner.Run(ctx, projDir)\n  1012→\t}\n  1013→\n  1014→\tloop := host.NewLoop(loopCfg, s.store, runFn)\n  1015→\n  1016→\t// Configure daemon-managed task assignment if a list-tasks command is set.\n  1017→\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n  1018→\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n  1019→\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n  1020→\t}\n  1021→\n  1022→\treturn loop\n  1023→}\n  1024→\n  1025→// GetLoopTasks returns the current task pipeline state for a project's\n  1026→// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n  1027→// loop is active for the project.\n  1028→func (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n  1029→\ts.mu.Lock()\n  1030→\tloop, ok := s.loops[projectDir]\n  1031→\ts.mu.Unlock()\n  1032→\tif !ok {\n  1033→\t\treturn nil\n  1034→\t}\n  1035→\tsnapshot := loop.GetTaskSnapshot()\n  1036→\n  1037→\t// Build a set of task IDs that have active (pending/running) runs.\n  1038→\tactiveTaskIDs := make(map[string]bool)\n  1039→\tctx := context.Background()\n  1040→\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n  1041→\tfor _, r := range allRuns {\n  1042→\t\tif r.TaskID != \"\" && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n  1043→\t\t\tactiveTaskIDs[r.TaskID] = true\n  1044→\t\t}\n  1045→\t}\n  1046→\n  1047→\tentries := make([]web.TaskEntry, len(snapshot))\n  1048→\tfor i, e := range snapshot {\n  1049→\t\tentry := web.TaskEntry{\n  1050→\t\t\tID:          e.Task.ID,\n  1051→\t\t\tStatus:      e.Task.Status,\n  1052→\t\t\tTitle:       e.Task.Title,\n  1053→\t\t\tDescription: e.Task.Description,\n  1054→\t\t\tMetadata:    e.Task.Metadata,\n  1055→\t\t\tAssigned:    e.Assigned,\n  1056→\t\t\tRunID:       e.RunID,\n  1057→\t\t}\n  1058→\t\tif !e.AssignedAt.IsZero() {\n  1059→\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n  1060→\t\t}\n  1061→\t\t// Stale: task is in_progress but has no active worker.\n  1062→\t\tif host.TaskStatus(e.Task.Status) == host.TaskStatusInProgress && !activeTaskIDs[e.Task.ID] {\n  1063→\t\t\tentry.Stale = true\n  1064→\t\t}\n  1065→\t\tentries[i] = entry\n  1066→\t}\n  1067→\treturn entries\n  1068→}\n  1069→\n  1070→// ReleaseTask runs the release-task host workflow for a specific task,\n  1071→// returning it to open status.\n  1072→func (s *ClocheServer) ReleaseTask(ctx context.Context, projectDir string, taskID string) error {\n  1073→\trunner := &host.Runner{\n  1074→\t\tDispatcher:   s,\n  1075→\t\tStore:        s.store,\n  1076→\t\tCaptures:     s.captures,\n  1077→\t\tLogBroadcast: s.logBroadcast,\n  1078→\t\tTaskID:       taskID,\n  1079→\t}\n  1080→\tresult, err := runner.RunNamed(ctx, projectDir, \"release-task\")\n  1081→\tif err != nil {\n  1082→\t\treturn fmt.Errorf(\"release-task workflow failed: %w\", err)\n  1083→\t}\n  1084→\tif result.State != domain.RunStateSucceeded {\n  1085→\t\treturn fmt.Errorf(\"release-task workflow finished with state %s\", result.State)\n  1086→\t}\n  1087→\treturn nil\n  1088→}\n  1089→\n  1090→func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n  1091→\tprojectDir := req.ProjectDir\n  1092→\tif projectDir == \"\" {\n  1093→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n  1094→\t}\n  1095→\n  1096→\ts.mu.Lock()\n  1097→\tdefer s.mu.Unlock()\n  1098→\n  1099→\tif loop, ok := s.loops[projectDir]; ok {\n  1100→\t\tloop.Stop()\n  1101→\t\tdelete(s.loops, projectDir)\n  1102→\t}\n  1103→\n  1104→\treturn &pb.DisableLoopResponse{}, nil\n  1105→}\n  1106→\n  1107→func (s *ClocheServer) ResumeLoop(ctx context.Context, req *pb.ResumeLoopRequest) (*pb.ResumeLoopResponse, error) {\n  1108→\tprojectDir := req.ProjectDir\n  1109→\tif projectDir == \"\" {\n  1110→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n  1111→\t}\n  1112→\n  1113→\ts.mu.Lock()\n  1114→\tloop, ok := s.loops[projectDir]\n  1115→\ts.mu.Unlock()\n  1116→\n  1117→\tif !ok || loop == nil {\n  1118→\t\treturn nil, fmt.Errorf(\"no orchestration loop for %s\", projectDir)\n  1119→\t}\n  1120→\n  1121→\tloop.Resume()\n  1122→\treturn &pb.ResumeLoopResponse{}, nil\n  1123→}\n  1124→\n  1125→func (s *ClocheServer) GetProjectInfo(ctx context.Context, req *pb.GetProjectInfoRequest) (*pb.GetProjectInfoResponse, error) {\n  1126→\tprojectDir := req.ProjectDir\n  1127→\n  1128→\t// Resolve by name if provided.\n  1129→\tif req.Name != \"\" && projectDir == \"\" {\n  1130→\t\tprojects, err := s.store.ListProjects(ctx)\n  1131→\t\tif err != nil {\n  1132→\t\t\treturn nil, fmt.Errorf(\"listing projects: %w\", err)\n  1133→\t\t}\n  1134→\t\tlabels := projectLabels(projects)\n  1135→\t\tfound := false\n  1136→\t\tfor dir, label := range labels {"}]},"parent_tool_use_id":"toolu_01SyKs3xQqMBueW7mcyz65pv","session_id":"85615324-ec9e-4511-9465-2c631732f71f","uuid":"a9a7a0be-1efa-4c12-8d8a-443f29202635"}
