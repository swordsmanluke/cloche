{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YQUbgDSs6ACiSrZjWqZErs","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"sync\"\n    10→\t\"time\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14→)\n    15→\n    16→const (\n    17→\tdefaultMaxConcurrent = 1\n    18→\tdefaultDedupTimeout  = 5 * time.Minute\n    19→\tidlePollInterval     = 2 * time.Minute\n    20→\tcapacityPollInterval = 30 * time.Second\n    21→)\n    22→\n    23→// LoopConfig holds configuration for an orchestration loop.\n    24→type LoopConfig struct {\n    25→\tProjectDir    string\n    26→\tMaxConcurrent int\n    27→\tStaggerDelay  time.Duration // delay between launching consecutive runs\n    28→\tDedupTimeout  time.Duration // how long to suppress reassignment of the same task ID\n    29→\tStopOnError   bool          // halt loop on unrecovered error (allow in-flight work to finish)\n    30→}\n    31→\n    32→// ListTasksFunc is called to discover available tasks. It should run the\n    33→// list-tasks workflow (or equivalent) and return the parsed tasks.\n    34→type ListTasksFunc func(ctx context.Context, projectDir string) ([]Task, error)\n    35→\n    36→// MainFunc is called to execute the main workflow for a given task.\n    37→type MainFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n    38→\n    39→// FinalizeFunc is called after the main workflow completes (both success and\n    40→// failure). It receives the task ID and the outcome of the main phase.\n    41→type FinalizeFunc func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error)\n    42→\n    43→// RunFunc is the legacy function signature for launching a host workflow run.\n    44→// When taskID is non-empty, the runner should propagate it as CLOCHE_TASK_ID.\n    45→type RunFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n    46→\n    47→// TaskAssignment tracks the assignment state of a task.\n    48→type TaskAssignment struct {\n    49→\tAssignedAt time.Time\n    50→\tRunID      string // run ID handling this task (set after main completes)\n    51→}\n    52→\n    53→// TaskStateEntry combines a task with its assignment state.\n    54→type TaskStateEntry struct {\n    55→\tTask       Task\n    56→\tAssigned   bool\n    57→\tAssignedAt time.Time\n    58→\tRunID      string // empty if not yet known\n    59→}\n    60→\n    61→// Loop manages a continuous orchestration loop for a project, keeping up to\n    62→// MaxConcurrent host workflow runs active at all times when work is available.\n    63→//\n    64→// When configured with three-phase functions (list-tasks, main, finalize), the\n    65→// loop discovers tasks via list-tasks, picks open ones, runs main for each, and\n    66→// then runs finalize on completion. When configured with a legacy RunFunc, it\n    67→// falls back to the single-function approach.\n    68→type Loop struct {\n    69→\tconfig     LoopConfig\n    70→\tlistTasks  ListTasksFunc\n    71→\tmainFn     MainFunc\n    72→\tfinalizeFn FinalizeFunc // optional; skipped if nil\n    73→\trunner     RunFunc      // legacy single-function mode\n    74→\tstore      ports.RunStore\n    75→\tassigner   TaskAssigner // optional; legacy task assignment\n    76→\tstopCh     chan struct{}\n    77→\tresumeCh   chan struct{} // signaled by Resume() to wake the loop\n    78→\tmu         sync.Mutex\n    79→\trunning    bool\n    80→\thaltedMu   sync.RWMutex\n    81→\thalted     bool   // true when loop is halted due to an unrecovered error\n    82→\thaltError  string // the error message that caused the halt\n    83→\tdedupMu    sync.Mutex\n    84→\tdedup      map[string]time.Time // task ID -> last assignment time\n    85→\ttasksMu    sync.RWMutex\n    86→\tlastTasks  []Task                    // most recently fetched tasks\n    87→\ttaskRuns   map[string]TaskAssignment // task ID -> assignment info\n    88→}\n    89→\n    90→// NewLoop creates an orchestration loop using a single run function (legacy mode).\n    91→// For three-phase orchestration, use NewPhaseLoop instead.\n    92→func NewLoop(cfg LoopConfig, store ports.RunStore, runFn RunFunc) *Loop {\n    93→\tif cfg.MaxConcurrent <= 0 {\n    94→\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n    95→\t}\n    96→\tif cfg.DedupTimeout <= 0 {\n    97→\t\tcfg.DedupTimeout = defaultDedupTimeout\n    98→\t}\n    99→\treturn &Loop{\n   100→\t\tconfig:   cfg,\n   101→\t\trunner:   runFn,\n   102→\t\tstore:    store,\n   103→\t\tresumeCh: make(chan struct{}, 1),\n   104→\t\tdedup:    make(map[string]time.Time),\n   105→\t\ttaskRuns: make(map[string]TaskAssignment),\n   106→\t}\n   107→}\n   108→\n   109→// NewPhaseLoop creates a three-phase orchestration loop. The listTasksFn\n   110→// discovers available tasks, mainFn executes the main workflow for a task,\n   111→// and finalizeFn (optional) runs cleanup after main completes.\n   112→func NewPhaseLoop(cfg LoopConfig, store ports.RunStore, listTasksFn ListTasksFunc, mainFn MainFunc, finalizeFn FinalizeFunc) *Loop {\n   113→\tif cfg.MaxConcurrent <= 0 {\n   114→\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n   115→\t}\n   116→\tif cfg.DedupTimeout <= 0 {\n   117→\t\tcfg.DedupTimeout = defaultDedupTimeout\n   118→\t}\n   119→\treturn &Loop{\n   120→\t\tconfig:     cfg,\n   121→\t\tlistTasks:  listTasksFn,\n   122→\t\tmainFn:     mainFn,\n   123→\t\tfinalizeFn: finalizeFn,\n   124→\t\tstore:      store,\n   125→\t\tresumeCh:   make(chan struct{}, 1),\n   126→\t\tdedup:      make(map[string]time.Time),\n   127→\t\ttaskRuns:   make(map[string]TaskAssignment),\n   128→\t}\n   129→}\n   130→\n   131→// SetTaskAssigner configures a TaskAssigner for daemon-managed task assignment.\n   132→// Only used in legacy (single RunFunc) mode when no list-tasks function is set.\n   133→func (l *Loop) SetTaskAssigner(a TaskAssigner) {\n   134→\tl.assigner = a\n   135→}\n   136→\n   137→// Start begins the orchestration loop. No-op if already running.\n   138→func (l *Loop) Start() {\n   139→\tl.mu.Lock()\n   140→\tdefer l.mu.Unlock()\n   141→\tif l.running {\n   142→\t\treturn\n   143→\t}\n   144→\tl.running = true\n   145→\tl.stopCh = make(chan struct{})\n   146→\tgo l.run()\n   147→\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n   148→}\n   149→\n   150→// Stop signals the loop to stop. Active runs continue to completion.\n   151→func (l *Loop) Stop() {\n   152→\tl.mu.Lock()\n   153→\tdefer l.mu.Unlock()\n   154→\tif !l.running {\n   155→\t\treturn\n   156→\t}\n   157→\tl.running = false\n   158→\tclose(l.stopCh)\n   159→\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n   160→}\n   161→\n   162→// Running returns whether the loop is currently active.\n   163→func (l *Loop) Running() bool {\n   164→\tl.mu.Lock()\n   165→\tdefer l.mu.Unlock()\n   166→\treturn l.running\n   167→}\n   168→\n   169→// Halted returns whether the loop is halted due to an unrecovered error,\n   170→// along with the error message that caused the halt. When halted, the loop\n   171→// is still running but will not pick up new work.\n   172→func (l *Loop) Halted() (bool, string) {\n   173→\tl.haltedMu.RLock()\n   174→\tdefer l.haltedMu.RUnlock()\n   175→\treturn l.halted, l.haltError\n   176→}\n   177→\n   178→// Resume clears the halted state so the loop resumes picking up new work.\n   179→func (l *Loop) Resume() {\n   180→\tl.haltedMu.Lock()\n   181→\tdefer l.haltedMu.Unlock()\n   182→\tif l.halted {\n   183→\t\tlog.Printf(\"orchestration loop: resumed for %s (was halted: %s)\", l.config.ProjectDir, l.haltError)\n   184→\t\tl.halted = false\n   185→\t\tl.haltError = \"\"\n   186→\t\t// Wake the loop from any sleep so it picks up work immediately.\n   187→\t\tselect {\n   188→\t\tcase l.resumeCh <- struct{}{}:\n   189→\t\tdefault:\n   190→\t\t}\n   191→\t}\n   192→}\n   193→\n   194→// halt sets the loop into halted state with the given error message.\n   195→func (l *Loop) halt(errMsg string) {\n   196→\tl.haltedMu.Lock()\n   197→\tdefer l.haltedMu.Unlock()\n   198→\tl.halted = true\n   199→\tl.haltError = errMsg\n   200→\tlog.Printf(\"orchestration loop: halted for %s (stop_on_error): %s\", l.config.ProjectDir, errMsg)\n   201→}\n   202→\n   203→// isHalted returns true if the loop is currently halted.\n   204→func (l *Loop) isHalted() bool {\n   205→\tl.haltedMu.RLock()\n   206→\tdefer l.haltedMu.RUnlock()\n   207→\treturn l.halted\n   208→}\n   209→\n   210→func (l *Loop) run() {\n   211→\tif l.listTasks != nil && l.mainFn != nil {\n   212→\t\tl.runPhased()\n   213→\t} else {\n   214→\t\tl.runLegacy()\n   215→\t}\n   216→}\n   217→\n   218→// runPhased implements the three-phase orchestration loop:\n   219→// 1. list-tasks → discover available work\n   220→// 2. main → execute work for each open task (up to MaxConcurrent)\n   221→// 3. finalize → cleanup after main completes (on both success and failure)\n   222→func (l *Loop) runPhased() {\n   223→\ttype result struct {\n   224→\t\tstate  domain.RunState\n   225→\t\terrMsg string\n   226→\t}\n   227→\n   228→\tcompletions := make(chan result, l.config.MaxConcurrent)\n   229→\tinFlight := 0\n   230→\n   231→\tfor {\n   232→\t\t// Fill up to max concurrent slots.\n   233→\t\tlaunched := 0\n   234→\t\tfor inFlight < l.config.MaxConcurrent {\n   235→\t\t\tselect {\n   236→\t\t\tcase <-l.stopCh:\n   237→\t\t\t\treturn\n   238→\t\t\tdefault:\n   239→\t\t\t}\n   240→\n   241→\t\t\t// If halted, don't pick up new work.\n   242→\t\t\tif l.isHalted() {\n   243→\t\t\t\tbreak\n   244→\t\t\t}\n   245→\n   246→\t\t\t// Check how many host runs are active for this project.\n   247→\t\t\tactive := l.countActiveHostRuns()\n   248→\t\t\tif active >= l.config.MaxConcurrent {\n   249→\t\t\t\tbreak\n   250→\t\t\t}"}]},"parent_tool_use_id":"toolu_01SyKs3xQqMBueW7mcyz65pv","session_id":"85615324-ec9e-4511-9465-2c631732f71f","uuid":"21cf03c4-6d6d-4b36-aee5-49d05bf3d433"}
