   46→\tWorkflowName   string\n    47→\tTriggerRunID   string\n    48→\tCreatedAt      time.Time\n    49→\tClassification string\n    50→\tChangesJSON    string\n    51→\tKnowledgeDelta string\n    52→}\n    53→\n    54→type EvolutionStore interface {\n    55→\tSaveEvolution(ctx context.Context, entry *EvolutionEntry) error\n    56→\tGetLastEvolution(ctx context.Context, projectDir, workflowName string) (*EvolutionEntry, error)\n    57→\tListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error)\n    58→}\n    59→"}]},"parent_tool_use_id":"toolu_01FcGA6ED8WPxbTS4TE3BjwZ","session_id":"d13e2ce4-0d07-448e-8673-06ba707df971","uuid":"9c5a8247-3d40-4c0b-a685-34ae99c6a20f"}
