[2026-03-12T15:54:35Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CP9MJqG1kBKNUmskGLovAP","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"errors\"\n     7→\t\"fmt\"\n     8→\t\"io\"\n     9→\t\"net/http\"\n    10→\t\"os\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"time\"\n    14→\n    15→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    16→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    17→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    18→\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    19→\t\"google.golang.org/grpc\"\n    20→\t\"google.golang.org/grpc/credentials/insecure\"\n    21→\t\"google.golang.org/grpc/metadata\"\n    22→)\n    23→\n    24→func main() {\n    25→\tif len(os.Args) < 2 {\n    26→\t\tusage()\n    27→\t\tos.Exit(1)\n    28→\t}\n    29→\n    30→\t// Commands that don't need a daemon connection\n    31→\tswitch os.Args[1] {\n    32→\tcase \"init\":\n    33→\t\tcmdInit(os.Args[2:])\n    34→\t\treturn\n    35→\tcase \"health\":\n    36→\t\tcmdHealth(os.Args[2:])\n    37→\t\treturn\n    38→\tcase \"get\":\n    39→\t\tcmdGet(os.Args[2:])\n    40→\t\treturn\n    41→\tcase \"set\":\n    42→\t\tcmdSet(os.Args[2:])\n    43→\t\treturn\n    44→\tcase \"tasks\":\n    45→\t\tcmdTasks(os.Args[2:])\n    46→\t\treturn\n    47→\t}\n    48→\n    49→\t// Commands that need a daemon connection\n    50→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    51→\tif addr == \"\" {\n    52→\t\taddr = \"unix:///tmp/cloche.sock\"\n    53→\t}\n    54→\n    55→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n    56→\tif err != nil {\n    57→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n    58→\t\tos.Exit(1)\n    59→\t}\n    60→\tdefer conn.Close()\n    61→\n    62→\tclient := pb.NewClocheServiceClient(conn)\n    63→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n    64→\tdefer cancel()\n    65→\n    66→\tswitch os.Args[1] {\n    67→\tcase \"run\":\n    68→\t\tcmdRun(ctx, client, os.Args[2:])\n    69→\tcase \"status\":\n    70→\t\tcmdStatus(ctx, client, os.Args[2:])\n    71→\tcase \"logs\":\n    72→\t\tcmdLogs(client, os.Args[2:])\n    73→\tcase \"poll\":\n    74→\t\tcmdPoll(client, os.Args[2:])\n    75→\tcase \"list\":\n    76→\t\tcmdList(ctx, client, os.Args[2:])\n    77→\tcase \"stop\":\n    78→\t\tcmdStop(ctx, client, os.Args[2:])\n    79→\tcase \"delete\":\n    80→\t\tcmdDelete(ctx, client, os.Args[2:])\n    81→\tcase \"loop\":\n    82→\t\tcmdLoop(ctx, client, os.Args[2:])\n    83→\tcase \"shutdown\":\n    84→\t\tcmdShutdown(ctx, client)\n    85→\tdefault:\n    86→\t\tusage()\n    87→\t\tos.Exit(1)\n    88→\t}\n    89→}\n    90→\n    91→func usage() {\n    92→\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n    93→\n    94→Commands:\n    95→  init [--workflow <name>] [--base-image <image>]\n    96→                                             Initialize a Cloche project\n    97→  health                                   Show project health summary\n    98→  run --workflow <name> [--prompt \"...\"] [--title \"...\"] [--keep-container]\n    99→                                             Launch a workflow run\n   100→  status <run-id>                            Check run status\n   101→  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n   102→                                             Show logs for a run\n   103→  poll <run-id>                              Wait for a run to finish\n   104→  list [--all]                                List runs (last hour by default)\n   105→  stop <run-id>                              Stop a running workflow\n   106→  delete <container-or-run-id>               Delete a retained container\n   107→  tasks [--project <dir>]                     Show task pipeline and assignment state\n   108→  loop [--max <n>]                            Start orchestration loop (default max=1)\n   109→  loop stop                                  Stop orchestration loop\n   110→  get <key>                                  Get a value from the run context store\n   111→  set <key> <value>                          Set a value in the run context store\n   112→  shutdown                                   Shut down the daemon\n   113→`)\n   114→}\n   115→\n   116→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   117→\tvar workflow, prompt, title string\n   118→\tvar keepContainer bool\n   119→\n   120→\tfor i := 0; i < len(args); i++ {\n   121→\t\tswitch args[i] {\n   122→\t\tcase \"--workflow\":\n   123→\t\t\tif i+1 < len(args) {\n   124→\t\t\t\ti++\n   125→\t\t\t\tworkflow = args[i]\n   126→\t\t\t}\n   127→\t\tcase \"--prompt\", \"-p\":\n   128→\t\t\tif i+1 < len(args) {\n   129→\t\t\t\ti++\n   130→\t\t\t\tprompt = args[i]\n   131→\t\t\t}\n   132→\t\tcase \"--title\":\n   133→\t\t\tif i+1 < len(args) {\n   134→\t\t\t\ti++\n   135→\t\t\t\ttitle = args[i]\n   136→\t\t\t}\n   137→\t\tcase \"--keep-container\":\n   138→\t\t\tkeepContainer = true\n   139→\t\tdefault:\n   140→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   141→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   142→\t\t\t\tworkflow = args[i]\n   143→\t\t\t}\n   144→\t\t}\n   145→\t}\n   146→\n   147→\tif workflow == \"\" {\n   148→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   149→\t\tos.Exit(1)\n   150→\t}\n   151→\n   152→\tcwd, _ := os.Getwd()\n   153→\n   154→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   155→\tvar image string\n   156→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   157→\tif data, err := os.ReadFile(wfPath); err == nil {\n   158→\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   159→\t\t\timage = wf.Config[\"container.image\"]\n   160→\t\t}\n   161→\t}\n   162→\n   163→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   164→\t\tWorkflowName:  workflow,\n   165→\t\tProjectDir:    cwd,\n   166→\t\tImage:         image,\n   167→\t\tPrompt:        prompt,\n   168→\t\tKeepContainer: keepContainer,\n   169→\t\tTitle:         title,\n   170→\t})\n   171→\tif err != nil {\n   172→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   173→\t\tos.Exit(1)\n   174→\t}\n   175→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   176→}\n   177→\n   178→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   179→\tif len(args) < 1 {\n   180→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   181→\t\tos.Exit(1)\n   182→\t}\n   183→\n   184→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   185→\tif err != nil {\n   186→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   187→\t\tos.Exit(1)\n   188→\t}\n   189→\n   190→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   191→\tif resp.Title != \"\" {\n   192→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   193→\t}\n   194→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   195→\tif resp.IsHost {\n   196→\t\tfmt.Printf(\"Type:      host\\n\")\n   197→\t} else {\n   198→\t\tfmt.Printf(\"Type:      container\\n\")\n   199→\t}\n   200→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   201→\tif resp.ContainerId != \"\" {\n   202→\t\tcid := resp.ContainerId\n   203→\t\tif len(cid) > 12 {\n   204→\t\t\tcid = cid[:12]\n   205→\t\t}\n   206→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   207→\t}\n   208→\tif resp.ErrorMessage != \"\" {\n   209→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   210→\t}\n   211→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   212→\tfor _, exec := range resp.StepExecutions {\n   213→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   214→\t}\n   215→}\n   216→\n   217→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   218→\tvar all bool\n   219→\tfor _, arg := range args {\n   220→\t\tif arg == \"--all\" {\n   221→\t\t\tall = true\n   222→\t\t}\n   223→\t}\n   224→\n   225→\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n   226→\tif err != nil {\n   227→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   228→\t\tos.Exit(1)\n   229→\t}\n   230→\n   231→\tif len(resp.Runs) == 0 {\n   232→\t\tfmt.Println(\"No runs found.\")\n   233→\t\treturn\n   234→\t}\n   235→\n   236→\tfor _, run := range resp.Runs {\n   237→\t\trunType := \"container\"\n   238→\t\tif run.IsHost {\n   239→\t\t\trunType = \"host\"\n   240→\t\t}\n   241→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   242→\t\tif run.Title != \"\" {\n   243→\t\t\tt := run.Title\n   244→\t\t\tif len(t) > 40 {\n   245→\t\t\t\tt = t[:37] + \"...\"\n   246→\t\t\t}\n   247→\t\t\tline += \"  \" + t\n   248→\t\t}\n   249→\t\tif run.ContainerId != \"\" {\n   250→\t\t\tline += \"  \" + run.ContainerId\n   251→\t\t}\n   252→\t\tif run.ErrorMessage != \"\" {\n   253→\t\t\terrMsg := run.ErrorMessage\n   254→\t\t\tif len(errMsg) > 60 {\n   255→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   256→\t\t\t}\n   257→\t\t\tline += \"  \" + errMsg\n   258→\t\t}\n   259→\t\tfmt.Println(line)\n   260→\t}\n   261→}\n   262→\n   263→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   264→\tif len(args) < 1 {\n   265→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n   266→\t\tos.Exit(1)\n   267→\t}\n   268→\n   269→\tvar stepFilter, typeFilter string\n   270→\tvar follow bool\n   271→\trunID := args[0]\n   272→\n   273→\tfor i := 1; i < len(args); i++ {\n   274→\t\tswitch args[i] {\n   275→\t\tcase \"--step\":\n   276→\t\t\tif i+1 < len(args) {\n   277→\t\t\t\ti++\n   278→\t\t\t\tstepFilter = args[i]\n   279→\t\t\t}\n   280→\t\tcase \"--type\":\n   281→\t\t\tif i+1 < len(args) {\n   282→\t\t\t\ti++\n   283→\t\t\t\ttypeFilter = args[i]\n   284→\t\t\t}\n   285→\t\tcase \"--follow\", \"-f\":\n   286→\t\t\tfollow = true\n   287→\t\t}\n   288→\t}\n   289→\n   290→\t// Use background context — log output can be large and follow mode blocks.\n   291→\tctx := context.Background()\n   292→\tif follow {\n   293→\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n   294→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   295→\t}\n   296→\n   297→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   298→\t\tRunId:    runID,\n   299→\t\tStepName: stepFilter,\n   300→\t\tLogType:  typeFilter,\n   301→\t})\n   302→\tif err != nil {\n   303→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   304→\t\tos.Exit(1)\n   305→\t}\n   306→\n   307→\tfor {\n   308→\t\tentry, err := stream.Recv()\n   309→\t\tif err != nil {\n   310→\t\t\tif errors.Is(err, io.EOF) {\n   311→\t\t\t\tbreak\n   312→\t\t\t}\n   313→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   314→\t\t\tos.Exit(1)\n   315→\t\t}\n   316→\n   317→\t\tswitch entry.Type {\n   318→\t\tcase \"step_started\":\n   319→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   320→\t\t\tif entry.Message != \"\" {\n   321→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   322→\t\t\t}\n   323→\t\tcase \"step_completed\":\n   324→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   325→\t\t\tif entry.Message != \"\" {\n   326→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   327→\t\t\t}\n   328→\t\tcase \"run_completed\":\n   329→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   330→\t\t\tif entry.Message != \"\" {\n   331→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   332→\t\t\t}\n   333→\t\tcase \"full_log\":\n   334→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   335→\t\tcase \"log\":\n   336→\t\t\t// Live-streamed log line from an active run.\n   337→\t\t\tfmt.Println(entry.Message)\n   338→\t\tdefault:\n   339→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   340→\t\t\tif entry.StepName != \"\" {\n   341→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   342→\t\t\t}\n   343→\t\t\tif entry.Message != \"\" {\n   344→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   345→\t\t\t}\n   346→\t\t}\n   347→\t}\n   348→}\n   349→\n   350→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   351→\tif len(args) < 1 {\n   352→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   353→\t\tos.Exit(1)\n   354→\t}\n   355→\n   356→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   357→\tif err != nil {\n   358→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   359→\t\tos.Exit(1)\n   360→\t}\n   361→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   362→}\n   363→\n   364→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   365→\tif len(args) < 1 {\n   366→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   367→\t\tos.Exit(1)\n   368→\t}\n   369→\n   370→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   371→\tif err != nil {\n   372→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   373→\t\tos.Exit(1)\n   374→\t}\n   375→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   376→}\n   377→\n   378→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   379→\tcwd, _ := os.Getwd()\n   380→\n   381→\t// Check for \"stop\" subcommand\n   382→\tif len(args) > 0 && args[0] == \"stop\" {\n   383→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   384→\t\tif err != nil {\n   385→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   386→\t\t\tos.Exit(1)\n   387→\t\t}\n   388→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   389→\t\treturn\n   390→\t}\n   391→\n   392→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   393→\tvar maxConcurrent int32\n   394→\tfor i := 0; i < len(args); i++ {\n   395→\t\tswitch args[i] {\n   396→\t\tcase \"--max\":\n   397→\t\t\tif i+1 < len(args) {\n   398→\t\t\t\ti++\n   399→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   400→\t\t\t\tif n != 1 || err != nil {\n   401→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   402→\t\t\t\t\tos.Exit(1)\n   403→\t\t\t\t}\n   404→\t\t\t}\n   405→\t\t}\n   406→\t}\n   407→\n   408→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   409→\t\tProjectDir:    cwd,\n   410→\t\tMaxConcurrent: maxConcurrent,\n   411→\t})\n   412→\tif err != nil {\n   413→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   414→\t\tos.Exit(1)\n   415→\t}\n   416→\tif maxConcurrent > 0 {\n   417→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   418→\t} else {\n   419→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   420→\t}\n   421→}\n   422→\n   423→func cmdTasks(args []string) {\n   424→\t// Determine HTTP address from env\n   425→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   426→\tif httpAddr == \"\" {\n   427→\t\thttpAddr = \"localhost:8080\"\n   428→\t}\n   429→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   430→\n   431→\t// Determine project label from --project flag or current directory\n   432→\tprojectDir := \"\"\n   433→\tfor i := 0; i < len(args); i++ {\n   434→\t\tswitch args[i] {\n   435→\t\tcase \"--project\":\n   436→\t\t\tif i+1 < len(args) {\n   437→\t\t\t\ti++\n   438→\t\t\t\tprojectDir = args[i]\n   439→\t\t\t}\n   440→\t\t}\n   441→\t}\n   442→\n   443→\tif projectDir == \"\" {\n   444→\t\tcwd, _ := os.Getwd()\n   445→\t\tprojectDir = filepath.Base(cwd)\n   446→\t}\n   447→\n   448→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   449→\tresp, err := http.Get(tasksURL)\n   450→\tif err != nil {\n   451→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   452→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   453→\t\tos.Exit(1)\n   454→\t}\n   455→\tdefer resp.Body.Close()\n   456→\n   457→\tif resp.StatusCode != 200 {\n   458→\t\tbody, _ := io.ReadAll(resp.Body)\n   459→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   460→\t\tos.Exit(1)\n   461→\t}\n   462→\n   463→\ttype taskEntry struct {\n   464→\t\tID          string `json:\"id\"`\n   465→\t\tStatus      string `json:\"status\"`\n   466→\t\tTitle       string `json:\"title\"`\n   467→\t\tDescription string `json:\"description\"`\n   468→\t\tAssigned    bool   `json:\"assigned\"`\n   469→\t\tAssignedAt  string `json:\"assigned_at\"`\n   470→\t\tRunID       string `json:\"run_id\"`\n   471→\t}\n   472→\n   473→\tvar tasks []taskEntry\n   474→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   475→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   476→\t\tos.Exit(1)\n   477→\t}\n   478→\n   479→\tif len(tasks) == 0 {\n   480→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   481→\t\treturn\n   482→\t}\n   483→\n   484→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   485→\tfor _, t := range tasks {\n   486→\t\tstatus := t.Status\n   487→\t\tif status == \"\" {\n   488→\t\t\tstatus = \"open\"\n   489→\t\t}\n   490→\t\tassigned := \"-\"\n   491→\t\tif t.Assigned {\n   492→\t\t\tassigned = \"yes\"\n   493→\t\t}\n   494→\t\trunID := \"\"\n   495→\t\tif t.RunID != \"\" {\n   496→\t\t\trunID = t.RunID\n   497→\t\t\tif len(runID) > 30 {\n   498→\t\t\t\trunID = runID[:27] + \"...\"\n   499→\t\t\t}\n   500→\t\t}\n   501→\t\ttitle := t.Title\n   502→\t\tif len(title) > 40 {\n   503→\t\t\ttitle = title[:37] + \"...\"\n   504→\t\t}\n   505→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   506→\t}\n   507→}\n   508→\n   509→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   510→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   511→\tif err != nil {\n   512→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   513→\t\tos.Exit(1)\n   514→\t}\n   515→\tfmt.Println(\"Daemon shutting down.\")\n   516→}\n   517→\n   518→// resolveRunContext returns the project directory and run ID for context\n   519→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   520→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   521→func resolveRunContext() (projectDir, runID string, err error) {\n   522→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   523→\tif runID == \"\" {\n   524→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   525→\t}\n   526→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   527→\tif projectDir == \"\" {\n   528→\t\tprojectDir, err = os.Getwd()\n   529→\t\tif err != nil {\n   530→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   531→\t\t}\n   532→\t}\n   533→\treturn projectDir, runID, nil\n   534→}\n   535→\n   536→func cmdGet(args []string) {\n   537→\tif len(args) < 1 {\n   538→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   539→\t\tos.Exit(1)\n   540→\t}\n   541→\n   542→\tprojectDir, runID, err := resolveRunContext()\n   543→\tif err != nil {\n   544→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   545→\t\tos.Exit(1)\n   546→\t}\n   547→\n   548→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   549→\tif err != nil {\n   550→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   551→\t\tos.Exit(1)\n   552→\t}\n   553→\tif !ok {\n   554→\t\tos.Exit(1)\n   555→\t}\n   556→\tfmt.Println(val)\n   557→}\n   558→\n   559→func cmdSet(args []string) {\n   560→\tif len(args) < 2 {\n   561→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   562→\t\tos.Exit(1)\n   563→\t}\n   564→\n   565→\tprojectDir, runID, err := resolveRunContext()\n   566→\tif err != nil {\n   567→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   568→\t\tos.Exit(1)\n   569→\t}\n   570→\n   571→\tif err := runcontext.Set(projectDir, runID, args[0], args[1]); err != nil {\n   572→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   573→\t\tos.Exit(1)\n   574→\t}\n   575→}\n   576→"}]},"parent_tool_use_id":null,"session_id":"d13e2ce4-0d07-448e-8673-06ba707df971","uuid":"88962f64-565e-45be-b658-4ffb18d5c1be","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\tcase \"get\":\n\t\tcmdGet(os.Args[2:])\n\t\treturn\n\tcase \"set\":\n\t\tcmdSet(os.Args[2:])\n\t\treturn\n\tcase \"tasks\":\n\t\tcmdTasks(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client)\n\tdefault:\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n}\n\nfunc usage() {\n\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n\nCommands:\n  init [--workflow <name>] [--base-image <image>]\n                                             Initialize a Cloche project\n  health                                   Show project health summary\n  run --workflow <name> [--prompt \"...\"] [--title \"...\"] [--keep-container]\n                                             Launch a workflow run\n  status <run-id>                            Check run status\n  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n                                             Show logs for a run\n  poll <run-id>                              Wait for a run to finish\n  list [--all]                                List runs (last hour by default)\n  stop <run-id>                              Stop a running workflow\n  delete <container-or-run-id>               Delete a retained container\n  tasks [--project <dir>]                     Show task pipeline and assignment state\n  loop [--max <n>]                            Start orchestration loop (default max=1)\n  loop stop                                  Stop orchestration loop\n  get <key>                                  Get a value from the run context store\n  set <key> <value>                          Set a value in the run context store\n  shutdown                                   Shut down the daemon\n`)\n}\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n\tvar image string\n\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n\tif data, err := os.ReadFile(wfPath); err == nil {\n\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n\t\t\timage = wf.Config[\"container.image\"]\n\t\t}\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t}\n\t}\n\n\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n\t\tif run.Title != \"\" {\n\t\t\tt := run.Title\n\t\t\tif len(t) > 40 {\n\t\t\t\tt = t[:37] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + t\n\t\t}\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\t}\n\t}\n\n\t// Use background context — log output can be large and follow mode blocks.\n\tctx := context.Background()\n\tif follow {\n\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n\t\tctx = metadata.NewOutgoingContext(ctx, md)\n\t}\n\n\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdTasks(args []string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\t// Determine project label from --project flag or current directory\n\tprojectDir := \"\"\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tcwd, _ := os.Getwd()\n\t\tprojectDir = filepath.Base(cwd)\n\t}\n\n\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n\tresp, err := http.Get(tasksURL)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\ttype taskEntry struct {\n\t\tID          string `json:\"id\"`\n\t\tStatus      string `json:\"status\"`\n\t\tTitle       string `json:\"title\"`\n\t\tDescription string `json:\"description\"`\n\t\tAssigned    bool   `json:\"assigned\"`\n\t\tAssignedAt  string `json:\"assigned_at\"`\n\t\tRunID       string `json:\"run_id\"`\n\t}\n\n\tvar tasks []taskEntry\n\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(tasks) == 0 {\n\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n\t\treturn\n\t}\n\n\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n\tfor _, t := range tasks {\n\t\tstatus := t.Status\n\t\tif status == \"\" {\n\t\t\tstatus = \"open\"\n\t\t}\n\t\tassigned := \"-\"\n\t\tif t.Assigned {\n\t\t\tassigned = \"yes\"\n\t\t}\n\t\trunID := \"\"\n\t\tif t.RunID != \"\" {\n\t\t\trunID = t.RunID\n\t\t\tif len(runID) > 30 {\n\t\t\t\trunID = runID[:27] + \"...\"\n\t\t\t}\n\t\t}\n\t\ttitle := t.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n\n// resolveRunContext returns the project directory and run ID for context\n// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n// from CLOCHE_PROJECT_DIR (falling back to cwd).\nfunc resolveRunContext() (projectDir, runID string, err error) {\n\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n\tif runID == \"\" {\n\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n\t}\n\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n\tif projectDir == \"\" {\n\t\tprojectDir, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n\t\t}\n\t}\n\treturn projectDir, runID, nil\n}\n\nfunc cmdGet(args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif !ok {\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(val)\n}\n\nfunc cmdSet(args []string) {\n\tif len(args) < 2 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif err := runcontext.Set(projectDir, runID, args[0], args[1]); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n","numLines":576,"startLine":1,"totalLines":576}}}
