[2026-03-12T15:54:35Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012b3fSENo5YoZhMFbk4a1sK","type":"tool_result","content":"     1→package grpc_test\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"sync/atomic\"\n    10→\t\"testing\"\n    11→\t\"time\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\tserver \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    15→\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    16→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    17→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    18→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    19→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    20→\t\"github.com/stretchr/testify/assert\"\n    21→\t\"github.com/stretchr/testify/require\"\n    22→\tgrpclib \"google.golang.org/grpc\"\n    23→\t\"google.golang.org/grpc/metadata\"\n    24→)\n    25→\n    26→func TestServer_ListRuns_Empty(t *testing.T) {\n    27→\tstore, err := sqlite.NewStore(\":memory:\")\n    28→\trequire.NoError(t, err)\n    29→\tdefer store.Close()\n    30→\n    31→\tsrv := server.NewClocheServer(store, nil)\n    32→\tresp, err := srv.ListRuns(context.Background(), &pb.ListRunsRequest{All: true})\n    33→\trequire.NoError(t, err)\n    34→\tassert.Empty(t, resp.Runs)\n    35→}\n    36→\n    37→func TestServer_GetStatus_NotFound(t *testing.T) {\n    38→\tstore, err := sqlite.NewStore(\":memory:\")\n    39→\trequire.NoError(t, err)\n    40→\tdefer store.Close()\n    41→\n    42→\tsrv := server.NewClocheServer(store, nil)\n    43→\t_, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: \"nonexistent\"})\n    44→\tassert.Error(t, err)\n    45→}\n    46→\n    47→func TestServer_RunWorkflow(t *testing.T) {\n    48→\tstore, err := sqlite.NewStore(\":memory:\")\n    49→\trequire.NoError(t, err)\n    50→\tdefer store.Close()\n    51→\n    52→\tdir := t.TempDir()\n    53→\n    54→\t// Create a mock \"agent\" shell script at test.cloche that outputs JSON status lines.\n    55→\t// The local runtime runs: sh <projectDir>/test.cloche\n    56→\tmsgs := []protocol.StatusMessage{\n    57→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n    58→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n    59→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n    60→\t}\n    61→\tscript := \"#!/bin/sh\\n\"\n    62→\tfor _, msg := range msgs {\n    63→\t\tdata, _ := json.Marshal(msg)\n    64→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n    65→\t}\n    66→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n    67→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n    68→\n    69→\t// Use \"sh\" as the agent binary so it runs: sh test.cloche\n    70→\trt := local.NewRuntime(\"sh\")\n    71→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n    72→\n    73→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n    74→\t\tWorkflowName: \"test\",\n    75→\t\tProjectDir:   dir,\n    76→\t\tPrompt:       \"hello world\",\n    77→\t})\n    78→\trequire.NoError(t, err)\n    79→\tassert.NotEmpty(t, resp.RunId)\n    80→\n    81→\t// Verify prompt was written to run-specific path\n    82→\tpromptData, err := os.ReadFile(filepath.Join(dir, \".cloche\", resp.RunId, \"prompt.txt\"))\n    83→\trequire.NoError(t, err)\n    84→\tassert.Equal(t, \"hello world\", string(promptData))\n    85→\n    86→\t// Poll until the background goroutine finishes processing (up to 5s)\n    87→\tvar status *pb.GetStatusResponse\n    88→\tdeadline := time.Now().Add(5 * time.Second)\n    89→\tfor time.Now().Before(deadline) {\n    90→\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n    91→\t\trequire.NoError(t, err)\n    92→\t\tif status.State == \"succeeded\" && len(status.StepExecutions) >= 1 {\n    93→\t\t\tbreak\n    94→\t\t}\n    95→\t\ttime.Sleep(50 * time.Millisecond)\n    96→\t}\n    97→\n    98→\t// Check that the run was tracked and completed\n    99→\trequire.NotNil(t, status)\n   100→\tassert.Equal(t, resp.RunId, status.RunId)"}]},"parent_tool_use_id":"toolu_01FcGA6ED8WPxbTS4TE3BjwZ","session_id":"d13e2ce4-0d07-448e-8673-06ba707df971","uuid":"2fffc72d-a91d-40b7-87da-116239e4aa7b"}
