\n    50→\tdefer store.Close()\n    51→\n    52→\tdir := t.TempDir()\n    53→\n    54→\t// Create a mock \"agent\" shell script at test.cloche that outputs JSON status lines.\n    55→\t// The local runtime runs: sh <projectDir>/test.cloche\n    56→\tmsgs := []protocol.StatusMessage{\n    57→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n    58→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n    59→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n    60→\t}\n    61→\tscript := \"#!/bin/sh\\n\"\n    62→\tfor _, msg := range msgs {\n    63→\t\tdata, _ := json.Marshal(msg)\n    64→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n    65→\t}\n    66→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n    67→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n    68→\n    69→\t// Use \"sh\" as the agent binary so it runs: sh test.cloche\n    70→\trt := local.NewRuntime(\"sh\")\n    71→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n    72→\n    73→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n    74→\t\tWorkflowName: \"test\",\n    75→\t\tProjectDir:   dir,\n    76→\t\tPrompt:       \"hello world\",\n    77→\t})\n    78→\trequire.NoError(t, err)\n    79→\tassert.NotEmpty(t, resp.RunId)\n    80→\n    81→\t// Verify prompt was written to run-specific path\n    82→\tpromptData, err := os.ReadFile(filepath.Join(dir, \".cloche\", resp.RunId, \"prompt.txt\"))\n    83→\trequire.NoError(t, err)\n    84→\tassert.Equal(t, \"hello world\", string(promptData))\n    85→\n    86→\t// Poll until the background goroutine finishes processing (up to 5s)\n    87→\tvar status *pb.GetStatusResponse\n    88→\tdeadline := time.Now().Add(5 * time.Second)\n    89→\tfor time.Now().Before(deadline) {\n    90→\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n    91→