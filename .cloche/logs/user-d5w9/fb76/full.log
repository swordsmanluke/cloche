;\n    54→  string started_at = 3;\n    55→  string completed_at = 4;\n    56→}\n    57→\n    58→message StreamLogsRequest {\n    59→  string run_id = 1;\n    60→  string step_name = 2;\n    61→  string log_type = 3;\n    62→  bool follow = 4;  // When true, stream existing logs then continue tailing new lines (like tail -f).\n    63→                     // Passed via gRPC metadata header \"x-cloche-follow\" until proto is regenerated.\n    64→}\n    65→\n    66→message LogEntry {\n    67→  string type = 1;\n    68→  string step_name = 2;\n    69→  string result = 3;\n    70→  string message = 4;\n    71→  string timestamp = 5;\n    72→}\n    73→\n    74→message StopRunRequest {\n    75→  string run_id = 1;\n    76→}\n    77→\n    78→message StopRunResponse {}\n    79→\n    80→message ShutdownRequest {}\n    81→\n    82→message ShutdownResponse {}\n    83→\n    84→message DeleteContainerRequest {\n    85→  string id = 1;\n    86→}\n    87→\n    88→message DeleteContainerResponse {}\n    89→\n    90→message ListRunsRequest {\n    91→  bool all = 1;\n    92→  string project_dir = 2;\n    93→}\n    94→\n    95→message ListRunsResponse {\n    96→  repeated RunSummary runs = 1;\n    97→}\n    98→\n    99→message RunSummary {\n   100→  string run_id = 1;\n   101→  string workflow_name = 2;\n   102→  string state = 3;\n   103→  string started_at = 4;\n   104→  string error_message = 5;\n   105→  string container_id = 6;\n   106→  string title = 7;\n   107→  bool is_host = 8;\n   108→  string project_dir = 9;\n   109→}\n   110→\n   111→message EnableLoopRequest {\n   112→  string project_dir = 1;\n   113→  int32 max_concurrent = 2;\n   114→}\n   115→\n   116→message EnableLoopResponse {}\n   117→\n   118→message DisableLoopRequest {\n   119→  string project_dir = 1;\n   120→}\n   121→\n   122→message DisableLoopResponse {}\n   123→"}]},"parent_tool_use_id":"toolu_0165mefFg1Fyf6LaLScEQMXV","session_id":"b681cdd1-b2f2-4224-b489-8b848ed1cf19","uuid":"44e34dbe-6893-4379-b44c-78