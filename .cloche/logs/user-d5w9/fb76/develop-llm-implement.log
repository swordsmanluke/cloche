{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J9AQqXN3UNdtbdooDYyc8X","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    19→\t\"github.com/cloche-dev/cloche/internal/config\"\n    20→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    21→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    22→\t\"github.com/cloche-dev/cloche/internal/host\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    26→\trpcgrpc \"google.golang.org/grpc\"\n    27→\t\"google.golang.org/grpc/metadata\"\n    28→)\n    29→\n    30→type ClocheServer struct {\n    31→\tpb.UnimplementedClocheServiceServer\n    32→\tstore        ports.RunStore\n    33→\tcaptures     ports.CaptureStore\n    34→\tlogStore     ports.LogStore\n    35→\tcontainer    ports.ContainerRuntime\n    36→\tdefaultImage string\n    37→\tevolution    *evolution.Trigger\n    38→\tlogBroadcast *logstream.Broadcaster\n    39→\tshutdownFn   func()\n    40→\tmu           sync.Mutex\n    41→\trunIDs       map[string]string      // run_id -> container_id\n    42→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    43→}\n    44→\n    45→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    46→\treturn &ClocheServer{\n    47→\t\tstore:     store,\n    48→\t\tcontainer: container,\n    49→\t\trunIDs:    make(map[string]string),\n    50→\t\tloops:     make(map[string]*host.Loop),\n    51→\t}\n    52→}\n    53→\n    54→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    55→\treturn &ClocheServer{\n    56→\t\tstore:        store,\n    57→\t\tcaptures:     captures,\n    58→\t\tcontainer:    container,\n    59→\t\tdefaultImage: defaultImage,\n    60→\t\trunIDs:       make(map[string]string),\n    61→\t\tloops:        make(map[string]*host.Loop),\n    62→\t}\n    63→}\n    64→\n    65→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    66→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    67→\ts.logStore = ls\n    68→}\n    69→\n    70→\n    71→// SetEvolution attaches an evolution trigger to the server.\n    72→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    73→\ts.evolution = trigger\n    74→}\n    75→\n    76→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    77→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    78→\ts.logBroadcast = b\n    79→}\n    80→\n    81→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    82→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    83→\ts.shutdownFn = fn\n    84→}\n    85→\n    86→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    87→\tif s.container == nil {\n    88→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    89→\t}\n    90→\n    91→\t// Generate a unique run ID, retrying on collision\n    92→\tvar runID string\n    93→\tfor attempts := 0; attempts < 10; attempts++ {\n    94→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    95→\t\texisting, err := s.store.GetRun(ctx, runID)\n    96→\t\tif err != nil {\n    97→\t\t\tbreak // ID is free\n    98→\t\t}\n    99→\t\t// Reuse if completed more than 1 hour ago\n   100→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   101→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   102→\t\t\tbreak\n   103→\t\t}\n   104→\t}\n   105→\n   106→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   107→\tif req.Prompt != \"\" {\n   108→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   109→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   110→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   111→\t\t}\n   112→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   113→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   114→\t\t}\n   115→\t}\n   116→\trun := domain.NewRun(runID, req.WorkflowName)\n   117→\trun.ProjectDir = req.ProjectDir\n   118→\trun.Title = req.Title\n   119→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   120→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   121→\t}\n   122→\n   123→\t// Resolve image: request-level override, then server default\n   124→\timage := req.Image\n   125→\tif image == \"\" {\n   126→\t\timage = s.defaultImage\n   127→\t}\n   128→\n   129→\t// Launch container start + tracking in background so the RPC returns immediately.\n   130→\t// The run stays in \"pending\" state until the container is up.\n   131→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   132→\n   133→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   134→}\n   135→\n   136→// launchAndTrack starts the container and then tracks it to completion.\n   137→// It runs in a background goroutine with its own context, independent of the\n   138→// RPC context which may be cancelled after RunWorkflow returns.\n   139→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   140→\tctx := context.Background()\n   141→\n   142→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   143→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   144→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   145→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   146→\t\t\tif run != nil {\n   147→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   148→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   149→\t\t\t}\n   150→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   151→\t\t\t\treturn\n   152→\t\t}\n   153→\t}\n   154→\n   155→\tbaseSHA := gitHEAD(req.ProjectDir)\n   156→\n   157→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   158→\t\tImage:        image,\n   159→\t\tWorkflowName: req.WorkflowName,\n   160→\t\tProjectDir:   req.ProjectDir,\n   161→\t\tRunID:        runID,\n   162→\t\tNetworkAllow: []string{\"*\"},\n   163→\t})\n   164→\tif err != nil {\n   165→\t\trun, _ := s.store.GetRun(ctx, runID)\n   166→\t\tif run != nil {\n   167→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   168→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   169→\t\t}\n   170→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   171→\t\treturn\n   172→\t}\n   173→\n   174→\ts.mu.Lock()\n   175→\ts.runIDs[runID] = containerID\n   176→\ts.mu.Unlock()\n   177→\n   178→\trun, _ := s.store.GetRun(ctx, runID)\n   179→\tif run != nil {\n   180→\t\trun.Start()\n   181→\t\trun.ContainerID = containerID\n   182→\t\trun.BaseSHA = baseSHA\n   183→\t\t_ = s.store.UpdateRun(ctx, run)\n   184→\t}\n   185→\n   186→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   187→}\n   188→\n   189→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   190→\tctx := context.Background()\n   191→\n   192→\t// Attach to agent output\n   193→\treader, err := s.container.AttachOutput(ctx, containerID)\n   194→\tif err != nil {\n   195→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   196→\t\t\treturn\n   197→\t}\n   198→\n   199→\t// Parse JSON-lines status messages\n   200→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   201→\tscanner := bufio.NewScanner(reader)\n   202→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   203→\tfor scanner.Scan() {\n   204→\t\tvar msg protocol.StatusMessage\n   205→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   206→\t\t\tcontinue\n   207→\t\t}\n   208→\n   209→\t\t// Fast path: log messages don't need store interaction.\n   210→\t\tif msg.Type == protocol.MsgLog {\n   211→\t\t\tif s.logBroadcast != nil {\n   212→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   213→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   214→\t\t\t\t\tType:      \"llm\",\n   215→\t\t\t\t\tContent:   msg.Message,\n   216→\t\t\t\t\tStepName:  msg.StepName,\n   217→\t\t\t\t})\n   218→\t\t\t}\n   219→\t\t\tcontinue\n   220→\t\t}\n   221→\n   222→\t\trun, err := s.store.GetRun(ctx, runID)\n   223→\t\tif err != nil {\n   224→\t\t\tcontinue\n   225→\t\t}\n   226→\n   227→\t\tswitch msg.Type {\n   228→\t\tcase protocol.MsgStepStarted:\n   229→\t\t\trun.RecordStepStart(msg.StepName)\n   230→\t\t\tif s.captures != nil {\n   231→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   232→\t\t\t\t\tStepName:  msg.StepName,\n   233→\t\t\t\t\tStartedAt: msg.Timestamp,\n   234→\t\t\t\t})\n   235→\t\t\t}\n   236→\t\t\tif s.logBroadcast != nil {\n   237→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   238→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   239→\t\t\t\t\tType:      \"status\",\n   240→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   241→\t\t\t\t\tStepName:  msg.StepName,\n   242→\t\t\t\t})\n   243→\t\t\t}\n   244→\t\tcase protocol.MsgStepCompleted:\n   245→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   246→\t\t\tif s.captures != nil {\n   247→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   248→\t\t\t\t\tStepName:    msg.StepName,\n   249→\t\t\t\t\tResult:      msg.Result,\n   250→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   251→\t\t\t\t})\n   252→\t\t\t}\n   253→\t\t\tif s.logBroadcast != nil {\n   254→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   255→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   256→\t\t\t\t\tType:      \"status\",\n   257→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   258→\t\t\t\t\tStepName:  msg.StepName,\n   259→\t\t\t\t})\n   260→\t\t\t}\n   261→\t\tcase protocol.MsgRunTitle:\n   262→\t\t\tif run.Title == \"\" {\n   263→\t\t\t\trun.Title = msg.Message\n   264→\t\t\t}\n   265→\t\tcase protocol.MsgRunCompleted:\n   266→\t\t\treportedResult = msg.Result\n   267→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   268→\t\t}\n   269→\n   270→\t\t_ = s.store.UpdateRun(ctx, run)\n   271→\t}\n   272→\treader.Close()\n   273→\n   274→\t// Signal live-stream subscribers that this run is done.\n   275→\tif s.logBroadcast != nil {\n   276→\t\ts.logBroadcast.Finish(runID)\n   277→\t}\n   278→\n   279→\t// Wait for process exit\n   280→\texitCode, err := s.container.Wait(ctx, containerID)\n   281→\tif err != nil {\n   282→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   283→\t}\n   284→\n   285→\t// Extract step output files from container before it's removed\n   286→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   287→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   288→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   289→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   290→\t\t}\n   291→\t}\n   292→\n   293→\t// Capture full container stdout/stderr before the container is removed\n   294→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   295→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   296→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   297→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   298→\t\t}\n   299→\t}\n   300→\n   301→\t// Index extracted log files in the log store\n   302→\tif s.logStore != nil {\n   303→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   304→\t}\n   305→\n   306→\t// Extract results to git branch BEFORE finalizing state, so that\n   307→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   308→\t// before the run is marked complete.\n   309→\tresultLabel := reportedResult\n   310→\tif resultLabel == \"\" {\n   311→\t\tif exitCode == 0 {\n   312→\t\t\tresultLabel = \"succeeded\"\n   313→\t\t} else {\n   314→\t\t\tresultLabel = \"failed\"\n   315→\t\t}\n   316→\t}\n   317→\t{\n   318→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   319→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   320→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   321→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   322→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   323→\t\t\t} else {\n   324→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   325→\t\t\t}\n   326→\t\t} else {\n   327→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   328→\t\t}\n   329→\t}\n   330→\n   331→\t// Now finalize run state\n   332→\trun, err := s.store.GetRun(ctx, runID)\n   333→\tif err != nil {\n   334→\t\treturn\n   335→\t}\n   336→\tif run.State == domain.RunStateRunning {\n   337→\t\tif reportedResult == \"succeeded\" {\n   338→\t\t\trun.Complete(domain.RunStateSucceeded)\n   339→\t\t} else if reportedResult != \"\" {\n   340→\t\t\trun.Complete(domain.RunStateFailed)\n   341→\t\t} else if exitCode == 0 {\n   342→\t\t\trun.Complete(domain.RunStateSucceeded)\n   343→\t\t} else {\n   344→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   345→\t\t}\n   346→\t\t_ = s.store.UpdateRun(ctx, run)\n   347→\t}\n   348→\n   349→\t// Fire evolution trigger if configured\n   350→\tif s.evolution != nil {\n   351→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   352→\t}\n   353→\n   354→\t// Merge is handled as a workflow step in host.cloche, not here.\n   355→\n   356→\t// Container retention policy:\n   357→\t// - Failed runs: always keep the container for debugging\n   358→\t// - Successful runs + --keep-container: keep the container\n   359→\t// - Successful runs without --keep-container: remove the container\n   360→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   361→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   362→\n   363→\tif keepContainer || runFailed {\n   364→\t\treason := \"--keep-container\"\n   365→\t\tif runFailed {\n   366→\t\t\treason = \"run failed\"\n   367→\t\t}\n   368→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   369→\t\tif runFinal != nil {\n   370→\t\t\trunFinal.ContainerKept = true\n   371→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   372→\t\t}\n   373→\t} else {\n   374→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   375→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   376→\t\t} else {\n   377→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   378→\t\t}\n   379→\t}\n   380→\n   381→\t// Cleanup mapping\n   382→\ts.mu.Lock()\n   383→\tdelete(s.runIDs, runID)\n   384→\ts.mu.Unlock()\n   385→}\n   386→\n   387→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   388→\tvar since time.Time\n   389→\tif !req.All {\n   390→\t\tsince = time.Now().Add(-1 * time.Hour)\n   391→\t}\n   392→\truns, err := s.store.ListRuns(ctx, since)\n   393→\tif err != nil {\n   394→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   395→\t}\n   396→\n   397→\tresp := &pb.ListRunsResponse{}\n   398→\tfor _, run := range runs {\n   399→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   400→\t\t\tRunId:        run.ID,\n   401→\t\t\tWorkflowName: run.WorkflowName,\n   402→\t\t\tState:        string(run.State),\n   403→\t\t\tStartedAt:    run.StartedAt.String(),\n   404→\t\t\tErrorMessage: run.ErrorMessage,\n   405→\t\t\tContainerId:  run.ContainerID,\n   406→\t\t\tTitle:        run.Title,\n   407→\t\t\tIsHost:       run.IsHost,\n   408→\t\t})\n   409→\t}\n   410→\treturn resp, nil\n   411→}\n   412→\n   413→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   414→\trun, err := s.store.GetRun(ctx, req.RunId)\n   415→\tif err != nil {\n   416→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   417→\t}\n   418→\n   419→\tresp := &pb.GetStatusResponse{\n   420→\t\tRunId:        run.ID,\n   421→\t\tWorkflowName: run.WorkflowName,\n   422→\t\tState:        string(run.State),\n   423→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   424→\t\tErrorMessage: run.ErrorMessage,\n   425→\t\tContainerId:  run.ContainerID,\n   426→\t\tTitle:        run.Title,\n   427→\t\tIsHost:       run.IsHost,\n   428→\t}\n   429→\n   430→\t// Check container liveness\n   431→\tif run.ContainerID != \"\" && s.container != nil {\n   432→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   433→\t\t\tresp.ContainerAlive = cs.Running\n   434→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   435→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   436→\t\t\t}\n   437→\t\t}\n   438→\t}\n   439→\n   440→\t// Load step executions from captures store if available\n   441→\tif s.captures != nil {\n   442→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   443→\t\tif err == nil {\n   444→\t\t\tfor _, exec := range captures {\n   445→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   446→\t\t\t\t\tStepName:    exec.StepName,\n   447→\t\t\t\t\tResult:      exec.Result,\n   448→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   449→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   450→\t\t\t\t})\n   451→\t\t\t}\n   452→\t\t}\n   453→\t} else {\n   454→\t\tfor _, exec := range run.StepExecutions {\n   455→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   456→\t\t\t\tStepName:    exec.StepName,\n   457→\t\t\t\tResult:      exec.Result,\n   458→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   459→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   460→\t\t\t})\n   461→\t\t}\n   462→\t}\n   463→\n   464→\treturn resp, nil\n   465→}\n   466→\n   467→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   468→\tctx := stream.Context()\n   469→\n   470→\t// Check for follow mode via gRPC metadata.\n   471→\tfollow := followFromContext(ctx)\n   472→\n   473→\t// Verify run exists\n   474→\trun, err := s.store.GetRun(ctx, req.RunId)\n   475→\tif err != nil {\n   476→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   477→\t}\n   478→\n   479→\t// If step_name or log_type filter is set, serve content directly from the log index\n   480→\tif req.StepName != \"\" || req.LogType != \"\" {\n   481→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   482→\t}\n   483→\n   484→\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n   485→\n   486→\t// With -f on an active run: send existing logs then tail live output.\n   487→\tif follow && isActive && s.logBroadcast != nil {\n   488→\t\treturn s.streamFollowLogs(req.RunId, run, stream)\n   489→\t}\n   490→\n   491→\t// Without -f on an active run: snapshot existing logs and return.\n   492→\t// (Legacy callers that relied on implicit live streaming should use -f.)\n   493→\t// With -f on a completed run: same as without -f — no new lines will arrive.\n   494→\n   495→\t// Check for full.log first — if it exists, serve it as the unified log\n   496→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   497→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   498→\t\tif err := stream.Send(&pb.LogEntry{\n   499→\t\t\tType:    \"full_log\",\n   500→\t\t\tMessage: string(data),\n   501→\t\t}); err != nil {\n   502→\t\t\treturn err\n   503→\t\t}\n   504→\t\tif !isActive {\n   505→\t\t\tif err := stream.Send(&pb.LogEntry{\n   506→\t\t\t\tType:      \"run_completed\",\n   507→\t\t\t\tResult:    string(run.State),\n   508→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   509→\t\t\t\tMessage:   run.ErrorMessage,\n   510→\t\t\t}); err != nil {\n   511→\t\t\t\treturn err\n   512→\t\t\t}\n   513→\t\t}\n   514→\t\treturn nil\n   515→\t}\n   516→\n   517→\tif s.captures == nil {\n   518→\t\treturn fmt.Errorf(\"captures store not configured\")\n   519→\t}\n   520→\n   521→\t// Fall back to capture-based streaming\n   522→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   523→\tif err != nil {\n   524→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   525→\t}\n   526→\n   527→\tfor _, exec := range captures {\n   528→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   529→\t\t// and one for step_completed (has Result).\n   530→\t\tif exec.Result == \"\" {\n   531→\t\t\tentry := &pb.LogEntry{\n   532→\t\t\t\tType:      \"step_started\",\n   533→\t\t\t\tStepName:  exec.StepName,\n   534→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   535→\t\t\t}\n   536→\t\t\tif err := stream.Send(entry); err != nil {\n   537→\t\t\t\treturn err\n   538→\t\t\t}\n   539→\t\t} else {\n   540→\t\t\t// Read step output from per-step log file.\n   541→\t\t\t// Do NOT fall back to container.log — it contains unfiltered output\n   542→\t\t\t// from ALL steps and would show wrong content for this step.\n   543→\t\t\tvar output string\n   544→\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   545→\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   546→\t\t\t\toutput = string(data)\n   547→\t\t\t}\n   548→\t\t\tentry := &pb.LogEntry{\n   549→\t\t\t\tType:      \"step_completed\",\n   550→\t\t\t\tStepName:  exec.StepName,\n   551→\t\t\t\tResult:    exec.Result,\n   552→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   553→\t\t\t\tMessage:   output,\n   554→\t\t\t}\n   555→\t\t\tif err := stream.Send(entry); err != nil {\n   556→\t\t\t\treturn err\n   557→\t\t\t}\n   558→\t\t}\n   559→\t}\n   560→\n   561→\t// Send run completion entry\n   562→\tif !isActive {\n   563→\t\tif err := stream.Send(&pb.LogEntry{\n   564→\t\t\tType:      \"run_completed\",\n   565→\t\t\tResult:    string(run.State),\n   566→\t\t\tTimestamp: run.CompletedAt.String(),\n   567→\t\t\tMessage:   run.ErrorMessage,\n   568→\t\t}); err != nil {\n   569→\t\t\treturn err\n   570→\t\t}\n   571→\t}\n   572→\n   573→\treturn nil\n   574→}\n   575→\n   576→// followFromContext checks for the follow flag in gRPC metadata.\n   577→func followFromContext(ctx context.Context) bool {\n   578→\tmd, ok := metadata.FromIncomingContext(ctx)\n   579→\tif !ok {\n   580→\t\treturn false\n   581→\t}\n   582→\tvals := md.Get(\"x-cloche-follow\")\n   583→\treturn len(vals) > 0 && vals[0] == \"true\"\n   584→}\n   585→\n   586→// streamFollowLogs sends existing log content then tails live output from the\n   587→// broadcaster. It combines snapshot + live streaming (like tail -f).\n   588→func (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   589→\t// Subscribe first so we don't miss lines written between read and subscribe.\n   590→\tsub := s.logBroadcast.Subscribe(runID)\n   591→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   592→\n   593→\t// Send existing full.log content if available.\n   594→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n   595→\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n   596→\t\tif err := stream.Send(&pb.LogEntry{\n   597→\t\t\tType:    \"full_log\",\n   598→\t\t\tMessage: string(data),\n   599→\t\t}); err != nil {\n   600→\t\t\treturn err\n   601→\t\t}\n   602→\t}\n   603→\n   604→\t// Now tail live output from the broadcaster.\n   605→\tctx := stream.Context()\n   606→\tfor {\n   607→\t\tselect {\n   608→\t\tcase <-ctx.Done():\n   609→\t\t\treturn ctx.Err()\n   610→\t\tcase line, ok := <-sub.C:\n   611→\t\t\tif !ok {\n   612→\t\t\t\t// Run completed — send terminal entry.\n   613→\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n   614→\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n   615→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   616→\t\t\t\t\t\tType:      \"run_completed\",\n   617→\t\t\t\t\t\tResult:    string(r.State),\n   618→\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n   619→\t\t\t\t\t\tMessage:   r.ErrorMessage,\n   620→\t\t\t\t\t})\n   621→\t\t\t\t}\n   622→\t\t\t\treturn nil\n   623→\t\t\t}\n   624→\t\t\tif err := stream.Send(&pb.LogEntry{\n   625→\t\t\t\tType:      \"log\",\n   626→\t\t\t\tStepName:  line.StepName,\n   627→\t\t\t\tMessage:   line.Content,\n   628→\t\t\t\tTimestamp: line.Timestamp,\n   629→\t\t\t}); err != nil {\n   630→\t\t\t\treturn err\n   631→\t\t\t}\n   632→\t\t}\n   633→\t}\n   634→}\n   635→\n   636→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   637→// It uses the log index when available, falling back to file path conventions.\n   638→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   639→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   640→\n   641→\t// Try log index first\n   642→\tif s.logStore != nil {\n   643→\t\tvar logFiles []*ports.LogFileEntry\n   644→\t\tvar err error\n   645→\n   646→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   647→\t\t\t// Filter by both step and type\n   648→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   649→\t\t\tif err == nil {\n   650→\t\t\t\tfiltered := logFiles[:0]\n   651→\t\t\t\tfor _, lf := range logFiles {\n   652→\t\t\t\t\tif lf.FileType == req.LogType {\n   653→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   654→\t\t\t\t\t}\n   655→\t\t\t\t}\n   656→\t\t\t\tlogFiles = filtered\n   657→\t\t\t}\n   658→\t\t} else if req.StepName != \"\" {\n   659→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   660→\t\t} else {\n   661→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   662→\t\t}\n   663→\n   664→\t\tif err == nil && len(logFiles) > 0 {\n   665→\t\t\tfor _, lf := range logFiles {\n   666→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   667→\t\t\t\tif readErr != nil {\n   668→\t\t\t\t\tcontinue\n   669→\t\t\t\t}\n   670→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   671→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   672→\t\t\t\t\tStepName: lf.StepName,\n   673→\t\t\t\t\tMessage:  string(data),\n   674→\t\t\t\t}); err != nil {\n   675→\t\t\t\t\treturn err\n   676→\t\t\t\t}\n   677→\t\t\t}\n   678→\t\t\treturn nil\n   679→\t\t}\n   680→\t}\n   681→\n   682→\t// Fall back to file path conventions\n   683→\tif req.StepName != \"\" {\n   684→\t\tvar logPath string\n   685→\t\tswitch req.LogType {\n   686→\t\tcase \"llm\":\n   687→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   688→\t\tdefault:\n   689→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   690→\t\t}\n   691→\n   692→\t\tdata, err := os.ReadFile(logPath)\n   693→\t\tif err != nil {\n   694→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   695→\t\t}\n   696→\t\treturn stream.Send(&pb.LogEntry{\n   697→\t\t\tType:     \"step_log\",\n   698→\t\t\tStepName: req.StepName,\n   699→\t\t\tMessage:  string(data),\n   700→\t\t})\n   701→\t}\n   702→\n   703→\treturn fmt.Errorf(\"no log files found matching filter\")\n   704→}\n   705→\n   706→// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n   707→// time for an active run. The stream closes when the run completes or the\n   708→// client disconnects.\n   709→func (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   710→\tsub := s.logBroadcast.Subscribe(runID)\n   711→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   712→\n   713→\tctx := stream.Context()\n   714→\tfor {\n   715→\t\tselect {\n   716→\t\tcase <-ctx.Done():\n   717→\t\t\treturn ctx.Err()\n   718→\t\tcase line, ok := <-sub.C:\n   719→\t\t\tif !ok {\n   720→\t\t\t\t// Run completed — send terminal entry.\n   721→\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   722→\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   723→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   724→\t\t\t\t\t\tType:      \"run_completed\",\n   725→\t\t\t\t\t\tResult:    string(run.State),\n   726→\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   727→\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   728→\t\t\t\t\t})\n   729→\t\t\t\t}\n   730→\t\t\t\treturn nil\n   731→\t\t\t}\n   732→\t\t\tif err := stream.Send(&pb.LogEntry{\n   733→\t\t\t\tType:      \"log\",\n   734→\t\t\t\tStepName:  line.StepName,\n   735→\t\t\t\tMessage:   line.Content,\n   736→\t\t\t\tTimestamp: line.Timestamp,\n   737→\t\t\t}); err != nil {\n   738→\t\t\t\treturn err\n   739→\t\t\t}\n   740→\t\t}\n   741→\t}\n   742→}\n   743→\n   744→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   745→\ts.mu.Lock()\n   746→\tcontainerID, ok := s.runIDs[req.RunId]\n   747→\ts.mu.Unlock()\n   748→\n   749→\tif !ok {\n   750→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   751→\t}\n   752→\n   753→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   754→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   755→\t}\n   756→\n   757→\t// Mark as cancelled in store\n   758→\trun, err := s.store.GetRun(ctx, req.RunId)\n   759→\tif err == nil {\n   760→\t\trun.Complete(domain.RunStateCancelled)\n   761→\t\t_ = s.store.UpdateRun(ctx, run)\n   762→\t}\n   763→\n   764→\treturn &pb.StopRunResponse{}, nil\n   765→}\n   766→\n   767→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   768→\tif s.container == nil {\n   769→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   770→\t}\n   771→\n   772→\tid := req.Id\n   773→\tif id == \"\" {\n   774→\t\treturn nil, fmt.Errorf(\"id is required\")\n   775→\t}\n   776→\n   777→\t// Try to resolve as a run ID first\n   778→\tcontainerID := id\n   779→\trun, err := s.store.GetRun(ctx, id)\n   780→\tif err == nil {\n   781→\t\t// It's a run ID — use the container ID from the run record\n   782→\t\tif run.ContainerID == \"\" {\n   783→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   784→\t\t}\n   785→\t\tcontainerID = run.ContainerID\n   786→\t}\n   787→\n   788→\t// Remove the container\n   789→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   790→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   791→\t}\n   792→\n   793→\t// If we resolved a run, clear the container_kept flag\n   794→\tif run != nil {\n   795→\t\trun.ContainerKept = false\n   796→\t\t_ = s.store.UpdateRun(ctx, run)\n   797→\t}\n   798→\n   799→\treturn &pb.DeleteContainerResponse{}, nil\n   800→}\n   801→\n   802→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   803→\tprojectDir := req.ProjectDir\n   804→\tif projectDir == \"\" {\n   805→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   806→\t}\n   807→\n   808→\t// Verify host.cloche exists\n   809→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   810→\tif _, err := os.Stat(hostPath); err != nil {\n   811→\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n   812→\t}\n   813→\n   814→\t// Load project config for defaults.\n   815→\tprojCfg, _ := config.Load(projectDir)\n   816→\n   817→\tmaxConc := int(req.MaxConcurrent)\n   818→\tif maxConc <= 0 {\n   819→\t\tmaxConc = projCfg.Orchestration.Concurrency\n   820→\t}\n   821→\tif maxConc <= 0 {\n   822→\t\tmaxConc = 1\n   823→\t}\n   824→\n   825→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   826→\n   827→\t// Compute dedup timeout from config (default 5 minutes).\n   828→\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n   829→\n   830→\tloopCfg := host.LoopConfig{\n   831→\t\tProjectDir:    projectDir,\n   832→\t\tMaxConcurrent: maxConc,\n   833→\t\tStaggerDelay:  stagger,\n   834→\t\tDedupTimeout:  dedupTimeout,\n   835→\t}\n   836→\n   837→\ts.mu.Lock()\n   838→\tdefer s.mu.Unlock()\n   839→\n   840→\t// Stop existing loop if running.\n   841→\tif existing, ok := s.loops[projectDir]; ok {\n   842→\t\texisting.Stop()\n   843→\t}\n   844→\n   845→\t// Check if host.cloche defines a list-tasks workflow for three-phase mode.\n   846→\tvar loop *host.Loop\n   847→\tif s.hasWorkflow(hostPath, \"list-tasks\") {\n   848→\t\tloop = s.createPhaseLoop(loopCfg, projectDir, hostPath, dedupTimeout)\n   849→\t} else {\n   850→\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n   851→\t}\n   852→\n   853→\ts.loops[projectDir] = loop\n   854→\tloop.Start()\n   855→\n   856→\treturn &pb.EnableLoopResponse{}, nil\n   857→}\n   858→\n   859→// hasWorkflow checks if host.cloche contains a workflow with the given name.\n   860→func (s *ClocheServer) hasWorkflow(hostPath, workflowName string) bool {\n   861→\tdata, err := os.ReadFile(hostPath)\n   862→\tif err != nil {\n   863→\t\treturn false\n   864→\t}\n   865→\treturn strings.Contains(string(data), fmt.Sprintf(\"workflow %q\", workflowName))\n   866→}\n   867→\n   868→// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n   869→// main, and finalize workflows from host.cloche.\n   870→func (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir, hostPath string, dedupTimeout time.Duration) *host.Loop {\n   871→\t// Phase 1: list-tasks function\n   872→\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n   873→\t\trunner := &host.Runner{\n   874→\t\t\tDispatcher: s,\n   875→\t\t\tStore:      s.store,\n   876→\t\t}\n   877→\t\ttasks, _, err := host.RunListTasksWorkflow(ctx, runner, projDir)\n   878→\t\treturn tasks, err\n   879→\t}\n   880→\n   881→\t// Phase 2: main function\n   882→\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   883→\t\trunner := &host.Runner{\n   884→\t\t\tDispatcher: s,\n   885→\t\t\tStore:      s.store,\n   886→\t\t\tTaskID:     taskID,\n   887→\t\t}\n   888→\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n   889→\t}\n   890→\n   891→\t// Phase 3: finalize function (optional — only if host.cloche has it)\n   892→\tvar finalizeFn host.FinalizeFunc\n   893→\tif s.hasWorkflow(hostPath, \"finalize\") {\n   894→\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n   895→\t\t\tmainRunID := \"\"\n   896→\t\t\tmainOutcome := \"failed\"\n   897→\t\t\tif mainResult != nil {\n   898→\t\t\t\tmainRunID = mainResult.RunID\n   899→\t\t\t\tmainOutcome = string(mainResult.State)\n   900→\t\t\t}\n   901→\t\t\trunner := &host.Runner{\n   902→\t\t\t\tDispatcher: s,\n   903→\t\t\t\tStore:      s.store,\n   904→\t\t\t\tTaskID:     taskID,\n   905→\t\t\t\tExtraEnv: []string{\n   906→\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n   907→\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n   908→\t\t\t\t},\n   909→\t\t\t}\n   910→\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n   911→\t\t}\n   912→\t}\n   913→\n   914→\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n   915→\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n   916→}\n   917→\n   918→// createLegacyLoop creates a legacy single-function orchestration loop.\n   919→func (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n   920→\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   921→\t\trunner := &host.Runner{\n   922→\t\t\tDispatcher: s,\n   923→\t\t\tStore:      s.store,\n   924→\t\t\tTaskID:     taskID,\n   925→\t\t}\n   926→\t\treturn runner.Run(ctx, projDir)\n   927→\t}\n   928→\n   929→\tloop := host.NewLoop(loopCfg, s.store, runFn)\n   930→\n   931→\t// Configure daemon-managed task assignment if a list-tasks command is set.\n   932→\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n   933→\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n   934→\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n   935→\t}\n   936→\n   937→\treturn loop\n   938→}\n   939→\n   940→// GetLoopTasks returns the current task pipeline state for a project's\n   941→// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n   942→// loop is active for the project.\n   943→func (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n   944→\ts.mu.Lock()\n   945→\tloop, ok := s.loops[projectDir]\n   946→\ts.mu.Unlock()\n   947→\tif !ok {\n   948→\t\treturn nil\n   949→\t}\n   950→\tsnapshot := loop.GetTaskSnapshot()\n   951→\tentries := make([]web.TaskEntry, len(snapshot))\n   952→\tfor i, e := range snapshot {\n   953→\t\tentry := web.TaskEntry{\n   954→\t\t\tID:          e.Task.ID,\n   955→\t\t\tStatus:      e.Task.Status,\n   956→\t\t\tTitle:       e.Task.Title,\n   957→\t\t\tDescription: e.Task.Description,\n   958→\t\t\tMetadata:    e.Task.Metadata,\n   959→\t\t\tAssigned:    e.Assigned,\n   960→\t\t\tRunID:       e.RunID,\n   961→\t\t}\n   962→\t\tif !e.AssignedAt.IsZero() {\n   963→\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n   964→\t\t}\n   965→\t\tentries[i] = entry\n   966→\t}\n   967→\treturn entries\n   968→}\n   969→\n   970→func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n   971→\tprojectDir := req.ProjectDir\n   972→\tif projectDir == \"\" {\n   973→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   974→\t}\n   975→\n   976→\ts.mu.Lock()\n   977→\tdefer s.mu.Unlock()\n   978→\n   979→\tif loop, ok := s.loops[projectDir]; ok {\n   980→\t\tloop.Stop()\n   981→\t\tdelete(s.loops, projectDir)\n   982→\t}\n   983→\n   984→\treturn &pb.DisableLoopResponse{}, nil\n   985→}\n   986→\n   987→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n   988→\t// Stop all orchestration loops.\n   989→\ts.mu.Lock()\n   990→\tfor _, loop := range s.loops {\n   991→\t\tloop.Stop()\n   992→\t}\n   993→\ts.loops = make(map[string]*host.Loop)\n   994→\ts.mu.Unlock()\n   995→\n   996→\tif s.shutdownFn == nil {\n   997→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n   998→\t}\n   999→\tgo s.shutdownFn()\n  1000→\treturn &pb.ShutdownResponse{}, nil\n  1001→}\n  1002→\n  1003→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n  1004→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n  1005→\tentries, err := os.ReadDir(outputDir)\n  1006→\tif err != nil {\n  1007→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n  1008→\t\treturn\n  1009→\t}\n  1010→\n  1011→\tnow := time.Now()\n  1012→\tfor _, entry := range entries {\n  1013→\t\tif entry.IsDir() {\n  1014→\t\t\tcontinue\n  1015→\t\t}\n  1016→\t\tname := entry.Name()\n  1017→\t\tif !strings.HasSuffix(name, \".log\") {\n  1018→\t\t\tcontinue\n  1019→\t\t}\n  1020→\n  1021→\t\tvar fileType, stepName string\n  1022→\t\tbase := strings.TrimSuffix(name, \".log\")\n  1023→\n  1024→\t\tswitch {\n  1025→\t\tcase name == \"full.log\":\n  1026→\t\t\tfileType = \"full\"\n  1027→\t\tcase name == \"container.log\":\n  1028→\t\t\t// container.log is internal, not indexed as a user-facing log type\n  1029→\t\t\tcontinue\n  1030→\t\tcase strings.HasPrefix(name, \"llm-\"):\n  1031→\t\t\tfileType = \"llm\"\n  1032→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n  1033→\t\tdefault:\n  1034→\t\t\tfileType = \"script\"\n  1035→\t\t\tstepName = base\n  1036→\t\t}\n  1037→\n  1038→\t\tinfo, _ := entry.Info()\n  1039→\t\tvar fileSize int64\n  1040→\t\tif info != nil {\n  1041→\t\t\tfileSize = info.Size()\n  1042→\t\t}\n  1043→\n  1044→\t\tlogEntry := &ports.LogFileEntry{\n  1045→\t\t\tRunID:     runID,\n  1046→\t\t\tStepName:  stepName,\n  1047→\t\t\tFileType:  fileType,\n  1048→\t\t\tFilePath:  filepath.Join(outputDir, name),\n  1049→\t\t\tFileSize:  fileSize,\n  1050→\t\t\tCreatedAt: now,\n  1051→\t\t}\n  1052→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n  1053→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n  1054→\t\t}\n  1055→\t}\n  1056→}\n  1057→\n  1058→func gitHEAD(dir string) string {\n  1059→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n  1060→\tcmd.Dir = dir\n  1061→\tout, err := cmd.Output()\n  1062→\tif err != nil {\n  1063→\t\treturn \"\"\n  1064→\t}\n  1065→\treturn strings.TrimSpace(string(out))\n  1066→}\n  1067→"}]},"parent_tool_use_id":null,"session_id":"d13e2ce4-0d07-448e-8673-06ba707df971","uuid":"a2fe48d9-9e9d-4fe1-bb73-99f8da17c4ed","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server.go","content":"package grpc\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\t\"github.com/cloche-dev/cloche/internal/host\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\trpcgrpc \"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\ntype ClocheServer struct {\n\tpb.UnimplementedClocheServiceServer\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogStore     ports.LogStore\n\tcontainer    ports.ContainerRuntime\n\tdefaultImage string\n\tevolution    *evolution.Trigger\n\tlogBroadcast *logstream.Broadcaster\n\tshutdownFn   func()\n\tmu           sync.Mutex\n\trunIDs       map[string]string      // run_id -> container_id\n\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n}\n\nfunc NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:     store,\n\t\tcontainer: container,\n\t\trunIDs:    make(map[string]string),\n\t\tloops:     make(map[string]*host.Loop),\n\t}\n}\n\nfunc NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:        store,\n\t\tcaptures:     captures,\n\t\tcontainer:    container,\n\t\tdefaultImage: defaultImage,\n\t\trunIDs:       make(map[string]string),\n\t\tloops:        make(map[string]*host.Loop),\n\t}\n}\n\n// SetLogStore attaches a log store to the server for indexing extracted log files.\nfunc (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n\ts.logStore = ls\n}\n\n\n// SetEvolution attaches an evolution trigger to the server.\nfunc (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n\ts.evolution = trigger\n}\n\n// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\nfunc (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n\ts.logBroadcast = b\n}\n\n// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\nfunc (s *ClocheServer) SetShutdownFunc(fn func()) {\n\ts.shutdownFn = fn\n}\n\nfunc (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\t// Generate a unique run ID, retrying on collision\n\tvar runID string\n\tfor attempts := 0; attempts < 10; attempts++ {\n\t\trunID = domain.GenerateRunID(req.WorkflowName)\n\t\texisting, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tbreak // ID is free\n\t\t}\n\t\t// Reuse if completed more than 1 hour ago\n\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n\t\t\t_ = s.store.DeleteRun(ctx, runID)\n\t\t\tbreak\n\t\t}\n\t}\n\n\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n\tif req.Prompt != \"\" {\n\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n\t\t}\n\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n\t\t}\n\t}\n\trun := domain.NewRun(runID, req.WorkflowName)\n\trun.ProjectDir = req.ProjectDir\n\trun.Title = req.Title\n\tif err := s.store.CreateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n\t}\n\n\t// Resolve image: request-level override, then server default\n\timage := req.Image\n\tif image == \"\" {\n\t\timage = s.defaultImage\n\t}\n\n\t// Launch container start + tracking in background so the RPC returns immediately.\n\t// The run stays in \"pending\" state until the container is up.\n\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n\n\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n}\n\n// launchAndTrack starts the container and then tracks it to completion.\n// It runs in a background goroutine with its own context, independent of the\n// RPC context which may be cancelled after RunWorkflow returns.\nfunc (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n\tctx := context.Background()\n\n\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n\t\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\t\tif run != nil {\n\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t\t}\n\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n\t\t\t\treturn\n\t\t}\n\t}\n\n\tbaseSHA := gitHEAD(req.ProjectDir)\n\n\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n\t\tImage:        image,\n\t\tWorkflowName: req.WorkflowName,\n\t\tProjectDir:   req.ProjectDir,\n\t\tRunID:        runID,\n\t\tNetworkAllow: []string{\"*\"},\n\t})\n\tif err != nil {\n\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\tif run != nil {\n\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t}\n\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n\t\treturn\n\t}\n\n\ts.mu.Lock()\n\ts.runIDs[runID] = containerID\n\ts.mu.Unlock()\n\n\trun, _ := s.store.GetRun(ctx, runID)\n\tif run != nil {\n\t\trun.Start()\n\t\trun.ContainerID = containerID\n\t\trun.BaseSHA = baseSHA\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n}\n\nfunc (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n\tctx := context.Background()\n\n\t// Attach to agent output\n\treader, err := s.container.AttachOutput(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n\t\t\treturn\n\t}\n\n\t// Parse JSON-lines status messages\n\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n\tscanner := bufio.NewScanner(reader)\n\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n\tfor scanner.Scan() {\n\t\tvar msg protocol.StatusMessage\n\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Fast path: log messages don't need store interaction.\n\t\tif msg.Type == protocol.MsgLog {\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"llm\",\n\t\t\t\t\tContent:   msg.Message,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\trun, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch msg.Type {\n\t\tcase protocol.MsgStepStarted:\n\t\t\trun.RecordStepStart(msg.StepName)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t\tStartedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"status\",\n\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgStepCompleted:\n\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:    msg.StepName,\n\t\t\t\t\tResult:      msg.Result,\n\t\t\t\t\tCompletedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"status\",\n\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgRunTitle:\n\t\t\tif run.Title == \"\" {\n\t\t\t\trun.Title = msg.Message\n\t\t\t}\n\t\tcase protocol.MsgRunCompleted:\n\t\t\treportedResult = msg.Result\n\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n\t\t}\n\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\treader.Close()\n\n\t// Signal live-stream subscribers that this run is done.\n\tif s.logBroadcast != nil {\n\t\ts.logBroadcast.Finish(runID)\n\t}\n\n\t// Wait for process exit\n\texitCode, err := s.container.Wait(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n\t}\n\n\t// Extract step output files from container before it's removed\n\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n\t\t}\n\t}\n\n\t// Capture full container stdout/stderr before the container is removed\n\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n\t\t}\n\t}\n\n\t// Index extracted log files in the log store\n\tif s.logStore != nil {\n\t\ts.indexLogFiles(ctx, runID, outputDst)\n\t}\n\n\t// Extract results to git branch BEFORE finalizing state, so that\n\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n\t// before the run is marked complete.\n\tresultLabel := reportedResult\n\tif resultLabel == \"\" {\n\t\tif exitCode == 0 {\n\t\t\tresultLabel = \"succeeded\"\n\t\t} else {\n\t\t\tresultLabel = \"failed\"\n\t\t}\n\t}\n\t{\n\t\textractRun, _ := s.store.GetRun(ctx, runID)\n\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n\t\t\t} else {\n\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n\t\t\t}\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n\t\t}\n\t}\n\n\t// Now finalize run state\n\trun, err := s.store.GetRun(ctx, runID)\n\tif err != nil {\n\t\treturn\n\t}\n\tif run.State == domain.RunStateRunning {\n\t\tif reportedResult == \"succeeded\" {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else if reportedResult != \"\" {\n\t\t\trun.Complete(domain.RunStateFailed)\n\t\t} else if exitCode == 0 {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else {\n\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n\t\t}\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\t// Fire evolution trigger if configured\n\tif s.evolution != nil {\n\t\ts.evolution.Fire(projectDir, workflowName, runID)\n\t}\n\n\t// Merge is handled as a workflow step in host.cloche, not here.\n\n\t// Container retention policy:\n\t// - Failed runs: always keep the container for debugging\n\t// - Successful runs + --keep-container: keep the container\n\t// - Successful runs without --keep-container: remove the container\n\trunFinal, _ := s.store.GetRun(ctx, runID)\n\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n\n\tif keepContainer || runFailed {\n\t\treason := \"--keep-container\"\n\t\tif runFailed {\n\t\t\treason = \"run failed\"\n\t\t}\n\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n\t\tif runFinal != nil {\n\t\t\trunFinal.ContainerKept = true\n\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n\t\t}\n\t} else {\n\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n\t\t}\n\t}\n\n\t// Cleanup mapping\n\ts.mu.Lock()\n\tdelete(s.runIDs, runID)\n\ts.mu.Unlock()\n}\n\nfunc (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n\tvar since time.Time\n\tif !req.All {\n\t\tsince = time.Now().Add(-1 * time.Hour)\n\t}\n\truns, err := s.store.ListRuns(ctx, since)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n\t}\n\n\tresp := &pb.ListRunsResponse{}\n\tfor _, run := range runs {\n\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n\t\t\tRunId:        run.ID,\n\t\t\tWorkflowName: run.WorkflowName,\n\t\t\tState:        string(run.State),\n\t\t\tStartedAt:    run.StartedAt.String(),\n\t\t\tErrorMessage: run.ErrorMessage,\n\t\t\tContainerId:  run.ContainerID,\n\t\t\tTitle:        run.Title,\n\t\t\tIsHost:       run.IsHost,\n\t\t})\n\t}\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n\t}\n\n\tresp := &pb.GetStatusResponse{\n\t\tRunId:        run.ID,\n\t\tWorkflowName: run.WorkflowName,\n\t\tState:        string(run.State),\n\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n\t\tErrorMessage: run.ErrorMessage,\n\t\tContainerId:  run.ContainerID,\n\t\tTitle:        run.Title,\n\t\tIsHost:       run.IsHost,\n\t}\n\n\t// Check container liveness\n\tif run.ContainerID != \"\" && s.container != nil {\n\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n\t\t\tresp.ContainerAlive = cs.Running\n\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n\t\t\t}\n\t\t}\n\t}\n\n\t// Load step executions from captures store if available\n\tif s.captures != nil {\n\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\t\tif err == nil {\n\t\t\tfor _, exec := range captures {\n\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\t\tStepName:    exec.StepName,\n\t\t\t\t\tResult:      exec.Result,\n\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, exec := range run.StepExecutions {\n\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\tStepName:    exec.StepName,\n\t\t\t\tResult:      exec.Result,\n\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t})\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tctx := stream.Context()\n\n\t// Check for follow mode via gRPC metadata.\n\tfollow := followFromContext(ctx)\n\n\t// Verify run exists\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n\t}\n\n\t// If step_name or log_type filter is set, serve content directly from the log index\n\tif req.StepName != \"\" || req.LogType != \"\" {\n\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n\t}\n\n\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n\n\t// With -f on an active run: send existing logs then tail live output.\n\tif follow && isActive && s.logBroadcast != nil {\n\t\treturn s.streamFollowLogs(req.RunId, run, stream)\n\t}\n\n\t// Without -f on an active run: snapshot existing logs and return.\n\t// (Legacy callers that relied on implicit live streaming should use -f.)\n\t// With -f on a completed run: same as without -f — no new lines will arrive.\n\n\t// Check for full.log first — if it exists, serve it as the unified log\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: string(data),\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif !isActive {\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"run_completed\",\n\t\t\t\tResult:    string(run.State),\n\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}\n\n\tif s.captures == nil {\n\t\treturn fmt.Errorf(\"captures store not configured\")\n\t}\n\n\t// Fall back to capture-based streaming\n\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n\t}\n\n\tfor _, exec := range captures {\n\t\t// Captures are stored as separate rows: one for step_started (no Result)\n\t\t// and one for step_completed (has Result).\n\t\tif exec.Result == \"\" {\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_started\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tTimestamp: exec.StartedAt.String(),\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t} else {\n\t\t\t// Read step output from per-step log file.\n\t\t\t// Do NOT fall back to container.log — it contains unfiltered output\n\t\t\t// from ALL steps and would show wrong content for this step.\n\t\t\tvar output string\n\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\t\t\toutput = string(data)\n\t\t\t}\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_completed\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tResult:    exec.Result,\n\t\t\t\tTimestamp: exec.CompletedAt.String(),\n\t\t\t\tMessage:   output,\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\t// Send run completion entry\n\tif !isActive {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:      \"run_completed\",\n\t\t\tResult:    string(run.State),\n\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\tMessage:   run.ErrorMessage,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// followFromContext checks for the follow flag in gRPC metadata.\nfunc followFromContext(ctx context.Context) bool {\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif !ok {\n\t\treturn false\n\t}\n\tvals := md.Get(\"x-cloche-follow\")\n\treturn len(vals) > 0 && vals[0] == \"true\"\n}\n\n// streamFollowLogs sends existing log content then tails live output from the\n// broadcaster. It combines snapshot + live streaming (like tail -f).\nfunc (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\t// Subscribe first so we don't miss lines written between read and subscribe.\n\tsub := s.logBroadcast.Subscribe(runID)\n\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n\n\t// Send existing full.log content if available.\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: string(data),\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\t// Now tail live output from the broadcaster.\n\tctx := stream.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Run completed — send terminal entry.\n\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n\t\t\t\t\t\tType:      \"run_completed\",\n\t\t\t\t\t\tResult:    string(r.State),\n\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n\t\t\t\t\t\tMessage:   r.ErrorMessage,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"log\",\n\t\t\t\tStepName:  line.StepName,\n\t\t\t\tMessage:   line.Content,\n\t\t\t\tTimestamp: line.Timestamp,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n}\n\n// streamFilteredLogs serves log content filtered by step name and/or log type.\n// It uses the log index when available, falling back to file path conventions.\nfunc (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n\n\t// Try log index first\n\tif s.logStore != nil {\n\t\tvar logFiles []*ports.LogFileEntry\n\t\tvar err error\n\n\t\tif req.StepName != \"\" && req.LogType != \"\" {\n\t\t\t// Filter by both step and type\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t\tif err == nil {\n\t\t\t\tfiltered := logFiles[:0]\n\t\t\t\tfor _, lf := range logFiles {\n\t\t\t\t\tif lf.FileType == req.LogType {\n\t\t\t\t\t\tfiltered = append(filtered, lf)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tlogFiles = filtered\n\t\t\t}\n\t\t} else if req.StepName != \"\" {\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t} else {\n\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n\t\t}\n\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr != nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\t\tType:     lf.FileType + \"_log\",\n\t\t\t\t\tStepName: lf.StepName,\n\t\t\t\t\tMessage:  string(data),\n\t\t\t\t}); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Fall back to file path conventions\n\tif req.StepName != \"\" {\n\t\tvar logPath string\n\t\tswitch req.LogType {\n\t\tcase \"llm\":\n\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n\t\tdefault:\n\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n\t\t}\n\n\t\tdata, err := os.ReadFile(logPath)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n\t\t}\n\t\treturn stream.Send(&pb.LogEntry{\n\t\t\tType:     \"step_log\",\n\t\t\tStepName: req.StepName,\n\t\t\tMessage:  string(data),\n\t\t})\n\t}\n\n\treturn fmt.Errorf(\"no log files found matching filter\")\n}\n\n// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n// time for an active run. The stream closes when the run completes or the\n// client disconnects.\nfunc (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tsub := s.logBroadcast.Subscribe(runID)\n\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n\n\tctx := stream.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Run completed — send terminal entry.\n\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n\t\t\t\t\t\tType:      \"run_completed\",\n\t\t\t\t\t\tResult:    string(run.State),\n\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"log\",\n\t\t\t\tStepName:  line.StepName,\n\t\t\t\tMessage:   line.Content,\n\t\t\t\tTimestamp: line.Timestamp,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n\ts.mu.Lock()\n\tcontainerID, ok := s.runIDs[req.RunId]\n\ts.mu.Unlock()\n\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n\t}\n\n\tif err := s.container.Stop(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n\t}\n\n\t// Mark as cancelled in store\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err == nil {\n\t\trun.Complete(domain.RunStateCancelled)\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.StopRunResponse{}, nil\n}\n\nfunc (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\tid := req.Id\n\tif id == \"\" {\n\t\treturn nil, fmt.Errorf(\"id is required\")\n\t}\n\n\t// Try to resolve as a run ID first\n\tcontainerID := id\n\trun, err := s.store.GetRun(ctx, id)\n\tif err == nil {\n\t\t// It's a run ID — use the container ID from the run record\n\t\tif run.ContainerID == \"\" {\n\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n\t\t}\n\t\tcontainerID = run.ContainerID\n\t}\n\n\t// Remove the container\n\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n\t}\n\n\t// If we resolved a run, clear the container_kept flag\n\tif run != nil {\n\t\trun.ContainerKept = false\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.DeleteContainerResponse{}, nil\n}\n\nfunc (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n\tprojectDir := req.ProjectDir\n\tif projectDir == \"\" {\n\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n\t}\n\n\t// Verify host.cloche exists\n\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n\tif _, err := os.Stat(hostPath); err != nil {\n\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n\t}\n\n\t// Load project config for defaults.\n\tprojCfg, _ := config.Load(projectDir)\n\n\tmaxConc := int(req.MaxConcurrent)\n\tif maxConc <= 0 {\n\t\tmaxConc = projCfg.Orchestration.Concurrency\n\t}\n\tif maxConc <= 0 {\n\t\tmaxConc = 1\n\t}\n\n\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n\n\t// Compute dedup timeout from config (default 5 minutes).\n\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n\n\tloopCfg := host.LoopConfig{\n\t\tProjectDir:    projectDir,\n\t\tMaxConcurrent: maxConc,\n\t\tStaggerDelay:  stagger,\n\t\tDedupTimeout:  dedupTimeout,\n\t}\n\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\t// Stop existing loop if running.\n\tif existing, ok := s.loops[projectDir]; ok {\n\t\texisting.Stop()\n\t}\n\n\t// Check if host.cloche defines a list-tasks workflow for three-phase mode.\n\tvar loop *host.Loop\n\tif s.hasWorkflow(hostPath, \"list-tasks\") {\n\t\tloop = s.createPhaseLoop(loopCfg, projectDir, hostPath, dedupTimeout)\n\t} else {\n\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n\t}\n\n\ts.loops[projectDir] = loop\n\tloop.Start()\n\n\treturn &pb.EnableLoopResponse{}, nil\n}\n\n// hasWorkflow checks if host.cloche contains a workflow with the given name.\nfunc (s *ClocheServer) hasWorkflow(hostPath, workflowName string) bool {\n\tdata, err := os.ReadFile(hostPath)\n\tif err != nil {\n\t\treturn false\n\t}\n\treturn strings.Contains(string(data), fmt.Sprintf(\"workflow %q\", workflowName))\n}\n\n// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n// main, and finalize workflows from host.cloche.\nfunc (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir, hostPath string, dedupTimeout time.Duration) *host.Loop {\n\t// Phase 1: list-tasks function\n\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n\t\trunner := &host.Runner{\n\t\t\tDispatcher: s,\n\t\t\tStore:      s.store,\n\t\t}\n\t\ttasks, _, err := host.RunListTasksWorkflow(ctx, runner, projDir)\n\t\treturn tasks, err\n\t}\n\n\t// Phase 2: main function\n\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n\t\trunner := &host.Runner{\n\t\t\tDispatcher: s,\n\t\t\tStore:      s.store,\n\t\t\tTaskID:     taskID,\n\t\t}\n\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n\t}\n\n\t// Phase 3: finalize function (optional — only if host.cloche has it)\n\tvar finalizeFn host.FinalizeFunc\n\tif s.hasWorkflow(hostPath, \"finalize\") {\n\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n\t\t\tmainRunID := \"\"\n\t\t\tmainOutcome := \"failed\"\n\t\t\tif mainResult != nil {\n\t\t\t\tmainRunID = mainResult.RunID\n\t\t\t\tmainOutcome = string(mainResult.State)\n\t\t\t}\n\t\t\trunner := &host.Runner{\n\t\t\t\tDispatcher: s,\n\t\t\t\tStore:      s.store,\n\t\t\t\tTaskID:     taskID,\n\t\t\t\tExtraEnv: []string{\n\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n\t\t\t\t},\n\t\t\t}\n\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n\t\t}\n\t}\n\n\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n}\n\n// createLegacyLoop creates a legacy single-function orchestration loop.\nfunc (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n\t\trunner := &host.Runner{\n\t\t\tDispatcher: s,\n\t\t\tStore:      s.store,\n\t\t\tTaskID:     taskID,\n\t\t}\n\t\treturn runner.Run(ctx, projDir)\n\t}\n\n\tloop := host.NewLoop(loopCfg, s.store, runFn)\n\n\t// Configure daemon-managed task assignment if a list-tasks command is set.\n\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n\t}\n\n\treturn loop\n}\n\n// GetLoopTasks returns the current task pipeline state for a project's\n// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n// loop is active for the project.\nfunc (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n\ts.mu.Lock()\n\tloop, ok := s.loops[projectDir]\n\ts.mu.Unlock()\n\tif !ok {\n\t\treturn nil\n\t}\n\tsnapshot := loop.GetTaskSnapshot()\n\tentries := make([]web.TaskEntry, len(snapshot))\n\tfor i, e := range snapshot {\n\t\tentry := web.TaskEntry{\n\t\t\tID:          e.Task.ID,\n\t\t\tStatus:      e.Task.Status,\n\t\t\tTitle:       e.Task.Title,\n\t\t\tDescription: e.Task.Description,\n\t\t\tMetadata:    e.Task.Metadata,\n\t\t\tAssigned:    e.Assigned,\n\t\t\tRunID:       e.RunID,\n\t\t}\n\t\tif !e.AssignedAt.IsZero() {\n\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n\t\t}\n\t\tentries[i] = entry\n\t}\n\treturn entries\n}\n\nfunc (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n\tprojectDir := req.ProjectDir\n\tif projectDir == \"\" {\n\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n\t}\n\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\tif loop, ok := s.loops[projectDir]; ok {\n\t\tloop.Stop()\n\t\tdelete(s.loops, projectDir)\n\t}\n\n\treturn &pb.DisableLoopResponse{}, nil\n}\n\nfunc (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n\t// Stop all orchestration loops.\n\ts.mu.Lock()\n\tfor _, loop := range s.loops {\n\t\tloop.Stop()\n\t}\n\ts.loops = make(map[string]*host.Loop)\n\ts.mu.Unlock()\n\n\tif s.shutdownFn == nil {\n\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n\t}\n\tgo s.shutdownFn()\n\treturn &pb.ShutdownResponse{}, nil\n}\n\n// indexLogFiles scans the extracted output directory and creates log_files index entries.\nfunc (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tname := entry.Name()\n\t\tif !strings.HasSuffix(name, \".log\") {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar fileType, stepName string\n\t\tbase := strings.TrimSuffix(name, \".log\")\n\n\t\tswitch {\n\t\tcase name == \"full.log\":\n\t\t\tfileType = \"full\"\n\t\tcase name == \"container.log\":\n\t\t\t// container.log is internal, not indexed as a user-facing log type\n\t\t\tcontinue\n\t\tcase strings.HasPrefix(name, \"llm-\"):\n\t\t\tfileType = \"llm\"\n\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n\t\tdefault:\n\t\t\tfileType = \"script\"\n\t\t\tstepName = base\n\t\t}\n\n\t\tinfo, _ := entry.Info()\n\t\tvar fileSize int64\n\t\tif info != nil {\n\t\t\tfileSize = info.Size()\n\t\t}\n\n\t\tlogEntry := &ports.LogFileEntry{\n\t\t\tRunID:     runID,\n\t\t\tStepName:  stepName,\n\t\t\tFileType:  fileType,\n\t\t\tFilePath:  filepath.Join(outputDir, name),\n\t\t\tFileSize:  fileSize,\n\t\t\tCreatedAt: now,\n\t\t}\n\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n\t\t}\n\t}\n}\n\nfunc gitHEAD(dir string) string {\n\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\treturn strings.TrimSpace(string(out))\n}\n","numLines":1067,"startLine":1,"totalLines":1067}}}
