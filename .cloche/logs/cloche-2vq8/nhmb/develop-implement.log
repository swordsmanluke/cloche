   118Ôćĺ\t\treturn\n   119Ôćĺ\t}\n   120Ôćĺ\n   121Ôćĺ\t// Commands that need a daemon connection\n   122Ôćĺ\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   123Ôćĺ\tif addr == \"\" {\n   124Ôćĺ\t\taddr = config.DefaultSocketAddr()\n   125Ôćĺ\t}\n   126Ôćĺ\n   127Ôćĺ\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   128Ôćĺ\tif err != nil {\n   129Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   130Ôćĺ\t\tos.Exit(1)\n   131Ôćĺ\t}\n   132Ôćĺ\tdefer conn.Close()\n   133Ôćĺ\n   134Ôćĺ\tclient := pb.NewClocheServiceClient(conn)\n   135Ôćĺ\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   136Ôćĺ\tdefer cancel()\n   137Ôćĺ\n   138Ôćĺ\tswitch os.Args[1] {\n   139Ôćĺ\tcase \"run\":\n   140Ôćĺ\t\tcmdRun(ctx, client, os.Args[2:])\n   141Ôćĺ\tcase \"resume\":\n   142Ôćĺ\t\tcmdResume(ctx, client, os.Args[2:])\n   143Ôćĺ\tcase \"status\":\n   144Ôćĺ\t\tcmdStatus(ctx, client, os.Args[2:])\n   145Ôćĺ\tcase \"logs\":\n   146Ôćĺ\t\tcmdLogs(client, os.Args[2:])\n   147Ôćĺ\tcase \"poll\":\n   148Ôćĺ\t\tcmdPoll(client, os.Args[2:])\n   149Ôćĺ\tcase \"list\":\n   150Ôćĺ\t\tcmdList(ctx, client, os.Args[2:])\n   151Ôćĺ\tcase \"stop\":\n   152Ôćĺ\t\tcmdStop(ctx, client, os.Args[2:])\n   153Ôćĺ\tcase \"delete\":\n   154Ôćĺ\t\tcmdDelete(ctx, client, os.Args[2:])\n   155Ôćĺ\tcase \"loop\":\n   156Ôćĺ\t\tcmdLoop(ctx, client, os.Args[2:])\n   157Ôćĺ\tcase \"shutdown\":\n   158Ôćĺ\t\tcmdShutdown(ctx, client, os.Args[2:])\n   159Ôćĺ\tdefault:\n   160Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   161Ôćĺ\t\tprintTopLevelHelp()\n   162Ôćĺ\t\tos.Exit(1)\n   163Ôćĺ\t}\n   164Ôćĺ}\n   165Ôćĺ\n   166Ôćĺ\n   167Ôćĺfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   168Ôćĺ\tvar workflow, prompt, title, issueID string\n   169Ôćĺ\tvar keepContainer bool\n   170Ôćĺ\n   171Ôćĺ\tfor i := 0; i < len(args); i++ {\n   172Ôćĺ\t\tswitch args[i] {\n   173Ôćĺ\t\tcase \"--workflow\":\n   174Ôćĺ\t\t\tif i+1 < len(args) {\n   175Ôćĺ\t\t\t\ti++\n   176Ôćĺ\t\t\t\tworkflow = args[i]\n   177Ôćĺ\t\t\t}\n   178Ôćĺ\t\tcase \"--prompt\", \"-p\":\n   179Ôćĺ\t\t\tif i+1 < len(args) {\n   180Ôćĺ\t\t\t\ti++\n   181Ôćĺ\t\t\t\tprompt = args[i]\n   182Ôćĺ\t\t\t}\n   183Ôćĺ\t\tcase \"--title\":\n   184Ôćĺ\t\t\tif i+1 < len(args) {\n   185Ôćĺ\t\t\t\ti++\n   186Ôćĺ\t\t\t\ttitle = args[i]\n   187Ôćĺ\t\t\t}\n   188Ôćĺ\t\tcase \"--issue\", \"-i\":\n   189Ôćĺ\t\t\tif i+1 < len(args) {\n   190Ôćĺ\t\t\t\ti++\n   191Ôćĺ\t\t\t\tissueID = args[i]\n   192Ôćĺ\t\t\t}\n   193Ôćĺ\t\tcase \"--keep-container\":\n   194Ôćĺ\t\t\tkeepContainer = true\n   195Ôćĺ\t\tdefault:\n   196Ôćĺ\t\t\t// Support bare positional arg as workflow name for backwards compat\n   197Ôćĺ\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   198Ôćĺ\t\t\t\tworkflow = args[i]\n   199Ôćĺ\t\t\t}\n   200Ôćĺ\t\t}\n   201Ôćĺ\t}\n   202Ôćĺ\n   203Ôćĺ\tif workflow == \"\" {\n   204Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"] [--issue ID]\\n\")\n   205Ôćĺ\t\tos.Exit(1)\n   206Ôćĺ\t}\n   207Ôćĺ\n   208Ôćĺ\tcwd, _ := os.Getwd()\n   209Ôćĺ\n   210Ôćĺ\t// Resolve image from workflow file (soft failure ÔÇö fall back to daemon default).\n   211Ôćĺ\t// Try loading from any .cloche file; only extract image for container workflows.\n   212Ôćĺ\tvar image string\n   213Ôćĺ\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n   214Ôćĺ\t\timage = wf.Config[\"container.image\"]\n   215Ôćĺ\t}\n   216Ôćĺ\n   217Ôćĺ\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   218Ôćĺ\t\tWorkflowName:  workflow,\n   219Ôćĺ\t\tProjectDir:    cwd,\n   220Ôćĺ\t\tImage:         image,\n   221Ôćĺ\t\tPrompt:        prompt,\n   222Ôćĺ\t\tKeepContainer: keepContainer,\n   223Ôćĺ\t\tTitle:         title,\n   224Ôćĺ\t\tIssueId:       issueID,\n   225Ôćĺ\t})\n   226Ôćĺ\tif err != nil {\n   227Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   228Ôćĺ\t\tos.Exit(1)\n   229Ôćĺ\t}\n   230Ôćĺ\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   231Ôćĺ}\n   232Ôćĺ\n   233Ôćĺfunc cmdResume(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   234Ôćĺ\tif len(args) < 1 {\n   235Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche resume <run-id> [step-name]\\n\")\n   236Ôćĺ\t\tos.Exit(1)\n   237Ôćĺ\t}\n   238Ôćĺ\n   239Ôćĺ\trunID := args[0]\n   240Ôćĺ\tstepName := \"\"\n   241Ôćĺ\tif len(args) > 1 {\n   242Ôćĺ\t\tstepName = args[1]\n   243Ôćĺ\t}\n   244Ôćĺ\n   245Ôćĺ\t// Send resume via gRPC metadata on a RunWorkflow call\n   246Ôćĺ\tmd := metadata.Pairs(\n   247Ôćĺ\t\t\"x-cloche-resume-run-id\", runID,\n   248Ôćĺ\t\t\"x-cloche-resume-step\", stepName,\n   249Ôćĺ\t)\n   250Ôćĺ\tctx = metadata.NewOutgoingContext(ctx, md)\n   251Ôćĺ\n   252Ôćĺ\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{})\n   253Ôćĺ\tif err != nil {\n   254Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   255Ôćĺ\t\tos.Exit(1)\n   256Ôćĺ\t}\n   257Ôćĺ\tfmt.Printf(\"Resumed run: %s\\n\", resp.RunId)\n   258Ôćĺ}\n   259Ôćĺ\n   260Ôćĺfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   261Ôćĺ\t// Parse flags to detect --all before checking positional args.\n   262Ôćĺ\tvar all bool\n   263Ôćĺ\tvar positional []string\n   264Ôćĺ\tfor _, arg := range args {\n   265Ôćĺ\t\tif arg == \"--all\" {\n   266Ôćĺ\t\t\tall = true\n   267Ôćĺ\t\t} else {\n   268Ôćĺ\t\t\tpositional = append(positional, arg)\n   269Ôćĺ\t\t}\n   270Ôćĺ\t}\n   271Ôćĺ\n   272Ôćĺ\t// If a run ID is provided, show single-run status.\n   273Ôćĺ\tif len(positional) > 0 {\n   274Ôćĺ\t\tcmdStatusRun(ctx, client, positional[0])\n   275Ôćĺ\t\treturn\n   276Ôćĺ\t}\n   277Ôćĺ\n   278Ôćĺ\t// No run ID: show daemon status overview.\n   279Ôćĺ\tcmdStatusOverview(ctx, client, os.Stdout, all)\n   280Ôćĺ}\n   281Ôćĺ\n   282Ôćĺfunc cmdStatusRun(ctx context.Context, client pb.ClocheServiceClient, runID string) {\n   283Ôćĺ\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: runID})\n   284Ôćĺ\tif err != nil {\n   285Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   286Ôćĺ\t\tos.Exit(1)\n   287Ôćĺ\t}\n   288Ôćĺ\n   289Ôćĺ\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   290Ôćĺ\tif resp.Title != \"\" {\n   291Ôćĺ\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   292Ôćĺ\t}\n   293Ôćĺ\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   294Ôćĺ\tif resp.IsHost {\n   295Ôćĺ\t\tfmt.Printf(\"Type:      host\\n\")\n   296Ôćĺ\t} else {\n   297Ôćĺ\t\tfmt.Printf(\"Type:      container\\n\")\n   298Ôćĺ\t}\n   299Ôćĺ\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   300Ôćĺ\tif resp.ContainerId != \"\" {\n   301Ôćĺ\t\tcid := resp.ContainerId\n   302Ôćĺ\t\tif len(cid) > 12 {\n   303Ôćĺ\t\t\tcid = cid[:12]\n   304Ôćĺ\t\t}\n   305Ôćĺ\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   306Ôćĺ\t}\n   307Ôćĺ\tif resp.ErrorMessage != \"\" {\n   308Ôćĺ\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   309Ôćĺ\t}\n   310Ôćĺ\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   311Ôćĺ\tfor _, exec := range resp.StepExecutions {\n   312Ôćĺ\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   313Ôćĺ\t}\n   314Ôćĺ}\n   315Ôćĺ\n   316Ôćĺfunc cmdStatusOverview(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, all bool) {\n   317Ôćĺ\t// Get daemon version.\n   318Ôćĺ\tverResp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   319Ôćĺ\tif err != nil {\n   320Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   321Ôćĺ\t\tos.Exit(1)\n   322Ôćĺ\t}\n   323Ôćĺ\tfmt.Fprintf(w, \"Daemon version: %s\\n\", verResp.Version)\n   324Ôćĺ\n   325Ôćĺ\tcwd, _ := os.Getwd()\n   326Ôćĺ\t_, hasClocheDir := os.Stat(filepath.Join(cwd, \".cloche\"))\n   327Ôćĺ\n   328Ôćĺ\tif !all && hasClocheDir == nil {\n   329Ôćĺ\t\t// In a project directory: show project-specific info.\n   330Ôćĺ\t\tcmdStatusProject(ctx, client, w, cwd)\n   331Ôćĺ\t} else {\n   332Ôćĺ\t\t// Not in a project directory or --all: show global overview.\n   333Ôćĺ\t\tcmdStatusGlobal(ctx, client, w)\n   334Ôćĺ\t}\n   335Ôćĺ}\n   336Ôćĺ\n   337Ôćĺfunc cmdStatusProject(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, projectDir string) {\n   338Ôćĺ\tinfo, err := client.GetProjectInfo(ctx, &pb.GetProjectInfoRequest{ProjectDir: projectDir})\n   339Ôćĺ\tif err != nil {\n   340Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   341Ôćĺ\t\tos.Exit(1)\n   342Ôćĺ\t}\n   343Ôćĺ\n   344Ôćĺ\tfmt.Fprintf(w, \"Project: %s\\n\", info.Name)\n   345Ôćĺ\tfmt.Fprintf(w, \"Concurrency: %d\\n\", info.Concurrency)\n   346Ôćĺ\n   347Ôćĺ\tloopStatus := \"stopped\"\n   348Ôćĺ\tif info.LoopRunning {\n   349Ôćĺ\t\tif info.ErrorHalted {\n   350Ôćĺ\t\t\tloopStatus = \"halted\"\n   351Ôćĺ\t\t} else {\n   352Ôćĺ\t\t\tloopStatus = \"running\"\n   353Ôćĺ\t\t}\n   354Ôćĺ\t}\n   355Ôćĺ\tfmt.Fprintf(w, \"Orchestration loop: %s\\n\", loopStatus)\n   356Ôćĺ\n   357Ôćĺ\t// Fetch runs for the past hour to compute success rate.\n   358Ôćĺ\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: projectDir})\n   359Ôćĺ\tif err != nil {\n   360Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   361Ôćĺ\t\tos.Exit(1)\n   362Ôćĺ\t}\n   363Ôćĺ\n   364Ôćĺ\tvar succeeded int\n   365Ôćĺ\tfor _, run := range listResp.Runs {\n   366Ôćĺ\t\tif run.State == \"succeeded\" {\n   367Ôćĺ\t\t\tsucceeded++\n   368Ôćĺ\t\t}\n   369Ôćĺ\t}\n   370Ôćĺ\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n   371Ôćĺ\n   372Ôćĺ\t// Active runs from project info.\n   373Ôćĺ\tfmt.Fprintf(w, \"Active runs: %d\\n\", len(info.ActiveRuns))\n   374Ôćĺ\tfor _, run := range info.ActiveRuns {\n   375Ôćĺ\t\tdur := formatDuration(run.StartedAt)\n   376Ôćĺ\t\tfmt.Fprintf(w, \"  %s: %s\\n\", run.RunId, dur)\n   377Ôćĺ\t}\n   378Ôćĺ}\n   379Ôćĺ\n   380Ôćĺfunc cmdStatusGlobal(ctx context.Context, client pb.ClocheServiceClient, w io.Writer) {\n   381Ôćĺ\t// Server filters to past hour when All is not set.\n   382Ôćĺ\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{})\n   383Ôćĺ\tif err != nil {\n   384Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   385Ôćĺ\t\tos.Exit(1)\n   386Ôćĺ\t}\n   387Ôćĺ\n   388Ôćĺ\tvar succeeded, activeCount int\n   389Ôćĺ\ttype activeRun struct {\n   390Ôćĺ\t\tid        string\n   391Ôćĺ\t\tstartedAt string\n   392Ôćĺ\t}\n   393Ôćĺ\tvar actives []activeRun\n   394Ôćĺ\n   395Ôćĺ\tfor _, run := range listResp.Runs {\n   396Ôćĺ\t\tif run.State == \"succeeded\" {\n   397Ôćĺ\t\t\tsucceeded++\n   398Ôćĺ\t\t}\n   399Ôćĺ\t\tif run.State == \"running\" || run.State == \"pending\" {\n   400Ôćĺ\t\t\tactiveCount++\n   401Ôćĺ\t\t\tactives = append(actives, activeRun{id: run.RunId, startedAt: run.StartedAt})\n   402Ôćĺ\t\t}\n   403Ôćĺ\t}\n   404Ôćĺ\n   405Ôćĺ\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n   406Ôćĺ\tfmt.Fprintf(w, \"Active runs: %d\\n\", activeCount)\n   407Ôćĺ\tfor _, a := range actives {\n   408Ôćĺ\t\tdur := formatDuration(a.startedAt)\n   409Ôćĺ\t\tfmt.Fprintf(w, \"  %s: %s\\n\", a.id, dur)\n   410Ôćĺ\t}\n   411Ôćĺ}\n   412Ôćĺ\n   413Ôćĺ// formatDuration parses a Go time string and returns a human-readable duration since then.\n   414Ôćĺfunc formatDuration(startedAt string) string {\n   415Ôćĺ\tparsed, err := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", startedAt)\n   416Ôćĺ\tif err != nil {\n   417Ôćĺ\t\treturn startedAt\n   418Ôćĺ\t}\n   419Ôćĺ\td := time.Since(parsed)\n   420Ôćĺ\tif d < time.Minute {\n   421Ôćĺ\t\treturn fmt.Sprintf(\"%ds\", int(d.Seconds()))\n   422Ôćĺ\t}\n   423Ôćĺ\tif d < time.Hour {\n   424Ôćĺ\t\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n   425Ôćĺ\t}\n   426Ôćĺ\treturn fmt.Sprintf(\"%dh%dm\", int(d.Hours()), int(d.Minutes())%60)\n   427Ôćĺ}\n   428Ôćĺ\n   429Ôćĺfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   430Ôćĺ\tvar all bool\n   431Ôćĺ\tvar projectDir, stateFilter, issueFilter string\n   432Ôćĺ\tvar limit int32\n   433Ôćĺ\n   434Ôćĺ\tfor i := 0; i < len(args); i++ {\n   435Ôćĺ\t\tswitch args[i] {\n   436Ôćĺ\t\tcase \"--all\":\n   437Ôćĺ\t\t\tall = true\n   438Ôćĺ\t\tcase \"--project\", \"-p\":\n   439Ôćĺ\t\t\tif i+1 < len(args) {\n   440Ôćĺ\t\t\t\ti++\n   441Ôćĺ\t\t\t\tprojectDir = args[i]\n   442Ôćĺ\t\t\t}\n   443Ôćĺ\t\tcase \"--state\", \"-s\":\n   444Ôćĺ\t\t\tif i+1 < len(args) {\n   445Ôćĺ\t\t\t\ti++\n   446Ôćĺ\t\t\t\tstateFilter = args[i]\n   447Ôćĺ\t\t\t}\n   448Ôćĺ\t\tcase \"--limit\", \"-n\":\n   449Ôćĺ\t\t\tif i+1 < len(args) {\n   450Ôćĺ\t\t\t\ti++\n   451Ôćĺ\t\t\t\tn, err := strconv.Atoi(args[i])\n   452Ôćĺ\t\t\t\tif err != nil {\n   453Ôćĺ\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   454Ôćĺ\t\t\t\t\tos.Exit(1)\n   455Ôćĺ\t\t\t\t}\n   456Ôćĺ\t\t\t\tlimit = int32(n)\n   457Ôćĺ\t\t\t}\n   458Ôćĺ\t\tcase \"--issue\", \"-i\":\n   459Ôćĺ\t\t\tif i+1 < len(args) {\n   460Ôćĺ\t\t\t\ti++\n   461Ôćĺ\t\t\t\tissueFilter = args[i]\n   462Ôćĺ\t\t\t}\n   463Ôćĺ\t\t}\n   464Ôćĺ\t}\n   465Ôćĺ\n   466Ôćĺ\treq := &pb.ListRunsRequest{\n   467Ôćĺ\t\tState:  stateFilter,\n   468Ôćĺ\t\tLimit:  limit,\n   469Ôćĺ\t\tTaskId: issueFilter,\n   470Ôćĺ\t}\n   471Ôćĺ\tif projectDir != \"\" {\n   472Ôćĺ\t\treq.ProjectDir = projectDir\n   473Ôćĺ\t} else if all {\n   474Ôćĺ\t\treq.All = true\n   475Ôćĺ\t} else {\n   476Ôćĺ\t\t// Default: filter to current project\n   477Ôćĺ\t\tcwd, _ := os.Getwd()\n   478Ôćĺ\t\treq.ProjectDir = cwd\n   479Ôćĺ\t}\n   480Ôćĺ\n   481Ôćĺ\tresp, err := client.ListRuns(ctx, req)\n   482Ôćĺ\tif err != nil {\n   483Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   484Ôćĺ\t\tos.Exit(1)\n   485Ôćĺ\t}\n   486Ôćĺ\n   487Ôćĺ\tif len(resp.Runs) == 0 {\n   488Ôćĺ\t\tfmt.Println(\"No runs found.\")\n   489Ôćĺ\t\treturn\n   490Ôćĺ\t}\n   491Ôćĺ\n   492Ôćĺ\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n   493Ôćĺ\tfmt.Fprintln(w, \"RUN ID\\tWORKFLOW\\tSTATE\\tTYPE\\tTASK ID\\tTITLE\\tCONTAINER\\tERROR\")\n   494Ôćĺ\tfor _, run := range resp.Runs {\n   495Ôćĺ\t\trunType := \"container\"\n   496Ôćĺ\t\tif run.IsHost {\n   497Ôćĺ\t\t\trunType = \"host\"\n   498Ôćĺ\t\t}\n   499Ôćĺ\t\ttitle := run.Title\n   500Ôćĺ\t\tif len(title) > 40 {\n   501Ôćĺ\t\t\ttitle = title[:37] + \"...\"\n   502Ôćĺ\t\t}\n   503Ôćĺ\t\terrMsg := run.ErrorMessage\n   504Ôćĺ\t\tif len(errMsg) > 60 {\n   505Ôćĺ\t\t\terrMsg = errMsg[:57] + \"...\"\n   506Ôćĺ\t\t}\n   507Ôćĺ\t\tfmt.Fprintf(w, \"%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\n\",\n   508Ôćĺ\t\t\trun.RunId, run.WorkflowName, run.State, runType,\n   509Ôćĺ\t\t\trun.TaskId, title, run.ContainerId, errMsg)\n   510Ôćĺ\t}\n   511Ôćĺ\tw.Flush()\n   512Ôćĺ}\n   513Ôćĺ\n   514Ôćĺfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n   515Ôćĺ\tif len(args) < 1 {\n   516Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n   517Ôćĺ\t\tos.Exit(1)\n   518Ôćĺ\t}\n   519Ôćĺ\n   520Ôćĺ\tvar stepFilter, typeFilter string\n   521Ôćĺ\tvar follow bool\n   522Ôćĺ\tvar limit int\n   523Ôćĺ\trunID := args[0]\n   524Ôćĺ\n   525Ôćĺ\tfor i := 1; i < len(args); i++ {\n   526Ôćĺ\t\tswitch args[i] {\n   527Ôćĺ\t\tcase \"--step\", \"-s\":\n   528Ôćĺ\t\t\tif i+1 < len(args) {\n   529Ôćĺ\t\t\t\ti++\n   530Ôćĺ\t\t\t\tstepFilter = args[i]\n   531Ôćĺ\t\t\t}\n   532Ôćĺ\t\tcase \"--type\":\n   533Ôćĺ\t\t\tif i+1 < len(args) {\n   534Ôćĺ\t\t\t\ti++\n   535Ôćĺ\t\t\t\ttypeFilter = args[i]\n   536Ôćĺ\t\t\t}\n   537Ôćĺ\t\tcase \"--follow\", \"-f\":\n   538Ôćĺ\t\t\tfollow = true\n   539Ôćĺ\t\tcase \"--limit\", \"-l\":\n   540Ôćĺ\t\t\tif i+1 < len(args) {\n   541Ôćĺ\t\t\t\ti++\n   542Ôćĺ\t\t\t\tn, err := strconv.Atoi(args[i])\n   543Ôćĺ\t\t\t\tif err != nil || n < 0 {\n   544Ôćĺ\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n   545Ôćĺ\t\t\t\t\tos.Exit(1)\n   546Ôćĺ\t\t\t\t}\n   547Ôćĺ\t\t\t\tlimit = n\n   548Ôćĺ\t\t\t}\n   549Ôćĺ\t\t}\n   550Ôćĺ\t}\n   551Ôćĺ\n   552Ôćĺ\t// Use background context ÔÇö log output can be large and follow mode blocks.\n   553Ôćĺ\tctx := context.Background()\n   554Ôćĺ\tvar mdPairs []string\n   555Ôćĺ\tif follow {\n   556Ôćĺ\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n   557Ôćĺ\t}\n   558Ôćĺ\tif limit > 0 {\n   559Ôćĺ\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n   560Ôćĺ\t}\n   561Ôćĺ\tif len(mdPairs) > 0 {\n   562Ôćĺ\t\tmd := metadata.Pairs(mdPairs...)\n   563Ôćĺ\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   564Ôćĺ\t}\n   565Ôćĺ\n   566Ôćĺ\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   567Ôćĺ\t\tRunId:    runID,\n   568Ôćĺ\t\tStepName: stepFilter,\n   569Ôćĺ\t\tLogType:  typeFilter,\n   570Ôćĺ\t})\n   571Ôćĺ\tif err != nil {\n   572Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   573Ôćĺ\t\tos.Exit(1)\n   574Ôćĺ\t}\n   575Ôćĺ\n   576Ôćĺ\tfor {\n   577Ôćĺ\t\tentry, err := stream.Recv()\n   578Ôćĺ\t\tif err != nil {\n   579Ôćĺ\t\t\tif errors.Is(err, io.EOF) {\n   580Ôćĺ\t\t\t\tbreak\n   581Ôćĺ\t\t\t}\n   582Ôćĺ\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   583Ôćĺ\t\t\tos.Exit(1)\n   584Ôćĺ\t\t}\n   585Ôćĺ\n   586Ôćĺ\t\tswitch entry.Type {\n   587Ôćĺ\t\tcase \"step_started\":\n   588Ôćĺ\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   589Ôćĺ\t\t\tif entry.Message != \"\" {\n   590Ôćĺ\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   591Ôćĺ\t\t\t}\n   592Ôćĺ\t\tcase \"step_completed\":\n   593Ôćĺ\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   594Ôćĺ\t\t\tif entry.Message != \"\" {\n   595Ôćĺ\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   596Ôćĺ\t\t\t}\n   597Ôćĺ\t\tcase \"run_completed\":\n   598Ôćĺ\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   599Ôćĺ\t\t\tif entry.Message != \"\" {\n   600Ôćĺ\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   601Ôćĺ\t\t\t}\n   602Ôćĺ\t\tcase \"full_log\":\n   603Ôćĺ\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   604Ôćĺ\t\tcase \"log\":\n   605Ôćĺ\t\t\t// Live-streamed log line from an active run.\n   606Ôćĺ\t\t\tfmt.Println(entry.Message)\n   607Ôćĺ\t\tdefault:\n   608Ôćĺ\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   609Ôćĺ\t\t\tif entry.StepName != \"\" {\n   610Ôćĺ\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   611Ôćĺ\t\t\t}\n   612Ôćĺ\t\t\tif entry.Message != \"\" {\n   613Ôćĺ\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   614Ôćĺ\t\t\t}\n   615Ôćĺ\t\t}\n   616Ôćĺ\t}\n   617Ôćĺ}\n   618Ôćĺ\n   619Ôćĺfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   620Ôćĺ\tif len(args) < 1 {\n   621Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   622Ôćĺ\t\tos.Exit(1)\n   623Ôćĺ\t}\n   624Ôćĺ\n   625Ôćĺ\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   626Ôćĺ\tif err != nil {\n   627Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   628Ôćĺ\t\tos.Exit(1)\n   629Ôćĺ\t}\n   630Ôćĺ\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   631Ôćĺ}\n   632Ôćĺ\n   633Ôćĺfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   634Ôćĺ\tif len(args) < 1 {\n   635Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   636Ôćĺ\t\tos.Exit(1)\n   637Ôćĺ\t}\n   638Ôćĺ\n   639Ôćĺ\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   640Ôćĺ\tif err != nil {\n   641Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   642Ôćĺ\t\tos.Exit(1)\n   643Ôćĺ\t}\n   644Ôćĺ\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   645Ôćĺ}\n   646Ôćĺ\n   647Ôćĺfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   648Ôćĺ\tcwd, _ := os.Getwd()\n   649Ôćĺ\n   650Ôćĺ\t// Check for \"stop\" subcommand\n   651Ôćĺ\tif len(args) > 0 && args[0] == \"stop\" {\n   652Ôćĺ\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   653Ôćĺ\t\tif err != nil {\n   654Ôćĺ\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   655Ôćĺ\t\t\tos.Exit(1)\n   656Ôćĺ\t\t}\n   657Ôćĺ\t\tfmt.Println(\"Orchestration loop stopped.\")\n   658Ôćĺ\t\treturn\n   659Ôćĺ\t}\n   660Ôćĺ\n   661Ôćĺ\t// Check for \"resume\" subcommand\n   662Ôćĺ\tif len(args) > 0 && args[0] == \"resume\" {\n   663Ôćĺ\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n   664Ôćĺ\t\tif err != nil {\n   665Ôćĺ\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   666Ôćĺ\t\t\tos.Exit(1)\n   667Ôćĺ\t\t}\n   668Ôćĺ\t\tfmt.Println(\"Orchestration loop resumed.\")\n   669Ôćĺ\t\treturn\n   670Ôćĺ\t}\n   671Ôćĺ\n   672Ôćĺ\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   673Ôćĺ\tvar maxConcurrent int32\n   674Ôćĺ\tfor i := 0; i < len(args); i++ {\n   675Ôćĺ\t\tswitch args[i] {\n   676Ôćĺ\t\tcase \"--max\":\n   677Ôćĺ\t\t\tif i+1 < len(args) {\n   678Ôćĺ\t\t\t\ti++\n   679Ôćĺ\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   680Ôćĺ\t\t\t\tif n != 1 || err != nil {\n   681Ôćĺ\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   682Ôćĺ\t\t\t\t\tos.Exit(1)\n   683Ôćĺ\t\t\t\t}\n   684Ôćĺ\t\t\t}\n   685Ôćĺ\t\t}\n   686Ôćĺ\t}\n   687Ôćĺ\n   688Ôćĺ\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   689Ôćĺ\t\tProjectDir:    cwd,\n   690Ôćĺ\t\tMaxConcurrent: maxConcurrent,\n   691Ôćĺ\t})\n   692Ôćĺ\tif err != nil {\n   693Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   694Ôćĺ\t\tos.Exit(1)\n   695Ôćĺ\t}\n   696Ôćĺ\tif maxConcurrent > 0 {\n   697Ôćĺ\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   698Ôćĺ\t} else {\n   699Ôćĺ\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   700Ôćĺ\t}\n   701Ôćĺ}\n   702Ôćĺ\n   703Ôćĺfunc cmdTasks(args []string) {\n   704Ôćĺ\t// Determine HTTP address from env\n   705Ôćĺ\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   706Ôćĺ\tif httpAddr == \"\" {\n   707Ôćĺ\t\thttpAddr = \"localhost:8080\"\n   708Ôćĺ\t}\n   709Ôćĺ\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   710Ôćĺ\n   711Ôćĺ\t// Determine project label from --project flag or current directory\n   712Ôćĺ\tprojectDir := \"\"\n   713Ôćĺ\tfor i := 0; i < len(args); i++ {\n   714Ôćĺ\t\tswitch args[i] {\n   715Ôćĺ\t\tcase \"--project\":\n   716Ôćĺ\t\t\tif i+1 < len(args) {\n   717Ôćĺ\t\t\t\ti++\n   718Ôćĺ\t\t\t\tprojectDir = args[i]\n   719Ôćĺ\t\t\t}\n   720Ôćĺ\t\t}\n   721Ôćĺ\t}\n   722Ôćĺ\n   723Ôćĺ\tif projectDir == \"\" {\n   724Ôćĺ\t\tcwd, _ := os.Getwd()\n   725Ôćĺ\t\tprojectDir = filepath.Base(cwd)\n   726Ôćĺ\t}\n   727Ôćĺ\n   728Ôćĺ\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   729Ôćĺ\tresp, err := http.Get(tasksURL)\n   730Ôćĺ\tif err != nil {\n   731Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   732Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   733Ôćĺ\t\tos.Exit(1)\n   734Ôćĺ\t}\n   735Ôćĺ\tdefer resp.Body.Close()\n   736Ôćĺ\n   737Ôćĺ\tif resp.StatusCode != 200 {\n   738Ôćĺ\t\tbody, _ := io.ReadAll(resp.Body)\n   739Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   740Ôćĺ\t\tos.Exit(1)\n   741Ôćĺ\t}\n   742Ôćĺ\n   743Ôćĺ\ttype taskEntry struct {\n   744Ôćĺ\t\tID          string `json:\"id\"`\n   745Ôćĺ\t\tStatus      string `json:\"status\"`\n   746Ôćĺ\t\tTitle       string `json:\"title\"`\n   747Ôćĺ\t\tDescription string `json:\"description\"`\n   748Ôćĺ\t\tAssigned    bool   `json:\"assigned\"`\n   749Ôćĺ\t\tAssignedAt  string `json:\"assigned_at\"`\n   750Ôćĺ\t\tRunID       string `json:\"run_id\"`\n   751Ôćĺ\t}\n   752Ôćĺ\n   753Ôćĺ\tvar tasks []taskEntry\n   754Ôćĺ\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   755Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   756Ôćĺ\t\tos.Exit(1)\n   757Ôćĺ\t}\n   758Ôćĺ\n   759Ôćĺ\tif len(tasks) == 0 {\n   760Ôćĺ\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   761Ôćĺ\t\treturn\n   762Ôćĺ\t}\n   763Ôćĺ\n   764Ôćĺ\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   765Ôćĺ\tfor _, t := range tasks {\n   766Ôćĺ\t\tstatus := t.Status\n   767Ôćĺ\t\tif status == \"\" {\n   768Ôćĺ\t\t\tstatus = \"open\"\n   769Ôćĺ\t\t}\n   770Ôćĺ\t\tassigned := \"-\"\n   771Ôćĺ\t\tif t.Assigned {\n   772Ôćĺ\t\t\tassigned = \"yes\"\n   773Ôćĺ\t\t}\n   774Ôćĺ\t\trunID := \"\"\n   775Ôćĺ\t\tif t.RunID != \"\" {\n   776Ôćĺ\t\t\trunID = t.RunID\n   777Ôćĺ\t\t\tif len(runID) > 30 {\n   778Ôćĺ\t\t\t\trunID = runID[:27] + \"...\"\n   779Ôćĺ\t\t\t}\n   780Ôćĺ\t\t}\n   781Ôćĺ\t\ttitle := t.Title\n   782Ôćĺ\t\tif len(title) > 40 {\n   783Ôćĺ\t\t\ttitle = title[:37] + \"...\"\n   784Ôćĺ\t\t}\n   785Ôćĺ\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   786Ôćĺ\t}\n   787Ôćĺ}\n   788Ôćĺ\n   789Ôćĺfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   790Ôćĺ\tvar force bool\n   791Ôćĺ\tfor _, a := range args {\n   792Ôćĺ\t\tif a == \"-f\" || a == \"--force\" {\n   793Ôćĺ\t\t\tforce = true\n   794Ôćĺ\t\t}\n   795Ôćĺ\t}\n   796Ôćĺ\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n   797Ôćĺ\tif err != nil {\n   798Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   799Ôćĺ\t\tos.Exit(1)\n   800Ôćĺ\t}\n   801Ôćĺ\tfmt.Println(\"Daemon shutting down.\")\n   802Ôćĺ}\n   803Ôćĺ\n   804Ôćĺ// resolveRunContext returns the project directory and run ID for context\n   805Ôćĺ// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   806Ôćĺ// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   807Ôćĺfunc resolveRunContext() (projectDir, runID string, err error) {\n   808Ôćĺ\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   809Ôćĺ\tif runID == \"\" {\n   810Ôćĺ\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   811Ôćĺ\t}\n   812Ôćĺ\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   813Ôćĺ\tif projectDir == \"\" {\n   814Ôćĺ\t\tprojectDir, err = os.Getwd()\n   815Ôćĺ\t\tif err != nil {\n   816Ôćĺ\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   817Ôćĺ\t\t}\n   818Ôćĺ\t}\n   819Ôćĺ\treturn projectDir, runID, nil\n   820Ôćĺ}\n   821Ôćĺ\n   822Ôćĺfunc cmdGet(args []string) {\n   823Ôćĺ\tif len(args) < 1 {\n   824Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   825Ôćĺ\t\tos.Exit(1)\n   826Ôćĺ\t}\n   827Ôćĺ\n   828Ôćĺ\tprojectDir, runID, err := resolveRunContext()\n   829Ôćĺ\tif err != nil {\n   830Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   831Ôćĺ\t\tos.Exit(1)\n   832Ôćĺ\t}\n   833Ôćĺ\n   834Ôćĺ\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   835Ôćĺ\tif err != nil {\n   836Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   837Ôćĺ\t\tos.Exit(1)\n   838Ôćĺ\t}\n   839Ôćĺ\tif !ok {\n   840Ôćĺ\t\tos.Exit(1)\n   841Ôćĺ\t}\n   842Ôćĺ\tfmt.Println(val)\n   843Ôćĺ}\n   844Ôćĺ\n   845Ôćĺfunc cmdSet(args []string) {\n   846Ôćĺ\tif len(args) < 2 {\n   847Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   848Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   849Ôćĺ\t\tos.Exit(1)\n   850Ôćĺ\t}\n   851Ôćĺ\n   852Ôćĺ\tprojectDir, runID, err := resolveRunContext()\n   853Ôćĺ\tif err != nil {\n   854Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   855Ôćĺ\t\tos.Exit(1)\n   856Ôćĺ\t}\n   857Ôćĺ\n   858Ôćĺ\tvalue := args[1]\n   859Ôćĺ\tif value == \"-\" {\n   860Ôćĺ\t\tdata, err := io.ReadAll(os.Stdin)\n   861Ôćĺ\t\tif err != nil {\n   862Ôćĺ\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   863Ôćĺ\t\t\tos.Exit(1)\n   864Ôćĺ\t\t}\n   865Ôćĺ\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   866Ôćĺ\t}\n   867Ôćĺ\n   868Ôćĺ\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   869Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   870Ôćĺ\t\tos.Exit(1)\n   871Ôćĺ\t}\n   872Ôćĺ}\n   873Ôćĺ\n   874Ôćĺfunc cmdVersion() {\n   875Ôćĺ\tcliVersion := version.Version()\n   876Ôćĺ\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   877Ôćĺ\n   878Ôćĺ\t// Try to get daemon version via gRPC\n   879Ôćĺ\tdaemonVersion := \"<unavailable>\"\n   880Ôćĺ\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   881Ôćĺ\tif addr == \"\" {\n   882Ôćĺ\t\taddr = config.DefaultSocketAddr()\n   883Ôćĺ\t}\n   884Ôćĺ\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   885Ôćĺ\tif err == nil {\n   886Ôćĺ\t\tdefer conn.Close()\n   887Ôćĺ\t\tclient := pb.NewClocheServiceClient(conn)\n   888Ôćĺ\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   889Ôćĺ\t\tdefer cancel()\n   890Ôćĺ\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   891Ôćĺ\t\tif err == nil {\n   892Ôćĺ\t\t\tdaemonVersion = resp.Version\n   893Ôćĺ\t\t}\n   894Ôćĺ\t}\n   895Ôćĺ\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   896Ôćĺ\n   897Ôćĺ\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   898Ôćĺ\tagentVersion := \"<unavailable>\"\n   899Ôćĺ\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   900Ôćĺ\tif image == \"\" {\n   901Ôćĺ\t\timage = \"cloche-agent:latest\"\n   902Ôćĺ\t}\n   903Ôćĺ\tout, err := exec.CommandContext(\n   904Ôćĺ\t\tcontext.Background(),\n   905Ôćĺ\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   906Ôćĺ\t).Output()\n   907Ôćĺ\tif err == nil {\n   908Ôćĺ\t\tagentVersion = strings.TrimSpace(string(out))\n   909Ôćĺ\t\t// Strip \"cloche-agent \" prefix if present\n   910Ôćĺ\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n   911Ôćĺ\t}\n   912Ôćĺ\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n   913Ôćĺ\n   914Ôćĺ\t// Warn about version mismatches\n   915Ôćĺ\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n   916Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n   917Ôćĺ\t}\n   918Ôćĺ\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n   919Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n   920Ôćĺ\t}\n   921Ôćĺ}\n   922Ôćĺ"}]},"parent_tool_use_id":null,"session_id":"4ff3ccd2-e0d4-4cea-9924-a15740aebe51","uuid":"66e12d6c-17ad-4f07-b862-edc444a1d481","timestamp":"2026-03-18T16:10:31.795Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\t\"text/tabwriter\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n\t\"github.com/cloche-dev/cloche/internal/version\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n\n\t// Handle version flags before anything else\n\tif os.Args[1] == \"-v\" || os.Args[1] == \"--version\" {\n\t\tcmdVersion()\n\t\treturn\n\t}\n\n\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n\tswitch os.Args[1] {\n\tcase \"help\":\n\t\tprintHelp(os.Args[2:])\n\t\treturn\n\tcase \"--help\", \"-h\":\n\t\tprintTopLevelHelp()\n\t\treturn\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"init\")\n\t\t\treturn\n\t\t}\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"health\")\n\t\t\treturn\n\t\t}\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\tcase \"get\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"get\")\n\t\t\treturn\n\t\t}\n\t\tcmdGet(os.Args[2:])\n\t\treturn\n\tcase \"set\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"set\")\n\t\t\treturn\n\t\t}\n\t\tcmdSet(os.Args[2:])\n\t\treturn\n\tcase \"tasks\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"tasks\")\n\t\t\treturn\n\t\t}\n\t\tcmdTasks(os.Args[2:])\n\t\treturn\n\tcase \"workflow\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"workflow\")\n\t\t\treturn\n\t\t}\n\t\tcmdWorkflow(os.Args[2:])\n\t\treturn\n\tcase \"project\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"project\")\n\t\t\treturn\n\t\t}\n\t\tcmdProject(os.Args[2:])\n\t\treturn\n\tcase \"validate\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"validate\")\n\t\t\treturn\n\t\t}\n\t\tcmdValidate(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Handle --help for daemon commands before connecting\n\tdaemonCmds := map[string]bool{\n\t\t\"run\": true, \"resume\": true, \"status\": true, \"logs\": true, \"poll\": true,\n\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n\t}\n\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n\t\tprintSubcommandHelp(os.Args[1])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = config.DefaultSocketAddr()\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"resume\":\n\t\tcmdResume(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client, os.Args[2:])\n\tdefault:\n\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n}\n\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title, issueID string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--issue\", \"-i\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tissueID = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"] [--issue ID]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure ÔÇö fall back to daemon default).\n\t// Try loading from any .cloche file; only extract image for container workflows.\n\tvar image string\n\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n\t\timage = wf.Config[\"container.image\"]\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t\tIssueId:       issueID,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdResume(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche resume <run-id> [step-name]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\trunID := args[0]\n\tstepName := \"\"\n\tif len(args) > 1 {\n\t\tstepName = args[1]\n\t}\n\n\t// Send resume via gRPC metadata on a RunWorkflow call\n\tmd := metadata.Pairs(\n\t\t\"x-cloche-resume-run-id\", runID,\n\t\t\"x-cloche-resume-step\", stepName,\n\t)\n\tctx = metadata.NewOutgoingContext(ctx, md)\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Resumed run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\t// Parse flags to detect --all before checking positional args.\n\tvar all bool\n\tvar positional []string\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t} else {\n\t\t\tpositional = append(positional, arg)\n\t\t}\n\t}\n\n\t// If a run ID is provided, show single-run status.\n\tif len(positional) > 0 {\n\t\tcmdStatusRun(ctx, client, positional[0])\n\t\treturn\n\t}\n\n\t// No run ID: show daemon status overview.\n\tcmdStatusOverview(ctx, client, os.Stdout, all)\n}\n\nfunc cmdStatusRun(ctx context.Context, client pb.ClocheServiceClient, runID string) {\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: runID})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdStatusOverview(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, all bool) {\n\t// Get daemon version.\n\tverResp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Fprintf(w, \"Daemon version: %s\\n\", verResp.Version)\n\n\tcwd, _ := os.Getwd()\n\t_, hasClocheDir := os.Stat(filepath.Join(cwd, \".cloche\"))\n\n\tif !all && hasClocheDir == nil {\n\t\t// In a project directory: show project-specific info.\n\t\tcmdStatusProject(ctx, client, w, cwd)\n\t} else {\n\t\t// Not in a project directory or --all: show global overview.\n\t\tcmdStatusGlobal(ctx, client, w)\n\t}\n}\n\nfunc cmdStatusProject(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, projectDir string) {\n\tinfo, err := client.GetProjectInfo(ctx, &pb.GetProjectInfoRequest{ProjectDir: projectDir})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Fprintf(w, \"Project: %s\\n\", info.Name)\n\tfmt.Fprintf(w, \"Concurrency: %d\\n\", info.Concurrency)\n\n\tloopStatus := \"stopped\"\n\tif info.LoopRunning {\n\t\tif info.ErrorHalted {\n\t\t\tloopStatus = \"halted\"\n\t\t} else {\n\t\t\tloopStatus = \"running\"\n\t\t}\n\t}\n\tfmt.Fprintf(w, \"Orchestration loop: %s\\n\", loopStatus)\n\n\t// Fetch runs for the past hour to compute success rate.\n\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: projectDir})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvar succeeded int\n\tfor _, run := range listResp.Runs {\n\t\tif run.State == \"succeeded\" {\n\t\t\tsucceeded++\n\t\t}\n\t}\n\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n\n\t// Active runs from project info.\n\tfmt.Fprintf(w, \"Active runs: %d\\n\", len(info.ActiveRuns))\n\tfor _, run := range info.ActiveRuns {\n\t\tdur := formatDuration(run.StartedAt)\n\t\tfmt.Fprintf(w, \"  %s: %s\\n\", run.RunId, dur)\n\t}\n}\n\nfunc cmdStatusGlobal(ctx context.Context, client pb.ClocheServiceClient, w io.Writer) {\n\t// Server filters to past hour when All is not set.\n\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvar succeeded, activeCount int\n\ttype activeRun struct {\n\t\tid        string\n\t\tstartedAt string\n\t}\n\tvar actives []activeRun\n\n\tfor _, run := range listResp.Runs {\n\t\tif run.State == \"succeeded\" {\n\t\t\tsucceeded++\n\t\t}\n\t\tif run.State == \"running\" || run.State == \"pending\" {\n\t\t\tactiveCount++\n\t\t\tactives = append(actives, activeRun{id: run.RunId, startedAt: run.StartedAt})\n\t\t}\n\t}\n\n\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n\tfmt.Fprintf(w, \"Active runs: %d\\n\", activeCount)\n\tfor _, a := range actives {\n\t\tdur := formatDuration(a.startedAt)\n\t\tfmt.Fprintf(w, \"  %s: %s\\n\", a.id, dur)\n\t}\n}\n\n// formatDuration parses a Go time string and returns a human-readable duration since then.\nfunc formatDuration(startedAt string) string {\n\tparsed, err := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", startedAt)\n\tif err != nil {\n\t\treturn startedAt\n\t}\n\td := time.Since(parsed)\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%ds\", int(d.Seconds()))\n\t}\n\tif d < time.Hour {\n\t\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n\t}\n\treturn fmt.Sprintf(\"%dh%dm\", int(d.Hours()), int(d.Minutes())%60)\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tvar projectDir, stateFilter, issueFilter string\n\tvar limit int32\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--all\":\n\t\t\tall = true\n\t\tcase \"--project\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\tcase \"--state\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstateFilter = args[i]\n\t\t\t}\n\t\tcase \"--limit\", \"-n\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = int32(n)\n\t\t\t}\n\t\tcase \"--issue\", \"-i\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tissueFilter = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\treq := &pb.ListRunsRequest{\n\t\tState:  stateFilter,\n\t\tLimit:  limit,\n\t\tTaskId: issueFilter,\n\t}\n\tif projectDir != \"\" {\n\t\treq.ProjectDir = projectDir\n\t} else if all {\n\t\treq.All = true\n\t} else {\n\t\t// Default: filter to current project\n\t\tcwd, _ := os.Getwd()\n\t\treq.ProjectDir = cwd\n\t}\n\n\tresp, err := client.ListRuns(ctx, req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n\tfmt.Fprintln(w, \"RUN ID\\tWORKFLOW\\tSTATE\\tTYPE\\tTASK ID\\tTITLE\\tCONTAINER\\tERROR\")\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\ttitle := run.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\terrMsg := run.ErrorMessage\n\t\tif len(errMsg) > 60 {\n\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t}\n\t\tfmt.Fprintf(w, \"%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\n\",\n\t\t\trun.RunId, run.WorkflowName, run.State, runType,\n\t\t\trun.TaskId, title, run.ContainerId, errMsg)\n\t}\n\tw.Flush()\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\tvar limit int\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\tcase \"--limit\", \"-l\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil || n < 0 {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = n\n\t\t\t}\n\t\t}\n\t}\n\n\t// Use background context ÔÇö log output can be large and follow mode blocks.\n\tctx := context.Background()\n\tvar mdPairs []string\n\tif follow {\n\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n\t}\n\tif limit > 0 {\n\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n\t}\n\tif len(mdPairs) > 0 {\n\t\tmd := metadata.Pairs(mdPairs...)\n\t\tctx = metadata.NewOutgoingContext(ctx, md)\n\t}\n\n\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Check for \"resume\" subcommand\n\tif len(args) > 0 && args[0] == \"resume\" {\n\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop resumed.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdTasks(args []string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\t// Determine project label from --project flag or current directory\n\tprojectDir := \"\"\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tcwd, _ := os.Getwd()\n\t\tprojectDir = filepath.Base(cwd)\n\t}\n\n\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n\tresp, err := http.Get(tasksURL)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\ttype taskEntry struct {\n\t\tID          string `json:\"id\"`\n\t\tStatus      string `json:\"status\"`\n\t\tTitle       string `json:\"title\"`\n\t\tDescription string `json:\"description\"`\n\t\tAssigned    bool   `json:\"assigned\"`\n\t\tAssignedAt  string `json:\"assigned_at\"`\n\t\tRunID       string `json:\"run_id\"`\n\t}\n\n\tvar tasks []taskEntry\n\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(tasks) == 0 {\n\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n\t\treturn\n\t}\n\n\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n\tfor _, t := range tasks {\n\t\tstatus := t.Status\n\t\tif status == \"\" {\n\t\t\tstatus = \"open\"\n\t\t}\n\t\tassigned := \"-\"\n\t\tif t.Assigned {\n\t\t\tassigned = \"yes\"\n\t\t}\n\t\trunID := \"\"\n\t\tif t.RunID != \"\" {\n\t\t\trunID = t.RunID\n\t\t\tif len(runID) > 30 {\n\t\t\t\trunID = runID[:27] + \"...\"\n\t\t\t}\n\t\t}\n\t\ttitle := t.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar force bool\n\tfor _, a := range args {\n\t\tif a == \"-f\" || a == \"--force\" {\n\t\t\tforce = true\n\t\t}\n\t}\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n\n// resolveRunContext returns the project directory and run ID for context\n// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n// from CLOCHE_PROJECT_DIR (falling back to cwd).\nfunc resolveRunContext() (projectDir, runID string, err error) {\n\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n\tif runID == \"\" {\n\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n\t}\n\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n\tif projectDir == \"\" {\n\t\tprojectDir, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n\t\t}\n\t}\n\treturn projectDir, runID, nil\n}\n\nfunc cmdGet(args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif !ok {\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(val)\n}\n\nfunc cmdSet(args []string) {\n\tif len(args) < 2 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvalue := args[1]\n\tif value == \"-\" {\n\t\tdata, err := io.ReadAll(os.Stdin)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n\t}\n\n\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n\nfunc cmdVersion() {\n\tcliVersion := version.Version()\n\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n\n\t// Try to get daemon version via gRPC\n\tdaemonVersion := \"<unavailable>\"\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = config.DefaultSocketAddr()\n\t}\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err == nil {\n\t\tdefer conn.Close()\n\t\tclient := pb.NewClocheServiceClient(conn)\n\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n\t\tdefer cancel()\n\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n\t\tif err == nil {\n\t\t\tdaemonVersion = resp.Version\n\t\t}\n\t}\n\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n\n\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n\tagentVersion := \"<unavailable>\"\n\timage := os.Getenv(\"CLOCHE_IMAGE\")\n\tif image == \"\" {\n\t\timage = \"cloche-agent:latest\"\n\t}\n\tout, err := exec.CommandContext(\n\t\tcontext.Background(),\n\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n\t).Output()\n\tif err == nil {\n\t\tagentVersion = strings.TrimSpace(string(out))\n\t\t// Strip \"cloche-agent \" prefix if present\n\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n\t}\n\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n\n\t// Warn about version mismatches\n\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n\t}\n\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n\t}\n}\n","numLines":922,"startLine":1,"totalLines":922}}}
