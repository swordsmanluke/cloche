{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VmkN4W31a86ZrBV3Dq3DC5","type":"tool_result","content":"     1Ôćĺpackage host\n     2Ôćĺ\n     3Ôćĺimport (\n     4Ôćĺ\t\"context\"\n     5Ôćĺ\t\"fmt\"\n     6Ôćĺ\t\"log\"\n     7Ôćĺ\t\"os\"\n     8Ôćĺ\t\"path/filepath\"\n     9Ôćĺ\t\"sync\"\n    10Ôćĺ\t\"time\"\n    11Ôćĺ\n    12Ôćĺ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13Ôćĺ\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14Ôćĺ)\n    15Ôćĺ\n    16Ôćĺconst (\n    17Ôćĺ\tdefaultMaxConcurrent          = 1\n    18Ôćĺ\tdefaultDedupTimeout           = 5 * time.Minute\n    19Ôćĺ\tdefaultMaxConsecutiveFailures = 3\n    20Ôćĺ\tidlePollInterval              = 2 * time.Minute\n    21Ôćĺ\tcapacityPollInterval          = 30 * time.Second\n    22Ôćĺ)\n    23Ôćĺ\n    24Ôćĺ// LoopConfig holds configuration for an orchestration loop.\n    25Ôćĺtype LoopConfig struct {\n    26Ôćĺ\tProjectDir             string\n    27Ôćĺ\tMaxConcurrent          int\n    28Ôćĺ\tStaggerDelay           time.Duration // delay between launching consecutive runs\n    29Ôćĺ\tDedupTimeout           time.Duration // how long to suppress reassignment of the same task ID\n    30Ôćĺ\tStopOnError            bool          // halt loop on unrecovered error (allow in-flight work to finish)\n    31Ôćĺ\tMaxConsecutiveFailures int           // halt loop after N consecutive failures (default: 3, must be > 0)\n    32Ôćĺ}\n    33Ôćĺ\n    34Ôćĺ// ListTasksFunc is called to discover available tasks. It should run the\n    35Ôćĺ// list-tasks workflow (or equivalent) and return the parsed tasks.\n    36Ôćĺtype ListTasksFunc func(ctx context.Context, projectDir string) ([]Task, error)\n    37Ôćĺ\n    38Ôćĺ// MainFunc is called to execute the main workflow for a given task.\n    39Ôćĺtype MainFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n    40Ôćĺ\n    41Ôćĺ// FinalizeFunc is called after the main workflow completes (both success and\n    42Ôćĺ// failure). It receives the task ID and the outcome of the main phase.\n    43Ôćĺtype FinalizeFunc func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error)\n    44Ôćĺ\n    45Ôćĺ// RunFunc is the legacy function signature for launching a host workflow run.\n    46Ôćĺ// When taskID is non-empty, the runner should propagate it as CLOCHE_TASK_ID.\n    47Ôćĺtype RunFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n    48Ôćĺ\n    49Ôćĺ// TaskAssignment tracks the assignment state of a task.\n    50Ôćĺtype TaskAssignment struct {\n    51Ôćĺ\tAssignedAt time.Time\n    52Ôćĺ\tRunID      string // run ID handling this task (set after main completes)\n    53Ôćĺ}\n    54Ôćĺ\n    55Ôćĺ// TaskStateEntry combines a task with its assignment state.\n    56Ôćĺtype TaskStateEntry struct {\n    57Ôćĺ\tTask       Task\n    58Ôćĺ\tAssigned   bool\n    59Ôćĺ\tAssignedAt time.Time\n    60Ôćĺ\tRunID      string // empty if not yet known\n    61Ôćĺ}\n    62Ôćĺ\n    63Ôćĺ// Loop manages a continuous orchestration loop for a project, keeping up to\n    64Ôćĺ// MaxConcurrent host workflow runs active at all times when work is available.\n    65Ôćĺ//\n    66Ôćĺ// When configured with three-phase functions (list-tasks, main, finalize), the\n    67Ôćĺ// loop discovers tasks via list-tasks, picks open ones, runs main for each, and\n    68Ôćĺ// then runs finalize on completion. When configured with a legacy RunFunc, it\n    69Ôćĺ// falls back to the single-function approach.\n    70Ôćĺtype Loop struct {\n    71Ôćĺ\tconfig     LoopConfig\n    72Ôćĺ\tlistTasks  ListTasksFunc\n    73Ôćĺ\tmainFn     MainFunc\n    74Ôćĺ\tfinalizeFn FinalizeFunc // optional; skipped if nil\n    75Ôćĺ\trunner     RunFunc      // legacy single-function mode\n    76Ôćĺ\tstore      ports.RunStore\n    77Ôćĺ\tassigner   TaskAssigner // optional; legacy task assignment\n    78Ôćĺ\tstopCh     chan struct{}\n    79Ôćĺ\tresumeCh   chan struct{} // signaled by Resume() to wake the loop\n    80Ôćĺ\tmu         sync.Mutex\n    81Ôćĺ\trunning    bool\n    82Ôćĺ\thaltedMu            sync.RWMutex\n    83Ôćĺ\thalted              bool   // true when loop is halted due to an unrecovered error\n    84Ôćĺ\thaltError           string // the error message that caused the halt\n    85Ôćĺ\tconsecutiveFailures int    // number of consecutive failed runs\n    86Ôćĺ\tdedupMu             sync.Mutex\n    87Ôćĺ\tdedup      map[string]time.Time // task ID -> last assignment time\n    88Ôćĺ\ttasksMu    sync.RWMutex\n    89Ôćĺ\tlastTasks  []Task                    // most recently fetched tasks\n    90Ôćĺ\ttaskRuns   map[string]TaskAssignment // task ID -> assignment info\n    91Ôćĺ}\n    92Ôćĺ\n    93Ôćĺ// NewLoop creates an orchestration loop using a single run function (legacy mode).\n    94Ôćĺ// For three-phase orchestration, use NewPhaseLoop instead.\n    95Ôćĺfunc NewLoop(cfg LoopConfig, store ports.RunStore, runFn RunFunc) *Loop {\n    96Ôćĺ\tif cfg.MaxConcurrent <= 0 {\n    97Ôćĺ\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n    98Ôćĺ\t}\n    99Ôćĺ\tif cfg.DedupTimeout <= 0 {\n   100Ôćĺ\t\tcfg.DedupTimeout = defaultDedupTimeout\n   101Ôćĺ\t}\n   102Ôćĺ\tif cfg.MaxConsecutiveFailures <= 0 {\n   103Ôćĺ\t\tcfg.MaxConsecutiveFailures = defaultMaxConsecutiveFailures\n   104Ôćĺ\t}\n   105Ôćĺ\treturn &Loop{\n   106Ôćĺ\t\tconfig:   cfg,\n   107Ôćĺ\t\trunner:   runFn,\n   108Ôćĺ\t\tstore:    store,\n   109Ôćĺ\t\tresumeCh: make(chan struct{}, 1),\n   110Ôćĺ\t\tdedup:    make(map[string]time.Time),\n   111Ôćĺ\t\ttaskRuns: make(map[string]TaskAssignment),\n   112Ôćĺ\t}\n   113Ôćĺ}\n   114Ôćĺ\n   115Ôćĺ// NewPhaseLoop creates a three-phase orchestration loop. The listTasksFn\n   116Ôćĺ// discovers available tasks, mainFn executes the main workflow for a task,\n   117Ôćĺ// and finalizeFn (optional) runs cleanup after main completes.\n   118Ôćĺfunc NewPhaseLoop(cfg LoopConfig, store ports.RunStore, listTasksFn ListTasksFunc, mainFn MainFunc, finalizeFn FinalizeFunc) *Loop {\n   119Ôćĺ\tif cfg.MaxConcurrent <= 0 {\n   120Ôćĺ\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n   121Ôćĺ\t}\n   122Ôćĺ\tif cfg.DedupTimeout <= 0 {\n   123Ôćĺ\t\tcfg.DedupTimeout = defaultDedupTimeout\n   124Ôćĺ\t}\n   125Ôćĺ\tif cfg.MaxConsecutiveFailures <= 0 {\n   126Ôćĺ\t\tcfg.MaxConsecutiveFailures = defaultMaxConsecutiveFailures\n   127Ôćĺ\t}\n   128Ôćĺ\treturn &Loop{\n   129Ôćĺ\t\tconfig:     cfg,\n   130Ôćĺ\t\tlistTasks:  listTasksFn,\n   131Ôćĺ\t\tmainFn:     mainFn,\n   132Ôćĺ\t\tfinalizeFn: finalizeFn,\n   133Ôćĺ\t\tstore:      store,\n   134Ôćĺ\t\tresumeCh:   make(chan struct{}, 1),\n   135Ôćĺ\t\tdedup:      make(map[string]time.Time),\n   136Ôćĺ\t\ttaskRuns:   make(map[string]TaskAssignment),\n   137Ôćĺ\t}\n   138Ôćĺ}\n   139Ôćĺ\n   140Ôćĺ// SetTaskAssigner configures a TaskAssigner for daemon-managed task assignment.\n   141Ôćĺ// Only used in legacy (single RunFunc) mode when no list-tasks function is set.\n   142Ôćĺfunc (l *Loop) SetTaskAssigner(a TaskAssigner) {\n   143Ôćĺ\tl.assigner = a\n   144Ôćĺ}\n   145Ôćĺ\n   146Ôćĺ// Start begins the orchestration loop. No-op if already running.\n   147Ôćĺfunc (l *Loop) Start() {\n   148Ôćĺ\tl.mu.Lock()\n   149Ôćĺ\tdefer l.mu.Unlock()\n   150Ôćĺ\tif l.running {\n   151Ôćĺ\t\treturn\n   152Ôćĺ\t}\n   153Ôćĺ\tl.running = true\n   154Ôćĺ\tl.stopCh = make(chan struct{})\n   155Ôćĺ\tgo l.run()\n   156Ôćĺ\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n   157Ôćĺ}\n   158Ôćĺ\n   159Ôćĺ// Stop signals the loop to stop. Active runs continue to completion.\n   160Ôćĺfunc (l *Loop) Stop() {\n   161Ôćĺ\tl.mu.Lock()\n   162Ôćĺ\tdefer l.mu.Unlock()\n   163Ôćĺ\tif !l.running {\n   164Ôćĺ\t\treturn\n   165Ôćĺ\t}\n   166Ôćĺ\tl.running = false\n   167Ôćĺ\tclose(l.stopCh)\n   168Ôćĺ\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n   169Ôćĺ}\n   170Ôćĺ\n   171Ôćĺ// Running returns whether the loop is currently active.\n   172Ôćĺfunc (l *Loop) Running() bool {\n   173Ôćĺ\tl.mu.Lock()\n   174Ôćĺ\tdefer l.mu.Unlock()\n   175Ôćĺ\treturn l.running\n   176Ôćĺ}\n   177Ôćĺ\n   178Ôćĺ// Halted returns whether the loop is halted due to an unrecovered error,\n   179Ôćĺ// along with the error message that caused the halt. When halted, the loop\n   180Ôćĺ// is still running but will not pick up new work.\n   181Ôćĺfunc (l *Loop) Halted() (bool, string) {\n   182Ôćĺ\tl.haltedMu.RLock()\n   183Ôćĺ\tdefer l.haltedMu.RUnlock()\n   184Ôćĺ\treturn l.halted, l.haltError\n   185Ôćĺ}\n   186Ôćĺ\n   187Ôćĺ// Resume clears the halted state so the loop resumes picking up new work.\n   188Ôćĺfunc (l *Loop) Resume() {\n   189Ôćĺ\tl.haltedMu.Lock()\n   190Ôćĺ\tdefer l.haltedMu.Unlock()\n   191Ôćĺ\tif l.halted {\n   192Ôćĺ\t\tlog.Printf(\"orchestration loop: resumed for %s (was halted: %s)\", l.config.ProjectDir, l.haltError)\n   193Ôćĺ\t\tl.halted = false\n   194Ôćĺ\t\tl.haltError = \"\"\n   195Ôćĺ\t\tl.consecutiveFailures = 0\n   196Ôćĺ\t\t// Wake the loop from any sleep so it picks up work immediately.\n   197Ôćĺ\t\tselect {\n   198Ôćĺ\t\tcase l.resumeCh <- struct{}{}:\n   199Ôćĺ\t\tdefault:\n   200Ôćĺ\t\t}\n   201Ôćĺ\t}\n   202Ôćĺ}\n   203Ôćĺ\n   204Ôćĺ// halt sets the loop into halted state with the given error message.\n   205Ôćĺfunc (l *Loop) halt(errMsg string) {\n   206Ôćĺ\tl.haltedMu.Lock()\n   207Ôćĺ\tdefer l.haltedMu.Unlock()\n   208Ôćĺ\tl.halted = true\n   209Ôćĺ\tl.haltError = errMsg\n   210Ôćĺ\tlog.Printf(\"orchestration loop: halted for %s (stop_on_error): %s\", l.config.ProjectDir, errMsg)\n   211Ôćĺ}\n   212Ôćĺ\n   213Ôćĺ// recordConsecutiveFailure increments the consecutive failure counter and\n   214Ôćĺ// returns true if the threshold has been reached.\n   215Ôćĺfunc (l *Loop) recordConsecutiveFailure() bool {\n   216Ôćĺ\tl.haltedMu.Lock()\n   217Ôćĺ\tdefer l.haltedMu.Unlock()\n   218Ôćĺ\tif l.halted {\n   219Ôćĺ\t\treturn false // already halted (e.g. by StopOnError)\n   220Ôćĺ\t}\n   221Ôćĺ\tl.consecutiveFailures++\n   222Ôćĺ\treturn l.consecutiveFailures >= l.config.MaxConsecutiveFailures\n   223Ôćĺ}\n   224Ôćĺ\n   225Ôćĺ// resetConsecutiveFailures resets the consecutive failure counter to zero.\n   226Ôćĺfunc (l *Loop) resetConsecutiveFailures() {\n   227Ôćĺ\tl.haltedMu.Lock()\n   228Ôćĺ\tdefer l.haltedMu.Unlock()\n   229Ôćĺ\tl.consecutiveFailures = 0\n   230Ôćĺ}\n   231Ôćĺ\n   232Ôćĺ// isHalted returns true if the loop is currently halted.\n   233Ôćĺfunc (l *Loop) isHalted() bool {\n   234Ôćĺ\tl.haltedMu.RLock()\n   235Ôćĺ\tdefer l.haltedMu.RUnlock()\n   236Ôćĺ\treturn l.halted\n   237Ôćĺ}\n   238Ôćĺ\n   239Ôćĺfunc (l *Loop) run() {\n   240Ôćĺ\tif l.listTasks != nil && l.mainFn != nil {\n   241Ôćĺ\t\tl.runPhased()\n   242Ôćĺ\t} else {\n   243Ôćĺ\t\tl.runLegacy()\n   244Ôćĺ\t}\n   245Ôćĺ}\n   246Ôćĺ\n   247Ôćĺ// runPhased implements the three-phase orchestration loop:\n   248Ôćĺ// 1. list-tasks Ôćĺ discover available work\n   249Ôćĺ// 2. main Ôćĺ execute work for each open task (up to MaxConcurrent)\n   250Ôćĺ// 3. finalize Ôćĺ cleanup after main completes (on both success and failure)\n   251Ôćĺfunc (l *Loop) runPhased() {\n   252Ôćĺ\ttype result struct {\n   253Ôćĺ\t\tstate  domain.RunState\n   254Ôćĺ\t\terrMsg string\n   255Ôćĺ\t}\n   256Ôćĺ\n   257Ôćĺ\tcompletions := make(chan result, l.config.MaxConcurrent)\n   258Ôćĺ\tinFlight := 0\n   259Ôćĺ\n   260Ôćĺ\tfor {\n   261Ôćĺ\t\t// Fill up to max concurrent slots.\n   262Ôćĺ\t\tlaunched := 0\n   263Ôćĺ\t\tfor inFlight < l.config.MaxConcurrent {\n   264Ôćĺ\t\t\tselect {\n   265Ôćĺ\t\t\tcase <-l.stopCh:\n   266Ôćĺ\t\t\t\treturn\n   267Ôćĺ\t\t\tdefault:\n   268Ôćĺ\t\t\t}\n   269Ôćĺ\n   270Ôćĺ\t\t\t// If halted, don't pick up new work.\n   271Ôćĺ\t\t\tif l.isHalted() {\n   272Ôćĺ\t\t\t\tbreak\n   273Ôćĺ\t\t\t}\n   274Ôćĺ\n   275Ôćĺ\t\t\t// Check how many host runs are active for this project.\n   276Ôćĺ\t\t\tactive := l.countActiveHostRuns()\n   277Ôćĺ\t\t\tif active >= l.config.MaxConcurrent {\n   278Ôćĺ\t\t\t\tbreak\n   279Ôćĺ\t\t\t}\n   280Ôćĺ\n   281Ôćĺ\t\t\t// Stagger consecutive launches.\n   282Ôćĺ\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   283Ôćĺ\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   284Ôćĺ\t\t\t\t\treturn\n   285Ôćĺ\t\t\t\t}\n   286Ôćĺ\t\t\t}\n   287Ôćĺ\n   288Ôćĺ\t\t\t// Phase 1: list-tasks ÔÇö discover available work.\n   289Ôćĺ\t\t\ttaskID, taskTitle, ok := l.pickTaskFromPhase()\n   290Ôćĺ\t\t\tif !ok {\n   291Ôćĺ\t\t\t\tbreak // no assignable tasks\n   292Ôćĺ\t\t\t}\n   293Ôćĺ\n   294Ôćĺ\t\t\t// Launch main + finalize in a goroutine.\n   295Ôćĺ\t\t\tinFlight++\n   296Ôćĺ\t\t\tlaunched++\n   297Ôćĺ\t\t\ttid := taskID\n   298Ôćĺ\t\t\tttitle := taskTitle\n   299Ôćĺ\t\t\tgo func() {\n   300Ôćĺ\t\t\t\t// Phase 2: main ÔÇö do the work.\n   301Ôćĺ\t\t\t\tmainResult, err := l.mainFn(context.Background(), l.config.ProjectDir, tid)\n   302Ôćĺ\t\t\t\tif err != nil {\n   303Ôćĺ\t\t\t\t\tlog.Printf(\"orchestration loop: main failed for %s task %s: %v\", l.config.ProjectDir, tid, err)\n   304Ôćĺ\t\t\t\t\tif mainResult == nil {\n   305Ôćĺ\t\t\t\t\t\tmainResult = &RunResult{State: domain.RunStateFailed}\n   306Ôćĺ\t\t\t\t\t}\n   307Ôćĺ\t\t\t\t}\n   308Ôćĺ\n   309Ôćĺ\t\t\t\t// Track the run ID for this task and persist the task title.\n   310Ôćĺ\t\t\t\tif mainResult != nil && mainResult.RunID != \"\" {\n   311Ôćĺ\t\t\t\t\tl.tasksMu.Lock()\n   312Ôćĺ\t\t\t\t\tl.taskRuns[tid] = TaskAssignment{\n   313Ôćĺ\t\t\t\t\t\tAssignedAt: time.Now(),\n   314Ôćĺ\t\t\t\t\t\tRunID:      mainResult.RunID,\n   315Ôćĺ\t\t\t\t\t}\n   316Ôćĺ\t\t\t\t\tl.tasksMu.Unlock()\n   317Ôćĺ\n   318Ôćĺ\t\t\t\t\tif ttitle != \"\" {\n   319Ôćĺ\t\t\t\t\t\tif r, err := l.store.GetRun(context.Background(), mainResult.RunID); err == nil && r.TaskTitle == \"\" {\n   320Ôćĺ\t\t\t\t\t\t\tr.TaskTitle = ttitle\n   321Ôćĺ\t\t\t\t\t\t\t_ = l.store.UpdateRun(context.Background(), r)\n   322Ôćĺ\t\t\t\t\t\t}\n   323Ôćĺ\t\t\t\t\t}\n   324Ôćĺ\t\t\t\t}\n   325Ôćĺ\n   326Ôćĺ\t\t\t\t// Phase 3: finalize ÔÇö cleanup (runs on both success and failure).\n   327Ôćĺ\t\t\t\t// The overall state is the worst of main and finalize outcomes.\n   328Ôćĺ\t\t\t\toverallState := mainResult.State\n   329Ôćĺ\t\t\t\tif l.finalizeFn != nil {\n   330Ôćĺ\t\t\t\t\tfinalizeResult, finalizeErr := l.finalizeFn(context.Background(), l.config.ProjectDir, tid, mainResult)\n   331Ôćĺ\t\t\t\t\tif finalizeErr != nil {\n   332Ôćĺ\t\t\t\t\t\tlog.Printf(\"orchestration loop: finalize failed for %s task %s: %v\", l.config.ProjectDir, tid, finalizeErr)\n   333Ôćĺ\t\t\t\t\t\toverallState = domain.WorseState(overallState, domain.RunStateFailed)\n   334Ôćĺ\t\t\t\t\t} else if finalizeResult != nil {\n   335Ôćĺ\t\t\t\t\t\toverallState = domain.WorseState(overallState, finalizeResult.State)\n   336Ôćĺ\t\t\t\t\t}\n   337Ôćĺ\t\t\t\t}\n   338Ôćĺ\n   339Ôćĺ\t\t\t\tcompletions <- result{state: overallState, errMsg: fmt.Sprintf(\"task %s failed\", tid)}\n   340Ôćĺ\t\t\t}()\n   341Ôćĺ\t\t}\n   342Ôćĺ\n   343Ôćĺ\t\tif inFlight == 0 {\n   344Ôćĺ\t\t\t// Nothing in flight and couldn't launch anything ÔÇö wait before checking again.\n   345Ôćĺ\t\t\tif !l.sleep(capacityPollInterval) {\n   346Ôćĺ\t\t\t\treturn\n   347Ôćĺ\t\t\t}\n   348Ôćĺ\t\t\tcontinue\n   349Ôćĺ\t\t}\n   350Ôćĺ\n   351Ôćĺ\t\t// Wait for any run to complete.\n   352Ôćĺ\t\tselect {\n   353Ôćĺ\t\tcase r := <-completions:\n   354Ôćĺ\t\t\tinFlight--\n   355Ôćĺ\t\t\tif r.state == domain.RunStateSucceeded {\n   356Ôćĺ\t\t\t\tl.resetConsecutiveFailures()\n   357Ôćĺ\t\t\t\t// Work was done ÔÇö try to fill slots immediately.\n   358Ôćĺ\t\t\t\tcontinue\n   359Ôćĺ\t\t\t}\n   360Ôćĺ\t\t\t// Run failed or aborted.\n   361Ôćĺ\t\t\tif l.config.StopOnError {\n   362Ôćĺ\t\t\t\tl.halt(r.errMsg)\n   363Ôćĺ\t\t\t}\n   364Ôćĺ\t\t\tif l.recordConsecutiveFailure() {\n   365Ôćĺ\t\t\t\tl.halt(fmt.Sprintf(\"halted after %d consecutive failures: %s\", l.config.MaxConsecutiveFailures, r.errMsg))\n   366Ôćĺ\t\t\t}\n   367Ôćĺ\t\t\t// Back off.\n   368Ôćĺ\t\t\tif !l.sleep(idlePollInterval) {\n   369Ôćĺ\t\t\t\treturn\n   370Ôćĺ\t\t\t}\n   371Ôćĺ\t\tcase <-l.stopCh:\n   372Ôćĺ\t\t\treturn\n   373Ôćĺ\t\t}\n   374Ôćĺ\t}\n   375Ôćĺ}\n   376Ôćĺ\n   377Ôćĺ// GetTaskSnapshot returns the current task pipeline state: the most recently\n   378Ôćĺ// fetched tasks with their assignment information.\n   379Ôćĺfunc (l *Loop) GetTaskSnapshot() []TaskStateEntry {\n   380Ôćĺ\tl.tasksMu.RLock()\n   381Ôćĺ\ttasks := make([]Task, len(l.lastTasks))\n   382Ôćĺ\tcopy(tasks, l.lastTasks)\n   383Ôćĺ\tl.tasksMu.RUnlock()\n   384Ôćĺ\n   385Ôćĺ\tl.dedupMu.Lock()\n   386Ôćĺ\tdefer l.dedupMu.Unlock()\n   387Ôćĺ\n   388Ôćĺ\tnow := time.Now()\n   389Ôćĺ\tvar entries []TaskStateEntry\n   390Ôćĺ\tfor _, task := range tasks {\n   391Ôćĺ\t\tentry := TaskStateEntry{Task: task}\n   392Ôćĺ\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   393Ôćĺ\t\t\tentry.Assigned = true\n   394Ôćĺ\t\t\tentry.AssignedAt = ts\n   395Ôćĺ\t\t}\n   396Ôćĺ\n   397Ôćĺ\t\tl.tasksMu.RLock()\n   398Ôćĺ\t\tif a, ok := l.taskRuns[task.ID]; ok {\n   399Ôćĺ\t\t\tentry.RunID = a.RunID\n   400Ôćĺ\t\t\tif !entry.Assigned {\n   401Ôćĺ\t\t\t\tentry.AssignedAt = a.AssignedAt\n   402Ôćĺ\t\t\t}\n   403Ôćĺ\t\t}\n   404Ôćĺ\t\tl.tasksMu.RUnlock()\n   405Ôćĺ\n   406Ôćĺ\t\tentries = append(entries, entry)\n   407Ôćĺ\t}\n   408Ôćĺ\treturn entries\n   409Ôćĺ}\n   410Ôćĺ\n   411Ôćĺ// pickTaskFromPhase runs the list-tasks function and picks the first open,\n   412Ôćĺ// non-deduped task. Returns the task ID, title, and whether a task was found.\n   413Ôćĺfunc (l *Loop) pickTaskFromPhase() (string, string, bool) {\n   414Ôćĺ\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   415Ôćĺ\tdefer cancel()\n   416Ôćĺ\n   417Ôćĺ\ttasks, err := l.listTasks(ctx, l.config.ProjectDir)\n   418Ôćĺ\tif err != nil {\n   419Ôćĺ\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n   420Ôćĺ\t\treturn \"\", \"\", false\n   421Ôćĺ\t}\n   422Ôćĺ\n   423Ôćĺ\t// Cache the latest tasks for snapshot queries.\n   424Ôćĺ\tl.tasksMu.Lock()\n   425Ôćĺ\tl.lastTasks = tasks\n   426Ôćĺ\tl.tasksMu.Unlock()\n   427Ôćĺ\n   428Ôćĺ\tnow := time.Now()\n   429Ôćĺ\tl.dedupMu.Lock()\n   430Ôćĺ\tdefer l.dedupMu.Unlock()\n   431Ôćĺ\n   432Ôćĺ\t// Expire old dedup entries.\n   433Ôćĺ\tfor id, ts := range l.dedup {\n   434Ôćĺ\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n   435Ôćĺ\t\t\tdelete(l.dedup, id)\n   436Ôćĺ\t\t}\n   437Ôćĺ\t}\n   438Ôćĺ\n   439Ôćĺ\tfor _, task := range tasks {\n   440Ôćĺ\t\tif task.ID == \"\" {\n   441Ôćĺ\t\t\tcontinue\n   442Ôćĺ\t\t}\n   443Ôćĺ\t\tif !task.IsOpen() {\n   444Ôćĺ\t\t\tcontinue\n   445Ôćĺ\t\t}\n   446Ôćĺ\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   447Ôćĺ\t\t\tcontinue\n   448Ôćĺ\t\t}\n   449Ôćĺ\t\tl.dedup[task.ID] = now\n   450Ôćĺ\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n   451Ôćĺ\t\treturn task.ID, task.Title, true\n   452Ôćĺ\t}\n   453Ôćĺ\n   454Ôćĺ\treturn \"\", \"\", false\n   455Ôćĺ}\n   456Ôćĺ\n   457Ôćĺ// runLegacy implements the original single-function orchestration loop.\n   458Ôćĺfunc (l *Loop) runLegacy() {\n   459Ôćĺ\ttype result struct {\n   460Ôćĺ\t\tstate  domain.RunState\n   461Ôćĺ\t\terrMsg string\n   462Ôćĺ\t}\n   463Ôćĺ\n   464Ôćĺ\tcompletions := make(chan result, l.config.MaxConcurrent)\n   465Ôćĺ\tinFlight := 0\n   466Ôćĺ\n   467Ôćĺ\tfor {\n   468Ôćĺ\t\t// Fill up to max concurrent slots.\n   469Ôćĺ\t\tlaunched := 0\n   470Ôćĺ\t\tfor inFlight < l.config.MaxConcurrent {\n   471Ôćĺ\t\t\tselect {\n   472Ôćĺ\t\t\tcase <-l.stopCh:\n   473Ôćĺ\t\t\t\treturn\n   474Ôćĺ\t\t\tdefault:\n   475Ôćĺ\t\t\t}\n   476Ôćĺ\n   477Ôćĺ\t\t\t// If halted, don't pick up new work.\n   478Ôćĺ\t\t\tif l.isHalted() {\n   479Ôćĺ\t\t\t\tbreak\n   480Ôćĺ\t\t\t}\n   481Ôćĺ\n   482Ôćĺ\t\t\t// Check how many host runs are active for this project (in case of\n   483Ôćĺ\t\t\t// leftover runs from previous loops).\n   484Ôćĺ\t\t\tactive := l.countActiveHostRuns()\n   485Ôćĺ\t\t\tif active >= l.config.MaxConcurrent {\n   486Ôćĺ\t\t\t\tbreak\n   487Ôćĺ\t\t\t}\n   488Ôćĺ\n   489Ôćĺ\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n   490Ôćĺ\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   491Ôćĺ\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   492Ôćĺ\t\t\t\t\treturn\n   493Ôćĺ\t\t\t\t}\n   494Ôćĺ\t\t\t}\n   495Ôćĺ\n   496Ôćĺ\t\t\t// Determine task ID (if task assigner is configured).\n   497Ôćĺ\t\t\ttaskID := \"\"\n   498Ôćĺ\t\t\tif l.assigner != nil {\n   499Ôćĺ\t\t\t\tvar ok bool\n   500Ôćĺ\t\t\t\ttaskID, ok = l.pickTask()\n   501Ôćĺ\t\t\t\tif !ok {\n   502Ôćĺ\t\t\t\t\t// No assignable tasks available.\n   503Ôćĺ\t\t\t\t\tbreak\n   504Ôćĺ\t\t\t\t}\n   505Ôćĺ\t\t\t}\n   506Ôćĺ\n   507Ôćĺ\t\t\t// Launch a new orchestration run in a goroutine.\n   508Ôćĺ\t\t\tinFlight++\n   509Ôćĺ\t\t\tlaunched++\n   510Ôćĺ\t\t\ttid := taskID // capture for goroutine\n   511Ôćĺ\t\t\tgo func() {\n   512Ôćĺ\t\t\t\tres, err := l.runner(context.Background(), l.config.ProjectDir, tid)\n   513Ôćĺ\t\t\t\tif err != nil {\n   514Ôćĺ\t\t\t\t\tlog.Printf(\"orchestration loop: run failed for %s: %v\", l.config.ProjectDir, err)\n   515Ôćĺ\t\t\t\t\tcompletions <- result{state: domain.RunStateFailed, errMsg: err.Error()}\n   516Ôćĺ\t\t\t\t\treturn\n   517Ôćĺ\t\t\t\t}\n   518Ôćĺ\t\t\t\tif res.State != domain.RunStateSucceeded {\n   519Ôćĺ\t\t\t\t\tcompletions <- result{state: res.State, errMsg: \"run failed with state \" + string(res.State)}\n   520Ôćĺ\t\t\t\t\treturn\n   521Ôćĺ\t\t\t\t}\n   522Ôćĺ\t\t\t\tcompletions <- result{state: res.State}\n   523Ôćĺ\t\t\t}()\n   524Ôćĺ\t\t}\n   525Ôćĺ\n   526Ôćĺ\t\tif inFlight == 0 {\n   527Ôćĺ\t\t\t// Nothing in flight and at capacity ÔÇö wait before checking again.\n   528Ôćĺ\t\t\tif !l.sleep(capacityPollInterval) {\n   529Ôćĺ\t\t\t\treturn\n   530Ôćĺ\t\t\t}\n   531Ôćĺ\t\t\tcontinue\n   532Ôćĺ\t\t}\n   533Ôćĺ\n   534Ôćĺ\t\t// Wait for any run to complete.\n   535Ôćĺ\t\tselect {\n   536Ôćĺ\t\tcase r := <-completions:\n   537Ôćĺ\t\t\tinFlight--\n   538Ôćĺ\t\t\tif r.state == domain.RunStateSucceeded {\n   539Ôćĺ\t\t\t\tl.resetConsecutiveFailures()\n   540Ôćĺ\t\t\t\t// Work was done ÔÇö try to fill slots immediately.\n   541Ôćĺ\t\t\t\tcontinue\n   542Ôćĺ\t\t\t}\n   543Ôćĺ\t\t\t// Run failed or aborted (no tasks available).\n   544Ôćĺ\t\t\tif l.config.StopOnError {\n   545Ôćĺ\t\t\t\tl.halt(r.errMsg)\n   546Ôćĺ\t\t\t}\n   547Ôćĺ\t\t\tif l.recordConsecutiveFailure() {\n   548Ôćĺ\t\t\t\tl.halt(fmt.Sprintf(\"halted after %d consecutive failures: %s\", l.config.MaxConsecutiveFailures, r.errMsg))\n   549Ôćĺ\t\t\t}\n   550Ôćĺ\t\t\t// Back off.\n   551Ôćĺ\t\t\tif !l.sleep(idlePollInterval) {\n   552Ôćĺ\t\t\t\treturn\n   553Ôćĺ\t\t\t}\n   554Ôćĺ\t\tcase <-l.stopCh:\n   555Ôćĺ\t\t\treturn\n   556Ôćĺ\t\t}\n   557Ôćĺ\t}\n   558Ôćĺ}\n   559Ôćĺ\n   560Ôćĺ// pickTask queries the task assigner for available tasks, filters out those\n   561Ôćĺ// within the dedup timeout window, and returns the first assignable task ID.\n   562Ôćĺ// It records the assignment time so the same task won't be picked again until\n   563Ôćĺ// the dedup timeout expires. Returns (\"\", false) if no tasks are available.\n   564Ôćĺfunc (l *Loop) pickTask() (string, bool) {\n   565Ôćĺ\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   566Ôćĺ\tdefer cancel()\n   567Ôćĺ\n   568Ôćĺ\ttasks, err := l.assigner.ListTasks(ctx, l.config.ProjectDir)\n   569Ôćĺ\tif err != nil {\n   570Ôćĺ\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n   571Ôćĺ\t\treturn \"\", false\n   572Ôćĺ\t}\n   573Ôćĺ\n   574Ôćĺ\t// Cache the latest tasks for snapshot queries.\n   575Ôćĺ\tl.tasksMu.Lock()\n   576Ôćĺ\tl.lastTasks = tasks\n   577Ôćĺ\tl.tasksMu.Unlock()\n   578Ôćĺ\n   579Ôćĺ\tnow := time.Now()\n   580Ôćĺ\tl.dedupMu.Lock()\n   581Ôćĺ\tdefer l.dedupMu.Unlock()\n   582Ôćĺ\n   583Ôćĺ\t// Expire old dedup entries while we're here.\n   584Ôćĺ\tfor id, ts := range l.dedup {\n   585Ôćĺ\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n   586Ôćĺ\t\t\tdelete(l.dedup, id)\n   587Ôćĺ\t\t}\n   588Ôćĺ\t}\n   589Ôćĺ\n   590Ôćĺ\tfor _, task := range tasks {\n   591Ôćĺ\t\tif task.ID == \"\" {\n   592Ôćĺ\t\t\tcontinue\n   593Ôćĺ\t\t}\n   594Ôćĺ\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   595Ôćĺ\t\t\tcontinue // still within dedup window\n   596Ôćĺ\t\t}\n   597Ôćĺ\t\t// Assign this task.\n   598Ôćĺ\t\tl.dedup[task.ID] = now\n   599Ôćĺ\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n   600Ôćĺ\t\treturn task.ID, true\n   601Ôćĺ\t}\n   602Ôćĺ\n   603Ôćĺ\treturn \"\", false\n   604Ôćĺ}\n   605Ôćĺ\n   606Ôćĺ// countActiveHostRuns counts running or pending host runs for the project.\n   607Ôćĺfunc (l *Loop) countActiveHostRuns() int {\n   608Ôćĺ\tctx := context.Background()\n   609Ôćĺ\truns, err := l.store.ListRunsByProject(ctx, l.config.ProjectDir, time.Time{})\n   610Ôćĺ\tif err != nil {\n   611Ôćĺ\t\treturn 0\n   612Ôćĺ\t}\n   613Ôćĺ\tcount := 0\n   614Ôćĺ\tfor _, r := range runs {\n   615Ôćĺ\t\tif r.IsHost && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n   616Ôćĺ\t\t\tcount++\n   617Ôćĺ\t\t}\n   618Ôćĺ\t}\n   619Ôćĺ\treturn count\n   620Ôćĺ}\n   621Ôćĺ\n   622Ôćĺ// sleep waits for the given duration or until the loop is stopped or resumed.\n   623Ôćĺ// Returns false if the loop was stopped.\n   624Ôćĺfunc (l *Loop) sleep(d time.Duration) bool {\n   625Ôćĺ\tselect {\n   626Ôćĺ\tcase <-time.After(d):\n   627Ôćĺ\t\treturn true\n   628Ôćĺ\tcase <-l.resumeCh:\n   629Ôćĺ\t\treturn true\n   630Ôćĺ\tcase <-l.stopCh:\n   631Ôćĺ\t\treturn false\n   632Ôćĺ\t}\n   633Ôćĺ}\n   634Ôćĺ\n   635Ôćĺ// ReadListTasksOutput reads the output directory from a list-tasks workflow run\n   636Ôćĺ// and parses JSONL task output from the last step's output file.\n   637Ôćĺfunc ReadListTasksOutput(outputDir string) ([]Task, error) {\n   638Ôćĺ\tentries, err := os.ReadDir(outputDir)\n   639Ôćĺ\tif err != nil {\n   640Ôćĺ\t\treturn nil, fmt.Errorf(\"reading list-tasks output dir: %w\", err)\n   641Ôćĺ\t}\n   642Ôćĺ\n   643Ôćĺ\t// Find the most recently modified .out file.\n   644Ôćĺ\tvar latest string\n   645Ôćĺ\tvar latestMod time.Time\n   646Ôćĺ\tfor _, e := range entries {\n   647Ôćĺ\t\tif e.IsDir() || filepath.Ext(e.Name()) != \".out\" {\n   648Ôćĺ\t\t\tcontinue\n   649Ôćĺ\t\t}\n   650Ôćĺ\t\tinfo, err := e.Info()\n   651Ôćĺ\t\tif err != nil {\n   652Ôćĺ\t\t\tcontinue\n   653Ôćĺ\t\t}\n   654Ôćĺ\t\tif latest == \"\" || info.ModTime().After(latestMod) {\n   655Ôćĺ\t\t\tlatest = e.Name()\n   656Ôćĺ\t\t\tlatestMod = info.ModTime()\n   657Ôćĺ\t\t}\n   658Ôćĺ\t}\n   659Ôćĺ\n   660Ôćĺ\tif latest == \"\" {\n   661Ôćĺ\t\treturn nil, fmt.Errorf(\"no output files found in %s\", outputDir)\n   662Ôćĺ\t}\n   663Ôćĺ\n   664Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, latest))\n   665Ôćĺ\tif err != nil {\n   666Ôćĺ\t\treturn nil, fmt.Errorf(\"reading output file %s: %w\", latest, err)\n   667Ôćĺ\t}\n   668Ôćĺ\n   669Ôćĺ\treturn ParseTasksJSONL(string(data))\n   670Ôćĺ}\n   671Ôćĺ"}]},"parent_tool_use_id":null,"session_id":"4ff3ccd2-e0d4-4cea-9924-a15740aebe51","uuid":"6a591cb6-2597-4382-9a93-1e14a095777d","timestamp":"2026-03-18T16:10:31.187Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/loop.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\nconst (\n\tdefaultMaxConcurrent          = 1\n\tdefaultDedupTimeout           = 5 * time.Minute\n\tdefaultMaxConsecutiveFailures = 3\n\tidlePollInterval              = 2 * time.Minute\n\tcapacityPollInterval          = 30 * time.Second\n)\n\n// LoopConfig holds configuration for an orchestration loop.\ntype LoopConfig struct {\n\tProjectDir             string\n\tMaxConcurrent          int\n\tStaggerDelay           time.Duration // delay between launching consecutive runs\n\tDedupTimeout           time.Duration // how long to suppress reassignment of the same task ID\n\tStopOnError            bool          // halt loop on unrecovered error (allow in-flight work to finish)\n\tMaxConsecutiveFailures int           // halt loop after N consecutive failures (default: 3, must be > 0)\n}\n\n// ListTasksFunc is called to discover available tasks. It should run the\n// list-tasks workflow (or equivalent) and return the parsed tasks.\ntype ListTasksFunc func(ctx context.Context, projectDir string) ([]Task, error)\n\n// MainFunc is called to execute the main workflow for a given task.\ntype MainFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n\n// FinalizeFunc is called after the main workflow completes (both success and\n// failure). It receives the task ID and the outcome of the main phase.\ntype FinalizeFunc func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error)\n\n// RunFunc is the legacy function signature for launching a host workflow run.\n// When taskID is non-empty, the runner should propagate it as CLOCHE_TASK_ID.\ntype RunFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n\n// TaskAssignment tracks the assignment state of a task.\ntype TaskAssignment struct {\n\tAssignedAt time.Time\n\tRunID      string // run ID handling this task (set after main completes)\n}\n\n// TaskStateEntry combines a task with its assignment state.\ntype TaskStateEntry struct {\n\tTask       Task\n\tAssigned   bool\n\tAssignedAt time.Time\n\tRunID      string // empty if not yet known\n}\n\n// Loop manages a continuous orchestration loop for a project, keeping up to\n// MaxConcurrent host workflow runs active at all times when work is available.\n//\n// When configured with three-phase functions (list-tasks, main, finalize), the\n// loop discovers tasks via list-tasks, picks open ones, runs main for each, and\n// then runs finalize on completion. When configured with a legacy RunFunc, it\n// falls back to the single-function approach.\ntype Loop struct {\n\tconfig     LoopConfig\n\tlistTasks  ListTasksFunc\n\tmainFn     MainFunc\n\tfinalizeFn FinalizeFunc // optional; skipped if nil\n\trunner     RunFunc      // legacy single-function mode\n\tstore      ports.RunStore\n\tassigner   TaskAssigner // optional; legacy task assignment\n\tstopCh     chan struct{}\n\tresumeCh   chan struct{} // signaled by Resume() to wake the loop\n\tmu         sync.Mutex\n\trunning    bool\n\thaltedMu            sync.RWMutex\n\thalted              bool   // true when loop is halted due to an unrecovered error\n\thaltError           string // the error message that caused the halt\n\tconsecutiveFailures int    // number of consecutive failed runs\n\tdedupMu             sync.Mutex\n\tdedup      map[string]time.Time // task ID -> last assignment time\n\ttasksMu    sync.RWMutex\n\tlastTasks  []Task                    // most recently fetched tasks\n\ttaskRuns   map[string]TaskAssignment // task ID -> assignment info\n}\n\n// NewLoop creates an orchestration loop using a single run function (legacy mode).\n// For three-phase orchestration, use NewPhaseLoop instead.\nfunc NewLoop(cfg LoopConfig, store ports.RunStore, runFn RunFunc) *Loop {\n\tif cfg.MaxConcurrent <= 0 {\n\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n\t}\n\tif cfg.DedupTimeout <= 0 {\n\t\tcfg.DedupTimeout = defaultDedupTimeout\n\t}\n\tif cfg.MaxConsecutiveFailures <= 0 {\n\t\tcfg.MaxConsecutiveFailures = defaultMaxConsecutiveFailures\n\t}\n\treturn &Loop{\n\t\tconfig:   cfg,\n\t\trunner:   runFn,\n\t\tstore:    store,\n\t\tresumeCh: make(chan struct{}, 1),\n\t\tdedup:    make(map[string]time.Time),\n\t\ttaskRuns: make(map[string]TaskAssignment),\n\t}\n}\n\n// NewPhaseLoop creates a three-phase orchestration loop. The listTasksFn\n// discovers available tasks, mainFn executes the main workflow for a task,\n// and finalizeFn (optional) runs cleanup after main completes.\nfunc NewPhaseLoop(cfg LoopConfig, store ports.RunStore, listTasksFn ListTasksFunc, mainFn MainFunc, finalizeFn FinalizeFunc) *Loop {\n\tif cfg.MaxConcurrent <= 0 {\n\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n\t}\n\tif cfg.DedupTimeout <= 0 {\n\t\tcfg.DedupTimeout = defaultDedupTimeout\n\t}\n\tif cfg.MaxConsecutiveFailures <= 0 {\n\t\tcfg.MaxConsecutiveFailures = defaultMaxConsecutiveFailures\n\t}\n\treturn &Loop{\n\t\tconfig:     cfg,\n\t\tlistTasks:  listTasksFn,\n\t\tmainFn:     mainFn,\n\t\tfinalizeFn: finalizeFn,\n\t\tstore:      store,\n\t\tresumeCh:   make(chan struct{}, 1),\n\t\tdedup:      make(map[string]time.Time),\n\t\ttaskRuns:   make(map[string]TaskAssignment),\n\t}\n}\n\n// SetTaskAssigner configures a TaskAssigner for daemon-managed task assignment.\n// Only used in legacy (single RunFunc) mode when no list-tasks function is set.\nfunc (l *Loop) SetTaskAssigner(a TaskAssigner) {\n\tl.assigner = a\n}\n\n// Start begins the orchestration loop. No-op if already running.\nfunc (l *Loop) Start() {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\tif l.running {\n\t\treturn\n\t}\n\tl.running = true\n\tl.stopCh = make(chan struct{})\n\tgo l.run()\n\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n}\n\n// Stop signals the loop to stop. Active runs continue to completion.\nfunc (l *Loop) Stop() {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\tif !l.running {\n\t\treturn\n\t}\n\tl.running = false\n\tclose(l.stopCh)\n\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n}\n\n// Running returns whether the loop is currently active.\nfunc (l *Loop) Running() bool {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\treturn l.running\n}\n\n// Halted returns whether the loop is halted due to an unrecovered error,\n// along with the error message that caused the halt. When halted, the loop\n// is still running but will not pick up new work.\nfunc (l *Loop) Halted() (bool, string) {\n\tl.haltedMu.RLock()\n\tdefer l.haltedMu.RUnlock()\n\treturn l.halted, l.haltError\n}\n\n// Resume clears the halted state so the loop resumes picking up new work.\nfunc (l *Loop) Resume() {\n\tl.haltedMu.Lock()\n\tdefer l.haltedMu.Unlock()\n\tif l.halted {\n\t\tlog.Printf(\"orchestration loop: resumed for %s (was halted: %s)\", l.config.ProjectDir, l.haltError)\n\t\tl.halted = false\n\t\tl.haltError = \"\"\n\t\tl.consecutiveFailures = 0\n\t\t// Wake the loop from any sleep so it picks up work immediately.\n\t\tselect {\n\t\tcase l.resumeCh <- struct{}{}:\n\t\tdefault:\n\t\t}\n\t}\n}\n\n// halt sets the loop into halted state with the given error message.\nfunc (l *Loop) halt(errMsg string) {\n\tl.haltedMu.Lock()\n\tdefer l.haltedMu.Unlock()\n\tl.halted = true\n\tl.haltError = errMsg\n\tlog.Printf(\"orchestration loop: halted for %s (stop_on_error): %s\", l.config.ProjectDir, errMsg)\n}\n\n// recordConsecutiveFailure increments the consecutive failure counter and\n// returns true if the threshold has been reached.\nfunc (l *Loop) recordConsecutiveFailure() bool {\n\tl.haltedMu.Lock()\n\tdefer l.haltedMu.Unlock()\n\tif l.halted {\n\t\treturn false // already halted (e.g. by StopOnError)\n\t}\n\tl.consecutiveFailures++\n\treturn l.consecutiveFailures >= l.config.MaxConsecutiveFailures\n}\n\n// resetConsecutiveFailures resets the consecutive failure counter to zero.\nfunc (l *Loop) resetConsecutiveFailures() {\n\tl.haltedMu.Lock()\n\tdefer l.haltedMu.Unlock()\n\tl.consecutiveFailures = 0\n}\n\n// isHalted returns true if the loop is currently halted.\nfunc (l *Loop) isHalted() bool {\n\tl.haltedMu.RLock()\n\tdefer l.haltedMu.RUnlock()\n\treturn l.halted\n}\n\nfunc (l *Loop) run() {\n\tif l.listTasks != nil && l.mainFn != nil {\n\t\tl.runPhased()\n\t} else {\n\t\tl.runLegacy()\n\t}\n}\n\n// runPhased implements the three-phase orchestration loop:\n// 1. list-tasks Ôćĺ discover available work\n// 2. main Ôćĺ execute work for each open task (up to MaxConcurrent)\n// 3. finalize Ôćĺ cleanup after main completes (on both success and failure)\nfunc (l *Loop) runPhased() {\n\ttype result struct {\n\t\tstate  domain.RunState\n\t\terrMsg string\n\t}\n\n\tcompletions := make(chan result, l.config.MaxConcurrent)\n\tinFlight := 0\n\n\tfor {\n\t\t// Fill up to max concurrent slots.\n\t\tlaunched := 0\n\t\tfor inFlight < l.config.MaxConcurrent {\n\t\t\tselect {\n\t\t\tcase <-l.stopCh:\n\t\t\t\treturn\n\t\t\tdefault:\n\t\t\t}\n\n\t\t\t// If halted, don't pick up new work.\n\t\t\tif l.isHalted() {\n\t\t\t\tbreak\n\t\t\t}\n\n\t\t\t// Check how many host runs are active for this project.\n\t\t\tactive := l.countActiveHostRuns()\n\t\t\tif active >= l.config.MaxConcurrent {\n\t\t\t\tbreak\n\t\t\t}\n\n\t\t\t// Stagger consecutive launches.\n\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// Phase 1: list-tasks ÔÇö discover available work.\n\t\t\ttaskID, taskTitle, ok := l.pickTaskFromPhase()\n\t\t\tif !ok {\n\t\t\t\tbreak // no assignable tasks\n\t\t\t}\n\n\t\t\t// Launch main + finalize in a goroutine.\n\t\t\tinFlight++\n\t\t\tlaunched++\n\t\t\ttid := taskID\n\t\t\tttitle := taskTitle\n\t\t\tgo func() {\n\t\t\t\t// Phase 2: main ÔÇö do the work.\n\t\t\t\tmainResult, err := l.mainFn(context.Background(), l.config.ProjectDir, tid)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlog.Printf(\"orchestration loop: main failed for %s task %s: %v\", l.config.ProjectDir, tid, err)\n\t\t\t\t\tif mainResult == nil {\n\t\t\t\t\t\tmainResult = &RunResult{State: domain.RunStateFailed}\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\t// Track the run ID for this task and persist the task title.\n\t\t\t\tif mainResult != nil && mainResult.RunID != \"\" {\n\t\t\t\t\tl.tasksMu.Lock()\n\t\t\t\t\tl.taskRuns[tid] = TaskAssignment{\n\t\t\t\t\t\tAssignedAt: time.Now(),\n\t\t\t\t\t\tRunID:      mainResult.RunID,\n\t\t\t\t\t}\n\t\t\t\t\tl.tasksMu.Unlock()\n\n\t\t\t\t\tif ttitle != \"\" {\n\t\t\t\t\t\tif r, err := l.store.GetRun(context.Background(), mainResult.RunID); err == nil && r.TaskTitle == \"\" {\n\t\t\t\t\t\t\tr.TaskTitle = ttitle\n\t\t\t\t\t\t\t_ = l.store.UpdateRun(context.Background(), r)\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\t// Phase 3: finalize ÔÇö cleanup (runs on both success and failure).\n\t\t\t\t// The overall state is the worst of main and finalize outcomes.\n\t\t\t\toverallState := mainResult.State\n\t\t\t\tif l.finalizeFn != nil {\n\t\t\t\t\tfinalizeResult, finalizeErr := l.finalizeFn(context.Background(), l.config.ProjectDir, tid, mainResult)\n\t\t\t\t\tif finalizeErr != nil {\n\t\t\t\t\t\tlog.Printf(\"orchestration loop: finalize failed for %s task %s: %v\", l.config.ProjectDir, tid, finalizeErr)\n\t\t\t\t\t\toverallState = domain.WorseState(overallState, domain.RunStateFailed)\n\t\t\t\t\t} else if finalizeResult != nil {\n\t\t\t\t\t\toverallState = domain.WorseState(overallState, finalizeResult.State)\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tcompletions <- result{state: overallState, errMsg: fmt.Sprintf(\"task %s failed\", tid)}\n\t\t\t}()\n\t\t}\n\n\t\tif inFlight == 0 {\n\t\t\t// Nothing in flight and couldn't launch anything ÔÇö wait before checking again.\n\t\t\tif !l.sleep(capacityPollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t// Wait for any run to complete.\n\t\tselect {\n\t\tcase r := <-completions:\n\t\t\tinFlight--\n\t\t\tif r.state == domain.RunStateSucceeded {\n\t\t\t\tl.resetConsecutiveFailures()\n\t\t\t\t// Work was done ÔÇö try to fill slots immediately.\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\t// Run failed or aborted.\n\t\t\tif l.config.StopOnError {\n\t\t\t\tl.halt(r.errMsg)\n\t\t\t}\n\t\t\tif l.recordConsecutiveFailure() {\n\t\t\t\tl.halt(fmt.Sprintf(\"halted after %d consecutive failures: %s\", l.config.MaxConsecutiveFailures, r.errMsg))\n\t\t\t}\n\t\t\t// Back off.\n\t\t\tif !l.sleep(idlePollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\tcase <-l.stopCh:\n\t\t\treturn\n\t\t}\n\t}\n}\n\n// GetTaskSnapshot returns the current task pipeline state: the most recently\n// fetched tasks with their assignment information.\nfunc (l *Loop) GetTaskSnapshot() []TaskStateEntry {\n\tl.tasksMu.RLock()\n\ttasks := make([]Task, len(l.lastTasks))\n\tcopy(tasks, l.lastTasks)\n\tl.tasksMu.RUnlock()\n\n\tl.dedupMu.Lock()\n\tdefer l.dedupMu.Unlock()\n\n\tnow := time.Now()\n\tvar entries []TaskStateEntry\n\tfor _, task := range tasks {\n\t\tentry := TaskStateEntry{Task: task}\n\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n\t\t\tentry.Assigned = true\n\t\t\tentry.AssignedAt = ts\n\t\t}\n\n\t\tl.tasksMu.RLock()\n\t\tif a, ok := l.taskRuns[task.ID]; ok {\n\t\t\tentry.RunID = a.RunID\n\t\t\tif !entry.Assigned {\n\t\t\t\tentry.AssignedAt = a.AssignedAt\n\t\t\t}\n\t\t}\n\t\tl.tasksMu.RUnlock()\n\n\t\tentries = append(entries, entry)\n\t}\n\treturn entries\n}\n\n// pickTaskFromPhase runs the list-tasks function and picks the first open,\n// non-deduped task. Returns the task ID, title, and whether a task was found.\nfunc (l *Loop) pickTaskFromPhase() (string, string, bool) {\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\ttasks, err := l.listTasks(ctx, l.config.ProjectDir)\n\tif err != nil {\n\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n\t\treturn \"\", \"\", false\n\t}\n\n\t// Cache the latest tasks for snapshot queries.\n\tl.tasksMu.Lock()\n\tl.lastTasks = tasks\n\tl.tasksMu.Unlock()\n\n\tnow := time.Now()\n\tl.dedupMu.Lock()\n\tdefer l.dedupMu.Unlock()\n\n\t// Expire old dedup entries.\n\tfor id, ts := range l.dedup {\n\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n\t\t\tdelete(l.dedup, id)\n\t\t}\n\t}\n\n\tfor _, task := range tasks {\n\t\tif task.ID == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif !task.IsOpen() {\n\t\t\tcontinue\n\t\t}\n\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n\t\t\tcontinue\n\t\t}\n\t\tl.dedup[task.ID] = now\n\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n\t\treturn task.ID, task.Title, true\n\t}\n\n\treturn \"\", \"\", false\n}\n\n// runLegacy implements the original single-function orchestration loop.\nfunc (l *Loop) runLegacy() {\n\ttype result struct {\n\t\tstate  domain.RunState\n\t\terrMsg string\n\t}\n\n\tcompletions := make(chan result, l.config.MaxConcurrent)\n\tinFlight := 0\n\n\tfor {\n\t\t// Fill up to max concurrent slots.\n\t\tlaunched := 0\n\t\tfor inFlight < l.config.MaxConcurrent {\n\t\t\tselect {\n\t\t\tcase <-l.stopCh:\n\t\t\t\treturn\n\t\t\tdefault:\n\t\t\t}\n\n\t\t\t// If halted, don't pick up new work.\n\t\t\tif l.isHalted() {\n\t\t\t\tbreak\n\t\t\t}\n\n\t\t\t// Check how many host runs are active for this project (in case of\n\t\t\t// leftover runs from previous loops).\n\t\t\tactive := l.countActiveHostRuns()\n\t\t\tif active >= l.config.MaxConcurrent {\n\t\t\t\tbreak\n\t\t\t}\n\n\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// Determine task ID (if task assigner is configured).\n\t\t\ttaskID := \"\"\n\t\t\tif l.assigner != nil {\n\t\t\t\tvar ok bool\n\t\t\t\ttaskID, ok = l.pickTask()\n\t\t\t\tif !ok {\n\t\t\t\t\t// No assignable tasks available.\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// Launch a new orchestration run in a goroutine.\n\t\t\tinFlight++\n\t\t\tlaunched++\n\t\t\ttid := taskID // capture for goroutine\n\t\t\tgo func() {\n\t\t\t\tres, err := l.runner(context.Background(), l.config.ProjectDir, tid)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlog.Printf(\"orchestration loop: run failed for %s: %v\", l.config.ProjectDir, err)\n\t\t\t\t\tcompletions <- result{state: domain.RunStateFailed, errMsg: err.Error()}\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t\tif res.State != domain.RunStateSucceeded {\n\t\t\t\t\tcompletions <- result{state: res.State, errMsg: \"run failed with state \" + string(res.State)}\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t\tcompletions <- result{state: res.State}\n\t\t\t}()\n\t\t}\n\n\t\tif inFlight == 0 {\n\t\t\t// Nothing in flight and at capacity ÔÇö wait before checking again.\n\t\t\tif !l.sleep(capacityPollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t// Wait for any run to complete.\n\t\tselect {\n\t\tcase r := <-completions:\n\t\t\tinFlight--\n\t\t\tif r.state == domain.RunStateSucceeded {\n\t\t\t\tl.resetConsecutiveFailures()\n\t\t\t\t// Work was done ÔÇö try to fill slots immediately.\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\t// Run failed or aborted (no tasks available).\n\t\t\tif l.config.StopOnError {\n\t\t\t\tl.halt(r.errMsg)\n\t\t\t}\n\t\t\tif l.recordConsecutiveFailure() {\n\t\t\t\tl.halt(fmt.Sprintf(\"halted after %d consecutive failures: %s\", l.config.MaxConsecutiveFailures, r.errMsg))\n\t\t\t}\n\t\t\t// Back off.\n\t\t\tif !l.sleep(idlePollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\tcase <-l.stopCh:\n\t\t\treturn\n\t\t}\n\t}\n}\n\n// pickTask queries the task assigner for available tasks, filters out those\n// within the dedup timeout window, and returns the first assignable task ID.\n// It records the assignment time so the same task won't be picked again until\n// the dedup timeout expires. Returns (\"\", false) if no tasks are available.\nfunc (l *Loop) pickTask() (string, bool) {\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\ttasks, err := l.assigner.ListTasks(ctx, l.config.ProjectDir)\n\tif err != nil {\n\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n\t\treturn \"\", false\n\t}\n\n\t// Cache the latest tasks for snapshot queries.\n\tl.tasksMu.Lock()\n\tl.lastTasks = tasks\n\tl.tasksMu.Unlock()\n\n\tnow := time.Now()\n\tl.dedupMu.Lock()\n\tdefer l.dedupMu.Unlock()\n\n\t// Expire old dedup entries while we're here.\n\tfor id, ts := range l.dedup {\n\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n\t\t\tdelete(l.dedup, id)\n\t\t}\n\t}\n\n\tfor _, task := range tasks {\n\t\tif task.ID == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n\t\t\tcontinue // still within dedup window\n\t\t}\n\t\t// Assign this task.\n\t\tl.dedup[task.ID] = now\n\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n\t\treturn task.ID, true\n\t}\n\n\treturn \"\", false\n}\n\n// countActiveHostRuns counts running or pending host runs for the project.\nfunc (l *Loop) countActiveHostRuns() int {\n\tctx := context.Background()\n\truns, err := l.store.ListRunsByProject(ctx, l.config.ProjectDir, time.Time{})\n\tif err != nil {\n\t\treturn 0\n\t}\n\tcount := 0\n\tfor _, r := range runs {\n\t\tif r.IsHost && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n\t\t\tcount++\n\t\t}\n\t}\n\treturn count\n}\n\n// sleep waits for the given duration or until the loop is stopped or resumed.\n// Returns false if the loop was stopped.\nfunc (l *Loop) sleep(d time.Duration) bool {\n\tselect {\n\tcase <-time.After(d):\n\t\treturn true\n\tcase <-l.resumeCh:\n\t\treturn true\n\tcase <-l.stopCh:\n\t\treturn false\n\t}\n}\n\n// ReadListTasksOutput reads the output directory from a list-tasks workflow run\n// and parses JSONL task output from the last step's output file.\nfunc ReadListTasksOutput(outputDir string) ([]Task, error) {\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading list-tasks output dir: %w\", err)\n\t}\n\n\t// Find the most recently modified .out file.\n\tvar latest string\n\tvar latestMod time.Time\n\tfor _, e := range entries {\n\t\tif e.IsDir() || filepath.Ext(e.Name()) != \".out\" {\n\t\t\tcontinue\n\t\t}\n\t\tinfo, err := e.Info()\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif latest == \"\" || info.ModTime().After(latestMod) {\n\t\t\tlatest = e.Name()\n\t\t\tlatestMod = info.ModTime()\n\t\t}\n\t}\n\n\tif latest == \"\" {\n\t\treturn nil, fmt.Errorf(\"no output files found in %s\", outputDir)\n\t}\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, latest))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading output file %s: %w\", latest, err)\n\t}\n\n\treturn ParseTasksJSONL(string(data))\n}\n","numLines":671,"startLine":1,"totalLines":671}}}
