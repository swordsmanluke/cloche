{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EMxQGLUcD3EZBTCcugPxJK","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"sync\"\n     7→\t\"sync/atomic\"\n     8→\t\"testing\"\n     9→\t\"time\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    12→\t\"github.com/stretchr/testify/assert\"\n    13→)\n    14→\n    15→func TestLoop_StartStop(t *testing.T) {\n    16→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    17→\tvar called atomic.Int32\n    18→\n    19→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    20→\t\tcalled.Add(1)\n    21→\t\t// Simulate a run that finds no work (failed = aborted).\n    22→\t\ttime.Sleep(50 * time.Millisecond)\n    23→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    24→\t}\n    25→\n    26→\tloop := NewLoop(LoopConfig{\n    27→\t\tProjectDir:    \"/tmp/test-project\",\n    28→\t\tMaxConcurrent: 1,\n    29→\t}, store, runFn)\n    30→\n    31→\tif loop.Running() {\n    32→\t\tt.Fatal(\"loop should not be running before Start\")\n    33→\t}\n    34→\n    35→\tloop.Start()\n    36→\tif !loop.Running() {\n    37→\t\tt.Fatal(\"loop should be running after Start\")\n    38→\t}\n    39→\n    40→\t// Wait enough time for at least one run to happen.\n    41→\ttime.Sleep(200 * time.Millisecond)\n    42→\tloop.Stop()\n    43→\n    44→\tif loop.Running() {\n    45→\t\tt.Fatal(\"loop should not be running after Stop\")\n    46→\t}\n    47→\n    48→\tif called.Load() < 1 {\n    49→\t\tt.Fatal(\"expected at least one run to be launched\")\n    50→\t}\n    51→}\n    52→\n    53→func TestLoop_RampsUpOnSuccess(t *testing.T) {\n    54→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    55→\tvar called atomic.Int32\n    56→\n    57→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    58→\t\tn := called.Add(1)\n    59→\t\ttime.Sleep(20 * time.Millisecond)\n    60→\t\t// First 3 succeed, then fail (no more work).\n    61→\t\tif n <= 3 {\n    62→\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n    63→\t\t}\n    64→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    65→\t}\n    66→\n    67→\tloop := NewLoop(LoopConfig{\n    68→\t\tProjectDir:    \"/tmp/test-project\",\n    69→\t\tMaxConcurrent: 1,\n    70→\t}, store, runFn)\n    71→\n    72→\tloop.Start()\n    73→\t// With no backoff between successes, 3 successful + 1 failed should happen fast.\n    74→\ttime.Sleep(300 * time.Millisecond)\n    75→\tloop.Stop()\n    76→\n    77→\tif called.Load() < 4 {\n    78→\t\tt.Fatalf(\"expected at least 4 runs, got %d\", called.Load())\n    79→\t}\n    80→}\n    81→\n    82→func TestLoop_DoubleStartIsNoop(t *testing.T) {\n    83→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    84→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    85→\t\ttime.Sleep(100 * time.Millisecond)\n    86→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    87→\t}\n    88→\n    89→\tloop := NewLoop(LoopConfig{\n    90→\t\tProjectDir:    \"/tmp/test-project\",\n    91→\t\tMaxConcurrent: 1,\n    92→\t}, store, runFn)\n    93→\n    94→\tloop.Start()\n    95→\tloop.Start() // Should be a no-op.\n    96→\tloop.Stop()\n    97→}\n    98→\n    99→// fakeTaskAssigner implements TaskAssigner for testing.\n   100→type fakeTaskAssigner struct {\n   101→\tmu    sync.Mutex\n   102→\ttasks []Task\n   103→\tcalls int\n   104→}\n   105→\n   106→func (f *fakeTaskAssigner) ListTasks(_ context.Context, _ string) ([]Task, error) {\n   107→\tf.mu.Lock()\n   108→\tdefer f.mu.Unlock()\n   109→\tf.calls++\n   110→\tresult := make([]Task, len(f.tasks))\n   111→\tcopy(result, f.tasks)\n   112→\treturn result, nil\n   113→}\n   114→\n   115→func TestLoop_TaskAssigner_PassesTaskID(t *testing.T) {\n   116→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   117→\n   118→\tassigner := &fakeTaskAssigner{\n   119→\t\ttasks: []Task{\n   120→\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n   121→\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n   122→\t\t},\n   123→\t}\n   124→\n   125→\tvar receivedTaskIDs []string\n   126→\tvar mu sync.Mutex\n   127→\n   128→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   129→\t\tmu.Lock()\n   130→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   131→\t\tmu.Unlock()\n   132→\t\ttime.Sleep(20 * time.Millisecond)\n   133→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   134→\t}\n   135→\n   136→\tloop := NewLoop(LoopConfig{\n   137→\t\tProjectDir:    \"/tmp/test-project\",\n   138→\t\tMaxConcurrent: 1,\n   139→\t\tDedupTimeout:  1 * time.Second,\n   140→\t}, store, runFn)\n   141→\tloop.SetTaskAssigner(assigner)\n   142→\n   143→\tloop.Start()\n   144→\ttime.Sleep(200 * time.Millisecond)\n   145→\tloop.Stop()\n   146→\n   147→\tmu.Lock()\n   148→\tdefer mu.Unlock()\n   149→\t// Should have received task-1 first, then task-2 (task-1 is deduped).\n   150→\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2)\n   151→\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   152→\tassert.Equal(t, \"task-2\", receivedTaskIDs[1])\n   153→}\n   154→\n   155→func TestLoop_TaskAssigner_DedupPreventsReassignment(t *testing.T) {\n   156→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   157→\n   158→\tassigner := &fakeTaskAssigner{\n   159→\t\ttasks: []Task{{ID: \"task-1\"}},\n   160→\t}\n   161→\n   162→\tvar receivedTaskIDs []string\n   163→\tvar mu sync.Mutex\n   164→\n   165→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   166→\t\tmu.Lock()\n   167→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   168→\t\tmu.Unlock()\n   169→\t\ttime.Sleep(20 * time.Millisecond)\n   170→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   171→\t}\n   172→\n   173→\tloop := NewLoop(LoopConfig{\n   174→\t\tProjectDir:    \"/tmp/test-project\",\n   175→\t\tMaxConcurrent: 1,\n   176→\t\tDedupTimeout:  2 * time.Second, // long enough that task-1 won't be reassigned during test\n   177→\t}, store, runFn)\n   178→\tloop.SetTaskAssigner(assigner)\n   179→\n   180→\tloop.Start()\n   181→\ttime.Sleep(200 * time.Millisecond)\n   182→\tloop.Stop()\n   183→\n   184→\tmu.Lock()\n   185→\tdefer mu.Unlock()\n   186→\t// Only one run should have been launched since task-1 is deduped after first assignment.\n   187→\tassert.Equal(t, 1, len(receivedTaskIDs))\n   188→\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   189→}\n   190→\n   191→func TestLoop_TaskAssigner_DedupExpires(t *testing.T) {\n   192→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   193→\n   194→\tassigner := &fakeTaskAssigner{\n   195→\t\ttasks: []Task{{ID: \"task-1\"}},\n   196→\t}\n   197→\n   198→\tvar receivedTaskIDs []string\n   199→\tvar mu sync.Mutex\n   200→\n   201→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   202→\t\tmu.Lock()\n   203→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   204→\t\tmu.Unlock()\n   205→\t\t// Run takes longer than dedup timeout, so by the time the run\n   206→\t\t// completes the dedup window has already expired and pickTask\n   207→\t\t// can re-assign immediately without hitting capacityPollInterval.\n   208→\t\ttime.Sleep(100 * time.Millisecond)\n   209→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   210→\t}\n   211→\n   212→\tloop := NewLoop(LoopConfig{\n   213→\t\tProjectDir:    \"/tmp/test-project\",\n   214→\t\tMaxConcurrent: 1,\n   215→\t\tDedupTimeout:  50 * time.Millisecond,\n   216→\t}, store, runFn)\n   217→\tloop.SetTaskAssigner(assigner)\n   218→\n   219→\tloop.Start()\n   220→\ttime.Sleep(500 * time.Millisecond)\n   221→\tloop.Stop()\n   222→\n   223→\tmu.Lock()\n   224→\tdefer mu.Unlock()\n   225→\t// With 50ms dedup and 100ms run time, dedup expires before run completes,\n   226→\t// so task-1 should be assigned multiple times.\n   227→\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2, \"dedup should have expired, allowing reassignment\")\n   228→\tfor _, id := range receivedTaskIDs {\n   229→\t\tassert.Equal(t, \"task-1\", id)\n   230→\t}\n   231→}\n   232→\n   233→func TestLoop_TaskAssigner_NoTasks_BacksOff(t *testing.T) {\n   234→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   235→\n   236→\tassigner := &fakeTaskAssigner{\n   237→\t\ttasks: nil, // no tasks available\n   238→\t}\n   239→\n   240→\tvar called atomic.Int32\n   241→\n   242→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   243→\t\tcalled.Add(1)\n   244→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   245→\t}\n   246→\n   247→\tloop := NewLoop(LoopConfig{\n   248→\t\tProjectDir:    \"/tmp/test-project\",\n   249→\t\tMaxConcurrent: 1,\n   250→\t}, store, runFn)\n   251→\tloop.SetTaskAssigner(assigner)\n   252→\n   253→\tloop.Start()\n   254→\ttime.Sleep(200 * time.Millisecond)\n   255→\tloop.Stop()\n   256→\n   257→\t// With no tasks, no runs should have been launched.\n   258→\tassert.Equal(t, int32(0), called.Load())\n   259→}\n   260→\n   261→func TestLoop_NoTaskAssigner_EmptyTaskID(t *testing.T) {\n   262→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   263→\n   264→\tvar receivedTaskID string\n   265→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   266→\t\treceivedTaskID = taskID\n   267→\t\ttime.Sleep(20 * time.Millisecond)\n   268→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   269→\t}\n   270→\n   271→\tloop := NewLoop(LoopConfig{\n   272→\t\tProjectDir:    \"/tmp/test-project\",\n   273→\t\tMaxConcurrent: 1,\n   274→\t}, store, runFn)\n   275→\t// No SetTaskAssigner call — backward compatible mode.\n   276→\n   277→\tloop.Start()\n   278→\ttime.Sleep(200 * time.Millisecond)\n   279→\tloop.Stop()\n   280→\n   281→\t// Without a task assigner, taskID should be empty.\n   282→\tassert.Empty(t, receivedTaskID)\n   283→}\n   284→\n   285→// --- Three-phase (NewPhaseLoop) tests ---\n   286→\n   287→func TestPhaseLoop_BasicFlow(t *testing.T) {\n   288→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   289→\n   290→\tvar mainCalls, finalizeCalls atomic.Int32\n   291→\tvar receivedTaskIDs []string\n   292→\tvar mu sync.Mutex\n   293→\n   294→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   295→\t\treturn []Task{\n   296→\t\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n   297→\t\t\t{ID: \"task-2\", Status: \"closed\", Title: \"Done task\"},\n   298→\t\t}, nil\n   299→\t}\n   300→\n   301→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   302→\t\tmainCalls.Add(1)\n   303→\t\tmu.Lock()\n   304→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   305→\t\tmu.Unlock()\n   306→\t\ttime.Sleep(20 * time.Millisecond)\n   307→\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n   308→\t}\n   309→\n   310→\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n   311→\t\tfinalizeCalls.Add(1)\n   312→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   313→\t}\n   314→\n   315→\tloop := NewPhaseLoop(LoopConfig{\n   316→\t\tProjectDir:    \"/tmp/test-project\",\n   317→\t\tMaxConcurrent: 1,\n   318→\t\tDedupTimeout:  2 * time.Second,\n   319→\t}, store, listTasksFn, mainFn, finalizeFn)\n   320→\n   321→\tloop.Start()\n   322→\ttime.Sleep(300 * time.Millisecond)\n   323→\tloop.Stop()\n   324→\n   325→\t// Should have picked task-1 (open) and skipped task-2 (closed).\n   326→\tmu.Lock()\n   327→\tdefer mu.Unlock()\n   328→\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n   329→\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   330→\n   331→\t// Finalize should have run for each main completion.\n   332→\tassert.Equal(t, mainCalls.Load(), finalizeCalls.Load())\n   333→}\n   334→\n   335→func TestPhaseLoop_SkipsClosedTasks(t *testing.T) {\n   336→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   337→\n   338→\tvar mainCalls atomic.Int32\n   339→\n   340→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   341→\t\treturn []Task{\n   342→\t\t\t{ID: \"task-1\", Status: \"closed\"},\n   343→\t\t\t{ID: \"task-2\", Status: \"in-progress\"},\n   344→\t\t}, nil\n   345→\t}\n   346→\n   347→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   348→\t\tmainCalls.Add(1)\n   349→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   350→\t}\n   351→\n   352→\tloop := NewPhaseLoop(LoopConfig{\n   353→\t\tProjectDir:    \"/tmp/test-project\",\n   354→\t\tMaxConcurrent: 1,\n   355→\t}, store, listTasksFn, mainFn, nil)\n   356→\n   357→\tloop.Start()\n   358→\ttime.Sleep(200 * time.Millisecond)\n   359→\tloop.Stop()\n   360→\n   361→\t// No open tasks → no main runs.\n   362→\tassert.Equal(t, int32(0), mainCalls.Load())\n   363→}\n   364→\n   365→func TestPhaseLoop_FinalizeRunsOnFailure(t *testing.T) {\n   366→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   367→\n   368→\tvar finalizeOutcome string\n   369→\tvar mu sync.Mutex\n   370→\n   371→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   372→\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n   373→\t}\n   374→\n   375→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   376→\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateFailed}, nil\n   377→\t}\n   378→\n   379→\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n   380→\t\tmu.Lock()\n   381→\t\tfinalizeOutcome = string(mainResult.State)\n   382→\t\tmu.Unlock()\n   383→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   384→\t}\n   385→\n   386→\tloop := NewPhaseLoop(LoopConfig{\n   387→\t\tProjectDir:    \"/tmp/test-project\",\n   388→\t\tMaxConcurrent: 1,\n   389→\t\tDedupTimeout:  2 * time.Second,\n   390→\t}, store, listTasksFn, mainFn, finalizeFn)\n   391→\n   392→\tloop.Start()\n   393→\ttime.Sleep(300 * time.Millisecond)\n   394→\tloop.Stop()\n   395→\n   396→\t// Finalize should have received the failed state.\n   397→\tmu.Lock()\n   398→\tdefer mu.Unlock()\n   399→\tassert.Equal(t, \"failed\", finalizeOutcome)\n   400→}\n   401→\n   402→func TestPhaseLoop_FinalizeFailureOverridesMainSuccess(t *testing.T) {\n   403→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   404→\n   405→\tvar completionStates []domain.RunState\n   406→\tvar mu sync.Mutex\n   407→\n   408→\tlistCallCount := 0\n   409→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   410→\t\tlistCallCount++\n   411→\t\tif listCallCount <= 1 {\n   412→\t\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n   413→\t\t}\n   414→\t\treturn nil, nil // no more tasks after first round\n   415→\t}\n   416→\n   417→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   418→\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n   419→\t}\n   420→\n   421→\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n   422→\t\t// Finalize fails (e.g., merge step failed).\n   423→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   424→\t}\n   425→\n   426→\tloop := NewPhaseLoop(LoopConfig{\n   427→\t\tProjectDir:    \"/tmp/test-project\",\n   428→\t\tMaxConcurrent: 1,\n   429→\t\tDedupTimeout:  2 * time.Second,\n   430→\t}, store, listTasksFn, mainFn, finalizeFn)\n   431→\n   432→\t// Intercept completions by observing backoff behavior:\n   433→\t// If finalize failure is correctly reported, the loop should back off\n   434→\t// (not immediately try to fill slots).\n   435→\tloop.Start()\n   436→\ttime.Sleep(300 * time.Millisecond)\n   437→\tloop.Stop()\n   438→\n   439→\t// Verify through a more direct test: run the phases manually and check\n   440→\t// that the overall state reflects the finalize failure.\n   441→\t_ = completionStates\n   442→\t_ = mu\n   443→\n   444→\t// The key assertion is that main succeeded but finalize failed,\n   445→\t// so WorseState(succeeded, failed) = failed.\n   446→\tgot := domain.WorseState(domain.RunStateSucceeded, domain.RunStateFailed)\n   447→\tassert.Equal(t, domain.RunStateFailed, got)\n   448→}\n   449→\n   450→func TestPhaseLoop_FinalizeErrorOverridesMainSuccess(t *testing.T) {\n   451→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   452→\n   453→\tvar mainCalls atomic.Int32\n   454→\n   455→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   456→\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n   457→\t}\n   458→\n   459→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   460→\t\tmainCalls.Add(1)\n   461→\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n   462→\t}\n   463→\n   464→\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n   465→\t\t// Finalize returns an error (infra failure).\n   466→\t\treturn nil, fmt.Errorf(\"finalize infra error\")\n   467→\t}\n   468→\n   469→\tloop := NewPhaseLoop(LoopConfig{\n   470→\t\tProjectDir:    \"/tmp/test-project\",\n   471→\t\tMaxConcurrent: 1,\n   472→\t\tDedupTimeout:  2 * time.Second,\n   473→\t}, store, listTasksFn, mainFn, finalizeFn)\n   474→\n   475→\tloop.Start()\n   476→\ttime.Sleep(300 * time.Millisecond)\n   477→\tloop.Stop()\n   478→\n   479→\t// Main should have run at least once.\n   480→\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n   481→}\n   482→\n   483→func TestPhaseLoop_NoFinalize(t *testing.T) {\n   484→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   485→\n   486→\tvar mainCalls atomic.Int32\n   487→\n   488→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   489→\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n   490→\t}\n   491→\n   492→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   493→\t\tmainCalls.Add(1)\n   494→\t\ttime.Sleep(20 * time.Millisecond)\n   495→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   496→\t}\n   497→\n   498→\t// nil finalize — should be skipped without error\n   499→\tloop := NewPhaseLoop(LoopConfig{\n   500→\t\tProjectDir:    \"/tmp/test-project\",\n   501→\t\tMaxConcurrent: 1,\n   502→\t\tDedupTimeout:  2 * time.Second,\n   503→\t}, store, listTasksFn, mainFn, nil)\n   504→\n   505→\tloop.Start()\n   506→\ttime.Sleep(200 * time.Millisecond)\n   507→\tloop.Stop()\n   508→\n   509→\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n   510→}\n   511→\n   512→func TestPhaseLoop_DedupFiltersOpenTasks(t *testing.T) {\n   513→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   514→\n   515→\tvar receivedTaskIDs []string\n   516→\tvar mu sync.Mutex\n   517→\n   518→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   519→\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n   520→\t}\n   521→\n   522→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   523→\t\tmu.Lock()\n   524→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   525→\t\tmu.Unlock()\n   526→\t\ttime.Sleep(20 * time.Millisecond)\n   527→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   528→\t}\n   529→\n   530→\tloop := NewPhaseLoop(LoopConfig{\n   531→\t\tProjectDir:    \"/tmp/test-project\",\n   532→\t\tMaxConcurrent: 1,\n   533→\t\tDedupTimeout:  2 * time.Second,\n   534→\t}, store, listTasksFn, mainFn, nil)\n   535→\n   536→\tloop.Start()\n   537→\ttime.Sleep(200 * time.Millisecond)\n   538→\tloop.Stop()\n   539→\n   540→\tmu.Lock()\n   541→\tdefer mu.Unlock()\n   542→\t// With 2s dedup, task-1 should only be assigned once.\n   543→\tassert.Equal(t, 1, len(receivedTaskIDs))\n   544→}\n   545→\n   546→// --- GetTaskSnapshot tests ---\n   547→\n   548→func TestLoop_GetTaskSnapshot_Empty(t *testing.T) {\n   549→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   550→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   551→\t\ttime.Sleep(100 * time.Millisecond)\n   552→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   553→\t}\n   554→\n   555→\tloop := NewLoop(LoopConfig{\n   556→\t\tProjectDir:    \"/tmp/test-project\",\n   557→\t\tMaxConcurrent: 1,\n   558→\t}, store, runFn)\n   559→\n   560→\tsnapshot := loop.GetTaskSnapshot()\n   561→\tassert.Empty(t, snapshot, \"snapshot should be empty when no tasks fetched\")\n   562→}\n   563→\n   564→func TestLoop_GetTaskSnapshot_ReturnsLastTasks(t *testing.T) {\n   565→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   566→\n   567→\ttasks := []Task{\n   568→\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n   569→\t\t{ID: \"task-2\", Status: \"closed\", Title: \"Done task\"},\n   570→\t\t{ID: \"task-3\", Status: \"open\", Title: \"Add feature\"},\n   571→\t}\n   572→\n   573→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   574→\t\treturn tasks, nil\n   575→\t}\n   576→\n   577→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   578→\t\ttime.Sleep(50 * time.Millisecond)\n   579→\t\treturn &RunResult{RunID: \"run-\" + taskID, State: domain.RunStateSucceeded}, nil\n   580→\t}\n   581→\n   582→\tloop := NewPhaseLoop(LoopConfig{\n   583→\t\tProjectDir:    \"/tmp/test-project\",\n   584→\t\tMaxConcurrent: 1,\n   585→\t\tDedupTimeout:  2 * time.Second,\n   586→\t}, store, listTasksFn, mainFn, nil)\n   587→\n   588→\tloop.Start()\n   589→\ttime.Sleep(300 * time.Millisecond)\n   590→\tloop.Stop()\n   591→\n   592→\tsnapshot := loop.GetTaskSnapshot()\n   593→\tassert.Len(t, snapshot, 3, \"should return all 3 tasks\")\n   594→\n   595→\t// task-1 should be assigned (it's open and was picked).\n   596→\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n   597→\tassert.True(t, snapshot[0].Assigned, \"task-1 should be assigned\")\n   598→\tassert.NotEmpty(t, snapshot[0].RunID, \"task-1 should have a run ID\")\n   599→\n   600→\t// task-2 is closed — should not be assigned.\n   601→\tassert.Equal(t, \"task-2\", snapshot[1].Task.ID)\n   602→\tassert.False(t, snapshot[1].Assigned, \"task-2 (closed) should not be assigned\")\n   603→\n   604→\t// task-3 should be assigned (it's open and would be picked after task-1).\n   605→\tassert.Equal(t, \"task-3\", snapshot[2].Task.ID)\n   606→\tassert.True(t, snapshot[2].Assigned, \"task-3 should be assigned\")\n   607→}\n   608→\n   609→func TestLoop_GetTaskSnapshot_LegacyWithAssigner(t *testing.T) {\n   610→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   611→\n   612→\tassigner := &fakeTaskAssigner{\n   613→\t\ttasks: []Task{\n   614→\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n   615→\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n   616→\t\t},\n   617→\t}\n   618→\n   619→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   620→\t\ttime.Sleep(20 * time.Millisecond)\n   621→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   622→\t}\n   623→\n   624→\tloop := NewLoop(LoopConfig{\n   625→\t\tProjectDir:    \"/tmp/test-project\",\n   626→\t\tMaxConcurrent: 1,\n   627→\t\tDedupTimeout:  2 * time.Second,\n   628→\t}, store, runFn)\n   629→\tloop.SetTaskAssigner(assigner)\n   630→\n   631→\tloop.Start()\n   632→\ttime.Sleep(200 * time.Millisecond)\n   633→\tloop.Stop()\n   634→\n   635→\tsnapshot := loop.GetTaskSnapshot()\n   636→\tassert.Len(t, snapshot, 2, \"should return tasks from assigner\")\n   637→\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n   638→\tassert.True(t, snapshot[0].Assigned, \"task-1 should be assigned\")\n   639→\tassert.Equal(t, \"task-2\", snapshot[1].Task.ID)\n   640→\tassert.True(t, snapshot[1].Assigned, \"task-2 should be assigned\")\n   641→}\n   642→\n   643→func TestLoop_GetTaskSnapshot_DedupExpired(t *testing.T) {\n   644→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   645→\n   646→\ttasks := []Task{\n   647→\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n   648→\t}\n   649→\n   650→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   651→\t\treturn tasks, nil\n   652→\t}\n   653→\n   654→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   655→\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n   656→\t}\n   657→\n   658→\tloop := NewPhaseLoop(LoopConfig{\n   659→\t\tProjectDir:    \"/tmp/test-project\",\n   660→\t\tMaxConcurrent: 1,\n   661→\t\tDedupTimeout:  10 * time.Millisecond, // very short dedup\n   662→\t}, store, listTasksFn, mainFn, nil)\n   663→\n   664→\tloop.Start()\n   665→\ttime.Sleep(200 * time.Millisecond)\n   666→\tloop.Stop()\n   667→\n   668→\tsnapshot := loop.GetTaskSnapshot()\n   669→\tassert.Len(t, snapshot, 1)\n   670→\t// After dedup expires, the task should show as unassigned in the snapshot\n   671→\t// (the dedup check in GetTaskSnapshot uses current time).\n   672→\t// But the run ID may still be recorded from a previous assignment.\n   673→\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n   674→}\n   675→\n   676→// --- StopOnError tests ---\n   677→\n   678→func TestLoop_StopOnError_HaltsOnFailure(t *testing.T) {\n   679→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   680→\tvar called atomic.Int32\n   681→\n   682→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   683→\t\tn := called.Add(1)\n   684→\t\ttime.Sleep(20 * time.Millisecond)\n   685→\t\tif n == 1 {\n   686→\t\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   687→\t\t}\n   688→\t\t// Subsequent calls should not happen while halted.\n   689→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   690→\t}\n   691→\n   692→\tloop := NewLoop(LoopConfig{\n   693→\t\tProjectDir:    \"/tmp/test-project\",\n   694→\t\tMaxConcurrent: 1,\n   695→\t\tStopOnError:   true,\n   696→\t}, store, runFn)\n   697→\n   698→\tloop.Start()\n   699→\t// Wait for the first run to fail and halt.\n   700→\ttime.Sleep(300 * time.Millisecond)\n   701→\n   702→\thalted, haltErr := loop.Halted()\n   703→\tassert.True(t, halted, \"loop should be halted after failure\")\n   704→\tassert.NotEmpty(t, haltErr, \"halt error should be set\")\n   705→\tassert.True(t, loop.Running(), \"loop should still be running (not stopped)\")\n   706→\n   707→\t// Only 1 run should have been launched since the loop halts after.\n   708→\tassert.Equal(t, int32(1), called.Load(), \"only one run should have been launched before halt\")\n   709→\n   710→\tloop.Stop()\n   711→}\n   712→\n   713→func TestLoop_StopOnError_ResumeAllowsNewWork(t *testing.T) {\n   714→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   715→\tvar called atomic.Int32\n   716→\tvar resumeReady atomic.Bool\n   717→\n   718→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   719→\t\tn := called.Add(1)\n   720→\t\ttime.Sleep(20 * time.Millisecond)\n   721→\t\tif n == 1 {\n   722→\t\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   723→\t\t}\n   724→\t\tresumeReady.Store(true)\n   725→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   726→\t}\n   727→\n   728→\tloop := NewLoop(LoopConfig{\n   729→\t\tProjectDir:    \"/tmp/test-project\",\n   730→\t\tMaxConcurrent: 1,\n   731→\t\tStopOnError:   true,\n   732→\t}, store, runFn)\n   733→\n   734→\tloop.Start()\n   735→\t// Wait for the first run to fail and halt.\n   736→\ttime.Sleep(300 * time.Millisecond)\n   737→\n   738→\thalted, _ := loop.Halted()\n   739→\tassert.True(t, halted, \"loop should be halted after failure\")\n   740→\tassert.Equal(t, int32(1), called.Load())\n   741→\n   742→\t// Resume the loop.\n   743→\tloop.Resume()\n   744→\n   745→\thalted, _ = loop.Halted()\n   746→\tassert.False(t, halted, \"loop should no longer be halted after resume\")\n   747→\n   748→\t// Resume() signals the loop to wake from its sleep, so new work should\n   749→\t// be picked up quickly.\n   750→\tdeadline := time.After(2 * time.Second)\n   751→\tfor !resumeReady.Load() {\n   752→\t\tselect {\n   753→\t\tcase <-deadline:\n   754→\t\t\tt.Fatal(\"timed out waiting for resumed run\")\n   755→\t\tcase <-time.After(50 * time.Millisecond):\n   756→\t\t}\n   757→\t}\n   758→\tloop.Stop()\n   759→\n   760→\t// After resume, at least one more run should have been launched.\n   761→\tassert.GreaterOrEqual(t, called.Load(), int32(2), \"resume should allow new runs\")\n   762→}\n   763→\n   764→func TestLoop_StopOnError_Disabled_ContinuesOnFailure(t *testing.T) {\n   765→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   766→\tvar called atomic.Int32\n   767→\n   768→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   769→\t\tcalled.Add(1)\n   770→\t\ttime.Sleep(20 * time.Millisecond)\n   771→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   772→\t}\n   773→\n   774→\tloop := NewLoop(LoopConfig{\n   775→\t\tProjectDir:    \"/tmp/test-project\",\n   776→\t\tMaxConcurrent: 1,\n   777→\t\tStopOnError:   false, // disabled\n   778→\t}, store, runFn)\n   779→\n   780→\tloop.Start()\n   781→\t// After first failure, loop backs off for idlePollInterval (2 min), so\n   782→\t// we can't easily wait for multiple runs. Instead, verify state after\n   783→\t// the first run: loop should not be halted and should still be running.\n   784→\ttime.Sleep(300 * time.Millisecond)\n   785→\tloop.Stop()\n   786→\n   787→\thalted, _ := loop.Halted()\n   788→\tassert.False(t, halted, \"loop should not be halted when stop_on_error is disabled\")\n   789→\tassert.GreaterOrEqual(t, called.Load(), int32(1), \"at least one run should have been launched\")\n   790→}\n   791→\n   792→func TestPhaseLoop_StopOnError_HaltsOnFailure(t *testing.T) {\n   793→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   794→\tvar mainCalls atomic.Int32\n   795→\n   796→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   797→\t\treturn []Task{\n   798→\t\t\t{ID: \"task-1\", Status: \"open\"},\n   799→\t\t\t{ID: \"task-2\", Status: \"open\"},\n   800→\t\t}, nil\n   801→\t}\n   802→\n   803→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   804→\t\tmainCalls.Add(1)\n   805→\t\ttime.Sleep(20 * time.Millisecond)\n   806→\t\treturn &RunResult{RunID: \"run-\" + taskID, State: domain.RunStateFailed}, nil\n   807→\t}\n   808→\n   809→\tloop := NewPhaseLoop(LoopConfig{\n   810→\t\tProjectDir:    \"/tmp/test-project\",\n   811→\t\tMaxConcurrent: 1,\n   812→\t\tDedupTimeout:  2 * time.Second,\n   813→\t\tStopOnError:   true,\n   814→\t}, store, listTasksFn, mainFn, nil)\n   815→\n   816→\tloop.Start()\n   817→\ttime.Sleep(300 * time.Millisecond)\n   818→\n   819→\thalted, haltErr := loop.Halted()\n   820→\tassert.True(t, halted, \"phased loop should be halted after failure\")\n   821→\tassert.Contains(t, haltErr, \"task-1\", \"halt error should reference the failed task\")\n   822→\n   823→\t// Only task-1 should have been attempted.\n   824→\tassert.Equal(t, int32(1), mainCalls.Load())\n   825→\n   826→\tloop.Stop()\n   827→}\n   828→\n   829→// --- MaxConsecutiveFailures tests ---\n   830→\n   831→func TestLoop_ConsecutiveFailures_RecordAndReset(t *testing.T) {\n   832→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   833→\tloop := NewLoop(LoopConfig{\n   834→\t\tProjectDir:             \"/tmp/test-project\",\n   835→\t\tMaxConcurrent:          1,\n   836→\t\tMaxConsecutiveFailures: 3,\n   837→\t}, store, func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   838→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   839→\t})\n   840→\n   841→\t// Below threshold — not halted.\n   842→\tassert.False(t, loop.recordConsecutiveFailure())\n   843→\tassert.False(t, loop.recordConsecutiveFailure())\n   844→\n   845→\t// Third failure reaches threshold.\n   846→\tassert.True(t, loop.recordConsecutiveFailure())\n   847→\n   848→\t// Reset clears the counter.\n   849→\tloop.resetConsecutiveFailures()\n   850→\tassert.False(t, loop.recordConsecutiveFailure()) // back to 1\n   851→}\n   852→\n   853→func TestLoop_ConsecutiveFailures_HaltsLoopOnThreshold(t *testing.T) {\n   854→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   855→\tvar called atomic.Int32\n   856→\n   857→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   858→\t\tn := called.Add(1)\n   859→\t\ttime.Sleep(20 * time.Millisecond)\n   860→\t\tif n == 1 {\n   861→\t\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   862→\t\t}\n   863→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   864→\t}\n   865→\n   866→\t// With MaxConsecutiveFailures=1, behaves like stop_on_error.\n   867→\tloop := NewLoop(LoopConfig{\n   868→\t\tProjectDir:             \"/tmp/test-project\",\n   869→\t\tMaxConcurrent:          1,\n   870→\t\tMaxConsecutiveFailures: 1,\n   871→\t}, store, runFn)\n   872→\n   873→\tloop.Start()\n   874→\ttime.Sleep(300 * time.Millisecond)\n   875→\n   876→\thalted, haltErr := loop.Halted()\n   877→\tassert.True(t, halted, \"loop should be halted after 1 consecutive failure\")\n   878→\tassert.Contains(t, haltErr, \"consecutive failures\")\n   879→\tassert.Equal(t, int32(1), called.Load())\n   880→\n   881→\tloop.Stop()\n   882→}\n   883→\n   884→func TestLoop_ConsecutiveFailures_ResumeResetsCounter(t *testing.T) {\n   885→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   886→\tvar called atomic.Int32\n   887→\n   888→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   889→\t\tcalled.Add(1)\n   890→\t\ttime.Sleep(20 * time.Millisecond)\n   891→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   892→\t}\n   893→\n   894→\tloop := NewLoop(LoopConfig{\n   895→\t\tProjectDir:             \"/tmp/test-project\",\n   896→\t\tMaxConcurrent:          1,\n   897→\t\tMaxConsecutiveFailures: 1,\n   898→\t}, store, runFn)\n   899→\n   900→\tloop.Start()\n   901→\ttime.Sleep(300 * time.Millisecond)\n   902→\n   903→\thalted, _ := loop.Halted()\n   904→\tassert.True(t, halted, \"loop should halt after 1 consecutive failure\")\n   905→\tassert.Equal(t, int32(1), called.Load())\n   906→\n   907→\t// Resume clears the counter so it takes another failure to halt.\n   908→\tloop.Resume()\n   909→\ttime.Sleep(300 * time.Millisecond)\n   910→\n   911→\thalted, _ = loop.Halted()\n   912→\tassert.True(t, halted, \"loop should halt again after resume\")\n   913→\tassert.Equal(t, int32(2), called.Load())\n   914→\n   915→\tloop.Stop()\n   916→}\n   917→\n   918→func TestLoop_ConsecutiveFailures_DefaultThreshold(t *testing.T) {\n   919→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   920→\n   921→\t// MaxConsecutiveFailures=0 should default to 3.\n   922→\tloop := NewLoop(LoopConfig{\n   923→\t\tProjectDir:             \"/tmp/test-project\",\n   924→\t\tMaxConcurrent:          1,\n   925→\t\tMaxConsecutiveFailures: 0,\n   926→\t}, store, func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   927→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   928→\t})\n   929→\n   930→\tassert.Equal(t, defaultMaxConsecutiveFailures, loop.config.MaxConsecutiveFailures)\n   931→}\n   932→\n   933→func TestLoop_ConsecutiveFailures_SuccessResetsInLoop(t *testing.T) {\n   934→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   935→\tvar called atomic.Int32\n   936→\n   937→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   938→\t\tn := called.Add(1)\n   939→\t\ttime.Sleep(20 * time.Millisecond)\n   940→\t\t// First succeeds (resets counter), second fails and halts (threshold=1).\n   941→\t\tif n == 1 {\n   942→\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   943→\t\t}\n   944→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   945→\t}\n   946→\n   947→\tloop := NewLoop(LoopConfig{\n   948→\t\tProjectDir:             \"/tmp/test-project\",\n   949→\t\tMaxConcurrent:          1,\n   950→\t\tMaxConsecutiveFailures: 1,\n   951→\t}, store, runFn)\n   952→\n   953→\tloop.Start()\n   954→\ttime.Sleep(300 * time.Millisecond)\n   955→\n   956→\thalted, _ := loop.Halted()\n   957→\tassert.True(t, halted, \"loop should halt on second run (first failure after success)\")\n   958→\tassert.Equal(t, int32(2), called.Load(), \"two runs: one success, one failure\")\n   959→\n   960→\tloop.Stop()\n   961→}\n   962→\n   963→func TestPhaseLoop_ConsecutiveFailures_HaltsAfterThreshold(t *testing.T) {\n   964→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   965→\tvar mainCalls atomic.Int32\n   966→\n   967→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   968→\t\treturn []Task{{ID: fmt.Sprintf(\"task-%d\", mainCalls.Load()+1), Status: \"open\"}}, nil\n   969→\t}\n   970→\n   971→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   972→\t\tmainCalls.Add(1)\n   973→\t\ttime.Sleep(20 * time.Millisecond)\n   974→\t\treturn &RunResult{RunID: \"run-\" + taskID, State: domain.RunStateFailed}, nil\n   975→\t}\n   976→\n   977→\tloop := NewPhaseLoop(LoopConfig{\n   978→\t\tProjectDir:             \"/tmp/test-project\",\n   979→\t\tMaxConcurrent:          1,\n   980→\t\tDedupTimeout:           50 * time.Millisecond,\n   981→\t\tMaxConsecutiveFailures: 1,\n   982→\t}, store, listTasksFn, mainFn, nil)\n   983→\n   984→\tloop.Start()\n   985→\ttime.Sleep(300 * time.Millisecond)\n   986→\n   987→\thalted, haltErr := loop.Halted()\n   988→\tassert.True(t, halted, \"phased loop should be halted after consecutive failures\")\n   989→\tassert.Contains(t, haltErr, \"consecutive failures\")\n   990→\tassert.Equal(t, int32(1), mainCalls.Load())\n   991→\n   992→\tloop.Stop()\n   993→}\n   994→\n   995→func TestLoop_Halted_DefaultFalse(t *testing.T) {\n   996→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   997→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   998→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   999→\t}\n  1000→\n  1001→\tloop := NewLoop(LoopConfig{\n  1002→\t\tProjectDir:    \"/tmp/test-project\",\n  1003→\t\tMaxConcurrent: 1,\n  1004→\t}, store, runFn)\n  1005→\n  1006→\thalted, haltErr := loop.Halted()\n  1007→\tassert.False(t, halted)\n  1008→\tassert.Empty(t, haltErr)\n  1009→}\n  1010→\n  1011→func TestLoop_Resume_NopWhenNotHalted(t *testing.T) {\n  1012→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n  1013→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n  1014→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n  1015→\t}\n  1016→\n  1017→\tloop := NewLoop(LoopConfig{\n  1018→\t\tProjectDir:    \"/tmp/test-project\",\n  1019→\t\tMaxConcurrent: 1,\n  1020→\t}, store, runFn)\n  1021→\n  1022→\t// Resume when not halted should be a no-op (no panic).\n  1023→\tloop.Resume()\n  1024→\thalted, _ := loop.Halted()\n  1025→\tassert.False(t, halted)\n  1026→}\n  1027→"}]},"parent_tool_use_id":null,"session_id":"29313778-dd33-4042-9e1f-2e370226ac12","uuid":"4c28fe7c-542c-4ffd-91f9-a3ccbfd2118b","timestamp":"2026-03-18T16:15:36.275Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/loop_test.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\t\"sync/atomic\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/stretchr/testify/assert\"\n)\n\nfunc TestLoop_StartStop(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tcalled.Add(1)\n\t\t// Simulate a run that finds no work (failed = aborted).\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\tif loop.Running() {\n\t\tt.Fatal(\"loop should not be running before Start\")\n\t}\n\n\tloop.Start()\n\tif !loop.Running() {\n\t\tt.Fatal(\"loop should be running after Start\")\n\t}\n\n\t// Wait enough time for at least one run to happen.\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tif loop.Running() {\n\t\tt.Fatal(\"loop should not be running after Stop\")\n\t}\n\n\tif called.Load() < 1 {\n\t\tt.Fatal(\"expected at least one run to be launched\")\n\t}\n}\n\nfunc TestLoop_RampsUpOnSuccess(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tn := called.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\t// First 3 succeed, then fail (no more work).\n\t\tif n <= 3 {\n\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t\t}\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\t// With no backoff between successes, 3 successful + 1 failed should happen fast.\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\tif called.Load() < 4 {\n\t\tt.Fatalf(\"expected at least 4 runs, got %d\", called.Load())\n\t}\n}\n\nfunc TestLoop_DoubleStartIsNoop(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\tloop.Start() // Should be a no-op.\n\tloop.Stop()\n}\n\n// fakeTaskAssigner implements TaskAssigner for testing.\ntype fakeTaskAssigner struct {\n\tmu    sync.Mutex\n\ttasks []Task\n\tcalls int\n}\n\nfunc (f *fakeTaskAssigner) ListTasks(_ context.Context, _ string) ([]Task, error) {\n\tf.mu.Lock()\n\tdefer f.mu.Unlock()\n\tf.calls++\n\tresult := make([]Task, len(f.tasks))\n\tcopy(result, f.tasks)\n\treturn result, nil\n}\n\nfunc TestLoop_TaskAssigner_PassesTaskID(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tassigner := &fakeTaskAssigner{\n\t\ttasks: []Task{\n\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n\t\t},\n\t}\n\n\tvar receivedTaskIDs []string\n\tvar mu sync.Mutex\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmu.Lock()\n\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n\t\tmu.Unlock()\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  1 * time.Second,\n\t}, store, runFn)\n\tloop.SetTaskAssigner(assigner)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tmu.Lock()\n\tdefer mu.Unlock()\n\t// Should have received task-1 first, then task-2 (task-1 is deduped).\n\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2)\n\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n\tassert.Equal(t, \"task-2\", receivedTaskIDs[1])\n}\n\nfunc TestLoop_TaskAssigner_DedupPreventsReassignment(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tassigner := &fakeTaskAssigner{\n\t\ttasks: []Task{{ID: \"task-1\"}},\n\t}\n\n\tvar receivedTaskIDs []string\n\tvar mu sync.Mutex\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmu.Lock()\n\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n\t\tmu.Unlock()\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second, // long enough that task-1 won't be reassigned during test\n\t}, store, runFn)\n\tloop.SetTaskAssigner(assigner)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tmu.Lock()\n\tdefer mu.Unlock()\n\t// Only one run should have been launched since task-1 is deduped after first assignment.\n\tassert.Equal(t, 1, len(receivedTaskIDs))\n\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n}\n\nfunc TestLoop_TaskAssigner_DedupExpires(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tassigner := &fakeTaskAssigner{\n\t\ttasks: []Task{{ID: \"task-1\"}},\n\t}\n\n\tvar receivedTaskIDs []string\n\tvar mu sync.Mutex\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmu.Lock()\n\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n\t\tmu.Unlock()\n\t\t// Run takes longer than dedup timeout, so by the time the run\n\t\t// completes the dedup window has already expired and pickTask\n\t\t// can re-assign immediately without hitting capacityPollInterval.\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  50 * time.Millisecond,\n\t}, store, runFn)\n\tloop.SetTaskAssigner(assigner)\n\n\tloop.Start()\n\ttime.Sleep(500 * time.Millisecond)\n\tloop.Stop()\n\n\tmu.Lock()\n\tdefer mu.Unlock()\n\t// With 50ms dedup and 100ms run time, dedup expires before run completes,\n\t// so task-1 should be assigned multiple times.\n\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2, \"dedup should have expired, allowing reassignment\")\n\tfor _, id := range receivedTaskIDs {\n\t\tassert.Equal(t, \"task-1\", id)\n\t}\n}\n\nfunc TestLoop_TaskAssigner_NoTasks_BacksOff(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tassigner := &fakeTaskAssigner{\n\t\ttasks: nil, // no tasks available\n\t}\n\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tcalled.Add(1)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\tloop.SetTaskAssigner(assigner)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\t// With no tasks, no runs should have been launched.\n\tassert.Equal(t, int32(0), called.Load())\n}\n\nfunc TestLoop_NoTaskAssigner_EmptyTaskID(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar receivedTaskID string\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treceivedTaskID = taskID\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\t// No SetTaskAssigner call — backward compatible mode.\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\t// Without a task assigner, taskID should be empty.\n\tassert.Empty(t, receivedTaskID)\n}\n\n// --- Three-phase (NewPhaseLoop) tests ---\n\nfunc TestPhaseLoop_BasicFlow(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar mainCalls, finalizeCalls atomic.Int32\n\tvar receivedTaskIDs []string\n\tvar mu sync.Mutex\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{\n\t\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n\t\t\t{ID: \"task-2\", Status: \"closed\", Title: \"Done task\"},\n\t\t}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\tmu.Lock()\n\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n\t\tmu.Unlock()\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n\t}\n\n\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n\t\tfinalizeCalls.Add(1)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, finalizeFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\t// Should have picked task-1 (open) and skipped task-2 (closed).\n\tmu.Lock()\n\tdefer mu.Unlock()\n\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n\n\t// Finalize should have run for each main completion.\n\tassert.Equal(t, mainCalls.Load(), finalizeCalls.Load())\n}\n\nfunc TestPhaseLoop_SkipsClosedTasks(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar mainCalls atomic.Int32\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{\n\t\t\t{ID: \"task-1\", Status: \"closed\"},\n\t\t\t{ID: \"task-2\", Status: \"in-progress\"},\n\t\t}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\t// No open tasks → no main runs.\n\tassert.Equal(t, int32(0), mainCalls.Load())\n}\n\nfunc TestPhaseLoop_FinalizeRunsOnFailure(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar finalizeOutcome string\n\tvar mu sync.Mutex\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateFailed}, nil\n\t}\n\n\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n\t\tmu.Lock()\n\t\tfinalizeOutcome = string(mainResult.State)\n\t\tmu.Unlock()\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, finalizeFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\t// Finalize should have received the failed state.\n\tmu.Lock()\n\tdefer mu.Unlock()\n\tassert.Equal(t, \"failed\", finalizeOutcome)\n}\n\nfunc TestPhaseLoop_FinalizeFailureOverridesMainSuccess(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar completionStates []domain.RunState\n\tvar mu sync.Mutex\n\n\tlistCallCount := 0\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\tlistCallCount++\n\t\tif listCallCount <= 1 {\n\t\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n\t\t}\n\t\treturn nil, nil // no more tasks after first round\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n\t}\n\n\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n\t\t// Finalize fails (e.g., merge step failed).\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, finalizeFn)\n\n\t// Intercept completions by observing backoff behavior:\n\t// If finalize failure is correctly reported, the loop should back off\n\t// (not immediately try to fill slots).\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\t// Verify through a more direct test: run the phases manually and check\n\t// that the overall state reflects the finalize failure.\n\t_ = completionStates\n\t_ = mu\n\n\t// The key assertion is that main succeeded but finalize failed,\n\t// so WorseState(succeeded, failed) = failed.\n\tgot := domain.WorseState(domain.RunStateSucceeded, domain.RunStateFailed)\n\tassert.Equal(t, domain.RunStateFailed, got)\n}\n\nfunc TestPhaseLoop_FinalizeErrorOverridesMainSuccess(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar mainCalls atomic.Int32\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n\t}\n\n\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n\t\t// Finalize returns an error (infra failure).\n\t\treturn nil, fmt.Errorf(\"finalize infra error\")\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, finalizeFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\t// Main should have run at least once.\n\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n}\n\nfunc TestPhaseLoop_NoFinalize(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar mainCalls atomic.Int32\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\t// nil finalize — should be skipped without error\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n}\n\nfunc TestPhaseLoop_DedupFiltersOpenTasks(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar receivedTaskIDs []string\n\tvar mu sync.Mutex\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmu.Lock()\n\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n\t\tmu.Unlock()\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tmu.Lock()\n\tdefer mu.Unlock()\n\t// With 2s dedup, task-1 should only be assigned once.\n\tassert.Equal(t, 1, len(receivedTaskIDs))\n}\n\n// --- GetTaskSnapshot tests ---\n\nfunc TestLoop_GetTaskSnapshot_Empty(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\tsnapshot := loop.GetTaskSnapshot()\n\tassert.Empty(t, snapshot, \"snapshot should be empty when no tasks fetched\")\n}\n\nfunc TestLoop_GetTaskSnapshot_ReturnsLastTasks(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\ttasks := []Task{\n\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n\t\t{ID: \"task-2\", Status: \"closed\", Title: \"Done task\"},\n\t\t{ID: \"task-3\", Status: \"open\", Title: \"Add feature\"},\n\t}\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn tasks, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\treturn &RunResult{RunID: \"run-\" + taskID, State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\tsnapshot := loop.GetTaskSnapshot()\n\tassert.Len(t, snapshot, 3, \"should return all 3 tasks\")\n\n\t// task-1 should be assigned (it's open and was picked).\n\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n\tassert.True(t, snapshot[0].Assigned, \"task-1 should be assigned\")\n\tassert.NotEmpty(t, snapshot[0].RunID, \"task-1 should have a run ID\")\n\n\t// task-2 is closed — should not be assigned.\n\tassert.Equal(t, \"task-2\", snapshot[1].Task.ID)\n\tassert.False(t, snapshot[1].Assigned, \"task-2 (closed) should not be assigned\")\n\n\t// task-3 should be assigned (it's open and would be picked after task-1).\n\tassert.Equal(t, \"task-3\", snapshot[2].Task.ID)\n\tassert.True(t, snapshot[2].Assigned, \"task-3 should be assigned\")\n}\n\nfunc TestLoop_GetTaskSnapshot_LegacyWithAssigner(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tassigner := &fakeTaskAssigner{\n\t\ttasks: []Task{\n\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n\t\t},\n\t}\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, runFn)\n\tloop.SetTaskAssigner(assigner)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tsnapshot := loop.GetTaskSnapshot()\n\tassert.Len(t, snapshot, 2, \"should return tasks from assigner\")\n\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n\tassert.True(t, snapshot[0].Assigned, \"task-1 should be assigned\")\n\tassert.Equal(t, \"task-2\", snapshot[1].Task.ID)\n\tassert.True(t, snapshot[1].Assigned, \"task-2 should be assigned\")\n}\n\nfunc TestLoop_GetTaskSnapshot_DedupExpired(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\ttasks := []Task{\n\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n\t}\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn tasks, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  10 * time.Millisecond, // very short dedup\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tsnapshot := loop.GetTaskSnapshot()\n\tassert.Len(t, snapshot, 1)\n\t// After dedup expires, the task should show as unassigned in the snapshot\n\t// (the dedup check in GetTaskSnapshot uses current time).\n\t// But the run ID may still be recorded from a previous assignment.\n\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n}\n\n// --- StopOnError tests ---\n\nfunc TestLoop_StopOnError_HaltsOnFailure(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tn := called.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\tif n == 1 {\n\t\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t\t}\n\t\t// Subsequent calls should not happen while halted.\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tStopOnError:   true,\n\t}, store, runFn)\n\n\tloop.Start()\n\t// Wait for the first run to fail and halt.\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, haltErr := loop.Halted()\n\tassert.True(t, halted, \"loop should be halted after failure\")\n\tassert.NotEmpty(t, haltErr, \"halt error should be set\")\n\tassert.True(t, loop.Running(), \"loop should still be running (not stopped)\")\n\n\t// Only 1 run should have been launched since the loop halts after.\n\tassert.Equal(t, int32(1), called.Load(), \"only one run should have been launched before halt\")\n\n\tloop.Stop()\n}\n\nfunc TestLoop_StopOnError_ResumeAllowsNewWork(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\tvar resumeReady atomic.Bool\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tn := called.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\tif n == 1 {\n\t\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t\t}\n\t\tresumeReady.Store(true)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tStopOnError:   true,\n\t}, store, runFn)\n\n\tloop.Start()\n\t// Wait for the first run to fail and halt.\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, _ := loop.Halted()\n\tassert.True(t, halted, \"loop should be halted after failure\")\n\tassert.Equal(t, int32(1), called.Load())\n\n\t// Resume the loop.\n\tloop.Resume()\n\n\thalted, _ = loop.Halted()\n\tassert.False(t, halted, \"loop should no longer be halted after resume\")\n\n\t// Resume() signals the loop to wake from its sleep, so new work should\n\t// be picked up quickly.\n\tdeadline := time.After(2 * time.Second)\n\tfor !resumeReady.Load() {\n\t\tselect {\n\t\tcase <-deadline:\n\t\t\tt.Fatal(\"timed out waiting for resumed run\")\n\t\tcase <-time.After(50 * time.Millisecond):\n\t\t}\n\t}\n\tloop.Stop()\n\n\t// After resume, at least one more run should have been launched.\n\tassert.GreaterOrEqual(t, called.Load(), int32(2), \"resume should allow new runs\")\n}\n\nfunc TestLoop_StopOnError_Disabled_ContinuesOnFailure(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tcalled.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tStopOnError:   false, // disabled\n\t}, store, runFn)\n\n\tloop.Start()\n\t// After first failure, loop backs off for idlePollInterval (2 min), so\n\t// we can't easily wait for multiple runs. Instead, verify state after\n\t// the first run: loop should not be halted and should still be running.\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\thalted, _ := loop.Halted()\n\tassert.False(t, halted, \"loop should not be halted when stop_on_error is disabled\")\n\tassert.GreaterOrEqual(t, called.Load(), int32(1), \"at least one run should have been launched\")\n}\n\nfunc TestPhaseLoop_StopOnError_HaltsOnFailure(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar mainCalls atomic.Int32\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{\n\t\t\t{ID: \"task-1\", Status: \"open\"},\n\t\t\t{ID: \"task-2\", Status: \"open\"},\n\t\t}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{RunID: \"run-\" + taskID, State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t\tStopOnError:   true,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, haltErr := loop.Halted()\n\tassert.True(t, halted, \"phased loop should be halted after failure\")\n\tassert.Contains(t, haltErr, \"task-1\", \"halt error should reference the failed task\")\n\n\t// Only task-1 should have been attempted.\n\tassert.Equal(t, int32(1), mainCalls.Load())\n\n\tloop.Stop()\n}\n\n// --- MaxConsecutiveFailures tests ---\n\nfunc TestLoop_ConsecutiveFailures_RecordAndReset(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 3,\n\t}, store, func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t})\n\n\t// Below threshold — not halted.\n\tassert.False(t, loop.recordConsecutiveFailure())\n\tassert.False(t, loop.recordConsecutiveFailure())\n\n\t// Third failure reaches threshold.\n\tassert.True(t, loop.recordConsecutiveFailure())\n\n\t// Reset clears the counter.\n\tloop.resetConsecutiveFailures()\n\tassert.False(t, loop.recordConsecutiveFailure()) // back to 1\n}\n\nfunc TestLoop_ConsecutiveFailures_HaltsLoopOnThreshold(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tn := called.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\tif n == 1 {\n\t\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t\t}\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\t// With MaxConsecutiveFailures=1, behaves like stop_on_error.\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, haltErr := loop.Halted()\n\tassert.True(t, halted, \"loop should be halted after 1 consecutive failure\")\n\tassert.Contains(t, haltErr, \"consecutive failures\")\n\tassert.Equal(t, int32(1), called.Load())\n\n\tloop.Stop()\n}\n\nfunc TestLoop_ConsecutiveFailures_ResumeResetsCounter(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tcalled.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, _ := loop.Halted()\n\tassert.True(t, halted, \"loop should halt after 1 consecutive failure\")\n\tassert.Equal(t, int32(1), called.Load())\n\n\t// Resume clears the counter so it takes another failure to halt.\n\tloop.Resume()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, _ = loop.Halted()\n\tassert.True(t, halted, \"loop should halt again after resume\")\n\tassert.Equal(t, int32(2), called.Load())\n\n\tloop.Stop()\n}\n\nfunc TestLoop_ConsecutiveFailures_DefaultThreshold(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\t// MaxConsecutiveFailures=0 should default to 3.\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 0,\n\t}, store, func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t})\n\n\tassert.Equal(t, defaultMaxConsecutiveFailures, loop.config.MaxConsecutiveFailures)\n}\n\nfunc TestLoop_ConsecutiveFailures_SuccessResetsInLoop(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tn := called.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\t// First succeeds (resets counter), second fails and halts (threshold=1).\n\t\tif n == 1 {\n\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t\t}\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, _ := loop.Halted()\n\tassert.True(t, halted, \"loop should halt on second run (first failure after success)\")\n\tassert.Equal(t, int32(2), called.Load(), \"two runs: one success, one failure\")\n\n\tloop.Stop()\n}\n\nfunc TestPhaseLoop_ConsecutiveFailures_HaltsAfterThreshold(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar mainCalls atomic.Int32\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{{ID: fmt.Sprintf(\"task-%d\", mainCalls.Load()+1), Status: \"open\"}}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{RunID: \"run-\" + taskID, State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tDedupTimeout:           50 * time.Millisecond,\n\t\tMaxConsecutiveFailures: 1,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, haltErr := loop.Halted()\n\tassert.True(t, halted, \"phased loop should be halted after consecutive failures\")\n\tassert.Contains(t, haltErr, \"consecutive failures\")\n\tassert.Equal(t, int32(1), mainCalls.Load())\n\n\tloop.Stop()\n}\n\nfunc TestLoop_Halted_DefaultFalse(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\thalted, haltErr := loop.Halted()\n\tassert.False(t, halted)\n\tassert.Empty(t, haltErr)\n}\n\nfunc TestLoop_Resume_NopWhenNotHalted(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\t// Resume when not halted should be a no-op (no panic).\n\tloop.Resume()\n\thalted, _ := loop.Halted()\n\tassert.False(t, halted)\n}\n","numLines":1027,"startLine":1,"totalLines":1027}}}
