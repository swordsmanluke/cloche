er.agent_command\"]; cmd != \"\" {\n    57→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    58→\t}\n    59→\tif args := wf.Config[\"container.agent_args\"]; args != \"\" {\n    60→\t\tpromptAdapter.ExplicitArgs = strings.Fields(args)\n    61→\t}\n    62→\n    63→\t// Reset per-run state from any previous run\n    64→\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"attempt_count\"))\n    65→\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"output\"))\n    66→\n    67→\t// Create unified log writer\n    68→\tulog, err := logstream.New(r.cfg.WorkDir)\n    69→\tif err != nil {\n    70→\t\treturn fmt.Errorf(\"creating unified log: %w\", err)\n    71→\t}\n    72→\tdefer ulog.Close()\n    73→\n    74→\texecutor := &stepExecutor{\n    75→\t\tworkDir:   r.cfg.WorkDir,\n    76→\t\tgeneric:   genericAdapter,\n    77→\t\tprompt:    promptAdapter,\n    78→\t\tlogStream: ulog,\n    79→\t}\n    80→\n    81→\teng := engine.New(executor)\n    82→\teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n    83→\n    84→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n    85→\n    86→\trun, runErr := eng.Run(ctx, wf)\n    87→\tif runErr != nil {\n    88→\t\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:failed\")\n    89→\t\tulog.Log(logstream.TypeStatus, \"error: \"+runErr.Error())\n    90→\t\tulog.Log(logstream.TypeStatus, \"run_completed: failed\")\n    91→\t\tstatusWriter.Error(\"\", runErr.Error())\n    92→\t\tstatusWriter.RunCompleted(\"failed\")\n    93→\t\treturn runErr\n    94→\t}\n    95→\n    96→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:\"+string(run.State))\n    97→\n    98→\tulog.Log(logstream.TypeStatus, \"run_completed: \"+string(run.State))\n    99→\tstatusWriter.RunCompleted(string(run.State))\n   100→\treturn nil\n   101→}\n   102→\n   103→type stepExecutor struct {\n   104→\tworkDir   string\n   105→\tgeneric