 struct {\n\tCommand string\n\tArgs    []string // per-command args from bracket syntax; nil means use profile defaults\n}\n\nvar builtinProfiles = map[string]AgentProfile{\n\t\"claude\": {\n\t\tCommand: \"claude\",\n\t\tArgs:    []string{\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n\t},\n\t\"gemini\": {\n\t\tCommand: \"gemini\",\n\t\tArgs:    []string{\"-p\"},\n\t},\n\t\"codex\": {\n\t\tCommand: \"codex\",\n\t\tArgs:    []string{\"-p\"},\n\t},\n}\n\n// LookupProfile returns the profile for a known agent, or nil if unknown.\nfunc LookupProfile(command string) *AgentProfile {\n\tif p, ok := builtinProfiles[command]; ok {\n\t\treturn &p\n\t}\n\treturn nil\n}\n","numLines":38,"startLine":1,"totalLines":38}}}
