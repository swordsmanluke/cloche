{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U1DQMocvjJ9wCyf9TYhoyE","type":"tool_result","content":"     1→package prompt\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"bytes\"\n     6→\t\"context\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strconv\"\n    13→\t\"strings\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17→)\n    18→\n    19→type Adapter struct {\n    20→\tCommands     []CommandSpec // ordered fallback chain of agent commands\n    21→\tExplicitArgs []string      // if non-nil, overrides default args for all commands\n    22→\tRunID        string\n    23→\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n    24→}\n    25→\n    26→func New() *Adapter {\n    27→\treturn &Adapter{\n    28→\t\tCommands: []CommandSpec{{Command: \"claude\"}},\n    29→\t}\n    30→}\n    31→\n    32→func (a *Adapter) Name() string {\n    33→\treturn \"prompt\"\n    34→}\n    35→\n    36→// argsFor returns the arguments for the given command spec. If ExplicitArgs is\n    37→// set, it overrides everything. Otherwise, per-command args from bracket syntax\n    38→// are used. If neither is set, profile defaults are consulted.\n    39→func (a *Adapter) argsFor(spec CommandSpec) []string {\n    40→\tif a.ExplicitArgs != nil {\n    41→\t\treturn a.ExplicitArgs\n    42→\t}\n    43→\tif spec.Args != nil {\n    44→\t\treturn spec.Args\n    45→\t}\n    46→\tif p := LookupProfile(spec.Command); p != nil {\n    47→\t\treturn p.Args\n    48→\t}\n    49→\treturn nil\n    50→}\n    51→\n    52→// ParseCommands splits a comma-separated agent_command string into CommandSpecs.\n    53→// Supports optional per-command args via bracket syntax: \"claude, gemini[--model gemini-2.5-pro], codex\"\n    54→func ParseCommands(s string) []CommandSpec {\n    55→\tparts := strings.Split(s, \",\")\n    56→\tvar cmds []CommandSpec\n    57→\tfor _, p := range parts {\n    58→\t\tp = strings.TrimSpace(p)\n    59→\t\tif p == \"\" {\n    60→\t\t\tcontinue\n    61→\t\t}\n    62→\t\tspec := CommandSpec{}\n    63→\t\tif idx := strings.IndexByte(p, '['); idx >= 0 {\n    64→\t\t\tend := strings.LastIndexByte(p, ']')\n    65→\t\t\tif end > idx {\n    66→\t\t\t\tspec.Command = strings.TrimSpace(p[:idx])\n    67→\t\t\t\targsStr := strings.TrimSpace(p[idx+1 : end])\n    68→\t\t\t\tif argsStr != \"\" {\n    69→\t\t\t\t\tspec.Args = strings.Fields(argsStr)\n    70→\t\t\t\t}\n    71→\t\t\t} else {\n    72→\t\t\t\tspec.Command = p\n    73→\t\t\t}\n    74→\t\t} else {\n    75→\t\t\tspec.Command = p\n    76→\t\t}\n    77→\t\tif spec.Command != \"\" {\n    78→\t\t\tcmds = append(cmds, spec)\n    79→\t\t}\n    80→\t}\n    81→\treturn cmds\n    82→}\n    83→\n    84→func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    85→\t// Check attempt count for retry limiting\n    86→\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n    87→\t\tmax, err := strconv.Atoi(maxStr)\n    88→\t\tif err == nil {\n    89→\t\t\tcount := readAttemptCount(workDir, step.Name)\n    90→\t\t\tif count >= max {\n    91→\t\t\t\treturn \"give-up\", nil\n    92→\t\t\t}\n    93→\t\t}\n    94→\t}\n    95→\tincrementAttemptCount(workDir, step.Name)\n    96→\n    97→\t// Build the full prompt\n    98→\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n    99→\tif err != nil {\n   100→\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n   101→\t}\n   102→\n   103→\t// Try each command in the fallback chain\n   104→\tvar lastResult string\n   105→\tvar lastStdout []byte\n   106→\tvar lastErr error\n   107→\tran := false\n   108→\n   109→\tfor _, spec := range a.Commands {\n   110→\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, spec, fullPrompt, workDir, step.Name)\n   111→\t\tlastResult = result\n   112→\t\tlastStdout = stdout\n   113→\t\tlastErr = fallbackErr\n   114→\n   115→\t\tif fallbackErr == nil {\n   116→\t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n   117→\t\t\tbreak\n   118→\t\t}\n   119→\t\tif stdout != nil {\n   120→\t\t\tran = true\n   121→\t\t}\n   122→\t\t// Fallback-eligible — try next command\n   123→\t}\n   124→\n   125→\tif lastErr != nil && !ran && lastStdout == nil {\n   126→\t\t// All commands failed to produce any output (e.g., all not found)\n   127→\t\treturn \"\", lastErr\n   128→\t}\n   129→\n   130→\tresult := lastResult\n   131→\tif lastErr != nil {\n   132→\t\t// Last command in chain crashed without a result marker\n   133→\t\tresult = \"fail\"\n   134→\t}\n   135→\n   136→\t// Write output file\n   137→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   138→\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n   139→\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n   140→\t}\n   141→\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n   142→\treturn result, nil\n   143→}\n   144→\n   145→// tryCommand executes a single agent command and returns:\n   146→//   - result: the step result name (e.g. \"success\", \"fail\")\n   147→//   - stdout: captured stdout bytes\n   148→//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n   149→//\n   150→// Fallback-eligible conditions:\n   151→//   - Command not found or failed to start (stdout will be nil)\n   152→//   - Command exited non-zero without a CLOCHE_RESULT marker\n   153→//\n   154→// Definitive (non-fallback) conditions:\n   155→//   - Command exited 0\n   156→//   - Command exited non-zero but produced a CLOCHE_RESULT marker\n   157→func (a *Adapter) tryCommand(ctx context.Context, spec CommandSpec, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n   158→\tcommand := spec.Command\n   159→\targs := a.argsFor(spec)\n   160→\tcmd := exec.CommandContext(ctx, command, args...)\n   161→\tcmd.Dir = workDir\n   162→\tcmd.Stdin = strings.NewReader(prompt)\n   163→\n   164→\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n   165→\tif a.StatusWriter == nil {\n   166→\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n   167→\t\tcmd.Stdout = &stdoutBuf\n   168→\t\tcmd.Stderr = &stderrBuf\n   169→\n   170→\t\trunErr := cmd.Run()\n   171→\t\tstdoutBytes := stdoutBuf.Bytes()\n   172→\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n   173→\t}\n   174→\n   175→\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n   176→\tpipe, err := cmd.StdoutPipe()\n   177→\tif err != nil {\n   178→\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n   179→\t}\n   180→\tcmd.Stderr = nil // discard stderr\n   181→\n   182→\tif err := cmd.Start(); err != nil {\n   183→\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n   184→\t}\n   185→\n   186→\t// textBuf accumulates extracted text content for result extraction.\n   187→\t// rawBuf accumulates raw stdout for the output log file.\n   188→\tvar textBuf, rawBuf bytes.Buffer\n   189→\t// lineBuf accumulates text deltas into lines for streaming.\n   190→\tvar lineBuf strings.Builder\n   191→\n   192→\tscanner := bufio.NewScanner(pipe)\n   193→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n   194→\tfor scanner.Scan() {\n   195→\t\traw := scanner.Bytes()\n   196→\t\trawBuf.Write(raw)\n   197→\t\trawBuf.WriteByte('\\n')\n   198→\n   199→\t\ttext := extractStreamText(raw)\n   200→\t\tif text == \"\" {\n   201→\t\t\tcontinue\n   202→\t\t}\n   203→\t\ttextBuf.WriteString(text)\n   204→\n   205→\t\t// Stream complete lines to StatusWriter as they form.\n   206→\t\tlineBuf.WriteString(text)\n   207→\t\tfor {\n   208→\t\t\ts := lineBuf.String()\n   209→\t\t\tidx := strings.IndexByte(s, '\\n')\n   210→\t\t\tif idx < 0 {\n   211→\t\t\t\tbreak\n   212→\t\t\t}\n   213→\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n   214→\t\t\tlineBuf.Reset()\n   215→\t\t\tlineBuf.WriteString(s[idx+1:])\n   216→\t\t}\n   217→\t}\n   218→\t// Flush any remaining partial line.\n   219→\tif lineBuf.Len() > 0 {\n   220→\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n   221→\t}\n   222→\tif scanErr := scanner.Err(); scanErr != nil {\n   223→\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n   224→\t}\n   225→\n   226→\twaitErr := cmd.Wait()\n   227→\t// Prefer extracted text (stream-json) for result classification; fall back\n   228→\t// to raw output for non-JSON commands (scripts, non-claude agents).\n   229→\tclassifyBuf := textBuf.Bytes()\n   230→\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n   231→\t\tclassifyBuf = rawBuf.Bytes()\n   232→\t}\n   233→\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n   234→\treturn result, rawBuf.Bytes(), fallbackErr\n   235→}\n   236→\n   237→// classifyResult interprets the command's exit status and stdout to determine\n   238→// the step result.\n   239→func (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n   240→\tif runErr != nil {\n   241→\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n   242→\t\t\t// Command failed to start (not found, permission denied, etc.)\n   243→\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n   244→\t\t}\n   245→\t\t// Command ran but exited non-zero\n   246→\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   247→\t\tif found {\n   248→\t\t\treturn markerResult, stdoutBytes, nil\n   249→\t\t}\n   250→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n   251→\t}\n   252→\n   253→\t// Command succeeded (exit 0)\n   254→\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n   255→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n   256→\t}\n   257→\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   258→\tresult := \"success\"\n   259→\tif found {\n   260→\t\tresult = markerResult\n   261→\t}\n   262→\treturn result, stdoutBytes, nil\n   263→}\n   264→\n   265→// extractStreamText parses a stream-json line and returns text content.\n   266→// It handles both content_block_delta (text_delta) events for streaming and\n   267→// result events for final output (which contains the CLOCHE_RESULT marker).\n   268→func extractStreamText(line []byte) string {\n   269→\t// Fast path: only parse lines that could contain text we care about.\n   270→\tif bytes.Contains(line, []byte(`\"text_delta\"`)) {\n   271→\t\tvar event struct {\n   272→\t\t\tType  string `json:\"type\"`\n   273→\t\t\tDelta struct {\n   274→\t\t\t\tType string `json:\"type\"`\n   275→\t\t\t\tText string `json:\"text\"`\n   276→\t\t\t} `json:\"delta\"`\n   277→\t\t}\n   278→\t\tif json.Unmarshal(line, &event) == nil &&\n   279→\t\t\tevent.Type == \"content_block_delta\" && event.Delta.Type == \"text_delta\" {\n   280→\t\t\treturn event.Delta.Text\n   281→\t\t}\n   282→\t}\n   283→\n   284→\t// Also extract the final result text (contains CLOCHE_RESULT marker).\n   285→\tif bytes.Contains(line, []byte(`\"result\"`)) && bytes.Contains(line, []byte(`\"subtype\"`)) {\n   286→\t\tvar event struct {\n   287→\t\t\tType   string `json:\"type\"`\n   288→\t\t\tResult string `json:\"result\"`\n   289→\t\t}\n   290→\t\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n   291→\t\t\treturn event.Result\n   292→\t\t}\n   293→\t}\n   294→\n   295→\treturn \"\"\n   296→}\n   297→\n   298→func assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n   299→\tvar parts []string\n   300→\n   301→\t// 1. Read system template from step config\n   302→\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n   303→\t\tcontent, err := resolveContent(tmpl, workDir)\n   304→\t\tif err != nil {\n   305→\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n   306→\t\t}\n   307→\t\tparts = append(parts, content)\n   308→\t}\n   309→\n   310→\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n   311→\tuserPrompt := readUserPrompt(workDir, runID)\n   312→\tif userPrompt != \"\" {\n   313→\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n   314→\t}\n   315→\n   316→\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n   317→\tif step.Config[\"feedback\"] == \"true\" {\n   318→\t\tfeedback := readFeedback(workDir)\n   319→\t\tif feedback != \"\" {\n   320→\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n   321→\t\t}\n   322→\t}\n   323→\n   324→\t// 4. Result selection instructions\n   325→\tif len(step.Results) > 0 {\n   326→\t\tvar resultLines []string\n   327→\t\tresultLines = append(resultLines, \"## Result Selection\")\n   328→\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n   329→\t\tfor _, r := range step.Results {\n   330→\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n   331→\t\t}\n   332→\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n   333→\t}\n   334→\n   335→\treturn strings.Join(parts, \"\\n\\n\"), nil\n   336→}\n   337→\n   338→// resolveContent handles file(\"path\") syntax or returns the string directly.\n   339→func resolveContent(value string, workDir string) (string, error) {\n   340→\t// Check for file(\"path\") syntax from DSL parser\n   341→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n   342→\t\tpath := value[6 : len(value)-2]\n   343→\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n   344→\t\tif err != nil {\n   345→\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n   346→\t\t}\n   347→\t\treturn string(data), nil\n   348→\t}\n   349→\treturn value, nil\n   350→}\n   351→\n   352→func readFeedback(workDir string) string {\n   353→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   354→\tentries, err := os.ReadDir(outputDir)\n   355→\tif err != nil {\n   356→\t\treturn \"\"\n   357→\t}\n   358→\n   359→\tvar parts []string\n   360→\tfor _, entry := range entries {\n   361→\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n   362→\t\t\tcontinue\n   363→\t\t}\n   364→\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n   365→\t\tif err != nil {\n   366→\t\t\tcontinue\n   367→\t\t}\n   368→\t\tcontent := strings.TrimSpace(string(data))\n   369→\t\tif content != \"\" {\n   370→\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n   371→\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n   372→\t\t}\n   373→\t}\n   374→\n   375→\treturn strings.Join(parts, \"\\n\\n\")\n   376→}\n   377→\n   378→func readAttemptCount(workDir, stepName string) int {\n   379→\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n   380→\tdata, err := os.ReadFile(path)\n   381→\tif err != nil {\n   382→\t\treturn 0\n   383→\t}\n   384→\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n   385→\treturn n\n   386→}\n   387→\n   388→// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\n   389→func readUserPrompt(workDir, runID string) string {\n   390→\tif runID == \"\" {\n   391→\t\treturn \"\"\n   392→\t}\n   393→\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   394→\tif data, err := os.ReadFile(path); err == nil {\n   395→\t\treturn string(data)\n   396→\t}\n   397→\treturn \"\"\n   398→}\n   399→\n   400→func incrementAttemptCount(workDir, stepName string) {\n   401→\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n   402→\t_ = os.MkdirAll(dir, 0755)\n   403→\tcount := readAttemptCount(workDir, stepName) + 1\n   404→\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n   405→}\n   406→"}]},"parent_tool_use_id":null,"session_id":"6bed6ee7-8ce9-41cc-ac67-7640c415ebf5","uuid":"0f2d1913-6306-40de-aa8c-ddcd8c333b2d","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/agents/prompt/prompt.go","content":"package prompt\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\ntype Adapter struct {\n\tCommands     []CommandSpec // ordered fallback chain of agent commands\n\tExplicitArgs []string      // if non-nil, overrides default args for all commands\n\tRunID        string\n\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n}\n\nfunc New() *Adapter {\n\treturn &Adapter{\n\t\tCommands: []CommandSpec{{Command: \"claude\"}},\n\t}\n}\n\nfunc (a *Adapter) Name() string {\n\treturn \"prompt\"\n}\n\n// argsFor returns the arguments for the given command spec. If ExplicitArgs is\n// set, it overrides everything. Otherwise, per-command args from bracket syntax\n// are used. If neither is set, profile defaults are consulted.\nfunc (a *Adapter) argsFor(spec CommandSpec) []string {\n\tif a.ExplicitArgs != nil {\n\t\treturn a.ExplicitArgs\n\t}\n\tif spec.Args != nil {\n\t\treturn spec.Args\n\t}\n\tif p := LookupProfile(spec.Command); p != nil {\n\t\treturn p.Args\n\t}\n\treturn nil\n}\n\n// ParseCommands splits a comma-separated agent_command string into CommandSpecs.\n// Supports optional per-command args via bracket syntax: \"claude, gemini[--model gemini-2.5-pro], codex\"\nfunc ParseCommands(s string) []CommandSpec {\n\tparts := strings.Split(s, \",\")\n\tvar cmds []CommandSpec\n\tfor _, p := range parts {\n\t\tp = strings.TrimSpace(p)\n\t\tif p == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tspec := CommandSpec{}\n\t\tif idx := strings.IndexByte(p, '['); idx >= 0 {\n\t\t\tend := strings.LastIndexByte(p, ']')\n\t\t\tif end > idx {\n\t\t\t\tspec.Command = strings.TrimSpace(p[:idx])\n\t\t\t\targsStr := strings.TrimSpace(p[idx+1 : end])\n\t\t\t\tif argsStr != \"\" {\n\t\t\t\t\tspec.Args = strings.Fields(argsStr)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tspec.Command = p\n\t\t\t}\n\t\t} else {\n\t\t\tspec.Command = p\n\t\t}\n\t\tif spec.Command != \"\" {\n\t\t\tcmds = append(cmds, spec)\n\t\t}\n\t}\n\treturn cmds\n}\n\nfunc (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n\t// Check attempt count for retry limiting\n\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n\t\tmax, err := strconv.Atoi(maxStr)\n\t\tif err == nil {\n\t\t\tcount := readAttemptCount(workDir, step.Name)\n\t\t\tif count >= max {\n\t\t\t\treturn \"give-up\", nil\n\t\t\t}\n\t\t}\n\t}\n\tincrementAttemptCount(workDir, step.Name)\n\n\t// Build the full prompt\n\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n\t}\n\n\t// Try each command in the fallback chain\n\tvar lastResult string\n\tvar lastStdout []byte\n\tvar lastErr error\n\tran := false\n\n\tfor _, spec := range a.Commands {\n\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, spec, fullPrompt, workDir, step.Name)\n\t\tlastResult = result\n\t\tlastStdout = stdout\n\t\tlastErr = fallbackErr\n\n\t\tif fallbackErr == nil {\n\t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n\t\t\tbreak\n\t\t}\n\t\tif stdout != nil {\n\t\t\tran = true\n\t\t}\n\t\t// Fallback-eligible — try next command\n\t}\n\n\tif lastErr != nil && !ran && lastStdout == nil {\n\t\t// All commands failed to produce any output (e.g., all not found)\n\t\treturn \"\", lastErr\n\t}\n\n\tresult := lastResult\n\tif lastErr != nil {\n\t\t// Last command in chain crashed without a result marker\n\t\tresult = \"fail\"\n\t}\n\n\t// Write output file\n\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n\t}\n\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n\treturn result, nil\n}\n\n// tryCommand executes a single agent command and returns:\n//   - result: the step result name (e.g. \"success\", \"fail\")\n//   - stdout: captured stdout bytes\n//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n//\n// Fallback-eligible conditions:\n//   - Command not found or failed to start (stdout will be nil)\n//   - Command exited non-zero without a CLOCHE_RESULT marker\n//\n// Definitive (non-fallback) conditions:\n//   - Command exited 0\n//   - Command exited non-zero but produced a CLOCHE_RESULT marker\nfunc (a *Adapter) tryCommand(ctx context.Context, spec CommandSpec, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n\tcommand := spec.Command\n\targs := a.argsFor(spec)\n\tcmd := exec.CommandContext(ctx, command, args...)\n\tcmd.Dir = workDir\n\tcmd.Stdin = strings.NewReader(prompt)\n\n\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n\tif a.StatusWriter == nil {\n\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n\t\tcmd.Stdout = &stdoutBuf\n\t\tcmd.Stderr = &stderrBuf\n\n\t\trunErr := cmd.Run()\n\t\tstdoutBytes := stdoutBuf.Bytes()\n\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n\t}\n\n\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n\tpipe, err := cmd.StdoutPipe()\n\tif err != nil {\n\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n\t}\n\tcmd.Stderr = nil // discard stderr\n\n\tif err := cmd.Start(); err != nil {\n\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n\t}\n\n\t// textBuf accumulates extracted text content for result extraction.\n\t// rawBuf accumulates raw stdout for the output log file.\n\tvar textBuf, rawBuf bytes.Buffer\n\t// lineBuf accumulates text deltas into lines for streaming.\n\tvar lineBuf strings.Builder\n\n\tscanner := bufio.NewScanner(pipe)\n\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n\tfor scanner.Scan() {\n\t\traw := scanner.Bytes()\n\t\trawBuf.Write(raw)\n\t\trawBuf.WriteByte('\\n')\n\n\t\ttext := extractStreamText(raw)\n\t\tif text == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\ttextBuf.WriteString(text)\n\n\t\t// Stream complete lines to StatusWriter as they form.\n\t\tlineBuf.WriteString(text)\n\t\tfor {\n\t\t\ts := lineBuf.String()\n\t\t\tidx := strings.IndexByte(s, '\\n')\n\t\t\tif idx < 0 {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n\t\t\tlineBuf.Reset()\n\t\t\tlineBuf.WriteString(s[idx+1:])\n\t\t}\n\t}\n\t// Flush any remaining partial line.\n\tif lineBuf.Len() > 0 {\n\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n\t}\n\tif scanErr := scanner.Err(); scanErr != nil {\n\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n\t}\n\n\twaitErr := cmd.Wait()\n\t// Prefer extracted text (stream-json) for result classification; fall back\n\t// to raw output for non-JSON commands (scripts, non-claude agents).\n\tclassifyBuf := textBuf.Bytes()\n\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n\t\tclassifyBuf = rawBuf.Bytes()\n\t}\n\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n\treturn result, rawBuf.Bytes(), fallbackErr\n}\n\n// classifyResult interprets the command's exit status and stdout to determine\n// the step result.\nfunc (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n\tif runErr != nil {\n\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n\t\t\t// Command failed to start (not found, permission denied, etc.)\n\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n\t\t}\n\t\t// Command ran but exited non-zero\n\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n\t\tif found {\n\t\t\treturn markerResult, stdoutBytes, nil\n\t\t}\n\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n\t}\n\n\t// Command succeeded (exit 0)\n\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n\t}\n\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, stdoutBytes, nil\n}\n\n// extractStreamText parses a stream-json line and returns text content.\n// It handles both content_block_delta (text_delta) events for streaming and\n// result events for final output (which contains the CLOCHE_RESULT marker).\nfunc extractStreamText(line []byte) string {\n\t// Fast path: only parse lines that could contain text we care about.\n\tif bytes.Contains(line, []byte(`\"text_delta\"`)) {\n\t\tvar event struct {\n\t\t\tType  string `json:\"type\"`\n\t\t\tDelta struct {\n\t\t\t\tType string `json:\"type\"`\n\t\t\t\tText string `json:\"text\"`\n\t\t\t} `json:\"delta\"`\n\t\t}\n\t\tif json.Unmarshal(line, &event) == nil &&\n\t\t\tevent.Type == \"content_block_delta\" && event.Delta.Type == \"text_delta\" {\n\t\t\treturn event.Delta.Text\n\t\t}\n\t}\n\n\t// Also extract the final result text (contains CLOCHE_RESULT marker).\n\tif bytes.Contains(line, []byte(`\"result\"`)) && bytes.Contains(line, []byte(`\"subtype\"`)) {\n\t\tvar event struct {\n\t\t\tType   string `json:\"type\"`\n\t\t\tResult string `json:\"result\"`\n\t\t}\n\t\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n\t\t\treturn event.Result\n\t\t}\n\t}\n\n\treturn \"\"\n}\n\nfunc assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n\tvar parts []string\n\n\t// 1. Read system template from step config\n\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n\t\tcontent, err := resolveContent(tmpl, workDir)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n\t\t}\n\t\tparts = append(parts, content)\n\t}\n\n\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n\tuserPrompt := readUserPrompt(workDir, runID)\n\tif userPrompt != \"\" {\n\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n\t}\n\n\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n\tif step.Config[\"feedback\"] == \"true\" {\n\t\tfeedback := readFeedback(workDir)\n\t\tif feedback != \"\" {\n\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n\t\t}\n\t}\n\n\t// 4. Result selection instructions\n\tif len(step.Results) > 0 {\n\t\tvar resultLines []string\n\t\tresultLines = append(resultLines, \"## Result Selection\")\n\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n\t\tfor _, r := range step.Results {\n\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n\t\t}\n\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n\t}\n\n\treturn strings.Join(parts, \"\\n\\n\"), nil\n}\n\n// resolveContent handles file(\"path\") syntax or returns the string directly.\nfunc resolveContent(value string, workDir string) (string, error) {\n\t// Check for file(\"path\") syntax from DSL parser\n\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n\t\tpath := value[6 : len(value)-2]\n\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n\t\t}\n\t\treturn string(data), nil\n\t}\n\treturn value, nil\n}\n\nfunc readFeedback(workDir string) string {\n\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\n\tvar parts []string\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tcontent := strings.TrimSpace(string(data))\n\t\tif content != \"\" {\n\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n\t\t}\n\t}\n\n\treturn strings.Join(parts, \"\\n\\n\")\n}\n\nfunc readAttemptCount(workDir, stepName string) int {\n\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n\tdata, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn 0\n\t}\n\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n\treturn n\n}\n\n// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\nfunc readUserPrompt(workDir, runID string) string {\n\tif runID == \"\" {\n\t\treturn \"\"\n\t}\n\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n\tif data, err := os.ReadFile(path); err == nil {\n\t\treturn string(data)\n\t}\n\treturn \"\"\n}\n\nfunc incrementAttemptCount(workDir, stepName string) {\n\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n\t_ = os.MkdirAll(dir, 0755)\n\tcount := readAttemptCount(workDir, stepName) + 1\n\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n}\n","numLines":406,"startLine":1,"totalLines":406}}}
