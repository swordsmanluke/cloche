[2026-03-10T23:03:20Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CRPfKan9scbx4nKnwUUXvu","type":"tool_result","content":"     1→package dsl_test\n     2→\n     3→import (\n     4→\t\"testing\"\n     5→\n     6→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n     7→\t\"github.com/stretchr/testify/assert\"\n     8→\t\"github.com/stretchr/testify/require\"\n     9→)\n    10→\n    11→func TestLexer_SimpleWorkflow(t *testing.T) {\n    12→\tinput := `workflow \"test\" {\n    13→  step code {\n    14→    run = \"echo hello\"\n    15→    results = [success, fail]\n    16→  }\n    17→  code:success -> done\n    18→}`\n    19→\n    20→\tlexer := dsl.NewLexer(input)\n    21→\ttokens := lexAll(lexer)\n    22→\n    23→\texpected := []dsl.TokenType{\n    24→\t\tdsl.TokenIdent,    // workflow\n    25→\t\tdsl.TokenString,   // \"test\"\n    26→\t\tdsl.TokenLBrace,   // {\n    27→\t\tdsl.TokenIdent,    // step\n    28→\t\tdsl.TokenIdent,    // code\n    29→\t\tdsl.TokenLBrace,   // {\n    30→\t\tdsl.TokenIdent,    // run\n    31→\t\tdsl.TokenEquals,   // =\n    32→\t\tdsl.TokenString,   // \"echo hello\"\n    33→\t\tdsl.TokenIdent,    // results\n    34→\t\tdsl.TokenEquals,   // =\n    35→\t\tdsl.TokenLBracket, // [\n    36→\t\tdsl.TokenIdent,    // success\n    37→\t\tdsl.TokenComma,    // ,\n    38→\t\tdsl.TokenIdent,    // fail\n    39→\t\tdsl.TokenRBracket, // ]\n    40→\t\tdsl.TokenRBrace,   // }\n    41→\t\tdsl.TokenIdent,    // code\n    42→\t\tdsl.TokenColon,    // :\n    43→\t\tdsl.TokenIdent,    // success\n    44→\t\tdsl.TokenArrow,    // ->\n    45→\t\tdsl.TokenIdent,    // done\n    46→\t\tdsl.TokenRBrace,   // }\n    47→\t\tdsl.TokenEOF,\n    48→\t}\n    49→\n    50→\trequire.Len(t, tokens, len(expected))\n    51→\tfor i, tok := range tokens {\n    52→\t\tassert.Equal(t, expected[i], tok.Type, \"token %d: expected %v got %v (%q)\", i, expected[i], tok.Type, tok.Literal)\n    53→\t}\n    54→}\n    55→\n    56→func TestLexer_StringLiteral(t *testing.T) {\n    57→\tinput := `\"hello world\"`\n    58→\tlexer := dsl.NewLexer(input)\n    59→\ttok := lexer.NextToken()\n    60→\tassert.Equal(t, dsl.TokenString, tok.Type)\n    61→\tassert.Equal(t, \"hello world\", tok.Literal)\n    62→}\n    63→\n    64→func TestLexer_Comments(t *testing.T) {\n    65→\tinput := `// this is a comment\n    66→workflow`\n    67→\tlexer := dsl.NewLexer(input)\n    68→\ttok := lexer.NextToken()\n    69→\tassert.Equal(t, dsl.TokenIdent, tok.Type)\n    70→\tassert.Equal(t, \"workflow\", tok.Literal)\n    71→}\n    72→\n    73→func TestLexer_Arrow(t *testing.T) {\n    74→\tinput := `a -> b`\n    75→\tlexer := dsl.NewLexer(input)\n    76→\ttokens := lexAll(lexer)\n    77→\tassert.Equal(t, dsl.TokenIdent, tokens[0].Type)\n    78→\tassert.Equal(t, dsl.TokenArrow, tokens[1].Type)\n    79→\tassert.Equal(t, dsl.TokenIdent, tokens[2].Type)\n    80→}\n    81→\n    82→func TestLexer_EscapedStrings(t *testing.T) {\n    83→\tinput := `\"echo \\\"hello\\\" world\"`\n    84→\tlexer := dsl.NewLexer(input)\n    85→\ttok := lexer.NextToken()\n    86→\tassert.Equal(t, dsl.TokenString, tok.Type)\n    87→\tassert.Equal(t, `echo \"hello\" world`, tok.Literal)\n    88→}\n    89→\n    90→func TestLexer_HyphenatedIdent(t *testing.T) {\n    91→\tinput := `simple-build`\n    92→\tlexer := dsl.NewLexer(input)\n    93→\ttok := lexer.NextToken()\n    94→\tassert.Equal(t, dsl.TokenIdent, tok.Type)\n    95→\tassert.Equal(t, \"simple-build\", tok.Literal)\n    96→}\n    97→\n    98→func TestLexer_IntLiteral(t *testing.T) {\n    99→\tlexer := dsl.NewLexer(\"42\")\n   100→\ttok := lexer.NextToken()\n   101→\tassert.Equal(t, dsl.TokenInt, tok.Type)\n   102→\tassert.Equal(t, \"42\", tok.Literal)\n   103→}\n   104→\n   105→func TestLexer_IntInBrackets(t *testing.T) {\n   106→\ttests := []struct {\n   107→\t\tinput    string\n   108→\t\texpected []dsl.Token\n   109→\t}{\n   110→\t\t{\n   111→\t\t\tinput: \"[0]\",\n   112→\t\t\texpected: []dsl.Token{\n   113→\t\t\t\t{Type: dsl.TokenLBracket, Literal: \"[\"},\n   114→\t\t\t\t{Type: dsl.TokenInt, Literal: \"0\"},\n   115→\t\t\t\t{Type: dsl.TokenRBracket, Literal: \"]\"},\n   116→\t\t\t\t{Type: dsl.TokenEOF},\n   117→\t\t\t},\n   118→\t\t},\n   119→\t\t{\n   120→\t\t\tinput: \"[42]\",\n   121→\t\t\texpected: []dsl.Token{\n   122→\t\t\t\t{Type: dsl.TokenLBracket, Literal: \"[\"},\n   123→\t\t\t\t{Type: dsl.TokenInt, Literal: \"42\"},\n   124→\t\t\t\t{Type: dsl.TokenRBracket, Literal: \"]\"},\n   125→\t\t\t\t{Type: dsl.TokenEOF},\n   126→\t\t\t},\n   127→\t\t},\n   128→\t}\n   129→\n   130→\tfor _, tt := range tests {\n   131→\t\tt.Run(tt.input, func(t *testing.T) {\n   132→\t\t\ttokens := lexAll(dsl.NewLexer(tt.input))\n   133→\t\t\trequire.Len(t, tokens, len(tt.expected))\n   134→\t\t\tfor i, exp := range tt.expected {\n   135→\t\t\t\tassert.Equal(t, exp.Type, tokens[i].Type, \"token %d type\", i)\n   136→\t\t\t\tif exp.Literal != \"\" {\n   137→\t\t\t\t\tassert.Equal(t, exp.Literal, tokens[i].Literal, \"token %d literal\", i)\n   138→\t\t\t\t}\n   139→\t\t\t}\n   140→\t\t})\n   141→\t}\n   142→}\n   143→\n   144→func TestLexer_IntMixedWithTokens(t *testing.T) {\n   145→\tinput := `output[0].id`\n   146→\ttokens := lexAll(dsl.NewLexer(input))\n   147→\n   148→\texpected := []dsl.TokenType{\n   149→\t\tdsl.TokenIdent,    // output\n   150→\t\tdsl.TokenLBracket, // [\n   151→\t\tdsl.TokenInt,      // 0\n   152→\t\tdsl.TokenRBracket, // ]\n   153→\t\tdsl.TokenDot,      // .\n   154→\t\tdsl.TokenIdent,    // id\n   155→\t\tdsl.TokenEOF,\n   156→\t}\n   157→\n   158→\trequire.Len(t, tokens, len(expected))\n   159→\tfor i, tok := range tokens {\n   160→\t\tassert.Equal(t, expected[i], tok.Type, \"token %d\", i)\n   161→\t}\n   162→\tassert.Equal(t, \"output\", tokens[0].Literal)\n   163→\tassert.Equal(t, \"0\", tokens[2].Literal)\n   164→\tassert.Equal(t, \"id\", tokens[5].Literal)\n   165→}\n   166→\n   167→func lexAll(l *dsl.Lexer) []dsl.Token {\n   168→\tvar tokens []dsl.Token\n   169→\tfor {\n   170→\t\ttok := l.NextToken()\n   171→\t\ttokens = append(tokens, tok)\n   172→\t\tif tok.Type == dsl.TokenEOF || tok.Type == dsl.TokenIllegal {\n   173→\t\t\tbreak\n   174→\t\t}\n   175→\t}\n   176→\treturn tokens\n   177→}\n   178→"}]},"parent_tool_use_id":"toolu_01GsFfdp8LiNf4bSxCYsZbbE","session_id":"175df06c-fcc9-44aa-9a28-027165407de1","uuid":"60c13f78-8f85-486e-b62e-8de9e5f2b3e7"}
