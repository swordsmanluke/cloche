[2026-03-10T23:03:20Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014rk9TuuAKHL1XTFEjWuVWX","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"strings\"\n    11→\t\"time\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    15→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    17→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    18→)\n    19→\n    20→// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    21→// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    22→// strings suitable for adding to a command's environment.\n    23→func (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    24→\tvar env []string\n    25→\tfor _, w := range wires {\n    26→\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    27→\t\t\tcontinue\n    28→\t\t}\n    29→\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    30→\t\tif err != nil {\n    31→\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    32→\t\t}\n    33→\t\tfor _, m := range w.OutputMap {\n    34→\t\t\tval, err := m.Path.Evaluate(data)\n    35→\t\t\tif err != nil {\n    36→\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    37→\t\t\t}\n    38→\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    39→\t\t}\n    40→\t}\n    41→\treturn env, nil\n    42→}\n    43→\n    44→// RunDispatcher dispatches a container workflow run and returns the run ID.\n    45→type RunDispatcher interface {\n    46→\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    47→}\n    48→\n    49→// Executor implements engine.StepExecutor for host workflow steps.\n    50→type Executor struct {\n    51→\tProjectDir string\n    52→\tMainDir    string         // main branch worktree dir; scripts execute from here\n    53→\tDispatcher RunDispatcher\n    54→\tStore      ports.RunStore\n    55→\tOutputDir  string         // directory for step output files\n    56→\tWires      []domain.Wire  // workflow wiring (for output mappings)\n    57→\tHostRunID  string         // ID of the parent host run (set on child runs)\n    58→}\n    59→\n    60→// scriptDir returns the directory from which scripts should execute.\n    61→// Uses MainDir if set, otherwise falls back to ProjectDir.\n    62→func (e *Executor) scriptDir() string {\n    63→\tif e.MainDir != \"\" {\n    64→\t\treturn e.MainDir\n    65→\t}\n    66→\treturn e.ProjectDir\n    67→}\n    68→\n    69→var _ engine.StepExecutor = (*Executor)(nil)\n    70→\n    71→// Execute runs a single host workflow step.\n    72→func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    73→\tswitch step.Type {\n    74→\tcase domain.StepTypeScript:\n    75→\t\treturn e.executeScript(ctx, step)\n    76→\tcase domain.StepTypeWorkflow:\n    77→\t\treturn e.executeWorkflow(ctx, step)\n    78→\tdefault:\n    79→\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    80→\t}\n    81→}\n    82→\n    83→// executeScript runs a shell command on the host.\n    84→func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    85→\tcmdStr := step.Config[\"run\"]\n    86→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    87→\tcmd.Dir = e.scriptDir()\n    88→\tcmd.Env = append(os.Environ(),\n    89→\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    90→\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    91→\t)\n    92→\n    93→\t// Pass previous step output if available\n    94→\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n    95→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n    96→\t}\n    97→\n    98→\t// Resolve output mappings from wires and add as env vars\n    99→\tif len(e.Wires) > 0 {\n   100→\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n   101→\t\tif err != nil {\n   102→\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n   103→\t\t}\n   104→\t\tcmd.Env = append(cmd.Env, mapped...)\n   105→\t}\n   106→\n   107→\toutput, err := cmd.CombinedOutput()\n   108→\n   109→\t// Extract result marker\n   110→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n   111→\n   112→\t// Write output to file\n   113→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   114→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   115→\t}\n   116→\n   117→\tif err != nil {\n   118→\t\tif _, ok := err.(*exec.ExitError); ok {\n   119→\t\t\tresult := \"fail\"\n   120→\t\t\tif found {\n   121→\t\t\t\tresult = markerResult\n   122→\t\t\t}\n   123→\t\t\treturn result, nil\n   124→\t\t}\n   125→\t\treturn \"\", err\n   126→\t}\n   127→\n   128→\tresult := \"success\"\n   129→\tif found {\n   130→\t\tresult = markerResult\n   131→\t}\n   132→\treturn result, nil\n   133→}\n   134→\n   135→// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   136→func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   137→\tworkflowName := step.Config[\"workflow_name\"]\n   138→\tif workflowName == \"\" {\n   139→\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   140→\t}\n   141→\n   142→\t// Read prompt from previous step output or prompt_step override\n   143→\tvar promptContent string\n   144→\tpromptSource := step.Config[\"prompt_step\"]\n   145→\tif promptSource != \"\" {\n   146→\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   147→\t\tif err == nil {\n   148→\t\t\tpromptContent = string(data)\n   149→\t\t}\n   150→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   151→\t\tdata, err := os.ReadFile(prev)\n   152→\t\tif err == nil {\n   153→\t\t\tpromptContent = string(data)\n   154→\t\t}\n   155→\t}\n   156→\n   157→\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   158→\t\tWorkflowName: workflowName,\n   159→\t\tProjectDir:   e.ProjectDir,\n   160→\t\tPrompt:       promptContent,\n   161→\t})\n   162→\tif err != nil {\n   163→\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   164→\t}\n   165→\n   166→\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   167→\n   168→\t// Link child run to parent host run\n   169→\tif e.HostRunID != \"\" {\n   170→\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n   171→\t\t\tchildRun.ParentRunID = e.HostRunID\n   172→\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n   173→\t\t}\n   174→\t}\n   175→\n   176→\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n   177→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   178→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n   179→\t}\n   180→\n   181→\t// Poll until the run reaches a terminal state\n   182→\tstate, err := e.waitForRun(ctx, resp.RunId)\n   183→\tif err != nil {\n   184→\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   185→\t}\n   186→\n   187→\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   188→\n   189→\t// Map run state to step result\n   190→\tif state == domain.RunStateSucceeded {\n   191→\t\treturn \"success\", nil\n   192→\t}\n   193→\treturn \"fail\", nil\n   194→}\n   195→\n   196→// waitForRun polls the store until the run reaches a terminal state.\n   197→func (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   198→\tticker := time.NewTicker(2 * time.Second)\n   199→\tdefer ticker.Stop()\n   200→\n   201→\tfor {\n   202→\t\tselect {\n   203→\t\tcase <-ctx.Done():\n   204→\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   205→\t\tcase <-ticker.C:\n   206→\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   207→\t\t\tif err != nil {\n   208→\t\t\t\tcontinue // transient error, retry\n   209→\t\t\t}\n   210→\t\t\tswitch run.State {\n   211→\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   212→\t\t\t\treturn run.State, nil\n   213→\t\t\t}\n   214→\t\t\t// Still pending or running, continue polling\n   215→\t\t}\n   216→\t}\n   217→}\n   218→\n   219→// stepOutputPath returns the path for a step's output file.\n   220→func (e *Executor) stepOutputPath(stepName string) string {\n   221→\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   222→}\n   223→\n   224→// findPrevOutput finds the output file from the step that wires into this one.\n   225→// It checks prompt_step config first, then walks the wiring graph to find the\n   226→// source step.\n   227→func (e *Executor) findPrevOutput(step *domain.Step) string {\n   228→\t// Explicit prompt_step config takes priority\n   229→\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   230→\t\tpath := e.stepOutputPath(ps)\n   231→\t\tif _, err := os.Stat(path); err == nil {\n   232→\t\t\treturn path\n   233→\t\t}\n   234→\t}\n   235→\n   236→\t// Walk wiring to find the step that feeds into this one\n   237→\tfor _, w := range e.Wires {\n   238→\t\tif w.To == step.Name {\n   239→\t\t\tpath := e.stepOutputPath(w.From)\n   240→\t\t\tif _, err := os.Stat(path); err == nil {\n   241→\t\t\t\treturn path\n   242→\t\t\t}\n   243→\t\t}\n   244→\t}\n   245→\treturn \"\"\n   246→}\n   247→\n   248→// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n   249→// the repository containing projectDir. If projectDir is already the main\n   250→// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n   251→// error (e.g. not a git repo).\n   252→func MainWorktreeDir(projectDir string) string {\n   253→\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n   254→\tout, err := cmd.Output()\n   255→\tif err != nil {\n   256→\t\treturn projectDir\n   257→\t}\n   258→\t// The first \"worktree <path>\" line is always the main worktree.\n   259→\tfor _, line := range strings.Split(string(out), \"\\n\") {\n   260→\t\tif strings.HasPrefix(line, \"worktree \") {\n   261→\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n   262→\t\t}\n   263→\t}\n   264→\treturn projectDir\n   265→}\n   266→"}]},"parent_tool_use_id":"toolu_01R9TdoBBis1LD81Bra6qw95","session_id":"175df06c-fcc9-44aa-9a28-027165407de1","uuid":"799ea98c-8b6d-4135-90d6-5646930d05a7"}
[2026-03-10T23:03:20Z] [llm] {"type":"system","subtype":"task_progress","task_id":"a3f14d4dc0cf7d7a1","tool_use_id":"toolu_01R9TdoBBis1LD81Bra6qw95","description":"Reading internal/host/loop.go","usage":{"total_tokens":24919,"tool_uses":16,"duration_ms":9487},"last_tool_name":"Read","uuid":"80139426-9c4e-4b74-8359-c6e0ecc05fa9","session_id":"175df06c-fcc9-44aa-9a28-027165407de1"}
[2026-03-10T23:03:20Z] [llm] {"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_013ZNu68PGZgTV7EKL3o8qtT","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01D994T9XM3oc5WtMnyzLffu","name":"Read","input":{"file_path":"/workspace/internal/host/loop.go"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":7,"cache_creation_input_tokens":5836,"cache_read_input_tokens":19056,"cache_creation":{"ephemeral_5m_input_tokens":5836,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01R9TdoBBis1LD81Bra6qw95","session_id":"175df06c-fcc9-44aa-9a28-027165407de1","uuid":"468b1d44-44a2-4626-8145-4704ef53f255"}
[2026-03-10T23:03:20Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D994T9XM3oc5WtMnyzLffu","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"log\"\n     6→\t\"sync\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11→)\n    12→\n    13→const (\n    14→\tdefaultMaxConcurrent = 1\n    15→\tidlePollInterval     = 30 * time.Second\n    16→\tcapacityPollInterval = 5 * time.Second\n    17→)\n    18→\n    19→// LoopConfig holds configuration for an orchestration loop.\n    20→type LoopConfig struct {\n    21→\tProjectDir    string\n    22→\tMaxConcurrent int\n    23→\tStaggerDelay  time.Duration // delay between launching consecutive runs\n    24→}\n    25→\n    26→// Loop manages a continuous orchestration loop for a project, keeping up to\n    27→// MaxConcurrent host workflow runs active at all times when work is available.\n    28→type Loop struct {\n    29→\tconfig     LoopConfig\n    30→\trunner     func(ctx context.Context, projectDir string) (*RunResult, error)\n    31→\tstore      ports.RunStore\n    32→\tstopCh     chan struct{}\n    33→\tmu         sync.Mutex\n    34→\trunning    bool\n    35→}\n    36→\n    37→// NewLoop creates an orchestration loop. The runFn is called to start each\n    38→// orchestration run and should block until the run completes.\n    39→func NewLoop(cfg LoopConfig, store ports.RunStore, runFn func(ctx context.Context, projectDir string) (*RunResult, error)) *Loop {\n    40→\tif cfg.MaxConcurrent <= 0 {\n    41→\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n    42→\t}\n    43→\treturn &Loop{\n    44→\t\tconfig: cfg,\n    45→\t\trunner: runFn,\n    46→\t\tstore:  store,\n    47→\t}\n    48→}\n    49→\n    50→// Start begins the orchestration loop. No-op if already running.\n    51→func (l *Loop) Start() {\n    52→\tl.mu.Lock()\n    53→\tdefer l.mu.Unlock()\n    54→\tif l.running {\n    55→\t\treturn\n    56→\t}\n    57→\tl.running = true\n    58→\tl.stopCh = make(chan struct{})\n    59→\tgo l.run()\n    60→\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n    61→}\n    62→\n    63→// Stop signals the loop to stop. Active runs continue to completion.\n    64→func (l *Loop) Stop() {\n    65→\tl.mu.Lock()\n    66→\tdefer l.mu.Unlock()\n    67→\tif !l.running {\n    68→\t\treturn\n    69→\t}\n    70→\tl.running = false\n    71→\tclose(l.stopCh)\n    72→\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n    73→}\n    74→\n    75→// Running returns whether the loop is currently active.\n    76→func (l *Loop) Running() bool {\n    77→\tl.mu.Lock()\n    78→\tdefer l.mu.Unlock()\n    79→\treturn l.running\n    80→}\n    81→\n    82→func (l *Loop) run() {\n    83→\ttype result struct {\n    84→\t\tstate domain.RunState\n    85→\t}\n    86→\n    87→\tcompletions := make(chan result, l.config.MaxConcurrent)\n    88→\tinFlight := 0\n    89→\n    90→\tfor {\n    91→\t\t// Fill up to max concurrent slots.\n    92→\t\tlaunched := 0\n    93→\t\tfor inFlight < l.config.MaxConcurrent {\n    94→\t\t\tselect {\n    95→\t\t\tcase <-l.stopCh:\n    96→\t\t\t\treturn\n    97→\t\t\tdefault:\n    98→\t\t\t}\n    99→\n   100→\t\t\t// Check how many host runs are active for this project (in case of\n   101→\t\t\t// leftover runs from previous loops).\n   102→\t\t\tactive := l.countActiveHostRuns()\n   103→\t\t\tif active >= l.config.MaxConcurrent {\n   104→\t\t\t\tbreak\n   105→\t\t\t}\n   106→\n   107→\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n   108→\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   109→\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   110→\t\t\t\t\treturn\n   111→\t\t\t\t}\n   112→\t\t\t}\n   113→\n   114→\t\t\t// Launch a new orchestration run in a goroutine.\n   115→\t\t\tinFlight++\n   116→\t\t\tlaunched++\n   117→\t\t\tgo func() {\n   118→\t\t\t\tres, err := l.runner(context.Background(), l.config.ProjectDir)\n   119→\t\t\t\tif err != nil {\n   120→\t\t\t\t\tlog.Printf(\"orchestration loop: run failed for %s: %v\", l.config.ProjectDir, err)\n   121→\t\t\t\t\tcompletions <- result{state: domain.RunStateFailed}\n   122→\t\t\t\t\treturn\n   123→\t\t\t\t}\n   124→\t\t\t\tcompletions <- result{state: res.State}\n   125→\t\t\t}()\n   126→\t\t}\n   127→\n   128→\t\tif inFlight == 0 {\n   129→\t\t\t// Nothing in flight and at capacity — wait before checking again.\n   130→\t\t\tif !l.sleep(capacityPollInterval) {\n   131→\t\t\t\treturn\n   132→\t\t\t}\n   133→\t\t\tcontinue\n   134→\t\t}\n   135→\n   136→\t\t// Wait for any run to complete.\n   137→\t\tselect {\n   138→\t\tcase r := <-completions:\n   139→\t\t\tinFlight--\n   140→\t\t\tif r.state == domain.RunStateSucceeded {\n   141→\t\t\t\t// Work was done — try to fill slots immediately.\n   142→\t\t\t\tcontinue\n   143→\t\t\t}\n   144→\t\t\t// Run failed or aborted (no tasks available). Back off.\n   145→\t\t\tif !l.sleep(idlePollInterval) {\n   146→\t\t\t\treturn\n   147→\t\t\t}\n   148→\t\tcase <-l.stopCh:\n   149→\t\t\treturn\n   150→\t\t}\n   151→\t}\n   152→}\n   153→\n   154→// countActiveHostRuns counts running or pending host runs for the project.\n   155→func (l *Loop) countActiveHostRuns() int {\n   156→\tctx := context.Background()\n   157→\truns, err := l.store.ListRunsByProject(ctx, l.config.ProjectDir, time.Time{})\n   158→\tif err != nil {\n   159→\t\treturn 0\n   160→\t}\n   161→\tcount := 0\n   162→\tfor _, r := range runs {\n   163→\t\tif r.IsHost && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n   164→\t\t\tcount++\n   165→\t\t}\n   166→\t}\n   167→\treturn count\n   168→}\n   169→\n   170→// sleep waits for the given duration or until the loop is stopped.\n   171→// Returns false if the loop was stopped.\n   172→func (l *Loop) sleep(d time.Duration) bool {\n   173→\tselect {\n   174→\tcase <-time.After(d):\n   175→\t\treturn true\n   176→\tcase <-l.stopCh:\n   177→\t\treturn false\n   178→\t}\n   179→}\n   180→"}]},"parent_tool_use_id":"toolu_01R9TdoBBis1LD81Bra6qw95","session_id":"175df06c-fcc9-44aa-9a28-027165407de1","uuid":"a845dd99-032a-4ad0-b175-16c08175f352"}
