[2026-03-10T23:03:20Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0154BdQiS2uQTt9yrQZHkXWN","type":"tool_result","content":"     1→package protocol\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"strings\"\n     6→)\n     7→\n     8→const ResultPrefix = \"CLOCHE_RESULT:\"\n     9→\n    10→// ExtractResult scans output for the last CLOCHE_RESULT:<name> line.\n    11→// Returns the result name, the output with all marker lines removed, and\n    12→// whether a marker was found.\n    13→func ExtractResult(output []byte) (result string, cleanOutput []byte, found bool) {\n    14→\tvar clean [][]byte\n    15→\tfor _, line := range bytes.Split(output, []byte(\"\\n\")) {\n    16→\t\ttrimmed := strings.TrimSpace(string(line))\n    17→\t\tif strings.HasPrefix(trimmed, ResultPrefix) {\n    18→\t\t\tresult = trimmed[len(ResultPrefix):]\n    19→\t\t\tfound = true\n    20→\t\t} else {\n    21→\t\t\tclean = append(clean, line)\n    22→\t\t}\n    23→\t}\n    24→\t// Rejoin and trim trailing empty line from split\n    25→\tjoined := bytes.Join(clean, []byte(\"\\n\"))\n    26→\tjoined = bytes.TrimRight(joined, \"\\n\")\n    27→\tif len(joined) > 0 {\n    28→\t\tjoined = append(joined, '\\n')\n    29→\t}\n    30→\treturn result, joined, found\n    31→}\n    32→"}]},"parent_tool_use_id":"toolu_01R9TdoBBis1LD81Bra6qw95","session_id":"175df06c-fcc9-44aa-9a28-027165407de1","uuid":"1d8fe0c8-37d1-41cd-8172-ba574b1a5c39"}
