ir, 0755)\n   222→\n   223→\t// Write a previous step's output\n   224→\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n   225→\n   226→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   227→\t\t\"develop-test-run\": {\n   228→\t\t\tID:    \"develop-test-run\",\n   229→\t\t\tState: domain.RunStateSucceeded,\n   230→\t\t},\n   231→\t}}\n   232→\n   233→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   234→\n   235→\texecutor := &Executor{\n   236→\t\tProjectDir: tmpDir,\n   237→\t\tDispatcher: dispatcher,\n   238→\t\tStore:      store,\n   239→\t\tOutputDir:  outputDir,\n   240→\t}\n   241→\n   242→\tstep := &domain.Step{\n   243→\t\tName:    \"develop\",\n   244→\t\tType:    domain.StepTypeWorkflow,\n   245→\t\tResults: []string{\"success\", \"fail\"},\n   246→\t\tConfig: map[string]string{\n   247→\t\t\t\"workflow_name\": \"develop\",\n   248→\t\t\t\"prompt_step\":   \"prepare-prompt\",\n   249→\t\t},\n   250→\t}\n   251→\n   252→\tresult, err := executor.Execute(context.Background(), step)\n   253→\trequire.NoError(t, err)\n   254→\tassert.Equal(t, \"success\", result)\n   255→\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n   256→}\n   257→\n   258→func TestEngine_HostWorkflow_Linear(t *testing.T) {\n   259→\ttmpDir := t.TempDir()\n   260→\toutputDir := filepath.Join(tmpDir, \"output\")\n   261→\n   262→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   263→\t\t\"develop-test-run\": {\n   264→\t\t\tID:    \"develop-test-run\",\n   265→\t\t\tState: domain.RunStateSucceeded,\n   266→\t\t},\n   267→\t}}\n   268→\n   269→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   270→\n   271→\texecutor := &Executor{\n   272→\t\tProjectDir: tmpDir,\n   273→\t\tDispatcher: dispatcher,\n   274→\t\tStore:      store,\n   275→\t\tOutputDir:  outputDir,\n   276→\t}\n   277→\n   278→\twf := &domain.Workflow{\n   279→\t\tName: \"main\",\n   280→\t\tSteps: map[string]*domain.Step{\n   281→\t\t\t\"prepare\": {\n   282→\t\t\t\tName:    \"prepare\",\n   283→\t\t\t\tType:    domain.StepTypeScript,\n   284→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   285→\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n   286→\t\t\t},\n   287→\t\t\t\"develop\": {\n   288→\t\t\t\tName:    \"develop\",\n   289→\t\t\t\tType:    domain.StepTypeWorkflow,\n   290→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   291→\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   292→\t\t\t},\n   293→\t\t\t\"merge\": {\n   294→\t\t\t\tName:    \"merge\",\n   295→\t\t\t\tType:    domain.StepTypeScript,\n   296→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   297→\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n   298→\t\t\t},\n   299→\t\t},\n   300→\t\tWiring: []domain.Wire{\n   301→\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   302→\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   303→\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n   304→\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   305→\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n   306→\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n   307→\t\t},\n   308→\t\tEntryStep: \"prepare\",\n   309→\t}\n   310→\n   311→\teng := engine.New(executor)\n   312→\trun, err := eng.Run(context.Background(), wf)\n   313→\trequire.NoError(t, err)\n   314→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   315→\tassert.Len(t, dispatcher.calls, 1)\n   316→}\n   317→\n   318→func TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n   319→\ttmpDir := t.TempDir()\n   320→\toutputDir := filepath.Join(tmpDir, \"output\")\n   321→\n   322→\texecutor := &Executor{\n   323→\t\tProjectDir: tmpDir,\n   324→\t\tOutputDir:  outputDir,\n   325→\t}\n   326→\n   327→\twf := &domain.Workflow{\n   328→\t\tName: \"main\",\n   329→\t\tSteps: map[string]*domain.Step{\n   330→\t\t\t\"prepare\": {\n   331→\t\t\t\tName:    \"prepare\",\n   332→\t\t\t\tType:    domain.StepTypeScript,\n   333→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   334→\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   335→\t\t\t},\n   336→\t\t\t\"develop\": {\n   337→\t\t\t\tName:    \"develop\",\n   338→\t\t\t\tType:    domain.StepTypeWorkflow,\n   339→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   340→\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   341→\t\t\t},\n   342→\t\t},\n   343→\t\tWiring: []domain.Wire{\n   344→\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   345→\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   346→\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n   347→\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   348→\t\t},\n   349→\t\tEntryStep: \"prepare\",\n   350→\t}\n   351→\n   352→\teng := engine.New(executor)\n   353→\trun, err := eng.Run(context.Background(), wf)\n   354→\trequire.NoError(t, err)\n   355→\tassert.Equal(t, domain.RunStateFailed, run.State)\n   356→}\n   357→\n   358→func TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n   359→\ttmpDir := t.TempDir()\n   360→\toutputDir := filepath.Join(tmpDir, \"output\")\n   361→\n   362→\texecutor := &Executor{\n   363→\t\tProjectDir: tmpDir,\n   364→\t\tOutputDir:  outputDir,\n   365→\t}\n   366→\n   367→\tstep := &domain.Step{\n   368→\t\tName:    \"env-check\",\n   369→\t\tType:    domain.StepTypeScript,\n   370→\t\tResults: []string{\"success\", \"fail\"},\n   371→\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n   372→\t}\n   373→\n   374→\tresult, err := executor.Execute(context.Background(), step)\n   375→\trequire.NoError(t, err)\n   376→\tassert.Equal(t, \"success\", result)\n   377→\n   378→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n   379→\trequire.NoError(t, err)\n   380→\tassert.Contains(t, string(data), tmpDir)\n   381→}\n   382→\n   383→func TestExecutor_ScriptStep_NoOutputMappings(t *testing.T) {\n   384→\ttmpDir := t.TempDir()\n   385→\toutputDir := filepath.Join(tmpDir, \"output\")\n   386→\n   387→\texecutor := &Executor{\n   388→\t\tProjectDir: tmpDir,\n   389→\t\tOutputDir:  outputDir,\n   390→\t\tWires: []domain.Wire{\n   391→\t\t\t{From: \"step-a\", Result: \"success\", To: \"step-b\"},\n   392→\t\t},\n   393→\t}\n   394→\n   395→\tstep := &domain.Step{\n   396→\t\tName:    \"step-b\",\n   397→\t\tType:    domain.StepTypeScript,\n   398→\t\tResults: []string{\"success\", \"fail\"},\n   399→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   400→\t}\n   401→\n   402→\tresult, err := executor.Execute(context.Background(), step)\n   403→\trequire.NoError(t, err)\n   404→\tassert.Equal(t, \"success\", result)\n   405→}\n   406→\n   407→func TestExecutor_ScriptStep_OutputMappings_JSONFields(t *testing.T) {\n   408→\ttmpDir := t.TempDir()\n   409→\toutputDir := filepath.Join(tmpDir, \"output\")\n   410→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   411→\n   412→\t// Write source step output as JSON\n   413→\tsourceJSON := `{\"title\": \"Fix bug\", \"priority\": \"high\"}`\n   414→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"get-tasks.out\"), []byte(sourceJSON), 0644))\n   415→\n   416→\texecutor := &Executor{\n   417→\t\tProjectDir: tmpDir,\n   418→\t\tOutputDir:  outputDir,\n   419→\t\tWires: []domain.Wire{\n   420→\t\t\t{\n   421→\t\t\t\tFrom:   \"get-tasks\",\n   422→\t\t\t\tResult: \"success\",\n   423→\t\t\t\tTo:     \"use-tasks\",\n   424→\t\t\t\tOutputMap: []domain.OutputMapping{\n   425→\t\t\t\t\t{\n   426→\t\t\t\t\t\tEnvVar: \"TASK_TITLE\",\n   427→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"title\"}}},\n   428→\t\t\t\t\t},\n   429→\t\t\t\t\t{\n   430→\t\t\t\t\t\tEnvVar: \"TASK_PRIORITY\",\n   431→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"priority\"}}},\n   432→\t\t\t\t\t},\n   433→\t\t\t\t},\n   434→\t\t\t},\n   435→\t\t},\n   436→\t}\n   437→\n   438→\tstep := &domain.Step{\n   439→\t\tName:    \"use-tasks\",\n   440→\t\tType:    domain.StepTypeScript,\n   441→\t\tResults: []string{\"success\", \"fail\"},\n   442→\t\tConfig:  map[string]string{\"run\": \"echo $TASK_TITLE $TASK_PRIORITY\"},\n   443→\t}\n   444→\n   445→\tresult, err := executor.Execute(context.Background(), step)\n   446→\trequire.NoError(t, err)\n   447→\tassert.Equal(t, \"success\", result)\n   448→\n   449→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"use-tasks.out\"))\n   450→\trequire.NoError(t, err)\n   451→\tassert.Contains(t, string(data), \"Fix bug\")\n   452→\tassert.Contains(t, string(data), \"high\")\n   453→}\n   454→\n   455→func TestExecutor_ScriptStep_OutputMappings_ArrayIndex(t *testing.T) {\n   456→\ttmpDir := t.TempDir()\n   457→\toutputDir := filepath.Join(tmpDir, \"output\")\n   458→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   459→\n   460→\t// Write source step output as JSON array\n   461→\tsourceJSON := `[{\"id\": \"task-1\", \"title\": \"First\"}, {\"id\": \"task-2\", \"title\": \"Second\"}]`\n   462→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"list-tasks.out\"), []byte(sourceJSON), 0644))\n   463→\n   464→\texecutor := &Executor{\n   465→\t\tProjectDir: tmpDir,\n   466→\t\tOutputDir:  outputDir,\n   467→\t\tWires: []domain.Wire{\n   468→\t\t\t{\n   469→\t\t\t\tFrom:   \"list-tasks\",\n   470→\t\t\t\tResult: \"success\",\n   471→\t\t\t\tTo:     \"process\",\n   472→\t\t\t\tOutputMap: []domain.OutputMapping{\n   473→\t\t\t\t\t{\n   474→\t\t\t\t\t\tEnvVar: \"FIRST_ID\",\n   475→\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n   476→\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 0},\n   477→\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"id\"},\n   478→\t\t\t\t\t\t}},\n   479→\t\t\t\t\t},\n   480→\t\t\t\t\t{\n   481→\t\t\t\t\t\tEnvVar: \"SECOND_TITLE\",\n   482→\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n   483→\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 1},\n   484→\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"title\"},\n   485→\t\t\t\t\t\t}},\n   486→\t\t\t\t\t},\n   487→\t\t\t\t},\n   488→\t\t\t},\n   489→\t\t},\n   490→\t}\n   491→\n   492→\tstep := &domain.Step{\n   493→\t\tName:    \"process\",\n   494→\t\tType:    domain.StepTypeScript,\n   495→\t\tResults: []string{\"success\", \"fail\"},\n   496→\t\tConfig:  map[string]string{\"run\": \"echo $FIRST_ID $SECOND_TITLE\"},\n   497→\t}\n   498→\n   499→\tresult, err := executor.Execute(context.Background(), step)\n   500→\trequire.NoError(t, err)\n   501→\tassert.Equal(t, \"success\", result)\n   502→\n   503→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"process.out\"))\n   504→\trequire.NoError(t, err)\n   505→\tassert.Contains(t, string(data), \"task-1\")\n   506→\tassert.Contains(t, string(data), \"Second\")\n   507→}\n   508→\n   509→func TestExecutor_ScriptStep_OutputMappings_MissingSourceOutput(t *testing.T) {\n   510→\ttmpDir := t.TempDir()\n   511→\toutputDir := filepath.Join(tmpDir, \"output\")\n   512→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   513→\n   514→\t// No source output file written\n   515→\n   516→\texecutor := &Executor{\n   517→\t\tProjectDir: tmpDir,\n   518→\t\tOutputDir:  outputDir,\n   519→\t\tWires: []domain.Wire{\n   520→\t\t\t{\n   521→\t\t\t\tFrom:   \"missing-step\",\n   522→\t\t\t\tResult: \"success\",\n   523→\t\t\t\tTo:     \"consumer\",\n   524→\t\t\t\tOutputMap: []domain.OutputMapping{\n   525→\t\t\t\t\t{\n   526→\t\t\t\t\t\tEnvVar: \"VAL\",\n   527→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n   528→\t\t\t\t\t},\n   529→\t\t\t\t},\n   530→\t\t\t},\n   531→\t\t},\n   532→\t}\n   533→\n   534→\tstep := &domain.Step{\n   535→\t\tName:    \"consumer\",\n   536→\t\tType:    domain.StepTypeScript,\n   537→\t\tResults: []string{\"success\", \"fail\"},\n   538→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   539→\t}\n   540→\n   541→\t_, err := executor.Execute(context.Background(), step)\n   542→\trequire.Error(t, err)\n   543→\tassert.Contains(t, err.Error(), \"reading output of missing-step\")\n   544→}\n   545→\n   546→func TestExecutor_ScriptStep_OutputMappings_NotJSON(t *testing.T) {\n   547→\ttmpDir := t.TempDir()\n   548→\toutputDir := filepath.Join(tmpDir, \"output\")\n   549→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   550→\n   551→\t// Write non-JSON output\n   552→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"plain.out\"), []byte(\"not json\"), 0644))\n   553→\n   554→\texecutor := &Executor{\n   555→\t\tProjectDir: tmpDir,\n   556→\t\tOutputDir:  outputDir,\n   557→\t\tWires: []domain.Wire{\n   558→\t\t\t{\n   559→\t\t\t\tFrom:   \"plain\",\n   560→\t\t\t\tResult: \"success\",\n   561→\t\t\t\tTo:     \"consumer\",\n   562→\t\t\t\tOutputMap: []domain.OutputMapping{\n   563→\t\t\t\t\t{\n   564→\t\t\t\t\t\tEnvVar: \"VAL\",\n   565→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n   566→\t\t\t\t\t},\n   567→\t\t\t\t},\n   568→\t\t\t},\n   569→\t\t},\n   570→\t}\n   571→\n   572→\tstep := &domain.Step{\n   573→\t\tName:    \"consumer\",\n   574→\t\tType:    domain.StepTypeScript,\n   575→\t\tResults: []string{\"success\", \"fail\"},\n   576→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   577→\t}\n   578→\n   579→\t_, err := executor.Execute(context.Background(), step)\n   580→\trequire.Error(t, err)\n   581→\tassert.Contains(t, err.Error(), \"not valid JSON\")\n   582→}\n   583→\n   584→func TestRunner_RunWithID(t *testing.T) {\n   585→\ttmpDir := t.TempDir()\n   586→\n   587→\t// Write a simple host.cloche\n   588→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   589→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   590→\thostCloche := `workflow \"main\" {\n   591→  step greet {\n   592→    run     = \"echo hi\"\n   593→    results = [success, fail]\n   594→  }\n   595→\n   596→  greet:success -> done\n   597→  greet:fail    -> abort\n   598→}`\n   599→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   600→\n   601→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   602→\n   603→\trunner := &Runner{\n   604→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   605→\t\tStore:      store,\n   606→\t}\n   607→\n   608→\tcustomID := \"my-custom-run-id\"\n   609→\tresult, err := runner.RunWithID(context.Background(), tmpDir, customID)\n   610→\trequire.NoError(t, err)\n   611→\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n   612→\tassert.Equal(t, customID, result.RunID, \"RunWithID should use the provided ID\")\n   613→\n   614→\t// Verify the run was persisted with the custom ID\n   615→\thostRun, err := store.GetRun(context.Background(), customID)\n   616→\trequire.NoError(t, err)\n   617→\tassert.True(t, hostRun.IsHost)\n   618→\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n   619→}\n   620→\n   621→func TestRunner_PersistsHostRun(t *testing.T) {\n   622→\ttmpDir := t.TempDir()\n   623→\n   624→\t// Write a simple host.cloche\n   625→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   626→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   627→\thostCloche := `workflow \"main\" {\n   628→  step prepare {\n   629→    run     = \"echo prepared\"\n   630→    results = [success, fail]\n   631→  }\n   632→\n   633→  prepare:success -> done\n   634→  prepare:fail    -> abort\n   635→}`\n   636→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   637→\n   638→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   639→\n   640→\trunner := &Runner{\n   641→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   642→\t\tStore:      store,\n   643→\t}\n   644→\n   645→\tresult, err := runner.Run(context.Background(), tmpDir)\n   646→\trequire.NoError(t, err)\n   647→\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n   648→\tassert.NotEmpty(t, result.RunID)\n   649→\n   650→\t// Verify the host run was persisted in the store\n   651→\thostRun, err := store.GetRun(context.Background(), result.RunID)\n   652→\trequire.NoError(t, err)\n   653→\tassert.True(t, hostRun.IsHost, \"host run should have IsHost=true\")\n   654→\tassert.Equal(t, tmpDir, hostRun.ProjectDir)\n   655→\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n   656→\tassert.False(t, hostRun.StartedAt.IsZero())\n   657→\tassert.False(t, hostRun.CompletedAt.IsZero())\n   658→}\n   659→\n   660→func TestExecutor_ScriptStep_UsesMainDir(t *testing.T) {\n   661→\t// ProjectDir has no script; MainDir has the script.\n   662→\tprojectDir := t.TempDir()\n   663→\tmainDir := t.TempDir()\n   664→\toutputDir := filepath.Join(projectDir, \"output\")\n   665→\n   666→\t// Create a script only in mainDir\n   667→\tscriptDir := filepath.Join(mainDir, \".cloche\", \"scripts\")\n   668→\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n   669→\trequire.NoError(t, os.WriteFile(\n   670→\t\tfilepath.Join(scriptDir, \"greet.sh\"),\n   671→\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n   672→\t\t0755,\n   673→\t))\n   674→\n   675→\texecutor := &Executor{\n   676→\t\tProjectDir: projectDir,\n   677→\t\tMainDir:    mainDir,\n   678→\t\tOutputDir:  outputDir,\n   679→\t}\n   680→\n   681→\tstep := &domain.Step{\n   682→\t\tName:    \"greet\",\n   683→\t\tType:    domain.StepTypeScript,\n   684→\t\tResults: []string{\"success\", \"fail\"},\n   685→\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/greet.sh\"},\n   686→\t}\n   687→\n   688→\tresult, err := executor.Execute(context.Background(), step)\n   689→\trequire.NoError(t, err)\n   690→\tassert.Equal(t, \"success\", result)\n   691→\n   692→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n   693→\trequire.NoError(t, err)\n   694→\tassert.Contains(t, string(data), \"from-main\")\n   695→}\n   696→\n   697→func TestExecutor_ScriptStep_MainDirOverridesProjectDir(t *testing.T) {\n   698→\t// Both dirs have a script with different content; MainDir's version wins.\n   699→\tprojectDir := t.TempDir()\n   700→\tmainDir := t.TempDir()\n   701→\toutputDir := filepath.Join(projectDir, \"output\")\n   702→\n   703→\t// Create script in both dirs with different content\n   704→\tfor _, dir := range []string{projectDir, mainDir} {\n   705→\t\tscriptDir := filepath.Join(dir, \".cloche\", \"scripts\")\n   706→\t\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n   707→\t}\n   708→\trequire.NoError(t, os.WriteFile(\n   709→\t\tfilepath.Join(projectDir, \".cloche\", \"scripts\", \"hello.sh\"),\n   710→\t\t[]byte(\"#!/bin/sh\\necho from-branch\"),\n   711→\t\t0755,\n   712→\t))\n   713→\trequire.NoError(t, os.WriteFile(\n   714→\t\tfilepath.Join(mainDir, \".cloche\", \"scripts\", \"hello.sh\"),\n   715→\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n   716→\t\t0755,\n   717→\t))\n   718→\n   719→\texecutor := &Executor{\n   720→\t\tProjectDir: projectDir,\n   721→\t\tMainDir:    mainDir,\n   722→\t\tOutputDir:  outputDir,\n   723→\t}\n   724→\n   725→\tstep := &domain.Step{\n   726→\t\tName:    \"hello\",\n   727→\t\tType:    domain.StepTypeScript,\n   728→\t\tResults: []string{\"success\", \"fail\"},\n   729→\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/hello.sh\"},\n   730→\t}\n   731→\n   732→\tresult, err := executor.Execute(context.Background(), step)\n   733→\trequire.NoError(t, err)\n   734→\tassert.Equal(t, \"success\", result)\n   735→\n   736→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"hello.out\"))\n   737→\trequire.NoError(t, err)\n   738→\tassert.Contains(t, string(data), \"from-main\")\n   739→\tassert.NotContains(t, string(data), \"from-branch\")\n   740→}\n   741→\n   742→func TestExecutor_ScriptStep_FallsBackToProjectDir(t *testing.T) {\n   743→\t// When MainDir is empty, scripts resolve from ProjectDir.\n   744→\tprojectDir := t.TempDir()\n   745→\toutputDir := filepath.Join(projectDir, \"output\")\n   746→\n   747→\texecutor := &Executor{\n   748→\t\tProjectDir: projectDir,\n   749→\t\tOutputDir:  outputDir,\n   750→\t}\n   751→\n   752→\tstep := &domain.Step{\n   753→\t\tName:    \"pwd-check\",\n   754→\t\tType:    domain.StepTypeScript,\n   755→\t\tResults: []string{\"success\", \"fail\"},\n   756→\t\tConfig:  map[string]string{\"run\": \"pwd\"},\n   757→\t}\n   758→\n   759→\tresult, err := executor.Execute(context.Background(), step)\n   760→\trequire.NoError(t, err)\n   761→\tassert.Equal(t, \"success\", result)\n   762→\n   763→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"pwd-check.out\"))\n   764→\trequire.NoError(t, err)\n   765→\tassert.Contains(t, string(data), projectDir)\n   766→}\n   767→\n   768→func TestExecutor_ScriptStep_ProjectDirEnvVar(t *testing.T) {\n   769→\t// CLOCHE_PROJECT_DIR should always point to ProjectDir, not MainDir.\n   770→\tprojectDir := t.TempDir()\n   771→\tmainDir := t.TempDir()\n   772→\toutputDir := filepath.Join(projectDir, \"output\")\n   773→\n   774→\texecutor := &Executor{\n   775→\t\tProjectDir: projectDir,\n   776→\t\tMainDir:    mainDir,\n   777→\t\tOutputDir:  outputDir,\n   778→\t}\n   779→\n   780→\tstep := &domain.Step{\n   781→\t\tName:    \"env-check\",\n   782→\t\tType:    domain.StepTypeScript,\n   783→\t\tResults: []string{\"success\", \"fail\"},\n   784→\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n   785→\t}\n   786→\n   787→\tresult, err := executor.Execute(context.Background(), step)\n   788→\trequire.NoError(t, err)\n   789→\tassert.Equal(t, \"success\", result)\n   790→\n   791→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n   792→\trequire.NoError(t, err)\n   793→\tassert.Contains(t, string(data), projectDir)\n   794→\tassert.NotContains(t, string(data), mainDir)\n   795→}\n   796→\n   797→func TestMainWorktreeDir_NonGitDir(t *testing.T) {\n   798→\ttmpDir := t.TempDir()\n   799→\t// Non-git directory should fall back to projectDir.\n   800→\tresult := MainWorktreeDir(tmpDir)\n   801→\tassert.Equal(t, tmpDir, result)\n   802→}\n   803→\n   804→func TestMainWorktreeDir_WithWorktree(t *testing.T) {\n   805→\t// Set up a real git repo with a linked worktree.\n   806→\tmainDir := t.TempDir()\n   807→\n   808→\t// Initialize git repo\n   809→\trun := func(dir string, args ...string) {\n   810→\t\tt.Helper()\n   811→\t\tcmd := exec.Command(args[0], args[1:]...)\n   812→\t\tcmd.Dir = dir\n   813→\t\tout, err := cmd.CombinedOutput()\n   814→\t\trequire.NoError(t, err, \"command %v failed: %s\", args, out)\n   815→\t}\n   816→\n   817→\trun(mainDir, \"git\", \"init\")\n   818→\trun(mainDir, \"git\", \"config\", \"user.email\", \"test@test.com\")\n   819→\trun(mainDir, \"git\", \"config\", \"user.name\", \"Test\")\n   820→\trequire.NoError(t, os.WriteFile(filepath.Join(mainDir, \"file.txt\"), []byte(\"hello\"), 0644))\n   821→\trun(mainDir, \"git\", \"add\", \".\")\n   822→\trun(mainDir, \"git\", \"commit\", \"-m\", \"initial\")\n   823→\n   824→\t// Create a branch and worktree\n   825→\tworktreeDir := filepath.Join(t.TempDir(), \"wt\")\n   826→\trun(mainDir, \"git\", \"worktree\", \"add\", worktreeDir, \"-b\", \"feature\")\n   827→\n   828→\t// MainWorktreeDir from the linked worktree should return mainDir.\n   829→\tresult := MainWorktreeDir(worktreeDir)\n   830→\tassert.Equal(t, mainDir, result)\n   831→\n   832→\t// MainWorktreeDir from main should return mainDir.\n   833→\tresult = MainWorktreeDir(mainDir)\n   834→\tassert.Equal(t, mainDir, result)\n   835→}\n   836→\n   837→func TestRunner_PersistsHostRunOnFailure(t *testing.T) {\n   838→\ttmpDir := t.TempDir()\n   839→\n   840→\t// Write a host.cloche that will fail\n   841→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   842→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   843→\thostCloche := `workflow \"main\" {\n   844→  step bad {\n   845→    run     = \"exit 1\"\n   846→    results = [success, fail]\n   847→  }\n   848→\n   849→  bad:success -> done\n   850→  bad:fail    -> abort\n   851→}`\n   852→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   853→\n   854→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   855→\n   856→\trunner := &Runner{\n   857→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   858→\t\tStore:      store,\n   859→\t}\n   860→\n   861→\tresult, err := runner.Run(context.Background(), tmpDir)\n   862→\trequire.NoError(t, err)\n   863→\tassert.Equal(t, domain.RunStateFailed, result.State)\n   864→\n   865→\t// Verify the host run was persisted with failed state\n   866→\thostRun, err := store.GetRun(context.Background(), result.RunID)\n   867→\trequire.NoError(t, err)\n   868→\tassert.True(t, hostRun.IsHost)\n   869→\tassert.Equal(t, domain.RunStateFailed, hostRun.State)\n   870→\tassert.False(t, hostRun.CompletedAt.IsZero())\n   871→}\n   872→"}]},"parent_tool_use_id":null,"session_id":"175df06c-fcc9-44aa-9a28-027165407de1","uuid":"94885e40-00bb-43a8-be37-17e14e4626f8","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor_test.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// fakeDispatcher records dispatch calls and returns a predetermined run ID.\ntype fakeDispatcher struct {\n\tcalls     []*pb.RunWorkflowRequest\n\trunID     string\n\treturnErr error\n}\n\nfunc (f *fakeDispatcher) RunWorkflow(_ context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tf.calls = append(f.calls, req)\n\tif f.returnErr != nil {\n\t\treturn nil, f.returnErr\n\t}\n\treturn &pb.RunWorkflowResponse{RunId: f.runID}, nil\n}\n\n// fakeStore returns a predetermined run on GetRun.\ntype fakeStore struct {\n\truns map[string]*domain.Run\n}\n\nfunc (f *fakeStore) CreateRun(_ context.Context, run *domain.Run) error {\n\tf.runs[run.ID] = run\n\treturn nil\n}\nfunc (f *fakeStore) GetRun(_ context.Context, id string) (*domain.Run, error) {\n\tif r, ok := f.runs[id]; ok {\n\t\treturn r, nil\n\t}\n\treturn nil, os.ErrNotExist\n}\nfunc (f *fakeStore) UpdateRun(_ context.Context, run *domain.Run) error {\n\tf.runs[run.ID] = run\n\treturn nil\n}\nfunc (f *fakeStore) DeleteRun(_ context.Context, id string) error {\n\tdelete(f.runs, id)\n\treturn nil\n}\nfunc (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListChildRuns(_ context.Context, parentRunID string) ([]*domain.Run, error) {\n\tvar children []*domain.Run\n\tfor _, r := range f.runs {\n\t\tif r.ParentRunID == parentRunID {\n\t\t\tchildren = append(children, r)\n\t\t}\n\t}\n\treturn children, nil\n}\n\nfunc TestExecutor_ScriptStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"greet\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Check output was written\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"hello\")\n}\n\nfunc TestExecutor_ScriptStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"bad\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"marker\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"custom\", result)\n\n\t// Marker line should be stripped from output\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n\trequire.NoError(t, err)\n\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n\tassert.Contains(t, string(data), \"some output\")\n}\n\nfunc TestExecutor_WorkflowStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\tassert.Len(t, dispatcher.calls, 1)\n\tassert.Equal(t, \"develop\", dispatcher.calls[0].WorkflowName)\n\tassert.Equal(t, tmpDir, dispatcher.calls[0].ProjectDir)\n}\n\nfunc TestExecutor_WorkflowStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateFailed,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_WorkflowStep_PassesPrompt(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\t// Write a previous step's output\n\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"workflow_name\": \"develop\",\n\t\t\t\"prompt_step\":   \"prepare-prompt\",\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n}\n\nfunc TestEngine_HostWorkflow_Linear(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n\t\t\t},\n\t\t\t\"develop\": {\n\t\t\t\tName:    \"develop\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t\t\"merge\": {\n\t\t\t\tName:    \"merge\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\tassert.Len(t, dispatcher.calls, 1)\n}\n\nfunc TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n\t\t\t},\n\t\t\t\"develop\": {\n\t\t\t\tName:    \"develop\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n}\n\nfunc TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"env-check\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), tmpDir)\n}\n\nfunc TestExecutor_ScriptStep_NoOutputMappings(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{From: \"step-a\", Result: \"success\", To: \"step-b\"},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"step-b\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_JSONFields(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write source step output as JSON\n\tsourceJSON := `{\"title\": \"Fix bug\", \"priority\": \"high\"}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"get-tasks.out\"), []byte(sourceJSON), 0644))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"get-tasks\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"use-tasks\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"TASK_TITLE\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"title\"}}},\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"TASK_PRIORITY\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"priority\"}}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"use-tasks\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $TASK_TITLE $TASK_PRIORITY\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"use-tasks.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"Fix bug\")\n\tassert.Contains(t, string(data), \"high\")\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_ArrayIndex(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write source step output as JSON array\n\tsourceJSON := `[{\"id\": \"task-1\", \"title\": \"First\"}, {\"id\": \"task-2\", \"title\": \"Second\"}]`\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"list-tasks.out\"), []byte(sourceJSON), 0644))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"list-tasks\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"process\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"FIRST_ID\",\n\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 0},\n\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"id\"},\n\t\t\t\t\t\t}},\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"SECOND_TITLE\",\n\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 1},\n\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"title\"},\n\t\t\t\t\t\t}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"process\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $FIRST_ID $SECOND_TITLE\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"process.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"task-1\")\n\tassert.Contains(t, string(data), \"Second\")\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_MissingSourceOutput(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// No source output file written\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"missing-step\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"consumer\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"VAL\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"consumer\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\t_, err := executor.Execute(context.Background(), step)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"reading output of missing-step\")\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_NotJSON(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write non-JSON output\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"plain.out\"), []byte(\"not json\"), 0644))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"plain\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"consumer\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"VAL\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"consumer\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\t_, err := executor.Execute(context.Background(), step)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"not valid JSON\")\n}\n\nfunc TestRunner_RunWithID(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Write a simple host.cloche\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  step greet {\n    run     = \"echo hi\"\n    results = [success, fail]\n  }\n\n  greet:success -> done\n  greet:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tcustomID := \"my-custom-run-id\"\n\tresult, err := runner.RunWithID(context.Background(), tmpDir, customID)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n\tassert.Equal(t, customID, result.RunID, \"RunWithID should use the provided ID\")\n\n\t// Verify the run was persisted with the custom ID\n\thostRun, err := store.GetRun(context.Background(), customID)\n\trequire.NoError(t, err)\n\tassert.True(t, hostRun.IsHost)\n\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n}\n\nfunc TestRunner_PersistsHostRun(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Write a simple host.cloche\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  step prepare {\n    run     = \"echo prepared\"\n    results = [success, fail]\n  }\n\n  prepare:success -> done\n  prepare:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tresult, err := runner.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n\tassert.NotEmpty(t, result.RunID)\n\n\t// Verify the host run was persisted in the store\n\thostRun, err := store.GetRun(context.Background(), result.RunID)\n\trequire.NoError(t, err)\n\tassert.True(t, hostRun.IsHost, \"host run should have IsHost=true\")\n\tassert.Equal(t, tmpDir, hostRun.ProjectDir)\n\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n\tassert.False(t, hostRun.StartedAt.IsZero())\n\tassert.False(t, hostRun.CompletedAt.IsZero())\n}\n\nfunc TestExecutor_ScriptStep_UsesMainDir(t *testing.T) {\n\t// ProjectDir has no script; MainDir has the script.\n\tprojectDir := t.TempDir()\n\tmainDir := t.TempDir()\n\toutputDir := filepath.Join(projectDir, \"output\")\n\n\t// Create a script only in mainDir\n\tscriptDir := filepath.Join(mainDir, \".cloche\", \"scripts\")\n\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n\trequire.NoError(t, os.WriteFile(\n\t\tfilepath.Join(scriptDir, \"greet.sh\"),\n\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n\t\t0755,\n\t))\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tMainDir:    mainDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"greet\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/greet.sh\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"from-main\")\n}\n\nfunc TestExecutor_ScriptStep_MainDirOverridesProjectDir(t *testing.T) {\n\t// Both dirs have a script with different content; MainDir's version wins.\n\tprojectDir := t.TempDir()\n\tmainDir := t.TempDir()\n\toutputDir := filepath.Join(projectDir, \"output\")\n\n\t// Create script in both dirs with different content\n\tfor _, dir := range []string{projectDir, mainDir} {\n\t\tscriptDir := filepath.Join(dir, \".cloche\", \"scripts\")\n\t\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n\t}\n\trequire.NoError(t, os.WriteFile(\n\t\tfilepath.Join(projectDir, \".cloche\", \"scripts\", \"hello.sh\"),\n\t\t[]byte(\"#!/bin/sh\\necho from-branch\"),\n\t\t0755,\n\t))\n\trequire.NoError(t, os.WriteFile(\n\t\tfilepath.Join(mainDir, \".cloche\", \"scripts\", \"hello.sh\"),\n\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n\t\t0755,\n\t))\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tMainDir:    mainDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"hello\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/hello.sh\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"hello.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"from-main\")\n\tassert.NotContains(t, string(data), \"from-branch\")\n}\n\nfunc TestExecutor_ScriptStep_FallsBackToProjectDir(t *testing.T) {\n\t// When MainDir is empty, scripts resolve from ProjectDir.\n\tprojectDir := t.TempDir()\n\toutputDir := filepath.Join(projectDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"pwd-check\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"pwd\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"pwd-check.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), projectDir)\n}\n\nfunc TestExecutor_ScriptStep_ProjectDirEnvVar(t *testing.T) {\n\t// CLOCHE_PROJECT_DIR should always point to ProjectDir, not MainDir.\n\tprojectDir := t.TempDir()\n\tmainDir := t.TempDir()\n\toutputDir := filepath.Join(projectDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tMainDir:    mainDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"env-check\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), projectDir)\n\tassert.NotContains(t, string(data), mainDir)\n}\n\nfunc TestMainWorktreeDir_NonGitDir(t *testing.T) {\n\ttmpDir := t.TempDir()\n\t// Non-git directory should fall back to projectDir.\n\tresult := MainWorktreeDir(tmpDir)\n\tassert.Equal(t, tmpDir, result)\n}\n\nfunc TestMainWorktreeDir_WithWorktree(t *testing.T) {\n\t// Set up a real git repo with a linked worktree.\n\tmainDir := t.TempDir()\n\n\t// Initialize git repo\n\trun := func(dir string, args ...string) {\n\t\tt.Helper()\n\t\tcmd := exec.Command(args[0], args[1:]...)\n\t\tcmd.Dir = dir\n\t\tout, err := cmd.CombinedOutput()\n\t\trequire.NoError(t, err, \"command %v failed: %s\", args, out)\n\t}\n\n\trun(mainDir, \"git\", \"init\")\n\trun(mainDir, \"git\", \"config\", \"user.email\", \"test@test.com\")\n\trun(mainDir, \"git\", \"config\", \"user.name\", \"Test\")\n\trequire.NoError(t, os.WriteFile(filepath.Join(mainDir, \"file.txt\"), []byte(\"hello\"), 0644))\n\trun(mainDir, \"git\", \"add\", \".\")\n\trun(mainDir, \"git\", \"commit\", \"-m\", \"initial\")\n\n\t// Create a branch and worktree\n\tworktreeDir := filepath.Join(t.TempDir(), \"wt\")\n\trun(mainDir, \"git\", \"worktree\", \"add\", worktreeDir, \"-b\", \"feature\")\n\n\t// MainWorktreeDir from the linked worktree should return mainDir.\n\tresult := MainWorktreeDir(worktreeDir)\n\tassert.Equal(t, mainDir, result)\n\n\t// MainWorktreeDir from main should return mainDir.\n\tresult = MainWorktreeDir(mainDir)\n\tassert.Equal(t, mainDir, result)\n}\n\nfunc TestRunner_PersistsHostRunOnFailure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Write a host.cloche that will fail\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  step bad {\n    run     = \"exit 1\"\n    results = [success, fail]\n  }\n\n  bad:success -> done\n  bad:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tresult, err := runner.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, result.State)\n\n\t// Verify the host run was persisted with failed state\n\thostRun, err := store.GetRun(context.Background(), result.RunID)\n\trequire.NoError(t, err)\n\tassert.True(t, hostRun.IsHost)\n\tassert.Equal(t, domain.RunStateFailed, hostRun.State)\n\tassert.False(t, hostRun.CompletedAt.IsZero())\n}\n","numLines":872,"startLine":1,"totalLines":872}}}
