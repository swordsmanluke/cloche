{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015eAgiJPJWnzbZSvqJkQGFJ","type":"tool_result","content":"     1→package logstream\n     2→\n     3→import (\n     4→\t\"encoding/json\"\n     5→\t\"fmt\"\n     6→\t\"strings\"\n     7→\t\"testing\"\n     8→\n     9→\t\"github.com/stretchr/testify/assert\"\n    10→)\n    11→\n    12→// --- Claude Code JSON format (type: \"assistant\", \"system\", \"user\") ---\n    13→\n    14→func TestParseClaudeLine_AssistantText(t *testing.T) {\n    15→\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"I'll read the file.\"}]}}`\n    16→\ttext, ok := ParseClaudeLine([]byte(line))\n    17→\tassert.True(t, ok)\n    18→\tassert.Contains(t, text, \"I'll read the file.\")\n    19→}\n    20→\n    21→func TestParseClaudeLine_AssistantToolUse(t *testing.T) {\n    22→\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"Let me check.\"},{\"type\":\"tool_use\",\"name\":\"Read\",\"input\":{\"file_path\":\"/workspace/main.go\"}}]}}`\n    23→\ttext, ok := ParseClaudeLine([]byte(line))\n    24→\tassert.True(t, ok)\n    25→\tassert.Contains(t, text, \"Let me check.\")\n    26→\tassert.Contains(t, text, \"--- Tool: Read('/workspace/main.go') ---\")\n    27→}\n    28→\n    29→func TestParseClaudeLine_AssistantToolOnly(t *testing.T) {\n    30→\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Bash\",\"input\":{\"command\":\"ls -al\"}}]}}`\n    31→\ttext, ok := ParseClaudeLine([]byte(line))\n    32→\tassert.True(t, ok)\n    33→\tassert.Contains(t, text, \"--- Tool: Bash('ls -al') ---\")\n    34→}\n    35→\n    36→func TestParseClaudeLine_AssistantToolNoInput(t *testing.T) {\n    37→\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Bash\"}]}}`\n    38→\ttext, ok := ParseClaudeLine([]byte(line))\n    39→\tassert.True(t, ok)\n    40→\tassert.Contains(t, text, \"--- Tool: Bash ---\")\n    41→}\n    42→\n    43→func TestParseClaudeLine_AssistantEmptyContent(t *testing.T) {\n    44→\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[]}}`\n    45→\t_, ok := ParseClaudeLine([]byte(line))\n    46→\tassert.False(t, ok)\n    47→}\n    48→\n    49→func TestParseClaudeLine_SystemEvent(t *testing.T) {\n    50→\tline := `{\"type\":\"system\",\"subtype\":\"init\",\"cwd\":\"/workspace\"}`\n    51→\t_, ok := ParseClaudeLine([]byte(line))\n    52→\tassert.False(t, ok)\n    53→}\n    54→\n    55→func TestParseClaudeLine_UserEvent(t *testing.T) {\n    56→\tline := `{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"type\":\"tool_result\",\"content\":\"ok\"}]}}`\n    57→\t_, ok := ParseClaudeLine([]byte(line))\n    58→\tassert.False(t, ok)\n    59→}\n    60→\n    61→// --- Streaming API format (content_block_delta, content_block_start) ---\n    62→\n    63→func TestParseClaudeLine_TextDelta(t *testing.T) {\n    64→\tline := `{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Hello!\"}}`\n    65→\ttext, ok := ParseClaudeLine([]byte(line))\n    66→\tassert.True(t, ok)\n    67→\tassert.Equal(t, \"Hello!\", text)\n    68→}\n    69→\n    70→func TestParseClaudeLine_ToolUseBlockStart(t *testing.T) {\n    71→\tline := `{\"type\":\"content_block_start\",\"index\":1,\"content_block\":{\"type\":\"tool_use\",\"id\":\"t1\",\"name\":\"Read\",\"input\":{}}}`\n    72→\ttext, ok := ParseClaudeLine([]byte(line))\n    73→\tassert.True(t, ok)\n    74→\t// content_block_start typically has empty input, so just tool name\n    75→\tassert.Contains(t, text, \"--- Tool: Read ---\")\n    76→}\n    77→\n    78→func TestParseClaudeLine_ToolUseBlockStartWithInput(t *testing.T) {\n    79→\tline := `{\"type\":\"content_block_start\",\"index\":1,\"content_block\":{\"type\":\"tool_use\",\"id\":\"t1\",\"name\":\"Read\",\"input\":{\"file_path\":\"/workspace/go.mod\"}}}`\n    80→\ttext, ok := ParseClaudeLine([]byte(line))\n    81→\tassert.True(t, ok)\n    82→\tassert.Contains(t, text, \"--- Tool: Read('/workspace/go.mod') ---\")\n    83→}\n    84→\n    85→func TestParseClaudeLine_ProtocolEvent(t *testing.T) {\n    86→\tline := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_01\"}}`\n    87→\t_, ok := ParseClaudeLine([]byte(line))\n    88→\tassert.False(t, ok)\n    89→}\n    90→\n    91→func TestParseClaudeLine_NonJSON(t *testing.T) {\n    92→\ttext, ok := ParseClaudeLine([]byte(\"plain text\"))\n    93→\tassert.True(t, ok)\n    94→\tassert.Equal(t, \"plain text\", text)\n    95→}\n    96→\n    97→func TestParseClaudeLine_Empty(t *testing.T) {\n    98→\t_, ok := ParseClaudeLine([]byte(\"\"))\n    99→\tassert.False(t, ok)\n   100→}\n   101→\n   102→// --- formatToolCall ---\n   103→\n   104→func TestFormatToolCall_Bash(t *testing.T) {\n   105→\tinput := json.RawMessage(`{\"command\":\"go test ./...\",\"description\":\"Run tests\"}`)\n   106→\tassert.Equal(t, \"Bash('go test ./...')\", formatToolCall(\"Bash\", input))\n   107→}\n   108→\n   109→func TestFormatToolCall_Read(t *testing.T) {\n   110→\tinput := json.RawMessage(`{\"file_path\":\"/workspace/main.go\"}`)\n   111→\tassert.Equal(t, \"Read('/workspace/main.go')\", formatToolCall(\"Read\", input))\n   112→}\n   113→\n   114→func TestFormatToolCall_Edit(t *testing.T) {\n   115→\tinput := json.RawMessage(`{\"file_path\":\"/workspace/main.go\",\"old_string\":\"foo\",\"new_string\":\"bar\"}`)\n   116→\tassert.Equal(t, \"Edit('/workspace/main.go')\", formatToolCall(\"Edit\", input))\n   117→}\n   118→\n   119→func TestFormatToolCall_Glob(t *testing.T) {\n   120→\tinput := json.RawMessage(`{\"pattern\":\"**/*.go\"}`)\n   121→\tassert.Equal(t, \"Glob('**/*.go')\", formatToolCall(\"Glob\", input))\n   122→}\n   123→\n   124→func TestFormatToolCall_Grep(t *testing.T) {\n   125→\tinput := json.RawMessage(`{\"pattern\":\"func main\",\"path\":\"/workspace\"}`)\n   126→\tassert.Equal(t, \"Grep('func main')\", formatToolCall(\"Grep\", input))\n   127→}\n   128→\n   129→func TestFormatToolCall_Agent(t *testing.T) {\n   130→\tinput := json.RawMessage(`{\"description\":\"Find test files\",\"prompt\":\"Search for test files\"}`)\n   131→\tassert.Equal(t, \"Agent('Find test files')\", formatToolCall(\"Agent\", input))\n   132→}\n   133→\n   134→func TestFormatToolCall_NilInput(t *testing.T) {\n   135→\tassert.Equal(t, \"Bash\", formatToolCall(\"Bash\", nil))\n   136→}\n   137→\n   138→func TestFormatToolCall_EmptyInput(t *testing.T) {\n   139→\tinput := json.RawMessage(`{}`)\n   140→\tassert.Equal(t, \"Read\", formatToolCall(\"Read\", input))\n   141→}\n   142→\n   143→func TestFormatToolCall_UnknownToolWithCommand(t *testing.T) {\n   144→\tinput := json.RawMessage(`{\"command\":\"do-something\"}`)\n   145→\tassert.Equal(t, \"CustomTool('do-something')\", formatToolCall(\"CustomTool\", input))\n   146→}\n   147→\n   148→func TestFormatToolCall_UnknownToolNoKnownParam(t *testing.T) {\n   149→\tinput := json.RawMessage(`{\"foo\":\"bar\"}`)\n   150→\tassert.Equal(t, \"CustomTool\", formatToolCall(\"CustomTool\", input))\n   151→}\n   152→\n   153→func TestFormatToolCall_LongCommandTruncated(t *testing.T) {\n   154→\tlong := strings.Repeat(\"x\", 100)\n   155→\tinput := json.RawMessage(`{\"command\":\"` + long + `\"}`)\n   156→\tresult := formatToolCall(\"Bash\", input)\n   157→\tassert.Contains(t, result, \"...\")\n   158→\t// 80 chars + \"...\" = truncated\n   159→\tassert.Equal(t, fmt.Sprintf(\"Bash('%s...')\", long[:80]), result)\n   160→}\n   161→\n   162→// --- ParseClaudeStream ---\n   163→\n   164→func TestParseClaudeStream_AssistantMessages(t *testing.T) {\n   165→\tinput := `{\"type\":\"system\",\"subtype\":\"init\",\"cwd\":\"/workspace\"}\n   166→{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"I'll implement the feature.\"}]}}\n   167→{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"type\":\"tool_result\",\"content\":\"ok\"}]}}\n   168→{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Edit\",\"input\":{\"file_path\":\"/workspace/main.go\",\"old_string\":\"foo\",\"new_string\":\"bar\"}},{\"type\":\"text\",\"text\":\"Done editing.\"}]}}\n   169→`\n   170→\tresult := string(ParseClaudeStream([]byte(input)))\n   171→\tassert.Contains(t, result, \"I'll implement the feature.\")\n   172→\tassert.Contains(t, result, \"--- Tool: Edit('/workspace/main.go') ---\")\n   173→\tassert.Contains(t, result, \"Done editing.\")\n   174→\tassert.NotContains(t, result, \"system\")\n   175→\tassert.NotContains(t, result, \"tool_result\")\n   176→}\n   177→\n   178→func TestParseClaudeStream_TextDeltas(t *testing.T) {\n   179→\tinput := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_01\",\"type\":\"message\",\"role\":\"assistant\"}}\n   180→{\"type\":\"content_block_start\",\"index\":0,\"content_block\":{\"type\":\"text\",\"text\":\"\"}}\n   181→{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Hello, \"}}\n   182→{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"world!\"}}\n   183→{\"type\":\"content_block_stop\",\"index\":0}\n   184→{\"type\":\"message_delta\",\"delta\":{\"stop_reason\":\"end_turn\"}}\n   185→{\"type\":\"message_stop\"}\n   186→`\n   187→\tresult := ParseClaudeStream([]byte(input))\n   188→\tassert.Equal(t, \"Hello, world!\", string(result))\n   189→}\n   190→\n   191→func TestParseClaudeStream_ResultEvent(t *testing.T) {\n   192→\tinput := `{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Done.\\n\"}}\n   193→{\"type\":\"result\",\"subtype\":\"success\",\"result\":\"Done.\\nCLOCHE_RESULT:success\"}\n   194→`\n   195→\tresult := string(ParseClaudeStream([]byte(input)))\n   196→\tassert.Contains(t, result, \"Done.\\n\")\n   197→\tassert.Contains(t, result, \"CLOCHE_RESULT:success\")\n   198→}\n   199→\n   200→func TestParseClaudeStream_NonJSON(t *testing.T) {\n   201→\tinput := \"This is plain text output\\nfrom a script step\\n\"\n   202→\tresult := ParseClaudeStream([]byte(input))\n   203→\tassert.Equal(t, input, string(result))\n   204→}\n   205→\n   206→func TestParseClaudeStream_Empty(t *testing.T) {\n   207→\tresult := ParseClaudeStream([]byte(\"\"))\n   208→\tassert.Equal(t, \"\", string(result))\n   209→}\n   210→"}]},"parent_tool_use_id":null,"session_id":"58c8b1f7-3f5a-4b6a-8e44-d03a95e09c20","uuid":"2c9aac9e-6618-4dc9-b721-8a7c208f05b8","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/logstream/parse_test.go","content":"package logstream\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n)\n\n// --- Claude Code JSON format (type: \"assistant\", \"system\", \"user\") ---\n\nfunc TestParseClaudeLine_AssistantText(t *testing.T) {\n\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"I'll read the file.\"}]}}`\n\ttext, ok := ParseClaudeLine([]byte(line))\n\tassert.True(t, ok)\n\tassert.Contains(t, text, \"I'll read the file.\")\n}\n\nfunc TestParseClaudeLine_AssistantToolUse(t *testing.T) {\n\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"Let me check.\"},{\"type\":\"tool_use\",\"name\":\"Read\",\"input\":{\"file_path\":\"/workspace/main.go\"}}]}}`\n\ttext, ok := ParseClaudeLine([]byte(line))\n\tassert.True(t, ok)\n\tassert.Contains(t, text, \"Let me check.\")\n\tassert.Contains(t, text, \"--- Tool: Read('/workspace/main.go') ---\")\n}\n\nfunc TestParseClaudeLine_AssistantToolOnly(t *testing.T) {\n\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Bash\",\"input\":{\"command\":\"ls -al\"}}]}}`\n\ttext, ok := ParseClaudeLine([]byte(line))\n\tassert.True(t, ok)\n\tassert.Contains(t, text, \"--- Tool: Bash('ls -al') ---\")\n}\n\nfunc TestParseClaudeLine_AssistantToolNoInput(t *testing.T) {\n\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Bash\"}]}}`\n\ttext, ok := ParseClaudeLine([]byte(line))\n\tassert.True(t, ok)\n\tassert.Contains(t, text, \"--- Tool: Bash ---\")\n}\n\nfunc TestParseClaudeLine_AssistantEmptyContent(t *testing.T) {\n\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[]}}`\n\t_, ok := ParseClaudeLine([]byte(line))\n\tassert.False(t, ok)\n}\n\nfunc TestParseClaudeLine_SystemEvent(t *testing.T) {\n\tline := `{\"type\":\"system\",\"subtype\":\"init\",\"cwd\":\"/workspace\"}`\n\t_, ok := ParseClaudeLine([]byte(line))\n\tassert.False(t, ok)\n}\n\nfunc TestParseClaudeLine_UserEvent(t *testing.T) {\n\tline := `{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"type\":\"tool_result\",\"content\":\"ok\"}]}}`\n\t_, ok := ParseClaudeLine([]byte(line))\n\tassert.False(t, ok)\n}\n\n// --- Streaming API format (content_block_delta, content_block_start) ---\n\nfunc TestParseClaudeLine_TextDelta(t *testing.T) {\n\tline := `{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Hello!\"}}`\n\ttext, ok := ParseClaudeLine([]byte(line))\n\tassert.True(t, ok)\n\tassert.Equal(t, \"Hello!\", text)\n}\n\nfunc TestParseClaudeLine_ToolUseBlockStart(t *testing.T) {\n\tline := `{\"type\":\"content_block_start\",\"index\":1,\"content_block\":{\"type\":\"tool_use\",\"id\":\"t1\",\"name\":\"Read\",\"input\":{}}}`\n\ttext, ok := ParseClaudeLine([]byte(line))\n\tassert.True(t, ok)\n\t// content_block_start typically has empty input, so just tool name\n\tassert.Contains(t, text, \"--- Tool: Read ---\")\n}\n\nfunc TestParseClaudeLine_ToolUseBlockStartWithInput(t *testing.T) {\n\tline := `{\"type\":\"content_block_start\",\"index\":1,\"content_block\":{\"type\":\"tool_use\",\"id\":\"t1\",\"name\":\"Read\",\"input\":{\"file_path\":\"/workspace/go.mod\"}}}`\n\ttext, ok := ParseClaudeLine([]byte(line))\n\tassert.True(t, ok)\n\tassert.Contains(t, text, \"--- Tool: Read('/workspace/go.mod') ---\")\n}\n\nfunc TestParseClaudeLine_ProtocolEvent(t *testing.T) {\n\tline := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_01\"}}`\n\t_, ok := ParseClaudeLine([]byte(line))\n\tassert.False(t, ok)\n}\n\nfunc TestParseClaudeLine_NonJSON(t *testing.T) {\n\ttext, ok := ParseClaudeLine([]byte(\"plain text\"))\n\tassert.True(t, ok)\n\tassert.Equal(t, \"plain text\", text)\n}\n\nfunc TestParseClaudeLine_Empty(t *testing.T) {\n\t_, ok := ParseClaudeLine([]byte(\"\"))\n\tassert.False(t, ok)\n}\n\n// --- formatToolCall ---\n\nfunc TestFormatToolCall_Bash(t *testing.T) {\n\tinput := json.RawMessage(`{\"command\":\"go test ./...\",\"description\":\"Run tests\"}`)\n\tassert.Equal(t, \"Bash('go test ./...')\", formatToolCall(\"Bash\", input))\n}\n\nfunc TestFormatToolCall_Read(t *testing.T) {\n\tinput := json.RawMessage(`{\"file_path\":\"/workspace/main.go\"}`)\n\tassert.Equal(t, \"Read('/workspace/main.go')\", formatToolCall(\"Read\", input))\n}\n\nfunc TestFormatToolCall_Edit(t *testing.T) {\n\tinput := json.RawMessage(`{\"file_path\":\"/workspace/main.go\",\"old_string\":\"foo\",\"new_string\":\"bar\"}`)\n\tassert.Equal(t, \"Edit('/workspace/main.go')\", formatToolCall(\"Edit\", input))\n}\n\nfunc TestFormatToolCall_Glob(t *testing.T) {\n\tinput := json.RawMessage(`{\"pattern\":\"**/*.go\"}`)\n\tassert.Equal(t, \"Glob('**/*.go')\", formatToolCall(\"Glob\", input))\n}\n\nfunc TestFormatToolCall_Grep(t *testing.T) {\n\tinput := json.RawMessage(`{\"pattern\":\"func main\",\"path\":\"/workspace\"}`)\n\tassert.Equal(t, \"Grep('func main')\", formatToolCall(\"Grep\", input))\n}\n\nfunc TestFormatToolCall_Agent(t *testing.T) {\n\tinput := json.RawMessage(`{\"description\":\"Find test files\",\"prompt\":\"Search for test files\"}`)\n\tassert.Equal(t, \"Agent('Find test files')\", formatToolCall(\"Agent\", input))\n}\n\nfunc TestFormatToolCall_NilInput(t *testing.T) {\n\tassert.Equal(t, \"Bash\", formatToolCall(\"Bash\", nil))\n}\n\nfunc TestFormatToolCall_EmptyInput(t *testing.T) {\n\tinput := json.RawMessage(`{}`)\n\tassert.Equal(t, \"Read\", formatToolCall(\"Read\", input))\n}\n\nfunc TestFormatToolCall_UnknownToolWithCommand(t *testing.T) {\n\tinput := json.RawMessage(`{\"command\":\"do-something\"}`)\n\tassert.Equal(t, \"CustomTool('do-something')\", formatToolCall(\"CustomTool\", input))\n}\n\nfunc TestFormatToolCall_UnknownToolNoKnownParam(t *testing.T) {\n\tinput := json.RawMessage(`{\"foo\":\"bar\"}`)\n\tassert.Equal(t, \"CustomTool\", formatToolCall(\"CustomTool\", input))\n}\n\nfunc TestFormatToolCall_LongCommandTruncated(t *testing.T) {\n\tlong := strings.Repeat(\"x\", 100)\n\tinput := json.RawMessage(`{\"command\":\"` + long + `\"}`)\n\tresult := formatToolCall(\"Bash\", input)\n\tassert.Contains(t, result, \"...\")\n\t// 80 chars + \"...\" = truncated\n\tassert.Equal(t, fmt.Sprintf(\"Bash('%s...')\", long[:80]), result)\n}\n\n// --- ParseClaudeStream ---\n\nfunc TestParseClaudeStream_AssistantMessages(t *testing.T) {\n\tinput := `{\"type\":\"system\",\"subtype\":\"init\",\"cwd\":\"/workspace\"}\n{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"I'll implement the feature.\"}]}}\n{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"type\":\"tool_result\",\"content\":\"ok\"}]}}\n{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Edit\",\"input\":{\"file_path\":\"/workspace/main.go\",\"old_string\":\"foo\",\"new_string\":\"bar\"}},{\"type\":\"text\",\"text\":\"Done editing.\"}]}}\n`\n\tresult := string(ParseClaudeStream([]byte(input)))\n\tassert.Contains(t, result, \"I'll implement the feature.\")\n\tassert.Contains(t, result, \"--- Tool: Edit('/workspace/main.go') ---\")\n\tassert.Contains(t, result, \"Done editing.\")\n\tassert.NotContains(t, result, \"system\")\n\tassert.NotContains(t, result, \"tool_result\")\n}\n\nfunc TestParseClaudeStream_TextDeltas(t *testing.T) {\n\tinput := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_01\",\"type\":\"message\",\"role\":\"assistant\"}}\n{\"type\":\"content_block_start\",\"index\":0,\"content_block\":{\"type\":\"text\",\"text\":\"\"}}\n{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Hello, \"}}\n{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"world!\"}}\n{\"type\":\"content_block_stop\",\"index\":0}\n{\"type\":\"message_delta\",\"delta\":{\"stop_reason\":\"end_turn\"}}\n{\"type\":\"message_stop\"}\n`\n\tresult := ParseClaudeStream([]byte(input))\n\tassert.Equal(t, \"Hello, world!\", string(result))\n}\n\nfunc TestParseClaudeStream_ResultEvent(t *testing.T) {\n\tinput := `{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Done.\\n\"}}\n{\"type\":\"result\",\"subtype\":\"success\",\"result\":\"Done.\\nCLOCHE_RESULT:success\"}\n`\n\tresult := string(ParseClaudeStream([]byte(input)))\n\tassert.Contains(t, result, \"Done.\\n\")\n\tassert.Contains(t, result, \"CLOCHE_RESULT:success\")\n}\n\nfunc TestParseClaudeStream_NonJSON(t *testing.T) {\n\tinput := \"This is plain text output\\nfrom a script step\\n\"\n\tresult := ParseClaudeStream([]byte(input))\n\tassert.Equal(t, input, string(result))\n}\n\nfunc TestParseClaudeStream_Empty(t *testing.T) {\n\tresult := ParseClaudeStream([]byte(\"\"))\n\tassert.Equal(t, \"\", string(result))\n}\n","numLines":210,"startLine":1,"totalLines":210}}}
