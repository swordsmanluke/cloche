[2026-03-10T01:30:37Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PsjmWdqLcHxrdirek3X31K","type":"tool_result","content":"     1→package logstream\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"encoding/json\"\n     6→\t\"strings\"\n     7→)\n     8→\n     9→// ParseClaudeLine parses a single Claude Code stream-json line and returns\n    10→// the human-readable text it represents. If the line is a protocol event\n    11→// with no user-visible content, ok is false. Non-JSON input is returned as-is.\n    12→func ParseClaudeLine(line []byte) (text string, ok bool) {\n    13→\tline = bytes.TrimSpace(line)\n    14→\tif len(line) == 0 {\n    15→\t\treturn \"\", false\n    16→\t}\n    17→\tif line[0] != '{' {\n    18→\t\treturn string(line), true\n    19→\t}\n    20→\n    21→\tvar base struct {\n    22→\t\tType string `json:\"type\"`\n    23→\t}\n    24→\tif json.Unmarshal(line, &base) != nil {\n    25→\t\treturn string(line), true\n    26→\t}\n    27→\n    28→\tswitch base.Type {\n    29→\tcase \"assistant\":\n    30→\t\tt := extractAssistantText(line)\n    31→\t\treturn t, t != \"\"\n    32→\tcase \"result\":\n    33→\t\tt := extractResultText(line)\n    34→\t\treturn t, t != \"\"\n    35→\tcase \"content_block_delta\":\n    36→\t\tt := extractDeltaText(line)\n    37→\t\treturn t, t != \"\"\n    38→\tcase \"content_block_start\":\n    39→\t\tt := extractBlockStart(line)\n    40→\t\treturn t, t != \"\"\n    41→\tdefault:\n    42→\t\t// Skip system, user (tool results), and other protocol events\n    43→\t\treturn \"\", false\n    44→\t}\n    45→}\n    46→\n    47→// ParseClaudeStream converts raw Claude Code stream-json output into\n    48→// human-readable text. It extracts assistant text, tool call summaries,\n    49→// and error messages, discarding protocol-level events.\n    50→//\n    51→// If the input does not appear to be stream-json (no valid JSON lines\n    52→// detected), it is returned unchanged.\n    53→func ParseClaudeStream(raw []byte) []byte {\n    54→\tlines := bytes.Split(raw, []byte(\"\\n\"))\n    55→\tvar out strings.Builder\n    56→\tjsonLines := 0\n    57→\n    58→\tfor _, line := range lines {\n    59→\t\tline = bytes.TrimSpace(line)\n    60→\t\tif len(line) == 0 {\n    61→\t\t\tcontinue\n    62→\t\t}\n    63→\n    64→\t\tif line[0] != '{' {\n    65→\t\t\tout.Write(line)\n    66→\t\t\tout.WriteByte('\\n')\n    67→\t\t\tcontinue\n    68→\t\t}\n    69→\n    70→\t\tvar base struct {\n    71→\t\t\tType string `json:\"type\"`\n    72→\t\t}\n    73→\t\tif json.Unmarshal(line, &base) != nil {\n    74→\t\t\tout.Write(line)\n    75→\t\t\tout.WriteByte('\\n')\n    76→\t\t\tcontinue\n    77→\t\t}\n    78→\t\tjsonLines++\n    79→\n    80→\t\tif text, ok := ParseClaudeLine(line); ok {\n    81→\t\t\tout.WriteString(text)\n    82→\t\t}\n    83→\t}\n    84→\n    85→\tif jsonLines == 0 {\n    86→\t\treturn raw\n    87→\t}\n    88→\n    89→\treturn []byte(out.String())\n    90→}\n    91→\n    92→// extractAssistantText handles Claude Code \"assistant\" events.\n    93→// Extracts text content from message.content blocks.\n    94→func extractAssistantText(line []byte) string {\n    95→\tvar event struct {\n    96→\t\tMessage struct {\n    97→\t\t\tContent []struct {\n    98→\t\t\t\tType string `json:\"type\"`\n    99→\t\t\t\tText string `json:\"text\"`\n   100→\t\t\t\tName string `json:\"name\"` // for tool_use blocks\n   101→\t\t\t} `json:\"content\"`\n   102→\t\t} `json:\"message\"`\n   103→\t}\n   104→\tif json.Unmarshal(line, &event) != nil {\n   105→\t\treturn \"\"\n   106→\t}\n   107→\n   108→\tvar parts []string\n   109→\tfor _, block := range event.Message.Content {\n   110→\t\tswitch block.Type {\n   111→\t\tcase \"text\":\n   112→\t\t\tif t := strings.TrimSpace(block.Text); t != \"\" {\n   113→\t\t\t\tparts = append(parts, t)\n   114→\t\t\t}\n   115→\t\tcase \"tool_use\":\n   116→\t\t\tparts = append(parts, \"\\n--- Tool: \"+block.Name+\" ---\")\n   117→\t\t}\n   118→\t}\n   119→\tif len(parts) == 0 {\n   120→\t\treturn \"\"\n   121→\t}\n   122→\treturn strings.Join(parts, \"\\n\") + \"\\n\"\n   123→}\n   124→\n   125→// extractDeltaText handles content_block_delta events (streaming API format).\n   126→func extractDeltaText(line []byte) string {\n   127→\tif bytes.Contains(line, []byte(`\"text_delta\"`)) {\n   128→\t\tvar event struct {\n   129→\t\t\tDelta struct {\n   130→\t\t\t\tType string `json:\"type\"`\n   131→\t\t\t\tText string `json:\"text\"`\n   132→\t\t\t} `json:\"delta\"`\n   133→\t\t}\n   134→\t\tif json.Unmarshal(line, &event) == nil && event.Delta.Type == \"text_delta\" {\n   135→\t\t\treturn event.Delta.Text\n   136→\t\t}\n   137→\t}\n   138→\treturn \"\"\n   139→}\n   140→\n   141→// extractBlockStart handles content_block_start events (streaming API format).\n   142→func extractBlockStart(line []byte) string {\n   143→\tif !bytes.Contains(line, []byte(`\"tool_use\"`)) {\n   144→\t\treturn \"\"\n   145→\t}\n   146→\tvar event struct {\n   147→\t\tContentBlock struct {\n   148→\t\t\tType string `json:\"type\"`\n   149→\t\t\tName string `json:\"name\"`\n   150→\t\t} `json:\"content_block\"`\n   151→\t}\n   152→\tif json.Unmarshal(line, &event) == nil && event.ContentBlock.Type == \"tool_use\" {\n   153→\t\treturn \"\\n--- Tool: \" + event.ContentBlock.Name + \" ---\\n\"\n   154→\t}\n   155→\treturn \"\"\n   156→}\n   157→\n   158→// extractResultText handles result events (final output).\n   159→func extractResultText(line []byte) string {\n   160→\tvar event struct {\n   161→\t\tType   string `json:\"type\"`\n   162→\t\tResult string `json:\"result\"`\n   163→\t}\n   164→\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n   165→\t\treturn event.Result\n   166→\t}\n   167→\treturn \"\"\n   168→}\n   169→"}]},"parent_tool_use_id":"toolu_01Lu7qgwcufs5u4isGeAdHs6","session_id":"9f3f88b7-a9c0-408f-9619-e3d7b92e6b51","uuid":"eb91d3f1-32ec-4aa8-a057-932db4d0a555"}
