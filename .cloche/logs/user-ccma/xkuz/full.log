7→  string step_name = 2;\n    58→  string log_type = 3;\n    59→}\n    60→\n    61→message LogEntry {\n    62→  string type = 1;\n    63→  string step_name = 2;\n    64→  string result = 3;\n    65→  string message = 4;\n    66→  string timestamp = 5;\n    67→}\n    68→\n    69→message StopRunRequest {\n    70→  string run_id = 1;\n    71→}\n    72→\n    73→message StopRunResponse {}\n    74→\n    75→message ShutdownRequest {}\n    76→\n    77→message ShutdownResponse {}\n    78→\n    79→message DeleteContainerRequest {\n    80→  string id = 1;\n    81→}\n    82→\n    83→message DeleteContainerResponse {}\n    84→\n    85→message ListRunsRequest {\n    86→  bool all = 1;\n    87→}\n    88→\n    89→message ListRunsResponse {\n    90→  repeated RunSummary runs = 1;\n    91→}\n    92→\n    93→message RunSummary {\n    94→  string run_id = 1;\n    95→  string workflow_name = 2;\n    96→  string state = 3;\n    97→  string started_at = 4;\n    98→  string error_message = 5;\n    99→  string container_id = 6;\n   100→  string title = 7;\n   101→  bool is_host = 8;\n   102→}\n   103→"}]},"parent_tool_use_id":"toolu_01Lu7qgwcufs5u4isGeAdHs6","session_id":"9f3f88b7-a9c0-408f-9619-e3d7b92e6b51","uuid":"70e1612b-26c0-41a6-9090-817b74a2844f"}
