[2026-03-10T01:30:37Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KZooHGKGGtiDh9nQRF8Gds","type":"tool_result","content":"     1→package logstream\n     2→\n     3→import (\n     4→\t\"testing\"\n     5→\n     6→\t\"github.com/stretchr/testify/assert\"\n     7→)\n     8→\n     9→// --- Claude Code JSON format (type: \"assistant\", \"system\", \"user\") ---\n    10→\n    11→func TestParseClaudeLine_AssistantText(t *testing.T) {\n    12→\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"I'll read the file.\"}]}}`\n    13→\ttext, ok := ParseClaudeLine([]byte(line))\n    14→\tassert.True(t, ok)\n    15→\tassert.Contains(t, text, \"I'll read the file.\")\n    16→}\n    17→\n    18→func TestParseClaudeLine_AssistantToolUse(t *testing.T) {\n    19→\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"Let me check.\"},{\"type\":\"tool_use\",\"name\":\"Read\"}]}}`\n    20→\ttext, ok := ParseClaudeLine([]byte(line))\n    21→\tassert.True(t, ok)\n    22→\tassert.Contains(t, text, \"Let me check.\")\n    23→\tassert.Contains(t, text, \"--- Tool: Read ---\")\n    24→}\n    25→\n    26→func TestParseClaudeLine_AssistantToolOnly(t *testing.T) {\n    27→\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Bash\"}]}}`\n    28→\ttext, ok := ParseClaudeLine([]byte(line))\n    29→\tassert.True(t, ok)\n    30→\tassert.Contains(t, text, \"--- Tool: Bash ---\")\n    31→}\n    32→\n    33→func TestParseClaudeLine_AssistantEmptyContent(t *testing.T) {\n    34→\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[]}}`\n    35→\t_, ok := ParseClaudeLine([]byte(line))\n    36→\tassert.False(t, ok)\n    37→}\n    38→\n    39→func TestParseClaudeLine_SystemEvent(t *testing.T) {\n    40→\tline := `{\"type\":\"system\",\"subtype\":\"init\",\"cwd\":\"/workspace\"}`\n    41→\t_, ok := ParseClaudeLine([]byte(line))\n    42→\tassert.False(t, ok)\n    43→}\n    44→\n    45→func TestParseClaudeLine_UserEvent(t *testing.T) {\n    46→\tline := `{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"type\":\"tool_result\",\"content\":\"ok\"}]}}`\n    47→\t_, ok := ParseClaudeLine([]byte(line))\n    48→\tassert.False(t, ok)\n    49→}\n    50→\n    51→// --- Streaming API format (content_block_delta, content_block_start) ---\n    52→\n    53→func TestParseClaudeLine_TextDelta(t *testing.T) {\n    54→\tline := `{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Hello!\"}}`\n    55→\ttext, ok := ParseClaudeLine([]byte(line))\n    56→\tassert.True(t, ok)\n    57→\tassert.Equal(t, \"Hello!\", text)\n    58→}\n    59→\n    60→func TestParseClaudeLine_ToolUseBlockStart(t *testing.T) {\n    61→\tline := `{\"type\":\"content_block_start\",\"index\":1,\"content_block\":{\"type\":\"tool_use\",\"id\":\"t1\",\"name\":\"Read\",\"input\":{}}}`\n    62→\ttext, ok := ParseClaudeLine([]byte(line))\n    63→\tassert.True(t, ok)\n    64→\tassert.Contains(t, text, \"--- Tool: Read ---\")\n    65→}\n    66→\n    67→func TestParseClaudeLine_ProtocolEvent(t *testing.T) {\n    68→\tline := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_01\"}}`\n    69→\t_, ok := ParseClaudeLine([]byte(line))\n    70→\tassert.False(t, ok)\n    71→}\n    72→\n    73→func TestParseClaudeLine_NonJSON(t *testing.T) {\n    74→\ttext, ok := ParseClaudeLine([]byte(\"plain text\"))\n    75→\tassert.True(t, ok)\n    76→\tassert.Equal(t, \"plain text\", text)\n    77→}\n    78→\n    79→func TestParseClaudeLine_Empty(t *testing.T) {\n    80→\t_, ok := ParseClaudeLine([]byte(\"\"))\n    81→\tassert.False(t, ok)\n    82→}\n    83→\n    84→// --- ParseClaudeStream ---\n    85→\n    86→func TestParseClaudeStream_AssistantMessages(t *testing.T) {\n    87→\tinput := `{\"type\":\"system\",\"subtype\":\"init\",\"cwd\":\"/workspace\"}\n    88→{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"I'll implement the feature.\"}]}}\n    89→{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"type\":\"tool_result\",\"content\":\"ok\"}]}}\n    90→{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Edit\"},{\"type\":\"text\",\"text\":\"Done editing.\"}]}}\n    91→`\n    92→\tresult := string(ParseClaudeStream([]byte(input)))\n    93→\tassert.Contains(t, result, \"I'll implement the feature.\")\n    94→\tassert.Contains(t, result, \"--- Tool: Edit ---\")\n    95→\tassert.Contains(t, result, \"Done editing.\")\n    96→\tassert.NotContains(t, result, \"system\")\n    97→\tassert.NotContains(t, result, \"tool_result\")\n    98→}\n    99→\n   100→func TestParseClaudeStream_TextDeltas(t *testing.T) {\n   101→\tinput := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_01\",\"type\":\"message\",\"role\":\"assistant\"}}\n   102→{\"type\":\"content_block_start\",\"index\":0,\"content_block\":{\"type\":\"text\",\"text\":\"\"}}\n   103→{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Hello, \"}}\n   104→{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"world!\"}}\n   105→{\"type\":\"content_block_stop\",\"index\":0}\n   106→{\"type\":\"message_delta\",\"delta\":{\"stop_reason\":\"end_turn\"}}\n   107→{\"type\":\"message_stop\"}\n   108→`\n   109→\tresult := ParseClaudeStream([]byte(input))\n   110→\tassert.Equal(t, \"Hello, world!\", string(result))\n   111→}\n   112→\n   113→func TestParseClaudeStream_ResultEvent(t *testing.T) {\n   114→\tinput := `{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Done.\\n\"}}\n   115→{\"type\":\"result\",\"subtype\":\"success\",\"result\":\"Done.\\nCLOCHE_RESULT:success\"}\n   116→`\n   117→\tresult := string(ParseClaudeStream([]byte(input)))\n   118→\tassert.Contains(t, result, \"Done.\\n\")\n   119→\tassert.Contains(t, result, \"CLOCHE_RESULT:success\")\n   120→}\n   121→\n   122→func TestParseClaudeStream_NonJSON(t *testing.T) {\n   123→\tinput := \"This is plain text output\\nfrom a script step\\n\"\n   124→\tresult := ParseClaudeStream([]byte(input))\n   125→\tassert.Equal(t, input, string(result))\n   126→}\n   127→\n   128→func TestParseClaudeStream_Empty(t *testing.T) {\n   129→\tresult := ParseClaudeStream([]byte(\"\"))\n   130→\tassert.Equal(t, \"\", string(result))\n   131→}\n   132→"}]},"parent_tool_use_id":null,"session_id":"9f3f88b7-a9c0-408f-9619-e3d7b92e6b51","uuid":"bee6f36b-2b90-49f0-8c8e-2eaef16fd93c","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/logstream/parse_test.go","content":"package logstream\n\nimport (\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n)\n\n// --- Claude Code JSON format (type: \"assistant\", \"system\", \"user\") ---\n\nfunc TestParseClaudeLine_AssistantText(t *testing.T) {\n\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"I'll read the file.\"}]}}`\n\ttext, ok := ParseClaudeLine([]byte(line))\n\tassert.True(t, ok)\n\tassert.Contains(t, text, \"I'll read the file.\")\n}\n\nfunc TestParseClaudeLine_AssistantToolUse(t *testing.T) {\n\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"Let me check.\"},{\"type\":\"tool_use\",\"name\":\"Read\"}]}}`\n\ttext, ok := ParseClaudeLine([]byte(line))\n\tassert.True(t, ok)\n\tassert.Contains(t, text, \"Let me check.\")\n\tassert.Contains(t, text, \"--- Tool: Read ---\")\n}\n\nfunc TestParseClaudeLine_AssistantToolOnly(t *testing.T) {\n\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Bash\"}]}}`\n\ttext, ok := ParseClaudeLine([]byte(line))\n\tassert.True(t, ok)\n\tassert.Contains(t, text, \"--- Tool: Bash ---\")\n}\n\nfunc TestParseClaudeLine_AssistantEmptyContent(t *testing.T) {\n\tline := `{\"type\":\"assistant\",\"message\":{\"content\":[]}}`\n\t_, ok := ParseClaudeLine([]byte(line))\n\tassert.False(t, ok)\n}\n\nfunc TestParseClaudeLine_SystemEvent(t *testing.T) {\n\tline := `{\"type\":\"system\",\"subtype\":\"init\",\"cwd\":\"/workspace\"}`\n\t_, ok := ParseClaudeLine([]byte(line))\n\tassert.False(t, ok)\n}\n\nfunc TestParseClaudeLine_UserEvent(t *testing.T) {\n\tline := `{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"type\":\"tool_result\",\"content\":\"ok\"}]}}`\n\t_, ok := ParseClaudeLine([]byte(line))\n\tassert.False(t, ok)\n}\n\n// --- Streaming API format (content_block_delta, content_block_start) ---\n\nfunc TestParseClaudeLine_TextDelta(t *testing.T) {\n\tline := `{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Hello!\"}}`\n\ttext, ok := ParseClaudeLine([]byte(line))\n\tassert.True(t, ok)\n\tassert.Equal(t, \"Hello!\", text)\n}\n\nfunc TestParseClaudeLine_ToolUseBlockStart(t *testing.T) {\n\tline := `{\"type\":\"content_block_start\",\"index\":1,\"content_block\":{\"type\":\"tool_use\",\"id\":\"t1\",\"name\":\"Read\",\"input\":{}}}`\n\ttext, ok := ParseClaudeLine([]byte(line))\n\tassert.True(t, ok)\n\tassert.Contains(t, text, \"--- Tool: Read ---\")\n}\n\nfunc TestParseClaudeLine_ProtocolEvent(t *testing.T) {\n\tline := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_01\"}}`\n\t_, ok := ParseClaudeLine([]byte(line))\n\tassert.False(t, ok)\n}\n\nfunc TestParseClaudeLine_NonJSON(t *testing.T) {\n\ttext, ok := ParseClaudeLine([]byte(\"plain text\"))\n\tassert.True(t, ok)\n\tassert.Equal(t, \"plain text\", text)\n}\n\nfunc TestParseClaudeLine_Empty(t *testing.T) {\n\t_, ok := ParseClaudeLine([]byte(\"\"))\n\tassert.False(t, ok)\n}\n\n// --- ParseClaudeStream ---\n\nfunc TestParseClaudeStream_AssistantMessages(t *testing.T) {\n\tinput := `{\"type\":\"system\",\"subtype\":\"init\",\"cwd\":\"/workspace\"}\n{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"I'll implement the feature.\"}]}}\n{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"type\":\"tool_result\",\"content\":\"ok\"}]}}\n{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Edit\"},{\"type\":\"text\",\"text\":\"Done editing.\"}]}}\n`\n\tresult := string(ParseClaudeStream([]byte(input)))\n\tassert.Contains(t, result, \"I'll implement the feature.\")\n\tassert.Contains(t, result, \"--- Tool: Edit ---\")\n\tassert.Contains(t, result, \"Done editing.\")\n\tassert.NotContains(t, result, \"system\")\n\tassert.NotContains(t, result, \"tool_result\")\n}\n\nfunc TestParseClaudeStream_TextDeltas(t *testing.T) {\n\tinput := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_01\",\"type\":\"message\",\"role\":\"assistant\"}}\n{\"type\":\"content_block_start\",\"index\":0,\"content_block\":{\"type\":\"text\",\"text\":\"\"}}\n{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Hello, \"}}\n{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"world!\"}}\n{\"type\":\"content_block_stop\",\"index\":0}\n{\"type\":\"message_delta\",\"delta\":{\"stop_reason\":\"end_turn\"}}\n{\"type\":\"message_stop\"}\n`\n\tresult := ParseClaudeStream([]byte(input))\n\tassert.Equal(t, \"Hello, world!\", string(result))\n}\n\nfunc TestParseClaudeStream_ResultEvent(t *testing.T) {\n\tinput := `{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Done.\\n\"}}\n{\"type\":\"result\",\"subtype\":\"success\",\"result\":\"Done.\\nCLOCHE_RESULT:success\"}\n`\n\tresult := string(ParseClaudeStream([]byte(input)))\n\tassert.Contains(t, result, \"Done.\\n\")\n\tassert.Contains(t, result, \"CLOCHE_RESULT:success\")\n}\n\nfunc TestParseClaudeStream_NonJSON(t *testing.T) {\n\tinput := \"This is plain text output\\nfrom a script step\\n\"\n\tresult := ParseClaudeStream([]byte(input))\n\tassert.Equal(t, input, string(result))\n}\n\nfunc TestParseClaudeStream_Empty(t *testing.T) {\n\tresult := ParseClaudeStream([]byte(\"\"))\n\tassert.Equal(t, \"\", string(result))\n}\n","numLines":132,"startLine":1,"totalLines":132}}}
