tFormatToolCall_UnknownToolWithCommand(t *testing.T) {\n\tinput := json.RawMessage(`{\"command\":\"do-something\"}`)\n\tassert.Equal(t, \"CustomTool('do-something')\", formatToolCall(\"CustomTool\", input))\n}\n\nfunc TestFormatToolCall_UnknownToolNoKnownParam(t *testing.T) {\n\tinput := json.RawMessage(`{\"foo\":\"bar\"}`)\n\tassert.Equal(t, \"CustomTool\", formatToolCall(\"CustomTool\", input))\n}\n\nfunc TestFormatToolCall_LongCommandTruncated(t *testing.T) {\n\tlong := strings.Repeat(\"x\", 100)\n\tinput := json.RawMessage(`{\"command\":\"` + long + `\"}`)\n\tresult := formatToolCall(\"Bash\", input)\n\tassert.Contains(t, result, \"...\")\n\t// 80 chars + \"...\" = truncated\n\tassert.Equal(t, fmt.Sprintf(\"Bash('%s...')\", long[:80]), result)\n}\n\n// --- ParseClaudeStream ---"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":677,"cache_read_input_tokens":24843,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":677},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"9f3f88b7-a9c0-408f-9619-e3d7b92e6b51","uuid":"72b9d961-afad-48e1-af16-52f63179712f"}
