[2026-03-10T01:30:37Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xw2zrF3ZkMUPYYu7LDugQ9","type":"tool_result","content":"   669→// handleAPIStream serves an SSE stream of log lines for a run.\n   670→// For active runs, it subscribes to the live broadcaster.\n   671→// For completed runs, it serves the archived full.log then closes.\n   672→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   673→\tid := r.PathValue(\"id\")\n   674→\n   675→\trun, err := h.store.GetRun(r.Context(), id)\n   676→\tif err != nil {\n   677→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   678→\t\treturn\n   679→\t}\n   680→\n   681→\tflusher, ok := w.(http.Flusher)\n   682→\tif !ok {\n   683→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   684→\t\treturn\n   685→\t}\n   686→\n   687→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   688→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   689→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   690→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   691→\n   692→\tisComplete := run.State == domain.RunStateSucceeded ||\n   693→\t\trun.State == domain.RunStateFailed ||\n   694→\t\trun.State == domain.RunStateCancelled\n   695→\n   696→\tif isComplete {\n   697→\t\t// Serve archived full.log\n   698→\t\th.streamFullLog(w, flusher, run)\n   699→\t\t// Send done event\n   700→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   701→\t\tflusher.Flush()\n   702→\t\treturn\n   703→\t}\n   704→\n   705→\t// Active run: subscribe to live broadcaster\n   706→\tif h.logBroadcast == nil {\n   707→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   708→\t\treturn\n   709→\t}\n   710→\n   711→\tsub := h.logBroadcast.Subscribe(id)\n   712→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   713→\n   714→\tctx := r.Context()\n   715→\tfor {\n   716→\t\tselect {\n   717→\t\tcase <-ctx.Done():\n   718→\t\t\treturn\n   719→\t\tcase line, ok := <-sub.C:\n   720→\t\t\tif !ok {\n   721→\t\t\t\t// Stream finished (run completed)\n   722→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   723→\t\t\t\tflusher.Flush()\n   724→\t\t\t\treturn\n   725→\t\t\t}\n   726→\t\t\tline = parseLLMLogLine(line)\n   727→\t\t\tif line.Type == \"\" {\n   728→\t\t\t\tcontinue // skip protocol-only llm lines\n   729→\t\t\t}\n   730→\t\t\tdata, _ := json.Marshal(line)\n   731→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   732→\t\t\tflusher.Flush()\n   733→\t\t}\n   734→\t}\n   735→}\n   736→\n   737→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   738→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   739→\n   740→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   741→// LLM-type lines are parsed from raw Claude JSON into human-readable text.\n   742→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   743→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   744→\tf, err := os.Open(logPath)\n   745→\tif err != nil {\n   746→\t\treturn\n   747→\t}\n   748→\tdefer f.Close()\n   749→\n   750→\tscanner := bufio.NewScanner(f)\n   751→\tfor scanner.Scan() {\n   752→\t\ttext := scanner.Text()\n   753→\t\tline := parseFullLogLine(text)\n   754→\t\tline = parseLLMLogLine(line)\n   755→\t\tif line.Type == \"\" {\n   756→\t\t\tcontinue // skip protocol-only llm lines\n   757→\t\t}\n   758→\t\tdata, _ := json.Marshal(line)\n   759→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   760→\t\tflusher.Flush()\n   761→\t}\n   762→}\n   763→\n   764→// parseLLMLogLine parses a LogLine whose type is \"llm\". If the content is\n   765→// Claude stream JSON, it extracts the human-readable text. Protocol-only\n   766→// events return a LogLine with an empty Type (caller should skip it).\n   767→// Non-llm lines are returned unchanged.\n   768→func parseLLMLogLine(line logstream.LogLine) logstream.LogLine {\n   769→\tif line.Type != \"llm\" {\n   770→\t\treturn line\n   771→\t}\n   772→\ttext, ok := logstream.ParseClaudeLine([]byte(line.Content))\n   773→\tif !ok {\n   774→\t\treturn logstream.LogLine{} // signal to skip\n   775→\t}\n   776→\tline.Content = text\n   777→\treturn line\n   778→}\n   779→\n   780→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   781→func parseFullLogLine(text string) logstream.LogLine {\n   782→\tm := logLineRegex.FindStringSubmatch(text)\n   783→\tif m == nil {\n   784→\t\treturn logstream.LogLine{\n   785→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   786→\t\t\tType:      \"script\",\n   787→\t\t\tContent:   text,\n   788→\t\t}"}]},"parent_tool_use_id":"toolu_01Lu7qgwcufs5u4isGeAdHs6","session_id":"9f3f88b7-a9c0-408f-9619-e3d7b92e6b51","uuid":"d304c984-58f4-480f-be0d-9781087574a2"}
