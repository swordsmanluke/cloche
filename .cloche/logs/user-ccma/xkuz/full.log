oadcast != nil {\n   251→\t\ts.logBroadcast.Finish(runID)\n   252→\t}\n   253→\n   254→\t// Wait for process exit\n   255→\texitCode, err := s.container.Wait(ctx, containerID)\n   256→\tif err != nil {\n   257→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   258→\t}\n   259→\n   260→\t// Extract step output files from container before it's removed\n   261→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   262→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   263→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   264→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   265→\t\t}\n   266→\t}\n   267→\n   268→\t// Capture full container stdout/stderr before the container is removed\n   269→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   270→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   271→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   272→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   273→\t\t}\n   274→\t}\n   275→\n   276→\t// Index extracted log files in the log store\n   277→\tif s.logStore != nil {\n   278→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   279→\t}\n   280→\n   281→\t// Extract results to git branch BEFORE finalizing state, so that\n   282→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   283→\t// before the run is marked complete.\n   284→\tresultLabel := reportedResult\n   285→\tif resultLabel == \"\" {\n   286→\t\tif exitCode == 0 {\n   287→\t\t\tresultLabel = \"succeeded\"\n   288→\t\t} else {\n   289→\t\t\tresultLabel = \"failed\"\n   290→\t\t}\n   291→\t}\n   292→\t{\n   293→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   294→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   295→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   296→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   297→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   298→\t\t\t} else {\n   299→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   300→\t\t\t}\n   301→\t\t} else {\n   302→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   303→\t\t}\n   304→\t}\n   305→\n   306→\t// Now finalize run state\n   307→\trun, err := s.store.GetRun(ctx, runID)\n   308→\tif err != nil {\n   309→\t\treturn\n   310→\t}\n   311→\tif run.State == domain.RunStateRunning {\n   312→\t\tif reportedResult == \"succeeded\" {\n   313→\t\t\trun.Complete(domain.RunStateSucceeded)\n   314→\t\t} else if reportedResult != \"\" {\n   315→\t\t\trun.Complete(domain.RunStateFailed)\n   316→\t\t} else if exitCode == 0 {\n   317→\t\t\trun.Complete(domain.RunStateSucceeded)\n   318→\t\t} else {\n   319→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   320→\t\t}\n   321→\t\t_ = s.store.UpdateRun(ctx, run)\n   322→\t}\n   323→\n   324→\t// Fire evolution trigger if configured\n   325→\tif s.evolution != nil {\n   326→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   327→\t}\n   328→\n   329→\t// Merge is handled as a workflow step in host.cloche, not here.\n   330→\n   331→\t// Container retention policy:\n   332→\t// - Failed runs: always keep the container for debugging\n   333→\t// - Successful runs + --keep-container: keep the container\n   334→\t// - Successful runs without --keep-container: remove the container\n   335→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   336→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   337→\n   338→\tif keepContainer || runFailed {\n   339→\t\treason := \"--keep-container\"\n   340→\t\tif runFailed {\n   341→\t\t\treason = \"run failed\"\n   342→\t\t}\n   343→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   344→\t\tif runFinal != nil {\n   345→\t\t\trunFinal.ContainerKept = true\n   346→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   347→\t\t}\n   348→\t} else {\n   349→\t\tif err := s.container.Remove(ctx, containerID); err != nil {"}]},"parent_tool_use_id":"toolu_01Lu7qgwcufs5u4isGeAdHs6","session_id":"9f3f88b7-a9c0-408f-9619-e3d7b92e6b51","uuid":"c0c8075a-ee0a-43af-8454-0118dceab458"}
