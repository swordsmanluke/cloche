alue = value[:spec.maxLen] + \"...\"\n\t}\n\n\treturn fmt.Sprintf(\"%s('%s')\", name, value)\n}\n\n// extractResultText handles result events (final output)."},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":491,"cache_read_input_tokens":22272,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":491},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"9f3f88b7-a9c0-408f-9619-e3d7b92e6b51","uuid":"75a3f953-6e6f-4e4f-b735-d0b4a62cf36f"}
