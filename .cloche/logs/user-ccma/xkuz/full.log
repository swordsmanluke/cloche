tedAt = time.Now()\n    59→}\n    60→\n    61→func (r *Run) RecordStepStart(stepName string) {\n    62→\tr.ActiveSteps = append(r.ActiveSteps, stepName)\n    63→\tr.StepExecutions = append(r.StepExecutions, &StepExecution{\n    64→\t\tStepName:  stepName,\n    65→\t\tStartedAt: time.Now(),\n    66→\t})\n    67→}\n    68→\n    69→func (r *Run) RecordStepComplete(stepName, result string) {\n    70→\t// Remove from active steps\n    71→\tfor i, name := range r.ActiveSteps {\n    72→\t\tif name == stepName {\n    73→\t\t\tr.ActiveSteps = append(r.ActiveSteps[:i], r.ActiveSteps[i+1:]...)\n    74→\t\t\tbreak\n    75→\t\t}\n    76→\t}\n    77→\t// Mark execution complete\n    78→\tfor i := len(r.StepExecutions) - 1; i >= 0; i-- {\n    79→\t\tif r.StepExecutions[i].StepName == stepName && r.StepExecutions[i].CompletedAt.IsZero() {\n    80→\t\t\tr.StepExecutions[i].Result = result\n    81→\t\t\tr.StepExecutions[i].CompletedAt = time.Now()\n    82→\t\t\treturn\n    83→\t\t}\n    84→\t}\n    85→}\n    86→\n    87→// ActiveStepsString returns a comma-separated representation of active steps\n    88→// for backward-compatible serialization.\n    89→func (r *Run) ActiveStepsString() string {\n    90→\treturn strings.Join(r.ActiveSteps, \",\")\n    91→}\n    92→\n    93→// SetActiveStepsFromString parses a comma-separated string into ActiveSteps.\n    94→func (r *Run) SetActiveStepsFromString(s string) {\n    95→\tif s == \"\" {\n    96→\t\tr.ActiveSteps = nil\n    97→\t\treturn\n    98→\t}\n    99→\tr.ActiveSteps = strings.Split(s, \",\")\n   100→}\n   101→\n   102→func (r *Run) Complete(state RunState) {\n   103→\tr.State = state\n   104→\tr.CompletedAt = time.Now()\n   105→}\n   106→\n   107→func (r *Run) Fail(msg string) {\n   108→\tr.State = RunStateFailed\n   109→\tr.CompletedAt = time.Now()\n   110→\tr.ErrorMessage = msg\n   111→}\n   112→"}]},"parent_tool_use_id":"toolu_01Lu7qgwcufs5u4isGeAdHs6","session_id":"9f3f88b7-a9c0-408f-9619-e3d7b92e6b51","uuid":"07a81e7c-7688-4a30