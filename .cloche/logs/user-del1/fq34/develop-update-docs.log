    65→\t\tcmdList(ctx, client, os.Args[2:])\n    66→\tcase \"stop\":\n    67→\t\tcmdStop(ctx, client, os.Args[2:])\n    68→\tcase \"delete\":\n    69→\t\tcmdDelete(ctx, client, os.Args[2:])\n    70→\tcase \"orchestrate\":\n    71→\t\tcmdOrchestrate(ctx, client)\n    72→\tcase \"shutdown\":\n    73→\t\tcmdShutdown(ctx, client)\n    74→\tdefault:\n    75→\t\tusage()\n    76→\t\tos.Exit(1)\n    77→\t}\n    78→}\n    79→\n    80→func usage() {\n    81→\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n    82→\n    83→Commands:\n    84→  init [--workflow <name>] [--base-image <image>]\n    85→                                             Initialize a Cloche project\n    86→  health                                   Show project health summary\n    87→  run --workflow <name> [--prompt \"...\"] [--keep-container]\n    88→                                             Launch a workflow run\n    89→  status <run-id>                            Check run status\n    90→  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n    91→                                             Show logs for a run\n    92→  poll <run-id>                              Wait for a run to finish\n    93→  list [--all]                                List runs (last hour by default)\n    94→  stop <run-id>                              Stop a running workflow\n    95→  delete <container-or-run-id>               Delete a retained container\n    96→  orchestrate                                Dispatch ready workflow runs\n    97→  shutdown                                   Shut down the daemon\n    98→`)\n    99→}\n   100→\n   101→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   102→\tvar workflow, prompt string\n   103→\tvar keepContainer bool\n   104→\n   105→\tfor i := 0; i < len(args); i++ {\n   106→\t\tswitch args[i] {\n   107→\t\tcase \"--workflow\":\n   108→\t\t\tif i+1 < len(args) {\n   109→\t\t\t\ti++\n   110→\t\t\t\tworkflow = args[i]\n   111→\t\t\t}\n   112→\t\tcase \"--prompt\", \"-p\":\n   113→\t\t\tif i+1 < len(args) {\n   114→\t\t\t\ti++\n   115→\t\t\t\tprompt = args[i]\n   116→\t\t\t}\n   117→\t\tcase \"--keep-container\":\n   118→\t\t\tkeepContainer = true\n   119→\t\tdefault:\n   120→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   121→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   122→\t\t\t\tworkflow = args[i]\n   123→\t\t\t}\n   124→\t\t}\n   125→\t}\n   126→\n   127→\tif workflow == \"\" {\n   128→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"]\\n\")\n   129→\t\tos.Exit(1)\n   130→\t}\n   131→\n   132→\tcwd, _ := os.Getwd()\n   133→\n   134→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   135→\tvar image string\n   136→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   137→\tif data, err := os.ReadFile(wfPath); err == nil {\n   138→\t\tif wf, err := dsl.Parse(string(data)); err == nil {\n   139→\t\t\timage = wf.Config[\"container.image\"]\n   140→\t\t}\n   141→\t}\n   142→\n   143→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   144→\t\tWorkflowName:  workflow,\n   145→\t\tProjectDir:    cwd,\n   146→\t\tImage:         image,\n   147→\t\tPrompt:        prompt,\n   148→\t\tKeepContainer: keepContainer,\n   149→\t})\n   150→\tif err != nil {\n   151→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   152→\t\tos.Exit(1)\n   153→\t}\n   154→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   155→}\n   156→\n   157→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   158→\tif len(args) < 1 {\n   159→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   160→\t\tos.Exit(1)\n   161→\t}\n   162→\n   163→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   164→\tif err != nil {\n   165→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   166→\t\tos.Exit(1)\n   167→\t}\n   168→\n   169→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   170→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   171→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   172→\tif resp.ContainerId != \"\" {\n   173→\t\tcid := resp.ContainerId\n   174→\t\tif len(cid) > 12 {\n   175→\t\t\tcid = cid[:12]\n   176→\t\t}\n   177→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   178→\t}\n   179→\tif resp.ErrorMessage != \"\" {\n   180→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   181→\t}\n   182→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   183→\tfor _, exec := range resp.StepExecutions {\n   184→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   185→\t}\n   186→}\n   187→\n   188→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   189→\tvar all bool\n   190→\tfor _, arg := range args {\n   191→\t\tif arg == \"--all\" {\n   192→\t\t\tall = true\n   193→\t\t}\n   194→\t}\n   195→\n   196→\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n   197→\tif err != nil {\n   198→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   199→\t\tos.Exit(1)\n   200→\t}\n   201→\n   202→\tif len(resp.Runs) == 0 {\n   203→\t\tfmt.Println(\"No runs found.\")\n   204→\t\treturn\n   205→\t}\n   206→\n   207→\tfor _, run := range resp.Runs {\n   208→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s\", run.RunId, run.WorkflowName, run.State)\n   209→\t\tif run.ContainerId != \"\" {\n   210→\t\t\tline += \"  \" + run.ContainerId\n   211→\t\t}\n   212→\t\tif run.ErrorMessage != \"\" {\n   213→\t\t\terrMsg := run.ErrorMessage\n   214→\t\t\tif len(errMsg) > 60 {\n   215→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   216→\t\t\t}\n   217→\t\t\tline += \"  \" + errMsg\n   218→\t\t}\n   219→\t\tfmt.Println(line)\n   220→\t}\n   221→}\n   222→\n   223→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   224→\tif len(args) < 1 {\n   225→\t\tfmt.Fprintf