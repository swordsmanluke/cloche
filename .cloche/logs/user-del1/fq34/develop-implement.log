{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XU1T7CfAi3nMuW2ypW4yTS","type":"tool_result","content":"     1→package prompt_test\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"os\"\n     6→\t\"path/filepath\"\n     7→\t\"testing\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    10→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11→\t\"github.com/stretchr/testify/assert\"\n    12→\t\"github.com/stretchr/testify/require\"\n    13→)\n    14→\n    15→func TestPromptAdapter_ExecutesCommand(t *testing.T) {\n    16→\tdir := t.TempDir()\n    17→\n    18→\t// Write a user prompt under a run ID\n    19→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"test-run\"), 0755))\n    20→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test-run\", \"prompt.txt\"), []byte(\"add a calculator\"), 0644))\n    21→\n    22→\t// Use a mock command that writes a file to prove it ran\n    23→\tadapter := &prompt.Adapter{\n    24→\t\tCommands:     []string{\"sh\"},\n    25→\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'implemented' > result.txt && echo ok\"},\n    26→\t\tRunID:        \"test-run\",\n    27→\t}\n    28→\n    29→\tstep := &domain.Step{\n    30→\t\tName:    \"implement\",\n    31→\t\tType:    domain.StepTypeAgent,\n    32→\t\tResults: []string{\"success\", \"fail\"},\n    33→\t\tConfig:  map[string]string{\"prompt\": \"You are a coding assistant.\"},\n    34→\t}\n    35→\n    36→\tresult, err := adapter.Execute(context.Background(), step, dir)\n    37→\trequire.NoError(t, err)\n    38→\tassert.Equal(t, \"success\", result)\n    39→\n    40→\t// Verify the mock command ran\n    41→\tcontent, err := os.ReadFile(filepath.Join(dir, \"result.txt\"))\n    42→\trequire.NoError(t, err)\n    43→\tassert.Contains(t, string(content), \"implemented\")\n    44→}\n    45→\n    46→func TestPromptAdapter_IncludesFeedback(t *testing.T) {\n    47→\tdir := t.TempDir()\n    48→\n    49→\t// Set up feedback logs\n    50→\toutputDir := filepath.Join(dir, \".cloche\", \"output\")\n    51→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n    52→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"test.log\"), []byte(\"3 failures\"), 0644))\n    53→\n    54→\t// Mock command that captures stdin to a file so we can inspect it\n    55→\tadapter := &prompt.Adapter{\n    56→\t\tCommands:     []string{\"sh\"},\n    57→\t\tExplicitArgs: []string{\"-c\", \"cat > captured_prompt.txt && echo ok\"},\n    58→\t}\n    59→\n    60→\tstep := &domain.Step{\n    61→\t\tName:    \"fix\",\n    62→\t\tType:    domain.StepTypeAgent,\n    63→\t\tResults: []string{\"success\", \"fail\", \"give-up\"},\n    64→\t\tConfig:  map[string]string{\"prompt\": \"Fix the code.\", \"feedback\": \"true\"},\n    65→\t}\n    66→\n    67→\tresult, err := adapter.Execute(context.Background(), step, dir)\n    68→\trequire.NoError(t, err)\n    69→\tassert.Equal(t, \"success\", result)\n    70→\n    71→\t// Verify feedback was included in the prompt\n    72→\tcaptured, err := os.ReadFile(filepath.Join(dir, \"captured_prompt.txt\"))\n    73→\trequire.NoError(t, err)\n    74→\tassert.Contains(t, string(captured), \"Fix the code.\")\n    75→\tassert.Contains(t, string(captured), \"3 failures\")\n    76→}\n    77→\n    78→func TestPromptAdapter_NoFeedbackByDefault(t *testing.T) {\n    79→\tdir := t.TempDir()\n    80→\n    81→\t// Set up feedback logs\n    82→\toutputDir := filepath.Join(dir, \".cloche\", \"output\")\n    83→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n    84→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"test.log\"), []byte(\"3 failures\"), 0644))\n    85→\n    86→\t// Mock command that captures stdin to a file so we can inspect it\n    87→\tadapter := &prompt.Adapter{\n    88→\t\tCommands:     []string{\"sh\"},\n    89→\t\tExplicitArgs: []string{\"-c\", \"cat > captured_prompt.txt && echo ok\"},\n    90→\t}\n    91→\n    92→\tstep := &domain.Step{\n    93→\t\tName:    \"update-docs\",\n    94→\t\tType:    domain.StepTypeAgent,\n    95→\t\tResults: []string{\"success\", \"fail\"},\n    96→\t\tConfig:  map[string]string{\"prompt\": \"Update the docs.\"},\n    97→\t}\n    98→\n    99→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   100→\trequire.NoError(t, err)\n   101→\tassert.Equal(t, \"success\", result)\n   102→\n   103→\t// Verify feedback was NOT included in the prompt\n   104→\tcaptured, err := os.ReadFile(filepath.Join(dir, \"captured_prompt.txt\"))\n   105→\trequire.NoError(t, err)\n   106→\tassert.Contains(t, string(captured), \"Update the docs.\")\n   107→\tassert.NotContains(t, string(captured), \"3 failures\")\n   108→\tassert.NotContains(t, string(captured), \"Validation Output\")\n   109→}\n   110→\n   111→func TestPromptAdapter_RespectsMaxAttempts(t *testing.T) {\n   112→\tdir := t.TempDir()\n   113→\n   114→\t// Pre-set attempt count to the max\n   115→\tattemptDir := filepath.Join(dir, \".cloche\", \"attempt_count\")\n   116→\trequire.NoError(t, os.MkdirAll(attemptDir, 0755))\n   117→\trequire.NoError(t, os.WriteFile(filepath.Join(attemptDir, \"fix\"), []byte(\"2\"), 0644))\n   118→\n   119→\t// Command should NOT be called since max is reached\n   120→\tadapter := &prompt.Adapter{\n   121→\t\tCommands:     []string{\"sh\"},\n   122→\t\tExplicitArgs: []string{\"-c\", \"exit 1\"}, // would fail if called\n   123→\t}\n   124→\n   125→\tstep := &domain.Step{\n   126→\t\tName:    \"fix\",\n   127→\t\tType:    domain.StepTypeAgent,\n   128→\t\tResults: []string{\"fixed\", \"give-up\"},\n   129→\t\tConfig: map[string]string{\n   130→\t\t\t\"prompt\":       \"Fix the code.\",\n   131→\t\t\t\"max_attempts\": \"2\",\n   132→\t\t},\n   133→\t}\n   134→\n   135→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   136→\trequire.NoError(t, err)\n   137→\tassert.Equal(t, \"give-up\", result)\n   138→}\n   139→\n   140→func TestPromptAdapter_CommandFailure(t *testing.T) {\n   141→\tdir := t.TempDir()\n   142→\n   143→\tadapter := &prompt.Adapter{\n   144→\t\tCommands:     []string{\"sh\"},\n   145→\t\tExplicitArgs: []string{\"-c\", \"exit 1\"},\n   146→\t}\n   147→\n   148→\tstep := &domain.Step{\n   149→\t\tName:    \"implement\",\n   150→\t\tType:    domain.StepTypeAgent,\n   151→\t\tResults: []string{\"success\", \"fail\"},\n   152→\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   153→\t}\n   154→\n   155→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   156→\trequire.NoError(t, err)\n   157→\tassert.Equal(t, \"fail\", result)\n   158→}\n   159→\n   160→func TestPromptAdapter_InjectsResultInstructions(t *testing.T) {\n   161→\tdir := t.TempDir()\n   162→\n   163→\tadapter := &prompt.Adapter{\n   164→\t\tCommands:     []string{\"sh\"},\n   165→\t\tExplicitArgs: []string{\"-c\", \"cat > captured_prompt.txt && echo ok\"},\n   166→\t}\n   167→\n   168→\tstep := &domain.Step{\n   169→\t\tName:    \"analyze\",\n   170→\t\tType:    domain.StepTypeAgent,\n   171→\t\tResults: []string{\"success\", \"fail\", \"needs_research\"},\n   172→\t\tConfig:  map[string]string{\"prompt\": \"Analyze the code.\"},\n   173→\t}\n   174→\n   175→\t_, err := adapter.Execute(context.Background(), step, dir)\n   176→\trequire.NoError(t, err)\n   177→\n   178→\tcaptured, err := os.ReadFile(filepath.Join(dir, \"captured_prompt.txt\"))\n   179→\trequire.NoError(t, err)\n   180→\tassert.Contains(t, string(captured), \"CLOCHE_RESULT:success\")\n   181→\tassert.Contains(t, string(captured), \"CLOCHE_RESULT:fail\")\n   182→\tassert.Contains(t, string(captured), \"CLOCHE_RESULT:needs_research\")\n   183→}\n   184→\n   185→func TestPromptAdapter_StdoutMarkerSelectsResult(t *testing.T) {\n   186→\tdir := t.TempDir()\n   187→\n   188→\tadapter := &prompt.Adapter{\n   189→\t\tCommands:     []string{\"sh\"},\n   190→\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'CLOCHE_RESULT:needs_research'\"},\n   191→\t}\n   192→\n   193→\tstep := &domain.Step{\n   194→\t\tName:    \"analyze\",\n   195→\t\tType:    domain.StepTypeAgent,\n   196→\t\tResults: []string{\"success\", \"fail\", \"needs_research\"},\n   197→\t\tConfig:  map[string]string{\"prompt\": \"Analyze the code.\"},\n   198→\t}\n   199→\n   200→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   201→\trequire.NoError(t, err)\n   202→\tassert.Equal(t, \"needs_research\", result)\n   203→}\n   204→\n   205→func TestExecuteWritesOutputFile(t *testing.T) {\n   206→\tdir := t.TempDir()\n   207→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"test-run\"), 0755)\n   208→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"test-run\", \"prompt.txt\"), []byte(\"user request\"), 0644)\n   209→\n   210→\ta := &prompt.Adapter{\n   211→\t\tCommands:     []string{\"sh\"},\n   212→\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'agent output'\"},\n   213→\t\tRunID:        \"test-run\",\n   214→\t}\n   215→\n   216→\tstep := &domain.Step{\n   217→\t\tName:    \"implement\",\n   218→\t\tType:    domain.StepTypeAgent,\n   219→\t\tResults: []string{\"success\", \"fail\"},\n   220→\t\tConfig:  map[string]string{\"prompt\": \"Build something\"},\n   221→\t}\n   222→\n   223→\tresult, err := a.Execute(context.Background(), step, dir)\n   224→\trequire.NoError(t, err)\n   225→\tassert.Equal(t, \"success\", result)\n   226→\n   227→\t// Verify output was written to file\n   228→\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n   229→\tdata, err := os.ReadFile(outputPath)\n   230→\trequire.NoError(t, err)\n   231→\tassert.Contains(t, string(data), \"agent output\")\n   232→}\n   233→\n   234→func TestPromptAdapter_IncrementsAttemptCount(t *testing.T) {\n   235→\tdir := t.TempDir()\n   236→\n   237→\tadapter := &prompt.Adapter{\n   238→\t\tCommands:     []string{\"sh\"},\n   239→\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null\"},\n   240→\t}\n   241→\n   242→\tstep := &domain.Step{\n   243→\t\tName:    \"fix\",\n   244→\t\tType:    domain.StepTypeAgent,\n   245→\t\tResults: []string{\"fixed\", \"give-up\"},\n   246→\t\tConfig:  map[string]string{\"prompt\": \"Fix it.\"},\n   247→\t}\n   248→\n   249→\t// Execute twice\n   250→\t_, err := adapter.Execute(context.Background(), step, dir)\n   251→\trequire.NoError(t, err)\n   252→\t_, err = adapter.Execute(context.Background(), step, dir)\n   253→\trequire.NoError(t, err)\n   254→\n   255→\t// Verify count is 2\n   256→\tcountPath := filepath.Join(dir, \".cloche\", \"attempt_count\", \"fix\")\n   257→\tdata, err := os.ReadFile(countPath)\n   258→\trequire.NoError(t, err)\n   259→\tassert.Equal(t, \"2\", string(data))\n   260→}\n   261→\n   262→// --- Fallback chain tests ---\n   263→\n   264→func TestPromptAdapter_FallbackOnCommandNotFound(t *testing.T) {\n   265→\tdir := t.TempDir()\n   266→\n   267→\t// First command doesn't exist, second one does\n   268→\tadapter := &prompt.Adapter{\n   269→\t\tCommands:     []string{\"nonexistent-agent-xyz\", \"sh\"},\n   270→\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'fallback ran'\"},\n   271→\t}\n   272→\n   273→\tstep := &domain.Step{\n   274→\t\tName:    \"implement\",\n   275→\t\tType:    domain.StepTypeAgent,\n   276→\t\tResults: []string{\"success\", \"fail\"},\n   277→\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   278→\t}\n   279→\n   280→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   281→\trequire.NoError(t, err)\n   282→\tassert.Equal(t, \"success\", result)\n   283→\n   284→\t// Verify the fallback command's output was captured\n   285→\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n   286→\tdata, err := os.ReadFile(outputPath)\n   287→\trequire.NoError(t, err)\n   288→\tassert.Contains(t, string(data), \"fallback ran\")\n   289→}\n   290→\n   291→func TestPromptAdapter_FallbackOnExitErrorNoMarker(t *testing.T) {\n   292→\tdir := t.TempDir()\n   293→\n   294→\t// Create two scripts: first exits 1 without marker, second succeeds\n   295→\tfailing := filepath.Join(dir, \"failing-agent.sh\")\n   296→\trequire.NoError(t, os.WriteFile(failing, []byte(\"#!/bin/sh\\ncat > /dev/null\\nexit 1\\n\"), 0755))\n   297→\n   298→\tsucceeding := filepath.Join(dir, \"good-agent.sh\")\n   299→\trequire.NoError(t, os.WriteFile(succeeding, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'good agent output'\\n\"), 0755))\n   300→\n   301→\tadapter := &prompt.Adapter{\n   302→\t\tCommands: []string{failing, succeeding},\n   303→\t}\n   304→\n   305→\tstep := &domain.Step{\n   306→\t\tName:    \"implement\",\n   307→\t\tType:    domain.StepTypeAgent,\n   308→\t\tResults: []string{\"success\", \"fail\"},\n   309→\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   310→\t}\n   311→\n   312→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   313→\trequire.NoError(t, err)\n   314→\tassert.Equal(t, \"success\", result)\n   315→\n   316→\t// Verify the fallback command's output was captured\n   317→\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n   318→\tdata, err := os.ReadFile(outputPath)\n   319→\trequire.NoError(t, err)\n   320→\tassert.Contains(t, string(data), \"good agent output\")\n   321→}\n   322→\n   323→func TestPromptAdapter_NoFallbackOnMarkerResult(t *testing.T) {\n   324→\tdir := t.TempDir()\n   325→\n   326→\t// First command exits 1 but reports a CLOCHE_RESULT marker — should NOT fall back\n   327→\tfailing := filepath.Join(dir, \"reporting-agent.sh\")\n   328→\trequire.NoError(t, os.WriteFile(failing, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'CLOCHE_RESULT:fail'\\nexit 1\\n\"), 0755))\n   329→\n   330→\tshouldNotRun := filepath.Join(dir, \"should-not-run.sh\")\n   331→\trequire.NoError(t, os.WriteFile(shouldNotRun, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'CLOCHE_RESULT:success'\\n\"), 0755))\n   332→\n   333→\tadapter := &prompt.Adapter{\n   334→\t\tCommands: []string{failing, shouldNotRun},\n   335→\t}\n   336→\n   337→\tstep := &domain.Step{\n   338→\t\tName:    \"implement\",\n   339→\t\tType:    domain.StepTypeAgent,\n   340→\t\tResults: []string{\"success\", \"fail\"},\n   341→\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   342→\t}\n   343→\n   344→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   345→\trequire.NoError(t, err)\n   346→\t// Should use the first agent's result, not fall back\n   347→\tassert.Equal(t, \"fail\", result)\n   348→}\n   349→\n   350→func TestPromptAdapter_AllCommandsFail(t *testing.T) {\n   351→\tdir := t.TempDir()\n   352→\n   353→\t// All commands don't exist\n   354→\tadapter := &prompt.Adapter{\n   355→\t\tCommands: []string{\"nonexistent-agent-1\", \"nonexistent-agent-2\"},\n   356→\t}\n   357→\n   358→\tstep := &domain.Step{\n   359→\t\tName:    \"implement\",\n   360→\t\tType:    domain.StepTypeAgent,\n   361→\t\tResults: []string{\"success\", \"fail\"},\n   362→\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   363→\t}\n   364→\n   365→\t_, err := adapter.Execute(context.Background(), step, dir)\n   366→\trequire.Error(t, err)\n   367→\tassert.Contains(t, err.Error(), \"failed to start\")\n   368→}\n   369→\n   370→func TestPromptAdapter_LastCommandCrashReturnsFailResult(t *testing.T) {\n   371→\tdir := t.TempDir()\n   372→\n   373→\t// Both commands exit non-zero without marker\n   374→\tfailing1 := filepath.Join(dir, \"failing1.sh\")\n   375→\trequire.NoError(t, os.WriteFile(failing1, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'crash1'\\nexit 1\\n\"), 0755))\n   376→\n   377→\tfailing2 := filepath.Join(dir, \"failing2.sh\")\n   378→\trequire.NoError(t, os.WriteFile(failing2, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'crash2'\\nexit 1\\n\"), 0755))\n   379→\n   380→\tadapter := &prompt.Adapter{\n   381→\t\tCommands: []string{failing1, failing2},\n   382→\t}\n   383→\n   384→\tstep := &domain.Step{\n   385→\t\tName:    \"implement\",\n   386→\t\tType:    domain.StepTypeAgent,\n   387→\t\tResults: []string{\"success\", \"fail\"},\n   388→\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   389→\t}\n   390→\n   391→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   392→\trequire.NoError(t, err)\n   393→\tassert.Equal(t, \"fail\", result)\n   394→}\n   395→\n   396→func TestPromptAdapter_SingleCommandPreservesBehavior(t *testing.T) {\n   397→\tdir := t.TempDir()\n   398→\n   399→\t// Single command, exit 0 — should behave exactly like before\n   400→\tadapter := &prompt.Adapter{\n   401→\t\tCommands:     []string{\"sh\"},\n   402→\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo hello\"},\n   403→\t}\n   404→\n   405→\tstep := &domain.Step{\n   406→\t\tName:    \"implement\",\n   407→\t\tType:    domain.StepTypeAgent,\n   408→\t\tResults: []string{\"success\", \"fail\"},\n   409→\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   410→\t}\n   411→\n   412→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   413→\trequire.NoError(t, err)\n   414→\tassert.Equal(t, \"success\", result)\n   415→}\n   416→\n   417→func TestPromptAdapter_DefaultArgsForClaude(t *testing.T) {\n   418→\t// Verify New() creates an adapter with \"claude\" as the default command\n   419→\tadapter := prompt.New()\n   420→\tassert.Equal(t, []string{\"claude\"}, adapter.Commands)\n   421→\tassert.Nil(t, adapter.ExplicitArgs)\n   422→}\n   423→\n   424→func TestParseCommands(t *testing.T) {\n   425→\ttests := []struct {\n   426→\t\tinput    string\n   427→\t\texpected []string\n   428→\t}{\n   429→\t\t{\"claude\", []string{\"claude\"}},\n   430→\t\t{\"claude,gemini\", []string{\"claude\", \"gemini\"}},\n   431→\t\t{\"claude, gemini, codex\", []string{\"claude\", \"gemini\", \"codex\"}},\n   432→\t\t{\" claude , gemini , codex \", []string{\"claude\", \"gemini\", \"codex\"}},\n   433→\t\t{\"claude,,gemini\", []string{\"claude\", \"gemini\"}},\n   434→\t\t{\"\", nil},\n   435→\t}\n   436→\tfor _, tc := range tests {\n   437→\t\tt.Run(tc.input, func(t *testing.T) {\n   438→\t\t\tresult := prompt.ParseCommands(tc.input)\n   439→\t\t\tassert.Equal(t, tc.expected, result)\n   440→\t\t})\n   441→\t}\n   442→}\n   443→"}]},"parent_tool_use_id":"toolu_01AkfWUPgq78MP7yViLUjjcD","session_id":"abc5f750-0862-4f12-8214-59a5ee9bdc43","uuid":"e84a5840-92c2-4c09-82f1-4bae0c3870a1"}
