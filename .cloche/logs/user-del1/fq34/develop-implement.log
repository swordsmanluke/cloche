{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hngz6CwHsdo6xzQSc3vcpq","type":"tool_result","content":"     1→package dsl\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"strings\"\n     6→\n     7→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     8→)\n     9→\n    10→type Parser struct {\n    11→\tlexer   *Lexer\n    12→\tcurrent Token\n    13→\tpeek    Token\n    14→}\n    15→\n    16→func Parse(input string) (*domain.Workflow, error) {\n    17→\tp := &Parser{lexer: NewLexer(input)}\n    18→\tp.advance() // load current\n    19→\tp.advance() // load peek\n    20→\treturn p.parseWorkflow()\n    21→}\n    22→\n    23→func (p *Parser) advance() {\n    24→\tp.current = p.peek\n    25→\tp.peek = p.lexer.NextToken()\n    26→}\n    27→\n    28→func (p *Parser) expect(typ TokenType) (Token, error) {\n    29→\tif p.current.Type != typ {\n    30→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n    31→\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n    32→\t}\n    33→\ttok := p.current\n    34→\tp.advance()\n    35→\treturn tok, nil\n    36→}\n    37→\n    38→func (p *Parser) expectIdent(value string) (Token, error) {\n    39→\tif p.current.Type != TokenIdent || p.current.Literal != value {\n    40→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n    41→\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n    42→\t}\n    43→\ttok := p.current\n    44→\tp.advance()\n    45→\treturn tok, nil\n    46→}\n    47→\n    48→func (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n    49→\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n    50→\t\treturn nil, err\n    51→\t}\n    52→\n    53→\tnameTok, err := p.expect(TokenString)\n    54→\tif err != nil {\n    55→\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n    56→\t}\n    57→\n    58→\tif _, err := p.expect(TokenLBrace); err != nil {\n    59→\t\treturn nil, err\n    60→\t}\n    61→\n    62→\twf := &domain.Workflow{\n    63→\t\tName:   nameTok.Literal,\n    64→\t\tSteps:  make(map[string]*domain.Step),\n    65→\t\tConfig: make(map[string]string),\n    66→\t}\n    67→\n    68→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n    69→\t\tif p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n    70→\t\t\tstep, err := p.parseStep()\n    71→\t\t\tif err != nil {\n    72→\t\t\t\treturn nil, err\n    73→\t\t\t}\n    74→\t\t\twf.Steps[step.Name] = step\n    75→\t\t\tif wf.EntryStep == \"\" {\n    76→\t\t\t\twf.EntryStep = step.Name\n    77→\t\t\t}\n    78→\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n    79→\t\t\tcollect, err := p.parseCollect()\n    80→\t\t\tif err != nil {\n    81→\t\t\t\treturn nil, err\n    82→\t\t\t}\n    83→\t\t\twf.Collects = append(wf.Collects, collect)\n    84→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n    85→\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n    86→\t\t\t\treturn nil, err\n    87→\t\t\t}\n    88→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n    89→\t\t\twire, err := p.parseWire()\n    90→\t\t\tif err != nil {\n    91→\t\t\t\treturn nil, err\n    92→\t\t\t}\n    93→\t\t\twf.Wiring = append(wf.Wiring, wire)\n    94→\t\t} else {\n    95→\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n    96→\t\t}\n    97→\t}\n    98→\n    99→\tif _, err := p.expect(TokenRBrace); err != nil {\n   100→\t\treturn nil, err\n   101→\t}\n   102→\n   103→\treturn wf, nil\n   104→}\n   105→\n   106→func (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n   107→\tprefix := p.current.Literal // e.g. \"container\"\n   108→\tp.advance()                 // consume prefix ident\n   109→\n   110→\tif _, err := p.expect(TokenLBrace); err != nil {\n   111→\t\treturn err\n   112→\t}\n   113→\n   114→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   115→\t\tkeyTok, err := p.expect(TokenIdent)\n   116→\t\tif err != nil {\n   117→\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   118→\t\t}\n   119→\n   120→\t\tif _, err := p.expect(TokenEquals); err != nil {\n   121→\t\t\treturn err\n   122→\t\t}\n   123→\n   124→\t\tval, err := p.parseValue()\n   125→\t\tif err != nil {\n   126→\t\t\treturn err\n   127→\t\t}\n   128→\n   129→\t\twf.Config[prefix+\".\"+keyTok.Literal] = val\n   130→\t}\n   131→\n   132→\tif _, err := p.expect(TokenRBrace); err != nil {\n   133→\t\treturn err\n   134→\t}\n   135→\n   136→\treturn nil\n   137→}\n   138→\n   139→func (p *Parser) parseStep() (*domain.Step, error) {\n   140→\tp.advance() // consume \"step\"\n   141→\n   142→\tnameTok, err := p.expect(TokenIdent)\n   143→\tif err != nil {\n   144→\t\treturn nil, fmt.Errorf(\"expected step name: %w\", err)\n   145→\t}\n   146→\n   147→\tif _, err := p.expect(TokenLBrace); err != nil {\n   148→\t\treturn nil, err\n   149→\t}\n   150→\n   151→\tstep := &domain.Step{\n   152→\t\tName:   nameTok.Literal,\n   153→\t\tConfig: make(map[string]string),\n   154→\t}\n   155→\n   156→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   157→\t\tif err := p.parseStepField(step, \"\"); err != nil {\n   158→\t\t\treturn nil, err\n   159→\t\t}\n   160→\t}\n   161→\n   162→\tif _, err := p.expect(TokenRBrace); err != nil {\n   163→\t\treturn nil, err\n   164→\t}\n   165→\n   166→\t// Infer step type from content\n   167→\t_, hasPrompt := step.Config[\"prompt\"]\n   168→\t_, hasRun := step.Config[\"run\"]\n   169→\t_, hasWorkflowName := step.Config[\"workflow_name\"]\n   170→\n   171→\tcount := 0\n   172→\tif hasPrompt {\n   173→\t\tcount++\n   174→\t}\n   175→\tif hasRun {\n   176→\t\tcount++\n   177→\t}\n   178→\tif hasWorkflowName {\n   179→\t\tcount++\n   180→\t}\n   181→\n   182→\tif count > 1 {\n   183→\t\treturn nil, fmt.Errorf(\"step %q has multiple of 'prompt', 'run', 'workflow_name'; must have exactly one\", step.Name)\n   184→\t}\n   185→\n   186→\tswitch {\n   187→\tcase hasPrompt:\n   188→\t\tstep.Type = domain.StepTypeAgent\n   189→\tcase hasRun:\n   190→\t\tstep.Type = domain.StepTypeScript\n   191→\tcase hasWorkflowName:\n   192→\t\tstep.Type = domain.StepTypeWorkflow\n   193→\tdefault:\n   194→\t\treturn nil, fmt.Errorf(\"step %q has none of 'prompt', 'run', or 'workflow_name'; must have exactly one\", step.Name)\n   195→\t}\n   196→\n   197→\treturn step, nil\n   198→}\n   199→\n   200→func (p *Parser) parseStepField(step *domain.Step, prefix string) error {"}]},"parent_tool_use_id":"toolu_01AkfWUPgq78MP7yViLUjjcD","session_id":"abc5f750-0862-4f12-8214-59a5ee9bdc43","uuid":"dfb1ac96-fbc8-42d2-bd2a-6f9a60e49e9d"}
