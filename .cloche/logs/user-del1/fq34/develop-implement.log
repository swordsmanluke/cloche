{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KMCxu87WuLSTQ98s16YHyN","type":"tool_result","content":"     1→package generic\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"os\"\n     6→\t\"os/exec\"\n     7→\t\"path/filepath\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    11→)\n    12→\n    13→type Adapter struct{}\n    14→\n    15→func New() *Adapter {\n    16→\treturn &Adapter{}\n    17→}\n    18→\n    19→func (a *Adapter) Name() string {\n    20→\treturn \"generic\"\n    21→}\n    22→\n    23→func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    24→\tcmdStr := step.Config[\"run\"]\n    25→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    26→\tcmd.Dir = workDir\n    27→\n    28→\toutput, err := cmd.CombinedOutput()\n    29→\n    30→\t// Extract result marker before writing logs\n    31→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n    32→\n    33→\t// Write cleaned output to log file\n    34→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n    35→\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n    36→\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), cleanOutput, 0644)\n    37→\t}\n    38→\n    39→\tisAgent := step.Type == domain.StepTypeAgent\n    40→\n    41→\tif err != nil {\n    42→\t\tif _, ok := err.(*exec.ExitError); ok {\n    43→\t\t\tresult := \"fail\"\n    44→\t\t\tif found {\n    45→\t\t\t\tresult = markerResult\n    46→\t\t\t}\n    47→\t\t\tprotocol.AppendHistory(workDir, step.Name, result, isAgent, cleanOutput)\n    48→\t\t\treturn result, nil\n    49→\t\t}\n    50→\t\treturn \"\", err\n    51→\t}\n    52→\n    53→\tresult := \"success\"\n    54→\tif found {\n    55→\t\tresult = markerResult\n    56→\t}\n    57→\tprotocol.AppendHistory(workDir, step.Name, result, isAgent, cleanOutput)\n    58→\treturn result, nil\n    59→}\n    60→"}]},"parent_tool_use_id":"toolu_01AkfWUPgq78MP7yViLUjjcD","session_id":"abc5f750-0862-4f12-8214-59a5ee9bdc43","uuid":"b4a00880-e9b8-40e0-891b-ba13a0e51915"}
