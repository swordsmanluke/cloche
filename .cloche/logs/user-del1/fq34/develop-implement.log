{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018mQo9vXqMYNZNGDdTU9jjp","type":"tool_result","content":"     1→package engine\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"sync\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11→)\n    12→\n    13→const DefaultStepTimeout = 30 * time.Minute\n    14→\n    15→// StepExecutor executes a single step and returns the result name.\n    16→type StepExecutor interface {\n    17→\tExecute(ctx context.Context, step *domain.Step) (string, error)\n    18→}\n    19→\n    20→// StepExecutorFunc adapts a function to the StepExecutor interface.\n    21→type StepExecutorFunc func(ctx context.Context, step *domain.Step) (string, error)\n    22→\n    23→func (f StepExecutorFunc) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    24→\treturn f(ctx, step)\n    25→}\n    26→\n    27→// StatusHandler receives notifications about workflow execution progress.\n    28→type StatusHandler interface {\n    29→\tOnStepStart(run *domain.Run, step *domain.Step)\n    30→\tOnStepComplete(run *domain.Run, step *domain.Step, result string)\n    31→\tOnRunComplete(run *domain.Run)\n    32→}\n    33→\n    34→type noopStatus struct{}\n    35→\n    36→func (noopStatus) OnStepStart(*domain.Run, *domain.Step)            {}\n    37→func (noopStatus) OnStepComplete(*domain.Run, *domain.Step, string) {}\n    38→func (noopStatus) OnRunComplete(*domain.Run)                        {}\n    39→\n    40→type Engine struct {\n    41→\texecutor       StepExecutor\n    42→\tstatus         StatusHandler\n    43→\tmaxSteps       int\n    44→\tdefaultTimeout time.Duration\n    45→}\n    46→\n    47→func New(executor StepExecutor) *Engine {\n    48→\treturn &Engine{\n    49→\t\texecutor:       executor,\n    50→\t\tstatus:         noopStatus{},\n    51→\t\tmaxSteps:       1000,\n    52→\t\tdefaultTimeout: DefaultStepTimeout,\n    53→\t}\n    54→}\n    55→\n    56→func (e *Engine) SetStatusHandler(h StatusHandler) {\n    57→\te.status = h\n    58→}\n    59→\n    60→func (e *Engine) SetMaxSteps(n int) {\n    61→\te.maxSteps = n\n    62→}\n    63→\n    64→// SetDefaultTimeout sets the default timeout for steps that don't specify one.\n    65→func (e *Engine) SetDefaultTimeout(d time.Duration) {\n    66→\te.defaultTimeout = d\n    67→}\n    68→\n    69→// stepResult is sent from worker goroutines back to the main event loop.\n    70→type stepResult struct {\n    71→\tstepName string\n    72→\tresult   string\n    73→\terr      error\n    74→}\n    75→\n    76→// collectState tracks the satisfaction state of a single Collect clause.\n    77→type collectState struct {\n    78→\tcollect   *domain.Collect\n    79→\tsatisfied map[int]bool\n    80→\tfired     bool\n    81→}\n    82→\n    83→func (e *Engine) Run(ctx context.Context, wf *domain.Workflow) (*domain.Run, error) {\n    84→\tif err := wf.Validate(); err != nil {\n    85→\t\treturn nil, fmt.Errorf(\"invalid workflow: %w\", err)\n    86→\t}\n    87→\tfor _, w := range wf.ValidateConfig() {\n    88→\t\tlog.Printf(\"WARNING: %s\", w)\n    89→\t}\n    90→\n    91→\trun := domain.NewRun(generateRunID(), wf.Name)\n    92→\trun.Start()\n    93→\n    94→\t// Check context cancellation before starting.\n    95→\tif err := ctx.Err(); err != nil {\n    96→\t\trun.Complete(domain.RunStateCancelled)\n    97→\t\treturn run, fmt.Errorf(\"workflow cancelled: %w\", err)\n    98→\t}\n    99→\n   100→\t// Build a set of (step, result) pairs that are handled by collects,\n   101→\t// so we know when a missing wire is acceptable.\n   102→\tcollectHandled := make(map[string]map[string]bool)\n   103→\tfor _, c := range wf.Collects {\n   104→\t\tfor _, cond := range c.Conditions {\n   105→\t\t\tif collectHandled[cond.Step] == nil {\n   106→\t\t\t\tcollectHandled[cond.Step] = make(map[string]bool)\n   107→\t\t\t}\n   108→\t\t\tcollectHandled[cond.Step][cond.Result] = true\n   109→\t\t}\n   110→\t}\n   111→\n   112→\t// Initialize collect states.\n   113→\tcStates := make([]*collectState, len(wf.Collects))\n   114→\tfor i := range wf.Collects {\n   115→\t\tcStates[i] = &collectState{\n   116→\t\t\tcollect:   &wf.Collects[i],\n   117→\t\t\tsatisfied: make(map[int]bool),\n   118→\t\t}\n   119→\t}\n   120→\n   121→\tresults := make(chan stepResult, e.maxSteps)\n   122→\tactiveCount := 0\n   123→\tstepCount := 0\n   124→\tdoneCount := 0\n   125→\taborted := false\n   126→\tvar runErr error\n   127→\n   128→\t// Use a mutex to protect run state from concurrent goroutine access.\n   129→\t// Only the main loop should touch the Run, but we record step start before\n   130→\t// launching the goroutine, so this is safe without a mutex for now.\n   131→\t// The goroutines only read the step and send on the channel.\n   132→\n   133→\tlaunchStep := func(stepName string) error {\n   134→\t\tstepCount++\n   135→\t\tif stepCount > e.maxSteps {\n   136→\t\t\treturn fmt.Errorf(\"workflow exceeded maximum step count (%d)\", e.maxSteps)\n   137→\t\t}\n   138→\n   139→\t\tstep, ok := wf.Steps[stepName]\n   140→\t\tif !ok {\n   141→\t\t\treturn fmt.Errorf(\"step %q not found in workflow\", stepName)\n   142→\t\t}\n   143→\n   144→\t\tactiveCount++\n   145→\t\trun.RecordStepStart(step.Name)\n   146→\t\te.status.OnStepStart(run, step)\n   147→\n   148→\t\tgo func(s *domain.Step) {\n   149→\t\t\tstepCtx := ctx\n   150→\t\t\tif d := stepTimeout(s, e.defaultTimeout); d > 0 {"}]},"parent_tool_use_id":"toolu_01AkfWUPgq78MP7yViLUjjcD","session_id":"abc5f750-0862-4f12-8214-59a5ee9bdc43","uuid":"6b8bfe7b-ccf5-4283-806c-3f7559ca24b3"}
