{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HvCF49Ar4a2KaiVevG8nCC","type":"tool_result","content":"     1→package prompt\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"bytes\"\n     6→\t\"context\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strconv\"\n    13→\t\"strings\"\n    14→\n    15→\t\"log\"\n    16→\n    17→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    18→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    19→)\n    20→\n    21→// defaultAgentArgs maps known agent commands to their default arguments.\n    22→// Commands not in this map receive no default arguments (prompt on stdin only).\n    23→var defaultAgentArgs = map[string][]string{\n    24→\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n    25→\t\"gemini\": {\"-p\"},\n    26→\t\"codex\":  {\"--full-auto\"},\n    27→}\n    28→\n    29→type Adapter struct {\n    30→\tCommands     []string // ordered fallback chain of agent commands\n    31→\tExplicitArgs []string // if non-nil, overrides default args for all commands\n    32→\tRunID        string\n    33→\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n    34→}\n    35→\n    36→func New() *Adapter {\n    37→\treturn &Adapter{\n    38→\t\tCommands: []string{\"claude\"},\n    39→\t}\n    40→}\n    41→\n    42→func (a *Adapter) Name() string {\n    43→\treturn \"prompt\"\n    44→}\n    45→\n    46→// logMessage writes a message to the StatusWriter if available, otherwise to the standard logger.\n    47→func (a *Adapter) logMessage(stepName, msg string) {\n    48→\tif a.StatusWriter != nil {\n    49→\t\ta.StatusWriter.Log(stepName, msg)\n    50→\t} else {\n    51→\t\tlog.Println(msg)\n    52→\t}\n    53→}\n    54→\n    55→// argsFor returns the arguments for the given command. If ExplicitArgs is set,\n    56→// it is used for all commands. Otherwise, known agents get their default args.\n    57→func (a *Adapter) argsFor(command string) []string {\n    58→\tif a.ExplicitArgs != nil {\n    59→\t\treturn a.ExplicitArgs\n    60→\t}\n    61→\tif args, ok := defaultAgentArgs[command]; ok {\n    62→\t\treturn args\n    63→\t}\n    64→\treturn nil\n    65→}\n    66→\n    67→// ParseCommands splits a comma-separated agent_command string into individual\n    68→// command names, trimming whitespace from each entry.\n    69→func ParseCommands(s string) []string {\n    70→\tparts := strings.Split(s, \",\")\n    71→\tvar cmds []string\n    72→\tfor _, p := range parts {\n    73→\t\tp = strings.TrimSpace(p)\n    74→\t\tif p != \"\" {\n    75→\t\t\tcmds = append(cmds, p)\n    76→\t\t}\n    77→\t}\n    78→\treturn cmds\n    79→}\n    80→\n    81→func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    82→\t// Check attempt count for retry limiting\n    83→\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n    84→\t\tmax, err := strconv.Atoi(maxStr)\n    85→\t\tif err == nil {\n    86→\t\t\tcount := readAttemptCount(workDir, step.Name)\n    87→\t\t\tif count >= max {\n    88→\t\t\t\treturn \"give-up\", nil\n    89→\t\t\t}\n    90→\t\t}\n    91→\t}\n    92→\tincrementAttemptCount(workDir, step.Name)\n    93→\n    94→\t// Build the full prompt\n    95→\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n    96→\tif err != nil {\n    97→\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n    98→\t}\n    99→\n   100→\t// Try each command in the fallback chain\n   101→\tvar lastResult string\n   102→\tvar lastStdout []byte\n   103→\tvar lastErr error\n   104→\tran := false\n   105→\n   106→\tfor i, command := range a.Commands {\n   107→\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n   108→\t\tlastResult = result\n   109→\t\tlastStdout = stdout\n   110→\t\tlastErr = fallbackErr\n   111→\n   112→\t\tif fallbackErr == nil {\n   113→\t\t\tif i > 0 {\n   114→\t\t\t\tmsg := fmt.Sprintf(\"[fallback] step %q: using agent %q (primary agents failed)\", step.Name, command)\n   115→\t\t\t\ta.logMessage(step.Name, msg)\n   116→\t\t\t}\n   117→\t\t\tbreak\n   118→\t\t}\n   119→\t\tif stdout != nil {\n   120→\t\t\tran = true\n   121→\t\t}\n   122→\t\t// Log the fallback attempt\n   123→\t\tif i < len(a.Commands)-1 {\n   124→\t\t\tmsg := fmt.Sprintf(\"[fallback] step %q: agent %q failed (%v), trying %q\", step.Name, command, fallbackErr, a.Commands[i+1])\n   125→\t\t\ta.logMessage(step.Name, msg)\n   126→\t\t}\n   127→\t}\n   128→\n   129→\tif lastErr != nil && !ran && lastStdout == nil {\n   130→\t\t// All commands failed to produce any output (e.g., all not found)\n   131→\t\treturn \"\", lastErr\n   132→\t}\n   133→\n   134→\tresult := lastResult\n   135→\tif lastErr != nil {\n   136→\t\t// Last command in chain crashed without a result marker\n   137→\t\tresult = \"fail\"\n   138→\t}\n   139→\n   140→\t// Write output file\n   141→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   142→\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n   143→\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n   144→\t}\n   145→\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n   146→\treturn result, nil\n   147→}\n   148→\n   149→// tryCommand executes a single agent command and returns:\n   150→//   - result: the step result name (e.g. \"success\", \"fail\")\n   151→//   - stdout: captured stdout bytes\n   152→//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n   153→//\n   154→// Fallback-eligible conditions:\n   155→//   - Command not found or failed to start (stdout will be nil)\n   156→//   - Command exited non-zero without a CLOCHE_RESULT marker\n   157→//\n   158→// Definitive (non-fallback) conditions:\n   159→//   - Command exited 0\n   160→//   - Command exited non-zero but produced a CLOCHE_RESULT marker\n   161→func (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n   162→\targs := a.argsFor(command)\n   163→\tcmd := exec.CommandContext(ctx, command, args...)\n   164→\tcmd.Dir = workDir\n   165→\tcmd.Stdin = strings.NewReader(prompt)\n   166→\n   167→\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n   168→\tif a.StatusWriter == nil {\n   169→\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n   170→\t\tcmd.Stdout = &stdoutBuf\n   171→\t\tcmd.Stderr = &stderrBuf\n   172→\n   173→\t\trunErr := cmd.Run()\n   174→\t\tstdoutBytes := stdoutBuf.Bytes()\n   175→\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n   176→\t}\n   177→\n   178→\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n   179→\tpipe, err := cmd.StdoutPipe()\n   180→\tif err != nil {\n   181→\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n   182→\t}\n   183→\tcmd.Stderr = nil // discard stderr\n   184→\n   185→\tif err := cmd.Start(); err != nil {\n   186→\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n   187→\t}\n   188→\n   189→\t// textBuf accumulates extracted text content for result extraction.\n   190→\t// rawBuf accumulates raw stdout for the output log file.\n   191→\tvar textBuf, rawBuf bytes.Buffer\n   192→\t// lineBuf accumulates text deltas into lines for streaming.\n   193→\tvar lineBuf strings.Builder\n   194→\n   195→\tscanner := bufio.NewScanner(pipe)\n   196→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n   197→\tfor scanner.Scan() {\n   198→\t\traw := scanner.Bytes()\n   199→\t\trawBuf.Write(raw)\n   200→\t\trawBuf.WriteByte('\\n')\n   201→\n   202→\t\ttext := extractStreamText(raw)\n   203→\t\tif text == \"\" {\n   204→\t\t\tcontinue\n   205→\t\t}\n   206→\t\ttextBuf.WriteString(text)\n   207→\n   208→\t\t// Stream complete lines to StatusWriter as they form.\n   209→\t\tlineBuf.WriteString(text)\n   210→\t\tfor {\n   211→\t\t\ts := lineBuf.String()\n   212→\t\t\tidx := strings.IndexByte(s, '\\n')\n   213→\t\t\tif idx < 0 {\n   214→\t\t\t\tbreak\n   215→\t\t\t}\n   216→\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n   217→\t\t\tlineBuf.Reset()\n   218→\t\t\tlineBuf.WriteString(s[idx+1:])\n   219→\t\t}\n   220→\t}\n   221→\t// Flush any remaining partial line.\n   222→\tif lineBuf.Len() > 0 {\n   223→\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n   224→\t}\n   225→\tif scanErr := scanner.Err(); scanErr != nil {\n   226→\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n   227→\t}\n   228→\n   229→\twaitErr := cmd.Wait()\n   230→\t// Prefer extracted text (stream-json) for result classification; fall back\n   231→\t// to raw output for non-JSON commands (scripts, non-claude agents).\n   232→\tclassifyBuf := textBuf.Bytes()\n   233→\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n   234→\t\tclassifyBuf = rawBuf.Bytes()\n   235→\t}\n   236→\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n   237→\treturn result, rawBuf.Bytes(), fallbackErr\n   238→}\n   239→\n   240→// classifyResult interprets the command's exit status and stdout to determine\n   241→// the step result.\n   242→func (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n   243→\tif runErr != nil {\n   244→\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n   245→\t\t\t// Command failed to start (not found, permission denied, etc.)\n   246→\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n   247→\t\t}\n   248→\t\t// Command ran but exited non-zero\n   249→\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   250→\t\tif found {\n   251→\t\t\treturn markerResult, stdoutBytes, nil\n   252→\t\t}\n   253→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n   254→\t}\n   255→\n   256→\t// Command succeeded (exit 0)\n   257→\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n   258→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n   259→\t}\n   260→\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   261→\tresult := \"success\"\n   262→\tif found {\n   263→\t\tresult = markerResult\n   264→\t}\n   265→\treturn result, stdoutBytes, nil\n   266→}\n   267→\n   268→// extractStreamText parses a stream-json line and returns text content.\n   269→// It handles both content_block_delta (text_delta) events for streaming and\n   270→// result events for final output (which contains the CLOCHE_RESULT marker).\n   271→func extractStreamText(line []byte) string {\n   272→\t// Fast path: only parse lines that could contain text we care about.\n   273→\tif bytes.Contains(line, []byte(`\"text_delta\"`)) {\n   274→\t\tvar event struct {\n   275→\t\t\tType  string `json:\"type\"`\n   276→\t\t\tDelta struct {\n   277→\t\t\t\tType string `json:\"type\"`\n   278→\t\t\t\tText string `json:\"text\"`\n   279→\t\t\t} `json:\"delta\"`\n   280→\t\t}\n   281→\t\tif json.Unmarshal(line, &event) == nil &&\n   282→\t\t\tevent.Type == \"content_block_delta\" && event.Delta.Type == \"text_delta\" {\n   283→\t\t\treturn event.Delta.Text\n   284→\t\t}\n   285→\t}\n   286→\n   287→\t// Also extract the final result text (contains CLOCHE_RESULT marker).\n   288→\tif bytes.Contains(line, []byte(`\"result\"`)) && bytes.Contains(line, []byte(`\"subtype\"`)) {\n   289→\t\tvar event struct {\n   290→\t\t\tType   string `json:\"type\"`\n   291→\t\t\tResult string `json:\"result\"`\n   292→\t\t}\n   293→\t\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n   294→\t\t\treturn event.Result\n   295→\t\t}\n   296→\t}\n   297→\n   298→\treturn \"\"\n   299→}\n   300→\n   301→func assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n   302→\tvar parts []string\n   303→\n   304→\t// 1. Read system template from step config\n   305→\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n   306→\t\tcontent, err := resolveContent(tmpl, workDir)\n   307→\t\tif err != nil {\n   308→\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n   309→\t\t}\n   310→\t\tparts = append(parts, content)\n   311→\t}\n   312→\n   313→\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n   314→\tuserPrompt := readUserPrompt(workDir, runID)\n   315→\tif userPrompt != \"\" {\n   316→\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n   317→\t}\n   318→\n   319→\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n   320→\tif step.Config[\"feedback\"] == \"true\" {\n   321→\t\tfeedback := readFeedback(workDir)\n   322→\t\tif feedback != \"\" {\n   323→\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n   324→\t\t}\n   325→\t}\n   326→\n   327→\t// 4. Result selection instructions\n   328→\tif len(step.Results) > 0 {\n   329→\t\tvar resultLines []string\n   330→\t\tresultLines = append(resultLines, \"## Result Selection\")\n   331→\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n   332→\t\tfor _, r := range step.Results {\n   333→\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n   334→\t\t}\n   335→\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n   336→\t}\n   337→\n   338→\treturn strings.Join(parts, \"\\n\\n\"), nil\n   339→}\n   340→\n   341→// resolveContent handles file(\"path\") syntax or returns the string directly.\n   342→func resolveContent(value string, workDir string) (string, error) {\n   343→\t// Check for file(\"path\") syntax from DSL parser\n   344→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n   345→\t\tpath := value[6 : len(value)-2]\n   346→\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n   347→\t\tif err != nil {\n   348→\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n   349→\t\t}\n   350→\t\treturn string(data), nil\n   351→\t}\n   352→\treturn value, nil\n   353→}\n   354→\n   355→func readFeedback(workDir string) string {\n   356→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   357→\tentries, err := os.ReadDir(outputDir)\n   358→\tif err != nil {\n   359→\t\treturn \"\"\n   360→\t}\n   361→\n   362→\tvar parts []string\n   363→\tfor _, entry := range entries {\n   364→\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n   365→\t\t\tcontinue\n   366→\t\t}\n   367→\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n   368→\t\tif err != nil {\n   369→\t\t\tcontinue\n   370→\t\t}\n   371→\t\tcontent := strings.TrimSpace(string(data))\n   372→\t\tif content != \"\" {\n   373→\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n   374→\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n   375→\t\t}\n   376→\t}\n   377→\n   378→\treturn strings.Join(parts, \"\\n\\n\")\n   379→}\n   380→\n   381→func readAttemptCount(workDir, stepName string) int {\n   382→\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n   383→\tdata, err := os.ReadFile(path)\n   384→\tif err != nil {\n   385→\t\treturn 0\n   386→\t}\n   387→\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n   388→\treturn n\n   389→}\n   390→\n   391→// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\n   392→func readUserPrompt(workDir, runID string) string {\n   393→\tif runID == \"\" {\n   394→\t\treturn \"\"\n   395→\t}\n   396→\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   397→\tif data, err := os.ReadFile(path); err == nil {\n   398→\t\treturn string(data)\n   399→\t}\n   400→\treturn \"\"\n   401→}\n   402→\n   403→func incrementAttemptCount(workDir, stepName string) {\n   404→\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n   405→\t_ = os.MkdirAll(dir, 0755)\n   406→\tcount := readAttemptCount(workDir, stepName) + 1\n   407→\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n   408→}\n   409→"}]},"parent_tool_use_id":null,"session_id":"abc5f750-0862-4f12-8214-59a5ee9bdc43","uuid":"b1b69912-9806-44f1-832d-a4c4df2589ea","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/agents/prompt/prompt.go","content":"package prompt\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"log\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\n// defaultAgentArgs maps known agent commands to their default arguments.\n// Commands not in this map receive no default arguments (prompt on stdin only).\nvar defaultAgentArgs = map[string][]string{\n\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n\t\"gemini\": {\"-p\"},\n\t\"codex\":  {\"--full-auto\"},\n}\n\ntype Adapter struct {\n\tCommands     []string // ordered fallback chain of agent commands\n\tExplicitArgs []string // if non-nil, overrides default args for all commands\n\tRunID        string\n\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n}\n\nfunc New() *Adapter {\n\treturn &Adapter{\n\t\tCommands: []string{\"claude\"},\n\t}\n}\n\nfunc (a *Adapter) Name() string {\n\treturn \"prompt\"\n}\n\n// logMessage writes a message to the StatusWriter if available, otherwise to the standard logger.\nfunc (a *Adapter) logMessage(stepName, msg string) {\n\tif a.StatusWriter != nil {\n\t\ta.StatusWriter.Log(stepName, msg)\n\t} else {\n\t\tlog.Println(msg)\n\t}\n}\n\n// argsFor returns the arguments for the given command. If ExplicitArgs is set,\n// it is used for all commands. Otherwise, known agents get their default args.\nfunc (a *Adapter) argsFor(command string) []string {\n\tif a.ExplicitArgs != nil {\n\t\treturn a.ExplicitArgs\n\t}\n\tif args, ok := defaultAgentArgs[command]; ok {\n\t\treturn args\n\t}\n\treturn nil\n}\n\n// ParseCommands splits a comma-separated agent_command string into individual\n// command names, trimming whitespace from each entry.\nfunc ParseCommands(s string) []string {\n\tparts := strings.Split(s, \",\")\n\tvar cmds []string\n\tfor _, p := range parts {\n\t\tp = strings.TrimSpace(p)\n\t\tif p != \"\" {\n\t\t\tcmds = append(cmds, p)\n\t\t}\n\t}\n\treturn cmds\n}\n\nfunc (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n\t// Check attempt count for retry limiting\n\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n\t\tmax, err := strconv.Atoi(maxStr)\n\t\tif err == nil {\n\t\t\tcount := readAttemptCount(workDir, step.Name)\n\t\t\tif count >= max {\n\t\t\t\treturn \"give-up\", nil\n\t\t\t}\n\t\t}\n\t}\n\tincrementAttemptCount(workDir, step.Name)\n\n\t// Build the full prompt\n\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n\t}\n\n\t// Try each command in the fallback chain\n\tvar lastResult string\n\tvar lastStdout []byte\n\tvar lastErr error\n\tran := false\n\n\tfor i, command := range a.Commands {\n\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n\t\tlastResult = result\n\t\tlastStdout = stdout\n\t\tlastErr = fallbackErr\n\n\t\tif fallbackErr == nil {\n\t\t\tif i > 0 {\n\t\t\t\tmsg := fmt.Sprintf(\"[fallback] step %q: using agent %q (primary agents failed)\", step.Name, command)\n\t\t\t\ta.logMessage(step.Name, msg)\n\t\t\t}\n\t\t\tbreak\n\t\t}\n\t\tif stdout != nil {\n\t\t\tran = true\n\t\t}\n\t\t// Log the fallback attempt\n\t\tif i < len(a.Commands)-1 {\n\t\t\tmsg := fmt.Sprintf(\"[fallback] step %q: agent %q failed (%v), trying %q\", step.Name, command, fallbackErr, a.Commands[i+1])\n\t\t\ta.logMessage(step.Name, msg)\n\t\t}\n\t}\n\n\tif lastErr != nil && !ran && lastStdout == nil {\n\t\t// All commands failed to produce any output (e.g., all not found)\n\t\treturn \"\", lastErr\n\t}\n\n\tresult := lastResult\n\tif lastErr != nil {\n\t\t// Last command in chain crashed without a result marker\n\t\tresult = \"fail\"\n\t}\n\n\t// Write output file\n\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n\t}\n\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n\treturn result, nil\n}\n\n// tryCommand executes a single agent command and returns:\n//   - result: the step result name (e.g. \"success\", \"fail\")\n//   - stdout: captured stdout bytes\n//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n//\n// Fallback-eligible conditions:\n//   - Command not found or failed to start (stdout will be nil)\n//   - Command exited non-zero without a CLOCHE_RESULT marker\n//\n// Definitive (non-fallback) conditions:\n//   - Command exited 0\n//   - Command exited non-zero but produced a CLOCHE_RESULT marker\nfunc (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n\targs := a.argsFor(command)\n\tcmd := exec.CommandContext(ctx, command, args...)\n\tcmd.Dir = workDir\n\tcmd.Stdin = strings.NewReader(prompt)\n\n\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n\tif a.StatusWriter == nil {\n\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n\t\tcmd.Stdout = &stdoutBuf\n\t\tcmd.Stderr = &stderrBuf\n\n\t\trunErr := cmd.Run()\n\t\tstdoutBytes := stdoutBuf.Bytes()\n\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n\t}\n\n\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n\tpipe, err := cmd.StdoutPipe()\n\tif err != nil {\n\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n\t}\n\tcmd.Stderr = nil // discard stderr\n\n\tif err := cmd.Start(); err != nil {\n\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n\t}\n\n\t// textBuf accumulates extracted text content for result extraction.\n\t// rawBuf accumulates raw stdout for the output log file.\n\tvar textBuf, rawBuf bytes.Buffer\n\t// lineBuf accumulates text deltas into lines for streaming.\n\tvar lineBuf strings.Builder\n\n\tscanner := bufio.NewScanner(pipe)\n\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n\tfor scanner.Scan() {\n\t\traw := scanner.Bytes()\n\t\trawBuf.Write(raw)\n\t\trawBuf.WriteByte('\\n')\n\n\t\ttext := extractStreamText(raw)\n\t\tif text == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\ttextBuf.WriteString(text)\n\n\t\t// Stream complete lines to StatusWriter as they form.\n\t\tlineBuf.WriteString(text)\n\t\tfor {\n\t\t\ts := lineBuf.String()\n\t\t\tidx := strings.IndexByte(s, '\\n')\n\t\t\tif idx < 0 {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n\t\t\tlineBuf.Reset()\n\t\t\tlineBuf.WriteString(s[idx+1:])\n\t\t}\n\t}\n\t// Flush any remaining partial line.\n\tif lineBuf.Len() > 0 {\n\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n\t}\n\tif scanErr := scanner.Err(); scanErr != nil {\n\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n\t}\n\n\twaitErr := cmd.Wait()\n\t// Prefer extracted text (stream-json) for result classification; fall back\n\t// to raw output for non-JSON commands (scripts, non-claude agents).\n\tclassifyBuf := textBuf.Bytes()\n\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n\t\tclassifyBuf = rawBuf.Bytes()\n\t}\n\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n\treturn result, rawBuf.Bytes(), fallbackErr\n}\n\n// classifyResult interprets the command's exit status and stdout to determine\n// the step result.\nfunc (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n\tif runErr != nil {\n\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n\t\t\t// Command failed to start (not found, permission denied, etc.)\n\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n\t\t}\n\t\t// Command ran but exited non-zero\n\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n\t\tif found {\n\t\t\treturn markerResult, stdoutBytes, nil\n\t\t}\n\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n\t}\n\n\t// Command succeeded (exit 0)\n\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n\t}\n\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, stdoutBytes, nil\n}\n\n// extractStreamText parses a stream-json line and returns text content.\n// It handles both content_block_delta (text_delta) events for streaming and\n// result events for final output (which contains the CLOCHE_RESULT marker).\nfunc extractStreamText(line []byte) string {\n\t// Fast path: only parse lines that could contain text we care about.\n\tif bytes.Contains(line, []byte(`\"text_delta\"`)) {\n\t\tvar event struct {\n\t\t\tType  string `json:\"type\"`\n\t\t\tDelta struct {\n\t\t\t\tType string `json:\"type\"`\n\t\t\t\tText string `json:\"text\"`\n\t\t\t} `json:\"delta\"`\n\t\t}\n\t\tif json.Unmarshal(line, &event) == nil &&\n\t\t\tevent.Type == \"content_block_delta\" && event.Delta.Type == \"text_delta\" {\n\t\t\treturn event.Delta.Text\n\t\t}\n\t}\n\n\t// Also extract the final result text (contains CLOCHE_RESULT marker).\n\tif bytes.Contains(line, []byte(`\"result\"`)) && bytes.Contains(line, []byte(`\"subtype\"`)) {\n\t\tvar event struct {\n\t\t\tType   string `json:\"type\"`\n\t\t\tResult string `json:\"result\"`\n\t\t}\n\t\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n\t\t\treturn event.Result\n\t\t}\n\t}\n\n\treturn \"\"\n}\n\nfunc assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n\tvar parts []string\n\n\t// 1. Read system template from step config\n\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n\t\tcontent, err := resolveContent(tmpl, workDir)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n\t\t}\n\t\tparts = append(parts, content)\n\t}\n\n\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n\tuserPrompt := readUserPrompt(workDir, runID)\n\tif userPrompt != \"\" {\n\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n\t}\n\n\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n\tif step.Config[\"feedback\"] == \"true\" {\n\t\tfeedback := readFeedback(workDir)\n\t\tif feedback != \"\" {\n\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n\t\t}\n\t}\n\n\t// 4. Result selection instructions\n\tif len(step.Results) > 0 {\n\t\tvar resultLines []string\n\t\tresultLines = append(resultLines, \"## Result Selection\")\n\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n\t\tfor _, r := range step.Results {\n\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n\t\t}\n\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n\t}\n\n\treturn strings.Join(parts, \"\\n\\n\"), nil\n}\n\n// resolveContent handles file(\"path\") syntax or returns the string directly.\nfunc resolveContent(value string, workDir string) (string, error) {\n\t// Check for file(\"path\") syntax from DSL parser\n\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n\t\tpath := value[6 : len(value)-2]\n\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n\t\t}\n\t\treturn string(data), nil\n\t}\n\treturn value, nil\n}\n\nfunc readFeedback(workDir string) string {\n\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\n\tvar parts []string\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tcontent := strings.TrimSpace(string(data))\n\t\tif content != \"\" {\n\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n\t\t}\n\t}\n\n\treturn strings.Join(parts, \"\\n\\n\")\n}\n\nfunc readAttemptCount(workDir, stepName string) int {\n\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n\tdata, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn 0\n\t}\n\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n\treturn n\n}\n\n// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\nfunc readUserPrompt(workDir, runID string) string {\n\tif runID == \"\" {\n\t\treturn \"\"\n\t}\n\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n\tif data, err := os.ReadFile(path); err == nil {\n\t\treturn string(data)\n\t}\n\treturn \"\"\n}\n\nfunc incrementAttemptCount(workDir, stepName string) {\n\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n\t_ = os.MkdirAll(dir, 0755)\n\tcount := readAttemptCount(workDir, stepName) + 1\n\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n}\n","numLines":409,"startLine":1,"totalLines":409}}}
