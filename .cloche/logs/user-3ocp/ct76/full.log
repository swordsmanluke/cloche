result, err = r.execWorkflow(ctx, step, task, projectDir, orchRunID, prevOutput, outputDir)\n\t\tdefault:\n\t\t\treturn \"\", fmt.Errorf(\"unsupported step type %q for step %q\", step.Type, step.Name)\n\t\t}\n\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"step %q: %w\", step.Name, err)\n\t\t}\n\n\t\tlog.Printf(\"hostrunner: step %q result=%q\", step.Name, result)\n\n\t\t// Update prevOutput for next step\n\t\tif step.Type != domain.StepTypeWorkflow {\n\t\t\tprevOutput = stepOutput\n\t\t}\n\n\t\t// Walk the wiring\n\t\tnext, err := wf.NextStep(currentStep, result)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"wiring from step %q result %q: %w\", currentStep, result, err)\n\t\t}\n\n\t\tif next == domain.StepDone || next == domain.StepAbort {\n\t\t\treturn next, nil\n\t\t}\n\n\t\tcurrentStep = next\n\t}\n}\n\nfunc (r *HostRunner) buildEnv(task ports.TrackerTask, projectDir, stepOutput, prevOutput string) []string {\n\tenv := os.Environ()\n\tenv = append(env,\n\t\t\"CLOCHE_TASK_ID=\"+task.ID,\n\t\t\"CLOCHE_TASK_TITLE=\"+task.Title,\n\t\t\"CLOCHE_TASK_BODY=\"+task.Description,\n\t\t\"CLOCHE_PROJECT_DIR=\"+projectDir,\n\t\t\"CLOCHE_STEP_OUTPUT=\"+stepOutput,\n\t\t\"CLOCHE_PREV_OUTPUT=\"+prevOutput,\n\t)\n\treturn env\n}\n\nfunc (r *HostRunner) execScript(ctx context.Context, step *domain.Step, task ports.TrackerTask, projectDir, stepOutput, prevOutput string) (string, error) {\n\trunCmd := step.Config[\"run\"]\n\n\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", runCmd)\n\tcmd.Dir = projectDir\n\tcmd.Env = r.buildEnv(task, projectDir, stepOutput, prevOutput)\n\n\tvar stdout, stderr bytes.Buffer\n\tcmd.Stdout = &stdout\n\tcmd.Stderr = &stderr\n\n\terr := cmd.Run()\n\n\t// Write stdout to output file\n\tif wErr := os.WriteFile(stepOutput, stdout.Bytes(), 0644); wErr != nil {\n\t\tlog.Printf(\"hostrunner: failed to write step output %s: %v\", stepOutput, wErr)\n\t}\n\n\tif err != nil {\n\t\treturn \"fail\", nil\n\t}\n\treturn \"success\", nil\n}\n\nfunc (r *HostRunner) execAgent(ctx context.Context, step *domain.Step, task ports.TrackerTask, projectDir, stepOutput, prevOutput string) (string, error) {\n\tagentCmd := r.AgentCmd\n\tif agentCmd == \"\" {\n\t\tagentCmd = \"claude\"\n\t}\n\n\tpromptContent := step.Config[\"prompt\"]\n\n\tparts := strings.Fields(agentCmd)\n\tcmd := exec.CommandContext(ctx, parts[0], parts[1:]...)\n\tcmd.Dir = projectDir\n\tcmd.Env = r.buildEnv(task, projectDir, stepOutput, prevOutput)\n\tcmd.Stdin = strings.NewReader(promptContent)\n\n\tvar stdout, stderr bytes.Buffer\n\tcmd.Stdout = &stdout\n\tcmd.Stderr = &stderr\n\n\terr := cmd.Run()\n\n\tif wErr := os.WriteFile(stepOutput, stdout.Bytes(), 0644); wErr != nil {\n\t\tlog.Printf(\"hostrunner: failed to write step output %s: %v\", stepOutput, wErr)\n\t}\n\n\tif err != nil {\n\t\treturn \"fail\", nil\n\t}\n\treturn \"success\", nil\n}\n\nfunc (r *HostRunner) execWorkflow(ctx context.Context, step *domain.Step, task ports.TrackerTask, projectDir, orchRunID, prevOutput, outputDir string) (string, error) {\n\tworkflowName := step.Config[\"workflow_name\"]\n\n\t// Determine prompt: read from previous step's output or prompt_step override\n\tpromptSource := prevOutput\n\tif ps, ok := step.Config[\"prompt_step\"]; ok && ps != \"\" {\n\t\tpromptSource = filepath.Join(outputDir, ps+\".out\")\n\t}\n\n\tvar prompt string\n\tif promptSource != \"\" {\n\t\tdata, err := os.ReadFile(promptSource)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"reading prompt from %s: %w\", promptSource, err)\n\t\t}\n\t\tprompt = strings.TrimSpace(string(data))\n\t}\n\n\t// Dispatch the container workflow run\n\trunID, err := r.Dispatch(ctx, workflowName, projectDir, prompt)\n\tif err != nil {\n\t\treturn \"fail\", nil\n\t}\n\n\tlog.Printf(\"hostrunner: dispatched container run %s for workflow %q\", runID, workflowName)\n\n\t// Wait for the run to complete\n\tstate, err := r.WaitRun.WaitRun(ctx, runID)\n\tif err != nil {\n\t\treturn \"fail\", nil\n\t}\n\n\tswitch state {\n\tcase domain.RunStateSucceeded:\n\t\treturn \"success\", nil\n\tdefault:\n\t\treturn \"fail\", nil\n\t}\n}\n","structuredPatch":[],"originalFile":null}}
