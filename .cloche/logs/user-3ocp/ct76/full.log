rfile has\n// changed since the last build.\ntype ImageEnsurer interface {\n\tEnsureImage(ctx context.Context, projectDir, image string) error\n}\n","structuredPatch":[{"oldStart":4,"oldLines":6,"newStart":4,"newLines":8,"lines":["   \"context\"","   \"io\"","   \"time\"","+","+  \"github.com/cloche-dev/cloche/internal/domain\""," )"," "," type ContainerStatus struct {"]}],"userModified":false,"replaceAll":false}}
