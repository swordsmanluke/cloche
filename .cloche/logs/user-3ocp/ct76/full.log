 Dockerfile has\n// changed since the last build.\ntype ImageEnsurer interface {\n\tEnsureImage(ctx context.Context, projectDir, image string) error\n}\n","structuredPatch":[{"oldStart":32,"oldLines":6,"newStart":32,"newLines":11,"lines":["   Inspect(ctx context.Context, containerID string) (*ContainerStatus, error)"," }"," ","+// RunWaiter blocks until the run with the given ID reaches a terminal state.","+type RunWaiter interface {","+  WaitRun(ctx context.Context, runID string) (domain.RunState, error)","+}","+"," // ImageEnsurer is an optional interface that a ContainerRuntime may implement"," // to validate and rebuild container images when the project Dockerfile has"," // changed since the last build."]}],"userModified":false,"replaceAll":false}}
