elp(\"health\")\n    63→\t\t\treturn\n    64→\t\t}\n    65→\t\tcmdHealth(os.Args[2:])\n    66→\t\treturn\n    67→\tcase \"get\":\n    68→\t\tif hasHelpFlag(os.Args[2:]) {\n    69→\t\t\tprintSubcommandHelp(\"get\")\n    70→\t\t\treturn\n    71→\t\t}\n    72→\t\tcmdGet(os.Args[2:])\n    73→\t\treturn\n    74→\tcase \"set\":\n    75→\t\tif hasHelpFlag(os.Args[2:]) {\n    76→\t\t\tprintSubcommandHelp(\"set\")\n    77→\t\t\treturn\n    78→\t\t}\n    79→\t\tcmdSet(os.Args[2:])\n    80→\t\treturn\n    81→\tcase \"tasks\":\n    82→\t\tif hasHelpFlag(os.Args[2:]) {\n    83→\t\t\tprintSubcommandHelp(\"tasks\")\n    84→\t\t\treturn\n    85→\t\t}\n    86→\t\tcmdTasks(os.Args[2:])\n    87→\t\treturn\n    88→\tcase \"workflow\":\n    89→\t\tif hasHelpFlag(os.Args[2:]) {\n    90→\t\t\tprintSubcommandHelp(\"workflow\")\n    91→\t\t\treturn\n    92→\t\t}\n    93→\t\tcmdWorkflow(os.Args[2:])\n    94→\t\treturn\n    95→\tcase \"project\":\n    96→\t\tif hasHelpFlag(os.Args[2:]) {\n    97→\t\t\tprintSubcommandHelp(\"project\")\n    98→\t\t\treturn\n    99→\t\t}\n   100→\t\tcmdProject(os.Args[2:])\n   101→\t\treturn\n   102→\tcase \"validate\":\n   103→\t\tif hasHelpFlag(os.Args[2:]) {\n   104→\t\t\tprintSubcommandHelp(\"validate\")\n   105→\t\t\treturn\n   106→\t\t}\n   107→\t\tcmdValidate(os.Args[2:])\n   108→\t\treturn\n   109→\t}\n   110→\n   111→\t// Handle --help for daemon commands before connecting\n   112→\tdaemonCmds := map[string]bool{\n   113→\t\t\"run\": true, \"resume\": true, \"status\": true, \"logs\": true, \"poll\": true,\n   114→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n   115→\t}\n   116→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n   117→\t\tprintSubcommandHelp(os.Args[1])\n   118→\t\treturn\n   119→\t}\n   120→\n   121→\t// Commands that need a daemon connection\n   122→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   123→\tif addr == \"\" {\n   124→\t\taddr = config.DefaultSocketAddr()\n   125→\t}\n   126→\n   127→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   128→\tif err != nil {\n   129→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   130→\t\tos.Exit(1)\n   131→\t}\n   132→\tdefer conn.Close()\n   133→\n   134→\tclient := pb.NewClocheServiceClient(conn)\n   135→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   136→\tdefer cancel()\n   137→\n   138→\tswitch os.Args[1] {\n   139→\tcase \"run\":\n   140→\t\tcmdRun(ctx, client, os.Args[2:])\n   141→\tcase \"resume\":\n   142→\t\tcmdResume(ctx, client, os.Args[2:])\n   143→\tcase \"status\":\n   144→\t\tcmdStatus(ctx, client, os.Args[2:])\n   145→\tcase \"logs\":\n   146→\t\tcmdLogs(client, os.Args[2:])\n   147→\tcase \"poll\":\n   148→\t\tcmdPoll(client, os.Args[2:])\n   149→\tcase \"list\":\n   150→\t\tcmdList(ctx, client, os.Args[2:])\n   151→\tcase \"stop\":\n   152→\t\tcmdStop(ctx, client, os.Args[2:])\n   153→\tcase \"delete\":\n   154→\t\tcmdDelete(ctx, client, os.Args[2:])\n   155→\tcase \"loop\":\n   156→\t\tcmdLoop(ctx, client, os.Args[2:])\n   157→\tcase \"shutdown\":\n   158→\t\tcmdShutdown(ctx, client, os.Args[2:])\n   159→\tdefault:\n   160→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   161→\t\tprintTopLevelHelp()\n   162→\t\tos.Exit(1)\n   163→\t}\n   164→}\n   165→\n   166→\n   167→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   168→\tvar workflow, prompt, title, issueID string\n   169→\tvar keepContainer bool\n   170→\n   171→\tfor i := 0; i < len(args); i++ {\n   172→\t\tswitch args[i] {\n   173→\t\tcase \"--workflow\":\n   174→\t\t\tif i+1 < len(args) {\n   175→\t\t\t\ti++\n   176→\t\t\t\tworkflow = args[i]\n   177→\t\t\t}\n   178→\t\tcase \"--prompt\", \"-p\":\n   179→\t\t\tif i+1 < len(args) {\n   180→\t\t\t\ti++\n   181→\t\t\t\tprompt = args[i]\n   182→\t\t\t}\n   183→\t\tcase \"--title\":\n   184→\t\t\tif i+1 < len(args) {\n   185→\t\t\t\ti++\n   186→\t\t\t\ttitle = args[i]\n   187→\t\t\t}\n   188→\t\tcase \"--issue\", \"-i\":\n   189→\t\t\tif i+1 < len(args) {\n   190→\t\t\t\ti++\n   191→\t\t\t\tissueID = args[i]\n   192→\t\t\t}\n   193→\t\tcase \"--keep-container\":\n   194→\t\t\tkeepContainer = true\n   195→\t\tdefault:\n   196→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   197→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   198→\t\t\t\tworkflow = args[i]\n   199→\t\t\t}\n   200→\t\t}\n   201→\t}\n   202→\n   203→\tif workflow == \"\" {\n   204→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"] [--issue ID]\\n\")\n   205→\t\tos.Exit(1)\n   206→\t}\n   207→\n   208→\tcwd, _ := os.Getwd()\n   209→\n   210→\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n   211→\t// Try loading from any .cloche file; only extract image for container workflows.\n   212→\tvar image string\n   213→\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n   214→\t\timage = wf.Config[\"container.image\"]\n   215→\t}\n   216→\n   217→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   218→\t\tWorkflowName:  workflow,\n   219→\t\tProjectDir:    cwd,\n   220→\t\tImage:         image,\n   221→\t\tPrompt:        prompt,\n   222→\t\tKeepContainer: keepContainer,\n   223→\t\tTitle:         title,\n   224→\t\tIssueId:       issueID,\n   225→\t})\n   226→\tif err != nil {\n   227→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   228→\t\tos.Exit(1)\n   229→\t}\n   230→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   231→}\n   232→\n   233→func cmdResume(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   234→\tif len(args) < 1 {\n   235→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche resume <run-id> [step-name]\\n\")\n   236→\t\tos.Exit(1)\n   237→\t}\n   238→\n   239→\trunID := args[0]\n   240→\tstepName := \"\"\n   241→\tif len(args) > 1 {\n   242→\t\tstepName = args[1]\n   243→\t}\n   244→\n   245→\t// Send resume via gRPC metadata on a RunWorkflow call\n   246→\tmd := metadata.Pairs(\n   247→\t\t\"x-cloche-resume-run-id\", runID,\n   248→\t\t\"x-cloche-resume-step\", stepName,\n   249→\t)\n   250→\tctx = metadata.NewOutgoingContext(ctx, md)\n   251→\n   252→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{})\n   253→\tif err != nil {\n   254→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   255→\t\tos.Exit(1)\n   256→\t}\n   257→\tfmt.Printf(\"Resumed run: %s\\n\", resp.RunId)\n   258→}\n   259→\n   260→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   261→\t// Parse flags to detect --all before checking positional args.\n   262→\tvar all bool\n   263→\tvar positional []string\n   264→\tfor _, arg := range args {\n   265→\t\tif arg == \"--all\" {\n   266→\t\t\tall = true\n   267→\t\t} else {\n   268→\t\t\tpositional = append(positional, arg)\n   269→\t\t}\n   270→\t}\n   271→\n   272→\t// If a run ID is provided, show single-run status.\n   273→\tif len(positional) > 0 {\n   274→\t\tcmdStatusRun(ctx, client, positional[0])\n   275→\t\treturn\n   276→\t}\n   277→\n   278→\t// No run ID: show daemon status overview.\n   279→\tcmdStatusOverview(ctx, client, os.Stdout, all)\n   280→}\n   281→\n   282→func cmdStatusRun(ctx context.Context, client pb.ClocheServiceClient, runID string) {\n   283→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: runID})\n   284→\tif err != nil {\n   285→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   286→\t\tos.Exit(1)\n   287→\t}\n   288→\n   289→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   290→\tif resp.Title != \"\" {\n   291→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   292→\t}\n   293→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   294→\tif resp.IsHost {\n   295→\t\tfmt.Printf(\"Type:      host\\n\")\n   296→\t} else {\n   297→\t\tfmt.Printf(\"Type:      container\\n\")\n   298→\t}\n   299→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   300→\tif resp.ContainerId != \"\" {\n   301→\t\tcid := resp.ContainerId\n   302→\t\tif len(cid) > 12 {\n   303→\t\t\tcid = cid[:12]\n   304→\t\t}\n   305→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   306→\t}\n   307→\tif resp.ErrorMessage != \"\" {\n   308→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   309→\t}\n   310→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   311→\tfor _, exec := range resp.StepExecutions {\n   312→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   313→\t}\n   314→}\n   315→\n   316→func cmdStatusOverview(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, all bool) {\n   317→\t// Get daemon version.\n   318→\tverResp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   319→\tif err != nil {\n   320→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   321→\t\tos.Exit(1)\n   322→\t}\n   323→\tfmt.Fprintf(w, \"Daemon version: %s\\n\", verResp.Version)\n   324→\n   325→\tcwd, _ := os.Getwd()\n   326→\t_, hasClocheDir := os.Stat(filepath.Join(cwd, \".cloche\"))\n   327→\n   328→\tif !all && hasClocheDir == nil {\n   329→\t\t// In a project directory: show project-specific info.\n   330→\t\tcmdStatusProject(ctx, client, w, cwd)\n   331→\t} else {\n   332→\t\t// Not in a project directory or --all: show global overview.\n   333→\t\tcmdStatusGlobal(ctx, client, w)\n   334→\t}\n   335→}\n   336→\n   337→func cmdStatusProject(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, projectDir string) {\n   338→\tinfo, err := client.GetProjectInfo(ctx, &pb.GetProjectInfoRequest{ProjectDir: projectDir})\n   339→\tif err != nil {\n   340→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   341→\t\tos.Exit(1)\n   342→\t}\n   343→\n   344→\tfmt.Fprintf(w, \"Project: %s\\n\", info.Name)\n   345→\tfmt.Fprintf(w, \"Concurrency: %d\\n\", info.Concurrency)\n   346→\n   347→\tloopStatus := \"stopped\"\n   348→\tif info.LoopRunning {\n   349→\t\tif info.ErrorHalted {\n   350→\t\t\tloopStatus = \"halted\"\n   351→\t\t} else {\n   352→\t\t\tloopStatus = \"running\"\n   353→\t\t}\n   354→\t}\n   355→\tfmt.Fprintf(w, \"Orchestration loop: %s\\n\", loopStatus)\n   356→\n   357→\t// Fetch runs for the past hour to compute success rate.\n   358→\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: projectDir})\n   359→\tif err != nil {\n   360→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   361→\t\tos.Exit(1)\n   362→\t}\n   363→\n   364→\tvar succeeded int\n   365→\tfor _, run := range listResp.Runs {\n   366→\t\tif run.State == \"succeeded\" {\n   367→\t\t\tsucceeded++\n   368→\t\t}\n   369→\t}\n   370→\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n   371→\n   372→\t// Active runs from project info.\n   373→\tfmt.Fprintf(w, \"Active runs: %d\\n\", len(info.ActiveRuns))\n   374→\tfor _, run := range info.ActiveRuns {\n   375→\t\tdur := formatDuration(run.StartedAt)\n   376→\t\tfmt.Fprintf(w, \"  %s: %s\\n\", run.RunId, dur)\n   377→\t}\n   378→}\n   379→\n   380→func cmdStatusGlobal(ctx context.Context, client pb.ClocheServiceClient, w io.Writer) {\n   381→\t// Server filters to past hour when All is not set.\n   382→\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{})\n   383→\tif err != nil {\n   384→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   385→\t\tos.Exit(1)\n   386→\t}\n   387→\n   388→\tvar succeeded, activeCount int\n   389→\ttype activeRun struct {\n   390→\t\tid        string\n   391→\t\tstartedAt string\n   392→\t}\n   393→\tvar actives []activeRun\n   394→\n   395→\tfor _, run := range listResp.Runs {\n   396→\t\tif run.State == \"succeeded\" {\n   397→\t\t\tsucceeded++\n   398→\t\t}\n   399→\t\tif run.State == \"running\" || run.State == \"pending\" {\n   400→\t\t\tactiveCount++\n   401→\t\t\tactives = append(actives, activeRun{id: run.RunId, startedAt: run.StartedAt})\n   402→\t\t}\n   403→\t}\n   404→\n   405→\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n   406→\tfmt.Fprintf(w, \"Active runs: %d\\n\", activeCount)\n   407→\tfor _, a := range actives {\n   408→\t\tdur := formatDuration(a.startedAt)\n   409→\t\tfmt.Fprintf(w, \"  %s: %s\\n\", a.id, dur)\n   410→\t}\n   411→}\n   412→\n   413→// formatDuration parses a Go time string and returns a human-readable duration since then.\n   414→func formatDuration(startedAt string) string {\n   415→\tparsed, err := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", startedAt)\n   416→\tif err != nil {\n   417→\t\treturn startedAt\n   418→\t}\n   419→\td := time.Since(parsed)\n   420→\tif d < time.Minute {\n   421→\t\treturn fmt.Sprintf(\"%ds\", int(d.Seconds()))\n   422→\t}\n   423→\tif d < time.Hour {\n   424→\t\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n   425→\t}\n   426→\treturn fmt.Sprintf(\"%dh%dm\", int(d.Hours()), int(d.Minutes())%60)\n   427→}\n   428→\n   429→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   430→\tvar all bool\n   431→\tvar projectDir, stateFilter, issueFilter string\n   432→\tvar limit int32\n   433→\n   434→\tfor i := 0; i < len(args); i++ {\n   435→\t\tswitch args[i] {\n   436→\t\tcase \"--all\":\n   437→\t\t\tall = true\n   438→\t\tcase \"--project\", \"-p\":\n   439→\t\t\tif i+1 < len(args) {\n   440→\t\t\t\ti++\n   441→\t\t\t\tprojectDir = args[i]\n   442→\t\t\t}\n   443→\t\tcase \"--state\", \"-s\":\n   444→\t\t\tif i+1 < len(args) {\n   445→\t\t\t\ti++\n   446→\t\t\t\tstateFilter = args[i]\n   447→\t\t\t}\n   448→\t\tcase \"--limit\", \"-n\":\n   449→\t\t\tif i+1 < len(args) {\n   450→\t\t\t\ti++\n   451→\t\t\t\tn, err := strconv.Atoi(args[i])\n   452→\t\t\t\tif err != nil {\n   453→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   454→\t\t\t\t\tos.Exit(1)\n   455→\t\t\t\t}\n   456→\t\t\t\tlimit = int32(n)\n   457→\t\t\t}\n   458→\t\tcase \"--issue\", \"-i\":\n   459→\t\t\tif i+1 < len(args) {\n   460→\t\t\t\ti++\n   461→\t\t\t\tissueFilter = args[i]\n   462→\t\t\t}\n   463→\t\t}\n   464→\t}\n   465→\n   466→\treq := &pb.ListRunsRequest{\n   467→\t\tState:  stateFilter,\n   468→\t\tLimit:  limit,\n   469→\t\tTaskId: issueFilter,\n   470→\t}\n   471→\tif projectDir != \"\" {\n   472→\t\treq.ProjectDir = projectDir\n   473→\t} else if all {\n   474→\t\treq.All = true\n   475→\t} else {\n   476→\t\t// Default: filter to current project\n   477→\t\tcwd, _ := os.Getwd()\n   478→\t\treq.ProjectDir = cwd\n   479→\t}\n   480→\n   481→\tresp, err := client.ListRuns(ctx, req)\n   482→\tif err != nil {\n   483→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   484→\t\tos.Exit(1)\n   485→\t}\n   486→\n   487→\tif len(resp.Runs) == 0 {\n   488→\t\tfmt.Println(\"No runs found.\")\n   489→\t\treturn\n   490→\t}\n   491→\n   492→\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n   493→\tfmt.Fprintln(w, \"RUN ID\\tWORKFLOW\\tSTATE\\tTYPE\\tTASK ID\\tTITLE\\tCONTAINER\\tERROR\")\n   494→\tfor _, run := range resp.Runs {\n   495→\t\trunType := \"container\"\n   496→\t\tif run.IsHost {\n   497→\t\t\trunType = \"host\"\n   498→\t\t}\n   499→\t\ttitle := run.Title\n   500→\t\tif len(title) > 40 {\n   501→\t\t\ttitle = title[:37] + \"...\"\n   502→\t\t}\n   503→\t\terrMsg := run.ErrorMessage\n   504→\t\tif len(errMsg) > 60 {\n   505→\t\t\terrMsg = errMsg[:57] + \"...\"\n   506→\t\t}\n   507→\t\tfmt.Fprintf(w, \"%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\n\",\n   508→\t\t\trun.RunId, run.WorkflowName, run.State, runType,\n   509→\t\t\trun.TaskId, title, run.ContainerId, errMsg)\n   510→\t}\n   511→\tw.Flush()\n   512→}\n   513→\n   514→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   515→\tif len(args) < 1 {\n   516→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n   517→\t\tos.Exit(1)\n   518→\t}\n   519→\n   520→\tvar stepFilter, typeFilter string\n   521→\tvar follow bool\n   522→\tvar limit int\n   523→\trunID := args[0]\n   524→\n   525→\tfor i := 1; i < len(args); i++ {\n   526→\t\tswitch args[i] {\n   527→\t\tcase \"--step\", \"-s\":\n   528→\t\t\tif i+1 < len(args) {\n   529→\t\t\t\ti++\n   530→\t\t\t\tstepFilter = args[i]\n   531→\t\t\t}\n   532→\t\tcase \"--type\":\n   533→\t\t\tif i+1 < len(args) {\n   534→\t\t\t\ti++\n   535→\t\t\t\ttypeFilter = args[i]\n   536→\t\t\t}\n   537→\t\tcase \"--follow\", \"-f\":\n   538→\t\t\tfollow = true\n   539→\t\tcase \"--limit\", \"-l\":\n   540→\t\t\tif i+1 < len(args) {\n   541→\t\t\t\ti++\n   542→\t\t\t\tn, err := strconv.Atoi(args[i])\n   543→\t\t\t\tif err != nil || n < 0 {\n   544→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n   545→\t\t\t\t\tos.Exit(1)\n   546→\t\t\t\t}\n   547→\t\t\t\tlimit = n\n   548→\t\t\t}\n   549→\t\t}\n   550→\t}\n   551→\n   552→\t// Use background context — log output can be large and follow mode blocks.\n   553→\tctx := context.Background()\n   554→\tvar mdPairs []string\n   555→\tif follow {\n   556→\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n   557→\t}\n   558→\tif limit > 0 {\n   559→\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n   560→\t}\n   561→\tif len(mdPairs) > 0 {\n   562→\t\tmd := metadata.Pairs(mdPairs...)\n   563→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   564→\t}\n   565→\n   566→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   567→\t\tRunId:    runID,\n   568→\t\tStepName: stepFilter,\n   569→\t\tLogType:  typeFilter,\n   570→\t})\n   571→\tif err != nil {\n   572→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   573→\t\tos.Exit(1)\n   574→\t}\n   575→\n   576→\tfor {\n   577→\t\tentry, err := stream.Recv()\n   578→\t\tif err != nil {\n   579→\t\t\tif errors.Is(err, io.EOF) {\n   580→\t\t\t\tbreak\n   581→\t\t\t}\n   582→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   583→\t\t\tos.Exit(1)\n   584→\t\t}\n   585→\n   586→\t\tswitch entry.Type {\n   587→\t\tcase \"step_started\":\n   588→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   589→\t\t\tif entry.Message != \"\" {\n   590→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   591→\t\t\t}\n   592→\t\tcase \"step_completed\":\n   593→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   594→\t\t\tif entry.Message != \"\" {\n   595→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   596→\t\t\t}\n   597→\t\tcase \"run_completed\":\n   598→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   599→\t\t\tif entry.Message != \"\" {\n   600→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   601→\t\t\t}\n   602→\t\tcase \"full_log\":\n   603→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   604→\t\tcase \"log\":\n   605→\t\t\t// Live-streamed log line from an active run.\n   606→\t\t\tfmt.Println(entry.Message)\n   607→\t\tdefault:\n   608→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   609→\t\t\tif entry.StepName != \"\" {\n   610→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   611→\t\t\t}\n   612→\t\t\tif entry.Message != \"\" {\n   613→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   614→\t\t\t}\n   615→\t\t}\n   616→\t}\n   617→}\n   618→\n   619→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   620→\tif len(args) < 1 {\n   621→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   622→\t\tos.Exit(1)\n   623→\t}\n   624→\n   625→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   626→\tif err != nil {\n   627→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   628→\t\tos.Exit(1)\n   629→\t}\n   630→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   631→}\n   632→\n   633→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   634→\tif len(args) < 1 {\n   635→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   636→\t\tos.Exit(1)\n   637→\t}\n   638→\n   639→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   640→\tif err != nil {\n   641→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   642→\t\tos.Exit(1)\n   643→\t}\n   644→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   645→}\n   646→\n   647→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   648→\tcwd, _ := os.Getwd()\n   649→\n   650→\t// Check for \"stop\" subcommand\n   651→\tif len(args) > 0 && args[0] == \"stop\" {\n   652→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   653→\t\tif err != nil {\n   654→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   655→\t\t\tos.Exit(1)\n   656→\t\t}\n   657→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   658→\t\treturn\n   659→\t}\n   660→\n   661→\t// Check for \"resume\" subcommand\n   662→\tif len(args) > 0 && args[0] == \"resume\" {\n   663→\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n   664→\t\tif err != nil {\n   665→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   666→\t\t\tos.Exit(1)\n   667→\t\t}\n   668→\t\tfmt.Println(\"Orchestration loop resumed.\")\n   669→\t\treturn\n   670→\t}\n   671→\n   672→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   673→\tvar maxConcurrent int32\n   674→\tfor i := 0; i < len(args); i++ {\n   675→\t\tswitch args[i] {\n   676→\t\tcase \"--max\":\n   677→\t\t\tif i+1 < len(args) {\n   678→\t\t\t\ti++\n   679→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   680→\t\t\t\tif n != 1 || err != nil {\n   681→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   682→\t\t\t\t\tos.Exit(1)\n   683→\t\t\t\t}\n   684→\t\t\t}\n   685→\t\t}\n   686→\t}\n   687→\n   688→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   689→\t\tProjectDir:    cwd,\n   690→\t\tMaxConcurrent: maxConcurrent,\n   691→\t})\n   692→\tif err != nil {\n   693→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   694→\t\tos.Exit(1)\n   695→\t}\n   696→\tif maxConcurrent > 0 {\n   697→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   698→\t} else {\n   699→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   700→\t}\n   701→}\n   702→\n   703→func cmdTasks(args []string) {\n   704→\t// Determine HTTP address from env\n   705→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   706→\tif httpAddr == \"\" {\n   707→\t\thttpAddr = \"localhost:8080\"\n   708→\t}\n   709→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   710→\n   711→\t// Determine project label from --project flag or current directory\n   712→\tprojectDir := \"\"\n   713→\tfor i := 0; i < len(args); i++ {\n   714→\t\tswitch args[i] {\n   715→\t\tcase \"--project\":\n   716→\t\t\tif i+1 < len(args) {\n   717→\t\t\t\ti++\n   718→\t\t\t\tprojectDir = args[i]\n   719→\t\t\t}\n   720→\t\t}\n   721→\t}\n   722→\n   723→\tif projectDir == \"\" {\n   724→\t\tcwd, _ := os.Getwd()\n   725→\t\tprojectDir = filepath.Base(cwd)\n   726→\t}\n   727→\n   728→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   729→\tresp, err := http.Get(tasksURL)\n   730→\tif err != nil {\n   731→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   732→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   733→\t\tos.Exit(1)\n   734→\t}\n   735→\tdefer resp.Body.Close()\n   736→\n   737→\tif resp.StatusCode != 200 {\n   738→\t\tbody, _ := io.ReadAll(resp.Body)\n   739→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   740→\t\tos.Exit(1)\n   741→\t}\n   742→\n   743→\ttype taskEntry struct {\n   744→\t\tID          string `json:\"id\"`\n   745→\t\tStatus      string `json:\"status\"`\n   746→\t\tTitle       string `json:\"title\"`\n   747→\t\tDescription string `json:\"description\"`\n   748→\t\tAssigned    bool   `json:\"assigned\"`\n   749→\t\tAssignedAt  string `json:\"assigned_at\"`\n   750→\t\tRunID       string `json:\"run_id\"`\n   751→\t}\n   752→\n   753→\tvar tasks []taskEntry\n   754→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   755→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   756→\t\tos.Exit(1)\n   757→\t}\n   758→\n   759→\tif len(tasks) == 0 {\n   760→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   761→\t\treturn\n   762→\t}\n   763→\n   764→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   765→\tfor _, t := range tasks {\n   766→\t\tstatus := t.Status\n   767→\t\tif status == \"\" {\n   768→\t\t\tstatus = \"open\"\n   769→\t\t}\n   770→\t\tassigned := \"-\"\n   771→\t\tif t.Assigned {\n   772→\t\t\tassigned = \"yes\"\n   773→\t\t}\n   774→\t\trunID := \"\"\n   775→\t\tif t.RunID != \"\" {\n   776→\t\t\trunID = t.RunID\n   777→\t\t\tif len(runID) > 30 {\n   778→\t\t\t\trunID = runID[:27] + \"...\"\n   779→\t\t\t}\n   780→\t\t}\n   781→\t\ttitle := t.Title\n   782→\t\tif len(title) > 40 {\n   783→\t\t\ttitle = title[:37] + \"...\"\n   784→\t\t}\n   785→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   786→\t}\n   787→}\n   788→\n   789→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   790→\tvar force bool\n   791→\tfor _, a := range args {\n   792→\t\tif a == \"-f\" || a == \"--force\" {\n   793→\t\t\tforce = true\n   794→\t\t}\n   795→\t}\n   796→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n   797→\tif err != nil {\n   798→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   799→\t\tos.Exit(1)\n   800→\t}\n   801→\tfmt.Println(\"Daemon shutting down.\")\n   802→}\n   803→\n   804→// resolveRunContext returns the project directory and run ID for context\n   805→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   806→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   807→func resolveRunContext() (projectDir, runID string, err error) {\n   808→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   809→\tif runID == \"\" {\n   810→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   811→\t}\n   812→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   813→\tif projectDir == \"\" {\n   814→\t\tprojectDir, err = os.Getwd()\n   815→\t\tif err != nil {\n   816→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   817→\t\t}\n   818→\t}\n   819→\treturn projectDir, runID, nil\n   820→}\n   821→\n   822→func cmdGet(args []string) {\n   823→\tif len(args) < 1 {\n   824→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   825→\t\tos.Exit(1)\n   826→\t}\n   827→\n   828→\tprojectDir, runID, err := resolveRunContext()\n   829→\tif err != nil {\n   830→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   831→\t\tos.Exit(1)\n   832→\t}\n   833→\n   834→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   835→\tif err != nil {\n   836→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   837→\t\tos.Exit(1)\n   838→\t}\n   839→\tif !ok {\n   840→\t\tos.Exit(1)\n   841→\t}\n   842→\tfmt.Println(val)\n   843→}\n   844→\n   845→func cmdSet(args []string) {\n   846→\tif len(args) < 2 {\n   847→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   848→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   849→\t\tos.Exit(1)\n   850→\t}\n   851→\n   852→\tprojectDir, runID, err := resolveRunContext()\n   853→\tif err != nil {\n   854→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   855→\t\tos.Exit(1)\n   856→\t}\n   857→\n   858→\tvalue := args[1]\n   859→\tif value == \"-\" {\n   860→\t\tdata, err := io.ReadAll(os.Stdin)\n   861→\t\tif err != nil {\n   862→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   863→\t\t\tos.Exit(1)\n   864→\t\t}\n   865→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   866→\t}\n   867→\n   868→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   869→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   870→\t\tos.Exit(1)\n   871→\t}\n   872→}\n   873→\n   874→func cmdVersion() {\n   875→\tcliVersion := version.Version()\n   876→\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   877→\n   878→\t// Try to get daemon version via gRPC\n   879→\tdaemonVersion := \"<unavailable>\"\n   880→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   881→\tif addr == \"\" {\n   882→\t\taddr = config.DefaultSocketAddr()\n   883→\t}\n   884→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   885→\tif err == nil {\n   886→\t\tdefer conn.Close()\n   887→\t\tclient := pb.NewClocheServiceClient(conn)\n   888→\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   889→\t\tdefer cancel()\n   890→\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   891→\t\tif err == nil {\n   892→\t\t\tdaemonVersion = resp.Version\n   893→\t\t}\n   894→\t}\n   895→\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   896→\n   897→\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   898→\tagentVersion := \"<unavailable>\"\n   899→\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   900→\tif image == \"\" {\n   901→\t\timage = \"cloche-agent:latest\"\n   902→\t}\n   903→\tout, err := exec.CommandContext(\n   904→\t\tcontext.Background(),\n   905→\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   906→\t).Output()\n   907→\tif err == nil {\n   908→\t\tagentVersion = strings.TrimSpace(string(out))\n   909→\t\t// Strip \"cloche-agent \" prefix if present\n   910→\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n   911→\t}\n   912→\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n   913→\n   914→\t// Warn about version mismatches\n   915→\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n   916→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n   917→\t}\n   918→\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n   919→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n   920→\t}\n   921→}\n   922→"}]},"parent_tool_use_id":null,"session_id":"cb424313-5312-4541-a526-925900ab026c","uuid":"5915089c-0ee4-4f1d-803f-f26be5e1aeec","timestamp":"2026-03-18T19:18:01.696Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\t\"text/tabwriter\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n\t\"github.com/cloche-dev/cloche/internal/version\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n\n\t// Handle version flags before anything else\n\tif os.Args[1] == \"-v\" || os.Args[1] == \"--version\" {\n\t\tcmdVersion()\n\t\treturn\n\t}\n\n\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n\tswitch os.Args[1] {\n\tcase \"help\":\n\t\tprintHelp(os.Args[2:])\n\t\treturn\n\tcase \"--help\", \"-h\":\n\t\tprintTopLevelHelp()\n\t\treturn\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"init\")\n\t\t\treturn\n\t\t}\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"health\")\n\t\t\treturn\n\t\t}\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\tcase \"get\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"get\")\n\t\t\treturn\n\t\t}\n\t\tcmdGet(os.Args[2:])\n\t\treturn\n\tcase \"set\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"set\")\n\t\t\treturn\n\t\t}\n\t\tcmdSet(os.Args[2:])\n\t\treturn\n\tcase \"tasks\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"tasks\")\n\t\t\treturn\n\t\t}\n\t\tcmdTasks(os.Args[2:])\n\t\treturn\n\tcase \"workflow\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"workflow\")\n\t\t\treturn\n\t\t}\n\t\tcmdWorkflow(os.Args[2:])\n\t\treturn\n\tcase \"project\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"project\")\n\t\t\treturn\n\t\t}\n\t\tcmdProject(os.Args[2:])\n\t\treturn\n\tcase \"validate\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"validate\")\n\t\t\treturn\n\t\t}\n\t\tcmdValidate(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Handle --help for daemon commands before connecting\n\tdaemonCmds := map[string]bool{\n\t\t\"run\": true, \"resume\": true, \"status\": true, \"logs\": true, \"poll\": true,\n\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n\t}\n\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n\t\tprintSubcommandHelp(os.Args[1])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = config.DefaultSocketAddr()\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"resume\":\n\t\tcmdResume(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client, os.Args[2:])\n\tdefault:\n\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n}\n\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title, issueID string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--issue\", \"-i\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tissueID = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"] [--issue ID]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n\t// Try loading from any .cloche file; only extract image for container workflows.\n\tvar image string\n\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n\t\timage = wf.Config[\"container.image\"]\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t\tIssueId:       issueID,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdResume(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche resume <run-id> [step-name]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\trunID := args[0]\n\tstepName := \"\"\n\tif len(args) > 1 {\n\t\tstepName = args[1]\n\t}\n\n\t// Send resume via gRPC metadata on a RunWorkflow call\n\tmd := metadata.Pairs(\n\t\t\"x-cloche-resume-run-id\", runID,\n\t\t\"x-cloche-resume-step\", stepName,\n\t)\n\tctx = metadata.NewOutgoingContext(ctx, md)\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Resumed run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\t// Parse flags to detect --all before checking positional args.\n\tvar all bool\n\tvar positional []string\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t} else {\n\t\t\tpositional = append(positional, arg)\n\t\t}\n\t}\n\n\t// If a run ID is provided, show single-run status.\n\tif len(positional) > 0 {\n\t\tcmdStatusRun(ctx, client, positional[0])\n\t\treturn\n\t}\n\n\t// No run ID: show daemon status overview.\n\tcmdStatusOverview(ctx, client, os.Stdout, all)\n}\n\nfunc cmdStatusRun(ctx context.Context, client pb.ClocheServiceClient, runID string) {\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: runID})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdStatusOverview(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, all bool) {\n\t// Get daemon version.\n\tverResp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Fprintf(w, \"Daemon version: %s\\n\", verResp.Version)\n\n\tcwd, _ := os.Getwd()\n\t_, hasClocheDir := os.Stat(filepath.Join(cwd, \".cloche\"))\n\n\tif !all && hasClocheDir == nil {\n\t\t// In a project directory: show project-specific info.\n\t\tcmdStatusProject(ctx, client, w, cwd)\n\t} else {\n\t\t// Not in a project directory or --all: show global overview.\n\t\tcmdStatusGlobal(ctx, client, w)\n\t}\n}\n\nfunc cmdStatusProject(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, projectDir string) {\n\tinfo, err := client.GetProjectInfo(ctx, &pb.GetProjectInfoRequest{ProjectDir: projectDir})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Fprintf(w, \"Project: %s\\n\", info.Name)\n\tfmt.Fprintf(w, \"Concurrency: %d\\n\", info.Concurrency)\n\n\tloopStatus := \"stopped\"\n\tif info.LoopRunning {\n\t\tif info.ErrorHalted {\n\t\t\tloopStatus = \"halted\"\n\t\t} else {\n\t\t\tloopStatus = \"running\"\n\t\t}\n\t}\n\tfmt.Fprintf(w, \"Orchestration loop: %s\\n\", loopStatus)\n\n\t// Fetch runs for the past hour to compute success rate.\n\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: projectDir})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvar succeeded int\n\tfor _, run := range listResp.Runs {\n\t\tif run.State == \"succeeded\" {\n\t\t\tsucceeded++\n\t\t}\n\t}\n\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n\n\t// Active runs from project info.\n\tfmt.Fprintf(w, \"Active runs: %d\\n\", len(info.ActiveRuns))\n\tfor _, run := range info.ActiveRuns {\n\t\tdur := formatDuration(run.StartedAt)\n\t\tfmt.Fprintf(w, \"  %s: %s\\n\", run.RunId, dur)\n\t}\n}\n\nfunc cmdStatusGlobal(ctx context.Context, client pb.ClocheServiceClient, w io.Writer) {\n\t// Server filters to past hour when All is not set.\n\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvar succeeded, activeCount int\n\ttype activeRun struct {\n\t\tid        string\n\t\tstartedAt string\n\t}\n\tvar actives []activeRun\n\n\tfor _, run := range listResp.Runs {\n\t\tif run.State == \"succeeded\" {\n\t\t\tsucceeded++\n\t\t}\n\t\tif run.State == \"running\" || run.State == \"pending\" {\n\t\t\tactiveCount++\n\t\t\tactives = append(actives, activeRun{id: run.RunId, startedAt: run.StartedAt})\n\t\t}\n\t}\n\n\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n\tfmt.Fprintf(w, \"Active runs: %d\\n\", activeCount)\n\tfor _, a := range actives {\n\t\tdur := formatDuration(a.startedAt)\n\t\tfmt.Fprintf(w, \"  %s: %s\\n\", a.id, dur)\n\t}\n}\n\n// formatDuration parses a Go time string and returns a human-readable duration since then.\nfunc formatDuration(startedAt string) string {\n\tparsed, err := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", startedAt)\n\tif err != nil {\n\t\treturn startedAt\n\t}\n\td := time.Since(parsed)\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%ds\", int(d.Seconds()))\n\t}\n\tif d < time.Hour {\n\t\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n\t}\n\treturn fmt.Sprintf(\"%dh%dm\", int(d.Hours()), int(d.Minutes())%60)\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tvar projectDir, stateFilter, issueFilter string\n\tvar limit int32\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--all\":\n\t\t\tall = true\n\t\tcase \"--project\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\tcase \"--state\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstateFilter = args[i]\n\t\t\t}\n\t\tcase \"--limit\", \"-n\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = int32(n)\n\t\t\t}\n\t\tcase \"--issue\", \"-i\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tissueFilter = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\treq := &pb.ListRunsRequest{\n\t\tState:  stateFilter,\n\t\tLimit:  limit,\n\t\tTaskId: issueFilter,\n\t}\n\tif projectDir != \"\" {\n\t\treq.ProjectDir = projectDir\n\t} else if all {\n\t\treq.All = true\n\t} else {\n\t\t// Default: filter to current project\n\t\tcwd, _ := os.Getwd()\n\t\treq.ProjectDir = cwd\n\t}\n\n\tresp, err := client.ListRuns(ctx, req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n\tfmt.Fprintln(w, \"RUN ID\\tWORKFLOW\\tSTATE\\tTYPE\\tTASK ID\\tTITLE\\tCONTAINER\\tERROR\")\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\ttitle := run.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\terrMsg := run.ErrorMessage\n\t\tif len(errMsg) > 60 {\n\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t}\n\t\tfmt.Fprintf(w, \"%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\n\",\n\t\t\trun.RunId, run.WorkflowName, run.State, runType,\n\t\t\trun.TaskId, title, run.ContainerId, errMsg)\n\t}\n\tw.Flush()\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\tvar limit int\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\tcase \"--limit\", \"-l\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil || n < 0 {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = n\n\t\t\t}\n\t\t}\n\t}\n\n\t// Use background context — log output can be large and follow mode blocks.\n\tctx := context.Background()\n\tvar mdPairs []string\n\tif follow {\n\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n\t}\n\tif limit > 0 {\n\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n\t}\n\tif len(mdPairs) > 0 {\n\t\tmd := metadata.Pairs(mdPairs...)\n\t\tctx = metadata.NewOutgoingContext(ctx, md)\n\t}\n\n\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Check for \"resume\" subcommand\n\tif len(args) > 0 && args[0] == \"resume\" {\n\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop resumed.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdTasks(args []string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\t// Determine project label from --project flag or current directory\n\tprojectDir := \"\"\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tcwd, _ := os.Getwd()\n\t\tprojectDir = filepath.Base(cwd)\n\t}\n\n\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n\tresp, err := http.Get(tasksURL)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\ttype taskEntry struct {\n\t\tID          string `json:\"id\"`\n\t\tStatus      string `json:\"status\"`\n\t\tTitle       string `json:\"title\"`\n\t\tDescription string `json:\"description\"`\n\t\tAssigned    bool   `json:\"assigned\"`\n\t\tAssignedAt  string `json:\"assigned_at\"`\n\t\tRunID       string `json:\"run_id\"`\n\t}\n\n\tvar tasks []taskEntry\n\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(tasks) == 0 {\n\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n\t\treturn\n\t}\n\n\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n\tfor _, t := range tasks {\n\t\tstatus := t.Status\n\t\tif status == \"\" {\n\t\t\tstatus = \"open\"\n\t\t}\n\t\tassigned := \"-\"\n\t\tif t.Assigned {\n\t\t\tassigned = \"yes\"\n\t\t}\n\t\trunID := \"\"\n\t\tif t.RunID != \"\" {\n\t\t\trunID = t.RunID\n\t\t\tif len(runID) > 30 {\n\t\t\t\trunID = runID[:27] + \"...\"\n\t\t\t}\n\t\t}\n\t\ttitle := t.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar force bool\n\tfor _, a := range args {\n\t\tif a == \"-f\" || a == \"--force\" {\n\t\t\tforce = true\n\t\t}\n\t}\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n\n// resolveRunContext returns the project directory and run ID for context\n// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n// from CLOCHE_PROJECT_DIR (falling back to cwd).\nfunc resolveRunContext() (projectDir, runID string, err error) {\n\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n\tif runID == \"\" {\n\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n\t}\n\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n\tif projectDir == \"\" {\n\t\tprojectDir, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n\t\t}\n\t}\n\treturn projectDir, runID, nil\n}\n\nfunc cmdGet(args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif !ok {\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(val)\n}\n\nfunc cmdSet(args []string) {\n\tif len(args) < 2 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvalue := args[1]\n\tif value == \"-\" {\n\t\tdata, err := io.ReadAll(os.Stdin)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n\t}\n\n\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n\nfunc cmdVersion() {\n\tcliVersion := version.Version()\n\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n\n\t// Try to get daemon version via gRPC\n\tdaemonVersion := \"<unavailable>\"\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = config.DefaultSocketAddr()\n\t}\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err == nil {\n\t\tdefer conn.Close()\n\t\tclient := pb.NewClocheServiceClient(conn)\n\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n\t\tdefer cancel()\n\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n\t\tif err == nil {\n\t\t\tdaemonVersion = resp.Version\n\t\t}\n\t}\n\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n\n\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n\tagentVersion := \"<unavailable>\"\n\timage := os.Getenv(\"CLOCHE_IMAGE\")\n\tif image == \"\" {\n\t\timage = \"cloche-agent:latest\"\n\t}\n\tout, err := exec.CommandContext(\n\t\tcontext.Background(),\n\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n\t).Output()\n\tif err == nil {\n\t\tagentVersion = strings.TrimSpace(string(out))\n\t\t// Strip \"cloche-agent \" prefix if present\n\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n\t}\n\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n\n\t// Warn about version mismatches\n\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n\t}\n\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n\t}\n}\n","numLines":922,"startLine":1,"totalLines":922}}}
