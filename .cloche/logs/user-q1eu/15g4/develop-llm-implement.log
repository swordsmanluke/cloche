{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CaE8gx3MJ9tFUvfJyhTRbe","type":"tool_result","content":"     1→package docker\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"os\"\n     6→\t\"os/exec\"\n     7→\t\"path/filepath\"\n     8→\t\"testing\"\n     9→\n    10→\t\"github.com/stretchr/testify/assert\"\n    11→\t\"github.com/stretchr/testify/require\"\n    12→)\n    13→\n    14→func TestHashBytes(t *testing.T) {\n    15→\th1 := hashBytes([]byte(\"hello\"))\n    16→\th2 := hashBytes([]byte(\"hello\"))\n    17→\th3 := hashBytes([]byte(\"world\"))\n    18→\n    19→\tassert.Equal(t, h1, h2, \"same input should produce same hash\")\n    20→\tassert.NotEqual(t, h1, h3, \"different input should produce different hash\")\n    21→\tassert.Len(t, h1, 64, \"SHA-256 hex digest should be 64 chars\")\n    22→}\n    23→\n    24→func TestEnsureImage_NoDockerfile(t *testing.T) {\n    25→\trt := &Runtime{}\n    26→\tdir := t.TempDir()\n    27→\n    28→\t// No .cloche/Dockerfile — should succeed (nothing to validate)\n    29→\terr := rt.EnsureImage(context.Background(), dir, \"test-image:latest\")\n    30→\tassert.NoError(t, err)\n    31→}\n    32→\n    33→func TestImageLabel_NonexistentImage(t *testing.T) {\n    34→\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n    35→\t\tt.Skip(\"Docker not available\")\n    36→\t}\n    37→\n    38→\t_, err := imageLabel(context.Background(), \"cloche-nonexistent-image-xyz:latest\", dockerfileHashLabel)\n    39→\tassert.Error(t, err)\n    40→}\n    41→\n    42→func TestEnsureImage_BuildsWhenImageMissing(t *testing.T) {\n    43→\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n    44→\t\tt.Skip(\"Docker not available\")\n    45→\t}\n    46→\n    47→\tdir := t.TempDir()\n    48→\tdockerfileDir := filepath.Join(dir, \".cloche\")\n    49→\trequire.NoError(t, os.MkdirAll(dockerfileDir, 0755))\n    50→\n    51→\t// Write a minimal Dockerfile\n    52→\tdockerfile := []byte(\"FROM alpine:latest\\nRUN echo hello\\n\")\n    53→\trequire.NoError(t, os.WriteFile(filepath.Join(dockerfileDir, \"Dockerfile\"), dockerfile, 0644))\n    54→\n    55→\timage := \"cloche-test-ensure-build:latest\"\n    56→\t// Clean up any pre-existing image\n    57→\texec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n    58→\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n    59→\n    60→\trt := &Runtime{}\n    61→\terr := rt.EnsureImage(context.Background(), dir, image)\n    62→\trequire.NoError(t, err)\n    63→\n    64→\t// Verify the image exists and has the label\n    65→\tlabel, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n    66→\trequire.NoError(t, err)\n    67→\tassert.Equal(t, hashBytes(dockerfile), label)\n    68→}\n    69→\n    70→func TestEnsureImage_SkipsWhenUpToDate(t *testing.T) {\n    71→\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n    72→\t\tt.Skip(\"Docker not available\")\n    73→\t}\n    74→\n    75→\tdir := t.TempDir()\n    76→\tdockerfileDir := filepath.Join(dir, \".cloche\")\n    77→\trequire.NoError(t, os.MkdirAll(dockerfileDir, 0755))\n    78→\n    79→\tdockerfile := []byte(\"FROM alpine:latest\\nRUN echo skip-test\\n\")\n    80→\trequire.NoError(t, os.WriteFile(filepath.Join(dockerfileDir, \"Dockerfile\"), dockerfile, 0644))\n    81→\n    82→\timage := \"cloche-test-ensure-skip:latest\"\n    83→\texec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n    84→\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n    85→\n    86→\trt := &Runtime{}\n    87→\n    88→\t// First call: builds\n    89→\terr := rt.EnsureImage(context.Background(), dir, image)\n    90→\trequire.NoError(t, err)\n    91→\n    92→\t// Second call with same Dockerfile: should skip (no rebuild)\n    93→\terr = rt.EnsureImage(context.Background(), dir, image)\n    94→\trequire.NoError(t, err)\n    95→\n    96→\t// Image should still have the correct label\n    97→\tlabel, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n    98→\trequire.NoError(t, err)\n    99→\tassert.Equal(t, hashBytes(dockerfile), label)\n   100→}\n   101→\n   102→func TestEnsureImage_RebuildsWhenDockerfileChanges(t *testing.T) {\n   103→\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n   104→\t\tt.Skip(\"Docker not available\")\n   105→\t}\n   106→\n   107→\tdir := t.TempDir()\n   108→\tdockerfileDir := filepath.Join(dir, \".cloche\")\n   109→\trequire.NoError(t, os.MkdirAll(dockerfileDir, 0755))\n   110→\n   111→\tdockerfilePath := filepath.Join(dockerfileDir, \"Dockerfile\")\n   112→\n   113→\t// Initial Dockerfile\n   114→\tv1 := []byte(\"FROM alpine:latest\\nRUN echo v1\\n\")\n   115→\trequire.NoError(t, os.WriteFile(dockerfilePath, v1, 0644))\n   116→\n   117→\timage := \"cloche-test-ensure-rebuild:latest\"\n   118→\texec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n   119→\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n   120→\n   121→\trt := &Runtime{}\n   122→\n   123→\t// Build with v1\n   124→\terr := rt.EnsureImage(context.Background(), dir, image)\n   125→\trequire.NoError(t, err)\n   126→\n   127→\tlabel1, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n   128→\trequire.NoError(t, err)\n   129→\tassert.Equal(t, hashBytes(v1), label1)\n   130→\n   131→\t// Change Dockerfile to v2\n   132→\tv2 := []byte(\"FROM alpine:latest\\nRUN echo v2\\n\")\n   133→\trequire.NoError(t, os.WriteFile(dockerfilePath, v2, 0644))\n   134→\n   135→\t// Should detect change and rebuild\n   136→\terr = rt.EnsureImage(context.Background(), dir, image)\n   137→\trequire.NoError(t, err)\n   138→\n   139→\tlabel2, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n   140→\trequire.NoError(t, err)\n   141→\tassert.Equal(t, hashBytes(v2), label2)\n   142→\tassert.NotEqual(t, label1, label2, \"label should change after rebuild\")\n   143→}\n   144→"}]},"parent_tool_use_id":null,"session_id":"704edf9b-135c-4fad-bd79-666e382f4c38","uuid":"c0dba68e-0a36-4b04-8936-f869231e1e63","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/docker/build_test.go","content":"package docker\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestHashBytes(t *testing.T) {\n\th1 := hashBytes([]byte(\"hello\"))\n\th2 := hashBytes([]byte(\"hello\"))\n\th3 := hashBytes([]byte(\"world\"))\n\n\tassert.Equal(t, h1, h2, \"same input should produce same hash\")\n\tassert.NotEqual(t, h1, h3, \"different input should produce different hash\")\n\tassert.Len(t, h1, 64, \"SHA-256 hex digest should be 64 chars\")\n}\n\nfunc TestEnsureImage_NoDockerfile(t *testing.T) {\n\trt := &Runtime{}\n\tdir := t.TempDir()\n\n\t// No .cloche/Dockerfile — should succeed (nothing to validate)\n\terr := rt.EnsureImage(context.Background(), dir, \"test-image:latest\")\n\tassert.NoError(t, err)\n}\n\nfunc TestImageLabel_NonexistentImage(t *testing.T) {\n\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n\t\tt.Skip(\"Docker not available\")\n\t}\n\n\t_, err := imageLabel(context.Background(), \"cloche-nonexistent-image-xyz:latest\", dockerfileHashLabel)\n\tassert.Error(t, err)\n}\n\nfunc TestEnsureImage_BuildsWhenImageMissing(t *testing.T) {\n\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n\t\tt.Skip(\"Docker not available\")\n\t}\n\n\tdir := t.TempDir()\n\tdockerfileDir := filepath.Join(dir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(dockerfileDir, 0755))\n\n\t// Write a minimal Dockerfile\n\tdockerfile := []byte(\"FROM alpine:latest\\nRUN echo hello\\n\")\n\trequire.NoError(t, os.WriteFile(filepath.Join(dockerfileDir, \"Dockerfile\"), dockerfile, 0644))\n\n\timage := \"cloche-test-ensure-build:latest\"\n\t// Clean up any pre-existing image\n\texec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n\n\trt := &Runtime{}\n\terr := rt.EnsureImage(context.Background(), dir, image)\n\trequire.NoError(t, err)\n\n\t// Verify the image exists and has the label\n\tlabel, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n\trequire.NoError(t, err)\n\tassert.Equal(t, hashBytes(dockerfile), label)\n}\n\nfunc TestEnsureImage_SkipsWhenUpToDate(t *testing.T) {\n\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n\t\tt.Skip(\"Docker not available\")\n\t}\n\n\tdir := t.TempDir()\n\tdockerfileDir := filepath.Join(dir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(dockerfileDir, 0755))\n\n\tdockerfile := []byte(\"FROM alpine:latest\\nRUN echo skip-test\\n\")\n\trequire.NoError(t, os.WriteFile(filepath.Join(dockerfileDir, \"Dockerfile\"), dockerfile, 0644))\n\n\timage := \"cloche-test-ensure-skip:latest\"\n\texec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n\n\trt := &Runtime{}\n\n\t// First call: builds\n\terr := rt.EnsureImage(context.Background(), dir, image)\n\trequire.NoError(t, err)\n\n\t// Second call with same Dockerfile: should skip (no rebuild)\n\terr = rt.EnsureImage(context.Background(), dir, image)\n\trequire.NoError(t, err)\n\n\t// Image should still have the correct label\n\tlabel, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n\trequire.NoError(t, err)\n\tassert.Equal(t, hashBytes(dockerfile), label)\n}\n\nfunc TestEnsureImage_RebuildsWhenDockerfileChanges(t *testing.T) {\n\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n\t\tt.Skip(\"Docker not available\")\n\t}\n\n\tdir := t.TempDir()\n\tdockerfileDir := filepath.Join(dir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(dockerfileDir, 0755))\n\n\tdockerfilePath := filepath.Join(dockerfileDir, \"Dockerfile\")\n\n\t// Initial Dockerfile\n\tv1 := []byte(\"FROM alpine:latest\\nRUN echo v1\\n\")\n\trequire.NoError(t, os.WriteFile(dockerfilePath, v1, 0644))\n\n\timage := \"cloche-test-ensure-rebuild:latest\"\n\texec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n\n\trt := &Runtime{}\n\n\t// Build with v1\n\terr := rt.EnsureImage(context.Background(), dir, image)\n\trequire.NoError(t, err)\n\n\tlabel1, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n\trequire.NoError(t, err)\n\tassert.Equal(t, hashBytes(v1), label1)\n\n\t// Change Dockerfile to v2\n\tv2 := []byte(\"FROM alpine:latest\\nRUN echo v2\\n\")\n\trequire.NoError(t, os.WriteFile(dockerfilePath, v2, 0644))\n\n\t// Should detect change and rebuild\n\terr = rt.EnsureImage(context.Background(), dir, image)\n\trequire.NoError(t, err)\n\n\tlabel2, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n\trequire.NoError(t, err)\n\tassert.Equal(t, hashBytes(v2), label2)\n\tassert.NotEqual(t, label1, label2, \"label should change after rebuild\")\n}\n","numLines":144,"startLine":1,"totalLines":144}}}
