{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LDSy9wuRNKicEmGndGE5B3","type":"tool_result","content":"     1→package orchestrator\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"sync\"\n     7→\t\"testing\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    10→\t\"github.com/stretchr/testify/assert\"\n    11→\t\"github.com/stretchr/testify/require\"\n    12→)\n    13→\n    14→// mockTracker implements ports.TaskTracker for testing.\n    15→type mockTracker struct {\n    16→\tmu       sync.Mutex\n    17→\ttasks    []ports.TrackerTask\n    18→\tclaimed  []string\n    19→\tcompleted []string\n    20→\tfailed   []string\n    21→\tclaimErr error\n    22→}\n    23→\n    24→func (m *mockTracker) ListReady(_ context.Context, project string) ([]ports.TrackerTask, error) {\n    25→\tm.mu.Lock()\n    26→\tdefer m.mu.Unlock()\n    27→\t// Return a copy\n    28→\tresult := make([]ports.TrackerTask, len(m.tasks))\n    29→\tcopy(result, m.tasks)\n    30→\treturn result, nil\n    31→}\n    32→\n    33→func (m *mockTracker) Claim(_ context.Context, taskID string) error {\n    34→\tm.mu.Lock()\n    35→\tdefer m.mu.Unlock()\n    36→\tif m.claimErr != nil {\n    37→\t\treturn m.claimErr\n    38→\t}\n    39→\tm.claimed = append(m.claimed, taskID)\n    40→\treturn nil\n    41→}\n    42→\n    43→func (m *mockTracker) Complete(_ context.Context, taskID string) error {\n    44→\tm.mu.Lock()\n    45→\tdefer m.mu.Unlock()\n    46→\tm.completed = append(m.completed, taskID)\n    47→\treturn nil\n    48→}\n    49→\n    50→func (m *mockTracker) Fail(_ context.Context, taskID string) error {\n    51→\tm.mu.Lock()\n    52→\tdefer m.mu.Unlock()\n    53→\tm.failed = append(m.failed, taskID)\n    54→\treturn nil\n    55→}\n    56→\n    57→// mockPromptGen implements PromptGenerator for testing.\n    58→type mockPromptGen struct {\n    59→\tresponse string\n    60→\terr      error\n    61→\tcalls    int\n    62→}\n    63→\n    64→func (m *mockPromptGen) Generate(_ context.Context, task ports.TrackerTask, projectDir string) (string, error) {\n    65→\tm.calls++\n    66→\treturn m.response, m.err\n    67→}\n    68→\n    69→func TestOrchestratorRun_DispatchesTasks(t *testing.T) {\n    70→\ttracker := &mockTracker{\n    71→\t\ttasks: []ports.TrackerTask{\n    72→\t\t\t{ID: \"task-1\", Title: \"First task\", Priority: 2},\n    73→\t\t\t{ID: \"task-2\", Title: \"Second task\", Priority: 1},\n    74→\t\t},\n    75→\t}\n    76→\tpromptGen := &mockPromptGen{response: \"generated prompt\"}\n    77→\n    78→\tvar dispatched []string\n    79→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n    80→\t\tdispatched = append(dispatched, prompt)\n    81→\t\treturn \"run-\" + fmt.Sprintf(\"%d\", len(dispatched)), nil\n    82→\t}\n    83→\n    84→\torch := New(promptGen, dispatch)\n    85→\torch.Register(&ProjectConfig{\n    86→\t\tDir:         \"/test/project\",\n    87→\t\tWorkflow:    \"develop\",\n    88→\t\tConcurrency: 2,\n    89→\t\tTracker:     tracker,\n    90→\t})\n    91→\n    92→\tn, err := orch.Run(context.Background(), \"/test/project\")\n    93→\trequire.NoError(t, err)\n    94→\tassert.Equal(t, 2, n)\n    95→\tassert.Equal(t, 2, len(dispatched))\n    96→\tassert.Equal(t, []string{\"task-1\", \"task-2\"}, tracker.claimed)\n    97→\tassert.Equal(t, 2, promptGen.calls)\n    98→}\n    99→\n   100→func TestOrchestratorRun_RespectsConncurrencyLimit(t *testing.T) {\n   101→\ttracker := &mockTracker{\n   102→\t\ttasks: []ports.TrackerTask{\n   103→\t\t\t{ID: \"task-1\", Title: \"First\", Priority: 2},\n   104→\t\t\t{ID: \"task-2\", Title: \"Second\", Priority: 1},\n   105→\t\t},\n   106→\t}\n   107→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   108→\n   109→\tdispatchCount := 0\n   110→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   111→\t\tdispatchCount++\n   112→\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n   113→\t}\n   114→\n   115→\torch := New(promptGen, dispatch)\n   116→\torch.Register(&ProjectConfig{\n   117→\t\tDir:         \"/test/project\",\n   118→\t\tWorkflow:    \"develop\",\n   119→\t\tConcurrency: 1, // only 1 slot\n   120→\t\tTracker:     tracker,\n   121→\t})\n   122→\n   123→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   124→\trequire.NoError(t, err)\n   125→\tassert.Equal(t, 1, n)\n   126→\tassert.Equal(t, 1, dispatchCount)\n   127→\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed) // highest priority\n   128→}\n   129→\n   130→func TestOrchestratorRun_NoAvailableSlots(t *testing.T) {\n   131→\ttracker := &mockTracker{\n   132→\t\ttasks: []ports.TrackerTask{\n   133→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   134→\t\t},\n   135→\t}\n   136→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   137→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   138→\t\treturn \"run-1\", nil\n   139→\t}\n   140→\n   141→\torch := New(promptGen, dispatch)\n   142→\torch.Register(&ProjectConfig{\n   143→\t\tDir:         \"/test/project\",\n   144→\t\tWorkflow:    \"develop\",\n   145→\t\tConcurrency: 1,\n   146→\t\tTracker:     tracker,\n   147→\t})\n   148→\n   149→\t// Simulate an in-flight run\n   150→\torch.mu.Lock()\n   151→\torch.inFlight[\"/test/project\"] = 1\n   152→\torch.mu.Unlock()\n   153→\n   154→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   155→\trequire.NoError(t, err)\n   156→\tassert.Equal(t, 0, n)\n   157→}\n   158→\n   159→func TestOrchestratorRun_NoReadyTasks(t *testing.T) {\n   160→\ttracker := &mockTracker{tasks: nil}\n   161→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   162→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   163→\t\tt.Fatal(\"dispatch should not be called\")\n   164→\t\treturn \"\", nil\n   165→\t}\n   166→\n   167→\torch := New(promptGen, dispatch)\n   168→\torch.Register(&ProjectConfig{\n   169→\t\tDir:         \"/test/project\",\n   170→\t\tWorkflow:    \"develop\",\n   171→\t\tConcurrency: 1,\n   172→\t\tTracker:     tracker,\n   173→\t})\n   174→\n   175→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   176→\trequire.NoError(t, err)\n   177→\tassert.Equal(t, 0, n)\n   178→}\n   179→\n   180→func TestOrchestratorRun_UnregisteredProject(t *testing.T) {\n   181→\torch := New(nil, nil)\n   182→\t_, err := orch.Run(context.Background(), \"/unknown\")\n   183→\tassert.Error(t, err)\n   184→\tassert.Contains(t, err.Error(), \"not registered\")\n   185→}\n   186→\n   187→func TestOrchestratorRun_PromptGenerationFailure(t *testing.T) {\n   188→\ttracker := &mockTracker{\n   189→\t\ttasks: []ports.TrackerTask{\n   190→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   191→\t\t},\n   192→\t}\n   193→\tpromptGen := &mockPromptGen{err: fmt.Errorf(\"LLM unavailable\")}\n   194→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   195→\t\tt.Fatal(\"dispatch should not be called on prompt failure\")\n   196→\t\treturn \"\", nil\n   197→\t}\n   198→\n   199→\torch := New(promptGen, dispatch)\n   200→\torch.Register(&ProjectConfig{\n   201→\t\tDir:         \"/test/project\",\n   202→\t\tWorkflow:    \"develop\",\n   203→\t\tConcurrency: 1,\n   204→\t\tTracker:     tracker,\n   205→\t})\n   206→\n   207→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   208→\trequire.NoError(t, err) // errors are logged, not returned\n   209→\tassert.Equal(t, 0, n)\n   210→\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed)\n   211→\tassert.Equal(t, []string{\"task-1\"}, tracker.failed) // task should be failed back\n   212→}\n   213→\n   214→func TestOrchestratorRun_DispatchFailure(t *testing.T) {\n   215→\ttracker := &mockTracker{\n   216→\t\ttasks: []ports.TrackerTask{\n   217→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   218→\t\t},\n   219→\t}\n   220→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   221→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   222→\t\treturn \"\", fmt.Errorf(\"container start failed\")\n   223→\t}\n   224→\n   225→\torch := New(promptGen, dispatch)\n   226→\torch.Register(&ProjectConfig{\n   227→\t\tDir:         \"/test/project\",\n   228→\t\tWorkflow:    \"develop\",\n   229→\t\tConcurrency: 1,\n   230→\t\tTracker:     tracker,\n   231→\t})\n   232→\n   233→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   234→\trequire.NoError(t, err)\n   235→\tassert.Equal(t, 0, n)\n   236→\tassert.Equal(t, []string{\"task-1\"}, tracker.failed)\n   237→}\n   238→\n   239→func TestOrchestratorRun_ClaimFailure(t *testing.T) {\n   240→\ttracker := &mockTracker{\n   241→\t\ttasks: []ports.TrackerTask{\n   242→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   243→\t\t},\n   244→\t\tclaimErr: fmt.Errorf(\"already claimed\"),\n   245→\t}\n   246→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   247→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   248→\t\tt.Fatal(\"dispatch should not be called on claim failure\")\n   249→\t\treturn \"\", nil\n   250→\t}\n   251→\n   252→\torch := New(promptGen, dispatch)\n   253→\torch.Register(&ProjectConfig{\n   254→\t\tDir:         \"/test/project\",\n   255→\t\tWorkflow:    \"develop\",\n   256→\t\tConcurrency: 1,\n   257→\t\tTracker:     tracker,\n   258→\t})\n   259→\n   260→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   261→\trequire.NoError(t, err)\n   262→\tassert.Equal(t, 0, n)\n   263→}\n   264→\n   265→func TestOrchestratorTriggerAll(t *testing.T) {\n   266→\ttracker1 := &mockTracker{\n   267→\t\ttasks: []ports.TrackerTask{{ID: \"t1\", Title: \"T1\", Priority: 1}},\n   268→\t}\n   269→\ttracker2 := &mockTracker{\n   270→\t\ttasks: []ports.TrackerTask{{ID: \"t2\", Title: \"T2\", Priority: 1}},\n   271→\t}\n   272→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   273→\n   274→\tdispatchCount := 0\n   275→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   276→\t\tdispatchCount++\n   277→\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n   278→\t}\n   279→\n   280→\torch := New(promptGen, dispatch)\n   281→\torch.Register(&ProjectConfig{Dir: \"/proj1\", Workflow: \"dev\", Concurrency: 1, Tracker: tracker1})\n   282→\torch.Register(&ProjectConfig{Dir: \"/proj2\", Workflow: \"dev\", Concurrency: 1, Tracker: tracker2})\n   283→\n   284→\ttotal := orch.TriggerAll(context.Background())\n   285→\tassert.Equal(t, 2, total)\n   286→\tassert.Equal(t, 2, dispatchCount)\n   287→}\n   288→\n   289→func TestOrchestratorOnRunComplete(t *testing.T) {\n   290→\ttracker := &mockTracker{\n   291→\t\ttasks: []ports.TrackerTask{\n   292→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   293→\t\t},\n   294→\t}\n   295→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   296→\n   297→\tdispatchCount := 0\n   298→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   299→\t\tdispatchCount++\n   300→\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n   301→\t}\n   302→\n   303→\torch := New(promptGen, dispatch)\n   304→\torch.Register(&ProjectConfig{\n   305→\t\tDir:         \"/test/project\",\n   306→\t\tWorkflow:    \"develop\",\n   307→\t\tConcurrency: 1,\n   308→\t\tTracker:     tracker,\n   309→\t})\n   310→\n   311→\t// Simulate a run is in flight (fills the concurrency slot)\n   312→\torch.mu.Lock()\n   313→\torch.inFlight[\"/test/project\"] = 1\n   314→\torch.mu.Unlock()\n   315→\n   316→\t// OnRunComplete should decrement in-flight and trigger new dispatch\n   317→\torch.OnRunComplete(context.Background(), \"/test/project\")\n   318→\n   319→\t// After OnRunComplete: 1 → 0 (decrement) → 1 (new run dispatched)\n   320→\tassert.Equal(t, 1, orch.InFlight(\"/test/project\"))\n   321→\tassert.Equal(t, 1, dispatchCount) // should have dispatched the waiting task\n   322→}\n   323→\n   324→func TestOrchestratorInFlightTracking(t *testing.T) {\n   325→\ttracker := &mockTracker{\n   326→\t\ttasks: []ports.TrackerTask{\n   327→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   328→\t\t},\n   329→\t}\n   330→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   331→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   332→\t\treturn \"run-1\", nil\n   333→\t}\n   334→\n   335→\torch := New(promptGen, dispatch)\n   336→\torch.Register(&ProjectConfig{\n   337→\t\tDir:         \"/test/project\",\n   338→\t\tWorkflow:    \"develop\",\n   339→\t\tConcurrency: 2,\n   340→\t\tTracker:     tracker,\n   341→\t})\n   342→\n   343→\tassert.Equal(t, 0, orch.InFlight(\"/test/project\"))\n   344→\n   345→\t_, err := orch.Run(context.Background(), \"/test/project\")\n   346→\trequire.NoError(t, err)\n   347→\n   348→\tassert.Equal(t, 1, orch.InFlight(\"/test/project\"))\n   349→}\n   350→\n   351→func TestOrchestratorRun_UsesCorrectWorkflow(t *testing.T) {\n   352→\ttracker := &mockTracker{\n   353→\t\ttasks: []ports.TrackerTask{\n   354→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   355→\t\t},\n   356→\t}\n   357→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   358→\n   359→\tvar capturedWorkflow string\n   360→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   361→\t\tcapturedWorkflow = workflow\n   362→\t\treturn \"run-1\", nil\n   363→\t}\n   364→\n   365→\torch := New(promptGen, dispatch)\n   366→\torch.Register(&ProjectConfig{\n   367→\t\tDir:         \"/test/project\",\n   368→\t\tWorkflow:    \"custom-workflow\",\n   369→\t\tConcurrency: 1,\n   370→\t\tTracker:     tracker,\n   371→\t})\n   372→\n   373→\t_, err := orch.Run(context.Background(), \"/test/project\")\n   374→\trequire.NoError(t, err)\n   375→\tassert.Equal(t, \"custom-workflow\", capturedWorkflow)\n   376→}\n   377→"}]},"parent_tool_use_id":null,"session_id":"70a7591d-eb45-4f1e-88f7-411785bbf426","uuid":"1133c57a-e82f-4dfa-b773-1706cbacb964","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/orchestrator/orchestrator_test.go","content":"package orchestrator\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\t\"testing\"\n\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// mockTracker implements ports.TaskTracker for testing.\ntype mockTracker struct {\n\tmu       sync.Mutex\n\ttasks    []ports.TrackerTask\n\tclaimed  []string\n\tcompleted []string\n\tfailed   []string\n\tclaimErr error\n}\n\nfunc (m *mockTracker) ListReady(_ context.Context, project string) ([]ports.TrackerTask, error) {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\t// Return a copy\n\tresult := make([]ports.TrackerTask, len(m.tasks))\n\tcopy(result, m.tasks)\n\treturn result, nil\n}\n\nfunc (m *mockTracker) Claim(_ context.Context, taskID string) error {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tif m.claimErr != nil {\n\t\treturn m.claimErr\n\t}\n\tm.claimed = append(m.claimed, taskID)\n\treturn nil\n}\n\nfunc (m *mockTracker) Complete(_ context.Context, taskID string) error {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tm.completed = append(m.completed, taskID)\n\treturn nil\n}\n\nfunc (m *mockTracker) Fail(_ context.Context, taskID string) error {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tm.failed = append(m.failed, taskID)\n\treturn nil\n}\n\n// mockPromptGen implements PromptGenerator for testing.\ntype mockPromptGen struct {\n\tresponse string\n\terr      error\n\tcalls    int\n}\n\nfunc (m *mockPromptGen) Generate(_ context.Context, task ports.TrackerTask, projectDir string) (string, error) {\n\tm.calls++\n\treturn m.response, m.err\n}\n\nfunc TestOrchestratorRun_DispatchesTasks(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"First task\", Priority: 2},\n\t\t\t{ID: \"task-2\", Title: \"Second task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"generated prompt\"}\n\n\tvar dispatched []string\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatched = append(dispatched, prompt)\n\t\treturn \"run-\" + fmt.Sprintf(\"%d\", len(dispatched)), nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 2,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 2, n)\n\tassert.Equal(t, 2, len(dispatched))\n\tassert.Equal(t, []string{\"task-1\", \"task-2\"}, tracker.claimed)\n\tassert.Equal(t, 2, promptGen.calls)\n}\n\nfunc TestOrchestratorRun_RespectsConncurrencyLimit(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"First\", Priority: 2},\n\t\t\t{ID: \"task-2\", Title: \"Second\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\n\tdispatchCount := 0\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatchCount++\n\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1, // only 1 slot\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 1, n)\n\tassert.Equal(t, 1, dispatchCount)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed) // highest priority\n}\n\nfunc TestOrchestratorRun_NoAvailableSlots(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\treturn \"run-1\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\t// Simulate an in-flight run\n\torch.mu.Lock()\n\torch.inFlight[\"/test/project\"] = 1\n\torch.mu.Unlock()\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 0, n)\n}\n\nfunc TestOrchestratorRun_NoReadyTasks(t *testing.T) {\n\ttracker := &mockTracker{tasks: nil}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tt.Fatal(\"dispatch should not be called\")\n\t\treturn \"\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 0, n)\n}\n\nfunc TestOrchestratorRun_UnregisteredProject(t *testing.T) {\n\torch := New(nil, nil)\n\t_, err := orch.Run(context.Background(), \"/unknown\")\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"not registered\")\n}\n\nfunc TestOrchestratorRun_PromptGenerationFailure(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{err: fmt.Errorf(\"LLM unavailable\")}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tt.Fatal(\"dispatch should not be called on prompt failure\")\n\t\treturn \"\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err) // errors are logged, not returned\n\tassert.Equal(t, 0, n)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.failed) // task should be failed back\n}\n\nfunc TestOrchestratorRun_DispatchFailure(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\treturn \"\", fmt.Errorf(\"container start failed\")\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 0, n)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.failed)\n}\n\nfunc TestOrchestratorRun_ClaimFailure(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t\tclaimErr: fmt.Errorf(\"already claimed\"),\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tt.Fatal(\"dispatch should not be called on claim failure\")\n\t\treturn \"\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 0, n)\n}\n\nfunc TestOrchestratorTriggerAll(t *testing.T) {\n\ttracker1 := &mockTracker{\n\t\ttasks: []ports.TrackerTask{{ID: \"t1\", Title: \"T1\", Priority: 1}},\n\t}\n\ttracker2 := &mockTracker{\n\t\ttasks: []ports.TrackerTask{{ID: \"t2\", Title: \"T2\", Priority: 1}},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\n\tdispatchCount := 0\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatchCount++\n\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{Dir: \"/proj1\", Workflow: \"dev\", Concurrency: 1, Tracker: tracker1})\n\torch.Register(&ProjectConfig{Dir: \"/proj2\", Workflow: \"dev\", Concurrency: 1, Tracker: tracker2})\n\n\ttotal := orch.TriggerAll(context.Background())\n\tassert.Equal(t, 2, total)\n\tassert.Equal(t, 2, dispatchCount)\n}\n\nfunc TestOrchestratorOnRunComplete(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\n\tdispatchCount := 0\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatchCount++\n\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\t// Simulate a run is in flight (fills the concurrency slot)\n\torch.mu.Lock()\n\torch.inFlight[\"/test/project\"] = 1\n\torch.mu.Unlock()\n\n\t// OnRunComplete should decrement in-flight and trigger new dispatch\n\torch.OnRunComplete(context.Background(), \"/test/project\")\n\n\t// After OnRunComplete: 1 → 0 (decrement) → 1 (new run dispatched)\n\tassert.Equal(t, 1, orch.InFlight(\"/test/project\"))\n\tassert.Equal(t, 1, dispatchCount) // should have dispatched the waiting task\n}\n\nfunc TestOrchestratorInFlightTracking(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\treturn \"run-1\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 2,\n\t\tTracker:     tracker,\n\t})\n\n\tassert.Equal(t, 0, orch.InFlight(\"/test/project\"))\n\n\t_, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, 1, orch.InFlight(\"/test/project\"))\n}\n\nfunc TestOrchestratorRun_UsesCorrectWorkflow(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\n\tvar capturedWorkflow string\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tcapturedWorkflow = workflow\n\t\treturn \"run-1\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"custom-workflow\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\t_, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"custom-workflow\", capturedWorkflow)\n}\n","numLines":377,"startLine":1,"totalLines":377}}}
