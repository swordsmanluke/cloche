{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Fcg7o6FgH3ZZyB8U3dKCtq","type":"tool_result","content":"     1→package orchestrator\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"context\"\n     6→\t\"fmt\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"strings\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    13→)\n    14→\n    15→// LLMClient abstracts LLM calls for prompt generation.\n    16→type LLMClient interface {\n    17→\tComplete(ctx context.Context, systemPrompt, userPrompt string) (string, error)\n    18→}\n    19→\n    20→// PromptGenerator generates implementation prompts from tracker tasks.\n    21→type PromptGenerator interface {\n    22→\tGenerate(ctx context.Context, task ports.TrackerTask, projectDir string) (string, error)\n    23→}\n    24→\n    25→// CommandLLMClient invokes an LLM via a shell command.\n    26→type CommandLLMClient struct {\n    27→\tCommand string\n    28→\tArgs    []string\n    29→}\n    30→\n    31→// Complete sends a system+user prompt to the LLM command and returns the response.\n    32→func (c *CommandLLMClient) Complete(ctx context.Context, systemPrompt, userPrompt string) (string, error) {\n    33→\tprompt := systemPrompt + \"\\n\\n\" + userPrompt\n    34→\n    35→\tcmd := exec.CommandContext(ctx, c.Command, c.Args...)\n    36→\tcmd.Stdin = strings.NewReader(prompt)\n    37→\n    38→\t// Strip CLAUDECODE env var so Claude Code doesn't refuse to start\n    39→\t// when cloched is running inside a Claude Code session.\n    40→\tfor _, e := range os.Environ() {\n    41→\t\tif !strings.HasPrefix(e, \"CLAUDECODE=\") {\n    42→\t\t\tcmd.Env = append(cmd.Env, e)\n    43→\t\t}\n    44→\t}\n    45→\n    46→\tvar stdout, stderr bytes.Buffer\n    47→\tcmd.Stdout = &stdout\n    48→\tcmd.Stderr = &stderr\n    49→\n    50→\tif err := cmd.Run(); err != nil {\n    51→\t\treturn \"\", fmt.Errorf(\"LLM command failed: %w (stderr: %s)\", err, stderr.String())\n    52→\t}\n    53→\n    54→\treturn strings.TrimSpace(stdout.String()), nil\n    55→}\n    56→\n    57→// LLMPromptGenerator uses an LLM to generate well-formed implementation prompts.\n    58→type LLMPromptGenerator struct {\n    59→\tLLM LLMClient\n    60→}\n    61→\n    62→// Generate produces an implementation prompt for the given task using project context.\n    63→func (g *LLMPromptGenerator) Generate(ctx context.Context, task ports.TrackerTask, projectDir string) (string, error) {\n    64→\tprojectContext := gatherProjectContext(projectDir)\n    65→\n    66→\tsystemPrompt := `You are a prompt engineer for an autonomous coding agent.\n    67→Given a task description and project context, generate a clear, actionable implementation prompt.\n    68→\n    69→The prompt you generate will be passed directly to a coding agent via \"cloche run --prompt\".\n    70→The agent will work autonomously in a container with the full project source.\n    71→\n    72→Your output must be ONLY the implementation prompt text — no wrapping, no commentary, no markdown fences.\n    73→\n    74→The prompt should include:\n    75→1. A clear statement of what to implement (from the task title and description)\n    76→2. Acceptance criteria (if provided)\n    77→3. Relevant project context that helps the agent understand conventions\n    78→4. Guidelines: follow existing patterns, write tests for new functionality, run tests before declaring success`\n    79→\n    80→\tvar parts []string\n    81→\tparts = append(parts, fmt.Sprintf(\"## Task\\nID: %s\\nTitle: %s\", task.ID, task.Title))\n    82→\n    83→\tif task.Description != \"\" {\n    84→\t\tparts = append(parts, \"## Description\\n\"+task.Description)\n    85→\t}\n    86→\n    87→\tif task.Acceptance != \"\" {\n    88→\t\tparts = append(parts, \"## Acceptance Criteria\\n\"+task.Acceptance)\n    89→\t}\n    90→\n    91→\tif len(task.Labels) > 0 {\n    92→\t\tparts = append(parts, \"## Labels\\n\"+strings.Join(task.Labels, \", \"))\n    93→\t}\n    94→\n    95→\tif task.Priority > 0 {\n    96→\t\tparts = append(parts, fmt.Sprintf(\"## Priority\\n%d\", task.Priority))\n    97→\t}\n    98→\n    99→\tif projectContext != \"\" {\n   100→\t\tparts = append(parts, \"## Project Context\\n\"+projectContext)\n   101→\t}\n   102→\n   103→\tuserPrompt := strings.Join(parts, \"\\n\\n\")\n   104→\n   105→\tresponse, err := g.LLM.Complete(ctx, systemPrompt, userPrompt)\n   106→\tif err != nil {\n   107→\t\treturn \"\", fmt.Errorf(\"prompt generation LLM call: %w\", err)\n   108→\t}\n   109→\n   110→\tresponse = strings.TrimSpace(response)\n   111→\tif response == \"\" {\n   112→\t\treturn \"\", fmt.Errorf(\"LLM returned empty prompt\")\n   113→\t}\n   114→\n   115→\treturn response, nil\n   116→}\n   117→\n   118→// gatherProjectContext reads available project context files.\n   119→func gatherProjectContext(projectDir string) string {\n   120→\tvar sections []string\n   121→\n   122→\t// Read CLAUDE.md if present\n   123→\tclaudeMD := readFileIfExists(filepath.Join(projectDir, \"CLAUDE.md\"))\n   124→\tif claudeMD != \"\" {\n   125→\t\tsections = append(sections, \"### CLAUDE.md\\n\"+claudeMD)\n   126→\t}\n   127→\n   128→\t// Read recent git log\n   129→\tgitLog := readGitLog(projectDir)\n   130→\tif gitLog != \"\" {\n   131→\t\tsections = append(sections, \"### Recent Git History\\n\"+gitLog)\n   132→\t}\n   133→\n   134→\t// Read project structure summary (top-level dirs and key files)\n   135→\tstructure := readProjectStructure(projectDir)\n   136→\tif structure != \"\" {\n   137→\t\tsections = append(sections, \"### Project Structure\\n\"+structure)\n   138→\t}\n   139→\n   140→\treturn strings.Join(sections, \"\\n\\n\")\n   141→}\n   142→\n   143→// readFileIfExists returns file contents or empty string.\n   144→func readFileIfExists(path string) string {\n   145→\tdata, err := os.ReadFile(path)\n   146→\tif err != nil {\n   147→\t\treturn \"\"\n   148→\t}\n   149→\tcontent := strings.TrimSpace(string(data))\n   150→\t// Limit to a reasonable size for context\n   151→\tif len(content) > 4000 {\n   152→\t\tcontent = content[:4000] + \"\\n...(truncated)\"\n   153→\t}\n   154→\treturn content\n   155→}\n   156→\n   157→// readGitLog returns recent git log entries, or empty string on error.\n   158→func readGitLog(projectDir string) string {\n   159→\tcmd := exec.Command(\"git\", \"log\", \"--oneline\", \"-20\")\n   160→\tcmd.Dir = projectDir\n   161→\tout, err := cmd.Output()\n   162→\tif err != nil {\n   163→\t\treturn \"\"\n   164→\t}\n   165→\treturn strings.TrimSpace(string(out))\n   166→}\n   167→\n   168→// readProjectStructure returns a summary of the project's top-level layout.\n   169→func readProjectStructure(projectDir string) string {\n   170→\tentries, err := os.ReadDir(projectDir)\n   171→\tif err != nil {\n   172→\t\treturn \"\"\n   173→\t}\n   174→\n   175→\tvar lines []string\n   176→\tfor _, entry := range entries {\n   177→\t\tname := entry.Name()\n   178→\t\tif strings.HasPrefix(name, \".\") {\n   179→\t\t\tcontinue\n   180→\t\t}\n   181→\t\tif entry.IsDir() {\n   182→\t\t\tlines = append(lines, name+\"/\")\n   183→\t\t} else {\n   184→\t\t\tlines = append(lines, name)\n   185→\t\t}\n   186→\t}\n   187→\treturn strings.Join(lines, \"\\n\")\n   188→}\n   189→\n   190→// NewCommandLLMClientFromEnv creates a CommandLLMClient from the CLOCHE_LLM_COMMAND\n   191→// environment variable. Falls back to \"claude\" with default args if unset.\n   192→func NewCommandLLMClientFromEnv() *CommandLLMClient {\n   193→\tcmdStr := os.Getenv(\"CLOCHE_LLM_COMMAND\")\n   194→\tif cmdStr == \"\" {\n   195→\t\treturn &CommandLLMClient{\n   196→\t\t\tCommand: \"claude\",\n   197→\t\t\tArgs:    []string{\"-p\"},\n   198→\t\t}\n   199→\t}\n   200→\n   201→\tparts := strings.Fields(cmdStr)\n   202→\treturn &CommandLLMClient{\n   203→\t\tCommand: parts[0],\n   204→\t\tArgs:    parts[1:],\n   205→\t}\n   206→}\n   207→"}]},"parent_tool_use_id":null,"session_id":"70a7591d-eb45-4f1e-88f7-411785bbf426","uuid":"af6e47ff-3403-4c77-ba77-fcc5dde03992","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/orchestrator/promptgen.go","content":"package orchestrator\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// LLMClient abstracts LLM calls for prompt generation.\ntype LLMClient interface {\n\tComplete(ctx context.Context, systemPrompt, userPrompt string) (string, error)\n}\n\n// PromptGenerator generates implementation prompts from tracker tasks.\ntype PromptGenerator interface {\n\tGenerate(ctx context.Context, task ports.TrackerTask, projectDir string) (string, error)\n}\n\n// CommandLLMClient invokes an LLM via a shell command.\ntype CommandLLMClient struct {\n\tCommand string\n\tArgs    []string\n}\n\n// Complete sends a system+user prompt to the LLM command and returns the response.\nfunc (c *CommandLLMClient) Complete(ctx context.Context, systemPrompt, userPrompt string) (string, error) {\n\tprompt := systemPrompt + \"\\n\\n\" + userPrompt\n\n\tcmd := exec.CommandContext(ctx, c.Command, c.Args...)\n\tcmd.Stdin = strings.NewReader(prompt)\n\n\t// Strip CLAUDECODE env var so Claude Code doesn't refuse to start\n\t// when cloched is running inside a Claude Code session.\n\tfor _, e := range os.Environ() {\n\t\tif !strings.HasPrefix(e, \"CLAUDECODE=\") {\n\t\t\tcmd.Env = append(cmd.Env, e)\n\t\t}\n\t}\n\n\tvar stdout, stderr bytes.Buffer\n\tcmd.Stdout = &stdout\n\tcmd.Stderr = &stderr\n\n\tif err := cmd.Run(); err != nil {\n\t\treturn \"\", fmt.Errorf(\"LLM command failed: %w (stderr: %s)\", err, stderr.String())\n\t}\n\n\treturn strings.TrimSpace(stdout.String()), nil\n}\n\n// LLMPromptGenerator uses an LLM to generate well-formed implementation prompts.\ntype LLMPromptGenerator struct {\n\tLLM LLMClient\n}\n\n// Generate produces an implementation prompt for the given task using project context.\nfunc (g *LLMPromptGenerator) Generate(ctx context.Context, task ports.TrackerTask, projectDir string) (string, error) {\n\tprojectContext := gatherProjectContext(projectDir)\n\n\tsystemPrompt := `You are a prompt engineer for an autonomous coding agent.\nGiven a task description and project context, generate a clear, actionable implementation prompt.\n\nThe prompt you generate will be passed directly to a coding agent via \"cloche run --prompt\".\nThe agent will work autonomously in a container with the full project source.\n\nYour output must be ONLY the implementation prompt text — no wrapping, no commentary, no markdown fences.\n\nThe prompt should include:\n1. A clear statement of what to implement (from the task title and description)\n2. Acceptance criteria (if provided)\n3. Relevant project context that helps the agent understand conventions\n4. Guidelines: follow existing patterns, write tests for new functionality, run tests before declaring success`\n\n\tvar parts []string\n\tparts = append(parts, fmt.Sprintf(\"## Task\\nID: %s\\nTitle: %s\", task.ID, task.Title))\n\n\tif task.Description != \"\" {\n\t\tparts = append(parts, \"## Description\\n\"+task.Description)\n\t}\n\n\tif task.Acceptance != \"\" {\n\t\tparts = append(parts, \"## Acceptance Criteria\\n\"+task.Acceptance)\n\t}\n\n\tif len(task.Labels) > 0 {\n\t\tparts = append(parts, \"## Labels\\n\"+strings.Join(task.Labels, \", \"))\n\t}\n\n\tif task.Priority > 0 {\n\t\tparts = append(parts, fmt.Sprintf(\"## Priority\\n%d\", task.Priority))\n\t}\n\n\tif projectContext != \"\" {\n\t\tparts = append(parts, \"## Project Context\\n\"+projectContext)\n\t}\n\n\tuserPrompt := strings.Join(parts, \"\\n\\n\")\n\n\tresponse, err := g.LLM.Complete(ctx, systemPrompt, userPrompt)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"prompt generation LLM call: %w\", err)\n\t}\n\n\tresponse = strings.TrimSpace(response)\n\tif response == \"\" {\n\t\treturn \"\", fmt.Errorf(\"LLM returned empty prompt\")\n\t}\n\n\treturn response, nil\n}\n\n// gatherProjectContext reads available project context files.\nfunc gatherProjectContext(projectDir string) string {\n\tvar sections []string\n\n\t// Read CLAUDE.md if present\n\tclaudeMD := readFileIfExists(filepath.Join(projectDir, \"CLAUDE.md\"))\n\tif claudeMD != \"\" {\n\t\tsections = append(sections, \"### CLAUDE.md\\n\"+claudeMD)\n\t}\n\n\t// Read recent git log\n\tgitLog := readGitLog(projectDir)\n\tif gitLog != \"\" {\n\t\tsections = append(sections, \"### Recent Git History\\n\"+gitLog)\n\t}\n\n\t// Read project structure summary (top-level dirs and key files)\n\tstructure := readProjectStructure(projectDir)\n\tif structure != \"\" {\n\t\tsections = append(sections, \"### Project Structure\\n\"+structure)\n\t}\n\n\treturn strings.Join(sections, \"\\n\\n\")\n}\n\n// readFileIfExists returns file contents or empty string.\nfunc readFileIfExists(path string) string {\n\tdata, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\tcontent := strings.TrimSpace(string(data))\n\t// Limit to a reasonable size for context\n\tif len(content) > 4000 {\n\t\tcontent = content[:4000] + \"\\n...(truncated)\"\n\t}\n\treturn content\n}\n\n// readGitLog returns recent git log entries, or empty string on error.\nfunc readGitLog(projectDir string) string {\n\tcmd := exec.Command(\"git\", \"log\", \"--oneline\", \"-20\")\n\tcmd.Dir = projectDir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\treturn strings.TrimSpace(string(out))\n}\n\n// readProjectStructure returns a summary of the project's top-level layout.\nfunc readProjectStructure(projectDir string) string {\n\tentries, err := os.ReadDir(projectDir)\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\n\tvar lines []string\n\tfor _, entry := range entries {\n\t\tname := entry.Name()\n\t\tif strings.HasPrefix(name, \".\") {\n\t\t\tcontinue\n\t\t}\n\t\tif entry.IsDir() {\n\t\t\tlines = append(lines, name+\"/\")\n\t\t} else {\n\t\t\tlines = append(lines, name)\n\t\t}\n\t}\n\treturn strings.Join(lines, \"\\n\")\n}\n\n// NewCommandLLMClientFromEnv creates a CommandLLMClient from the CLOCHE_LLM_COMMAND\n// environment variable. Falls back to \"claude\" with default args if unset.\nfunc NewCommandLLMClientFromEnv() *CommandLLMClient {\n\tcmdStr := os.Getenv(\"CLOCHE_LLM_COMMAND\")\n\tif cmdStr == \"\" {\n\t\treturn &CommandLLMClient{\n\t\t\tCommand: \"claude\",\n\t\t\tArgs:    []string{\"-p\"},\n\t\t}\n\t}\n\n\tparts := strings.Fields(cmdStr)\n\treturn &CommandLLMClient{\n\t\tCommand: parts[0],\n\t\tArgs:    parts[1:],\n\t}\n}\n","numLines":207,"startLine":1,"totalLines":207}}}
