n   198→\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   199→\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   200→\t\t\t// Load per-project config for confidence threshold\n   201→\t\t\tprojCfg, err := config.Load(projectDir)\n   202→\t\t\tif err != nil {\n   203→\t\t\t\tprojCfg = cfg // fall back to daemon config\n   204→\t\t\t}\n   205→\n   206→\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   207→\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   208→\t\t\t\tProjectDir:    projectDir,\n   209→\t\t\t\tWorkflowName:  workflowName,\n   210→\t\t\t\tLLM:           llm,\n   211→\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   212→\t\t\t})\n   213→\n   214→\t\t\tctx := context.Background()\n   215→\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   216→\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   217→\t\t\t}\n   218→\t\t},\n   219→\t})\n   220→\n   221→\treturn trigger\n   222→}\n   223→\n   224→func listen(addr string) (net.Listener, error) {\n   225→\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   226→\t\tsockPath := addr[7:]\n   227→\t\tos.Remove(sockPath)\n   228→\t\treturn net.Listen(\"unix\", sockPath)\n   229→\t}\n   230→\treturn net.Listen(\"tcp\", addr)\n   231→}\n   232→\n   233→func initOrchestrator(globalCfg *config.Config, store ports.RunStore, srv *adaptgrpc.ClocheServer) *orchestrator.Orchestrator {\n   234→\tllmClient := orchestrator.NewCommandLLMClientFromEnv()\n   235→\tpromptGen := &orchestrator.LLMPromptGenerator{LLM: llmClient}\n   236→\n   237→\tdispatch := func(ctx context.Context, workflowName, projectDir, prompt string) (string, error) {\n   238→\t\tresp, err := srv.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   239→\t\t\tWorkflowName: workflowName,\n   240→\t\t\tProjectDir:   projectDir,\n   241→\t\t\tPrompt:       prompt,\n   242→\t\t})\n   243→\t\tif err != nil {\n   244→\t\t\treturn \"\", e