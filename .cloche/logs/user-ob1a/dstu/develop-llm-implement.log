ose()\n    47→\n    48→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    49→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    50→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    51→\t} else if n > 0 {\n    52→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    53→\t}\n    54→\n    55→\truntime, err := initRuntime(globalCfg)\n    56→\tif err != nil {\n    57→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    58→\t\tos.Exit(1)\n    59→\t}\n    60→\n    61→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    62→\n    63→\tbroadcaster := logstream.NewBroadcaster()\n    64→\n    65→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    66→\tsrv.SetLogStore(store)\n    67→\tsrv.SetLogBroadcaster(broadcaster)\n    68→\n    69→\t// Set up evolution trigger\n    70→\tevoTrigger := initEvolution(globalCfg, store, store)\n    71→\tif evoTrigger != nil {\n    72→\t\tsrv.SetEvolution(evoTrigger)\n    73→\t}\n    74→\n    75→\t// Set up merge agent\n    76→\tsrv.SetMergeQueue(store)\n    77→\tmergeAgent := initMergeAgent(globalCfg, store)\n    78→\tif mergeAgent != nil {\n    79→\t\tsrv.SetOnMergeReady(func(ctx context.Context, projectDir string) {\n    80→\t\t\tmergeAgent.ProcessQueue(ctx, projectDir)\n    81→\t\t})\n    82→\t}\n    83→\n    84→\t// Set up orchestrator\n    85→\torch := initOrchestrator(globalCfg, store, srv)\n    86→\tif orch != nil {\n    87→\t\tsrv.SetOnRunComplete(func(ctx context.Context, projectDir string, state domain.RunState) {\n    88→\t\t\torch.OnRunComplete(ctx, projectDir)\n    89→\t\t})\n    90→\t\tsrv.SetOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n    91→\t\t\tif projectDir != \"\" {\n    92→\t\t\t\treturn orch.Run(ctx, projectDir)\n    93→\t\t\t}\n    94→\t\t\treturn orch.TriggerAll(ctx), nil\n    95→\t\t})\n    96→\t}\n    97→\n    98→\tgrpcServer := grpc.NewServer()\n    99→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n   100→\n   101→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n   102→\n   103→\tlis, err := listen(listenAddr)\n   104→\tif err != nil {\n   105→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n   106→\t\tos.Exit(1)\n   107→\t}\n   108→\n   109→\tvar httpServer *http.Server\n   110→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n   111→\t\twebOpts := []web.HandlerOption{\n   112→\t\t\tweb.WithContainerLogger(runtime),\n   113→\t\t\tweb.WithLogStore(store),\n   114→\t\t\tweb.WithLogBroadcaster(broadcaster),\n   115→\t\t}\n   116→\t\tif orch != nil {\n   117→\t\t\twebOpts = append(webOpts, web.WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   118→\t\t\t\treturn orch.Run(ctx, projectDir)\n   119→\t\t\t}))\n   120→\t\t}\n   121→\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n   122→\t\tif err != nil {\n   123→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n   124→\t\t\tos.Exit(1)\n   125→\t\t}\n   126→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n   127→\t\tgo func() {\n   128→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   129→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   130→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   131→\t\t\t}\n   132→\t\t}()\n   133→\t}\n   134→\n   135→\tsigCh := make(chan os.Signal, 1)\n   136→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   137→\tgo func() {\n   138→\t\t<-sigCh\n   139→\t\tif httpServer != nil {\n   140→\t\t\thttpServer.Close()\n   141→\t\t}\n   142→\t\tgrpcServer.GracefulStop()\n   143→\t}()\n   144→\n   145→\t// Trigger orchestration on startup\n   146→\tif