{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011p5PbH88vUFpzWTk18AobS","type":"tool_result","content":"     1→package orchestrator\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"sync\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/config\"\n    10→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11→)\n    12→\n    13→// RunDispatcher dispatches a workflow run and returns the run ID.\n    14→type RunDispatcher func(ctx context.Context, workflowName, projectDir, prompt string) (string, error)\n    15→\n    16→// ProjectConfig holds orchestration settings for a single project.\n    17→type ProjectConfig struct {\n    18→\tDir         string\n    19→\tWorkflow    string\n    20→\tConcurrency int\n    21→\tTracker     ports.TaskTracker\n    22→}\n    23→\n    24→// Orchestrator pulls ready tasks and dispatches workflow runs, respecting\n    25→// per-project concurrency limits.\n    26→type Orchestrator struct {\n    27→\tpromptGen  PromptGenerator\n    28→\tdispatch   RunDispatcher\n    29→\tmu         sync.Mutex\n    30→\tprojects   map[string]*ProjectConfig // keyed by Dir\n    31→\tinFlight   map[string]int            // keyed by Dir\n    32→}\n    33→\n    34→// New creates an Orchestrator.\n    35→func New(promptGen PromptGenerator, dispatch RunDispatcher) *Orchestrator {\n    36→\treturn &Orchestrator{\n    37→\t\tpromptGen: promptGen,\n    38→\t\tdispatch:  dispatch,\n    39→\t\tprojects:  make(map[string]*ProjectConfig),\n    40→\t\tinFlight:  make(map[string]int),\n    41→\t}\n    42→}\n    43→\n    44→// Register adds a project to the orchestrator.\n    45→func (o *Orchestrator) Register(pc *ProjectConfig) {\n    46→\to.mu.Lock()\n    47→\tdefer o.mu.Unlock()\n    48→\to.projects[pc.Dir] = pc\n    49→}\n    50→\n    51→// RegisterFromConfig registers a project using its config file.\n    52→// Returns false if orchestration is not enabled for the project.\n    53→func (o *Orchestrator) RegisterFromConfig(projectDir string, tracker ports.TaskTracker) bool {\n    54→\tcfg, err := config.Load(projectDir)\n    55→\tif err != nil || !cfg.Orchestration.Enabled {\n    56→\t\treturn false\n    57→\t}\n    58→\tworkflow := cfg.Orchestration.Workflow\n    59→\tif workflow == \"\" {\n    60→\t\tworkflow = \"develop\"\n    61→\t}\n    62→\tconcurrency := cfg.Orchestration.Concurrency\n    63→\tif concurrency < 1 {\n    64→\t\tconcurrency = 1\n    65→\t}\n    66→\to.Register(&ProjectConfig{\n    67→\t\tDir:         projectDir,\n    68→\t\tWorkflow:    workflow,\n    69→\t\tConcurrency: concurrency,\n    70→\t\tTracker:     tracker,\n    71→\t})\n    72→\treturn true\n    73→}\n    74→\n    75→// Run performs one orchestration cycle for a single project. It returns the\n    76→// number of runs dispatched.\n    77→func (o *Orchestrator) Run(ctx context.Context, projectDir string) (int, error) {\n    78→\to.mu.Lock()\n    79→\tpc, ok := o.projects[projectDir]\n    80→\tif !ok {\n    81→\t\to.mu.Unlock()\n    82→\t\treturn 0, fmt.Errorf(\"project %q not registered\", projectDir)\n    83→\t}\n    84→\tcurrent := o.inFlight[projectDir]\n    85→\tavailable := pc.Concurrency - current\n    86→\to.mu.Unlock()\n    87→\n    88→\tif available <= 0 {\n    89→\t\treturn 0, nil\n    90→\t}\n    91→\n    92→\ttasks, err := pc.Tracker.ListReady(ctx, projectDir)\n    93→\tif err != nil {\n    94→\t\treturn 0, fmt.Errorf(\"listing ready tasks: %w\", err)\n    95→\t}\n    96→\n    97→\tdispatched := 0\n    98→\tfor i := 0; i < len(tasks) && dispatched < available; i++ {\n    99→\t\ttask := tasks[i]\n   100→\n   101→\t\tif err := pc.Tracker.Claim(ctx, task.ID); err != nil {\n   102→\t\t\tlog.Printf(\"orchestrator: failed to claim task %s: %v\", task.ID, err)\n   103→\t\t\tcontinue\n   104→\t\t}\n   105→\n   106→\t\tprompt, err := o.promptGen.Generate(ctx, task, projectDir)\n   107→\t\tif err != nil {\n   108→\t\t\tlog.Printf(\"orchestrator: failed to generate prompt for task %s: %v\", task.ID, err)\n   109→\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   110→\t\t\tcontinue\n   111→\t\t}\n   112→\n   113→\t\trunID, err := o.dispatch(ctx, pc.Workflow, projectDir, prompt)\n   114→\t\tif err != nil {\n   115→\t\t\tlog.Printf(\"orchestrator: failed to dispatch run for task %s: %v\", task.ID, err)\n   116→\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   117→\t\t\tcontinue\n   118→\t\t}\n   119→\n   120→\t\to.mu.Lock()\n   121→\t\to.inFlight[projectDir]++\n   122→\t\to.mu.Unlock()\n   123→\n   124→\t\tlog.Printf(\"orchestrator: dispatched run %s for task %s in %s\", runID, task.ID, projectDir)\n   125→\t\tdispatched++\n   126→\t}\n   127→\n   128→\treturn dispatched, nil\n   129→}\n   130→\n   131→// TriggerAll runs orchestration for all registered projects. Returns total\n   132→// dispatched count.\n   133→func (o *Orchestrator) TriggerAll(ctx context.Context) int {\n   134→\to.mu.Lock()\n   135→\tdirs := make([]string, 0, len(o.projects))\n   136→\tfor dir := range o.projects {\n   137→\t\tdirs = append(dirs, dir)\n   138→\t}\n   139→\to.mu.Unlock()\n   140→\n   141→\ttotal := 0\n   142→\tfor _, dir := range dirs {\n   143→\t\tn, err := o.Run(ctx, dir)\n   144→\t\tif err != nil {\n   145→\t\t\tlog.Printf(\"orchestrator: error for project %s: %v\", dir, err)\n   146→\t\t\tcontinue\n   147→\t\t}\n   148→\t\ttotal += n\n   149→\t}\n   150→\treturn total\n   151→}\n   152→\n   153→// OnRunComplete should be called when a workflow run finishes. It decrements\n   154→// the in-flight counter and triggers a new orchestration cycle for that project.\n   155→func (o *Orchestrator) OnRunComplete(ctx context.Context, projectDir string) {\n   156→\to.mu.Lock()\n   157→\tif o.inFlight[projectDir] > 0 {\n   158→\t\to.inFlight[projectDir]--\n   159→\t}\n   160→\to.mu.Unlock()\n   161→\n   162→\tif _, err := o.Run(ctx, projectDir); err != nil {\n   163→\t\tlog.Printf(\"orchestrator: post-completion trigger failed for %s: %v\", projectDir, err)\n   