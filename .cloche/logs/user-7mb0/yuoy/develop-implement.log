{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gijzg2M6UN1ZeznVbfkwF4","type":"tool_result","content":"     1â†’package prompt\n     2â†’\n     3â†’import (\n     4â†’\t\"bufio\"\n     5â†’\t\"bytes\"\n     6â†’\t\"context\"\n     7â†’\t\"encoding/json\"\n     8â†’\t\"fmt\"\n     9â†’\t\"os\"\n    10â†’\t\"os/exec\"\n    11â†’\t\"path/filepath\"\n    12â†’\t\"strconv\"\n    13â†’\t\"strings\"\n    14â†’\n    15â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16â†’\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17â†’)\n    18â†’\n    19â†’// defaultAgentArgs maps known agent commands to their default arguments.\n    20â†’// Commands not in this map receive no default arguments (prompt on stdin only).\n    21â†’var defaultAgentArgs = map[string][]string{\n    22â†’\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n    23â†’}\n    24â†’\n    25â†’type Adapter struct {\n    26â†’\tCommands     []string // ordered fallback chain of agent commands\n    27â†’\tExplicitArgs []string // if non-nil, overrides default args for all commands\n    28â†’\tRunID        string\n    29â†’\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n    30â†’}\n    31â†’\n    32â†’func New() *Adapter {\n    33â†’\treturn &Adapter{\n    34â†’\t\tCommands: []string{\"claude\"},\n    35â†’\t}\n    36â†’}\n    37â†’\n    38â†’func (a *Adapter) Name() string {\n    39â†’\treturn \"prompt\"\n    40â†’}\n    41â†’\n    42â†’// argsFor returns the arguments for the given command. If ExplicitArgs is set,\n    43â†’// it is used for all commands. Otherwise, known agents get their default args.\n    44â†’func (a *Adapter) argsFor(command string) []string {\n    45â†’\tif a.ExplicitArgs != nil {\n    46â†’\t\treturn a.ExplicitArgs\n    47â†’\t}\n    48â†’\tif args, ok := defaultAgentArgs[command]; ok {\n    49â†’\t\treturn args\n    50â†’\t}\n    51â†’\treturn nil\n    52â†’}\n    53â†’\n    54â†’// ParseCommands splits a comma-separated agent_command string into individual\n    55â†’// command names, trimming whitespace from each entry.\n    56â†’func ParseCommands(s string) []string {\n    57â†’\tparts := strings.Split(s, \",\")\n    58â†’\tvar cmds []string\n    59â†’\tfor _, p := range parts {\n    60â†’\t\tp = strings.TrimSpace(p)\n    61â†’\t\tif p != \"\" {\n    62â†’\t\t\tcmds = append(cmds, p)\n    63â†’\t\t}\n    64â†’\t}\n    65â†’\treturn cmds\n    66â†’}\n    67â†’\n    68â†’func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    69â†’\t// Check attempt count for retry limiting\n    70â†’\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n    71â†’\t\tmax, err := strconv.Atoi(maxStr)\n    72â†’\t\tif err == nil {\n    73â†’\t\t\tcount := readAttemptCount(workDir, step.Name)\n    74â†’\t\t\tif count >= max {\n    75â†’\t\t\t\treturn \"give-up\", nil\n    76â†’\t\t\t}\n    77â†’\t\t}\n    78â†’\t}\n    79â†’\tincrementAttemptCount(workDir, step.Name)\n    80â†’\n    81â†’\t// Build the full prompt\n    82â†’\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n    83â†’\tif err != nil {\n    84â†’\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n    85â†’\t}\n    86â†’\n    87â†’\t// Try each command in the fallback chain\n    88â†’\tvar lastResult string\n    89â†’\tvar lastStdout []byte\n    90â†’\tvar lastErr error\n    91â†’\tran := false\n    92â†’\n    93â†’\tfor _, command := range a.Commands {\n    94â†’\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n    95â†’\t\tlastResult = result\n    96â†’\t\tlastStdout = stdout\n    97â†’\t\tlastErr = fallbackErr\n    98â†’\n    99â†’\t\tif fallbackErr == nil {\n   100â†’\t\t\t// Definitive result â€” agent completed (exit 0 or exit non-zero with marker)\n   101â†’\t\t\tbreak\n   102â†’\t\t}\n   103â†’\t\tif stdout != nil {\n   104â†’\t\t\tran = true\n   105â†’\t\t}\n   106â†’\t\t// Fallback-eligible â€” try next command\n   107â†’\t}\n   108â†’\n   109â†’\tif lastErr != nil && !ran && lastStdout == nil {\n   110â†’\t\t// All commands failed to produce any output (e.g., all not found)\n   111â†’\t\treturn \"\", lastErr\n   112â†’\t}\n   113â†’\n   114â†’\tresult := lastResult\n   115â†’\tif lastErr != nil {\n   116â†’\t\t// Last command in chain crashed without a result marker\n   117â†’\t\tresult = \"fail\"\n   118â†’\t}\n   119â†’\n   120â†’\t// Write output file\n   121â†’\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   122â†’\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n   123â†’\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n   124â†’\t}\n   125â†’\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n   126â†’\treturn result, nil\n   127â†’}\n   128â†’\n   129â†’// tryCommand executes a single agent command and returns:\n   130â†’//   - result: the step result name (e.g. \"success\", \"fail\")\n   131â†’//   - stdout: captured stdout bytes\n   132â†’//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n   133â†’//\n   134â†’// Fallback-eligible conditions:\n   135â†’//   - Command not found or failed to start (stdout will be nil)\n   136â†’//   - Command exited non-zero without a CLOCHE_RESULT marker\n   137â†’//\n   138â†’// Definitive (non-fallback) conditions:\n   139â†’//   - Command exited 0\n   140â†’//   - Command exited non-zero but produced a CLOCHE_RESULT marker\n   141â†’func (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n   142â†’\targs := a.argsFor(command)\n   143â†’\tcmd := exec.CommandContext(ctx, command, args...)\n   144â†’\tcmd.Dir = workDir\n   145â†’\tcmd.Stdin = strings.NewReader(prompt)\n   146â†’\n   147â†’\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n   148â†’\tif a.StatusWriter == nil {\n   149â†’\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n   150â†’\t\tcmd.Stdout = &stdoutBuf\n   151â†’\t\tcmd.Stderr = &stderrBuf\n   152â†’\n   153â†’\t\trunErr := cmd.Run()\n   154â†’\t\tstdoutBytes := stdoutBuf.Bytes()\n   155â†’\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n   156â†’\t}\n   157â†’\n   158â†’\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n   159â†’\tpipe, err := cmd.StdoutPipe()\n   160â†’\tif err != nil {\n   161â†’\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n   162â†’\t}\n   163â†’\tcmd.Stderr = nil // discard stderr\n   164â†’\n   165â†’\tif err := cmd.Start(); err != nil {\n   166â†’\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n   167â†’\t}\n   168â†’\n   169â†’\t// textBuf accumulates extracted text content for result extraction.\n   170â†’\t// rawBuf accumulates raw stdout for the output log file.\n   171â†’\tvar textBuf, rawBuf bytes.Buffer\n   172â†’\t// lineBuf accumulates text deltas into lines for streaming.\n   173â†’\tvar lineBuf strings.Builder\n   174â†’\n   175â†’\tscanner := bufio.NewScanner(pipe)\n   176â†’\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n   177â†’\tfor scanner.Scan() {\n   178â†’\t\traw := scanner.Bytes()\n   179â†’\t\trawBuf.Write(raw)\n   180â†’\t\trawBuf.WriteByte('\\n')\n   181â†’\n   182â†’\t\ttext := extractStreamText(raw)\n   183â†’\t\tif text == \"\" {\n   184â†’\t\t\tcontinue\n   185â†’\t\t}\n   186â†’\t\ttextBuf.WriteString(text)\n   187â†’\n   188â†’\t\t// Stream complete lines to StatusWriter as they form.\n   189â†’\t\tlineBuf.WriteString(text)\n   190â†’\t\tfor {\n   191â†’\t\t\ts := lineBuf.String()\n   192â†’\t\t\tidx := strings.IndexByte(s, '\\n')\n   193â†’\t\t\tif idx < 0 {\n   194â†’\t\t\t\tbreak\n   195â†’\t\t\t}\n   196â†’\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n   197â†’\t\t\tlineBuf.Reset()\n   198â†’\t\t\tlineBuf.WriteString(s[idx+1:])\n   199â†’\t\t}\n   200â†’\t}\n   201â†’\t// Flush any remaining partial line.\n   202â†’\tif lineBuf.Len() > 0 {\n   203â†’\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n   204â†’\t}\n   205â†’\tif scanErr := scanner.Err(); scanErr != nil {\n   206â†’\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n   207â†’\t}\n   208â†’\n   209â†’\twaitErr := cmd.Wait()\n   210â†’\t// Prefer extracted text (stream-json) for result classification; fall back\n   211â†’\t// to raw output for non-JSON commands (scripts, non-claude agents).\n   212â†’\tclassifyBuf := textBuf.Bytes()\n   213â†’\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n   214â†’\t\tclassifyBuf = rawBuf.Bytes()\n   215â†’\t}\n   216â†’\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n   217â†’\treturn result, rawBuf.Bytes(), fallbackErr\n   218â†’}\n   219â†’\n   220â†’// classifyResult interprets the command's exit status and stdout to determine\n   221â†’// the step result.\n   222â†’func (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n   223â†’\tif runErr != nil {\n   224â†’\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n   225â†’\t\t\t// Command failed to start (not found, permission denied, etc.)\n   226â†’\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n   227â†’\t\t}\n   228â†’\t\t// Command ran but exited non-zero\n   229â†’\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   230â†’\t\tif found {\n   231â†’\t\t\treturn markerResult, stdoutBytes, nil\n   232â†’\t\t}\n   233â†’\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n   234â†’\t}\n   235â†’\n   236â†’\t// Command succeeded (exit 0)\n   237â†’\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n   238â†’\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n   239â†’\t}\n   240â†’\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   241â†’\tresult := \"success\"\n   242â†’\tif found {\n   243â†’\t\tresult = markerResult\n   244â†’\t}\n   245â†’\treturn result, stdoutBytes, nil\n   246â†’}\n   247â†’\n   248â†’// extractStreamText parses a stream-json line and returns text content.\n   249â†’// It handles both content_block_delta (text_delta) events for streaming and\n   250â†’// result events for final output (which contains the CLOCHE_RESULT marker).\n   251â†’func extractStreamText(line []byte) string {\n   252â†’\t// Fast path: only parse lines that could contain text we care about.\n   253â†’\tif bytes.Contains(line, []byte(`\"text_delta\"`)) {\n   254â†’\t\tvar event struct {\n   255â†’\t\t\tType  string `json:\"type\"`\n   256â†’\t\t\tDelta struct {\n   257â†’\t\t\t\tType string `json:\"type\"`\n   258â†’\t\t\t\tText string `json:\"text\"`\n   259â†’\t\t\t} `json:\"delta\"`\n   260â†’\t\t}\n   261â†’\t\tif json.Unmarshal(line, &event) == nil &&\n   262â†’\t\t\tevent.Type == \"content_block_delta\" && event.Delta.Type == \"text_delta\" {\n   263â†’\t\t\treturn event.Delta.Text\n   264â†’\t\t}\n   265â†’\t}\n   266â†’\n   267â†’\t// Also extract the final result text (contains CLOCHE_RESULT marker).\n   268â†’\tif bytes.Contains(line, []byte(`\"result\"`)) && bytes.Contains(line, []byte(`\"subtype\"`)) {\n   269â†’\t\tvar event struct {\n   270â†’\t\t\tType   string `json:\"type\"`\n   271â†’\t\t\tResult string `json:\"result\"`\n   272â†’\t\t}\n   273â†’\t\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n   274â†’\t\t\treturn event.Result\n   275â†’\t\t}\n   276â†’\t}\n   277â†’\n   278â†’\treturn \"\"\n   279â†’}\n   280â†’\n   281â†’func assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n   282â†’\tvar parts []string\n   283â†’\n   284â†’\t// 1. Read system template from step config\n   285â†’\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n   286â†’\t\tcontent, err := resolveContent(tmpl, workDir)\n   287â†’\t\tif err != nil {\n   288â†’\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n   289â†’\t\t}\n   290â†’\t\tparts = append(parts, content)\n   291â†’\t}\n   292â†’\n   293â†’\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n   294â†’\tuserPrompt := readUserPrompt(workDir, runID)\n   295â†’\tif userPrompt != \"\" {\n   296â†’\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n   297â†’\t}\n   298â†’\n   299â†’\t// 3. Read feedback from .cloche/output/*.log\n   300â†’\tfeedback := readFeedback(workDir)\n   301â†’\tif feedback != \"\" {\n   302â†’\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n   303â†’\t}\n   304â†’\n   305â†’\t// 4. Result selection instructions\n   306â†’\tif len(step.Results) > 0 {\n   307â†’\t\tvar resultLines []string\n   308â†’\t\tresultLines = append(resultLines, \"## Result Selection\")\n   309â†’\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n   310â†’\t\tfor _, r := range step.Results {\n   311â†’\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n   312â†’\t\t}\n   313â†’\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n   314â†’\t}\n   315â†’\n   316â†’\treturn strings.Join(parts, \"\\n\\n\"), nil\n   317â†’}\n   318â†’\n   319â†’// resolveContent handles file(\"path\") syntax or returns the string directly.\n   320â†’func resolveContent(value string, workDir string) (string, error) {\n   321â†’\t// Check for file(\"path\") syntax from DSL parser\n   322â†’\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n   323â†’\t\tpath := value[6 : len(value)-2]\n   324â†’\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n   325â†’\t\tif err != nil {\n   326â†’\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n   327â†’\t\t}\n   328â†’\t\treturn string(data), nil\n   329â†’\t}\n   330â†’\treturn value, nil\n   331â†’}\n   332â†’\n   333â†’func readFeedback(workDir string) string {\n   334â†’\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   335â†’\tentries, err := os.ReadDir(outputDir)\n   336â†’\tif err != nil {\n   337â†’\t\treturn \"\"\n   338â†’\t}\n   339â†’\n   340â†’\tvar parts []string\n   341â†’\tfor _, entry := range entries {\n   342â†’\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n   343â†’\t\t\tcontinue\n   344â†’\t\t}\n   345â†’\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n   346â†’\t\tif err != nil {\n   347â†’\t\t\tcontinue\n   348â†’\t\t}\n   349â†’\t\tcontent := strings.TrimSpace(string(data))\n   350â†’\t\tif content != \"\" {\n   351â†’\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n   352â†’\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n   353â†’\t\t}\n   354â†’\t}\n   355â†’\n   356â†’\treturn strings.Join(parts, \"\\n\\n\")\n   357â†’}\n   358â†’\n   359â†’func readAttemptCount(workDir, stepName string) int {\n   360â†’\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n   361â†’\tdata, err := os.ReadFile(path)\n   362â†’\tif err != nil {\n   363â†’\t\treturn 0\n   364â†’\t}\n   365â†’\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n   366â†’\treturn n\n   367â†’}\n   368â†’\n   369â†’// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\n   370â†’func readUserPrompt(workDir, runID string) string {\n   371â†’\tif runID == \"\" {\n   372â†’\t\treturn \"\"\n   373â†’\t}\n   374â†’\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   375â†’\tif data, err := os.ReadFile(path); err == nil {\n   376â†’\t\treturn string(data)\n   377â†’\t}\n   378â†’\treturn \"\"\n   379â†’}\n   380â†’\n   381â†’func incrementAttemptCount(workDir, stepName string) {\n   382â†’\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n   383â†’\t_ = os.MkdirAll(dir, 0755)\n   384â†’\tcount := readAttemptCount(workDir, stepName) + 1\n   385â†’\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n   386â†’}\n   387â†’"}]},"parent_tool_use_id":null,"session_id":"410fed70-c824-4ba1-8e3b-ac0d517a6329","uuid":"ba2e0f26-d770-404b-8f56-5f66fcd3c2aa","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/agents/prompt/prompt.go","content":"package prompt\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\n// defaultAgentArgs maps known agent commands to their default arguments.\n// Commands not in this map receive no default arguments (prompt on stdin only).\nvar defaultAgentArgs = map[string][]string{\n\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n}\n\ntype Adapter struct {\n\tCommands     []string // ordered fallback chain of agent commands\n\tExplicitArgs []string // if non-nil, overrides default args for all commands\n\tRunID        string\n\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n}\n\nfunc New() *Adapter {\n\treturn &Adapter{\n\t\tCommands: []string{\"claude\"},\n\t}\n}\n\nfunc (a *Adapter) Name() string {\n\treturn \"prompt\"\n}\n\n// argsFor returns the arguments for the given command. If ExplicitArgs is set,\n// it is used for all commands. Otherwise, known agents get their default args.\nfunc (a *Adapter) argsFor(command string) []string {\n\tif a.ExplicitArgs != nil {\n\t\treturn a.ExplicitArgs\n\t}\n\tif args, ok := defaultAgentArgs[command]; ok {\n\t\treturn args\n\t}\n\treturn nil\n}\n\n// ParseCommands splits a comma-separated agent_command string into individual\n// command names, trimming whitespace from each entry.\nfunc ParseCommands(s string) []string {\n\tparts := strings.Split(s, \",\")\n\tvar cmds []string\n\tfor _, p := range parts {\n\t\tp = strings.TrimSpace(p)\n\t\tif p != \"\" {\n\t\t\tcmds = append(cmds, p)\n\t\t}\n\t}\n\treturn cmds\n}\n\nfunc (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n\t// Check attempt count for retry limiting\n\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n\t\tmax, err := strconv.Atoi(maxStr)\n\t\tif err == nil {\n\t\t\tcount := readAttemptCount(workDir, step.Name)\n\t\t\tif count >= max {\n\t\t\t\treturn \"give-up\", nil\n\t\t\t}\n\t\t}\n\t}\n\tincrementAttemptCount(workDir, step.Name)\n\n\t// Build the full prompt\n\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n\t}\n\n\t// Try each command in the fallback chain\n\tvar lastResult string\n\tvar lastStdout []byte\n\tvar lastErr error\n\tran := false\n\n\tfor _, command := range a.Commands {\n\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n\t\tlastResult = result\n\t\tlastStdout = stdout\n\t\tlastErr = fallbackErr\n\n\t\tif fallbackErr == nil {\n\t\t\t// Definitive result â€” agent completed (exit 0 or exit non-zero with marker)\n\t\t\tbreak\n\t\t}\n\t\tif stdout != nil {\n\t\t\tran = true\n\t\t}\n\t\t// Fallback-eligible â€” try next command\n\t}\n\n\tif lastErr != nil && !ran && lastStdout == nil {\n\t\t// All commands failed to produce any output (e.g., all not found)\n\t\treturn \"\", lastErr\n\t}\n\n\tresult := lastResult\n\tif lastErr != nil {\n\t\t// Last command in chain crashed without a result marker\n\t\tresult = \"fail\"\n\t}\n\n\t// Write output file\n\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n\t}\n\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n\treturn result, nil\n}\n\n// tryCommand executes a single agent command and returns:\n//   - result: the step result name (e.g. \"success\", \"fail\")\n//   - stdout: captured stdout bytes\n//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n//\n// Fallback-eligible conditions:\n//   - Command not found or failed to start (stdout will be nil)\n//   - Command exited non-zero without a CLOCHE_RESULT marker\n//\n// Definitive (non-fallback) conditions:\n//   - Command exited 0\n//   - Command exited non-zero but produced a CLOCHE_RESULT marker\nfunc (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n\targs := a.argsFor(command)\n\tcmd := exec.CommandContext(ctx, command, args...)\n\tcmd.Dir = workDir\n\tcmd.Stdin = strings.NewReader(prompt)\n\n\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n\tif a.StatusWriter == nil {\n\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n\t\tcmd.Stdout = &stdoutBuf\n\t\tcmd.Stderr = &stderrBuf\n\n\t\trunErr := cmd.Run()\n\t\tstdoutBytes := stdoutBuf.Bytes()\n\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n\t}\n\n\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n\tpipe, err := cmd.StdoutPipe()\n\tif err != nil {\n\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n\t}\n\tcmd.Stderr = nil // discard stderr\n\n\tif err := cmd.Start(); err != nil {\n\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n\t}\n\n\t// textBuf accumulates extracted text content for result extraction.\n\t// rawBuf accumulates raw stdout for the output log file.\n\tvar textBuf, rawBuf bytes.Buffer\n\t// lineBuf accumulates text deltas into lines for streaming.\n\tvar lineBuf strings.Builder\n\n\tscanner := bufio.NewScanner(pipe)\n\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n\tfor scanner.Scan() {\n\t\traw := scanner.Bytes()\n\t\trawBuf.Write(raw)\n\t\trawBuf.WriteByte('\\n')\n\n\t\ttext := extractStreamText(raw)\n\t\tif text == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\ttextBuf.WriteString(text)\n\n\t\t// Stream complete lines to StatusWriter as they form.\n\t\tlineBuf.WriteString(text)\n\t\tfor {\n\t\t\ts := lineBuf.String()\n\t\t\tidx := strings.IndexByte(s, '\\n')\n\t\t\tif idx < 0 {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n\t\t\tlineBuf.Reset()\n\t\t\tlineBuf.WriteString(s[idx+1:])\n\t\t}\n\t}\n\t// Flush any remaining partial line.\n\tif lineBuf.Len() > 0 {\n\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n\t}\n\tif scanErr := scanner.Err(); scanErr != nil {\n\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n\t}\n\n\twaitErr := cmd.Wait()\n\t// Prefer extracted text (stream-json) for result classification; fall back\n\t// to raw output for non-JSON commands (scripts, non-claude agents).\n\tclassifyBuf := textBuf.Bytes()\n\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n\t\tclassifyBuf = rawBuf.Bytes()\n\t}\n\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n\treturn result, rawBuf.Bytes(), fallbackErr\n}\n\n// classifyResult interprets the command's exit status and stdout to determine\n// the step result.\nfunc (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n\tif runErr != nil {\n\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n\t\t\t// Command failed to start (not found, permission denied, etc.)\n\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n\t\t}\n\t\t// Command ran but exited non-zero\n\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n\t\tif found {\n\t\t\treturn markerResult, stdoutBytes, nil\n\t\t}\n\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n\t}\n\n\t// Command succeeded (exit 0)\n\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n\t}\n\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, stdoutBytes, nil\n}\n\n// extractStreamText parses a stream-json line and returns text content.\n// It handles both content_block_delta (text_delta) events for streaming and\n// result events for final output (which contains the CLOCHE_RESULT marker).\nfunc extractStreamText(line []byte) string {\n\t// Fast path: only parse lines that could contain text we care about.\n\tif bytes.Contains(line, []byte(`\"text_delta\"`)) {\n\t\tvar event struct {\n\t\t\tType  string `json:\"type\"`\n\t\t\tDelta struct {\n\t\t\t\tType string `json:\"type\"`\n\t\t\t\tText string `json:\"text\"`\n\t\t\t} `json:\"delta\"`\n\t\t}\n\t\tif json.Unmarshal(line, &event) == nil &&\n\t\t\tevent.Type == \"content_block_delta\" && event.Delta.Type == \"text_delta\" {\n\t\t\treturn event.Delta.Text\n\t\t}\n\t}\n\n\t// Also extract the final result text (contains CLOCHE_RESULT marker).\n\tif bytes.Contains(line, []byte(`\"result\"`)) && bytes.Contains(line, []byte(`\"subtype\"`)) {\n\t\tvar event struct {\n\t\t\tType   string `json:\"type\"`\n\t\t\tResult string `json:\"result\"`\n\t\t}\n\t\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n\t\t\treturn event.Result\n\t\t}\n\t}\n\n\treturn \"\"\n}\n\nfunc assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n\tvar parts []string\n\n\t// 1. Read system template from step config\n\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n\t\tcontent, err := resolveContent(tmpl, workDir)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n\t\t}\n\t\tparts = append(parts, content)\n\t}\n\n\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n\tuserPrompt := readUserPrompt(workDir, runID)\n\tif userPrompt != \"\" {\n\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n\t}\n\n\t// 3. Read feedback from .cloche/output/*.log\n\tfeedback := readFeedback(workDir)\n\tif feedback != \"\" {\n\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n\t}\n\n\t// 4. Result selection instructions\n\tif len(step.Results) > 0 {\n\t\tvar resultLines []string\n\t\tresultLines = append(resultLines, \"## Result Selection\")\n\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n\t\tfor _, r := range step.Results {\n\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n\t\t}\n\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n\t}\n\n\treturn strings.Join(parts, \"\\n\\n\"), nil\n}\n\n// resolveContent handles file(\"path\") syntax or returns the string directly.\nfunc resolveContent(value string, workDir string) (string, error) {\n\t// Check for file(\"path\") syntax from DSL parser\n\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n\t\tpath := value[6 : len(value)-2]\n\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n\t\t}\n\t\treturn string(data), nil\n\t}\n\treturn value, nil\n}\n\nfunc readFeedback(workDir string) string {\n\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\n\tvar parts []string\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tcontent := strings.TrimSpace(string(data))\n\t\tif content != \"\" {\n\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n\t\t}\n\t}\n\n\treturn strings.Join(parts, \"\\n\\n\")\n}\n\nfunc readAttemptCount(workDir, stepName string) int {\n\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n\tdata, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn 0\n\t}\n\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n\treturn n\n}\n\n// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\nfunc readUserPrompt(workDir, runID string) string {\n\tif runID == \"\" {\n\t\treturn \"\"\n\t}\n\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n\tif data, err := os.ReadFile(path); err == nil {\n\t\treturn string(data)\n\t}\n\treturn \"\"\n}\n\nfunc incrementAttemptCount(workDir, stepName string) {\n\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n\t_ = os.MkdirAll(dir, 0755)\n\tcount := readAttemptCount(workDir, stepName) + 1\n\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n}\n","numLines":387,"startLine":1,"totalLines":387}}}
