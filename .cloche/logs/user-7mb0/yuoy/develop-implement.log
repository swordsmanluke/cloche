{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016dZD3PUWVqZys5PZkzwa8x","type":"tool_result","content":"     1â†’package prompt_test\n     2â†’\n     3â†’import (\n     4â†’\t\"context\"\n     5â†’\t\"os\"\n     6â†’\t\"path/filepath\"\n     7â†’\t\"testing\"\n     8â†’\n     9â†’\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    10â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11â†’\t\"github.com/stretchr/testify/assert\"\n    12â†’\t\"github.com/stretchr/testify/require\"\n    13â†’)\n    14â†’\n    15â†’func TestPromptAdapter_ExecutesCommand(t *testing.T) {\n    16â†’\tdir := t.TempDir()\n    17â†’\n    18â†’\t// Write a user prompt under a run ID\n    19â†’\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"test-run\"), 0755))\n    20â†’\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test-run\", \"prompt.txt\"), []byte(\"add a calculator\"), 0644))\n    21â†’\n    22â†’\t// Use a mock command that writes a file to prove it ran\n    23â†’\tadapter := &prompt.Adapter{\n    24â†’\t\tCommands:     []string{\"sh\"},\n    25â†’\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'implemented' > result.txt && echo ok\"},\n    26â†’\t\tRunID:        \"test-run\",\n    27â†’\t}\n    28â†’\n    29â†’\tstep := &domain.Step{\n    30â†’\t\tName:    \"implement\",\n    31â†’\t\tType:    domain.StepTypeAgent,\n    32â†’\t\tResults: []string{\"success\", \"fail\"},\n    33â†’\t\tConfig:  map[string]string{\"prompt\": \"You are a coding assistant.\"},\n    34â†’\t}\n    35â†’\n    36â†’\tresult, err := adapter.Execute(context.Background(), step, dir)\n    37â†’\trequire.NoError(t, err)\n    38â†’\tassert.Equal(t, \"success\", result)\n    39â†’\n    40â†’\t// Verify the mock command ran\n    41â†’\tcontent, err := os.ReadFile(filepath.Join(dir, \"result.txt\"))\n    42â†’\trequire.NoError(t, err)\n    43â†’\tassert.Contains(t, string(content), \"implemented\")\n    44â†’}\n    45â†’\n    46â†’func TestPromptAdapter_IncludesFeedback(t *testing.T) {\n    47â†’\tdir := t.TempDir()\n    48â†’\n    49â†’\t// Set up feedback logs\n    50â†’\toutputDir := filepath.Join(dir, \".cloche\", \"output\")\n    51â†’\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n    52â†’\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"test.log\"), []byte(\"3 failures\"), 0644))\n    53â†’\n    54â†’\t// Mock command that captures stdin to a file so we can inspect it\n    55â†’\tadapter := &prompt.Adapter{\n    56â†’\t\tCommands:     []string{\"sh\"},\n    57â†’\t\tExplicitArgs: []string{\"-c\", \"cat > captured_prompt.txt && echo ok\"},\n    58â†’\t}\n    59â†’\n    60â†’\tstep := &domain.Step{\n    61â†’\t\tName:    \"fix\",\n    62â†’\t\tType:    domain.StepTypeAgent,\n    63â†’\t\tResults: []string{\"success\", \"fail\", \"give-up\"},\n    64â†’\t\tConfig:  map[string]string{\"prompt\": \"Fix the code.\"},\n    65â†’\t}\n    66â†’\n    67â†’\tresult, err := adapter.Execute(context.Background(), step, dir)\n    68â†’\trequire.NoError(t, err)\n    69â†’\tassert.Equal(t, \"success\", result)\n    70â†’\n    71â†’\t// Verify feedback was included in the prompt\n    72â†’\tcaptured, err := os.ReadFile(filepath.Join(dir, \"captured_prompt.txt\"))\n    73â†’\trequire.NoError(t, err)\n    74â†’\tassert.Contains(t, string(captured), \"Fix the code.\")\n    75â†’\tassert.Contains(t, string(captured), \"3 failures\")\n    76â†’}\n    77â†’\n    78â†’func TestPromptAdapter_RespectsMaxAttempts(t *testing.T) {\n    79â†’\tdir := t.TempDir()\n    80â†’\n    81â†’\t// Pre-set attempt count to the max\n    82â†’\tattemptDir := filepath.Join(dir, \".cloche\", \"attempt_count\")\n    83â†’\trequire.NoError(t, os.MkdirAll(attemptDir, 0755))\n    84â†’\trequire.NoError(t, os.WriteFile(filepath.Join(attemptDir, \"fix\"), []byte(\"2\"), 0644))\n    85â†’\n    86â†’\t// Command should NOT be called since max is reached\n    87â†’\tadapter := &prompt.Adapter{\n    88â†’\t\tCommands:     []string{\"sh\"},\n    89â†’\t\tExplicitArgs: []string{\"-c\", \"exit 1\"}, // would fail if called\n    90â†’\t}\n    91â†’\n    92â†’\tstep := &domain.Step{\n    93â†’\t\tName:    \"fix\",\n    94â†’\t\tType:    domain.StepTypeAgent,\n    95â†’\t\tResults: []string{\"fixed\", \"give-up\"},\n    96â†’\t\tConfig: map[string]string{\n    97â†’\t\t\t\"prompt\":       \"Fix the code.\",\n    98â†’\t\t\t\"max_attempts\": \"2\",\n    99â†’\t\t},\n   100â†’\t}\n   101â†’\n   102â†’\tresult, err := adapter.Execute(context.Background(), step, dir)\n   103â†’\trequire.NoError(t, err)\n   104â†’\tassert.Equal(t, \"give-up\", result)\n   105â†’}\n   106â†’\n   107â†’func TestPromptAdapter_CommandFailure(t *testing.T) {\n   108â†’\tdir := t.TempDir()\n   109â†’\n   110â†’\tadapter := &prompt.Adapter{\n   111â†’\t\tCommands:     []string{\"sh\"},\n   112â†’\t\tExplicitArgs: []string{\"-c\", \"exit 1\"},\n   113â†’\t}\n   114â†’\n   115â†’\tstep := &domain.Step{\n   116â†’\t\tName:    \"implement\",\n   117â†’\t\tType:    domain.StepTypeAgent,\n   118â†’\t\tResults: []string{\"success\", \"fail\"},\n   119â†’\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   120â†’\t}\n   121â†’\n   122â†’\tresult, err := adapter.Execute(context.Background(), step, dir)\n   123â†’\trequire.NoError(t, err)\n   124â†’\tassert.Equal(t, \"fail\", result)\n   125â†’}\n   126â†’\n   127â†’func TestPromptAdapter_InjectsResultInstructions(t *testing.T) {\n   128â†’\tdir := t.TempDir()\n   129â†’\n   130â†’\tadapter := &prompt.Adapter{\n   131â†’\t\tCommands:     []string{\"sh\"},\n   132â†’\t\tExplicitArgs: []string{\"-c\", \"cat > captured_prompt.txt && echo ok\"},\n   133â†’\t}\n   134â†’\n   135â†’\tstep := &domain.Step{\n   136â†’\t\tName:    \"analyze\",\n   137â†’\t\tType:    domain.StepTypeAgent,\n   138â†’\t\tResults: []string{\"success\", \"fail\", \"needs_research\"},\n   139â†’\t\tConfig:  map[string]string{\"prompt\": \"Analyze the code.\"},\n   140â†’\t}\n   141â†’\n   142â†’\t_, err := adapter.Execute(context.Background(), step, dir)\n   143â†’\trequire.NoError(t, err)\n   144â†’\n   145â†’\tcaptured, err := os.ReadFile(filepath.Join(dir, \"captured_prompt.txt\"))\n   146â†’\trequire.NoError(t, err)\n   147â†’\tassert.Contains(t, string(captured), \"CLOCHE_RESULT:success\")\n   148â†’\tassert.Contains(t, string(captured), \"CLOCHE_RESULT:fail\")\n   149â†’\tassert.Contains(t, string(captured), \"CLOCHE_RESULT:needs_research\")\n   150â†’}\n   151â†’\n   152â†’func TestPromptAdapter_StdoutMarkerSelectsResult(t *testing.T) {\n   153â†’\tdir := t.TempDir()\n   154â†’\n   155â†’\tadapter := &prompt.Adapter{\n   156â†’\t\tCommands:     []string{\"sh\"},\n   157â†’\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'CLOCHE_RESULT:needs_research'\"},\n   158â†’\t}\n   159â†’\n   160â†’\tstep := &domain.Step{\n   161â†’\t\tName:    \"analyze\",\n   162â†’\t\tType:    domain.StepTypeAgent,\n   163â†’\t\tResults: []string{\"success\", \"fail\", \"needs_research\"},\n   164â†’\t\tConfig:  map[string]string{\"prompt\": \"Analyze the code.\"},\n   165â†’\t}\n   166â†’\n   167â†’\tresult, err := adapter.Execute(context.Background(), step, dir)\n   168â†’\trequire.NoError(t, err)\n   169â†’\tassert.Equal(t, \"needs_research\", result)\n   170â†’}\n   171â†’\n   172â†’func TestExecuteWritesOutputFile(t *testing.T) {\n   173â†’\tdir := t.TempDir()\n   174â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"test-run\"), 0755)\n   175â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"test-run\", \"prompt.txt\"), []byte(\"user request\"), 0644)\n   176â†’\n   177â†’\ta := &prompt.Adapter{\n   178â†’\t\tCommands:     []string{\"sh\"},\n   179â†’\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'agent output'\"},\n   180â†’\t\tRunID:        \"test-run\",\n   181â†’\t}\n   182â†’\n   183â†’\tstep := &domain.Step{\n   184â†’\t\tName:    \"implement\",\n   185â†’\t\tType:    domain.StepTypeAgent,\n   186â†’\t\tResults: []string{\"success\", \"fail\"},\n   187â†’\t\tConfig:  map[string]string{\"prompt\": \"Build something\"},\n   188â†’\t}\n   189â†’\n   190â†’\tresult, err := a.Execute(context.Background(), step, dir)\n   191â†’\trequire.NoError(t, err)\n   192â†’\tassert.Equal(t, \"success\", result)\n   193â†’\n   194â†’\t// Verify output was written to file\n   195â†’\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n   196â†’\tdata, err := os.ReadFile(outputPath)\n   197â†’\trequire.NoError(t, err)\n   198â†’\tassert.Contains(t, string(data), \"agent output\")\n   199â†’}\n   200â†’\n   201â†’func TestPromptAdapter_IncrementsAttemptCount(t *testing.T) {\n   202â†’\tdir := t.TempDir()\n   203â†’\n   204â†’\tadapter := &prompt.Adapter{\n   205â†’\t\tCommands:     []string{\"sh\"},\n   206â†’\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null\"},\n   207â†’\t}\n   208â†’\n   209â†’\tstep := &domain.Step{\n   210â†’\t\tName:    \"fix\",\n   211â†’\t\tType:    domain.StepTypeAgent,\n   212â†’\t\tResults: []string{\"fixed\", \"give-up\"},\n   213â†’\t\tConfig:  map[string]string{\"prompt\": \"Fix it.\"},\n   214â†’\t}\n   215â†’\n   216â†’\t// Execute twice\n   217â†’\t_, err := adapter.Execute(context.Background(), step, dir)\n   218â†’\trequire.NoError(t, err)\n   219â†’\t_, err = adapter.Execute(context.Background(), step, dir)\n   220â†’\trequire.NoError(t, err)\n   221â†’\n   222â†’\t// Verify count is 2\n   223â†’\tcountPath := filepath.Join(dir, \".cloche\", \"attempt_count\", \"fix\")\n   224â†’\tdata, err := os.ReadFile(countPath)\n   225â†’\trequire.NoError(t, err)\n   226â†’\tassert.Equal(t, \"2\", string(data))\n   227â†’}\n   228â†’\n   229â†’// --- Fallback chain tests ---\n   230â†’\n   231â†’func TestPromptAdapter_FallbackOnCommandNotFound(t *testing.T) {\n   232â†’\tdir := t.TempDir()\n   233â†’\n   234â†’\t// First command doesn't exist, second one does\n   235â†’\tadapter := &prompt.Adapter{\n   236â†’\t\tCommands:     []string{\"nonexistent-agent-xyz\", \"sh\"},\n   237â†’\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'fallback ran'\"},\n   238â†’\t}\n   239â†’\n   240â†’\tstep := &domain.Step{\n   241â†’\t\tName:    \"implement\",\n   242â†’\t\tType:    domain.StepTypeAgent,\n   243â†’\t\tResults: []string{\"success\", \"fail\"},\n   244â†’\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   245â†’\t}\n   246â†’\n   247â†’\tresult, err := adapter.Execute(context.Background(), step, dir)\n   248â†’\trequire.NoError(t, err)\n   249â†’\tassert.Equal(t, \"success\", result)\n   250â†’\n   251â†’\t// Verify the fallback command's output was captured\n   252â†’\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n   253â†’\tdata, err := os.ReadFile(outputPath)\n   254â†’\trequire.NoError(t, err)\n   255â†’\tassert.Contains(t, string(data), \"fallback ran\")\n   256â†’}\n   257â†’\n   258â†’func TestPromptAdapter_FallbackOnExitErrorNoMarker(t *testing.T) {\n   259â†’\tdir := t.TempDir()\n   260â†’\n   261â†’\t// Create two scripts: first exits 1 without marker, second succeeds\n   262â†’\tfailing := filepath.Join(dir, \"failing-agent.sh\")\n   263â†’\trequire.NoError(t, os.WriteFile(failing, []byte(\"#!/bin/sh\\ncat > /dev/null\\nexit 1\\n\"), 0755))\n   264â†’\n   265â†’\tsucceeding := filepath.Join(dir, \"good-agent.sh\")\n   266â†’\trequire.NoError(t, os.WriteFile(succeeding, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'good agent output'\\n\"), 0755))\n   267â†’\n   268â†’\tadapter := &prompt.Adapter{\n   269â†’\t\tCommands: []string{failing, succeeding},\n   270â†’\t}\n   271â†’\n   272â†’\tstep := &domain.Step{\n   273â†’\t\tName:    \"implement\",\n   274â†’\t\tType:    domain.StepTypeAgent,\n   275â†’\t\tResults: []string{\"success\", \"fail\"},\n   276â†’\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   277â†’\t}\n   278â†’\n   279â†’\tresult, err := adapter.Execute(context.Background(), step, dir)\n   280â†’\trequire.NoError(t, err)\n   281â†’\tassert.Equal(t, \"success\", result)\n   282â†’\n   283â†’\t// Verify the fallback command's output was captured\n   284â†’\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n   285â†’\tdata, err := os.ReadFile(outputPath)\n   286â†’\trequire.NoError(t, err)\n   287â†’\tassert.Contains(t, string(data), \"good agent output\")\n   288â†’}\n   289â†’\n   290â†’func TestPromptAdapter_NoFallbackOnMarkerResult(t *testing.T) {\n   291â†’\tdir := t.TempDir()\n   292â†’\n   293â†’\t// First command exits 1 but reports a CLOCHE_RESULT marker â€” should NOT fall back\n   294â†’\tfailing := filepath.Join(dir, \"reporting-agent.sh\")\n   295â†’\trequire.NoError(t, os.WriteFile(failing, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'CLOCHE_RESULT:fail'\\nexit 1\\n\"), 0755))\n   296â†’\n   297â†’\tshouldNotRun := filepath.Join(dir, \"should-not-run.sh\")\n   298â†’\trequire.NoError(t, os.WriteFile(shouldNotRun, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'CLOCHE_RESULT:success'\\n\"), 0755))\n   299â†’\n   300â†’\tadapter := &prompt.Adapter{\n   301â†’\t\tCommands: []string{failing, shouldNotRun},\n   302â†’\t}\n   303â†’\n   304â†’\tstep := &domain.Step{\n   305â†’\t\tName:    \"implement\",\n   306â†’\t\tType:    domain.StepTypeAgent,\n   307â†’\t\tResults: []string{\"success\", \"fail\"},\n   308â†’\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   309â†’\t}\n   310â†’\n   311â†’\tresult, err := adapter.Execute(context.Background(), step, dir)\n   312â†’\trequire.NoError(t, err)\n   313â†’\t// Should use the first agent's result, not fall back\n   314â†’\tassert.Equal(t, \"fail\", result)\n   315â†’}\n   316â†’\n   317â†’func TestPromptAdapter_AllCommandsFail(t *testing.T) {\n   318â†’\tdir := t.TempDir()\n   319â†’\n   320â†’\t// All commands don't exist\n   321â†’\tadapter := &prompt.Adapter{\n   322â†’\t\tCommands: []string{\"nonexistent-agent-1\", \"nonexistent-agent-2\"},\n   323â†’\t}\n   324â†’\n   325â†’\tstep := &domain.Step{\n   326â†’\t\tName:    \"implement\",\n   327â†’\t\tType:    domain.StepTypeAgent,\n   328â†’\t\tResults: []string{\"success\", \"fail\"},\n   329â†’\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   330â†’\t}\n   331â†’\n   332â†’\t_, err := adapter.Execute(context.Background(), step, dir)\n   333â†’\trequire.Error(t, err)\n   334â†’\tassert.Contains(t, err.Error(), \"failed to start\")\n   335â†’}\n   336â†’\n   337â†’func TestPromptAdapter_LastCommandCrashReturnsFailResult(t *testing.T) {\n   338â†’\tdir := t.TempDir()\n   339â†’\n   340â†’\t// Both commands exit non-zero without marker\n   341â†’\tfailing1 := filepath.Join(dir, \"failing1.sh\")\n   342â†’\trequire.NoError(t, os.WriteFile(failing1, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'crash1'\\nexit 1\\n\"), 0755))\n   343â†’\n   344â†’\tfailing2 := filepath.Join(dir, \"failing2.sh\")\n   345â†’\trequire.NoError(t, os.WriteFile(failing2, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'crash2'\\nexit 1\\n\"), 0755))\n   346â†’\n   347â†’\tadapter := &prompt.Adapter{\n   348â†’\t\tCommands: []string{failing1, failing2},\n   349â†’\t}\n   350â†’\n   351â†’\tstep := &domain.Step{\n   352â†’\t\tName:    \"implement\",\n   353â†’\t\tType:    domain.StepTypeAgent,\n   354â†’\t\tResults: []string{\"success\", \"fail\"},\n   355â†’\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   356â†’\t}\n   357â†’\n   358â†’\tresult, err := adapter.Execute(context.Background(), step, dir)\n   359â†’\trequire.NoError(t, err)\n   360â†’\tassert.Equal(t, \"fail\", result)\n   361â†’}\n   362â†’\n   363â†’func TestPromptAdapter_SingleCommandPreservesBehavior(t *testing.T) {\n   364â†’\tdir := t.TempDir()\n   365â†’\n   366â†’\t// Single command, exit 0 â€” should behave exactly like before\n   367â†’\tadapter := &prompt.Adapter{\n   368â†’\t\tCommands:     []string{\"sh\"},\n   369â†’\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo hello\"},\n   370â†’\t}\n   371â†’\n   372â†’\tstep := &domain.Step{\n   373â†’\t\tName:    \"implement\",\n   374â†’\t\tType:    domain.StepTypeAgent,\n   375â†’\t\tResults: []string{\"success\", \"fail\"},\n   376â†’\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   377â†’\t}\n   378â†’\n   379â†’\tresult, err := adapter.Execute(context.Background(), step, dir)\n   380â†’\trequire.NoError(t, err)\n   381â†’\tassert.Equal(t, \"success\", result)\n   382â†’}\n   383â†’\n   384â†’func TestPromptAdapter_DefaultArgsForClaude(t *testing.T) {\n   385â†’\t// Verify New() creates an adapter with \"claude\" as the default command\n   386â†’\tadapter := prompt.New()\n   387â†’\tassert.Equal(t, []string{\"claude\"}, adapter.Commands)\n   388â†’\tassert.Nil(t, adapter.ExplicitArgs)\n   389â†’}\n   390â†’\n   391â†’func TestParseCommands(t *testing.T) {\n   392â†’\ttests := []struct {\n   393â†’\t\tinput    string\n   394â†’\t\texpected []string\n   395â†’\t}{\n   396â†’\t\t{\"claude\", []string{\"claude\"}},\n   397â†’\t\t{\"claude,gemini\", []string{\"claude\", \"gemini\"}},\n   398â†’\t\t{\"claude, gemini, codex\", []string{\"claude\", \"gemini\", \"codex\"}},\n   399â†’\t\t{\" claude , gemini , codex \", []string{\"claude\", \"gemini\", \"codex\"}},\n   400â†’\t\t{\"claude,,gemini\", []string{\"claude\", \"gemini\"}},\n   401â†’\t\t{\"\", nil},\n   402â†’\t}\n   403â†’\tfor _, tc := range tests {\n   404â†’\t\tt.Run(tc.input, func(t *testing.T) {\n   405â†’\t\t\tresult := prompt.ParseCommands(tc.input)\n   406â†’\t\t\tassert.Equal(t, tc.expected, result)\n   407â†’\t\t})\n   408â†’\t}\n   409â†’}\n   410â†’"}]},"parent_tool_use_id":null,"session_id":"410fed70-c824-4ba1-8e3b-ac0d517a6329","uuid":"41a16dc9-4ff3-45f4-a113-2e665c3c7d2b","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/agents/prompt/prompt_test.go","content":"package prompt_test\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestPromptAdapter_ExecutesCommand(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Write a user prompt under a run ID\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"test-run\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test-run\", \"prompt.txt\"), []byte(\"add a calculator\"), 0644))\n\n\t// Use a mock command that writes a file to prove it ran\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'implemented' > result.txt && echo ok\"},\n\t\tRunID:        \"test-run\",\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"You are a coding assistant.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Verify the mock command ran\n\tcontent, err := os.ReadFile(filepath.Join(dir, \"result.txt\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"implemented\")\n}\n\nfunc TestPromptAdapter_IncludesFeedback(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Set up feedback logs\n\toutputDir := filepath.Join(dir, \".cloche\", \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"test.log\"), []byte(\"3 failures\"), 0644))\n\n\t// Mock command that captures stdin to a file so we can inspect it\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > captured_prompt.txt && echo ok\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"fix\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\", \"give-up\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Fix the code.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Verify feedback was included in the prompt\n\tcaptured, err := os.ReadFile(filepath.Join(dir, \"captured_prompt.txt\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(captured), \"Fix the code.\")\n\tassert.Contains(t, string(captured), \"3 failures\")\n}\n\nfunc TestPromptAdapter_RespectsMaxAttempts(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Pre-set attempt count to the max\n\tattemptDir := filepath.Join(dir, \".cloche\", \"attempt_count\")\n\trequire.NoError(t, os.MkdirAll(attemptDir, 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(attemptDir, \"fix\"), []byte(\"2\"), 0644))\n\n\t// Command should NOT be called since max is reached\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"exit 1\"}, // would fail if called\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"fix\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"fixed\", \"give-up\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\":       \"Fix the code.\",\n\t\t\t\"max_attempts\": \"2\",\n\t\t},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"give-up\", result)\n}\n\nfunc TestPromptAdapter_CommandFailure(t *testing.T) {\n\tdir := t.TempDir()\n\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"exit 1\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestPromptAdapter_InjectsResultInstructions(t *testing.T) {\n\tdir := t.TempDir()\n\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > captured_prompt.txt && echo ok\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"analyze\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\", \"needs_research\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Analyze the code.\"},\n\t}\n\n\t_, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\n\tcaptured, err := os.ReadFile(filepath.Join(dir, \"captured_prompt.txt\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(captured), \"CLOCHE_RESULT:success\")\n\tassert.Contains(t, string(captured), \"CLOCHE_RESULT:fail\")\n\tassert.Contains(t, string(captured), \"CLOCHE_RESULT:needs_research\")\n}\n\nfunc TestPromptAdapter_StdoutMarkerSelectsResult(t *testing.T) {\n\tdir := t.TempDir()\n\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'CLOCHE_RESULT:needs_research'\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"analyze\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\", \"needs_research\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Analyze the code.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"needs_research\", result)\n}\n\nfunc TestExecuteWritesOutputFile(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"test-run\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"test-run\", \"prompt.txt\"), []byte(\"user request\"), 0644)\n\n\ta := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'agent output'\"},\n\t\tRunID:        \"test-run\",\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Build something\"},\n\t}\n\n\tresult, err := a.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Verify output was written to file\n\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n\tdata, err := os.ReadFile(outputPath)\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"agent output\")\n}\n\nfunc TestPromptAdapter_IncrementsAttemptCount(t *testing.T) {\n\tdir := t.TempDir()\n\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"fix\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"fixed\", \"give-up\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Fix it.\"},\n\t}\n\n\t// Execute twice\n\t_, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\t_, err = adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\n\t// Verify count is 2\n\tcountPath := filepath.Join(dir, \".cloche\", \"attempt_count\", \"fix\")\n\tdata, err := os.ReadFile(countPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"2\", string(data))\n}\n\n// --- Fallback chain tests ---\n\nfunc TestPromptAdapter_FallbackOnCommandNotFound(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// First command doesn't exist, second one does\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"nonexistent-agent-xyz\", \"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'fallback ran'\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Verify the fallback command's output was captured\n\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n\tdata, err := os.ReadFile(outputPath)\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"fallback ran\")\n}\n\nfunc TestPromptAdapter_FallbackOnExitErrorNoMarker(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Create two scripts: first exits 1 without marker, second succeeds\n\tfailing := filepath.Join(dir, \"failing-agent.sh\")\n\trequire.NoError(t, os.WriteFile(failing, []byte(\"#!/bin/sh\\ncat > /dev/null\\nexit 1\\n\"), 0755))\n\n\tsucceeding := filepath.Join(dir, \"good-agent.sh\")\n\trequire.NoError(t, os.WriteFile(succeeding, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'good agent output'\\n\"), 0755))\n\n\tadapter := &prompt.Adapter{\n\t\tCommands: []string{failing, succeeding},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Verify the fallback command's output was captured\n\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n\tdata, err := os.ReadFile(outputPath)\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"good agent output\")\n}\n\nfunc TestPromptAdapter_NoFallbackOnMarkerResult(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// First command exits 1 but reports a CLOCHE_RESULT marker â€” should NOT fall back\n\tfailing := filepath.Join(dir, \"reporting-agent.sh\")\n\trequire.NoError(t, os.WriteFile(failing, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'CLOCHE_RESULT:fail'\\nexit 1\\n\"), 0755))\n\n\tshouldNotRun := filepath.Join(dir, \"should-not-run.sh\")\n\trequire.NoError(t, os.WriteFile(shouldNotRun, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'CLOCHE_RESULT:success'\\n\"), 0755))\n\n\tadapter := &prompt.Adapter{\n\t\tCommands: []string{failing, shouldNotRun},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\t// Should use the first agent's result, not fall back\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestPromptAdapter_AllCommandsFail(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// All commands don't exist\n\tadapter := &prompt.Adapter{\n\t\tCommands: []string{\"nonexistent-agent-1\", \"nonexistent-agent-2\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n\t}\n\n\t_, err := adapter.Execute(context.Background(), step, dir)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"failed to start\")\n}\n\nfunc TestPromptAdapter_LastCommandCrashReturnsFailResult(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Both commands exit non-zero without marker\n\tfailing1 := filepath.Join(dir, \"failing1.sh\")\n\trequire.NoError(t, os.WriteFile(failing1, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'crash1'\\nexit 1\\n\"), 0755))\n\n\tfailing2 := filepath.Join(dir, \"failing2.sh\")\n\trequire.NoError(t, os.WriteFile(failing2, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'crash2'\\nexit 1\\n\"), 0755))\n\n\tadapter := &prompt.Adapter{\n\t\tCommands: []string{failing1, failing2},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestPromptAdapter_SingleCommandPreservesBehavior(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Single command, exit 0 â€” should behave exactly like before\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo hello\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n}\n\nfunc TestPromptAdapter_DefaultArgsForClaude(t *testing.T) {\n\t// Verify New() creates an adapter with \"claude\" as the default command\n\tadapter := prompt.New()\n\tassert.Equal(t, []string{\"claude\"}, adapter.Commands)\n\tassert.Nil(t, adapter.ExplicitArgs)\n}\n\nfunc TestParseCommands(t *testing.T) {\n\ttests := []struct {\n\t\tinput    string\n\t\texpected []string\n\t}{\n\t\t{\"claude\", []string{\"claude\"}},\n\t\t{\"claude,gemini\", []string{\"claude\", \"gemini\"}},\n\t\t{\"claude, gemini, codex\", []string{\"claude\", \"gemini\", \"codex\"}},\n\t\t{\" claude , gemini , codex \", []string{\"claude\", \"gemini\", \"codex\"}},\n\t\t{\"claude,,gemini\", []string{\"claude\", \"gemini\"}},\n\t\t{\"\", nil},\n\t}\n\tfor _, tc := range tests {\n\t\tt.Run(tc.input, func(t *testing.T) {\n\t\t\tresult := prompt.ParseCommands(tc.input)\n\t\t\tassert.Equal(t, tc.expected, result)\n\t\t})\n\t}\n}\n","numLines":410,"startLine":1,"totalLines":410}}}
