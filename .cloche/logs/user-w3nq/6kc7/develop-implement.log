{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DvRBw2cXbvM1AYJsi52WYv","type":"tool_result","content":"     1→package prompt_test\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"os\"\n     6→\t\"path/filepath\"\n     7→\t\"testing\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    10→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11→\t\"github.com/stretchr/testify/assert\"\n    12→\t\"github.com/stretchr/testify/require\"\n    13→)\n    14→\n    15→func TestPromptAdapter_ExecutesCommand(t *testing.T) {\n    16→\tdir := t.TempDir()\n    17→\n    18→\t// Write a user prompt under a run ID\n    19→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"test-run\"), 0755))\n    20→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test-run\", \"prompt.txt\"), []byte(\"add a calculator\"), 0644))\n    21→\n    22→\t// Use a mock command that writes a file to prove it ran\n    23→\tadapter := &prompt.Adapter{\n    24→\t\tCommands:     []string{\"sh\"},\n    25→\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'implemented' > result.txt && echo ok\"},\n    26→\t\tRunID:        \"test-run\",\n    27→\t}\n    28→\n    29→\tstep := &domain.Step{\n    30→\t\tName:    \"implement\",\n    31→\t\tType:    domain.StepTypeAgent,\n    32→\t\tResults: []string{\"success\", \"fail\"},\n    33→\t\tConfig:  map[string]string{\"prompt\": \"You are a coding assistant.\"},\n    34→\t}\n    35→\n    36→\tresult, err := adapter.Execute(context.Background(), step, dir)\n    37→\trequire.NoError(t, err)\n    38→\tassert.Equal(t, \"success\", result)\n    39→\n    40→\t// Verify the mock command ran\n    41→\tcontent, err := os.ReadFile(filepath.Join(dir, \"result.txt\"))\n    42→\trequire.NoError(t, err)\n    43→\tassert.Contains(t, string(content), \"implemented\")\n    44→}\n    45→\n    46→func TestPromptAdapter_IncludesFeedback(t *testing.T) {\n    47→\tdir := t.TempDir()\n    48→\n    49→\t// Set up feedback logs\n    50→\toutputDir := filepath.Join(dir, \".cloche\", \"output\")\n    51→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n    52→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"test.log\"), []byte(\"3 failures\"), 0644))\n    53→\n    54→\t// Mock command that captures stdin to a file so we can inspect it\n    55→\tadapter := &prompt.Adapter{\n    56→\t\tCommands:     []string{\"sh\"},\n    57→\t\tExplicitArgs: []string{\"-c\", \"cat > captured_prompt.txt && echo ok\"},\n    58→\t}\n    59→\n    60→\tstep := &domain.Step{\n    61→\t\tName:    \"fix\",\n    62→\t\tType:    domain.StepTypeAgent,\n    63→\t\tResults: []string{\"success\", \"fail\", \"give-up\"},\n    64→\t\tConfig:  map[string]string{\"prompt\": \"Fix the code.\"},\n    65→\t}\n    66→\n    67→\tresult, err := adapter.Execute(context.Background(), step, dir)\n    68→\trequire.NoError(t, err)\n    69→\tassert.Equal(t, \"success\", result)\n    70→\n    71→\t// Verify feedback was included in the prompt\n    72→\tcaptured, err := os.ReadFile(filepath.Join(dir, \"captured_prompt.txt\"))\n    73→\trequire.NoError(t, err)\n    74→\tassert.Contains(t, string(captured), \"Fix the code.\")\n    75→\tassert.Contains(t, string(captured), \"3 failures\")\n    76→}\n    77→\n    78→func TestPromptAdapter_RespectsMaxAttempts(t *testing.T) {\n    79→\tdir := t.TempDir()\n    80→\n    81→\t// Pre-set attempt count to the max\n    82→\tattemptDir := filepath.Join(dir, \".cloche\", \"attempt_count\")\n    83→\trequire.NoError(t, os.MkdirAll(attemptDir, 0755))\n    84→\trequire.NoError(t, os.WriteFile(filepath.Join(attemptDir, \"fix\"), []byte(\"2\"), 0644))\n    85→\n    86→\t// Command should NOT be called since max is reached\n    87→\tadapter := &prompt.Adapter{\n    88→\t\tCommands:     []string{\"sh\"},\n    89→\t\tExplicitArgs: []string{\"-c\", \"exit 1\"}, // would fail if called\n    90→\t}\n    91→\n    92→\tstep := &domain.Step{\n    93→\t\tName:    \"fix\",\n    94→\t\tType:    domain.StepTypeAgent,\n    95→\t\tResults: []string{\"fixed\", \"give-up\"},\n    96→\t\tConfig: map[string]string{\n    97→\t\t\t\"prompt\":       \"Fix the code.\",\n    98→\t\t\t\"max_attempts\": \"2\",\n    99→\t\t},\n   100→\t}\n   101→\n   102→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   103→\trequire.NoError(t, err)\n   104→\tassert.Equal(t, \"give-up\", result)\n   105→}\n   106→\n   107→func TestPromptAdapter_CommandFailure(t *testing.T) {\n   108→\tdir := t.TempDir()\n   109→\n   110→\tadapter := &prompt.Adapter{\n   111→\t\tCommands:     []string{\"sh\"},\n   112→\t\tExplicitArgs: []string{\"-c\", \"exit 1\"},\n   113→\t}\n   114→\n   115→\tstep := &domain.Step{\n   116→\t\tName:    \"implement\",\n   117→\t\tType:    domain.StepTypeAgent,\n   118→\t\tResults: []string{\"success\", \"fail\"},\n   119→\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   120→\t}\n   121→\n   122→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   123→\trequire.NoError(t, err)\n   124→\tassert.Equal(t, \"fail\", result)\n   125→}\n   126→\n   127→func TestPromptAdapter_InjectsResultInstructions(t *testing.T) {\n   128→\tdir := t.TempDir()\n   129→\n   130→\tadapter := &prompt.Adapter{\n   131→\t\tCommands:     []string{\"sh\"},\n   132→\t\tExplicitArgs: []string{\"-c\", \"cat > captured_prompt.txt && echo ok\"},\n   133→\t}\n   134→\n   135→\tstep := &domain.Step{\n   136→\t\tName:    \"analyze\",\n   137→\t\tType:    domain.StepTypeAgent,\n   138→\t\tResults: []string{\"success\", \"fail\", \"needs_research\"},\n   139→\t\tConfig:  map[string]string{\"prompt\": \"Analyze the code.\"},\n   140→\t}\n   141→\n   142→\t_, err := adapter.Execute(context.Background(), step, dir)\n   143→\trequire.NoError(t, err)\n   144→\n   145→\tcaptured, err := os.ReadFile(filepath.Join(dir, \"captured_prompt.txt\"))\n   146→\trequire.NoError(t, err)\n   147→\tassert.Contains(t, string(captured), \"CLOCHE_RESULT:success\")\n   148→\tassert.Contains(t, string(captured), \"CLOCHE_RESULT:fail\")\n   149→\tassert.Contains(t, string(captured), \"CLOCHE_RESULT:needs_research\")\n   150→}\n   151→\n   152→func TestPromptAdapter_StdoutMarkerSelectsResult(t *testing.T) {\n   153→\tdir := t.TempDir()\n   154→\n   155→\tadapter := &prompt.Adapter{\n   156→\t\tCommands:     []string{\"sh\"},\n   157→\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'CLOCHE_RESULT:needs_research'\"},\n   158→\t}\n   159→\n   160→\tstep := &domain.Step{\n   161→\t\tName:    \"analyze\",\n   162→\t\tType:    domain.StepTypeAgent,\n   163→\t\tResults: []string{\"success\", \"fail\", \"needs_research\"},\n   164→\t\tConfig:  map[string]string{\"prompt\": \"Analyze the code.\"},\n   165→\t}\n   166→\n   167→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   168→\trequire.NoError(t, err)\n   169→\tassert.Equal(t, \"needs_research\", result)\n   170→}\n   171→\n   172→func TestExecuteWritesOutputFile(t *testing.T) {\n   173→\tdir := t.TempDir()\n   174→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"test-run\"), 0755)\n   175→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"test-run\", \"prompt.txt\"), []byte(\"user request\"), 0644)\n   176→\n   177→\ta := &prompt.Adapter{\n   178→\t\tCommands:     []string{\"sh\"},\n   179→\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'agent output'\"},\n   180→\t\tRunID:        \"test-run\",\n   181→\t}\n   182→\n   183→\tstep := &domain.Step{\n   184→\t\tName:    \"implement\",\n   185→\t\tType:    domain.StepTypeAgent,\n   186→\t\tResults: []string{\"success\", \"fail\"},\n   187→\t\tConfig:  map[string]string{\"prompt\": \"Build something\"},\n   188→\t}\n   189→\n   190→\tresult, err := a.Execute(context.Background(), step, dir)\n   191→\trequire.NoError(t, err)\n   192→\tassert.Equal(t, \"success\", result)\n   193→\n   194→\t// Verify output was written to file\n   195→\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n   196→\tdata, err := os.ReadFile(outputPath)\n   197→\trequire.NoError(t, err)\n   198→\tassert.Contains(t, string(data), \"agent output\")\n   199→}\n   200→\n   201→func TestPromptAdapter_IncrementsAttemptCount(t *testing.T) {\n   202→\tdir := t.TempDir()\n   203→\n   204→\tadapter := &prompt.Adapter{\n   205→\t\tCommands:     []string{\"sh\"},\n   206→\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null\"},\n   207→\t}\n   208→\n   209→\tstep := &domain.Step{\n   210→\t\tName:    \"fix\",\n   211→\t\tType:    domain.StepTypeAgent,\n   212→\t\tResults: []string{\"fixed\", \"give-up\"},\n   213→\t\tConfig:  map[string]string{\"prompt\": \"Fix it.\"},\n   214→\t}\n   215→\n   216→\t// Execute twice\n   217→\t_, err := adapter.Execute(context.Background(), step, dir)\n   218→\trequire.NoError(t, err)\n   219→\t_, err = adapter.Execute(context.Background(), step, dir)\n   220→\trequire.NoError(t, err)\n   221→\n   222→\t// Verify count is 2\n   223→\tcountPath := filepath.Join(dir, \".cloche\", \"attempt_count\", \"fix\")\n   224→\tdata, err := os.ReadFile(countPath)\n   225→\trequire.NoError(t, err)\n   226→\tassert.Equal(t, \"2\", string(data))\n   227→}\n   228→\n   229→// --- Fallback chain tests ---\n   230→\n   231→func TestPromptAdapter_FallbackOnCommandNotFound(t *testing.T) {\n   232→\tdir := t.TempDir()\n   233→\n   234→\t// First command doesn't exist, second one does\n   235→\tadapter := &prompt.Adapter{\n   236→\t\tCommands:     []string{\"nonexistent-agent-xyz\", \"sh\"},\n   237→\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'fallback ran'\"},\n   238→\t}\n   239→\n   240→\tstep := &domain.Step{\n   241→\t\tName:    \"implement\",\n   242→\t\tType:    domain.StepTypeAgent,\n   243→\t\tResults: []string{\"success\", \"fail\"},\n   244→\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   245→\t}\n   246→\n   247→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   248→\trequire.NoError(t, err)\n   249→\tassert.Equal(t, \"success\", result)\n   250→\n   251→\t// Verify the fallback command's output was captured\n   252→\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n   253→\tdata, err := os.ReadFile(outputPath)\n   254→\trequire.NoError(t, err)\n   255→\tassert.Contains(t, string(data), \"fallback ran\")\n   256→}\n   257→\n   258→func TestPromptAdapter_FallbackOnExitErrorNoMarker(t *testing.T) {\n   259→\tdir := t.TempDir()\n   260→\n   261→\t// Create two scripts: first exits 1 without marker, second succeeds\n   262→\tfailing := filepath.Join(dir, \"failing-agent.sh\")\n   263→\trequire.NoError(t, os.WriteFile(failing, []byte(\"#!/bin/sh\\ncat > /dev/null\\nexit 1\\n\"), 0755))\n   264→\n   265→\tsucceeding := filepath.Join(dir, \"good-agent.sh\")\n   266→\trequire.NoError(t, os.WriteFile(succeeding, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'good agent output'\\n\"), 0755))\n   267→\n   268→\tadapter := &prompt.Adapter{\n   269→\t\tCommands: []string{failing, succeeding},\n   270→\t}\n   271→\n   272→\tstep := &domain.Step{\n   273→\t\tName:    \"implement\",\n   274→\t\tType:    domain.StepTypeAgent,\n   275→\t\tResults: []string{\"success\", \"fail\"},\n   276→\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   277→\t}\n   278→\n   279→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   280→\trequire.NoError(t, err)\n   281→\tassert.Equal(t, \"success\", result)\n   282→\n   283→\t// Verify the fallback command's output was captured\n   284→\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n   285→\tdata, err := os.ReadFile(outputPath)\n   286→\trequire.NoError(t, err)\n   287→\tassert.Contains(t, string(data), \"good agent output\")\n   288→}\n   289→\n   290→func TestPromptAdapter_NoFallbackOnMarkerResult(t *testing.T) {\n   291→\tdir := t.TempDir()\n   292→\n   293→\t// First command exits 1 but reports a CLOCHE_RESULT marker — should NOT fall back\n   294→\tfailing := filepath.Join(dir, \"reporting-agent.sh\")\n   295→\trequire.NoError(t, os.WriteFile(failing, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'CLOCHE_RESULT:fail'\\nexit 1\\n\"), 0755))\n   296→\n   297→\tshouldNotRun := filepath.Join(dir, \"should-not-run.sh\")\n   298→\trequire.NoError(t, os.WriteFile(shouldNotRun, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'CLOCHE_RESULT:success'\\n\"), 0755))\n   299→\n   300→\tadapter := &prompt.Adapter{\n   301→\t\tCommands: []string{failing, shouldNotRun},\n   302→\t}\n   303→\n   304→\tstep := &domain.Step{\n   305→\t\tName:    \"implement\",\n   306→\t\tType:    domain.StepTypeAgent,\n   307→\t\tResults: []string{\"success\", \"fail\"},\n   308→\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   309→\t}\n   310→\n   311→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   312→\trequire.NoError(t, err)\n   313→\t// Should use the first agent's result, not fall back\n   314→\tassert.Equal(t, \"fail\", result)\n   315→}\n   316→\n   317→func TestPromptAdapter_AllCommandsFail(t *testing.T) {\n   318→\tdir := t.TempDir()\n   319→\n   320→\t// All commands don't exist\n   321→\tadapter := &prompt.Adapter{\n   322→\t\tCommands: []string{\"nonexistent-agent-1\", \"nonexistent-agent-2\"},\n   323→\t}\n   324→\n   325→\tstep := &domain.Step{\n   326→\t\tName:    \"implement\",\n   327→\t\tType:    domain.StepTypeAgent,\n   328→\t\tResults: []string{\"success\", \"fail\"},\n   329→\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   330→\t}\n   331→\n   332→\t_, err := adapter.Execute(context.Background(), step, dir)\n   333→\trequire.Error(t, err)\n   334→\tassert.Contains(t, err.Error(), \"failed to start\")\n   335→}\n   336→\n   337→func TestPromptAdapter_LastCommandCrashReturnsFailResult(t *testing.T) {\n   338→\tdir := t.TempDir()\n   339→\n   340→\t// Both commands exit non-zero without marker\n   341→\tfailing1 := filepath.Join(dir, \"failing1.sh\")\n   342→\trequire.NoError(t, os.WriteFile(failing1, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'crash1'\\nexit 1\\n\"), 0755))\n   343→\n   344→\tfailing2 := filepath.Join(dir, \"failing2.sh\")\n   345→\trequire.NoError(t, os.WriteFile(failing2, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'crash2'\\nexit 1\\n\"), 0755))\n   346→\n   347→\tadapter := &prompt.Adapter{\n   348→\t\tCommands: []string{failing1, failing2},\n   349→\t}\n   350→\n   351→\tstep := &domain.Step{\n   352→\t\tName:    \"implement\",\n   353→\t\tType:    domain.StepTypeAgent,\n   354→\t\tResults: []string{\"success\", \"fail\"},\n   355→\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   356→\t}\n   357→\n   358→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   359→\trequire.NoError(t, err)\n   360→\tassert.Equal(t, \"fail\", result)\n   361→}\n   362→\n   363→func TestPromptAdapter_SingleCommandPreservesBehavior(t *testing.T) {\n   364→\tdir := t.TempDir()\n   365→\n   366→\t// Single command, exit 0 — should behave exactly like before\n   367→\tadapter := &prompt.Adapter{\n   368→\t\tCommands:     []string{\"sh\"},\n   369→\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo hello\"},\n   370→\t}\n   371→\n   372→\tstep := &domain.Step{\n   373→\t\tName:    \"implement\",\n   374→\t\tType:    domain.StepTypeAgent,\n   375→\t\tResults: []string{\"success\", \"fail\"},\n   376→\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   377→\t}\n   378→\n   379→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   380→\trequire.NoError(t, err)\n   381→\tassert.Equal(t, \"success\", result)\n   382→}\n   383→\n   384→func TestPromptAdapter_DefaultArgsForClaude(t *testing.T) {\n   385→\t// Verify New() creates an adapter with \"claude\" as the default command\n   386→\tadapter := prompt.New()\n   387→\tassert.Equal(t, []string{\"claude\"}, adapter.Commands)\n   388→\tassert.Nil(t, adapter.ExplicitArgs)\n   389→}\n   390→\n   391→func TestParseCommands(t *testing.T) {\n   392→\ttests := []struct {\n   393→\t\tinput    string\n   394→\t\texpected []string\n   395→\t}{\n   396→\t\t{\"claude\", []string{\"claude\"}},\n   397→\t\t{\"claude,gemini\", []string{\"claude\", \"gemini\"}},\n   398→\t\t{\"claude, gemini, codex\", []string{\"claude\", \"gemini\", \"codex\"}},\n   399→\t\t{\" claude , gemini , codex \", []string{\"claude\", \"gemini\", \"codex\"}},\n   400→\t\t{\"claude,,gemini\", []string{\"claude\", \"gemini\"}},\n   401→\t\t{\"\", nil},\n   402→\t}\n   403→\tfor _, tc := range tests {\n   404→\t\tt.Run(tc.input, func(t *testing.T) {\n   405→\t\t\tresult := prompt.ParseCommands(tc.input)\n   406→\t\t\tassert.Equal(t, tc.expected, result)\n   407→\t\t})\n   408→\t}\n   409→}\n   410→"}]},"parent_tool_use_id":null,"session_id":"530de46c-d426-468f-b8ae-0ef7fcae37b4","uuid":"95e17061-af45-4904-a313-b5674b5280c5","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/agents/prompt/prompt_test.go","content":"package prompt_test\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestPromptAdapter_ExecutesCommand(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Write a user prompt under a run ID\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"test-run\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test-run\", \"prompt.txt\"), []byte(\"add a calculator\"), 0644))\n\n\t// Use a mock command that writes a file to prove it ran\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'implemented' > result.txt && echo ok\"},\n\t\tRunID:        \"test-run\",\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"You are a coding assistant.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Verify the mock command ran\n\tcontent, err := os.ReadFile(filepath.Join(dir, \"result.txt\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"implemented\")\n}\n\nfunc TestPromptAdapter_IncludesFeedback(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Set up feedback logs\n\toutputDir := filepath.Join(dir, \".cloche\", \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"test.log\"), []byte(\"3 failures\"), 0644))\n\n\t// Mock command that captures stdin to a file so we can inspect it\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > captured_prompt.txt && echo ok\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"fix\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\", \"give-up\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Fix the code.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Verify feedback was included in the prompt\n\tcaptured, err := os.ReadFile(filepath.Join(dir, \"captured_prompt.txt\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(captured), \"Fix the code.\")\n\tassert.Contains(t, string(captured), \"3 failures\")\n}\n\nfunc TestPromptAdapter_RespectsMaxAttempts(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Pre-set attempt count to the max\n\tattemptDir := filepath.Join(dir, \".cloche\", \"attempt_count\")\n\trequire.NoError(t, os.MkdirAll(attemptDir, 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(attemptDir, \"fix\"), []byte(\"2\"), 0644))\n\n\t// Command should NOT be called since max is reached\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"exit 1\"}, // would fail if called\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"fix\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"fixed\", \"give-up\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\":       \"Fix the code.\",\n\t\t\t\"max_attempts\": \"2\",\n\t\t},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"give-up\", result)\n}\n\nfunc TestPromptAdapter_CommandFailure(t *testing.T) {\n\tdir := t.TempDir()\n\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"exit 1\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestPromptAdapter_InjectsResultInstructions(t *testing.T) {\n\tdir := t.TempDir()\n\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > captured_prompt.txt && echo ok\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"analyze\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\", \"needs_research\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Analyze the code.\"},\n\t}\n\n\t_, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\n\tcaptured, err := os.ReadFile(filepath.Join(dir, \"captured_prompt.txt\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(captured), \"CLOCHE_RESULT:success\")\n\tassert.Contains(t, string(captured), \"CLOCHE_RESULT:fail\")\n\tassert.Contains(t, string(captured), \"CLOCHE_RESULT:needs_research\")\n}\n\nfunc TestPromptAdapter_StdoutMarkerSelectsResult(t *testing.T) {\n\tdir := t.TempDir()\n\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'CLOCHE_RESULT:needs_research'\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"analyze\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\", \"needs_research\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Analyze the code.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"needs_research\", result)\n}\n\nfunc TestExecuteWritesOutputFile(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"test-run\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"test-run\", \"prompt.txt\"), []byte(\"user request\"), 0644)\n\n\ta := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'agent output'\"},\n\t\tRunID:        \"test-run\",\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Build something\"},\n\t}\n\n\tresult, err := a.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Verify output was written to file\n\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n\tdata, err := os.ReadFile(outputPath)\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"agent output\")\n}\n\nfunc TestPromptAdapter_IncrementsAttemptCount(t *testing.T) {\n\tdir := t.TempDir()\n\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"fix\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"fixed\", \"give-up\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Fix it.\"},\n\t}\n\n\t// Execute twice\n\t_, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\t_, err = adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\n\t// Verify count is 2\n\tcountPath := filepath.Join(dir, \".cloche\", \"attempt_count\", \"fix\")\n\tdata, err := os.ReadFile(countPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"2\", string(data))\n}\n\n// --- Fallback chain tests ---\n\nfunc TestPromptAdapter_FallbackOnCommandNotFound(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// First command doesn't exist, second one does\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"nonexistent-agent-xyz\", \"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo 'fallback ran'\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Verify the fallback command's output was captured\n\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n\tdata, err := os.ReadFile(outputPath)\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"fallback ran\")\n}\n\nfunc TestPromptAdapter_FallbackOnExitErrorNoMarker(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Create two scripts: first exits 1 without marker, second succeeds\n\tfailing := filepath.Join(dir, \"failing-agent.sh\")\n\trequire.NoError(t, os.WriteFile(failing, []byte(\"#!/bin/sh\\ncat > /dev/null\\nexit 1\\n\"), 0755))\n\n\tsucceeding := filepath.Join(dir, \"good-agent.sh\")\n\trequire.NoError(t, os.WriteFile(succeeding, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'good agent output'\\n\"), 0755))\n\n\tadapter := &prompt.Adapter{\n\t\tCommands: []string{failing, succeeding},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Verify the fallback command's output was captured\n\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n\tdata, err := os.ReadFile(outputPath)\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"good agent output\")\n}\n\nfunc TestPromptAdapter_NoFallbackOnMarkerResult(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// First command exits 1 but reports a CLOCHE_RESULT marker — should NOT fall back\n\tfailing := filepath.Join(dir, \"reporting-agent.sh\")\n\trequire.NoError(t, os.WriteFile(failing, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'CLOCHE_RESULT:fail'\\nexit 1\\n\"), 0755))\n\n\tshouldNotRun := filepath.Join(dir, \"should-not-run.sh\")\n\trequire.NoError(t, os.WriteFile(shouldNotRun, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'CLOCHE_RESULT:success'\\n\"), 0755))\n\n\tadapter := &prompt.Adapter{\n\t\tCommands: []string{failing, shouldNotRun},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\t// Should use the first agent's result, not fall back\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestPromptAdapter_AllCommandsFail(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// All commands don't exist\n\tadapter := &prompt.Adapter{\n\t\tCommands: []string{\"nonexistent-agent-1\", \"nonexistent-agent-2\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n\t}\n\n\t_, err := adapter.Execute(context.Background(), step, dir)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"failed to start\")\n}\n\nfunc TestPromptAdapter_LastCommandCrashReturnsFailResult(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Both commands exit non-zero without marker\n\tfailing1 := filepath.Join(dir, \"failing1.sh\")\n\trequire.NoError(t, os.WriteFile(failing1, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'crash1'\\nexit 1\\n\"), 0755))\n\n\tfailing2 := filepath.Join(dir, \"failing2.sh\")\n\trequire.NoError(t, os.WriteFile(failing2, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'crash2'\\nexit 1\\n\"), 0755))\n\n\tadapter := &prompt.Adapter{\n\t\tCommands: []string{failing1, failing2},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestPromptAdapter_SingleCommandPreservesBehavior(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Single command, exit 0 — should behave exactly like before\n\tadapter := &prompt.Adapter{\n\t\tCommands:     []string{\"sh\"},\n\t\tExplicitArgs: []string{\"-c\", \"cat > /dev/null && echo hello\"},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n}\n\nfunc TestPromptAdapter_DefaultArgsForClaude(t *testing.T) {\n\t// Verify New() creates an adapter with \"claude\" as the default command\n\tadapter := prompt.New()\n\tassert.Equal(t, []string{\"claude\"}, adapter.Commands)\n\tassert.Nil(t, adapter.ExplicitArgs)\n}\n\nfunc TestParseCommands(t *testing.T) {\n\ttests := []struct {\n\t\tinput    string\n\t\texpected []string\n\t}{\n\t\t{\"claude\", []string{\"claude\"}},\n\t\t{\"claude,gemini\", []string{\"claude\", \"gemini\"}},\n\t\t{\"claude, gemini, codex\", []string{\"claude\", \"gemini\", \"codex\"}},\n\t\t{\" claude , gemini , codex \", []string{\"claude\", \"gemini\", \"codex\"}},\n\t\t{\"claude,,gemini\", []string{\"claude\", \"gemini\"}},\n\t\t{\"\", nil},\n\t}\n\tfor _, tc := range tests {\n\t\tt.Run(tc.input, func(t *testing.T) {\n\t\t\tresult := prompt.ParseCommands(tc.input)\n\t\t\tassert.Equal(t, tc.expected, result)\n\t\t})\n\t}\n}\n","numLines":410,"startLine":1,"totalLines":410}}}
