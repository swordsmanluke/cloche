{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QmGMu51LFDGfKGQrnBMH1Z","type":"tool_result","content":"     1→package evolution_test\n     2→\n     3→import (\n     4→\t\"path/filepath\"\n     5→\t\"sort\"\n     6→\t\"testing\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    11→\t\"github.com/stretchr/testify/assert\"\n    12→\t\"github.com/stretchr/testify/require\"\n    13→)\n    14→\n    15→func TestEvaluateRun(t *testing.T) {\n    16→\ttests := []struct {\n    17→\t\tname       string\n    18→\t\trun        *domain.Run\n    19→\t\tcandidate  string\n    20→\t\twantSucc   bool\n    21→\t\twantRetry  int\n    22→\t\twantDurPos bool\n    23→\t}{\n    24→\t\t{\n    25→\t\t\tname: \"succeeded run no retries\",\n    26→\t\t\trun: &domain.Run{\n    27→\t\t\t\tID:           \"r1\",\n    28→\t\t\t\tWorkflowName: \"develop\",\n    29→\t\t\t\tState:        domain.RunStateSucceeded,\n    30→\t\t\t\tStartedAt:    time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n    31→\t\t\t\tCompletedAt:  time.Date(2026, 1, 1, 0, 5, 0, 0, time.UTC),\n    32→\t\t\t\tStepExecutions: []*domain.StepExecution{\n    33→\t\t\t\t\t{StepName: \"code\"},\n    34→\t\t\t\t\t{StepName: \"test\"},\n    35→\t\t\t\t},\n    36→\t\t\t},\n    37→\t\t\tcandidate:  \"v1\",\n    38→\t\t\twantSucc:   true,\n    39→\t\t\twantRetry:  0,\n    40→\t\t\twantDurPos: true,\n    41→\t\t},\n    42→\t\t{\n    43→\t\t\tname: \"failed run with retries\",\n    44→\t\t\trun: &domain.Run{\n    45→\t\t\t\tID:           \"r2\",\n    46→\t\t\t\tWorkflowName: \"develop\",\n    47→\t\t\t\tState:        domain.RunStateFailed,\n    48→\t\t\t\tStartedAt:    time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n    49→\t\t\t\tCompletedAt:  time.Date(2026, 1, 1, 0, 10, 0, 0, time.UTC),\n    50→\t\t\t\tStepExecutions: []*domain.StepExecution{\n    51→\t\t\t\t\t{StepName: \"code\"},\n    52→\t\t\t\t\t{StepName: \"test\"},\n    53→\t\t\t\t\t{StepName: \"code\"}, // retry\n    54→\t\t\t\t\t{StepName: \"test\"}, // retry\n    55→\t\t\t\t},\n    56→\t\t\t},\n    57→\t\t\tcandidate:  \"v1\",\n    58→\t\t\twantSucc:   false,\n    59→\t\t\twantRetry:  2,\n    60→\t\t\twantDurPos: true,\n    61→\t\t},\n    62→\t\t{\n    63→\t\t\tname: \"cancelled run zero duration\",\n    64→\t\t\trun: &domain.Run{\n    65→\t\t\t\tID:           \"r3\",\n    66→\t\t\t\tWorkflowName: \"develop\",\n    67→\t\t\t\tState:        domain.RunStateCancelled,\n    68→\t\t\t\tStartedAt:    time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n    69→\t\t\t\tCompletedAt:  time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n    70→\t\t\t},\n    71→\t\t\tcandidate:  \"v2\",\n    72→\t\t\twantSucc:   false,\n    73→\t\t\twantRetry:  0,\n    74→\t\t\twantDurPos: false,\n    75→\t\t},\n    76→\t}\n    77→\n    78→\tfor _, tt := range tests {\n    79→\t\tt.Run(tt.name, func(t *testing.T) {\n    80→\t\t\trec := evolution.EvaluateRun(tt.run, tt.candidate)\n    81→\t\t\tassert.Equal(t, tt.run.ID, rec.RunID)\n    82→\t\t\tassert.Equal(t, tt.candidate, rec.Candidate)\n    83→\t\t\tassert.Equal(t, tt.wantSucc, rec.Success)\n    84→\t\t\tassert.Equal(t, tt.wantRetry, rec.RetryCount)\n    85→\t\t\tif tt.wantDurPos {\n    86→\t\t\t\tassert.Greater(t, rec.Duration, time.Duration(0))\n    87→\t\t\t}\n    88→\t\t})\n    89→\t}\n    90→}\n    91→\n    92→func TestRecordAndLoadFitness(t *testing.T) {\n    93→\tdir := t.TempDir()\n    94→\tpath := filepath.Join(dir, \"fitness.jsonl\")\n    95→\n    96→\t// Load from nonexistent file returns nil\n    97→\trecords, err := evolution.LoadFitness(path)\n    98→\trequire.NoError(t, err)\n    99→\tassert.Nil(t, records)\n   100→\n   101→\t// Write two records\n   102→\tr1 := evolution.FitnessRecord{\n   103→\t\tRunID:     \"r1\",\n   104→\t\tCandidate: \"v1\",\n   105→\t\tSuccess:   true,\n   106→\t\tDuration:  5 * time.Minute,\n   107→\t}\n   108→\tr2 := evolution.FitnessRecord{\n   109→\t\tRunID:      \"r2\",\n   110→\t\tCandidate:  \"v1\",\n   111→\t\tSuccess:    false,\n   112→\t\tRetryCount: 2,\n   113→\t\tDuration:   10 * time.Minute,\n   114→\t}\n   115→\n   116→\trequire.NoError(t, evolution.RecordFitness(path, r1))\n   117→\trequire.NoError(t, evolution.RecordFitness(path, r2))\n   118→\n   119→\trecords, err = evolution.LoadFitness(path)\n   120→\trequire.NoError(t, err)\n   121→\trequire.Len(t, records, 2)\n   122→\tassert.Equal(t, \"r1\", records[0].RunID)\n   123→\tassert.True(t, records[0].Success)\n   124→\tassert.Equal(t, \"r2\", records[1].RunID)\n   125→\tassert.Equal(t, 2, records[1].RetryCount)\n   126→}\n   127→\n   128→func TestAggregateFitness(t *testing.T) {\n   129→\trecords := []evolution.FitnessRecord{\n   130→\t\t{Candidate: \"a\", Success: true, RetryCount: 0, Duration: 60 * time.Second},\n   131→\t\t{Candidate: \"a\", Success: true, RetryCount: 0, Duration: 60 * time.Second},\n   132→\t\t{Candidate: \"b\", Success: true, RetryCount: 0, Duration: 60 * time.Second},\n   133→\t\t{Candidate: \"b\", Success: false, RetryCount: 2, Duration: 120 * time.Second},\n   134→\t}\n   135→\n   136→\tagg := evolution.AggregateFitness(records)\n   137→\tsort.Slice(agg, func(i, j int) bool { return agg[i].Candidate < agg[j].Candidate })\n   138→\n   139→\trequire.Len(t, agg, 2)\n   140→\n   141→\t// Candidate \"a\": 2/2 success, 0 retries, 60s avg → efficiency = 1/(1+0+1) = 0.5\n   142→\tassert.Equal(t, \"a\", agg[0].Candidate)\n   143→\tassert.Equal(t, 1.0, agg[0].SuccessRate)\n   144→\tassert.InDelta(t, 0.5, agg[0].Efficiency, 0.001)\n   145→\tassert.Equal(t, 2, agg[0].RunCount)\n   146→\n   147→\t// Candidate \"b\": 1/2 success, avg retries=1, avg dur=90s → efficiency = 1/(1+1+1.5) = 1/3.5\n   148→\tassert.Equal(t, \"b\", agg[1].Candidate)\n   149→\tassert.Equal(t, 0.5, agg[1].SuccessRate)\n   150→\tassert.InDelta(t, 1.0/3.5, agg[1].Efficiency, 0.001)\n   151→\tassert.Equal(t, 2, agg[1].RunCount)\n   152→}\n   153→\n   154→func TestDominates(t *testing.T) {\n   155→\ttests := []struct {\n   156→\t\tname string\n   157→\t\ta, b evolution.CandidateFitness\n   158→\t\twant bool\n   159→\t}{\n   160→\t\t{\n   161→\t\t\tname: \"a dominates b both better\",\n   162→\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n   163→\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.7, Efficiency: 0.5},\n   164→\t\t\twant: true,\n   165→\t\t},\n   166→\t\t{\n   167→\t\t\tname: \"a dominates b equal success better efficiency\",\n   168→\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n   169→\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.5},\n   170→\t\t\twant: true,\n   171→\t\t},\n   172→\t\t{\n   173→\t\t\tname: \"no domination equal\",\n   174→\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n   175→\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n   176→\t\t\twant: false,\n   177→\t\t},\n   178→\t\t{\n   179→\t\t\tname: \"no domination tradeoff\",\n   180→\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.3},\n   181→\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.7, Efficiency: 0.8},\n   182→\t\t\twant: false,\n   183→\t\t},\n   184→\t\t{\n   185→\t\t\tname: \"b dominates a\",\n   186→\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.5, Efficiency: 0.3},\n   187→\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n   188→\t\t\twant: false,\n   189→\t\t},\n   190→\t}\n   191→\n   192→\tfor _, tt := range tests {\n   193→\t\tt.Run(tt.name, func(t *testing.T) {\n   194→\t\t\tassert.Equal(t, tt.want, evolution.Dominates(tt.a, tt.b))\n   195→\t\t})\n   196→\t}\n   197→}\n   198→\n   199→func TestComputeParetoFront(t *testing.T) {\n   200→\ttests := []struct {\n   201→\t\tname       string\n   202→\t\tcandidates []evolution.CandidateFitness\n   203→\t\twantFront  []string // expected candidate names in front\n   204→\t}{\n   205→\t\t{\n   206→\t\t\tname: \"single candidate is front\",\n   207→\t\t\tcandidates: []evolution.CandidateFitness{\n   208→\t\t\t\t{Candidate: \"a\", SuccessRate: 0.8, Efficiency: 0.5},\n   209→\t\t\t},\n   210→\t\t\twantFront: []string{\"a\"},\n   211→\t\t},\n   212→\t\t{\n   213→\t\t\tname: \"one dominates the other\",\n   214→\t\t\tcandidates: []evolution.CandidateFitness{\n   215→\t\t\t\t{Candidate: \"a\", SuccessRate: 0.9, Efficiency: 0.8},\n   216→\t\t\t\t{Candidate: \"b\", SuccessRate: 0.7, Efficiency: 0.5},\n   217→\t\t\t},\n   218→\t\t\twantFront: []string{\"a\"},\n   219→\t\t},\n   220→\t\t{\n   221→\t\t\tname: \"tradeoff front\",\n   222→\t\t\tcandidates: []evolution.CandidateFitness{\n   223→\t\t\t\t{Candidate: \"fast\", SuccessRate: 0.6, Efficiency: 0.9},\n   224→\t\t\t\t{Candidate: \"reliable\", SuccessRate: 0.95, Efficiency: 0.3},\n   225→\t\t\t\t{Candidate: \"dominated\", SuccessRate: 0.5, Efficiency: 0.2},\n   226→\t\t\t},\n   227→\t\t\twantFront: []string{\"fast\", \"reliable\"},\n   228→\t\t},\n   229→\t\t{\n   230→\t\t\tname: \"all on front\",\n   231→\t\t\tcandidates: []evolution.CandidateFitness{\n   232→\t\t\t\t{Candidate: \"a\", SuccessRate: 1.0, Efficiency: 0.1},\n   233→\t\t\t\t{Candidate: \"b\", SuccessRate: 0.5, Efficiency: 0.5},\n   234→\t\t\t\t{Candidate: \"c\", SuccessRate: 0.1, Efficiency: 1.0},\n   235→\t\t\t},\n   236→\t\t\twantFront: []string{\"a\", \"b\", \"c\"},\n   237→\t\t},\n   238→\t\t{\n   239→\t\t\tname: \"complex front with interior points\",\n   240→\t\t\tcandidates: []evolution.CandidateFitness{\n   241→\t\t\t\t{Candidate: \"p1\", SuccessRate: 1.0, Efficiency: 0.2},\n   242→\t\t\t\t{Candidate: \"p2\", SuccessRate: 0.8, Efficiency: 0.7},\n   243→\t\t\t\t{Candidate: \"p3\", SuccessRate: 0.5, Efficiency: 0.9},\n   244→\t\t\t\t{Candidate: \"d1\", SuccessRate: 0.7, Efficiency: 0.3}, // dominated by p2\n   245→\t\t\t\t{Candidate: \"d2\", SuccessRate: 0.4, Efficiency: 0.5}, // dominated by p2\n   246→\t\t\t\t{Candidate: \"d3\", SuccessRate: 0.3, Efficiency: 0.8}, // dominated by p3\n   247→\t\t\t},\n   248→\t\t\twantFront: []string{\"p1\", \"p2\", \"p3\"},\n   249→\t\t},\n   250→\t\t{\n   251→\t\t\tname:       \"empty input\",\n   252→\t\t\tcandidates: nil,\n   253→\t\t\twantFront:  nil,\n   254→\t\t},\n   255→\t}\n   256→\n   257→\tfor _, tt := range tests {\n   258→\t\tt.Run(tt.name, func(t *testing.T) {\n   259→\t\t\tfront := evolution.ComputeParetoFront(tt.candidates)\n   260→\n   261→\t\t\tvar names []string\n   262→\t\t\tfor _, c := range front {\n   263→\t\t\t\tnames = append(names, c.Candidate)\n   264→\t\t\t}\n   265→\t\t\tsort.Strings(names)\n   266→\n   267→\t\t\tvar expected []string\n   268→\t\t\tif tt.wantFront != nil {\n   269→\t\t\t\texpected = make([]string, len(tt.wantFront))\n   270→\t\t\t\tcopy(expected, tt.wantFront)\n   271→\t\t\t\tsort.Strings(expected)\n   272→\t\t\t}\n   273→\n   274→\t\t\tassert.Equal(t, expected, names)\n   275→\t\t})\n   276→\t}\n   277→}\n   278→\n   279→func TestFitnessPath(t *testing.T) {\n   280→\tgot := evolution.FitnessPath(\"/home/user/project\", \"develop\")\n   281→\tassert.Equal(t, \"/home/user/project/.cloche/evolution/fitness/develop.jsonl\", got)\n   282→}\n   283→"}]},"parent_tool_use_id":null,"session_id":"ee4b9d5f-226b-4cd1-9d2c-3cf327fb6206","uuid":"3c536188-a7cb-4b49-8ce9-8e83ca0b9189","timestamp":"2026-03-18T16:10:56.862Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/fitness_test.go","content":"package evolution_test\n\nimport (\n\t\"path/filepath\"\n\t\"sort\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestEvaluateRun(t *testing.T) {\n\ttests := []struct {\n\t\tname       string\n\t\trun        *domain.Run\n\t\tcandidate  string\n\t\twantSucc   bool\n\t\twantRetry  int\n\t\twantDurPos bool\n\t}{\n\t\t{\n\t\t\tname: \"succeeded run no retries\",\n\t\t\trun: &domain.Run{\n\t\t\t\tID:           \"r1\",\n\t\t\t\tWorkflowName: \"develop\",\n\t\t\t\tState:        domain.RunStateSucceeded,\n\t\t\t\tStartedAt:    time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n\t\t\t\tCompletedAt:  time.Date(2026, 1, 1, 0, 5, 0, 0, time.UTC),\n\t\t\t\tStepExecutions: []*domain.StepExecution{\n\t\t\t\t\t{StepName: \"code\"},\n\t\t\t\t\t{StepName: \"test\"},\n\t\t\t\t},\n\t\t\t},\n\t\t\tcandidate:  \"v1\",\n\t\t\twantSucc:   true,\n\t\t\twantRetry:  0,\n\t\t\twantDurPos: true,\n\t\t},\n\t\t{\n\t\t\tname: \"failed run with retries\",\n\t\t\trun: &domain.Run{\n\t\t\t\tID:           \"r2\",\n\t\t\t\tWorkflowName: \"develop\",\n\t\t\t\tState:        domain.RunStateFailed,\n\t\t\t\tStartedAt:    time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n\t\t\t\tCompletedAt:  time.Date(2026, 1, 1, 0, 10, 0, 0, time.UTC),\n\t\t\t\tStepExecutions: []*domain.StepExecution{\n\t\t\t\t\t{StepName: \"code\"},\n\t\t\t\t\t{StepName: \"test\"},\n\t\t\t\t\t{StepName: \"code\"}, // retry\n\t\t\t\t\t{StepName: \"test\"}, // retry\n\t\t\t\t},\n\t\t\t},\n\t\t\tcandidate:  \"v1\",\n\t\t\twantSucc:   false,\n\t\t\twantRetry:  2,\n\t\t\twantDurPos: true,\n\t\t},\n\t\t{\n\t\t\tname: \"cancelled run zero duration\",\n\t\t\trun: &domain.Run{\n\t\t\t\tID:           \"r3\",\n\t\t\t\tWorkflowName: \"develop\",\n\t\t\t\tState:        domain.RunStateCancelled,\n\t\t\t\tStartedAt:    time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n\t\t\t\tCompletedAt:  time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n\t\t\t},\n\t\t\tcandidate:  \"v2\",\n\t\t\twantSucc:   false,\n\t\t\twantRetry:  0,\n\t\t\twantDurPos: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\trec := evolution.EvaluateRun(tt.run, tt.candidate)\n\t\t\tassert.Equal(t, tt.run.ID, rec.RunID)\n\t\t\tassert.Equal(t, tt.candidate, rec.Candidate)\n\t\t\tassert.Equal(t, tt.wantSucc, rec.Success)\n\t\t\tassert.Equal(t, tt.wantRetry, rec.RetryCount)\n\t\t\tif tt.wantDurPos {\n\t\t\t\tassert.Greater(t, rec.Duration, time.Duration(0))\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestRecordAndLoadFitness(t *testing.T) {\n\tdir := t.TempDir()\n\tpath := filepath.Join(dir, \"fitness.jsonl\")\n\n\t// Load from nonexistent file returns nil\n\trecords, err := evolution.LoadFitness(path)\n\trequire.NoError(t, err)\n\tassert.Nil(t, records)\n\n\t// Write two records\n\tr1 := evolution.FitnessRecord{\n\t\tRunID:     \"r1\",\n\t\tCandidate: \"v1\",\n\t\tSuccess:   true,\n\t\tDuration:  5 * time.Minute,\n\t}\n\tr2 := evolution.FitnessRecord{\n\t\tRunID:      \"r2\",\n\t\tCandidate:  \"v1\",\n\t\tSuccess:    false,\n\t\tRetryCount: 2,\n\t\tDuration:   10 * time.Minute,\n\t}\n\n\trequire.NoError(t, evolution.RecordFitness(path, r1))\n\trequire.NoError(t, evolution.RecordFitness(path, r2))\n\n\trecords, err = evolution.LoadFitness(path)\n\trequire.NoError(t, err)\n\trequire.Len(t, records, 2)\n\tassert.Equal(t, \"r1\", records[0].RunID)\n\tassert.True(t, records[0].Success)\n\tassert.Equal(t, \"r2\", records[1].RunID)\n\tassert.Equal(t, 2, records[1].RetryCount)\n}\n\nfunc TestAggregateFitness(t *testing.T) {\n\trecords := []evolution.FitnessRecord{\n\t\t{Candidate: \"a\", Success: true, RetryCount: 0, Duration: 60 * time.Second},\n\t\t{Candidate: \"a\", Success: true, RetryCount: 0, Duration: 60 * time.Second},\n\t\t{Candidate: \"b\", Success: true, RetryCount: 0, Duration: 60 * time.Second},\n\t\t{Candidate: \"b\", Success: false, RetryCount: 2, Duration: 120 * time.Second},\n\t}\n\n\tagg := evolution.AggregateFitness(records)\n\tsort.Slice(agg, func(i, j int) bool { return agg[i].Candidate < agg[j].Candidate })\n\n\trequire.Len(t, agg, 2)\n\n\t// Candidate \"a\": 2/2 success, 0 retries, 60s avg → efficiency = 1/(1+0+1) = 0.5\n\tassert.Equal(t, \"a\", agg[0].Candidate)\n\tassert.Equal(t, 1.0, agg[0].SuccessRate)\n\tassert.InDelta(t, 0.5, agg[0].Efficiency, 0.001)\n\tassert.Equal(t, 2, agg[0].RunCount)\n\n\t// Candidate \"b\": 1/2 success, avg retries=1, avg dur=90s → efficiency = 1/(1+1+1.5) = 1/3.5\n\tassert.Equal(t, \"b\", agg[1].Candidate)\n\tassert.Equal(t, 0.5, agg[1].SuccessRate)\n\tassert.InDelta(t, 1.0/3.5, agg[1].Efficiency, 0.001)\n\tassert.Equal(t, 2, agg[1].RunCount)\n}\n\nfunc TestDominates(t *testing.T) {\n\ttests := []struct {\n\t\tname string\n\t\ta, b evolution.CandidateFitness\n\t\twant bool\n\t}{\n\t\t{\n\t\t\tname: \"a dominates b both better\",\n\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.7, Efficiency: 0.5},\n\t\t\twant: true,\n\t\t},\n\t\t{\n\t\t\tname: \"a dominates b equal success better efficiency\",\n\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.5},\n\t\t\twant: true,\n\t\t},\n\t\t{\n\t\t\tname: \"no domination equal\",\n\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n\t\t\twant: false,\n\t\t},\n\t\t{\n\t\t\tname: \"no domination tradeoff\",\n\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.3},\n\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.7, Efficiency: 0.8},\n\t\t\twant: false,\n\t\t},\n\t\t{\n\t\t\tname: \"b dominates a\",\n\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.5, Efficiency: 0.3},\n\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n\t\t\twant: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, tt.want, evolution.Dominates(tt.a, tt.b))\n\t\t})\n\t}\n}\n\nfunc TestComputeParetoFront(t *testing.T) {\n\ttests := []struct {\n\t\tname       string\n\t\tcandidates []evolution.CandidateFitness\n\t\twantFront  []string // expected candidate names in front\n\t}{\n\t\t{\n\t\t\tname: \"single candidate is front\",\n\t\t\tcandidates: []evolution.CandidateFitness{\n\t\t\t\t{Candidate: \"a\", SuccessRate: 0.8, Efficiency: 0.5},\n\t\t\t},\n\t\t\twantFront: []string{\"a\"},\n\t\t},\n\t\t{\n\t\t\tname: \"one dominates the other\",\n\t\t\tcandidates: []evolution.CandidateFitness{\n\t\t\t\t{Candidate: \"a\", SuccessRate: 0.9, Efficiency: 0.8},\n\t\t\t\t{Candidate: \"b\", SuccessRate: 0.7, Efficiency: 0.5},\n\t\t\t},\n\t\t\twantFront: []string{\"a\"},\n\t\t},\n\t\t{\n\t\t\tname: \"tradeoff front\",\n\t\t\tcandidates: []evolution.CandidateFitness{\n\t\t\t\t{Candidate: \"fast\", SuccessRate: 0.6, Efficiency: 0.9},\n\t\t\t\t{Candidate: \"reliable\", SuccessRate: 0.95, Efficiency: 0.3},\n\t\t\t\t{Candidate: \"dominated\", SuccessRate: 0.5, Efficiency: 0.2},\n\t\t\t},\n\t\t\twantFront: []string{\"fast\", \"reliable\"},\n\t\t},\n\t\t{\n\t\t\tname: \"all on front\",\n\t\t\tcandidates: []evolution.CandidateFitness{\n\t\t\t\t{Candidate: \"a\", SuccessRate: 1.0, Efficiency: 0.1},\n\t\t\t\t{Candidate: \"b\", SuccessRate: 0.5, Efficiency: 0.5},\n\t\t\t\t{Candidate: \"c\", SuccessRate: 0.1, Efficiency: 1.0},\n\t\t\t},\n\t\t\twantFront: []string{\"a\", \"b\", \"c\"},\n\t\t},\n\t\t{\n\t\t\tname: \"complex front with interior points\",\n\t\t\tcandidates: []evolution.CandidateFitness{\n\t\t\t\t{Candidate: \"p1\", SuccessRate: 1.0, Efficiency: 0.2},\n\t\t\t\t{Candidate: \"p2\", SuccessRate: 0.8, Efficiency: 0.7},\n\t\t\t\t{Candidate: \"p3\", SuccessRate: 0.5, Efficiency: 0.9},\n\t\t\t\t{Candidate: \"d1\", SuccessRate: 0.7, Efficiency: 0.3}, // dominated by p2\n\t\t\t\t{Candidate: \"d2\", SuccessRate: 0.4, Efficiency: 0.5}, // dominated by p2\n\t\t\t\t{Candidate: \"d3\", SuccessRate: 0.3, Efficiency: 0.8}, // dominated by p3\n\t\t\t},\n\t\t\twantFront: []string{\"p1\", \"p2\", \"p3\"},\n\t\t},\n\t\t{\n\t\t\tname:       \"empty input\",\n\t\t\tcandidates: nil,\n\t\t\twantFront:  nil,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tfront := evolution.ComputeParetoFront(tt.candidates)\n\n\t\t\tvar names []string\n\t\t\tfor _, c := range front {\n\t\t\t\tnames = append(names, c.Candidate)\n\t\t\t}\n\t\t\tsort.Strings(names)\n\n\t\t\tvar expected []string\n\t\t\tif tt.wantFront != nil {\n\t\t\t\texpected = make([]string, len(tt.wantFront))\n\t\t\t\tcopy(expected, tt.wantFront)\n\t\t\t\tsort.Strings(expected)\n\t\t\t}\n\n\t\t\tassert.Equal(t, expected, names)\n\t\t})\n\t}\n}\n\nfunc TestFitnessPath(t *testing.T) {\n\tgot := evolution.FitnessPath(\"/home/user/project\", \"develop\")\n\tassert.Equal(t, \"/home/user/project/.cloche/evolution/fitness/develop.jsonl\", got)\n}\n","numLines":283,"startLine":1,"totalLines":283}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Bq5CKABNRehMt8JaMt8T61","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→\t\"testing\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    13→\t\"github.com/stretchr/testify/assert\"\n    14→\t\"github.com/stretchr/testify/require\"\n    15→)\n    16→\n    17→// fakeLLM returns a fixed response for testing.\n    18→type fakeLLM struct {\n    19→\tresponse string\n    20→}\n    21→\n    22→func (f *fakeLLM) Complete(ctx context.Context, system, user string) (string, error) {\n    23→\treturn f.response, nil\n    24→}\n    25→\n    26→// --- Collector tests ---\n    27→\n    28→func TestCollectorGathersData(t *testing.T) {\n    29→\tdir := t.TempDir()\n    30→\n    31→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n    32→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n    33→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.jsonl\"),\n    34→\t\t[]byte(`{\"id\":\"L000\",\"insight\":\"existing lesson\"}`+\"\\n\"), 0644)\n    35→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n    36→\t\t[]byte(\"Write good code\"), 0644)\n    37→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n    38→\t\t[]byte(`workflow \"develop\" {\n    39→  step impl {\n    40→    prompt = file(\".cloche/prompts/implement.md\")\n    41→    results = [success]\n    42→  }\n    43→  impl:success -> done\n    44→}`), 0644)\n    45→\n    46→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n    47→\tdata, err := c.Collect(context.Background(), nil, nil)\n    48→\trequire.NoError(t, err)\n    49→\n    50→\tassert.Contains(t, data.KnowledgeBase, \"existing lesson\")\n    51→\tassert.Contains(t, data.CurrentPrompts, \".cloche/prompts/implement.md\")\n    52→\tassert.Equal(t, \"Write good code\", data.CurrentPrompts[\".cloche/prompts/implement.md\"])\n    53→\tassert.NotEmpty(t, data.CurrentWorkflow)\n    54→\tassert.Equal(t, dir, data.ProjectDir)\n    55→\tassert.Equal(t, \"develop\", data.WorkflowName)\n    56→}\n    57→\n    58→func TestCollectorNoKnowledgeBase(t *testing.T) {\n    59→\tdir := t.TempDir()\n    60→\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n    61→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n    62→\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n    63→\n    64→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n    65→\tdata, err := c.Collect(context.Background(), nil, nil)\n    66→\trequire.NoError(t, err)\n    67→\tassert.Empty(t, data.KnowledgeBase)\n    68→}\n    69→\n    70→func TestExtractPromptFiles(t *testing.T) {\n    71→\tworkflow := `step impl { prompt = file(\".cloche/prompts/implement.md\") }\n    72→step fix { prompt = file(\".cloche/prompts/fix.md\") }\n    73→step test { run = \"make test\" }`\n    74→\n    75→\tfiles := extractPromptFiles(workflow)\n    76→\tassert.Len(t, files, 2)\n    77→\tassert.Contains(t, files, \".cloche/prompts/implement.md\")\n    78→\tassert.Contains(t, files, \".cloche/prompts/fix.md\")\n    79→}\n    80→\n    81→// --- Classifier tests ---\n    82→\n    83→func TestClassifierCategorizesRun(t *testing.T) {\n    84→\ttests := []struct {\n    85→\t\tname     string\n    86→\t\tresponse string\n    87→\t\texpected string\n    88→\t}{\n    89→\t\t{\"bug\", `{\"classification\": \"bug\"}`, \"bug\"},\n    90→\t\t{\"feature\", `{\"classification\": \"feature\"}`, \"feature\"},\n    91→\t\t{\"feedback\", `{\"classification\": \"feedback\"}`, \"feedback\"},\n    92→\t\t{\"enhancement\", `{\"classification\": \"enhancement\"}`, \"enhancement\"},\n    93→\t\t{\"chore\", `{\"classification\": \"chore\"}`, \"chore\"},\n    94→\t\t{\"invalid defaults to feature\", `{\"classification\": \"unknown\"}`, \"feature\"},\n    95→\t\t{\"malformed JSON defaults to feature\", `not json`, \"feature\"},\n    96→\t}\n    97→\n    98→\tfor _, tt := range tests {\n    99→\t\tt.Run(tt.name, func(t *testing.T) {\n   100→\t\t\tllm := &fakeLLM{response: tt.response}\n   101→\t\t\tc := &Classifier{LLM: llm}\n   102→\t\t\tresult, err := c.Classify(context.Background(), \"some prompt\")\n   103→\t\t\trequire.NoError(t, err)\n   104→\t\t\tassert.Equal(t, tt.expected, result)\n   105→\t\t})\n   106→\t}\n   107→}\n   108→\n   109→// --- Reflector tests ---\n   110→\n   111→func TestReflectorExtractsLessons(t *testing.T) {\n   112→\tlessonsJSON, _ := json.Marshal(map[string]any{\n   113→\t\t\"lessons\": []map[string]any{\n   114→\t\t\t{\n   115→\t\t\t\t\"id\":               \"lesson-001\",\n   116→\t\t\t\t\"category\":         \"prompt_improvement\",\n   117→\t\t\t\t\"target\":           \".cloche/prompts/implement.md\",\n   118→\t\t\t\t\"insight\":          \"Agent produces unsanitized HTML\",\n   119→\t\t\t\t\"suggested_action\": \"Add sanitization rule\",\n   120→\t\t\t\t\"evidence\":         []string{\"run-1\", \"run-2\"},\n   121→\t\t\t\t\"confidence\":       \"high\",\n   122→\t\t\t},\n   123→\t\t},\n   124→\t})\n   125→\n   126→\tllm := &fakeLLM{response: string(lessonsJSON)}\n   127→\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n   128→\n   129→\tdata := &CollectedData{WorkflowName: \"develop\", KnowledgeBase: \"# KB\\n\"}\n   130→\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n   131→\trequire.NoError(t, err)\n   132→\trequire.Len(t, lessons, 1)\n   133→\tassert.Equal(t, \"prompt_improvement\", lessons[0].Category)\n   134→\tassert.Equal(t, \"high\", lessons[0].Confidence)\n   135→}\n   136→\n   137→func TestReflectorFiltersLowConfidence(t *testing.T) {\n   138→\tlessonsJSON, _ := json.Marshal(map[string]any{\n   139→\t\t\"lessons\": []map[string]any{\n   140→\t\t\t{\"id\": \"L1\", \"category\": \"new_step\", \"confidence\": \"low\"},\n   141→\t\t\t{\"id\": \"L2\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n   142→\t\t},\n   143→\t})\n   144→\n   145→\tllm := &fakeLLM{response: string(lessonsJSON)}\n   146→\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n   147→\n   148→\tlessons, err := r.Reflect(context.Background(), &CollectedData{}, \"bug\")\n   149→\trequire.NoError(t, err)\n   150→\tassert.Len(t, lessons, 1)\n   151→\tassert.Equal(t, \"L2\", lessons[0].ID)\n   152→}\n   153→\n   154→func TestConfidenceLevel(t *testing.T) {\n   155→\tassert.Equal(t, 3, confidenceLevel(\"high\"))\n   156→\tassert.Equal(t, 2, confidenceLevel(\"medium\"))\n   157→\tassert.Equal(t, 1, confidenceLevel(\"low\"))\n   158→\tassert.Equal(t, 0, confidenceLevel(\"\"))\n   159→}\n   160→\n   161→// --- Audit Logger tests ---\n   162→\n   163→func TestAuditLoggerAppendsJSONL(t *testing.T) {\n   164→\tdir := t.TempDir()\n   165→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\"), 0755)\n   166→\n   167→\tlogger := &AuditLogger{ProjectDir: dir}\n   168→\n   169→\tresult1 := &EvolutionResult{\n   170→\t\tID:           \"evo-1\",\n   171→\t\tWorkflowName: \"develop\",\n   172→\t\tChanges:      []Change{{Type: \"prompt_update\", File: \".cloche/prompts/impl.md\"}},\n   173→\t}\n   174→\trequire.NoError(t, logger.Log(result1))\n   175→\n   176→\tresult2 := &EvolutionResult{\n   177→\t\tID:           \"evo-2\",\n   178→\t\tWorkflowName: \"develop\",\n   179→\t\tChanges:      []Change{{Type: \"add_step\", File: \".cloche/develop.cloche\"}},\n   180→\t}\n   181→\trequire.NoError(t, logger.Log(result2))\n   182→\n   183→\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n   184→\trequire.NoError(t, err)\n   185→\n   186→\tlines := strings.Split(strings.TrimSpace(string(content)), \"\\n\")\n   187→\tassert.Len(t, lines, 2)\n   188→\n   189→\tvar entry1 EvolutionResult\n   190→\trequire.NoError(t, json.Unmarshal([]byte(lines[0]), &entry1))\n   191→\tassert.Equal(t, \"evo-1\", entry1.ID)\n   192→}\n   193→\n   194→func TestAuditLoggerSnapshot(t *testing.T) {\n   195→\tdir := t.TempDir()\n   196→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   197→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   198→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"original content\"), 0644)\n   199→\n   200→\tlogger := &AuditLogger{ProjectDir: dir}\n   201→\tsnapName, err := logger.Snapshot(\".cloche/prompts/implement.md\")\n   202→\trequire.NoError(t, err)\n   203→\tassert.NotEmpty(t, snapName)\n   204→\n   205→\tsnapPath := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\", snapName)\n   206→\tcontent, err := os.ReadFile(snapPath)\n   207→\trequire.NoError(t, err)\n   208→\tassert.Equal(t, \"original content\", string(content))\n   209→}\n   210→\n   211→func TestAuditLoggerUpdatesKnowledge(t *testing.T) {\n   212→\tdir := t.TempDir()\n   213→\tkbDir := filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\")\n   214→\tos.MkdirAll(kbDir, 0755)\n   215→\n   216→\tlogger := &AuditLogger{ProjectDir: dir}\n   217→\tlessons := []Lesson{\n   218→\t\t{\n   219→\t\t\tID:              \"P001\",\n   220→\t\t\tCategory:        \"prompt_improvement\",\n   221→\t\t\tConfidence:      \"high\",\n   222→\t\t\tInsight:         \"Always sanitize HTML inputs\",\n   223→\t\t\tSuggestedAction: \"Add rule to implement prompt\",\n   224→\t\t\tEvidence:        []string{\"run-1\", \"run-2\"},\n   225→\t\t},\n   226→\t}\n   227→\n   228→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", lessons))\n   229→\n   230→\tcontent, err := os.ReadFile(filepath.Join(kbDir, \"develop.jsonl\"))\n   231→\trequire.NoError(t, err)\n   232→\tassert.Contains(t, string(content), \"P001\")\n   233→\tassert.Contains(t, string(content), \"sanitize HTML\")\n   234→\tassert.Contains(t, string(content), \"run-1\")\n   235→}\n   236→\n   237→func TestAuditLoggerDeduplicatesLessons(t *testing.T) {\n   238→\tdir := t.TempDir()\n   239→\tlogger := &AuditLogger{ProjectDir: dir}\n   240→\n   241→\tlesson := Lesson{\n   242→\t\tID:       \"L001\",\n   243→\t\tCategory: \"prompt_improvement\",\n   244→\t\tInsight:  \"Original insight\",\n   245→\t}\n   246→\n   247→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{lesson}))\n   248→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{lesson}))\n   249→\n   250→\t// Read back and verify only one entry\n   251→\tlessons, err := readKnowledge(logger.KnowledgePath(\"develop\"))\n   252→\trequire.NoError(t, err)\n   253→\tassert.Len(t, lessons, 1)\n   254→\tassert.Equal(t, \"L001\", lessons[0].ID)\n   255→}\n   256→\n   257→func TestAuditLoggerUpdatesExistingLesson(t *testing.T) {\n   258→\tdir := t.TempDir()\n   259→\tlogger := &AuditLogger{ProjectDir: dir}\n   260→\n   261→\toriginal := Lesson{ID: \"L001\", Insight: \"Original insight\"}\n   262→\tupdated := Lesson{ID: \"L001\", Insight: \"Updated insight\"}\n   263→\n   264→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{original}))\n   265→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{updated}))\n   266→\n   267→\tlessons, err := readKnowledge(logger.KnowledgePath(\"develop\"))\n   268→\trequire.NoError(t, err)\n   269→\tassert.Len(t, lessons, 1)\n   270→\tassert.Equal(t, \"Updated insight\", lessons[0].Insight)\n   271→}\n   272→\n   273→func TestAuditLoggerPrunesWithMaxPromptBullets(t *testing.T) {\n   274→\tdir := t.TempDir()\n   275→\tlogger := &AuditLogger{ProjectDir: dir, MaxPromptBullets: 5}\n   276→\n   277→\t// Add 10 lessons\n   278→\tfor i := 0; i < 10; i++ {\n   279→\t\tlesson := Lesson{\n   280→\t\t\tID:      fmt.Sprintf(\"L%03d\", i),\n   281→\t\t\tInsight: fmt.Sprintf(\"Insight %d\", i),\n   282→\t\t}\n   283→\t\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{lesson}))\n   284→\t}\n   285→\n   286→\tlessons, err := readKnowledge(logger.KnowledgePath(\"develop\"))\n   287→\trequire.NoError(t, err)\n   288→\tassert.Len(t, lessons, 5)\n   289→\t// Should keep the most recent 5 (L005-L009)\n   290→\tassert.Equal(t, \"L005\", lessons[0].ID)\n   291→\tassert.Equal(t, \"L009\", lessons[4].ID)\n   292→}\n   293→\n   294→// --- LLM Client tests ---\n   295→\n   296→// --- Curator tests ---\n   297→\n   298→func TestCuratorUpdatesPrompt(t *testing.T) {\n   299→\tdir := t.TempDir()\n   300→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   301→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   302→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   303→\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   304→\n   305→\tupdatedContent := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"\n   306→\tllm := &fakeLLM{response: updatedContent}\n   307→\n   308→\taudit := &AuditLogger{ProjectDir: dir}\n   309→\tc := &Curator{LLM: llm, Audit: audit}\n   310→\tlesson := &Lesson{\n   311→\t\tID:              \"lesson-001\",\n   312→\t\tCategory:        \"prompt_improvement\",\n   313→\t\tTarget:          \".cloche/prompts/implement.md\",\n   314→\t\tInsight:         \"XSS vulnerabilities in form handlers\",\n   315→\t\tSuggestedAction: \"Add sanitization rule\",\n   316→\t}\n   317→\n   318→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   319→\trequire.NoError(t, err)\n   320→\tassert.Equal(t, \"prompt_update\", change.Type)\n   321→\tassert.Equal(t, \".cloche/prompts/implement.md\", change.File)\n   322→\tassert.NotEmpty(t, change.Snapshot)\n   323→\n   324→\tcontent, err := os.ReadFile(promptPath)\n   325→\trequire.NoError(t, err)\n   326→\tassert.Contains(t, string(content), \"sanitize user inputs\")\n   327→}\n   328→\n   329→// --- stripCodeFences tests ---\n   330→\n   331→func TestStripCodeFences(t *testing.T) {\n   332→\ttests := []struct {\n   333→\t\tname     string\n   334→\t\tinput    string\n   335→\t\texpected string\n   336→\t}{\n   337→\t\t{\n   338→\t\t\tname:     \"no fences returns as-is\",\n   339→\t\t\tinput:    \"# Prompt\\n\\nDo good work.\\n\",\n   340→\t\t\texpected: \"# Prompt\\n\\nDo good work.\",\n   341→\t\t},\n   342→\t\t{\n   343→\t\t\tname:     \"plain code fence\",\n   344→\t\t\tinput:    \"```\\n# Prompt\\n\\nDo good work.\\n```\",\n   345→\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   346→\t\t},\n   347→\t\t{\n   348→\t\t\tname:     \"code fence with language hint\",\n   349→\t\t\tinput:    \"```markdown\\n# Prompt\\n\\nDo good work.\\n```\",\n   350→\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   351→\t\t},\n   352→\t\t{\n   353→\t\t\tname:     \"commentary before and after fence\",\n   354→\t\t\tinput:    \"Here's the updated prompt:\\n\\n```markdown\\n# Prompt\\n\\nDo good work.\\n```\\n\\nI've added the rule as requested.\",\n   355→\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   356→\t\t},\n   357→\t\t{\n   358→\t\t\tname:     \"no closing fence returns as-is\",\n   359→\t\t\tinput:    \"```markdown\\n# Prompt\\n\",\n   360→\t\t\texpected: \"```markdown\\n# Prompt\",\n   361→\t\t},\n   362→\t}\n   363→\n   364→\tfor _, tt := range tests {\n   365→\t\tt.Run(tt.name, func(t *testing.T) {\n   366→\t\t\tassert.Equal(t, tt.expected, stripCodeFences(tt.input))\n   367→\t\t})\n   368→\t}\n   369→}\n   370→\n   371→func TestCuratorStripsCodeFencesFromResponse(t *testing.T) {\n   372→\tdir := t.TempDir()\n   373→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   374→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   375→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   376→\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   377→\n   378→\t// LLM returns content wrapped in code fences with commentary\n   379→\tfencedResponse := \"Here is the updated prompt:\\n\\n```markdown\\n# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n```\\n\\nI added the validation rule.\"\n   380→\tllm := &fakeLLM{response: fencedResponse}\n   381→\n   382→\taudit := &AuditLogger{ProjectDir: dir}\n   383→\tc := &Curator{LLM: llm, Audit: audit}\n   384→\tlesson := &Lesson{\n   385→\t\tTarget:          \".cloche/prompts/implement.md\",\n   386→\t\tInsight:         \"Missing input validation\",\n   387→\t\tSuggestedAction: \"Add validation rule\",\n   388→\t}\n   389→\n   390→\t_, err := c.Apply(context.Background(), dir, lesson)\n   391→\trequire.NoError(t, err)\n   392→\n   393→\tcontent, err := os.ReadFile(promptPath)\n   394→\trequire.NoError(t, err)\n   395→\n   396→\t// Should contain the actual prompt content, not the commentary\n   397→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   398→\tassert.Contains(t, string(content), \"Always validate inputs\")\n   399→\tassert.NotContains(t, string(content), \"Here is the updated prompt\")\n   400→\tassert.NotContains(t, string(content), \"I added the validation rule\")\n   401→\tassert.NotContains(t, string(content), \"```\")\n   402→}\n   403→\n   404→func TestCuratorRejectsConversationalMetaText(t *testing.T) {\n   405→\tdir := t.TempDir()\n   406→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"fix.md\")\n   407→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   408→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   409→\toriginal := \"# Fix Prompt\\n\\nFix bugs carefully.\\n\"\n   410→\tos.WriteFile(promptPath, []byte(original), 0644)\n   411→\n   412→\t// LLM returns conversational meta-text\n   413→\tllm := &fakeLLM{response: \"I need write permission to update the file. Could you grant access to .cloche/prompts/fix.md?\"}\n   414→\taudit := &AuditLogger{ProjectDir: dir}\n   415→\tc := &Curator{LLM: llm, Audit: audit}\n   416→\tlesson := &Lesson{\n   417→\t\tTarget:          \".cloche/prompts/fix.md\",\n   418→\t\tInsight:         \"Missing error context\",\n   419→\t\tSuggestedAction: \"Wrap errors with context\",\n   420→\t}\n   421→\n   422→\t_, err := c.Apply(context.Background(), dir, lesson)\n   423→\trequire.NoError(t, err)\n   424→\n   425→\tcontent, err := os.ReadFile(promptPath)\n   426→\trequire.NoError(t, err)\n   427→\t// Must NOT contain the conversational text\n   428→\tassert.NotContains(t, string(content), \"I need write permission\")\n   429→\tassert.NotContains(t, string(content), \"Could you grant access\")\n   430→\t// Should contain the original content and the lesson appended directly\n   431→\tassert.Contains(t, string(content), \"# Fix Prompt\")\n   432→\tassert.Contains(t, string(content), \"Missing error context\")\n   433→}\n   434→\n   435→func TestCuratorRejectsUnfencedConversationalPrefix(t *testing.T) {\n   436→\tdir := t.TempDir()\n   437→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   438→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   439→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   440→\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n   441→\tos.WriteFile(promptPath, []byte(original), 0644)\n   442→\n   443→\t// LLM returns \"Here is the updated prompt:\" with NO code fences\n   444→\tllm := &fakeLLM{response: \"Here is the updated prompt:\\n\\n# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Validate inputs\\n\"}\n   445→\taudit := &AuditLogger{ProjectDir: dir}\n   446→\tc := &Curator{LLM: llm, Audit: audit}\n   447→\tlesson := &Lesson{\n   448→\t\tTarget:          \".cloche/prompts/implement.md\",\n   449→\t\tInsight:         \"Missing validation\",\n   450→\t\tSuggestedAction: \"Add input validation\",\n   451→\t}\n   452→\n   453→\t_, err := c.Apply(context.Background(), dir, lesson)\n   454→\trequire.NoError(t, err)\n   455→\n   456→\tcontent, err := os.ReadFile(promptPath)\n   457→\trequire.NoError(t, err)\n   458→\t// The conversational prefix must not appear\n   459→\tassert.NotContains(t, string(content), \"Here is the updated prompt\")\n   460→\t// Original content preserved, lesson appended via fallback\n   461→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   462→\tassert.Contains(t, string(content), \"Missing validation\")\n   463→}\n   464→\n   465→func TestCuratorAcceptsValidPromptWithoutFences(t *testing.T) {\n   466→\tdir := t.TempDir()\n   467→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   468→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   469→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   470→\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   471→\n   472→\t// LLM returns valid prompt content without code fences\n   473→\tvalidResponse := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n\"\n   474→\tllm := &fakeLLM{response: validResponse}\n   475→\taudit := &AuditLogger{ProjectDir: dir}\n   476→\tc := &Curator{LLM: llm, Audit: audit}\n   477→\tlesson := &Lesson{\n   478→\t\tTarget:          \".cloche/prompts/implement.md\",\n   479→\t\tInsight:         \"Missing validation\",\n   480→\t\tSuggestedAction: \"Add validation rule\",\n   481→\t}\n   482→\n   483→\t_, err := c.Apply(context.Background(), dir, lesson)\n   484→\trequire.NoError(t, err)\n   485→\n   486→\tcontent, err := os.ReadFile(promptPath)\n   487→\trequire.NoError(t, err)\n   488→\t// Should write the LLM response (after stripCodeFences trimming) since it's valid prompt content\n   489→\tassert.Contains(t, string(content), \"Always validate inputs\")\n   490→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   491→\tassert.NotContains(t, string(content), \"Missing validation\")\n   492→}\n   493→\n   494→func TestIsConversationalResponse(t *testing.T) {\n   495→\ttests := []struct {\n   496→\t\tname     string\n   497→\t\tinput    string\n   498→\t\texpected bool\n   499→\t}{\n   500→\t\t{\"permission request\", \"I need write permission to update the file\", true},\n   501→\t\t{\"grant request\", \"Could you grant access to the file?\", true},\n   502→\t\t{\"blocked message\", \"Permission blocked by sandbox\", true},\n   503→\t\t{\"here is updated\", \"Here is the updated prompt:\\n\\n# Prompt\", true},\n   504→\t\t{\"heres updated\", \"Here's the updated prompt:\\n\\n# Prompt\", true},\n   505→\t\t{\"ive updated\", \"I've updated the prompt with the new rule\", true},\n   506→\t\t{\"let me\", \"Let me update the file for you\", true},\n   507→\t\t{\"valid markdown heading\", \"# Prompt\\n\\nDo good work.\", false},\n   508→\t\t{\"valid bullet list\", \"- Rule one\\n- Rule two\", false},\n   509→\t\t{\"empty string\", \"\", true},\n   510→\t\t{\"valid content no heading\", \"Write good code and test everything.\", false},\n   511→\t}\n   512→\n   513→\tfor _, tt := range tests {\n   514→\t\tt.Run(tt.name, func(t *testing.T) {\n   515→\t\t\tassert.Equal(t, tt.expected, isConversationalResponse(tt.input))\n   516→\t\t})\n   517→\t}\n   518→}\n   519→\n   520→func TestAppendLessonDirectly(t *testing.T) {\n   521→\tt.Run(\"creates learned rules section\", func(t *testing.T) {\n   522→\t\tresult := appendLessonDirectly(\"# Prompt\\n\\nDo good work.\\n\", &Lesson{\n   523→\t\t\tInsight:         \"Missing validation\",\n   524→\t\t\tSuggestedAction: \"Add validation\",\n   525→\t\t})\n   526→\t\tassert.Contains(t, result, \"## Learned Rules\")\n   527→\t\tassert.Contains(t, result, \"Missing validation: Add validation\")\n   528→\t})\n   529→\n   530→\tt.Run(\"appends to existing learned rules\", func(t *testing.T) {\n   531→\t\texisting := \"# Prompt\\n\\n## Learned Rules\\n\\n- Existing rule\\n\"\n   532→\t\tresult := appendLessonDirectly(existing, &Lesson{\n   533→\t\t\tInsight:         \"New insight\",\n   534→\t\t\tSuggestedAction: \"New action\",\n   535→\t\t})\n   536→\t\tassert.Contains(t, result, \"- Existing rule\")\n   537→\t\tassert.Contains(t, result, \"- New insight: New action\")\n   538→\t\t// Should not create a duplicate section\n   539→\t\tassert.Equal(t, 1, strings.Count(result, \"## Learned Rules\"))\n   540→\t})\n   541→}\n   542→\n   543→// --- Script Generator tests ---\n   544→\n   545→func TestScriptGeneratorCreatesScript(t *testing.T) {\n   546→\tdir := t.TempDir()\n   547→\n   548→\tllm := &fakeLLM{response: `{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`}\n   549→\tg := &ScriptGenerator{LLM: llm}\n   550→\n   551→\tlesson := &Lesson{\n   552→\t\tID:              \"lesson-001\",\n   553→\t\tCategory:        \"new_step\",\n   554→\t\tStepType:        \"script\",\n   555→\t\tInsight:         \"No security scanning\",\n   556→\t\tSuggestedAction: \"Add gosec security scan\",\n   557→\t}\n   558→\n   559→\tresult, err := g.Generate(context.Background(), dir, lesson)\n   560→\trequire.NoError(t, err)\n   561→\tassert.Equal(t, \"scripts/security-scan.sh\", result.Path)\n   562→\n   563→\tcontent, err := os.ReadFile(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n   564→\trequire.NoError(t, err)\n   565→\tassert.Contains(t, string(content), \"gosec\")\n   566→\n   567→\tinfo, err := os.Stat(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n   568→\trequire.NoError(t, err)\n   569→\tassert.Zero(t, info.Mode()&0111) // non-executable; workflow engine handles execution\n   570→}\n   571→\n   572→// --- LLM Client tests ---\n   573→\n   574→func TestCommandLLMClientPrintMode(t *testing.T) {\n   575→\t// Use a shell script that dumps its args and stdin so we can verify\n   576→\t// that the client passes the right flags and prompt separation.\n   577→\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   578→\tos.WriteFile(script, []byte(`#!/bin/sh\n   579→echo \"ARGS:$*\"\n   580→echo \"STDIN:$(cat)\"\n   581→`), 0755)\n   582→\n   583→\tc := &CommandLLMClient{Command: script, Args: []string{}}\n   584→\tresult, err := c.Complete(context.Background(), \"You are a helpful assistant.\", \"Summarize this text\")\n   585→\trequire.NoError(t, err)\n   586→\n   587→\t// Should include -p flag for print/non-interactive mode\n   588→\tassert.Contains(t, result, \"-p\")\n   589→\n   590→\t// Should pass system prompt via --system-prompt flag\n   591→\tassert.Contains(t, result, \"--system-prompt\")\n   592→\tassert.Contains(t, result, \"You are a helpful assistant.\")\n   593→\n   594→\t// Should pass --output-format text\n   595→\tassert.Contains(t, result, \"--output-format text\")\n   596→\n   597→\t// Stdin should contain only the user prompt, not the system prompt\n   598→\tassert.Contains(t, result, \"STDIN:Summarize this text\")\n   599→\tassert.NotContains(t, result, \"STDIN:You are a helpful assistant\")\n   600→}\n   601→\n   602→func TestCommandLLMClientEmptySystemPrompt(t *testing.T) {\n   603→\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   604→\tos.WriteFile(script, []byte(`#!/bin/sh\n   605→echo \"ARGS:$*\"\n   606→echo \"STDIN:$(cat)\"\n   607→`), 0755)\n   608→\n   609→\tc := &CommandLLMClient{Command: script, Args: []string{}}\n   610→\tresult, err := c.Complete(context.Background(), \"\", \"just user prompt\")\n   611→\trequire.NoError(t, err)\n   612→\n   613→\t// Should NOT include --system-prompt when system prompt is empty\n   614→\tassert.NotContains(t, result, \"--system-prompt\")\n   615→\t// Should still have -p and --output-format\n   616→\tassert.Contains(t, result, \"-p\")\n   617→\tassert.Contains(t, result, \"--output-format text\")\n   618→\tassert.Contains(t, result, \"STDIN:just user prompt\")\n   619→}\n   620→\n   621→func TestCommandLLMClientExtraArgs(t *testing.T) {\n   622→\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   623→\tos.WriteFile(script, []byte(`#!/bin/sh\n   624→echo \"ARGS:$*\"\n   625→echo \"STDIN:$(cat)\"\n   626→`), 0755)\n   627→\n   628→\tc := &CommandLLMClient{Command: script, Args: []string{\"--model\", \"sonnet\"}}\n   629→\tresult, err := c.Complete(context.Background(), \"sys\", \"usr\")\n   630→\trequire.NoError(t, err)\n   631→\n   632→\t// Extra args should appear before the appended flags\n   633→\tassert.Contains(t, result, \"--model sonnet\")\n   634→\tassert.Contains(t, result, \"-p\")\n   635→}\n   636→\n   637→func TestCommandLLMClientDoesNotMutateArgs(t *testing.T) {\n   638→\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   639→\tos.WriteFile(script, []byte(\"#!/bin/sh\\ncat\\n\"), 0755)\n   640→\n   641→\toriginal := []string{\"--verbose\"}\n   642→\tc := &CommandLLMClient{Command: script, Args: original}\n   643→\t_, err := c.Complete(context.Background(), \"sys\", \"usr\")\n   644→\trequire.NoError(t, err)\n   645→\n   646→\t// The original Args slice should not be modified between calls.\n   647→\tassert.Equal(t, []string{\"--verbose\"}, original)\n   648→}\n   649→\n   650→// --- Orchestrator tests ---\n   651→\n   652→// scriptedLLM returns responses in order.\n   653→type scriptedLLM struct {\n   654→\tresponses []string\n   655→\tidx       int\n   656→}\n   657→\n   658→func (s *scriptedLLM) Complete(ctx context.Context, system, user string) (string, error) {\n   659→\tresp := s.responses[s.idx]\n   660→\ts.idx++\n   661→\treturn resp, nil\n   662→}\n   663→\n   664→func TestOrchestratorEndToEnd(t *testing.T) {\n   665→\tdir := t.TempDir()\n   666→\n   667→\t// Set up project structure\n   668→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   669→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   670→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   671→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n   672→\t\t[]byte(\"Write good code.\\n\"), 0644)\n   673→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   674→\t\t[]byte(`workflow \"develop\" {\n   675→  step implement {\n   676→    prompt = file(\".cloche/prompts/implement.md\")\n   677→    results = [success, fail]\n   678→  }\n   679→  step test {\n   680→    run = \"make test\"\n   681→    results = [success, fail]\n   682→  }\n   683→  implement:success -> test\n   684→  test:success -> done\n   685→  test:fail -> abort\n   686→}`), 0644)\n   687→\n   688→\t// Fake LLM that returns appropriate responses per stage\n   689→\tllm := &scriptedLLM{\n   690→\t\tresponses: []string{\n   691→\t\t\t// Classifier\n   692→\t\t\t`{\"classification\": \"bug\"}`,\n   693→\t\t\t// Reflector\n   694→\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n   695→\t\t\t// Curator\n   696→\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n   697→\t\t},\n   698→\t}\n   699→\n   700→\torch := NewOrchestrator(OrchestratorConfig{\n   701→\t\tProjectDir:    dir,\n   702→\t\tWorkflowName:  \"develop\",\n   703→\t\tLLM:           llm,\n   704→\t\tMinConfidence: \"medium\",\n   705→\t})\n   706→\n   707→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   708→\trequire.NoError(t, err)\n   709→\tassert.Equal(t, \"bug\", result.Classification)\n   710→\trequire.Len(t, result.Changes, 1)\n   711→\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n   712→\n   713→\t// Verify prompt was actually updated\n   714→\tcontent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n   715→\tassert.Contains(t, string(content), \"sanitize user inputs\")\n   716→\n   717→\t// Verify audit log was written\n   718→\tlogContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n   719→\tassert.Contains(t, string(logContent), \"prompt_update\")\n   720→\tassert.Contains(t, string(logContent), \"XSS pattern\")\n   721→\n   722→\t// Verify knowledge base was updated (JSONL format)\n   723→\tkbContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.jsonl\"))\n   724→\tassert.Contains(t, string(kbContent), \"L001\")\n   725→}\n   726→\n   727→func TestOrchestratorNewStepWiredIntoGraph(t *testing.T) {\n   728→\tdir := t.TempDir()\n   729→\n   730→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   731→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   732→\t// Knowledge base uses JSONL format (created automatically by UpdateKnowledge)\n   733→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   734→\t\t[]byte(`workflow \"develop\" {\n   735→  step implement {\n   736→    prompt = file(\".cloche/prompts/implement.md\")\n   737→    results = [success, fail]\n   738→  }\n   739→  step test {\n   740→    run = \"make test\"\n   741→    results = [success, fail]\n   742→  }\n   743→  implement:success -> test\n   744→  implement:fail -> abort\n   745→  test:success -> done\n   746→  test:fail -> abort\n   747→}`), 0644)\n   748→\n   749→\tllm := &scriptedLLM{\n   750→\t\tresponses: []string{\n   751→\t\t\t// Classifier\n   752→\t\t\t`{\"classification\": \"enhancement\"}`,\n   753→\t\t\t// Reflector\n   754→\t\t\t`{\"lessons\": [{\"id\": \"L002\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"No security scanning\", \"suggested_action\": \"Add gosec scan\", \"evidence\": [\"run-2\"], \"confidence\": \"high\"}]}`,\n   755→\t\t\t// ScriptGenerator\n   756→\t\t\t`{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`,\n   757→\t\t},\n   758→\t}\n   759→\n   760→\torch := NewOrchestrator(OrchestratorConfig{\n   761→\t\tProjectDir:    dir,\n   762→\t\tWorkflowName:  \"develop\",\n   763→\t\tLLM:           llm,\n   764→\t\tMinConfidence: \"medium\",\n   765→\t})\n   766→\n   767→\tresult, err := orch.Run(context.Background(), \"run-2\", nil, nil)\n   768→\trequire.NoError(t, err)\n   769→\trequire.Len(t, result.Changes, 2) // add_script + add_step\n   770→\tassert.Equal(t, \"add_script\", result.Changes[0].Type)\n   771→\tassert.Equal(t, \"add_step\", result.Changes[1].Type)\n   772→\n   773→\t// Read the updated workflow and verify the new step is reachable\n   774→\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   775→\trequire.NoError(t, err)\n   776→\n   777→\twfStr := string(wfContent)\n   778→\t// The new step should be wired into the graph\n   779→\tassert.Contains(t, wfStr, \"step security-scan\")\n   780→\t// An existing step should wire to the new step (rewired from -> done)\n   781→\tassert.Contains(t, wfStr, \"test:success -> security-scan\")\n   782→\t// The new step should wire its results to terminals\n   783→\tassert.Contains(t, wfStr, \"security-scan:success -> done\")\n   784→\tassert.Contains(t, wfStr, \"security-scan:fail -> abort\")\n   785→\n   786→\t// Verify the workflow parses and validates\n   787→\twf, err := dsl.Parse(wfStr)\n   788→\trequire.NoError(t, err)\n   789→\trequire.NoError(t, wf.Validate())\n   790→}\n   791→\n   792→func TestHandleNewStepSkipsDuplicate(t *testing.T) {\n   793→\tdir := t.TempDir()\n   794→\n   795→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   796→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   797→\n   798→\t// Workflow already contains a step named \"security-scan\"\n   799→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   800→\t\t[]byte(`workflow \"develop\" {\n   801→  step implement {\n   802→    prompt = file(\".cloche/prompts/implement.md\")\n   803→    results = [success, fail]\n   804→  }\n   805→  step security-scan {\n   806→    run = \"scripts/security-scan.sh\"\n   807→    results = [success, fail]\n   808→  }\n   809→  implement:success -> security-scan\n   810→  implement:fail -> abort\n   811→  security-scan:success -> done\n   812→  security-scan:fail -> abort\n   813→}`), 0644)\n   814→\n   815→\tllm := &scriptedLLM{\n   816→\t\tresponses: []string{\n   817→\t\t\t// Classifier\n   818→\t\t\t`{\"classification\": \"enhancement\"}`,\n   819→\t\t\t// Reflector — lesson wants to add \"security-scan\" again\n   820→\t\t\t`{\"lessons\": [{\"id\": \"L003\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add security scanning\", \"suggested_action\": \"Add gosec scan\", \"evidence\": [\"run-3\"], \"confidence\": \"high\"}]}`,\n   821→\t\t\t// ScriptGenerator\n   822→\t\t\t`{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`,\n   823→\t\t},\n   824→\t}\n   825→\n   826→\torch := NewOrchestrator(OrchestratorConfig{\n   827→\t\tProjectDir:    dir,\n   828→\t\tWorkflowName:  \"develop\",\n   829→\t\tLLM:           llm,\n   830→\t\tMinConfidence: \"medium\",\n   831→\t})\n   832→\n   833→\tresult, err := orch.Run(context.Background(), \"run-3\", nil, nil)\n   834→\trequire.NoError(t, err)\n   835→\n   836→\t// Should have add_script change but NOT add_step (skipped as duplicate)\n   837→\tstepChanges := 0\n   838→\tfor _, c := range result.Changes {\n   839→\t\tif c.Type == \"add_step\" {\n   840→\t\t\tstepChanges++\n   841→\t\t}\n   842→\t}\n   843→\tassert.Equal(t, 0, stepChanges, \"should not add a duplicate step\")\n   844→\n   845→\t// Workflow should be unchanged — still valid, no duplicates\n   846→\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   847→\trequire.NoError(t, err)\n   848→\twf, err := dsl.Parse(string(wfContent))\n   849→\trequire.NoError(t, err)\n   850→\trequire.NoError(t, wf.Validate())\n   851→\tassert.Equal(t, 2, len(wf.Steps), \"should still have exactly 2 steps\")\n   852→}\n   853→\n   854→func TestHandleNewStepNoDoneEdge(t *testing.T) {\n   855→\tdir := t.TempDir()\n   856→\n   857→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   858→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   859→\n   860→\t// Workflow has no -> done edges (all go to abort)\n   861→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   862→\t\t[]byte(`workflow \"develop\" {\n   863→  step implement {\n   864→    prompt = file(\".cloche/prompts/implement.md\")\n   865→    results = [success, fail]\n   866→  }\n   867→  implement:success -> done\n   868→  implement:fail -> abort\n   869→}`), 0644)\n   870→\n   871→\tllm := &scriptedLLM{\n   872→\t\tresponses: []string{\n   873→\t\t\t`{\"classification\": \"enhancement\"}`,\n   874→\t\t\t`{\"lessons\": [{\"id\": \"L004\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add linting\", \"suggested_action\": \"Add lint step\", \"evidence\": [\"run-4\"], \"confidence\": \"high\"}]}`,\n   875→\t\t\t`{\"path\": \"scripts/lint.sh\", \"content\": \"#!/bin/bash\\ngolangci-lint run\"}`,\n   876→\t\t},\n   877→\t}\n   878→\n   879→\torch := NewOrchestrator(OrchestratorConfig{\n   880→\t\tProjectDir:    dir,\n   881→\t\tWorkflowName:  \"develop\",\n   882→\t\tLLM:           llm,\n   883→\t\tMinConfidence: \"medium\",\n   884→\t})\n   885→\n   886→\tresult, err := orch.Run(context.Background(), \"run-4\", nil, nil)\n   887→\trequire.NoError(t, err)\n   888→\n   889→\t// The new step should be added and the resulting workflow must validate\n   890→\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   891→\trequire.NoError(t, err)\n   892→\twf, err := dsl.Parse(string(wfContent))\n   893→\trequire.NoError(t, err)\n   894→\trequire.NoError(t, wf.Validate(), \"resulting workflow should have no orphaned steps\")\n   895→\n   896→\t// The new step should be reachable\n   897→\t_, hasStep := wf.Steps[\"lint\"]\n   898→\tassert.True(t, hasStep, \"lint step should exist\")\n   899→\n   900→\t// Verify add_step change was recorded\n   901→\thasAddStep := false\n   902→\tfor _, c := range result.Changes {\n   903→\t\tif c.Type == \"add_step\" {\n   904→\t\t\thasAddStep = true\n   905→\t\t}\n   906→\t}\n   907→\tassert.True(t, hasAddStep, \"should have recorded add_step change\")\n   908→}\n   909→\n   910→func TestHandleNewStepValidatesResultingWorkflow(t *testing.T) {\n   911→\tdir := t.TempDir()\n   912→\n   913→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   914→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   915→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   916→\t\t[]byte(`workflow \"develop\" {\n   917→  step implement {\n   918→    prompt = file(\".cloche/prompts/implement.md\")\n   919→    results = [success, fail]\n   920→  }\n   921→  step test {\n   922→    run = \"make test\"\n   923→    results = [success, fail]\n   924→  }\n   925→  implement:success -> test\n   926→  implement:fail -> abort\n   927→  test:success -> done\n   928→  test:fail -> abort\n   929→}`), 0644)\n   930→\n   931→\tllm := &scriptedLLM{\n   932→\t\tresponses: []string{\n   933→\t\t\t`{\"classification\": \"enhancement\"}`,\n   934→\t\t\t`{\"lessons\": [{\"id\": \"L005\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add formatting check\", \"suggested_action\": \"Add gofmt check\", \"evidence\": [\"run-5\"], \"confidence\": \"high\"}]}`,\n   935→\t\t\t`{\"path\": \"scripts/format-check.sh\", \"content\": \"#!/bin/bash\\ngofmt -l .\"}`,\n   936→\t\t},\n   937→\t}\n   938→\n   939→\torch := NewOrchestrator(OrchestratorConfig{\n   940→\t\tProjectDir:    dir,\n   941→\t\tWorkflowName:  \"develop\",\n   942→\t\tLLM:           llm,\n   943→\t\tMinConfidence: \"medium\",\n   944→\t})\n   945→\n   946→\tresult, err := orch.Run(context.Background(), \"run-5\", nil, nil)\n   947→\trequire.NoError(t, err)\n   948→\n   949→\t// Read and fully validate the workflow\n   950→\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   951→\trequire.NoError(t, err)\n   952→\twf, err := dsl.Parse(string(wfContent))\n   953→\trequire.NoError(t, err)\n   954→\trequire.NoError(t, wf.Validate())\n   955→\n   956→\t// Verify we got 3 steps now\n   957→\tassert.Equal(t, 3, len(wf.Steps))\n   958→\n   959→\t// Verify we got the add_step change\n   960→\thasAddStep := false\n   961→\tfor _, c := range result.Changes {\n   962→\t\tif c.Type == \"add_step\" {\n   963→\t\t\thasAddStep = true\n   964→\t\t}\n   965→\t}\n   966→\tassert.True(t, hasAddStep)\n   967→}\n   968→\n   969→func TestOrchestratorNoLessons(t *testing.T) {\n   970→\tdir := t.TempDir()\n   971→\n   972→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   973→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   974→\t\t[]byte(`workflow \"develop\" {\n   975→  step s {\n   976→    run = \"echo hi\"\n   977→    results = [success]\n   978→  }\n   979→  s:success -> done\n   980→}`), 0644)\n   981→\n   982→\tllm := &scriptedLLM{\n   983→\t\tresponses: []string{\n   984→\t\t\t// Classifier\n   985→\t\t\t`{\"classification\": \"feature\"}`,\n   986→\t\t\t// Reflector — no lessons\n   987→\t\t\t`{\"lessons\": []}`,\n   988→\t\t},\n   989→\t}\n   990→\n   991→\torch := NewOrchestrator(OrchestratorConfig{\n   992→\t\tProjectDir:    dir,\n   993→\t\tWorkflowName:  \"develop\",\n   994→\t\tLLM:           llm,\n   995→\t\tMinConfidence: \"medium\",\n   996→\t})\n   997→\n   998→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   999→\trequire.NoError(t, err)\n  1000→\tassert.Equal(t, \"feature\", result.Classification)\n  1001→\tassert.Empty(t, result.Changes)\n  1002→}\n  1003→\n  1004→// --- Content-change guard tests ---\n  1005→\n  1006→func TestLessonAlreadyPresent(t *testing.T) {\n  1007→\ttests := []struct {\n  1008→\t\tname    string\n  1009→\t\tprompt  string\n  1010→\t\tlesson  *Lesson\n  1011→\t\tpresent bool\n  1012→\t}{\n  1013→\t\t{\n  1014→\t\t\tname:    \"insight present\",\n  1015→\t\t\tprompt:  \"# Prompt\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n  1016→\t\t\tlesson:  &Lesson{Insight: \"Always sanitize user inputs\", SuggestedAction: \"Add rule\"},\n  1017→\t\t\tpresent: true,\n  1018→\t\t},\n  1019→\t\t{\n  1020→\t\t\tname:    \"action present\",\n  1021→\t\t\tprompt:  \"# Prompt\\n\\n## Learned Rules\\n\\n- Add input validation for all forms\\n\",\n  1022→\t\t\tlesson:  &Lesson{Insight: \"Forms lack validation\", SuggestedAction: \"Add input validation for all forms\"},\n  1023→\t\t\tpresent: true,\n  1024→\t\t},\n  1025→\t\t{\n  1026→\t\t\tname:    \"case insensitive match\",\n  1027→\t\t\tprompt:  \"# Prompt\\n\\n## Learned Rules\\n\\n- always sanitize user inputs\\n\",\n  1028→\t\t\tlesson:  &Lesson{Insight: \"Always Sanitize User Inputs\", SuggestedAction: \"Do it\"},\n  1029→\t\t\tpresent: true,\n  1030→\t\t},\n  1031→\t\t{\n  1032→\t\t\tname:    \"not present\",\n  1033→\t\t\tprompt:  \"# Prompt\\n\\nWrite good code.\\n\",\n  1034→\t\t\tlesson:  &Lesson{Insight: \"Always sanitize user inputs\", SuggestedAction: \"Add sanitization\"},\n  1035→\t\t\tpresent: false,\n  1036→\t\t},\n  1037→\t\t{\n  1038→\t\t\tname:    \"empty insight and action\",\n  1039→\t\t\tprompt:  \"# Prompt\\n\\nWrite good code.\\n\",\n  1040→\t\t\tlesson:  &Lesson{Insight: \"\", SuggestedAction: \"\"},\n  1041→\t\t\tpresent: false,\n  1042→\t\t},\n  1043→\t}\n  1044→\n  1045→\tfor _, tt := range tests {\n  1046→\t\tt.Run(tt.name, func(t *testing.T) {\n  1047→\t\t\tassert.Equal(t, tt.present, lessonAlreadyPresent(tt.prompt, tt.lesson))\n  1048→\t\t})\n  1049→\t}\n  1050→}\n  1051→\n  1052→func TestCuratorSkipsWhenLessonAlreadyPresent(t *testing.T) {\n  1053→\tdir := t.TempDir()\n  1054→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n  1055→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n  1056→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n  1057→\n  1058→\t// Prompt already contains the lesson insight\n  1059→\tos.WriteFile(promptPath, []byte(\"# Prompt\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"), 0644)\n  1060→\n  1061→\t// LLM should NOT be called — use a response that would change the file\n  1062→\tllm := &fakeLLM{response: \"THIS SHOULD NOT APPEAR\"}\n  1063→\taudit := &AuditLogger{ProjectDir: dir}\n  1064→\tc := &Curator{LLM: llm, Audit: audit}\n  1065→\tlesson := &Lesson{\n  1066→\t\tTarget:          \".cloche/prompts/implement.md\",\n  1067→\t\tInsight:         \"Always sanitize user inputs\",\n  1068→\t\tSuggestedAction: \"Add sanitization rule\",\n  1069→\t}\n  1070→\n  1071→\tchange, err := c.Apply(context.Background(), dir, lesson)\n  1072→\trequire.NoError(t, err)\n  1073→\tassert.Nil(t, change, \"should return nil change when lesson already present\")\n  1074→\n  1075→\t// File should be unchanged\n  1076→\tcontent, _ := os.ReadFile(promptPath)\n  1077→\tassert.NotContains(t, string(content), \"THIS SHOULD NOT APPEAR\")\n  1078→}\n  1079→\n  1080→func TestReflectorFiltersAlreadyAppliedLessons(t *testing.T) {\n  1081→\tlessonsJSON, _ := json.Marshal(map[string]any{\n  1082→\t\t\"lessons\": []map[string]any{\n  1083→\t\t\t{\"id\": \"lesson-001\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n  1084→\t\t\t{\"id\": \"lesson-002\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n  1085→\t\t},\n  1086→\t})\n  1087→\n  1088→\tllm := &fakeLLM{response: string(lessonsJSON)}\n  1089→\tr := &Reflector{LLM: llm, MinConfidence: \"low\"}\n  1090→\n  1091→\t// Knowledge base already contains lesson-001\n  1092→\tdata := &CollectedData{\n  1093→\t\tKnowledgeBase: \"# Knowledge Base\\n\\n- **[lesson-001]** (prompt_improvement, confidence: high) Old insight\\n\",\n  1094→\t}\n  1095→\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n  1096→\trequire.NoError(t, err)\n  1097→\trequire.Len(t, lessons, 1)\n  1098→\tassert.Equal(t, \"lesson-002\", lessons[0].ID)\n  1099→}\n  1100→\n  1101→func TestOrchestratorSkipsAlreadyAppliedLessons(t *testing.T) {\n  1102→\tdir := t.TempDir()\n  1103→\n  1104→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n  1105→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n  1106→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.jsonl\"),\n  1107→\t\t[]byte(`{\"id\":\"L001\",\"category\":\"prompt_improvement\",\"insight\":\"XSS pattern\",\"suggested_action\":\"Add sanitization\",\"confidence\":\"high\"}`+\"\\n\"), 0644)\n  1108→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n  1109→\t\t[]byte(\"Write good code.\\n\"), 0644)\n  1110→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n  1111→\t\t[]byte(`workflow \"develop\" {\n  1112→  step s {\n  1113→    run = \"echo hi\"\n  1114→    results = [success]\n  1115→  }\n  1116→  s:success -> done\n  1117→}`), 0644)\n  1118→\n  1119→\t// Reflector returns a lesson that's already in the knowledge base\n  1120→\tllm := &scriptedLLM{\n  1121→\t\tresponses: []string{\n  1122→\t\t\t`{\"classification\": \"bug\"}`,\n  1123→\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n  1124→\t\t},\n  1125→\t}\n  1126→\n  1127→\torch := NewOrchestrator(OrchestratorConfig{\n  1128→\t\tProjectDir:    dir,\n  1129→\t\tWorkflowName:  \"develop\",\n  1130→\t\tLLM:           llm,\n  1131→\t\tMinConfidence: \"low\",\n  1132→\t})\n  1133→\n  1134→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n  1135→\trequire.NoError(t, err)\n  1136→\tassert.Empty(t, result.Changes, \"should produce zero changes for already-applied lesson\")\n  1137→}\n  1138→\n  1139→func TestOrchestratorSecondRunProducesNoChanges(t *testing.T) {\n  1140→\tdir := t.TempDir()\n  1141→\n  1142→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n  1143→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n  1144→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n  1145→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n  1146→\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n  1147→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n  1148→\t\t[]byte(\"Write good code.\\n\"), 0644)\n  1149→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n  1150→\t\t[]byte(`workflow \"develop\" {\n  1151→  step implement {\n  1152→    prompt = file(\".cloche/prompts/implement.md\")\n  1153→    results = [success, fail]\n  1154→  }\n  1155→  implement:success -> done\n  1156→  implement:fail -> abort\n  1157→}`), 0644)\n  1158→\n  1159→\t// First run: lesson gets applied\n  1160→\tllm1 := &scriptedLLM{\n  1161→\t\tresponses: []string{\n  1162→\t\t\t`{\"classification\": \"bug\"}`,\n  1163→\t\t\t`{\"lessons\": [{\"id\": \"L010\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Always sanitize user inputs\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n  1164→\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n  1165→\t\t},\n  1166→\t}\n  1167→\n  1168→\torch1 := NewOrchestrator(OrchestratorConfig{\n  1169→\t\tProjectDir:    dir,\n  1170→\t\tWorkflowName:  \"develop\",\n  1171→\t\tLLM:           llm1,\n  1172→\t\tMinConfidence: \"low\",\n  1173→\t})\n  1174→\n  1175→\tresult1, err := orch1.Run(context.Background(), \"run-1\", nil, nil)\n  1176→\trequire.NoError(t, err)\n  1177→\trequire.Len(t, result1.Changes, 1, \"first run should produce one change\")\n  1178→\n  1179→\t// Second run: same lesson ID — the knowledge base now contains L010,\n  1180→\t// and the prompt contains the insight text.\n  1181→\tllm2 := &scriptedLLM{\n  1182→\t\tresponses: []string{\n  1183→\t\t\t`{\"classification\": \"bug\"}`,\n  1184→\t\t\t`{\"lessons\": [{\"id\": \"L010\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Always sanitize user inputs\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n  1185→\t\t},\n  1186→\t}\n  1187→\n  1188→\torch2 := NewOrchestrator(OrchestratorConfig{\n  1189→\t\tProjectDir:    dir,\n  1190→\t\tWorkflowName:  \"develop\",\n  1191→\t\tLLM:           llm2,\n  1192→\t\tMinConfidence: \"low\",\n  1193→\t})\n  1194→\n  1195→\tresult2, err := orch2.Run(context.Background(), \"run-2\", nil, nil)\n  1196→\trequire.NoError(t, err)\n  1197→\tassert.Empty(t, result2.Changes, \"second run should produce zero changes\")\n  1198→}\n  1199→"}]},"parent_tool_use_id":null,"session_id":"ee4b9d5f-226b-4cd1-9d2c-3cf327fb6206","uuid":"b85b1c8c-24f4-4f4e-bda6-a586c205dc5d","timestamp":"2026-03-18T16:10:57.616Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/evolution_test.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// fakeLLM returns a fixed response for testing.\ntype fakeLLM struct {\n\tresponse string\n}\n\nfunc (f *fakeLLM) Complete(ctx context.Context, system, user string) (string, error) {\n\treturn f.response, nil\n}\n\n// --- Collector tests ---\n\nfunc TestCollectorGathersData(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.jsonl\"),\n\t\t[]byte(`{\"id\":\"L000\",\"insight\":\"existing lesson\"}`+\"\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"Write good code\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step impl {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success]\n  }\n  impl:success -> done\n}`), 0644)\n\n\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n\tdata, err := c.Collect(context.Background(), nil, nil)\n\trequire.NoError(t, err)\n\n\tassert.Contains(t, data.KnowledgeBase, \"existing lesson\")\n\tassert.Contains(t, data.CurrentPrompts, \".cloche/prompts/implement.md\")\n\tassert.Equal(t, \"Write good code\", data.CurrentPrompts[\".cloche/prompts/implement.md\"])\n\tassert.NotEmpty(t, data.CurrentWorkflow)\n\tassert.Equal(t, dir, data.ProjectDir)\n\tassert.Equal(t, \"develop\", data.WorkflowName)\n}\n\nfunc TestCollectorNoKnowledgeBase(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n\n\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n\tdata, err := c.Collect(context.Background(), nil, nil)\n\trequire.NoError(t, err)\n\tassert.Empty(t, data.KnowledgeBase)\n}\n\nfunc TestExtractPromptFiles(t *testing.T) {\n\tworkflow := `step impl { prompt = file(\".cloche/prompts/implement.md\") }\nstep fix { prompt = file(\".cloche/prompts/fix.md\") }\nstep test { run = \"make test\" }`\n\n\tfiles := extractPromptFiles(workflow)\n\tassert.Len(t, files, 2)\n\tassert.Contains(t, files, \".cloche/prompts/implement.md\")\n\tassert.Contains(t, files, \".cloche/prompts/fix.md\")\n}\n\n// --- Classifier tests ---\n\nfunc TestClassifierCategorizesRun(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tresponse string\n\t\texpected string\n\t}{\n\t\t{\"bug\", `{\"classification\": \"bug\"}`, \"bug\"},\n\t\t{\"feature\", `{\"classification\": \"feature\"}`, \"feature\"},\n\t\t{\"feedback\", `{\"classification\": \"feedback\"}`, \"feedback\"},\n\t\t{\"enhancement\", `{\"classification\": \"enhancement\"}`, \"enhancement\"},\n\t\t{\"chore\", `{\"classification\": \"chore\"}`, \"chore\"},\n\t\t{\"invalid defaults to feature\", `{\"classification\": \"unknown\"}`, \"feature\"},\n\t\t{\"malformed JSON defaults to feature\", `not json`, \"feature\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tllm := &fakeLLM{response: tt.response}\n\t\t\tc := &Classifier{LLM: llm}\n\t\t\tresult, err := c.Classify(context.Background(), \"some prompt\")\n\t\t\trequire.NoError(t, err)\n\t\t\tassert.Equal(t, tt.expected, result)\n\t\t})\n\t}\n}\n\n// --- Reflector tests ---\n\nfunc TestReflectorExtractsLessons(t *testing.T) {\n\tlessonsJSON, _ := json.Marshal(map[string]any{\n\t\t\"lessons\": []map[string]any{\n\t\t\t{\n\t\t\t\t\"id\":               \"lesson-001\",\n\t\t\t\t\"category\":         \"prompt_improvement\",\n\t\t\t\t\"target\":           \".cloche/prompts/implement.md\",\n\t\t\t\t\"insight\":          \"Agent produces unsanitized HTML\",\n\t\t\t\t\"suggested_action\": \"Add sanitization rule\",\n\t\t\t\t\"evidence\":         []string{\"run-1\", \"run-2\"},\n\t\t\t\t\"confidence\":       \"high\",\n\t\t\t},\n\t\t},\n\t})\n\n\tllm := &fakeLLM{response: string(lessonsJSON)}\n\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n\n\tdata := &CollectedData{WorkflowName: \"develop\", KnowledgeBase: \"# KB\\n\"}\n\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n\trequire.NoError(t, err)\n\trequire.Len(t, lessons, 1)\n\tassert.Equal(t, \"prompt_improvement\", lessons[0].Category)\n\tassert.Equal(t, \"high\", lessons[0].Confidence)\n}\n\nfunc TestReflectorFiltersLowConfidence(t *testing.T) {\n\tlessonsJSON, _ := json.Marshal(map[string]any{\n\t\t\"lessons\": []map[string]any{\n\t\t\t{\"id\": \"L1\", \"category\": \"new_step\", \"confidence\": \"low\"},\n\t\t\t{\"id\": \"L2\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n\t\t},\n\t})\n\n\tllm := &fakeLLM{response: string(lessonsJSON)}\n\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n\n\tlessons, err := r.Reflect(context.Background(), &CollectedData{}, \"bug\")\n\trequire.NoError(t, err)\n\tassert.Len(t, lessons, 1)\n\tassert.Equal(t, \"L2\", lessons[0].ID)\n}\n\nfunc TestConfidenceLevel(t *testing.T) {\n\tassert.Equal(t, 3, confidenceLevel(\"high\"))\n\tassert.Equal(t, 2, confidenceLevel(\"medium\"))\n\tassert.Equal(t, 1, confidenceLevel(\"low\"))\n\tassert.Equal(t, 0, confidenceLevel(\"\"))\n}\n\n// --- Audit Logger tests ---\n\nfunc TestAuditLoggerAppendsJSONL(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\"), 0755)\n\n\tlogger := &AuditLogger{ProjectDir: dir}\n\n\tresult1 := &EvolutionResult{\n\t\tID:           \"evo-1\",\n\t\tWorkflowName: \"develop\",\n\t\tChanges:      []Change{{Type: \"prompt_update\", File: \".cloche/prompts/impl.md\"}},\n\t}\n\trequire.NoError(t, logger.Log(result1))\n\n\tresult2 := &EvolutionResult{\n\t\tID:           \"evo-2\",\n\t\tWorkflowName: \"develop\",\n\t\tChanges:      []Change{{Type: \"add_step\", File: \".cloche/develop.cloche\"}},\n\t}\n\trequire.NoError(t, logger.Log(result2))\n\n\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n\trequire.NoError(t, err)\n\n\tlines := strings.Split(strings.TrimSpace(string(content)), \"\\n\")\n\tassert.Len(t, lines, 2)\n\n\tvar entry1 EvolutionResult\n\trequire.NoError(t, json.Unmarshal([]byte(lines[0]), &entry1))\n\tassert.Equal(t, \"evo-1\", entry1.ID)\n}\n\nfunc TestAuditLoggerSnapshot(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"original content\"), 0644)\n\n\tlogger := &AuditLogger{ProjectDir: dir}\n\tsnapName, err := logger.Snapshot(\".cloche/prompts/implement.md\")\n\trequire.NoError(t, err)\n\tassert.NotEmpty(t, snapName)\n\n\tsnapPath := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\", snapName)\n\tcontent, err := os.ReadFile(snapPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"original content\", string(content))\n}\n\nfunc TestAuditLoggerUpdatesKnowledge(t *testing.T) {\n\tdir := t.TempDir()\n\tkbDir := filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\")\n\tos.MkdirAll(kbDir, 0755)\n\n\tlogger := &AuditLogger{ProjectDir: dir}\n\tlessons := []Lesson{\n\t\t{\n\t\t\tID:              \"P001\",\n\t\t\tCategory:        \"prompt_improvement\",\n\t\t\tConfidence:      \"high\",\n\t\t\tInsight:         \"Always sanitize HTML inputs\",\n\t\t\tSuggestedAction: \"Add rule to implement prompt\",\n\t\t\tEvidence:        []string{\"run-1\", \"run-2\"},\n\t\t},\n\t}\n\n\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", lessons))\n\n\tcontent, err := os.ReadFile(filepath.Join(kbDir, \"develop.jsonl\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"P001\")\n\tassert.Contains(t, string(content), \"sanitize HTML\")\n\tassert.Contains(t, string(content), \"run-1\")\n}\n\nfunc TestAuditLoggerDeduplicatesLessons(t *testing.T) {\n\tdir := t.TempDir()\n\tlogger := &AuditLogger{ProjectDir: dir}\n\n\tlesson := Lesson{\n\t\tID:       \"L001\",\n\t\tCategory: \"prompt_improvement\",\n\t\tInsight:  \"Original insight\",\n\t}\n\n\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{lesson}))\n\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{lesson}))\n\n\t// Read back and verify only one entry\n\tlessons, err := readKnowledge(logger.KnowledgePath(\"develop\"))\n\trequire.NoError(t, err)\n\tassert.Len(t, lessons, 1)\n\tassert.Equal(t, \"L001\", lessons[0].ID)\n}\n\nfunc TestAuditLoggerUpdatesExistingLesson(t *testing.T) {\n\tdir := t.TempDir()\n\tlogger := &AuditLogger{ProjectDir: dir}\n\n\toriginal := Lesson{ID: \"L001\", Insight: \"Original insight\"}\n\tupdated := Lesson{ID: \"L001\", Insight: \"Updated insight\"}\n\n\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{original}))\n\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{updated}))\n\n\tlessons, err := readKnowledge(logger.KnowledgePath(\"develop\"))\n\trequire.NoError(t, err)\n\tassert.Len(t, lessons, 1)\n\tassert.Equal(t, \"Updated insight\", lessons[0].Insight)\n}\n\nfunc TestAuditLoggerPrunesWithMaxPromptBullets(t *testing.T) {\n\tdir := t.TempDir()\n\tlogger := &AuditLogger{ProjectDir: dir, MaxPromptBullets: 5}\n\n\t// Add 10 lessons\n\tfor i := 0; i < 10; i++ {\n\t\tlesson := Lesson{\n\t\t\tID:      fmt.Sprintf(\"L%03d\", i),\n\t\t\tInsight: fmt.Sprintf(\"Insight %d\", i),\n\t\t}\n\t\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{lesson}))\n\t}\n\n\tlessons, err := readKnowledge(logger.KnowledgePath(\"develop\"))\n\trequire.NoError(t, err)\n\tassert.Len(t, lessons, 5)\n\t// Should keep the most recent 5 (L005-L009)\n\tassert.Equal(t, \"L005\", lessons[0].ID)\n\tassert.Equal(t, \"L009\", lessons[4].ID)\n}\n\n// --- LLM Client tests ---\n\n// --- Curator tests ---\n\nfunc TestCuratorUpdatesPrompt(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n\n\tupdatedContent := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"\n\tllm := &fakeLLM{response: updatedContent}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tID:              \"lesson-001\",\n\t\tCategory:        \"prompt_improvement\",\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"XSS vulnerabilities in form handlers\",\n\t\tSuggestedAction: \"Add sanitization rule\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"prompt_update\", change.Type)\n\tassert.Equal(t, \".cloche/prompts/implement.md\", change.File)\n\tassert.NotEmpty(t, change.Snapshot)\n\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"sanitize user inputs\")\n}\n\n// --- stripCodeFences tests ---\n\nfunc TestStripCodeFences(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tinput    string\n\t\texpected string\n\t}{\n\t\t{\n\t\t\tname:     \"no fences returns as-is\",\n\t\t\tinput:    \"# Prompt\\n\\nDo good work.\\n\",\n\t\t\texpected: \"# Prompt\\n\\nDo good work.\",\n\t\t},\n\t\t{\n\t\t\tname:     \"plain code fence\",\n\t\t\tinput:    \"```\\n# Prompt\\n\\nDo good work.\\n```\",\n\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n\t\t},\n\t\t{\n\t\t\tname:     \"code fence with language hint\",\n\t\t\tinput:    \"```markdown\\n# Prompt\\n\\nDo good work.\\n```\",\n\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n\t\t},\n\t\t{\n\t\t\tname:     \"commentary before and after fence\",\n\t\t\tinput:    \"Here's the updated prompt:\\n\\n```markdown\\n# Prompt\\n\\nDo good work.\\n```\\n\\nI've added the rule as requested.\",\n\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n\t\t},\n\t\t{\n\t\t\tname:     \"no closing fence returns as-is\",\n\t\t\tinput:    \"```markdown\\n# Prompt\\n\",\n\t\t\texpected: \"```markdown\\n# Prompt\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, tt.expected, stripCodeFences(tt.input))\n\t\t})\n\t}\n}\n\nfunc TestCuratorStripsCodeFencesFromResponse(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n\n\t// LLM returns content wrapped in code fences with commentary\n\tfencedResponse := \"Here is the updated prompt:\\n\\n```markdown\\n# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n```\\n\\nI added the validation rule.\"\n\tllm := &fakeLLM{response: fencedResponse}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Missing input validation\",\n\t\tSuggestedAction: \"Add validation rule\",\n\t}\n\n\t_, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\n\t// Should contain the actual prompt content, not the commentary\n\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n\tassert.Contains(t, string(content), \"Always validate inputs\")\n\tassert.NotContains(t, string(content), \"Here is the updated prompt\")\n\tassert.NotContains(t, string(content), \"I added the validation rule\")\n\tassert.NotContains(t, string(content), \"```\")\n}\n\nfunc TestCuratorRejectsConversationalMetaText(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"fix.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\toriginal := \"# Fix Prompt\\n\\nFix bugs carefully.\\n\"\n\tos.WriteFile(promptPath, []byte(original), 0644)\n\n\t// LLM returns conversational meta-text\n\tllm := &fakeLLM{response: \"I need write permission to update the file. Could you grant access to .cloche/prompts/fix.md?\"}\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/fix.md\",\n\t\tInsight:         \"Missing error context\",\n\t\tSuggestedAction: \"Wrap errors with context\",\n\t}\n\n\t_, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\t// Must NOT contain the conversational text\n\tassert.NotContains(t, string(content), \"I need write permission\")\n\tassert.NotContains(t, string(content), \"Could you grant access\")\n\t// Should contain the original content and the lesson appended directly\n\tassert.Contains(t, string(content), \"# Fix Prompt\")\n\tassert.Contains(t, string(content), \"Missing error context\")\n}\n\nfunc TestCuratorRejectsUnfencedConversationalPrefix(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n\tos.WriteFile(promptPath, []byte(original), 0644)\n\n\t// LLM returns \"Here is the updated prompt:\" with NO code fences\n\tllm := &fakeLLM{response: \"Here is the updated prompt:\\n\\n# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Validate inputs\\n\"}\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Missing validation\",\n\t\tSuggestedAction: \"Add input validation\",\n\t}\n\n\t_, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\t// The conversational prefix must not appear\n\tassert.NotContains(t, string(content), \"Here is the updated prompt\")\n\t// Original content preserved, lesson appended via fallback\n\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n\tassert.Contains(t, string(content), \"Missing validation\")\n}\n\nfunc TestCuratorAcceptsValidPromptWithoutFences(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n\n\t// LLM returns valid prompt content without code fences\n\tvalidResponse := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n\"\n\tllm := &fakeLLM{response: validResponse}\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Missing validation\",\n\t\tSuggestedAction: \"Add validation rule\",\n\t}\n\n\t_, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\t// Should write the LLM response (after stripCodeFences trimming) since it's valid prompt content\n\tassert.Contains(t, string(content), \"Always validate inputs\")\n\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n\tassert.NotContains(t, string(content), \"Missing validation\")\n}\n\nfunc TestIsConversationalResponse(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tinput    string\n\t\texpected bool\n\t}{\n\t\t{\"permission request\", \"I need write permission to update the file\", true},\n\t\t{\"grant request\", \"Could you grant access to the file?\", true},\n\t\t{\"blocked message\", \"Permission blocked by sandbox\", true},\n\t\t{\"here is updated\", \"Here is the updated prompt:\\n\\n# Prompt\", true},\n\t\t{\"heres updated\", \"Here's the updated prompt:\\n\\n# Prompt\", true},\n\t\t{\"ive updated\", \"I've updated the prompt with the new rule\", true},\n\t\t{\"let me\", \"Let me update the file for you\", true},\n\t\t{\"valid markdown heading\", \"# Prompt\\n\\nDo good work.\", false},\n\t\t{\"valid bullet list\", \"- Rule one\\n- Rule two\", false},\n\t\t{\"empty string\", \"\", true},\n\t\t{\"valid content no heading\", \"Write good code and test everything.\", false},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, tt.expected, isConversationalResponse(tt.input))\n\t\t})\n\t}\n}\n\nfunc TestAppendLessonDirectly(t *testing.T) {\n\tt.Run(\"creates learned rules section\", func(t *testing.T) {\n\t\tresult := appendLessonDirectly(\"# Prompt\\n\\nDo good work.\\n\", &Lesson{\n\t\t\tInsight:         \"Missing validation\",\n\t\t\tSuggestedAction: \"Add validation\",\n\t\t})\n\t\tassert.Contains(t, result, \"## Learned Rules\")\n\t\tassert.Contains(t, result, \"Missing validation: Add validation\")\n\t})\n\n\tt.Run(\"appends to existing learned rules\", func(t *testing.T) {\n\t\texisting := \"# Prompt\\n\\n## Learned Rules\\n\\n- Existing rule\\n\"\n\t\tresult := appendLessonDirectly(existing, &Lesson{\n\t\t\tInsight:         \"New insight\",\n\t\t\tSuggestedAction: \"New action\",\n\t\t})\n\t\tassert.Contains(t, result, \"- Existing rule\")\n\t\tassert.Contains(t, result, \"- New insight: New action\")\n\t\t// Should not create a duplicate section\n\t\tassert.Equal(t, 1, strings.Count(result, \"## Learned Rules\"))\n\t})\n}\n\n// --- Script Generator tests ---\n\nfunc TestScriptGeneratorCreatesScript(t *testing.T) {\n\tdir := t.TempDir()\n\n\tllm := &fakeLLM{response: `{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`}\n\tg := &ScriptGenerator{LLM: llm}\n\n\tlesson := &Lesson{\n\t\tID:              \"lesson-001\",\n\t\tCategory:        \"new_step\",\n\t\tStepType:        \"script\",\n\t\tInsight:         \"No security scanning\",\n\t\tSuggestedAction: \"Add gosec security scan\",\n\t}\n\n\tresult, err := g.Generate(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"scripts/security-scan.sh\", result.Path)\n\n\tcontent, err := os.ReadFile(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"gosec\")\n\n\tinfo, err := os.Stat(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n\trequire.NoError(t, err)\n\tassert.Zero(t, info.Mode()&0111) // non-executable; workflow engine handles execution\n}\n\n// --- LLM Client tests ---\n\nfunc TestCommandLLMClientPrintMode(t *testing.T) {\n\t// Use a shell script that dumps its args and stdin so we can verify\n\t// that the client passes the right flags and prompt separation.\n\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n\tos.WriteFile(script, []byte(`#!/bin/sh\necho \"ARGS:$*\"\necho \"STDIN:$(cat)\"\n`), 0755)\n\n\tc := &CommandLLMClient{Command: script, Args: []string{}}\n\tresult, err := c.Complete(context.Background(), \"You are a helpful assistant.\", \"Summarize this text\")\n\trequire.NoError(t, err)\n\n\t// Should include -p flag for print/non-interactive mode\n\tassert.Contains(t, result, \"-p\")\n\n\t// Should pass system prompt via --system-prompt flag\n\tassert.Contains(t, result, \"--system-prompt\")\n\tassert.Contains(t, result, \"You are a helpful assistant.\")\n\n\t// Should pass --output-format text\n\tassert.Contains(t, result, \"--output-format text\")\n\n\t// Stdin should contain only the user prompt, not the system prompt\n\tassert.Contains(t, result, \"STDIN:Summarize this text\")\n\tassert.NotContains(t, result, \"STDIN:You are a helpful assistant\")\n}\n\nfunc TestCommandLLMClientEmptySystemPrompt(t *testing.T) {\n\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n\tos.WriteFile(script, []byte(`#!/bin/sh\necho \"ARGS:$*\"\necho \"STDIN:$(cat)\"\n`), 0755)\n\n\tc := &CommandLLMClient{Command: script, Args: []string{}}\n\tresult, err := c.Complete(context.Background(), \"\", \"just user prompt\")\n\trequire.NoError(t, err)\n\n\t// Should NOT include --system-prompt when system prompt is empty\n\tassert.NotContains(t, result, \"--system-prompt\")\n\t// Should still have -p and --output-format\n\tassert.Contains(t, result, \"-p\")\n\tassert.Contains(t, result, \"--output-format text\")\n\tassert.Contains(t, result, \"STDIN:just user prompt\")\n}\n\nfunc TestCommandLLMClientExtraArgs(t *testing.T) {\n\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n\tos.WriteFile(script, []byte(`#!/bin/sh\necho \"ARGS:$*\"\necho \"STDIN:$(cat)\"\n`), 0755)\n\n\tc := &CommandLLMClient{Command: script, Args: []string{\"--model\", \"sonnet\"}}\n\tresult, err := c.Complete(context.Background(), \"sys\", \"usr\")\n\trequire.NoError(t, err)\n\n\t// Extra args should appear before the appended flags\n\tassert.Contains(t, result, \"--model sonnet\")\n\tassert.Contains(t, result, \"-p\")\n}\n\nfunc TestCommandLLMClientDoesNotMutateArgs(t *testing.T) {\n\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n\tos.WriteFile(script, []byte(\"#!/bin/sh\\ncat\\n\"), 0755)\n\n\toriginal := []string{\"--verbose\"}\n\tc := &CommandLLMClient{Command: script, Args: original}\n\t_, err := c.Complete(context.Background(), \"sys\", \"usr\")\n\trequire.NoError(t, err)\n\n\t// The original Args slice should not be modified between calls.\n\tassert.Equal(t, []string{\"--verbose\"}, original)\n}\n\n// --- Orchestrator tests ---\n\n// scriptedLLM returns responses in order.\ntype scriptedLLM struct {\n\tresponses []string\n\tidx       int\n}\n\nfunc (s *scriptedLLM) Complete(ctx context.Context, system, user string) (string, error) {\n\tresp := s.responses[s.idx]\n\ts.idx++\n\treturn resp, nil\n}\n\nfunc TestOrchestratorEndToEnd(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Set up project structure\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"Write good code.\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n  implement:success -> test\n  test:success -> done\n  test:fail -> abort\n}`), 0644)\n\n\t// Fake LLM that returns appropriate responses per stage\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t// Reflector\n\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t\t// Curator\n\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"bug\", result.Classification)\n\trequire.Len(t, result.Changes, 1)\n\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n\n\t// Verify prompt was actually updated\n\tcontent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n\tassert.Contains(t, string(content), \"sanitize user inputs\")\n\n\t// Verify audit log was written\n\tlogContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n\tassert.Contains(t, string(logContent), \"prompt_update\")\n\tassert.Contains(t, string(logContent), \"XSS pattern\")\n\n\t// Verify knowledge base was updated (JSONL format)\n\tkbContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.jsonl\"))\n\tassert.Contains(t, string(kbContent), \"L001\")\n}\n\nfunc TestOrchestratorNewStepWiredIntoGraph(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\t// Knowledge base uses JSONL format (created automatically by UpdateKnowledge)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n  implement:success -> test\n  implement:fail -> abort\n  test:success -> done\n  test:fail -> abort\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"enhancement\"}`,\n\t\t\t// Reflector\n\t\t\t`{\"lessons\": [{\"id\": \"L002\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"No security scanning\", \"suggested_action\": \"Add gosec scan\", \"evidence\": [\"run-2\"], \"confidence\": \"high\"}]}`,\n\t\t\t// ScriptGenerator\n\t\t\t`{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-2\", nil, nil)\n\trequire.NoError(t, err)\n\trequire.Len(t, result.Changes, 2) // add_script + add_step\n\tassert.Equal(t, \"add_script\", result.Changes[0].Type)\n\tassert.Equal(t, \"add_step\", result.Changes[1].Type)\n\n\t// Read the updated workflow and verify the new step is reachable\n\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n\trequire.NoError(t, err)\n\n\twfStr := string(wfContent)\n\t// The new step should be wired into the graph\n\tassert.Contains(t, wfStr, \"step security-scan\")\n\t// An existing step should wire to the new step (rewired from -> done)\n\tassert.Contains(t, wfStr, \"test:success -> security-scan\")\n\t// The new step should wire its results to terminals\n\tassert.Contains(t, wfStr, \"security-scan:success -> done\")\n\tassert.Contains(t, wfStr, \"security-scan:fail -> abort\")\n\n\t// Verify the workflow parses and validates\n\twf, err := dsl.Parse(wfStr)\n\trequire.NoError(t, err)\n\trequire.NoError(t, wf.Validate())\n}\n\nfunc TestHandleNewStepSkipsDuplicate(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\n\t// Workflow already contains a step named \"security-scan\"\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  step security-scan {\n    run = \"scripts/security-scan.sh\"\n    results = [success, fail]\n  }\n  implement:success -> security-scan\n  implement:fail -> abort\n  security-scan:success -> done\n  security-scan:fail -> abort\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"enhancement\"}`,\n\t\t\t// Reflector — lesson wants to add \"security-scan\" again\n\t\t\t`{\"lessons\": [{\"id\": \"L003\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add security scanning\", \"suggested_action\": \"Add gosec scan\", \"evidence\": [\"run-3\"], \"confidence\": \"high\"}]}`,\n\t\t\t// ScriptGenerator\n\t\t\t`{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-3\", nil, nil)\n\trequire.NoError(t, err)\n\n\t// Should have add_script change but NOT add_step (skipped as duplicate)\n\tstepChanges := 0\n\tfor _, c := range result.Changes {\n\t\tif c.Type == \"add_step\" {\n\t\t\tstepChanges++\n\t\t}\n\t}\n\tassert.Equal(t, 0, stepChanges, \"should not add a duplicate step\")\n\n\t// Workflow should be unchanged — still valid, no duplicates\n\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n\trequire.NoError(t, err)\n\twf, err := dsl.Parse(string(wfContent))\n\trequire.NoError(t, err)\n\trequire.NoError(t, wf.Validate())\n\tassert.Equal(t, 2, len(wf.Steps), \"should still have exactly 2 steps\")\n}\n\nfunc TestHandleNewStepNoDoneEdge(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\n\t// Workflow has no -> done edges (all go to abort)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  implement:success -> done\n  implement:fail -> abort\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"enhancement\"}`,\n\t\t\t`{\"lessons\": [{\"id\": \"L004\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add linting\", \"suggested_action\": \"Add lint step\", \"evidence\": [\"run-4\"], \"confidence\": \"high\"}]}`,\n\t\t\t`{\"path\": \"scripts/lint.sh\", \"content\": \"#!/bin/bash\\ngolangci-lint run\"}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-4\", nil, nil)\n\trequire.NoError(t, err)\n\n\t// The new step should be added and the resulting workflow must validate\n\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n\trequire.NoError(t, err)\n\twf, err := dsl.Parse(string(wfContent))\n\trequire.NoError(t, err)\n\trequire.NoError(t, wf.Validate(), \"resulting workflow should have no orphaned steps\")\n\n\t// The new step should be reachable\n\t_, hasStep := wf.Steps[\"lint\"]\n\tassert.True(t, hasStep, \"lint step should exist\")\n\n\t// Verify add_step change was recorded\n\thasAddStep := false\n\tfor _, c := range result.Changes {\n\t\tif c.Type == \"add_step\" {\n\t\t\thasAddStep = true\n\t\t}\n\t}\n\tassert.True(t, hasAddStep, \"should have recorded add_step change\")\n}\n\nfunc TestHandleNewStepValidatesResultingWorkflow(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n  implement:success -> test\n  implement:fail -> abort\n  test:success -> done\n  test:fail -> abort\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"enhancement\"}`,\n\t\t\t`{\"lessons\": [{\"id\": \"L005\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add formatting check\", \"suggested_action\": \"Add gofmt check\", \"evidence\": [\"run-5\"], \"confidence\": \"high\"}]}`,\n\t\t\t`{\"path\": \"scripts/format-check.sh\", \"content\": \"#!/bin/bash\\ngofmt -l .\"}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-5\", nil, nil)\n\trequire.NoError(t, err)\n\n\t// Read and fully validate the workflow\n\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n\trequire.NoError(t, err)\n\twf, err := dsl.Parse(string(wfContent))\n\trequire.NoError(t, err)\n\trequire.NoError(t, wf.Validate())\n\n\t// Verify we got 3 steps now\n\tassert.Equal(t, 3, len(wf.Steps))\n\n\t// Verify we got the add_step change\n\thasAddStep := false\n\tfor _, c := range result.Changes {\n\t\tif c.Type == \"add_step\" {\n\t\t\thasAddStep = true\n\t\t}\n\t}\n\tassert.True(t, hasAddStep)\n}\n\nfunc TestOrchestratorNoLessons(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step s {\n    run = \"echo hi\"\n    results = [success]\n  }\n  s:success -> done\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"feature\"}`,\n\t\t\t// Reflector — no lessons\n\t\t\t`{\"lessons\": []}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"feature\", result.Classification)\n\tassert.Empty(t, result.Changes)\n}\n\n// --- Content-change guard tests ---\n\nfunc TestLessonAlreadyPresent(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tprompt  string\n\t\tlesson  *Lesson\n\t\tpresent bool\n\t}{\n\t\t{\n\t\t\tname:    \"insight present\",\n\t\t\tprompt:  \"# Prompt\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n\t\t\tlesson:  &Lesson{Insight: \"Always sanitize user inputs\", SuggestedAction: \"Add rule\"},\n\t\t\tpresent: true,\n\t\t},\n\t\t{\n\t\t\tname:    \"action present\",\n\t\t\tprompt:  \"# Prompt\\n\\n## Learned Rules\\n\\n- Add input validation for all forms\\n\",\n\t\t\tlesson:  &Lesson{Insight: \"Forms lack validation\", SuggestedAction: \"Add input validation for all forms\"},\n\t\t\tpresent: true,\n\t\t},\n\t\t{\n\t\t\tname:    \"case insensitive match\",\n\t\t\tprompt:  \"# Prompt\\n\\n## Learned Rules\\n\\n- always sanitize user inputs\\n\",\n\t\t\tlesson:  &Lesson{Insight: \"Always Sanitize User Inputs\", SuggestedAction: \"Do it\"},\n\t\t\tpresent: true,\n\t\t},\n\t\t{\n\t\t\tname:    \"not present\",\n\t\t\tprompt:  \"# Prompt\\n\\nWrite good code.\\n\",\n\t\t\tlesson:  &Lesson{Insight: \"Always sanitize user inputs\", SuggestedAction: \"Add sanitization\"},\n\t\t\tpresent: false,\n\t\t},\n\t\t{\n\t\t\tname:    \"empty insight and action\",\n\t\t\tprompt:  \"# Prompt\\n\\nWrite good code.\\n\",\n\t\t\tlesson:  &Lesson{Insight: \"\", SuggestedAction: \"\"},\n\t\t\tpresent: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, tt.present, lessonAlreadyPresent(tt.prompt, tt.lesson))\n\t\t})\n\t}\n}\n\nfunc TestCuratorSkipsWhenLessonAlreadyPresent(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\n\t// Prompt already contains the lesson insight\n\tos.WriteFile(promptPath, []byte(\"# Prompt\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"), 0644)\n\n\t// LLM should NOT be called — use a response that would change the file\n\tllm := &fakeLLM{response: \"THIS SHOULD NOT APPEAR\"}\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Always sanitize user inputs\",\n\t\tSuggestedAction: \"Add sanitization rule\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Nil(t, change, \"should return nil change when lesson already present\")\n\n\t// File should be unchanged\n\tcontent, _ := os.ReadFile(promptPath)\n\tassert.NotContains(t, string(content), \"THIS SHOULD NOT APPEAR\")\n}\n\nfunc TestReflectorFiltersAlreadyAppliedLessons(t *testing.T) {\n\tlessonsJSON, _ := json.Marshal(map[string]any{\n\t\t\"lessons\": []map[string]any{\n\t\t\t{\"id\": \"lesson-001\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n\t\t\t{\"id\": \"lesson-002\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n\t\t},\n\t})\n\n\tllm := &fakeLLM{response: string(lessonsJSON)}\n\tr := &Reflector{LLM: llm, MinConfidence: \"low\"}\n\n\t// Knowledge base already contains lesson-001\n\tdata := &CollectedData{\n\t\tKnowledgeBase: \"# Knowledge Base\\n\\n- **[lesson-001]** (prompt_improvement, confidence: high) Old insight\\n\",\n\t}\n\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n\trequire.NoError(t, err)\n\trequire.Len(t, lessons, 1)\n\tassert.Equal(t, \"lesson-002\", lessons[0].ID)\n}\n\nfunc TestOrchestratorSkipsAlreadyAppliedLessons(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.jsonl\"),\n\t\t[]byte(`{\"id\":\"L001\",\"category\":\"prompt_improvement\",\"insight\":\"XSS pattern\",\"suggested_action\":\"Add sanitization\",\"confidence\":\"high\"}`+\"\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"Write good code.\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step s {\n    run = \"echo hi\"\n    results = [success]\n  }\n  s:success -> done\n}`), 0644)\n\n\t// Reflector returns a lesson that's already in the knowledge base\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"low\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\tassert.Empty(t, result.Changes, \"should produce zero changes for already-applied lesson\")\n}\n\nfunc TestOrchestratorSecondRunProducesNoChanges(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"Write good code.\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  implement:success -> done\n  implement:fail -> abort\n}`), 0644)\n\n\t// First run: lesson gets applied\n\tllm1 := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t`{\"lessons\": [{\"id\": \"L010\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Always sanitize user inputs\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n\t\t},\n\t}\n\n\torch1 := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm1,\n\t\tMinConfidence: \"low\",\n\t})\n\n\tresult1, err := orch1.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\trequire.Len(t, result1.Changes, 1, \"first run should produce one change\")\n\n\t// Second run: same lesson ID — the knowledge base now contains L010,\n\t// and the prompt contains the insight text.\n\tllm2 := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t`{\"lessons\": [{\"id\": \"L010\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Always sanitize user inputs\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t},\n\t}\n\n\torch2 := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm2,\n\t\tMinConfidence: \"low\",\n\t})\n\n\tresult2, err := orch2.Run(context.Background(), \"run-2\", nil, nil)\n\trequire.NoError(t, err)\n\tassert.Empty(t, result2.Changes, \"second run should produce zero changes\")\n}\n","numLines":1199,"startLine":1,"totalLines":1199}}}
