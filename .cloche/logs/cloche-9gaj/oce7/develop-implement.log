{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013MfRSun5A4WuUf8aoGskFD","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"strings\"\n     9→\t\"time\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    12→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    13→)\n    14→\n    15→// OrchestratorConfig configures the evolution pipeline.\n    16→type OrchestratorConfig struct {\n    17→\tProjectDir       string\n    18→\tWorkflowName     string\n    19→\tLLM              LLMClient\n    20→\tMinConfidence    string\n    21→\tMaxPromptBullets int\n    22→}\n    23→\n    24→// Orchestrator wires all evolution pipeline stages together.\n    25→type Orchestrator struct {\n    26→\tcfg        OrchestratorConfig\n    27→\tcollector  *Collector\n    28→\tclassifier *Classifier\n    29→\treflector  *Reflector\n    30→\tcurator    *Curator\n    31→\tscriptGen  *ScriptGenerator\n    32→\tmutator    *dsl.Mutator\n    33→\taudit      *AuditLogger\n    34→}\n    35→\n    36→// NewOrchestrator creates a fully wired evolution pipeline.\n    37→func NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n    38→\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir, MaxPromptBullets: cfg.MaxPromptBullets}\n    39→\treturn &Orchestrator{\n    40→\t\tcfg:        cfg,\n    41→\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n    42→\t\tclassifier: &Classifier{LLM: cfg.LLM},\n    43→\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n    44→\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n    45→\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n    46→\t\tmutator:    &dsl.Mutator{},\n    47→\t\taudit:      audit,\n    48→\t}\n    49→}\n    50→\n    51→// Run executes the full evolution pipeline.\n    52→func (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n    53→\t// Stage 1: Collect\n    54→\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n    55→\tif err != nil {\n    56→\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n    57→\t}\n    58→\n    59→\t// Stage 2: Classify the triggering run\n    60→\tclassification, err := o.classifier.Classify(ctx, \"\")\n    61→\tif err != nil {\n    62→\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n    63→\t}\n    64→\n    65→\t// Stage 3: Reflect\n    66→\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n    67→\tif err != nil {\n    68→\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n    69→\t}\n    70→\n    71→\t// Filter out lessons whose IDs are already recorded in the knowledge base.\n    72→\t// This guards against the Reflector re-surfacing previously applied lessons.\n    73→\tif data.KnowledgeBase != \"\" {\n    74→\t\tvar fresh []Lesson\n    75→\t\tfor _, l := range lessons {\n    76→\t\t\tif l.ID != \"\" && strings.Contains(data.KnowledgeBase, l.ID) {\n    77→\t\t\t\tcontinue\n    78→\t\t\t}\n    79→\t\t\tfresh = append(fresh, l)\n    80→\t\t}\n    81→\t\tlessons = fresh\n    82→\t}\n    83→\n    84→\tresult := &EvolutionResult{\n    85→\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n    86→\t\tProjectDir:     o.cfg.ProjectDir,\n    87→\t\tWorkflowName:   o.cfg.WorkflowName,\n    88→\t\tTriggerRunID:   triggerRunID,\n    89→\t\tTimestamp:      time.Now().Format(time.RFC3339),\n    90→\t\tClassification: classification,\n    91→\t}\n    92→\n    93→\tif len(lessons) == 0 {\n    94→\t\t// No actionable lessons — log and return\n    95→\t\to.audit.Log(result)\n    96→\t\treturn result, nil\n    97→\t}\n    98→\n    99→\t// Stage 4: Execute branches based on lesson category\n   100→\tfor _, lesson := range lessons {\n   101→\t\tswitch lesson.Category {\n   102→\t\tcase \"prompt_improvement\":\n   103→\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n   104→\t\t\tif err != nil {\n   105→\t\t\t\tcontinue // log but don't fail the whole pipeline\n   106→\t\t\t}\n   107→\t\t\tif change == nil {\n   108→\t\t\t\tcontinue // lesson already present in prompt — no change needed\n   109→\t\t\t}\n   110→\t\t\tresult.Changes = append(result.Changes, *change)\n   111→\n   112→\t\tcase \"new_step\":\n   113→\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n   114→\t\t\t\tcontinue\n   115→\t\t\t}\n   116→\t\t}\n   117→\t}\n   118→\n   119→\t// Stage 5: Audit\n   120→\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n   121→\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n   122→\to.audit.Log(result)\n   123→\n   124→\t// Save to store if available\n   125→\tif evoStore != nil {\n   126→\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n   127→\t\t\tID:             result.ID,\n   128→\t\t\tProjectDir:     result.ProjectDir,\n   129→\t\t\tWorkflowName:   result.WorkflowName,\n   130→\t\t\tTriggerRunID:   result.TriggerRunID,\n   131→\t\t\tCreatedAt:      time.Now(),\n   132→\t\t\tClassification: result.Classification,\n   133→\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n   134→\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n   135→\t\t})\n   136→\t}\n   137→\n   138→\treturn result, nil\n   139→}\n   140→\n   141→// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\n   142→func (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n   143→\t// Generate the script or prompt file\n   144→\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n   145→\tif err != nil {\n   146→\t\treturn err\n   147→\t}\n   148→\n   149→\tresult.Changes = append(result.Changes, Change{\n   150→\t\tType:   \"add_script\",\n   151→\t\tFile:   generated.Path,\n   152→\t\tReason: lesson.Insight,\n   153→\t})\n   154→\n   155→\t// Add step and wiring to the workflow file\n   156→\tif data.WorkflowPath == \"\" {\n   157→\t\treturn nil\n   158→\t}\n   159→\n   160→\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n   161→\tif err != nil {\n   162→\t\treturn err\n   163→\t}\n   164→\n   165→\t// Snapshot the workflow\n   166→\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n   167→\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n   168→\toriginal := string(workflowContent)\n   169→\n   170→\t// Derive step name from the script path\n   171→\tstepName := filepath.Base(generated.Path)\n   172→\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n   173→\n   174→\t// Check if a step with this name already exists — skip if so\n   175→\texistingWf, parseErr := dsl.Parse(original)\n   176→\tif parseErr == nil {\n   177→\t\tif _, exists := existingWf.Steps[stepName]; exists {\n   178→\t\t\treturn nil\n   179→\t\t}\n   180→\t}\n   181→\n   182→\t// Determine the config based on step type\n   183→\tconfig := map[string]string{}\n   184→\tswitch lesson.StepType {\n   185→\tcase \"agent\":\n   186→\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n   187→\tdefault: // script\n   188→\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n   189→\t}\n   190→\n   191→\t// Add the step\n   192→\tupdated, err := o.mutator.AddStep(original, dsl.StepDef{\n   193→\t\tName:    stepName,\n   194→\t\tType:    lesson.StepType,\n   195→\t\tConfig:  config,\n   196→\t\tResults: []string{\"success\", \"fail\"},\n   197→\t})\n   198→\tif err != nil {\n   199→\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n   200→\t}\n   201→\n   202→\t// Wire the new step into the existing graph by finding a wire\n   203→\t// that currently goes to \"done\" and rerouting it through the new step.\n   204→\twf, parseErr := dsl.Parse(updated)\n   205→\tif parseErr == nil {\n   206→\t\tfor _, wire := range wf.Wiring {\n   207→\t\t\tif wire.To == \"done\" {\n   208→\t\t\t\trewired, rewireErr := o.mutator.RewireResult(updated, wire.From, wire.Result, \"done\", stepName)\n   209→\t\t\t\tif rewireErr == nil {\n   210→\t\t\t\t\tupdated = rewired\n   211→\t\t\t\t\tbreak\n   212→\t\t\t\t}\n   213→\t\t\t}\n   214→\t\t}\n   215→\t}\n   216→\n   217→\t// Wire the new step's results to terminals\n   218→\twires := []dsl.WireDef{\n   219→\t\t{From: stepName, Result: \"success\", To: \"done\"},\n   220→\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n   221→\t}\n   222→\tupdated, err = o.mutator.AddWiring(updated, wires)\n   223→\tif err != nil {\n   224→\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n   225→\t}\n   226→\n   227→\t// Validate the final workflow graph — roll back on failure\n   228→\tfinalWf, parseErr := dsl.Parse(updated)\n   229→\tif parseErr != nil {\n   230→\t\treturn fmt.Errorf(\"parsing updated workflow: %w\", parseErr)\n   231→\t}\n   232→\tif valErr := finalWf.Validate(); valErr != nil {\n   233→\t\treturn fmt.Errorf(\"workflow validation failed after adding step %q: %w\", stepName, valErr)\n   234→\t}\n   235→\n   236→\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n   237→\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n   238→\t}\n   239→\n   240→\tresult.Changes = append(result.Changes, Change{\n   241→\t\tType:     \"add_step\",\n   242→\t\tFile:     wfRelPath,\n   243→\t\tReason:   lesson.Insight,\n   244→\t\tSnapshot: snapName,\n   245→\t})\n   246→\n   247→\treturn nil\n   248→}\n   249→"}]},"parent_tool_use_id":null,"session_id":"ee4b9d5f-226b-4cd1-9d2c-3cf327fb6206","uuid":"62256433-bb58-48e0-bb4f-dea1d051f1fe","timestamp":"2026-03-18T16:10:48.635Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/orchestrator.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// OrchestratorConfig configures the evolution pipeline.\ntype OrchestratorConfig struct {\n\tProjectDir       string\n\tWorkflowName     string\n\tLLM              LLMClient\n\tMinConfidence    string\n\tMaxPromptBullets int\n}\n\n// Orchestrator wires all evolution pipeline stages together.\ntype Orchestrator struct {\n\tcfg        OrchestratorConfig\n\tcollector  *Collector\n\tclassifier *Classifier\n\treflector  *Reflector\n\tcurator    *Curator\n\tscriptGen  *ScriptGenerator\n\tmutator    *dsl.Mutator\n\taudit      *AuditLogger\n}\n\n// NewOrchestrator creates a fully wired evolution pipeline.\nfunc NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir, MaxPromptBullets: cfg.MaxPromptBullets}\n\treturn &Orchestrator{\n\t\tcfg:        cfg,\n\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n\t\tclassifier: &Classifier{LLM: cfg.LLM},\n\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n\t\tmutator:    &dsl.Mutator{},\n\t\taudit:      audit,\n\t}\n}\n\n// Run executes the full evolution pipeline.\nfunc (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n\t// Stage 1: Collect\n\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n\t}\n\n\t// Stage 2: Classify the triggering run\n\tclassification, err := o.classifier.Classify(ctx, \"\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n\t}\n\n\t// Stage 3: Reflect\n\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n\t}\n\n\t// Filter out lessons whose IDs are already recorded in the knowledge base.\n\t// This guards against the Reflector re-surfacing previously applied lessons.\n\tif data.KnowledgeBase != \"\" {\n\t\tvar fresh []Lesson\n\t\tfor _, l := range lessons {\n\t\t\tif l.ID != \"\" && strings.Contains(data.KnowledgeBase, l.ID) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfresh = append(fresh, l)\n\t\t}\n\t\tlessons = fresh\n\t}\n\n\tresult := &EvolutionResult{\n\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n\t\tProjectDir:     o.cfg.ProjectDir,\n\t\tWorkflowName:   o.cfg.WorkflowName,\n\t\tTriggerRunID:   triggerRunID,\n\t\tTimestamp:      time.Now().Format(time.RFC3339),\n\t\tClassification: classification,\n\t}\n\n\tif len(lessons) == 0 {\n\t\t// No actionable lessons — log and return\n\t\to.audit.Log(result)\n\t\treturn result, nil\n\t}\n\n\t// Stage 4: Execute branches based on lesson category\n\tfor _, lesson := range lessons {\n\t\tswitch lesson.Category {\n\t\tcase \"prompt_improvement\":\n\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // log but don't fail the whole pipeline\n\t\t\t}\n\t\t\tif change == nil {\n\t\t\t\tcontinue // lesson already present in prompt — no change needed\n\t\t\t}\n\t\t\tresult.Changes = append(result.Changes, *change)\n\n\t\tcase \"new_step\":\n\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\t}\n\n\t// Stage 5: Audit\n\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n\to.audit.Log(result)\n\n\t// Save to store if available\n\tif evoStore != nil {\n\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n\t\t\tID:             result.ID,\n\t\t\tProjectDir:     result.ProjectDir,\n\t\t\tWorkflowName:   result.WorkflowName,\n\t\t\tTriggerRunID:   result.TriggerRunID,\n\t\t\tCreatedAt:      time.Now(),\n\t\t\tClassification: result.Classification,\n\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n\t\t})\n\t}\n\n\treturn result, nil\n}\n\n// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\nfunc (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n\t// Generate the script or prompt file\n\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tresult.Changes = append(result.Changes, Change{\n\t\tType:   \"add_script\",\n\t\tFile:   generated.Path,\n\t\tReason: lesson.Insight,\n\t})\n\n\t// Add step and wiring to the workflow file\n\tif data.WorkflowPath == \"\" {\n\t\treturn nil\n\t}\n\n\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// Snapshot the workflow\n\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n\toriginal := string(workflowContent)\n\n\t// Derive step name from the script path\n\tstepName := filepath.Base(generated.Path)\n\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n\n\t// Check if a step with this name already exists — skip if so\n\texistingWf, parseErr := dsl.Parse(original)\n\tif parseErr == nil {\n\t\tif _, exists := existingWf.Steps[stepName]; exists {\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Determine the config based on step type\n\tconfig := map[string]string{}\n\tswitch lesson.StepType {\n\tcase \"agent\":\n\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n\tdefault: // script\n\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n\t}\n\n\t// Add the step\n\tupdated, err := o.mutator.AddStep(original, dsl.StepDef{\n\t\tName:    stepName,\n\t\tType:    lesson.StepType,\n\t\tConfig:  config,\n\t\tResults: []string{\"success\", \"fail\"},\n\t})\n\tif err != nil {\n\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n\t}\n\n\t// Wire the new step into the existing graph by finding a wire\n\t// that currently goes to \"done\" and rerouting it through the new step.\n\twf, parseErr := dsl.Parse(updated)\n\tif parseErr == nil {\n\t\tfor _, wire := range wf.Wiring {\n\t\t\tif wire.To == \"done\" {\n\t\t\t\trewired, rewireErr := o.mutator.RewireResult(updated, wire.From, wire.Result, \"done\", stepName)\n\t\t\t\tif rewireErr == nil {\n\t\t\t\t\tupdated = rewired\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Wire the new step's results to terminals\n\twires := []dsl.WireDef{\n\t\t{From: stepName, Result: \"success\", To: \"done\"},\n\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n\t}\n\tupdated, err = o.mutator.AddWiring(updated, wires)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n\t}\n\n\t// Validate the final workflow graph — roll back on failure\n\tfinalWf, parseErr := dsl.Parse(updated)\n\tif parseErr != nil {\n\t\treturn fmt.Errorf(\"parsing updated workflow: %w\", parseErr)\n\t}\n\tif valErr := finalWf.Validate(); valErr != nil {\n\t\treturn fmt.Errorf(\"workflow validation failed after adding step %q: %w\", stepName, valErr)\n\t}\n\n\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n\t}\n\n\tresult.Changes = append(result.Changes, Change{\n\t\tType:     \"add_step\",\n\t\tFile:     wfRelPath,\n\t\tReason:   lesson.Insight,\n\t\tSnapshot: snapName,\n\t})\n\n\treturn nil\n}\n","numLines":249,"startLine":1,"totalLines":249}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01QaZtRvqVVSquMQKbGFG3Ut","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Kk3Gm7R5gbofnrHAKroZJE","name":"Read","input":{"file_path":"/workspace/internal/evolution/population.go"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":441,"cache_read_input_tokens":17119,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":441},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ee4b9d5f-226b-4cd1-9d2c-3cf327fb6206","uuid":"199d67a9-98d2-491b-af9b-8d5c59660412"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kk3Gm7R5gbofnrHAKroZJE","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"encoding/json\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"strings\"\n     9→\t\"time\"\n    10→)\n    11→\n    12→// Population manages candidate prompt variants for a single workflow step.\n    13→// Disk layout:\n    14→//\n    15→//\t.cloche/evolution/population/<step-name>/\n    16→//\t  candidate-001.md\n    17→//\t  candidate-002.md\n    18→//\t  meta.jsonl\n    19→//\t  assignments.jsonl\n    20→type Population struct {\n    21→\tProjectDir string\n    22→\tStepName   string\n    23→}\n    24→\n    25→// CandidateMeta is one JSONL entry in meta.jsonl.\n    26→type CandidateMeta struct {\n    27→\tID        string  `json:\"id\"`        // e.g. \"candidate-001\"\n    28→\tStatus    string  `json:\"status\"`    // \"active\", \"archived\", \"promoted\"\n    29→\tCreatedAt string  `json:\"created_at\"`\n    30→\tParentID  string  `json:\"parent_id,omitempty\"` // ID of the candidate this was derived from\n    31→\tScore     float64 `json:\"score,omitempty\"`\n    32→}\n    33→\n    34→// Assignment maps a workflow run to the candidate it used.\n    35→type Assignment struct {\n    36→\tRunID       string `json:\"run_id\"`\n    37→\tCandidateID string `json:\"candidate_id\"`\n    38→\tAssignedAt  string `json:\"assigned_at\"`\n    39→}\n    40→\n    41→const (\n    42→\tcandidateStatusActive   = \"active\"\n    43→\tcandidateStatusArchived = \"archived\"\n    44→\tcandidateStatusPromoted = \"promoted\"\n    45→)\n    46→\n    47→// populationDir returns the directory for this step's population.\n    48→func (p *Population) populationDir() string {\n    49→\treturn filepath.Join(p.ProjectDir, \".cloche\", \"evolution\", \"population\", p.StepName)\n    50→}\n    51→\n    52→func (p *Population) metaPath() string {\n    53→\treturn filepath.Join(p.populationDir(), \"meta.jsonl\")\n    54→}\n    55→\n    56→func (p *Population) assignmentsPath() string {\n    57→\treturn filepath.Join(p.populationDir(), \"assignments.jsonl\")\n    58→}\n    59→\n    60→func (p *Population) candidatePath(id string) string {\n    61→\treturn filepath.Join(p.populationDir(), id+\".md\")\n    62→}\n    63→\n    64→// AddCandidate writes a new candidate prompt file and appends its metadata.\n    65→// Returns the assigned candidate ID (e.g. \"candidate-003\").\n    66→func (p *Population) AddCandidate(content string, parentID string) (string, error) {\n    67→\tdir := p.populationDir()\n    68→\tif err := os.MkdirAll(dir, 0755); err != nil {\n    69→\t\treturn \"\", fmt.Errorf(\"creating population dir: %w\", err)\n    70→\t}\n    71→\n    72→\t// Determine next candidate number from existing meta.\n    73→\tall, err := p.readMeta()\n    74→\tif err != nil {\n    75→\t\treturn \"\", fmt.Errorf(\"reading meta: %w\", err)\n    76→\t}\n    77→\n    78→\tnextNum := len(all) + 1\n    79→\tid := fmt.Sprintf(\"candidate-%03d\", nextNum)\n    80→\n    81→\t// Write prompt file.\n    82→\tif err := os.WriteFile(p.candidatePath(id), []byte(content), 0644); err != nil {\n    83→\t\treturn \"\", fmt.Errorf(\"writing candidate file: %w\", err)\n    84→\t}\n    85→\n    86→\t// Append meta entry.\n    87→\tmeta := CandidateMeta{\n    88→\t\tID:        id,\n    89→\t\tStatus:    candidateStatusActive,\n    90→\t\tCreatedAt: time.Now().UTC().Format(time.RFC3339),\n    91→\t\tParentID:  parentID,\n    92→\t}\n    93→\tif err := p.appendMeta(meta); err != nil {\n    94→\t\treturn \"\", fmt.Errorf(\"appending meta: %w\", err)\n    95→\t}\n    96→\n    97→\treturn id, nil\n    98→}\n    99→\n   100→// ListCandidates returns metadata for all active candidates.\n   101→func (p *Population) ListCandidates() ([]CandidateMeta, error) {\n   102→\tall, err := p.readMeta()\n   103→\tif err != nil {\n   104→\t\treturn nil, fmt.Errorf(\"reading meta: %w\", err)\n   105→\t}\n   106→\n   107→\tvar active []CandidateMeta\n   108→\tfor _, m := range all {\n   109→\t\tif m.Status == candidateStatusActive {\n   110→\t\t\tactive = append(active, m)\n   111→\t\t}\n   112→\t}\n   113→\treturn active, nil\n   114→}\n   115→\n   116→// GetContent reads the prompt content for a candidate.\n   117→func (p *Population) GetContent(candidateID string) (string, error) {\n   118→\tdata, err := os.ReadFile(p.candidatePath(candidateID))\n   119→\tif err != nil {\n   120→\t\treturn \"\", fmt.Errorf(\"reading candidate %s: %w\", candidateID, err)\n   121→\t}\n   122→\treturn string(data), nil\n   123→}\n   124→\n   125→// Promote snapshots the current base prompt, copies the winner as the new base,\n   126→// and archives all other active candidates.\n   127→func (p *Population) Promote(winnerID string, basePath string) error {\n   128→\tall, err := p.readMeta()\n   129→\tif err != nil {\n   130→\t\treturn fmt.Errorf(\"reading meta: %w\", err)\n   131→\t}\n   132→\n   133→\t// Verify winner exists and is active.\n   134→\tfound := false\n   135→\tfor _, m := range all {\n   136→\t\tif m.ID == winnerID && m.Status == candidateStatusActive {\n   137→\t\t\tfound = true\n   138→\t\t\tbreak\n   139→\t\t}\n   140→\t}\n   141→\tif !found {\n   142→\t\treturn fmt.Errorf(\"candidate %s not found or not active\", winnerID)\n   143→\t}\n   144→\n   145→\t// Snapshot the current base prompt.\n   146→\tsnapDir := filepath.Join(p.ProjectDir, \".cloche\", \"evolution\", \"snapshots\")\n   147→\tif err := os.MkdirAll(snapDir, 0755); err != nil {\n   148→\t\treturn fmt.Errorf(\"creating snapshots dir: %w\", err)\n   149→\t}\n   150→\n   151→\tabsBase := basePath\n   152→\tif !filepath.IsAbs(basePath) {\n   153→\t\tabsBase = filepath.Join(p.ProjectDir, basePath)\n   154→\t}\n   155→\n   156→\tbaseData, err := os.ReadFile(absBase)\n   157→\tif err != nil && !os.IsNotExist(err) {\n   158→\t\treturn fmt.Errorf(\"reading base prompt: %w\", err)\n   159→\t}\n  