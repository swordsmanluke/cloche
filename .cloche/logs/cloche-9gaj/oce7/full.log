[2026-03-18T16:11:00Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kk3Gm7R5gbofnrHAKroZJE","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"encoding/json\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"strings\"\n     9→\t\"time\"\n    10→)\n    11→\n    12→// Population manages candidate prompt variants for a single workflow step.\n    13→// Disk layout:\n    14→//\n    15→//\t.cloche/evolution/population/<step-name>/\n    16→//\t  candidate-001.md\n    17→//\t  candidate-002.md\n    18→//\t  meta.jsonl\n    19→//\t  assignments.jsonl\n    20→type Population struct {\n    21→\tProjectDir string\n    22→\tStepName   string\n    23→}\n    24→\n    25→// CandidateMeta is one JSONL entry in meta.jsonl.\n    26→type CandidateMeta struct {\n    27→\tID        string  `json:\"id\"`        // e.g. \"candidate-001\"\n    28→\tStatus    string  `json:\"status\"`    // \"active\", \"archived\", \"promoted\"\n    29→\tCreatedAt string  `json:\"created_at\"`\n    30→\tParentID  string  `json:\"parent_id,omitempty\"` // ID of the candidate this was derived from\n    31→\tScore     float64 `json:\"score,omitempty\"`\n    32→}\n    33→\n    34→// Assignment maps a workflow run to the candidate it used.\n    35→type Assignment struct {\n    36→\tRunID       string `json:\"run_id\"`\n    37→\tCandidateID string `json:\"candidate_id\"`\n    38→\tAssignedAt  string `json:\"assigned_at\"`\n    39→}\n    40→\n    41→const (\n    42→\tcandidateStatusActive   = \"active\"\n    43→\tcandidateStatusArchived = \"archived\"\n    44→\tcandidateStatusPromoted = \"promoted\"\n    45→)\n    46→\n    47→// populationDir returns the directory for this step's population.\n    48→func (p *Population) populationDir() string {\n    49→\treturn filepath.Join(p.ProjectDir, \".cloche\", \"evolution\", \"population\", p.StepName)\n    50→}\n    51→\n    52→func (p *Population) metaPath() string {\n    53→\treturn filepath.Join(p.populationDir(), \"meta.jsonl\")\n    54→}\n    55→\n    56→func (p *Population) assignmentsPath() string {\n    57→\treturn filepath.Join(p.populationDir(), \"assignments.jsonl\")\n    58→}\n    59→\n    60→func (p *Population) candidatePath(id string) string {\n    61→\treturn filepath.Join(p.populationDir(), id+\".md\")\n    62→}\n    63→\n    64→// AddCandidate writes a new candidate prompt file and appends its metadata.\n    65→// Returns the assigned candidate ID (e.g. \"candidate-003\").\n    66→func (p *Population) AddCandidate(content string, parentID string) (string, error) {\n    67→\tdir := p.populationDir()\n    68→\tif err := os.MkdirAll(dir, 0755); err != nil {\n    69→\t\treturn \"\", fmt.Errorf(\"creating population dir: %w\", err)\n    70→\t}\n    71→\n    72→\t// Determine next candidate number from existing meta.\n    73→\tall, err := p.readMeta()\n    74→\tif err != nil {\n    75→\t\treturn \"\", fmt.Errorf(\"reading meta: %w\", err)\n    76→\t}\n    77→\n    78→\tnextNum := len(all) + 1\n    79→\tid := fmt.Sprintf(\"candidate-%03d\", nextNum)\n    80→\n    81→\t// Write prompt file.\n    82→\tif err := os.WriteFile(p.candidatePath(id), []byte(content), 0644); err != nil {\n    83→\t\treturn \"\", fmt.Errorf(\"writing candidate file: %w\", err)\n    84→\t}\n    85→\n    86→\t// Append meta entry.\n    87→\tmeta := CandidateMeta{\n    88→\t\tID:        id,\n    89→\t\tStatus:    candidateStatusActive,\n    90→\t\tCreatedAt: time.Now().UTC().Format(time.RFC3339),\n    91→\t\tParentID:  parentID,\n    92→\t}\n    93→\tif err := p.appendMeta(meta); err != nil {\n    94→\t\treturn \"\", fmt.Errorf(\"appending meta: %w\", err)\n    95→\t}\n    96→\n    97→\treturn id, nil\n    98→}\n    99→\n   100→// ListCandidates returns metadata for all active candidates.\n   101→func (p *Population) ListCandidates() ([]CandidateMeta, error) {\n   102→\tall, err := p.readMeta()\n   103→\tif err != nil {\n   104→\t\treturn nil, fmt.Errorf(\"reading meta: %w\", err)\n   105→\t}\n   106→\n   107→\tvar active []CandidateMeta\n   108→\tfor _, m := range all {\n   109→\t\tif m.Status == candidateStatusActive {\n   110→\t\t\tactive = append(active, m)\n   111→\t\t}\n   112→\t}\n   113→\treturn active, nil\n   114→}\n   115→\n   116→// GetContent reads the prompt content for a candidate.\n   117→func (p *Population) GetContent(candidateID string) (string, error) {\n   118→\tdata, err := os.ReadFile(p.candidatePath(candidateID))\n   119→\tif err != nil {\n   120→\t\treturn \"\", fmt.Errorf(\"reading candidate %s: %w\", candidateID, err)\n   121→\t}\n   122→\treturn string(data), nil\n   123→}\n   124→\n   125→// Promote snapshots the current base prompt, copies the winner as the new base,\n   126→// and archives all other active candidates.\n   127→func (p *Population) Promote(winnerID string, basePath string) error {\n   128→\tall, err := p.readMeta()\n   129→\tif err != nil {\n   130→\t\treturn fmt.Errorf(\"reading meta: %w\", err)\n   131→\t}\n   132→\n   133→\t// Verify winner exists and is active.\n   134→\tfound := false\n   135→\tfor _, m := range all {\n   136→\t\tif m.ID == winnerID && m.Status == candidateStatusActive {\n   137→\t\t\tfound = true\n   138→\t\t\tbreak\n   139→\t\t}\n   140→\t}\n   141→\tif !found {\n   142→\t\treturn fmt.Errorf(\"candidate %s not found or not active\", winnerID)\n   143→\t}\n   144→\n   145→\t// Snapshot the current base prompt.\n   146→\tsnapDir := filepath.Join(p.ProjectDir, \".cloche\", \"evolution\", \"snapshots\")\n   147→\tif err := os.MkdirAll(snapDir, 0755); err != nil {\n   148→\t\treturn fmt.Errorf(\"creating snapshots dir: %w\", err)\n   149→\t}\n   150→\n   151→\tabsBase := basePath\n   152→\tif !filepath.IsAbs(basePath) {\n   153→\t\tabsBase = filepath.Join(p.ProjectDir, basePath)\n   154→\t}\n   155→\n   156→\tbaseData, err := os.ReadFile(absBase)\n   157→\tif err != nil && !os.IsNotExist(err) {\n   158→\t\treturn fmt.Errorf(\"reading base prompt: %w\", err)\n   159→\t}\n   160→\n   161→\tif err == nil {\n   162→\t\tsnapName := fmt.Sprintf(\"%s-%s-base%s\",\n   163→\t\t\ttime.Now().UTC().Format(\"20060102T150405\"),\n   164→\t\t\tp.StepName,\n   165→\t\t\tfilepath.Ext(basePath),\n   166→\t\t)\n   167→\t\tif err := os.WriteFile(filepath.Join(snapDir, snapName), baseData, 0644); err != nil {\n   168→\t\t\treturn fmt.Errorf(\"writing snapshot: %w\", err)\n   169→\t\t}\n   170→\t}\n   171→\n   172→\t// Copy winner content to base path.\n   173→\twinnerContent, err := p.GetContent(winnerID)\n   174→\tif err != nil {\n   175→\t\treturn fmt.Errorf(\"reading winner content: %w\", err)\n   176→\t}\n   177→\tif err := os.MkdirAll(filepath.Dir(absBase), 0755); err != nil {\n   178→\t\treturn fmt.Errorf(\"creating base dir: %w\", err)\n   179→\t}\n   180→\tif err := os.WriteFile(absBase, []byte(winnerContent), 0644); err != nil {\n   181→\t\treturn fmt.Errorf(\"writing promoted content to base: %w\", err)\n   182→\t}\n   183→\n   184→\t// Update statuses: winner -> promoted, others -> archived.\n   185→\tfor i := range all {\n   186→\t\tif all[i].Status != candidateStatusActive {\n   187→\t\t\tcontinue\n   188→\t\t}\n   189→\t\tif all[i].ID == winnerID {\n   190→\t\t\tall[i].Status = candidateStatusPromoted\n   191→\t\t} else {\n   192→\t\t\tall[i].Status = candidateStatusArchived\n   193→\t\t}\n   194→\t}\n   195→\n   196→\treturn p.writeMeta(all)\n   197→}\n   198→\n   199→// RecordAssignment tracks which candidate was used for a workflow run.\n   200→func (p *Population) RecordAssignment(runID, candidateID string) error {\n   201→\tdir := p.populationDir()\n   202→\tif err := os.MkdirAll(dir, 0755); err != nil {\n   203→\t\treturn fmt.Errorf(\"creating population dir: %w\", err)\n   204→\t}\n   205→\n   206→\ta := Assignment{\n   207→\t\tRunID:       runID,\n   208→\t\tCandidateID: candidateID,\n   209→\t\tAssignedAt:  time.Now().UTC().Format(time.RFC3339),\n   210→\t}\n   211→\n   212→\tdata, err := json.Marshal(a)\n   213→\tif err != nil {\n   214→\t\treturn fmt.Errorf(\"marshaling assignment: %w\", err)\n   215→\t}\n   216→\n   217→\tf, err := os.OpenFile(p.assignmentsPath(), os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644)\n   218→\tif err != nil {\n   219→\t\treturn fmt.Errorf(\"opening assignments file: %w\", err)\n   220→\t}\n   221→\tdefer f.Close()\n   222→\n   223→\tif _, err := f.Write(append(data, '\\n')); err != nil {\n   224→\t\treturn fmt.Errorf(\"writing assignment: %w\", err)\n   225→\t}\n   226→\n   227→\treturn nil\n   228→}\n   229→\n   230→// GetAssignment returns the candidate ID assigned to a run, or empty string if none.\n   231→func (p *Population) GetAssignment(runID string) (string, error) {\n   232→\tdata, err := os.ReadFile(p.assignmentsPath())\n   233→\tif os.IsNotExist(err) {\n   234→\t\treturn \"\", nil\n   235→\t}\n   236→\tif err != nil {\n   237→\t\treturn \"\", fmt.Errorf(\"reading assignments: %w\", err)\n   238→\t}\n   239→\n   240→\tfor _, line := range strings.Split(strings.TrimSpace(string(data)), \"\\n\") {\n   241→\t\tline = strings.TrimSpace(line)\n   242→\t\tif line == \"\" {\n   243→\t\t\tcontinue\n   244→\t\t}\n   245→\t\tvar a Assignment\n   246→\t\tif err := json.Unmarshal([]byte(line), &a); err != nil {\n   247→\t\t\tcontinue\n   248→\t\t}\n   249→\t\tif a.RunID == runID {\n   250→\t\t\treturn a.CandidateID, nil\n   251→\t\t}\n   252→\t}\n   253→\n   254→\treturn \"\", nil\n   255→}\n   256→\n   257→// readMeta reads all entries from meta.jsonl.\n   258→func (p *Population) readMeta() ([]CandidateMeta, error) {\n   259→\tdata, err := os.ReadFile(p.metaPath())\n   260→\tif os.IsNotExist(err) {\n   261→\t\treturn nil, nil\n   262→\t}\n   263→\tif err != nil {\n   264→\t\treturn nil, err\n   265→\t}\n   266→\n   267→\tvar entries []CandidateMeta\n   268→\tfor _, line := range strings.Split(strings.TrimSpace(string(data)), \"\\n\") {\n   269→\t\tline = strings.TrimSpace(line)\n   270→\t\tif line == \"\" {\n   271→\t\t\tcontinue\n   272→\t\t}\n   273→\t\tvar m CandidateMeta\n   274→\t\tif err := json.Unmarshal([]byte(line), &m); err != nil {\n   275→\t\t\tcontinue\n   276→\t\t}\n   277→\t\tentries = append(entries, m)\n   278→\t}\n   279→\treturn entries, nil\n   280→}\n   281→\n   282→// appendMeta appends a single meta entry to meta.jsonl.\n   283→func (p *Population) appendMeta(meta CandidateMeta) error {\n   284→\tdata, err := json.Marshal(meta)\n   285→\tif err != nil {\n   286→\t\treturn err\n   287→\t}\n   288→\n   289→\tf, err := os.OpenFile(p.metaPath(), os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644)\n   290→\tif err != nil {\n   291→\t\treturn err\n   292→\t}\n   293→\tdefer f.Close()\n   294→\n   295→\t_, err = f.Write(append(data, '\\n'))\n   296→\treturn err\n   297→}\n   298→\n   299→// writeMeta overwrites meta.jsonl with the given entries.\n   300→func (p *Population) writeMeta(entries []CandidateMeta) error {\n   301→\tif err := os.MkdirAll(p.populationDir(), 0755); err != nil {\n   302→\t\treturn fmt.Errorf(\"creating population dir: %w\", err)\n   303→\t}\n   304→\n   305→\tvar sb strings.Builder\n   306→\tfor _, m := range entries {\n   307→\t\tdata, err := json.Marshal(m)\n   308→\t\tif err != nil {\n   309→\t\t\tcontinue\n   310→\t\t}\n   311→\t\tsb.Write(data)\n   312→\t\tsb.WriteByte('\\n')\n   313→\t}\n   314→\treturn os.WriteFile(p.metaPath(), []byte(sb.String()), 0644)\n   315→}\n   316→"}]},"parent_tool_use_id":null,"session_id":"ee4b9d5f-226b-4cd1-9d2c-3cf327fb6206","uuid":"3c80aad2-b280-4f6a-aa4f-4f08135495e9","timestamp":"2026-03-18T16:10:49.098Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/population.go","content":"package evolution\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n)\n\n// Population manages candidate prompt variants for a single workflow step.\n// Disk layout:\n//\n//\t.cloche/evolution/population/<step-name>/\n//\t  candidate-001.md\n//\t  candidate-002.md\n//\t  meta.jsonl\n//\t  assignments.jsonl\ntype Population struct {\n\tProjectDir string\n\tStepName   string\n}\n\n// CandidateMeta is one JSONL entry in meta.jsonl.\ntype CandidateMeta struct {\n\tID        string  `json:\"id\"`        // e.g. \"candidate-001\"\n\tStatus    string  `json:\"status\"`    // \"active\", \"archived\", \"promoted\"\n\tCreatedAt string  `json:\"created_at\"`\n\tParentID  string  `json:\"parent_id,omitempty\"` // ID of the candidate this was derived from\n\tScore     float64 `json:\"score,omitempty\"`\n}\n\n// Assignment maps a workflow run to the candidate it used.\ntype Assignment struct {\n\tRunID       string `json:\"run_id\"`\n\tCandidateID string `json:\"candidate_id\"`\n\tAssignedAt  string `json:\"assigned_at\"`\n}\n\nconst (\n\tcandidateStatusActive   = \"active\"\n\tcandidateStatusArchived = \"archived\"\n\tcandidateStatusPromoted = \"promoted\"\n)\n\n// populationDir returns the directory for this step's population.\nfunc (p *Population) populationDir() string {\n\treturn filepath.Join(p.ProjectDir, \".cloche\", \"evolution\", \"population\", p.StepName)\n}\n\nfunc (p *Population) metaPath() string {\n\treturn filepath.Join(p.populationDir(), \"meta.jsonl\")\n}\n\nfunc (p *Population) assignmentsPath() string {\n\treturn filepath.Join(p.populationDir(), \"assignments.jsonl\")\n}\n\nfunc (p *Population) candidatePath(id string) string {\n\treturn filepath.Join(p.populationDir(), id+\".md\")\n}\n\n// AddCandidate writes a new candidate prompt file and appends its metadata.\n// Returns the assigned candidate ID (e.g. \"candidate-003\").\nfunc (p *Population) AddCandidate(content string, parentID string) (string, error) {\n\tdir := p.populationDir()\n\tif err := os.MkdirAll(dir, 0755); err != nil {\n\t\treturn \"\", fmt.Errorf(\"creating population dir: %w\", err)\n\t}\n\n\t// Determine next candidate number from existing meta.\n\tall, err := p.readMeta()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"reading meta: %w\", err)\n\t}\n\n\tnextNum := len(all) + 1\n\tid := fmt.Sprintf(\"candidate-%03d\", nextNum)\n\n\t// Write prompt file.\n\tif err := os.WriteFile(p.candidatePath(id), []byte(content), 0644); err != nil {\n\t\treturn \"\", fmt.Errorf(\"writing candidate file: %w\", err)\n\t}\n\n\t// Append meta entry.\n\tmeta := CandidateMeta{\n\t\tID:        id,\n\t\tStatus:    candidateStatusActive,\n\t\tCreatedAt: time.Now().UTC().Format(time.RFC3339),\n\t\tParentID:  parentID,\n\t}\n\tif err := p.appendMeta(meta); err != nil {\n\t\treturn \"\", fmt.Errorf(\"appending meta: %w\", err)\n\t}\n\n\treturn id, nil\n}\n\n// ListCandidates returns metadata for all active candidates.\nfunc (p *Population) ListCandidates() ([]CandidateMeta, error) {\n\tall, err := p.readMeta()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading meta: %w\", err)\n\t}\n\n\tvar active []CandidateMeta\n\tfor _, m := range all {\n\t\tif m.Status == candidateStatusActive {\n\t\t\tactive = append(active, m)\n\t\t}\n\t}\n\treturn active, nil\n}\n\n// GetContent reads the prompt content for a candidate.\nfunc (p *Population) GetContent(candidateID string) (string, error) {\n\tdata, err := os.ReadFile(p.candidatePath(candidateID))\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"reading candidate %s: %w\", candidateID, err)\n\t}\n\treturn string(data), nil\n}\n\n// Promote snapshots the current base prompt, copies the winner as the new base,\n// and archives all other active candidates.\nfunc (p *Population) Promote(winnerID string, basePath string) error {\n\tall, err := p.readMeta()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"reading meta: %w\", err)\n\t}\n\n\t// Verify winner exists and is active.\n\tfound := false\n\tfor _, m := range all {\n\t\tif m.ID == winnerID && m.Status == candidateStatusActive {\n\t\t\tfound = true\n\t\t\tbreak\n\t\t}\n\t}\n\tif !found {\n\t\treturn fmt.Errorf(\"candidate %s not found or not active\", winnerID)\n\t}\n\n\t// Snapshot the current base prompt.\n\tsnapDir := filepath.Join(p.ProjectDir, \".cloche\", \"evolution\", \"snapshots\")\n\tif err := os.MkdirAll(snapDir, 0755); err != nil {\n\t\treturn fmt.Errorf(\"creating snapshots dir: %w\", err)\n\t}\n\n\tabsBase := basePath\n\tif !filepath.IsAbs(basePath) {\n\t\tabsBase = filepath.Join(p.ProjectDir, basePath)\n\t}\n\n\tbaseData, err := os.ReadFile(absBase)\n\tif err != nil && !os.IsNotExist(err) {\n\t\treturn fmt.Errorf(\"reading base prompt: %w\", err)\n\t}\n\n\tif err == nil {\n\t\tsnapName := fmt.Sprintf(\"%s-%s-base%s\",\n\t\t\ttime.Now().UTC().Format(\"20060102T150405\"),\n\t\t\tp.StepName,\n\t\t\tfilepath.Ext(basePath),\n\t\t)\n\t\tif err := os.WriteFile(filepath.Join(snapDir, snapName), baseData, 0644); err != nil {\n\t\t\treturn fmt.Errorf(\"writing snapshot: %w\", err)\n\t\t}\n\t}\n\n\t// Copy winner content to base path.\n\twinnerContent, err := p.GetContent(winnerID)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"reading winner content: %w\", err)\n\t}\n\tif err := os.MkdirAll(filepath.Dir(absBase), 0755); err != nil {\n\t\treturn fmt.Errorf(\"creating base dir: %w\", err)\n\t}\n\tif err := os.WriteFile(absBase, []byte(winnerContent), 0644); err != nil {\n\t\treturn fmt.Errorf(\"writing promoted content to base: %w\", err)\n\t}\n\n\t// Update statuses: winner -> promoted, others -> archived.\n\tfor i := range all {\n\t\tif all[i].Status != candidateStatusActive {\n\t\t\tcontinue\n\t\t}\n\t\tif all[i].ID == winnerID {\n\t\t\tall[i].Status = candidateStatusPromoted\n\t\t} else {\n\t\t\tall[i].Status = candidateStatusArchived\n\t\t}\n\t}\n\n\treturn p.writeMeta(all)\n}\n\n// RecordAssignment tracks which candidate was used for a workflow run.\nfunc (p *Population) RecordAssignment(runID, candidateID string) error {\n\tdir := p.populationDir()\n\tif err := os.MkdirAll(dir, 0755); err != nil {\n\t\treturn fmt.Errorf(\"creating population dir: %w\", err)\n\t}\n\n\ta := Assignment{\n\t\tRunID:       runID,\n\t\tCandidateID: candidateID,\n\t\tAssignedAt:  time.Now().UTC().Format(time.RFC3339),\n\t}\n\n\tdata, err := json.Marshal(a)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"marshaling assignment: %w\", err)\n\t}\n\n\tf, err := os.OpenFile(p.assignmentsPath(), os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"opening assignments file: %w\", err)\n\t}\n\tdefer f.Close()\n\n\tif _, err := f.Write(append(data, '\\n')); err != nil {\n\t\treturn fmt.Errorf(\"writing assignment: %w\", err)\n\t}\n\n\treturn nil\n}\n\n// GetAssignment returns the candidate ID assigned to a run, or empty string if none.\nfunc (p *Population) GetAssignment(runID string) (string, error) {\n\tdata, err := os.ReadFile(p.assignmentsPath())\n\tif os.IsNotExist(err) {\n\t\treturn \"\", nil\n\t}\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"reading assignments: %w\", err)\n\t}\n\n\tfor _, line := range strings.Split(strings.TrimSpace(string(data)), \"\\n\") {\n\t\tline = strings.TrimSpace(line)\n\t\tif line == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tvar a Assignment\n\t\tif err := json.Unmarshal([]byte(line), &a); err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif a.RunID == runID {\n\t\t\treturn a.CandidateID, nil\n\t\t}\n\t}\n\n\treturn \"\", nil\n}\n\n// readMeta reads all entries from meta.jsonl.\nfunc (p *Population) readMeta() ([]CandidateMeta, error) {\n\tdata, err := os.ReadFile(p.metaPath())\n\tif os.IsNotExist(err) {\n\t\treturn nil, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar entries []CandidateMeta\n\tfor _, line := range strings.Split(strings.TrimSpace(string(data)), \"\\n\") {\n\t\tline = strings.TrimSpace(line)\n\t\tif line == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tvar m CandidateMeta\n\t\tif err := json.Unmarshal([]byte(line), &m); err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tentries = append(entries, m)\n\t}\n\treturn entries, nil\n}\n\n// appendMeta appends a single meta entry to meta.jsonl.\nfunc (p *Population) appendMeta(meta CandidateMeta) error {\n\tdata, err := json.Marshal(meta)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tf, err := os.OpenFile(p.metaPath(), os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer f.Close()\n\n\t_, err = f.Write(append(data, '\\n'))\n\treturn err\n}\n\n// writeMeta overwrites meta.jsonl with the given entries.\nfunc (p *Population) writeMeta(entries []CandidateMeta) error {\n\tif err := os.MkdirAll(p.populationDir(), 0755); err != nil {\n\t\treturn fmt.Errorf(\"creating population dir: %w\", err)\n\t}\n\n\tvar sb strings.Builder\n\tfor _, m := range entries {\n\t\tdata, err := json.Marshal(m)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tsb.Write(data)\n\t\tsb.WriteByte('\\n')\n\t}\n\treturn os.WriteFile(p.metaPath(), []byte(sb.String()), 0644)\n}\n","numLines":316,"startLine":1,"totalLines":316}}}
