rkflowName,\n    53→\t\tCandidate:    candidate,\n    54→\t\tSuccess:      r.State == domain.RunStateSucceeded,\n    55→\t\tRetryCount:   retries,\n    56→\t\tDuration:     dur,\n    57→\t\tTimestamp:    r.CompletedAt,\n    58→\t}\n    59→}\n    60→\n    61→// RecordFitness appends a FitnessRecord to the JSONL file at path.\n    62→func RecordFitness(path string, record FitnessRecord) error {\n    63→\tif err := os.MkdirAll(filepath.Dir(path), 0755); err != nil {\n    64→\t\treturn fmt.Errorf(\"creating fitness dir: %w\", err)\n    65→\t}\n    66→\n    67→\tf, err := os.OpenFile(path, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644)\n    68→\tif err != nil {\n    69→\t\treturn fmt.Errorf(\"opening fitness file: %w\", err)\n    70→\t}\n    71→\tdefer f.Close()\n    72→\n    73→\tdata, err := json.Marshal(record)\n    74→\tif err != nil {\n    75→\t\treturn fmt.Errorf(\"marshaling fitness record: %w\", err)\n    76→\t}\n    77→\n    78→\tif _, err := f.Write(append(data, '\\n')); err != nil {\n    79→\t\treturn fmt.Errorf(\"writing fitness record: %w\", err)\n    80→\t}\n    81→\n    82→\treturn nil\n    83→}\n    84→\n    85→// LoadFitness reads all FitnessRecords from a JSONL file.\n    86→func LoadFitness(path string) ([]FitnessRecord, error) {\n    87→\tdata, err := os.ReadFile(path)\n    88→\tif os.IsNotExist(err) {\n    89→\t\treturn nil, nil\n    90→\t}\n    91→\tif err != nil {\n    92→\t\treturn nil, fmt.Errorf(\"reading fitness file: %w\", err)\n    93→\t}\n    94→\n    95→\tvar records []FitnessRecord\n    96→\tfor _, line := range strings.Split(strings.TrimSpace(string(data)), \"\\n\") {\n    97→\t\tline = strings.TrimSpace(line)\n    98→\t\tif line == \"\" {\n    99→\t\t\tcontinue\n   100→\t\t}\n   101→\t\tvar rec FitnessRecord\n   102→\t\tif err := json.Unmarshal([]byte(line), &rec); err != nil {\n   103→\t\t\tcontinue\n   104→\t\t}\n   105→\t\trecords = append(records, rec)\n   106→\t}\n   107→\treturn records, nil\n   108→}\n   109→\n   110→// AggregateFitness groups records by candidate and computes success rate\n   111→// and efficiency for each. Efficiency is defined as 1 / (1 + avgRetries + avgDurationSeconds/60),\n   112→// giving higher values to faster candidates with fewer retries.\n   113→func AggregateFitness(records []FitnessRecord) []CandidateFitness {\n   114→\ttype accum struct {\n   115→\t\tsuccesses    int\n   116→\t\ttotalRetries int\n   117→\t\ttotalDur     time.Duration\n   118→\t\tcount        int\n   119→\t}\n   120→\n   121→\tgroups := make(map[string]*accum)\n   122→\tfor _, r := range records {\n   123→\t\ta, ok := groups[r.Candidate]\n   124→\t\tif !ok {\n   125→\t\t\ta = &accum{}\n   126→\t\t\tgroups[r.Candidate] = a\n   127→\t\t}\n   128→\t\ta.count++\n   129→\t\tif r.Success {\n   130→\t\t\ta.successes++\n   131→\t\t}\n   132→\t\ta.totalRetries += r.RetryCount\n   133→\t\ta.totalDur += r.Duration\n   134→\t}\n   135→\n   136→\tresults := make([]CandidateFitness, 0, len(groups))\n   137→\tfor candidate, a := range groups {\n   138→\t\tavgRetries := float64(a.totalRetries) / float64(a.count)\n   139→\t\tavgDurMin := a.totalDur.Seconds() / float64(a.count) / 60.0\n   140→\t\tresults = append(results, CandidateFitness{\n   141→\t\t\tCandidate:   candidate,\n   142→\t\t\tSuccessRate: float64(a.successes) / float64(a.count),\n   143→\t\t\tEfficiency:  1.0 / (1.0 + avgRetries + avgDurMin),\n   144→\t\t\tRunCount:    a.count,\n   145→\t\t})\n   146→\t}\n   147→\treturn results\n   148→}\n   149→\n   150→// Dominates returns true if a dominates b in multi-objective comparison.\n   151→// a dominates b when a is at least as good in all objectives and strictly\n   152→// better in at least one. Both objectives (success rate, efficiency) are\n   153→// maximized.\n   154→func Dominates(a, b CandidateFitness) bool {\n   155→\tatLeastAsGood := a.SuccessRate >= b.SuccessRate && a.Efficiency >= b.Efficiency\n   156→\tstrictlyBetter := a.SuccessRate > b.SuccessRate || a.Efficiency > b.Efficiency\n   157→\treturn atLeastAsGood && strictlyBetter\n   158→}\n   159→\n   160→// ComputeParetoFront returns the non-dominated set from the given candidates.\n   161→// A candidate is non-dominated if no other candidate dominates it.\n   162→func ComputeParetoFront(candidates []CandidateFitness) []CandidateFitness {\n   163→\tvar front []CandidateFitness\n   164→\tfor i := range candidates {\n   165→\t\tdominated := false\n   166→\t\tfor j := range candidates {\n   167→\t\t\tif i == j {\n   168→\t\t\t\tcontinue\n   169→\t\t\t}\n   170→\t\t\tif Dominates(candidates[j], candidates[i]) {\n   171→\t\t\t\tdominated = true\n   172→\t\t\t\tbreak\n   173→\t\t\t}\n   174→\t\t}\n   175→\t\tif !dominated {\n   176→\t\t\tfront = append(front, candidates[i])\n   177→\t\t}\n   178→\t}\n   179→\treturn front\n   180→}\n   181→\n   182→// FitnessPath returns the conventional JSONL fitness file path for a workflow.\n   183→func FitnessPath(projectDir, workflowName string) string {\n   184→\treturn filepath.Join(projectDir, \".cloche\", \"evolution\", \"fitness\", workflowName+\".jsonl\")\n   185→}\n   186→"}]},"parent_tool_use_id":null,"session_id":"f3767534-9579-456d-bf6d-723d1bda3fa3","uuid":"d7456664-b5e1-4dcc-9624-27e851ed2d6e","timestamp":"2026-03-18T16:12:22.497Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/fitness.go","content":"package evolution\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n)\n\n// FitnessRecord holds metrics extracted from a single run evaluation.\ntype FitnessRecord struct {\n\tRunID        string        `json:\"run_id\"`\n\tWorkflowName string        `json:\"workflow_name\"`\n\tCandidate    string        `json:\"candidate\"`\n\tSuccess      bool          `json:\"success\"`\n\tRetryCount   int           `json:\"retry_count\"`\n\tDuration     time.Duration `json:\"duration\"`\n\tTimestamp    time.Time     `json:\"timestamp\"`\n}\n\n// CandidateFitness holds aggregated fitness for a candidate across runs.\ntype CandidateFitness struct {\n\tCandidate   string  `json:\"candidate\"`\n\tSuccessRate float64 `json:\"success_rate\"`\n\tEfficiency  float64 `json:\"efficiency\"`\n\tRunCount    int     `json:\"run_count\"`\n}\n\n// EvaluateRun extracts fitness metrics from a domain.Run.\n// The candidate identifier groups runs for aggregation (e.g. a prompt version).\nfunc EvaluateRun(r *domain.Run, candidate string) FitnessRecord {\n\tretries := 0\n\tseen := make(map[string]int)\n\tfor _, exec := range r.StepExecutions {\n\t\tseen[exec.StepName]++\n\t\tif seen[exec.StepName] > 1 {\n\t\t\tretries++\n\t\t}\n\t}\n\n\tdur := r.CompletedAt.Sub(r.StartedAt)\n\tif dur < 0 {\n\t\tdur = 0\n\t}\n\n\treturn FitnessRecord{\n\t\tRunID:        r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tCandidate:    candidate,\n\t\tSuccess:      r.State == domain.RunStateSucceeded,\n\t\tRetryCount:   retries,\n\t\tDuration:     dur,\n\t\tTimestamp:    r.CompletedAt,\n\t}\n}\n\n// RecordFitness appends a FitnessRecord to the JSONL file at path.\nfunc RecordFitness(path string, record FitnessRecord) error {\n\tif err := os.MkdirAll(filepath.Dir(path), 0755); err != nil {\n\t\treturn fmt.Errorf(\"creating fitness dir: %w\", err)\n\t}\n\n\tf, err := os.OpenFile(path, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"opening fitness file: %w\", err)\n\t}\n\tdefer f.Close()\n\n\tdata, err := json.Marshal(record)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"marshaling fitness record: %w\", err)\n\t}\n\n\tif _, err := f.Write(append(data, '\\n')); err != nil {\n\t\treturn fmt.Errorf(\"writing fitness record: %w\", err)\n\t}\n\n\treturn nil\n}\n\n// LoadFitness reads all FitnessRecords from a JSONL file.\nfunc LoadFitness(path string) ([]FitnessRecord, error) {\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn nil, nil\n\t}\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading fitness file: %w\", err)\n\t}\n\n\tvar records []FitnessRecord\n\tfor _, line := range strings.Split(strings.TrimSpace(string(data)), \"\\n\") {\n\t\tline = strings.TrimSpace(line)\n\t\tif line == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tvar rec FitnessRecord\n\t\tif err := json.Unmarshal([]byte(line), &rec); err != nil {\n\t\t\tcontinue\n\t\t}\n\t\trecords = append(records, rec)\n\t}\n\treturn records, nil\n}\n\n// AggregateFitness groups records by candidate and computes success rate\n// and efficiency for each. Efficiency is defined as 1 / (1 + avgRetries + avgDurationSeconds/60),\n// giving higher values to faster candidates with fewer retries.\nfunc AggregateFitness(records []FitnessRecord) []CandidateFitness {\n\ttype accum struct {\n\t\tsuccesses    int\n\t\ttotalRetries int\n\t\ttotalDur     time.Duration\n\t\tcount        int\n\t}\n\n\tgroups := make(map[string]*accum)\n\tfor _, r := range records {\n\t\ta, ok := groups[r.Candidate]\n\t\tif !ok {\n\t\t\ta = &accum{}\n\t\t\tgroups[r.Candidate] = a\n\t\t}\n\t\ta.count++\n\t\tif r.Success {\n\t\t\ta.successes++\n\t\t}\n\t\ta.totalRetries += r.RetryCount\n\t\ta.totalDur += r.Duration\n\t}\n\n\tresults := make([]CandidateFitness, 0, len(groups))\n\tfor candidate, a := range groups {\n\t\tavgRetries := float64(a.totalRetries) / float64(a.count)\n\t\tavgDurMin := a.totalDur.Seconds() / float64(a.count) / 60.0\n\t\tresults = append(results, CandidateFitness{\n\t\t\tCandidate:   candidate,\n\t\t\tSuccessRate: float64(a.successes) / float64(a.count),\n\t\t\tEfficiency:  1.0 / (1.0 + avgRetries + avgDurMin),\n\t\t\tRunCount:    a.count,\n\t\t})\n\t}\n\treturn results\n}\n\n// Dominates returns true if a dominates b in multi-objective comparison.\n// a dominates b when a is at least as good in all objectives and strictly\n// better in at least one. Both objectives (success rate, efficiency) are\n// maximized.\nfunc Dominates(a, b CandidateFitness) bool {\n\tatLeastAsGood := a.SuccessRate >= b.SuccessRate && a.Efficiency >= b.Efficiency\n\tstrictlyBetter := a.SuccessRate > b.SuccessRate || a.Efficiency > b.Efficiency\n\treturn atLeastAsGood && strictlyBetter\n}\n\n// ComputeParetoFront returns the non-dominated set from the given candidates.\n// A candidate is non-dominated if no other candidate dominates it.\nfunc ComputeParetoFront(candidates []CandidateFitness) []CandidateFitness {\n\tvar front []CandidateFitness\n\tfor i := range candidates {\n\t\tdominated := false\n\t\tfor j := range candidates {\n\t\t\tif i == j {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif Dominates(candidates[j], candidates[i]) {\n\t\t\t\tdominated = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !dominated {\n\t\t\tfront = append(front, candidates[i])\n\t\t}\n\t}\n\treturn front\n}\n\n// FitnessPath returns the conventional JSONL fitness file path for a workflow.\nfunc FitnessPath(projectDir, workflowName string) string {\n\treturn filepath.Join(projectDir, \".cloche\", \"evolution\", \"fitness\", workflowName+\".jsonl\")\n}\n","numLines":186,"startLine":1,"totalLines":186}}}
