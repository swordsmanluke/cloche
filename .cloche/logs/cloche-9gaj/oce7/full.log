tor) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n    53→\t// Stage 1: Collect\n    54→\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n    55→\tif err != nil {\n    56→\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n    57→\t}\n    58→\n    59→\t// Stage 2: Classify the triggering run\n    60→\tclassification, err := o.classifier.Classify(ctx, \"\")\n    61→\tif err != nil {\n    62→\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n    63→\t}\n    64→\n    65→\t// Stage 3: Reflect\n    66→\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n    67→\tif err != nil {\n    68→\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n    69→\t}\n    70→\n    71→\t// Filter out lessons whose IDs are already recorded in the knowledge base.\n    72→\t// This guards against the Reflector re-surfacing previously applied lessons.\n    73→\tif data.KnowledgeBase != \"\" {\n    74→\t\tvar fresh []Lesson\n    75→\t\tfor _, l := range lessons {\n    76→\t\t\tif l.ID != \"\" && strings.Contains(data.KnowledgeBase, l.ID) {\n    77→\t\t\t\tcontinue\n    78→\t\t\t}\n    79→\t\t\tfresh = append(fresh, l)\n    80→\t\t}\n    81→\t\tlessons = fresh\n    82→\t}\n    83→\n    84→\tresult := &EvolutionResult{\n    85→\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n    86→\t\tProjectDir:     o.cfg.ProjectDir,\n    87→\t\tWorkflowName:   o.cfg.WorkflowName,\n    88→\t\tTriggerRunID:   triggerRunID,\n    89→\t\tTimestamp:      time.Now().Format(time.RFC3339),\n    90→\t\tClassification: classification,\n    91→\t}\n    92→\n    93→\tif len(lessons) == 0 {\n    94→\t\t// No actionable lessons — log and return\n    95→\t\to.audit.Log(result)\n    96→\t\treturn result, nil\n    97→\t}\n    98→\n    99→\t// Stage 4: Execute branches based on lesson category\n   100→\tfor _, lesson := range lessons {\n   101→\t\tswitch lesson.Category {\n   102→\t\tcase \"prompt_