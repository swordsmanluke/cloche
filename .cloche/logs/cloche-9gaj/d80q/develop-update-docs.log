pulation) AddCandidate(content string, ancestorLessons []Lesson) {\n    47→\tp.mu.Lock()\n    48→\tdefer p.mu.Unlock()\n    49→\n    50→\tid := fmt.Sprintf(\"candidate-%d\", len(p.Candidates)+1)\n    51→\tp.Candidates = append(p.Candidates, Candidate{\n    52→\t\tID:              id,\n    53→\t\tContent:         content,\n    54→\t\tAncestorLessons: ancestorLessons,\n    55→\t})\n    56→}\n    57→\n    58→// EvaluateRun records fitness data from a completed run for a candidate.\n    59→func (p *Population) EvaluateRun(candidateID string, run *domain.Run) error {\n    60→\tp.mu.Lock()\n    61→\tdefer p.mu.Unlock()\n    62→\n    63→\tfor i := range p.Candidates {\n    64→\t\tif p.Candidates[i].ID == candidateID {\n    65→\t\t\tc := &p.Candidates[i]\n    66→\t\t\toldTotal := c.Fitness.TotalRuns\n    67→\t\t\tnewTotal := oldTotal + 1\n    68→\n    69→\t\t\t// Update success rate incrementally\n    70→\t\t\tsuccessVal := 0.0\n    71→\t\t\tif run.State == domain.RunStateSucceeded {\n    72→\t\t\t\tsuccessVal = 1.0\n    73→\t\t\t}\n    74→\t\t\tc.Fitness.SuccessRate = (c.Fitness.SuccessRate*float64(oldTotal) + successVal) / float64(newTotal)\n    75→\n    76→\t\t\t// Update step count incrementally\n    77→\t\t\tstepCount := float64(len(run.StepExecutions))\n    78→\t\t\tc.Fitness.StepCount = (c.Fitness.StepCount*float64(oldTotal) + stepCount) / float64(newTotal)\n    79→\n    80→\t\t\tc.Fitness.TotalRuns = newTotal\n    81→\t\t\treturn nil\n    82→\t\t}\n    83→\t}\n    84→\treturn fmt.Errorf(\"candidate %q not found\", candidateID)\n    85→}\n    86→\n    87→// paretoDominates returns true if a dominates b: a is >= b on all fitness\n    88→// dimensions and strictly > on at least one.\n    89→func paretoDominates(a, b FitnessScores) bool {\n    90→\tbetterInAny := false\n    91→\n    92→\t// Higher success rate is better\n    93→\tif a.SuccessRate < b.SuccessRate {\n    94→\t\treturn false\n    95→\t}\n    96→\tif a.SuccessRate > b.SuccessRate {\n    97→\t\tbetterInAny = true\n    98→\t}\n    99→\n   100→\t// Higher step count means more steps completed (better)\n   101→\tif a.StepCount < b.StepCount {\n   102→\t\treturn false\n   103→\t}\n   104→\tif a.StepCount > b.StepCount {\n   105→\t\tbetterInAny = true\n   106→\t}\n   107→\n   108→\treturn betterInAny\n   109→}\n   110→\n   111→// FindPromotable returns the first candidate that meets promotion criteria:\n   112→// has at least MinRuns evaluations and Pareto-dominates all other candidates.\n   113→// Returns nil if no candidate qualifies.\n   114→func (p *Population) FindPromotable() *Candidate {\n   115→\tp.mu.Lock()\n   116→\tdefer p.mu.Unlock()\n   117→\n   118→\tfor i := range p.Candidates {\n   119→\t\tc := &p.Candidates[i]\n   120→\t\tif c.Fitness.TotalRuns < p.MinRuns {\n   121→\t\t\tcontinue\n   122→\t\t}\n   123→\n   124→\t\tdominatesAll := true\n   125→\t\tfor j := range p.Candidates {\n   126→\t\t\tif i == j {\n   127→\t\t\t\tcontinue\n   128→\t\t\t}\n   129→\t\t\tif !paretoDominates(c.Fitness, p.Candidates[j].Fitness) {\n   130→\t\t\t\tdominatesAll = false\n   131→\t\t\t\tbreak\n   132→\t\t\t}\n   133→\t\t}\n   134→\n   135→\t\tif dominatesAll {\n   136→\t\t\tresult := *c\n   137→\t\t\treturn &result\n   138→\t\t}\n   139→\t}\n   140→\treturn nil\n   141→}\n   142→\n   143→// Promote writes the winning candidate's content to the base prompt file,\n   144→// replacing the current content.\n   145→func (p *Population) Promote(candidate *Candidate) error {\n   146→\ttargetPath := filepath.Join(p.ProjectDir, p.TargetFile)\n   147→\tif err := os.MkdirAll(filepath.Dir(targetPath), 0755); err != nil {\n   148→\t\treturn fmt.Errorf(\"creating directory for promotion: %w\", err)\n   149→\t}\n   150→\tif err := os.WriteFile(targetPath, []byte(candidate.Content), 0644); err != nil {\n   151→\t\treturn fmt.Errorf(\"promoting candidate %s: %w\", candidate.ID, err)\n   152→\t}\n   153→\treturn nil\n   154→}\n   155→"}]},"parent_tool_use_id":null,"session_id":"81a83595-a06e-46f2-b0c3-1fba000c92af","uuid":"7235dd2a-49ab-4769-9f4e-88fdbfe742ba","timestamp":"2026-03-17T14:13:45.701Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/population.go","content":"package evolution\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sync\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n)\n\n// FitnessScores holds multi-dimensional fitness metrics for a candidate.\ntype FitnessScores struct {\n\tSuccessRate float64 `json:\"success_rate\"` // fraction of runs that succeeded\n\tStepCount   float64 `json:\"step_count\"`   // average number of steps completed\n\tTotalRuns   int     `json:\"total_runs\"`   // number of runs evaluated\n}\n\n// Candidate is a prompt variant being evaluated in population mode.\ntype Candidate struct {\n\tID              string        `json:\"id\"`\n\tContent         string        `json:\"content\"`          // curated prompt content\n\tAncestorLessons []Lesson      `json:\"ancestor_lessons\"` // lessons that produced this candidate\n\tFitness         FitnessScores `json:\"fitness\"`\n}\n\n// Population manages a set of prompt candidates for evolutionary selection.\ntype Population struct {\n\tmu         sync.Mutex\n\tCandidates []Candidate\n\tMinRuns    int    // minimum runs before a candidate can be promoted\n\tTargetFile string // relative path to the base prompt file\n\tProjectDir string\n}\n\n// NewPopulation creates a population for the given target prompt file.\nfunc NewPopulation(projectDir, targetFile string, minRuns int) *Population {\n\treturn &Population{\n\t\tProjectDir: projectDir,\n\t\tTargetFile: targetFile,\n\t\tMinRuns:    minRuns,\n\t}\n}\n\n// AddCandidate adds a new prompt candidate with its ancestor lessons.\nfunc (p *Population) AddCandidate(content string, ancestorLessons []Lesson) {\n\tp.mu.Lock()\n\tdefer p.mu.Unlock()\n\n\tid := fmt.Sprintf(\"candidate-%d\", len(p.Candidates)+1)\n\tp.Candidates = append(p.Candidates, Candidate{\n\t\tID:              id,\n\t\tContent:         content,\n\t\tAncestorLessons: ancestorLessons,\n\t})\n}\n\n// EvaluateRun records fitness data from a completed run for a candidate.\nfunc (p *Population) EvaluateRun(candidateID string, run *domain.Run) error {\n\tp.mu.Lock()\n\tdefer p.mu.Unlock()\n\n\tfor i := range p.Candidates {\n\t\tif p.Candidates[i].ID == candidateID {\n\t\t\tc := &p.Candidates[i]\n\t\t\toldTotal := c.Fitness.TotalRuns\n\t\t\tnewTotal := oldTotal + 1\n\n\t\t\t// Update success rate incrementally\n\t\t\tsuccessVal := 0.0\n\t\t\tif run.State == domain.RunStateSucceeded {\n\t\t\t\tsuccessVal = 1.0\n\t\t\t}\n\t\t\tc.Fitness.SuccessRate = (c.Fitness.SuccessRate*float64(oldTotal) + successVal) / float64(newTotal)\n\n\t\t\t// Update step count incrementally\n\t\t\tstepCount := float64(len(run.StepExecutions))\n\t\t\tc.Fitness.StepCount = (c.Fitness.StepCount*float64(oldTotal) + stepCount) / float64(newTotal)\n\n\t\t\tc.Fitness.TotalRuns = newTotal\n\t\t\treturn nil\n\t\t}\n\t}\n\treturn fmt.Errorf(\"candidate %q not found\", candidateID)\n}\n\n// paretoDominates returns true if a dominates b: a is >= b on all fitness\n// dimensions and strictly > on at least one.\nfunc paretoDominates(a, b FitnessScores) bool {\n\tbetterInAny := false\n\n\t// Higher success rate is better\n\tif a.SuccessRate < b.SuccessRate {\n\t\treturn false\n\t}\n\tif a.SuccessRate > b.SuccessRate {\n\t\tbetterInAny = true\n\t}\n\n\t// Higher step count means more steps completed (better)\n\tif a.StepCount < b.StepCount {\n\t\treturn false\n\t}\n\tif a.StepCount > b.StepCount {\n\t\tbetterInAny = true\n\t}\n\n\treturn betterInAny\n}\n\n// FindPromotable returns the first candidate that meets promotion criteria:\n// has at least MinRuns evaluations and Pareto-dominates all other candidates.\n// Returns nil if no candidate qualifies.\nfunc (p *Population) FindPromotable() *Candidate {\n\tp.mu.Lock()\n\tdefer p.mu.Unlock()\n\n\tfor i := range p.Candidates {\n\t\tc := &p.Candidates[i]\n\t\tif c.Fitness.TotalRuns < p.MinRuns {\n\t\t\tcontinue\n\t\t}\n\n\t\tdominatesAll := true\n\t\tfor j := range p.Candidates {\n\t\t\tif i == j {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif !paretoDominates(c.Fitness, p.Candidates[j].Fitness) {\n\t\t\t\tdominatesAll = false\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\tif dominatesAll {\n\t\t\tresult := *c\n\t\t\treturn &result\n\t\t}\n\t}\n\treturn nil\n}\n\n// Promote writes the winning candidate's content to the base prompt file,\n// replacing the current content.\nfunc (p *Population) Promote(candidate *Candidate) error {\n\ttargetPath := filepath.Join(p.ProjectDir, p.TargetFile)\n\tif err := os.MkdirAll(filepath.Dir(targetPath), 0755); err != nil {\n\t\treturn fmt.Errorf(\"creating directory for promotion: %w\", err)\n\t}\n\tif err := os.WriteFile(targetPath, []byte(candidate.Content), 0644); err != nil {\n\t\treturn fmt.Errorf(\"promoting candidate %s: %w\", candidate.ID, err)\n\t}\n\treturn nil\n}\n","numLines":155,"startLine":1,"totalLines":155}}}
