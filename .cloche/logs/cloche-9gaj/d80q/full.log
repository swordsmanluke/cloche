[2026-03-17T14:13:27Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Fjf2MK3LktSnCaSqdXdavF","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LvbrsTNMj6yELZdaekiQvw","name":"Write","input":{"file_path":"/workspace/internal/evolution/population_test.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// --- Population unit tests ---\n\nfunc TestPopulationAddCandidate(t *testing.T) {\n\tp := NewPopulation(t.TempDir(), \".cloche/prompts/impl.md\", 3)\n\n\tlessons := []Lesson{{ID: \"L1\", Insight: \"test insight\"}}\n\tp.AddCandidate(\"# Prompt\\n\\n## Learned Rules\\n\\n- test insight\\n\", lessons)\n\n\trequire.Len(t, p.Candidates, 1)\n\tassert.Equal(t, \"candidate-1\", p.Candidates[0].ID)\n\tassert.Equal(t, \"# Prompt\\n\\n## Learned Rules\\n\\n- test insight\\n\", p.Candidates[0].Content)\n\tassert.Equal(t, lessons, p.Candidates[0].AncestorLessons)\n}\n\nfunc TestPopulationEvaluateRun(t *testing.T) {\n\tp := NewPopulation(t.TempDir(), \".cloche/prompts/impl.md\", 2)\n\tp.AddCandidate(\"content\", nil)\n\n\trun1 := &domain.Run{State: domain.RunStateSucceeded, StepExecutions: []*domain.StepExecution{{}, {}}}\n\trequire.NoError(t, p.EvaluateRun(\"candidate-1\", run1))\n\n\tassert.Equal(t, 1, p.Candidates[0].Fitness.TotalRuns)\n\tassert.Equal(t, 1.0, p.Candidates[0].Fitness.SuccessRate)\n\tassert.Equal(t, 2.0, p.Candidates[0].Fitness.StepCount)\n\n\trun2 := &domain.Run{State: domain.RunStateFailed, StepExecutions: []*domain.StepExecution{{}}}\n\trequire.NoError(t, p.EvaluateRun(\"candidate-1\", run2))\n\n\tassert.Equal(t, 2, p.Candidates[0].Fitness.TotalRuns)\n\tassert.Equal(t, 0.5, p.Candidates[0].Fitness.SuccessRate)\n\tassert.Equal(t, 1.5, p.Candidates[0].Fitness.StepCount)\n}\n\nfunc TestPopulationEvaluateRunNotFound(t *testing.T) {\n\tp := NewPopulation(t.TempDir(), \".cloche/prompts/impl.md\", 2)\n\terr := p.EvaluateRun(\"nonexistent\", &domain.Run{})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"not found\")\n}\n\nfunc TestParetoDominates(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\ta, b     FitnessScores\n\t\texpected bool\n\t}{\n\t\t{\n\t\t\tname:     \"a dominates b on both dimensions\",\n\t\t\ta:        FitnessScores{SuccessRate: 0.9, StepCount: 3.0},\n\t\t\tb:        FitnessScores{SuccessRate: 0.5, StepCount: 2.0},\n\t\t\texpected: true,\n\t\t},\n\t\t{\n\t\t\tname:     \"a dominates b on success rate, equal step count\",\n\t\t\ta:        FitnessScores{SuccessRate: 0.9, StepCount: 2.0},\n\t\t\tb:        FitnessScores{SuccessRate: 0.5, StepCount: 2.0},\n\t\t\texpected: true,\n\t\t},\n\t\t{\n\t\t\tname:     \"equal scores — no dominance\",\n\t\t\ta:        FitnessScores{SuccessRate: 0.5, StepCount: 2.0},\n\t\t\tb:        FitnessScores{SuccessRate: 0.5, StepCount: 2.0},\n\t\t\texpected: false,\n\t\t},\n\t\t{\n\t\t\tname:     \"a worse on one dimension — no dominance\",\n\t\t\ta:        FitnessScores{SuccessRate: 0.9, StepCount: 1.0},\n\t\t\tb:        FitnessScores{SuccessRate: 0.5, StepCount: 2.0},\n\t\t\texpected: false,\n\t\t},\n\t\t{\n\t\t\tname:     \"b dominates a\",\n\t\t\ta:        FitnessScores{SuccessRate: 0.3, StepCount: 1.0},\n\t\t\tb:        FitnessScores{SuccessRate: 0.9, StepCount: 3.0},\n\t\t\texpected: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, tt.expected, paretoDominates(tt.a, tt.b))\n\t\t})\n\t}\n}\n\nfunc TestPopulationFindPromotable(t *testing.T) {\n\tt.Run(\"no candidates meet min runs\", func(t *testing.T) {\n\t\tp := NewPopulation(t.TempDir(), \"prompt.md\", 3)\n\t\tp.AddCandidate(\"content-a\", nil)\n\t\tp.Candidates[0].Fitness = FitnessScores{SuccessRate: 1.0, StepCount: 3.0, TotalRuns: 2}\n\t\tassert.Nil(t, p.FindPromotable())\n\t})\n\n\tt.Run(\"single candidate meets criteria\", func(t *testing.T) {\n\t\tp := NewPopulation(t.TempDir(), \"prompt.md\", 2)\n\t\tp.AddCandidate(\"content-a\", nil)\n\t\tp.Candidates[0].Fitness = FitnessScores{SuccessRate: 1.0, StepCount: 3.0, TotalRuns: 2}\n\t\twinner := p.FindPromotable()\n\t\trequire.NotNil(t, winner)\n\t\tassert.Equal(t, \"candidate-1\", winner.ID)\n\t})\n\n\tt.Run(\"dominant candidate among multiple\", func(t *testing.T) {\n\t\tp := NewPopulation(t.TempDir(), \"prompt.md\", 2)\n\t\tp.AddCandidate(\"content-a\", nil)\n\t\tp.AddCandidate(\"content-b\", nil)\n\t\tp.Candidates[0].Fitness = FitnessScores{SuccessRate: 0.9, StepCount: 3.0, TotalRuns: 3}\n\t\tp.Candidates[1].Fitness = FitnessScores{SuccessRate: 0.5, StepCount: 2.0, TotalRuns: 3}\n\t\twinner := p.FindPromotable()\n\t\trequire.NotNil(t, winner)\n\t\tassert.Equal(t, \"candidate-1\", winner.ID)\n\t})\n\n\tt.Run(\"no dominance — no promotion\", func(t *testing.T) {\n\t\tp := NewPopulation(t.TempDir(), \"prompt.md\", 2)\n\t\tp.AddCandidate(\"content-a\", nil)\n\t\tp.AddCandidate(\"content-b\", nil)\n\t\t// a is better on success rate, b is better on step count\n\t\tp.Candidates[0].Fitness = FitnessScores{SuccessRate: 0.9, StepCount: 1.0, TotalRuns: 3}\n\t\tp.Candidates[1].Fitness = FitnessScores{SuccessRate: 0.5, StepCount: 3.0, TotalRuns: 3}\n\t\tassert.Nil(t, p.FindPromotable())\n\t})\n}\n\nfunc TestPopulationPromote(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"impl.md\"), []byte(\"original\"), 0644)\n\n\tp := NewPopulation(dir, \".cloche/prompts/impl.md\", 1)\n\tcandidate := &Candidate{\n\t\tID:      \"candidate-1\",\n\t\tContent: \"# Improved Prompt\\n\\n## Learned Rules\\n\\n- Better rule\\n\",\n\t}\n\n\trequire.NoError(t, p.Promote(candidate))\n\n\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"impl.md\"))\n\trequire.NoError(t, err)\n\tassert.Equal(t, candidate.Content, string(content))\n}\n\n// --- Curator.Curate() tests ---\n\nfunc TestCuratorCurateReturnsContent(t *testing.T) {\n\tupdatedContent := \"# Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n\"\n\tllm := &fakeLLM{response: updatedContent}\n\tc := &Curator{LLM: llm}\n\n\tlesson := &Lesson{\n\t\tInsight:         \"Missing validation\",\n\t\tSuggestedAction: \"Add input validation\",\n\t}\n\n\tresult, err := c.Curate(context.Background(), \"# Prompt\\n\\nWrite good code.\\n\", lesson)\n\trequire.NoError(t, err)\n\tassert.Contains(t, result, \"Always validate inputs\")\n}\n\nfunc TestCuratorCurateSkipsExistingLesson(t *testing.T) {\n\tllm := &fakeLLM{response: \"THIS SHOULD NOT BE USED\"}\n\tc := &Curator{LLM: llm}\n\n\texisting := \"# Prompt\\n\\n## Learned Rules\\n\\n- Missing validation: Add input validation\\n\"\n\tlesson := &Lesson{\n\t\tInsight:         \"Missing validation\",\n\t\tSuggestedAction: \"Add input validation\",\n\t}\n\n\tresult, err := c.Curate(context.Background(), existing, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, existing, result)\n}\n\nfunc TestCuratorCurateFallsBackOnConversationalResponse(t *testing.T) {\n\tllm := &fakeLLM{response: \"I've updated the prompt with your changes.\"}\n\tc := &Curator{LLM: llm}\n\n\tlesson := &Lesson{\n\t\tInsight:         \"New rule needed\",\n\t\tSuggestedAction: \"Add the rule\",\n\t}\n\n\tresult, err := c.Curate(context.Background(), \"# Prompt\\n\\nDo work.\\n\", lesson)\n\trequire.NoError(t, err)\n\tassert.Contains(t, result, \"New rule needed\")\n\tassert.Contains(t, result, \"## Learned Rules\")\n}\n\n// --- Integration tests: Orchestrator with population mode ---\n\nfunc TestOrchestratorPopulationModeAddsCandidateInsteadOfEditing(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\n\toriginalPrompt := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(originalPrompt), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  implement:success -> done\n  implement:fail -> abort\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t// Reflector\n\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t\t// Curator.Curate\n\t\t\t\"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n\t\t},\n\t}\n\n\tpop := NewPopulation(dir, \".cloche/prompts/implement.md\", 3)\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\torch.Population = pop\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\n\t// Should have a population_candidate change, not a prompt_update\n\trequire.Len(t, result.Changes, 1)\n\tassert.Equal(t, \"population_candidate\", result.Changes[0].Type)\n\tassert.Equal(t, \".cloche/prompts/implement.md\", result.Changes[0].File)\n\n\t// The base prompt file should remain unchanged\n\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n\trequire.NoError(t, err)\n\tassert.Equal(t, originalPrompt, string(content))\n\n\t// Population should have one candidate\n\trequire.Len(t, pop.Candidates, 1)\n\tassert.Contains(t, pop.Candidates[0].Content, \"sanitize user inputs\")\n\trequire.Len(t, pop.Candidates[0].AncestorLessons, 1)\n\tassert.Equal(t, \"L001\", pop.Candidates[0].AncestorLessons[0].ID)\n}\n\nfunc TestScoreAndPromotePromotesCandidateAfterMinRuns(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"# Original Prompt\\n\"), 0644)\n\n\tpop := NewPopulation(dir, \".cloche/prompts/implement.md\", 2)\n\tpop.AddCandidate(\"# Improved Prompt\\n\\n## Learned Rules\\n\\n- New rule\\n\", []Lesson{{ID: \"L1\"}})\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:   dir,\n\t\tWorkflowName: \"develop\",\n\t\tLLM:          &fakeLLM{response: \"unused\"},\n\t})\n\torch.Population = pop\n\n\t// First run — not enough runs yet\n\trun1 := &domain.Run{\n\t\tState:          domain.RunStateSucceeded,\n\t\tStepExecutions: []*domain.StepExecution{{}, {}},\n\t}\n\twinner, err := orch.ScoreAndPromote(context.Background(), run1)\n\trequire.NoError(t, err)\n\tassert.Nil(t, winner, \"should not promote after only 1 run\")\n\n\t// Second run — meets MinRuns threshold\n\trun2 := &domain.Run{\n\t\tState:          domain.RunStateSucceeded,\n\t\tStepExecutions: []*domain.StepExecution{{}, {}, {}},\n\t}\n\twinner, err = orch.ScoreAndPromote(context.Background(), run2)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, winner, \"should promote after 2 runs\")\n\tassert.Equal(t, \"candidate-1\", winner.ID)\n\n\t// Verify file was updated\n\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"New rule\")\n}\n\nfunc TestScoreAndPromoteNoDominance(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"impl.md\"),\n\t\t[]byte(\"# Original\\n\"), 0644)\n\n\tpop := NewPopulation(dir, \".cloche/prompts/impl.md\", 1)\n\tpop.AddCandidate(\"content-a\", nil)\n\tpop.AddCandidate(\"content-b\", nil)\n\n\t// Set up non-dominating fitness (a better on success, b better on steps)\n\tpop.Candidates[0].Fitness = FitnessScores{SuccessRate: 0.9, StepCount: 1.0, TotalRuns: 2}\n\tpop.Candidates[1].Fitness = FitnessScores{SuccessRate: 0.5, StepCount: 3.0, TotalRuns: 1}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:   dir,\n\t\tWorkflowName: \"develop\",\n\t\tLLM:          &fakeLLM{response: \"unused\"},\n\t})\n\torch.Population = pop\n\n\t// Evaluate one more run for candidate-2 (most recent)\n\trun := &domain.Run{\n\t\tState:          domain.RunStateFailed,\n\t\tStepExecutions: []*domain.StepExecution{{}, {}, {}},\n\t}\n\twinner, err := orch.ScoreAndPromote(context.Background(), run)\n\trequire.NoError(t, err)\n\tassert.Nil(t, winner, \"should not promote when no candidate dominates\")\n\n\t// File should remain unchanged\n\tcontent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"impl.md\"))\n\tassert.Equal(t, \"# Original\\n\", string(content))\n}\n\nfunc TestScoreAndPromoteWithoutPopulationReturnsError(t *testing.T) {\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:   t.TempDir(),\n\t\tWorkflowName: \"develop\",\n\t\tLLM:          &fakeLLM{response: \"unused\"},\n\t})\n\n\t_, err := orch.ScoreAndPromote(context.Background(), &domain.Run{})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"population mode not enabled\")\n}\n\nfunc TestOrchestratorPopulationModeEndToEnd(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\n\toriginalPrompt := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(originalPrompt), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  implement:success -> done\n  implement:fail -> abort\n}`), 0644)\n\n\t// Step 1: Run orchestrator in population mode to produce a candidate\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Missing error handling\", \"suggested_action\": \"Add error handling rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t\t\"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always handle errors\\n\",\n\t\t},\n\t}\n\n\tpop := NewPopulation(dir, \".cloche/prompts/implement.md\", 2)\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\torch.Population = pop\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\trequire.Len(t, result.Changes, 1)\n\tassert.Equal(t, \"population_candidate\", result.Changes[0].Type)\n\n\t// Step 2: Score two successful runs\n\tfor i := 0; i < 2; i++ {\n\t\trun := &domain.Run{\n\t\t\tState:          domain.RunStateSucceeded,\n\t\t\tStepExecutions: []*domain.StepExecution{{}, {}},\n\t\t}\n\t\twinner, err := orch.ScoreAndPromote(context.Background(), run)\n\t\trequire.NoError(t, err)\n\t\tif i < 1 {\n\t\t\tassert.Nil(t, winner)\n\t\t} else {\n\t\t\trequire.NotNil(t, winner, \"should promote after MinRuns\")\n\t\t\tassert.Equal(t, \"candidate-1\", winner.ID)\n\t\t}\n\t}\n\n\t// Step 3: Verify the prompt file was updated\n\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"Always handle errors\")\n\tassert.NotEqual(t, originalPrompt, string(content))\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":363,"cache_read_input_tokens":55123,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":363},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f7e0d0a9-9907-4df1-a980-7e0c554bc17f","uuid":"103ab7ec-a358-4e6d-ba0a-1dae928c9709"}
[2026-03-17T14:13:27Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LvbrsTNMj6yELZdaekiQvw","type":"tool_result","content":"File created successfully at: /workspace/internal/evolution/population_test.go"}]},"parent_tool_use_id":null,"session_id":"f7e0d0a9-9907-4df1-a980-7e0c554bc17f","uuid":"6e10e858-5d89-4471-82da-673c7ede91c8","timestamp":"2026-03-17T14:12:17.473Z","tool_use_result":{"type":"create","filePath":"/workspace/internal/evolution/population_test.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// --- Population unit tests ---\n\nfunc TestPopulationAddCandidate(t *testing.T) {\n\tp := NewPopulation(t.TempDir(), \".cloche/prompts/impl.md\", 3)\n\n\tlessons := []Lesson{{ID: \"L1\", Insight: \"test insight\"}}\n\tp.AddCandidate(\"# Prompt\\n\\n## Learned Rules\\n\\n- test insight\\n\", lessons)\n\n\trequire.Len(t, p.Candidates, 1)\n\tassert.Equal(t, \"candidate-1\", p.Candidates[0].ID)\n\tassert.Equal(t, \"# Prompt\\n\\n## Learned Rules\\n\\n- test insight\\n\", p.Candidates[0].Content)\n\tassert.Equal(t, lessons, p.Candidates[0].AncestorLessons)\n}\n\nfunc TestPopulationEvaluateRun(t *testing.T) {\n\tp := NewPopulation(t.TempDir(), \".cloche/prompts/impl.md\", 2)\n\tp.AddCandidate(\"content\", nil)\n\n\trun1 := &domain.Run{State: domain.RunStateSucceeded, StepExecutions: []*domain.StepExecution{{}, {}}}\n\trequire.NoError(t, p.EvaluateRun(\"candidate-1\", run1))\n\n\tassert.Equal(t, 1, p.Candidates[0].Fitness.TotalRuns)\n\tassert.Equal(t, 1.0, p.Candidates[0].Fitness.SuccessRate)\n\tassert.Equal(t, 2.0, p.Candidates[0].Fitness.StepCount)\n\n\trun2 := &domain.Run{State: domain.RunStateFailed, StepExecutions: []*domain.StepExecution{{}}}\n\trequire.NoError(t, p.EvaluateRun(\"candidate-1\", run2))\n\n\tassert.Equal(t, 2, p.Candidates[0].Fitness.TotalRuns)\n\tassert.Equal(t, 0.5, p.Candidates[0].Fitness.SuccessRate)\n\tassert.Equal(t, 1.5, p.Candidates[0].Fitness.StepCount)\n}\n\nfunc TestPopulationEvaluateRunNotFound(t *testing.T) {\n\tp := NewPopulation(t.TempDir(), \".cloche/prompts/impl.md\", 2)\n\terr := p.EvaluateRun(\"nonexistent\", &domain.Run{})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"not found\")\n}\n\nfunc TestParetoDominates(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\ta, b     FitnessScores\n\t\texpected bool\n\t}{\n\t\t{\n\t\t\tname:     \"a dominates b on both dimensions\",\n\t\t\ta:        FitnessScores{SuccessRate: 0.9, StepCount: 3.0},\n\t\t\tb:        FitnessScores{SuccessRate: 0.5, StepCount: 2.0},\n\t\t\texpected: true,\n\t\t},\n\t\t{\n\t\t\tname:     \"a dominates b on success rate, equal step count\",\n\t\t\ta:        FitnessScores{SuccessRate: 0.9, StepCount: 2.0},\n\t\t\tb:        FitnessScores{SuccessRate: 0.5, StepCount: 2.0},\n\t\t\texpected: true,\n\t\t},\n\t\t{\n\t\t\tname:     \"equal scores — no dominance\",\n\t\t\ta:        FitnessScores{SuccessRate: 0.5, StepCount: 2.0},\n\t\t\tb:        FitnessScores{SuccessRate: 0.5, StepCount: 2.0},\n\t\t\texpected: false,\n\t\t},\n\t\t{\n\t\t\tname:     \"a worse on one dimension — no dominance\",\n\t\t\ta:        FitnessScores{SuccessRate: 0.9, StepCount: 1.0},\n\t\t\tb:        FitnessScores{SuccessRate: 0.5, StepCount: 2.0},\n\t\t\texpected: false,\n\t\t},\n\t\t{\n\t\t\tname:     \"b dominates a\",\n\t\t\ta:        FitnessScores{SuccessRate: 0.3, StepCount: 1.0},\n\t\t\tb:        FitnessScores{SuccessRate: 0.9, StepCount: 3.0},\n\t\t\texpected: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, tt.expected, paretoDominates(tt.a, tt.b))\n\t\t})\n\t}\n}\n\nfunc TestPopulationFindPromotable(t *testing.T) {\n\tt.Run(\"no candidates meet min runs\", func(t *testing.T) {\n\t\tp := NewPopulation(t.TempDir(), \"prompt.md\", 3)\n\t\tp.AddCandidate(\"content-a\", nil)\n\t\tp.Candidates[0].Fitness = FitnessScores{SuccessRate: 1.0, StepCount: 3.0, TotalRuns: 2}\n\t\tassert.Nil(t, p.FindPromotable())\n\t})\n\n\tt.Run(\"single candidate meets criteria\", func(t *testing.T) {\n\t\tp := NewPopulation(t.TempDir(), \"prompt.md\", 2)\n\t\tp.AddCandidate(\"content-a\", nil)\n\t\tp.Candidates[0].Fitness = FitnessScores{SuccessRate: 1.0, StepCount: 3.0, TotalRuns: 2}\n\t\twinner := p.FindPromotable()\n\t\trequire.NotNil(t, winner)\n\t\tassert.Equal(t, \"candidate-1\", winner.ID)\n\t})\n\n\tt.Run(\"dominant candidate among multiple\", func(t *testing.T) {\n\t\tp := NewPopulation(t.TempDir(), \"prompt.md\", 2)\n\t\tp.AddCandidate(\"content-a\", nil)\n\t\tp.AddCandidate(\"content-b\", nil)\n\t\tp.Candidates[0].Fitness = FitnessScores{SuccessRate: 0.9, StepCount: 3.0, TotalRuns: 3}\n\t\tp.Candidates[1].Fitness = FitnessScores{SuccessRate: 0.5, StepCount: 2.0, TotalRuns: 3}\n\t\twinner := p.FindPromotable()\n\t\trequire.NotNil(t, winner)\n\t\tassert.Equal(t, \"candidate-1\", winner.ID)\n\t})\n\n\tt.Run(\"no dominance — no promotion\", func(t *testing.T) {\n\t\tp := NewPopulation(t.TempDir(), \"prompt.md\", 2)\n\t\tp.AddCandidate(\"content-a\", nil)\n\t\tp.AddCandidate(\"content-b\", nil)\n\t\t// a is better on success rate, b is better on step count\n\t\tp.Candidates[0].Fitness = FitnessScores{SuccessRate: 0.9, StepCount: 1.0, TotalRuns: 3}\n\t\tp.Candidates[1].Fitness = FitnessScores{SuccessRate: 0.5, StepCount: 3.0, TotalRuns: 3}\n\t\tassert.Nil(t, p.FindPromotable())\n\t})\n}\n\nfunc TestPopulationPromote(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"impl.md\"), []byte(\"original\"), 0644)\n\n\tp := NewPopulation(dir, \".cloche/prompts/impl.md\", 1)\n\tcandidate := &Candidate{\n\t\tID:      \"candidate-1\",\n\t\tContent: \"# Improved Prompt\\n\\n## Learned Rules\\n\\n- Better rule\\n\",\n\t}\n\n\trequire.NoError(t, p.Promote(candidate))\n\n\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"impl.md\"))\n\trequire.NoError(t, err)\n\tassert.Equal(t, candidate.Content, string(content))\n}\n\n// --- Curator.Curate() tests ---\n\nfunc TestCuratorCurateReturnsContent(t *testing.T) {\n\tupdatedContent := \"# Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n\"\n\tllm := &fakeLLM{response: updatedContent}\n\tc := &Curator{LLM: llm}\n\n\tlesson := &Lesson{\n\t\tInsight:         \"Missing validation\",\n\t\tSuggestedAction: \"Add input validation\",\n\t}\n\n\tresult, err := c.Curate(context.Background(), \"# Prompt\\n\\nWrite good code.\\n\", lesson)\n\trequire.NoError(t, err)\n\tassert.Contains(t, result, \"Always validate inputs\")\n}\n\nfunc TestCuratorCurateSkipsExistingLesson(t *testing.T) {\n\tllm := &fakeLLM{response: \"THIS SHOULD NOT BE USED\"}\n\tc := &Curator{LLM: llm}\n\n\texisting := \"# Prompt\\n\\n## Learned Rules\\n\\n- Missing validation: Add input validation\\n\"\n\tlesson := &Lesson{\n\t\tInsight:         \"Missing validation\",\n\t\tSuggestedAction: \"Add input validation\",\n\t}\n\n\tresult, err := c.Curate(context.Background(), existing, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, existing, result)\n}\n\nfunc TestCuratorCurateFallsBackOnConversationalResponse(t *testing.T) {\n\tllm := &fakeLLM{response: \"I've updated the prompt with your changes.\"}\n\tc := &Curator{LLM: llm}\n\n\tlesson := &Lesson{\n\t\tInsight:         \"New rule needed\",\n\t\tSuggestedAction: \"Add the rule\",\n\t}\n\n\tresult, err := c.Curate(context.Background(), \"# Prompt\\n\\nDo work.\\n\", lesson)\n\trequire.NoError(t, err)\n\tassert.Contains(t, result, \"New rule needed\")\n\tassert.Contains(t, result, \"## Learned Rules\")\n}\n\n// --- Integration tests: Orchestrator with population mode ---\n\nfunc TestOrchestratorPopulationModeAddsCandidateInsteadOfEditing(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\n\toriginalPrompt := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(originalPrompt), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  implement:success -> done\n  implement:fail -> abort\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t// Reflector\n\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t\t// Curator.Curate\n\t\t\t\"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n\t\t},\n\t}\n\n\tpop := NewPopulation(dir, \".cloche/prompts/implement.md\", 3)\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\torch.Population = pop\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\n\t// Should have a population_candidate change, not a prompt_update\n\trequire.Len(t, result.Changes, 1)\n\tassert.Equal(t, \"population_candidate\", result.Changes[0].Type)\n\tassert.Equal(t, \".cloche/prompts/implement.md\", result.Changes[0].File)\n\n\t// The base prompt file should remain unchanged\n\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n\trequire.NoError(t, err)\n\tassert.Equal(t, originalPrompt, string(content))\n\n\t// Population should have one candidate\n\trequire.Len(t, pop.Candidates, 1)\n\tassert.Contains(t, pop.Candidates[0].Content, \"sanitize user inputs\")\n\trequire.Len(t, pop.Candidates[0].AncestorLessons, 1)\n\tassert.Equal(t, \"L001\", pop.Candidates[0].AncestorLessons[0].ID)\n}\n\nfunc TestScoreAndPromotePromotesCandidateAfterMinRuns(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"# Original Prompt\\n\"), 0644)\n\n\tpop := NewPopulation(dir, \".cloche/prompts/implement.md\", 2)\n\tpop.AddCandidate(\"# Improved Prompt\\n\\n## Learned Rules\\n\\n- New rule\\n\", []Lesson{{ID: \"L1\"}})\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:   dir,\n\t\tWorkflowName: \"develop\",\n\t\tLLM:          &fakeLLM{response: \"unused\"},\n\t})\n\torch.Population = pop\n\n\t// First run — not enough runs yet\n\trun1 := &domain.Run{\n\t\tState:          domain.RunStateSucceeded,\n\t\tStepExecutions: []*domain.StepExecution{{}, {}},\n\t}\n\twinner, err := orch.ScoreAndPromote(context.Background(), run1)\n\trequire.NoError(t, err)\n\tassert.Nil(t, winner, \"should not promote after only 1 run\")\n\n\t// Second run — meets MinRuns threshold\n\trun2 := &domain.Run{\n\t\tState:          domain.RunStateSucceeded,\n\t\tStepExecutions: []*domain.StepExecution{{}, {}, {}},\n\t}\n\twinner, err = orch.ScoreAndPromote(context.Background(), run2)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, winner, \"should promote after 2 runs\")\n\tassert.Equal(t, \"candidate-1\", winner.ID)\n\n\t// Verify file was updated\n\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"New rule\")\n}\n\nfunc TestScoreAndPromoteNoDominance(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"impl.md\"),\n\t\t[]byte(\"# Original\\n\"), 0644)\n\n\tpop := NewPopulation(dir, \".cloche/prompts/impl.md\", 1)\n\tpop.AddCandidate(\"content-a\", nil)\n\tpop.AddCandidate(\"content-b\", nil)\n\n\t// Set up non-dominating fitness (a better on success, b better on steps)\n\tpop.Candidates[0].Fitness = FitnessScores{SuccessRate: 0.9, StepCount: 1.0, TotalRuns: 2}\n\tpop.Candidates[1].Fitness = FitnessScores{SuccessRate: 0.5, StepCount: 3.0, TotalRuns: 1}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:   dir,\n\t\tWorkflowName: \"develop\",\n\t\tLLM:          &fakeLLM{response: \"unused\"},\n\t})\n\torch.Population = pop\n\n\t// Evaluate one more run for candidate-2 (most recent)\n\trun := &domain.Run{\n\t\tState:          domain.RunStateFailed,\n\t\tStepExecutions: []*domain.StepExecution{{}, {}, {}},\n\t}\n\twinner, err := orch.ScoreAndPromote(context.Background(), run)\n\trequire.NoError(t, err)\n\tassert.Nil(t, winner, \"should not promote when no candidate dominates\")\n\n\t// File should remain unchanged\n\tcontent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"impl.md\"))\n\tassert.Equal(t, \"# Original\\n\", string(content))\n}\n\nfunc TestScoreAndPromoteWithoutPopulationReturnsError(t *testing.T) {\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:   t.TempDir(),\n\t\tWorkflowName: \"develop\",\n\t\tLLM:          &fakeLLM{response: \"unused\"},\n\t})\n\n\t_, err := orch.ScoreAndPromote(context.Background(), &domain.Run{})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"population mode not enabled\")\n}\n\nfunc TestOrchestratorPopulationModeEndToEnd(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\n\toriginalPrompt := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(originalPrompt), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  implement:success -> done\n  implement:fail -> abort\n}`), 0644)\n\n\t// Step 1: Run orchestrator in population mode to produce a candidate\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Missing error handling\", \"suggested_action\": \"Add error handling rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t\t\"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always handle errors\\n\",\n\t\t},\n\t}\n\n\tpop := NewPopulation(dir, \".cloche/prompts/implement.md\", 2)\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\torch.Population = pop\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\trequire.Len(t, result.Changes, 1)\n\tassert.Equal(t, \"population_candidate\", result.Changes[0].Type)\n\n\t// Step 2: Score two successful runs\n\tfor i := 0; i < 2; i++ {\n\t\trun := &domain.Run{\n\t\t\tState:          domain.RunStateSucceeded,\n\t\t\tStepExecutions: []*domain.StepExecution{{}, {}},\n\t\t}\n\t\twinner, err := orch.ScoreAndPromote(context.Background(), run)\n\t\trequire.NoError(t, err)\n\t\tif i < 1 {\n\t\t\tassert.Nil(t, winner)\n\t\t} else {\n\t\t\trequire.NotNil(t, winner, \"should promote after MinRuns\")\n\t\t\tassert.Equal(t, \"candidate-1\", winner.ID)\n\t\t}\n\t}\n\n\t// Step 3: Verify the prompt file was updated\n\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"Always handle errors\")\n\tassert.NotEqual(t, originalPrompt, string(content))\n}\n","structuredPatch":[],"originalFile":null}}
