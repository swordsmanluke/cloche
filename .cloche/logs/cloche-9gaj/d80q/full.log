son{Insight: \"test\", SuggestedAction: \"test\"})\n    49→\trequire.Error(t, err)\n    50→\tassert.Contains(t, err.Error(), \"shebang\")\n    51→}\n    52→\n    53→func TestScriptGenerator_AlreadyExists(t *testing.T) {\n    54→\tdir := t.TempDir()\n    55→\tscriptPath := filepath.Join(dir, \"scripts\", \"check.sh\")\n    56→\tos.MkdirAll(filepath.Dir(scriptPath), 0755)\n    57→\tos.WriteFile(scriptPath, []byte(\"#!/bin/bash\\nold\"), 0644)\n    58→\n    59→\tresp, _ := json.Marshal(scriptResponse{\n    60→\t\tPath:    \"scripts/check.sh\",\n    61→\t\tContent: \"#!/bin/bash\\nnew\",\n    62→\t})\n    63→\tgen := &ScriptGenerator{LLM: &fakeLLM{response: string(resp)}}\n    64→\n    65→\t_, err := gen.Generate(context.Background(), dir, &Lesson{Insight: \"test\", SuggestedAction: \"test\"})\n    66→\trequire.Error(t, err)\n    67→\tassert.Contains(t, err.Error(), \"already exists\")\n    68→\n    69→\t// Verify old content is preserved\n    70→\tdata, _ := os.ReadFile(scriptPath)\n    71→\tassert.Equal(t, \"#!/bin/bash\\nold\", string(data))\n    72→}\n    73→\n    74→func TestScriptGenerator_ValidScript(t *testing.T) {\n    75→\tdir := t.TempDir()\n    76→\tresp, _ := json.Marshal(scriptResponse{\n    77→\t\tPath:    \"scripts/lint.sh\",\n    78→\t\tContent: \"#!/bin/bash\\nset -e\\ngo vet ./...\",\n    79→\t})\n    80→\tgen := &ScriptGenerator{LLM: &fakeLLM{response: string(resp)}}\n    81→\n    82→\tresult, err := gen.Generate(context.Background(), dir, &Lesson{Insight: \"test\", SuggestedAction: \"test\"})\n    83→\trequire.NoError(t, err)\n    84→\tassert.Equal(t, \"scripts/lint.sh\", result.Path)\n    85→\n    86→\t// Verify file was written non-executable\n    87→\tinfo, err := os.Stat(filepath.Join(dir, \"scripts\", \"lint.sh\"))\n    88→\trequire.NoError(t, err)\n    89→\tassert.Equal(t, os.FileMode(0644), info.Mode().Perm())\n    90→}\n    91→\n    92→func TestScriptGenerator_ClocheScriptsPath(t *testing.T) {\n    93→\tdir := t.TempDir()\n    94→\tresp, _ := json.Marshal(scriptResponse{\n    95→\t\tPath:    \".cloche/scripts/check.sh\",\n    96→\t\tContent: \"#!/bin/sh\\nexit 0\",\n    97→\t})\n    98→\tgen := &ScriptGenerator{LLM: &fakeLLM{response: string(resp)}}\n    99→\n   100→\tresult, err := gen.Generate(context.Background(), dir, &Lesson{Insight: \"test\", SuggestedAction: \"test\"})\n   101→\trequire.NoError(t, err)\n   102→\tassert.Equal(t, \".cloche/scripts/check.sh\", result.Path)\n   103→}\n   104→\n   105→func TestValidateScriptPath(t *testing.T) {\n   106→\ttests := []struct {\n   107→\t\tpath    string\n   108→\t\twantErr bool\n   109→\t}{\n   110→\t\t{\"scripts/check.sh\", false},\n   111→\t\t{\".cloche/scripts/check.sh\", false},\n   112→\t\t{\"scripts/sub/check.sh\", false},\n   113→\t\t{\"../scripts/check.sh\", true},\n   114→\t\t{\"scripts/../../../etc/passwd\", true},\n   115→\t\t{\"src/main.go\", true},\n   116→\t\t{\"prompts/foo.md\", true},\n   117→\t}\n   118→\tfor _, tt := range tests {\n   119→\t\tt.Run(tt.path, func(t *testing.T) {\n   120→\t\t\terr := validateScriptPath(tt.path)\n   121→\t\t\tif tt.wantErr {\n   122→\t\t\t\tassert.Error(t, err)\n   123→\t\t\t} else {\n   124→\t\t\t\tassert.NoError(t, err)\n   125→\t\t\t}\n   126→\t\t})\n   127→\t}\n   128→}\n   129→"}]},"parent_tool_use_id":"toolu_011hfDmo89C3udi3vGcWKPt1","session_id":"f7e0d0a9-9907-4df1-a980-7e0c554bc17f","uuid":"973344ab-cd0a-42a0-bd27-c79f4d9470fd","timestamp":"2026-03-17T14:08:57.397Z"}
