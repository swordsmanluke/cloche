[2026-03-17T14:14:48Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DAwWq2rCQhMVePjmKZvo4r","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"strings\"\n     9→\t\"time\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    12→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    13→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14→)\n    15→\n    16→// OrchestratorConfig configures the evolution pipeline.\n    17→type OrchestratorConfig struct {\n    18→\tProjectDir       string\n    19→\tWorkflowName     string\n    20→\tLLM              LLMClient\n    21→\tMinConfidence    string\n    22→\tMaxPromptBullets int\n    23→}\n    24→\n    25→// Orchestrator wires all evolution pipeline stages together.\n    26→type Orchestrator struct {\n    27→\tcfg        OrchestratorConfig\n    28→\tcollector  *Collector\n    29→\tclassifier *Classifier\n    30→\treflector  *Reflector\n    31→\tcurator    *Curator\n    32→\tscriptGen  *ScriptGenerator\n    33→\tmutator    *dsl.Mutator\n    34→\taudit      *AuditLogger\n    35→\tPopulation *Population // optional; when set, prompt_improvement lessons produce candidates instead of direct edits\n    36→}\n    37→\n    38→// NewOrchestrator creates a fully wired evolution pipeline.\n    39→func NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n    40→\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir, MaxPromptBullets: cfg.MaxPromptBullets}\n    41→\treturn &Orchestrator{\n    42→\t\tcfg:        cfg,\n    43→\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n    44→\t\tclassifier: &Classifier{LLM: cfg.LLM},\n    45→\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n    46→\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n    47→\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n    48→\t\tmutator:    &dsl.Mutator{},\n    49→\t\taudit:      audit,\n    50→\t}\n    51→}\n    52→\n    53→// Run executes the full evolution pipeline.\n    54→func (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n    55→\t// Stage 1: Collect\n    56→\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n    57→\tif err != nil {\n    58→\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n    59→\t}\n    60→\n    61→\t// Stage 2: Classify the triggering run\n    62→\tclassification, err := o.classifier.Classify(ctx, \"\")\n    63→\tif err != nil {\n    64→\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n    65→\t}\n    66→\n    67→\t// Stage 3: Reflect\n    68→\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n    69→\tif err != nil {\n    70→\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n    71→\t}\n    72→\n    73→\t// Filter out lessons whose IDs are already recorded in the knowledge base.\n    74→\t// This guards against the Reflector re-surfacing previously applied lessons.\n    75→\tif data.KnowledgeBase != \"\" {\n    76→\t\tvar fresh []Lesson\n    77→\t\tfor _, l := range lessons {\n    78→\t\t\tif l.ID != \"\" && strings.Contains(data.KnowledgeBase, l.ID) {\n    79→\t\t\t\tcontinue\n    80→\t\t\t}\n    81→\t\t\tfresh = append(fresh, l)\n    82→\t\t}\n    83→\t\tlessons = fresh\n    84→\t}\n    85→\n    86→\tresult := &EvolutionResult{\n    87→\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n    88→\t\tProjectDir:     o.cfg.ProjectDir,\n    89→\t\tWorkflowName:   o.cfg.WorkflowName,\n    90→\t\tTriggerRunID:   triggerRunID,\n    91→\t\tTimestamp:      time.Now().Format(time.RFC3339),\n    92→\t\tClassification: classification,\n    93→\t}\n    94→\n    95→\tif len(lessons) == 0 {\n    96→\t\t// No actionable lessons — log and return\n    97→\t\to.audit.Log(result)\n    98→\t\treturn result, nil\n    99→\t}\n   100→\n   101→\t// Stage 4: Execute branches based on lesson category\n   102→\tfor _, lesson := range lessons {\n   103→\t\tswitch lesson.Category {\n   104→\t\tcase \"prompt_improvement\":\n   105→\t\t\tif o.Population != nil {\n   106→\t\t\t\t// Population mode: produce a candidate instead of editing the base prompt\n   107→\t\t\t\tcurrentContent := data.CurrentPrompts[lesson.Target]\n   108→\t\t\t\tcontent, err := o.curator.Curate(ctx, currentContent, &lesson)\n   109→\t\t\t\tif err != nil {\n   110→\t\t\t\t\tcontinue\n   111→\t\t\t\t}\n   112→\t\t\t\tif content == currentContent {\n   113→\t\t\t\t\tcontinue // lesson already present — no candidate needed\n   114→\t\t\t\t}\n   115→\t\t\t\to.Population.AddCandidate(content, []Lesson{lesson})\n   116→\t\t\t\tresult.Changes = append(result.Changes, Change{\n   117→\t\t\t\t\tType:   \"population_candidate\",\n   118→\t\t\t\t\tFile:   lesson.Target,\n   119→\t\t\t\t\tReason: lesson.Insight,\n   120→\t\t\t\t})\n   121→\t\t\t} else {\n   122→\t\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n   123→\t\t\t\tif err != nil {\n   124→\t\t\t\t\tcontinue // log but don't fail the whole pipeline\n   125→\t\t\t\t}\n   126→\t\t\t\tif change == nil {\n   127→\t\t\t\t\tcontinue // lesson already present in prompt — no change needed\n   128→\t\t\t\t}\n   129→\t\t\t\tresult.Changes = append(result.Changes, *change)\n   130→\t\t\t}\n   131→\n   132→\t\tcase \"new_step\":\n   133→\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n   134→\t\t\t\tcontinue\n   135→\t\t\t}\n   136→\t\t}\n   137→\t}\n   138→\n   139→\t// Stage 5: Audit\n   140→\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n   141→\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n   142→\to.audit.Log(result)\n   143→\n   144→\t// Save to store if available\n   145→\tif evoStore != nil {\n   146→\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n   147→\t\t\tID:             result.ID,\n   148→\t\t\tProjectDir:     result.ProjectDir,\n   149→\t\t\tWorkflowName:   result.WorkflowName,\n   150→\t\t\tTriggerRunID:   result.TriggerRunID,\n   151→\t\t\tCreatedAt:      time.Now(),\n   152→\t\t\tClassification: result.Classification,\n   153→\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n   154→\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n   155→\t\t})\n   156→\t}\n   157→\n   158→\treturn result, nil\n   159→}\n   160→\n   161→// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\n   162→func (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n   163→\t// Generate the script or prompt file\n   164→\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n   165→\tif err != nil {\n   166→\t\treturn err\n   167→\t}\n   168→\n   169→\tresult.Changes = append(result.Changes, Change{\n   170→\t\tType:   \"add_script\",\n   171→\t\tFile:   generated.Path,\n   172→\t\tReason: lesson.Insight,\n   173→\t})\n   174→\n   175→\t// Add step and wiring to the workflow file\n   176→\tif data.WorkflowPath == \"\" {\n   177→\t\treturn nil\n   178→\t}\n   179→\n   180→\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n   181→\tif err != nil {\n   182→\t\treturn err\n   183→\t}\n   184→\n   185→\t// Snapshot the workflow\n   186→\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n   187→\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n   188→\toriginal := string(workflowContent)\n   189→\n   190→\t// Derive step name from the script path\n   191→\tstepName := filepath.Base(generated.Path)\n   192→\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n   193→\n   194→\t// Check if a step with this name already exists — skip if so\n   195→\texistingWf, parseErr := dsl.Parse(original)\n   196→\tif parseErr == nil {\n   197→\t\tif _, exists := existingWf.Steps[stepName]; exists {\n   198→\t\t\treturn nil\n   199→\t\t}\n   200→\t}\n   201→\n   202→\t// Determine the config based on step type\n   203→\tconfig := map[string]string{}\n   204→\tswitch lesson.StepType {\n   205→\tcase \"agent\":\n   206→\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n   207→\tdefault: // script\n   208→\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n   209→\t}\n   210→\n   211→\t// Add the step\n   212→\tupdated, err := o.mutator.AddStep(original, dsl.StepDef{\n   213→\t\tName:    stepName,\n   214→\t\tType:    lesson.StepType,\n   215→\t\tConfig:  config,\n   216→\t\tResults: []string{\"success\", \"fail\"},\n   217→\t})\n   218→\tif err != nil {\n   219→\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n   220→\t}\n   221→\n   222→\t// Wire the new step into the existing graph by finding a wire\n   223→\t// that currently goes to \"done\" and rerouting it through the new step.\n   224→\twf, parseErr := dsl.Parse(updated)\n   225→\tif parseErr == nil {\n   226→\t\tfor _, wire := range wf.Wiring {\n   227→\t\t\tif wire.To == \"done\" {\n   228→\t\t\t\trewired, rewireErr := o.mutator.RewireResult(updated, wire.From, wire.Result, \"done\", stepName)\n   229→\t\t\t\tif rewireErr == nil {\n   230→\t\t\t\t\tupdated = rewired\n   231→\t\t\t\t\tbreak\n   232→\t\t\t\t}\n   233→\t\t\t}\n   234→\t\t}\n   235→\t}\n   236→\n   237→\t// Wire the new step's results to terminals\n   238→\twires := []dsl.WireDef{\n   239→\t\t{From: stepName, Result: \"success\", To: \"done\"},\n   240→\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n   241→\t}\n   242→\tupdated, err = o.mutator.AddWiring(updated, wires)\n   243→\tif err != nil {\n   244→\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n   245→\t}\n   246→\n   247→\t// Validate the final workflow graph — roll back on failure\n   248→\tfinalWf, parseErr := dsl.Parse(updated)\n   249→\tif parseErr != nil {\n   250→\t\treturn fmt.Errorf(\"parsing updated workflow: %w\", parseErr)\n   251→\t}\n   252→\tif valErr := finalWf.Validate(); valErr != nil {\n   253→\t\treturn fmt.Errorf(\"workflow validation failed after adding step %q: %w\", stepName, valErr)\n   254→\t}\n   255→\n   256→\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n   257→\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n   258→\t}\n   259→\n   260→\tresult.Changes = append(result.Changes, Change{\n   261→\t\tType:     \"add_step\",\n   262→\t\tFile:     wfRelPath,\n   263→\t\tReason:   lesson.Insight,\n   264→\t\tSnapshot: snapName,\n   265→\t})\n   266→\n   267→\treturn nil\n   268→}\n   269→\n   270→// ScoreAndPromote evaluates a completed run against the population and\n   271→// promotes a candidate if it meets the promotion criteria (minimum runs\n   272→// and Pareto dominance over all other candidates).\n   273→func (o *Orchestrator) ScoreAndPromote(ctx context.Context, run *domain.Run) (*Candidate, error) {\n   274→\tif o.Population == nil {\n   275→\t\treturn nil, fmt.Errorf(\"population mode not enabled\")\n   276→\t}\n   277→\n   278→\tif len(o.Population.Candidates) == 0 {\n   279→\t\treturn nil, nil\n   280→\t}\n   281→\n   282→\t// Evaluate run fitness for all candidates. In a full implementation,\n   283→\t// runs would be tagged with the candidate that produced them; here we\n   284→\t// evaluate against the most recently added candidate.\n   285→\tlastIdx := len(o.Population.Candidates) - 1\n   286→\tlastID := o.Population.Candidates[lastIdx].ID\n   287→\n   288→\tif err := o.Population.EvaluateRun(lastID, run); err != nil {\n   289→\t\treturn nil, fmt.Errorf(\"evaluating run: %w\", err)\n   290→\t}\n   291→\n   292→\t// Check if any candidate meets promotion criteria\n   293→\twinner := o.Population.FindPromotable()\n   294→\tif winner == nil {\n   295→\t\treturn nil, nil\n   296→\t}\n   297→\n   298→\tif err := o.Population.Promote(winner); err != nil {\n   299→\t\treturn nil, fmt.Errorf(\"promoting candidate: %w\", err)\n   300→\t}\n   301→\n   302→\treturn winner, nil\n   303→}\n   304→"}]},"parent_tool_use_id":null,"session_id":"81a83595-a06e-46f2-b0c3-1fba000c92af","uuid":"5268045a-77a4-4dd4-b49f-7f14a67f3f14","timestamp":"2026-03-17T14:13:45.163Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/orchestrator.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// OrchestratorConfig configures the evolution pipeline.\ntype OrchestratorConfig struct {\n\tProjectDir       string\n\tWorkflowName     string\n\tLLM              LLMClient\n\tMinConfidence    string\n\tMaxPromptBullets int\n}\n\n// Orchestrator wires all evolution pipeline stages together.\ntype Orchestrator struct {\n\tcfg        OrchestratorConfig\n\tcollector  *Collector\n\tclassifier *Classifier\n\treflector  *Reflector\n\tcurator    *Curator\n\tscriptGen  *ScriptGenerator\n\tmutator    *dsl.Mutator\n\taudit      *AuditLogger\n\tPopulation *Population // optional; when set, prompt_improvement lessons produce candidates instead of direct edits\n}\n\n// NewOrchestrator creates a fully wired evolution pipeline.\nfunc NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir, MaxPromptBullets: cfg.MaxPromptBullets}\n\treturn &Orchestrator{\n\t\tcfg:        cfg,\n\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n\t\tclassifier: &Classifier{LLM: cfg.LLM},\n\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n\t\tmutator:    &dsl.Mutator{},\n\t\taudit:      audit,\n\t}\n}\n\n// Run executes the full evolution pipeline.\nfunc (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n\t// Stage 1: Collect\n\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n\t}\n\n\t// Stage 2: Classify the triggering run\n\tclassification, err := o.classifier.Classify(ctx, \"\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n\t}\n\n\t// Stage 3: Reflect\n\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n\t}\n\n\t// Filter out lessons whose IDs are already recorded in the knowledge base.\n\t// This guards against the Reflector re-surfacing previously applied lessons.\n\tif data.KnowledgeBase != \"\" {\n\t\tvar fresh []Lesson\n\t\tfor _, l := range lessons {\n\t\t\tif l.ID != \"\" && strings.Contains(data.KnowledgeBase, l.ID) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfresh = append(fresh, l)\n\t\t}\n\t\tlessons = fresh\n\t}\n\n\tresult := &EvolutionResult{\n\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n\t\tProjectDir:     o.cfg.ProjectDir,\n\t\tWorkflowName:   o.cfg.WorkflowName,\n\t\tTriggerRunID:   triggerRunID,\n\t\tTimestamp:      time.Now().Format(time.RFC3339),\n\t\tClassification: classification,\n\t}\n\n\tif len(lessons) == 0 {\n\t\t// No actionable lessons — log and return\n\t\to.audit.Log(result)\n\t\treturn result, nil\n\t}\n\n\t// Stage 4: Execute branches based on lesson category\n\tfor _, lesson := range lessons {\n\t\tswitch lesson.Category {\n\t\tcase \"prompt_improvement\":\n\t\t\tif o.Population != nil {\n\t\t\t\t// Population mode: produce a candidate instead of editing the base prompt\n\t\t\t\tcurrentContent := data.CurrentPrompts[lesson.Target]\n\t\t\t\tcontent, err := o.curator.Curate(ctx, currentContent, &lesson)\n\t\t\t\tif err != nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif content == currentContent {\n\t\t\t\t\tcontinue // lesson already present — no candidate needed\n\t\t\t\t}\n\t\t\t\to.Population.AddCandidate(content, []Lesson{lesson})\n\t\t\t\tresult.Changes = append(result.Changes, Change{\n\t\t\t\t\tType:   \"population_candidate\",\n\t\t\t\t\tFile:   lesson.Target,\n\t\t\t\t\tReason: lesson.Insight,\n\t\t\t\t})\n\t\t\t} else {\n\t\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n\t\t\t\tif err != nil {\n\t\t\t\t\tcontinue // log but don't fail the whole pipeline\n\t\t\t\t}\n\t\t\t\tif change == nil {\n\t\t\t\t\tcontinue // lesson already present in prompt — no change needed\n\t\t\t\t}\n\t\t\t\tresult.Changes = append(result.Changes, *change)\n\t\t\t}\n\n\t\tcase \"new_step\":\n\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\t}\n\n\t// Stage 5: Audit\n\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n\to.audit.Log(result)\n\n\t// Save to store if available\n\tif evoStore != nil {\n\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n\t\t\tID:             result.ID,\n\t\t\tProjectDir:     result.ProjectDir,\n\t\t\tWorkflowName:   result.WorkflowName,\n\t\t\tTriggerRunID:   result.TriggerRunID,\n\t\t\tCreatedAt:      time.Now(),\n\t\t\tClassification: result.Classification,\n\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n\t\t})\n\t}\n\n\treturn result, nil\n}\n\n// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\nfunc (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n\t// Generate the script or prompt file\n\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tresult.Changes = append(result.Changes, Change{\n\t\tType:   \"add_script\",\n\t\tFile:   generated.Path,\n\t\tReason: lesson.Insight,\n\t})\n\n\t// Add step and wiring to the workflow file\n\tif data.WorkflowPath == \"\" {\n\t\treturn nil\n\t}\n\n\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// Snapshot the workflow\n\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n\toriginal := string(workflowContent)\n\n\t// Derive step name from the script path\n\tstepName := filepath.Base(generated.Path)\n\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n\n\t// Check if a step with this name already exists — skip if so\n\texistingWf, parseErr := dsl.Parse(original)\n\tif parseErr == nil {\n\t\tif _, exists := existingWf.Steps[stepName]; exists {\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Determine the config based on step type\n\tconfig := map[string]string{}\n\tswitch lesson.StepType {\n\tcase \"agent\":\n\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n\tdefault: // script\n\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n\t}\n\n\t// Add the step\n\tupdated, err := o.mutator.AddStep(original, dsl.StepDef{\n\t\tName:    stepName,\n\t\tType:    lesson.StepType,\n\t\tConfig:  config,\n\t\tResults: []string{\"success\", \"fail\"},\n\t})\n\tif err != nil {\n\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n\t}\n\n\t// Wire the new step into the existing graph by finding a wire\n\t// that currently goes to \"done\" and rerouting it through the new step.\n\twf, parseErr := dsl.Parse(updated)\n\tif parseErr == nil {\n\t\tfor _, wire := range wf.Wiring {\n\t\t\tif wire.To == \"done\" {\n\t\t\t\trewired, rewireErr := o.mutator.RewireResult(updated, wire.From, wire.Result, \"done\", stepName)\n\t\t\t\tif rewireErr == nil {\n\t\t\t\t\tupdated = rewired\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Wire the new step's results to terminals\n\twires := []dsl.WireDef{\n\t\t{From: stepName, Result: \"success\", To: \"done\"},\n\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n\t}\n\tupdated, err = o.mutator.AddWiring(updated, wires)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n\t}\n\n\t// Validate the final workflow graph — roll back on failure\n\tfinalWf, parseErr := dsl.Parse(updated)\n\tif parseErr != nil {\n\t\treturn fmt.Errorf(\"parsing updated workflow: %w\", parseErr)\n\t}\n\tif valErr := finalWf.Validate(); valErr != nil {\n\t\treturn fmt.Errorf(\"workflow validation failed after adding step %q: %w\", stepName, valErr)\n\t}\n\n\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n\t}\n\n\tresult.Changes = append(result.Changes, Change{\n\t\tType:     \"add_step\",\n\t\tFile:     wfRelPath,\n\t\tReason:   lesson.Insight,\n\t\tSnapshot: snapName,\n\t})\n\n\treturn nil\n}\n\n// ScoreAndPromote evaluates a completed run against the population and\n// promotes a candidate if it meets the promotion criteria (minimum runs\n// and Pareto dominance over all other candidates).\nfunc (o *Orchestrator) ScoreAndPromote(ctx context.Context, run *domain.Run) (*Candidate, error) {\n\tif o.Population == nil {\n\t\treturn nil, fmt.Errorf(\"population mode not enabled\")\n\t}\n\n\tif len(o.Population.Candidates) == 0 {\n\t\treturn nil, nil\n\t}\n\n\t// Evaluate run fitness for all candidates. In a full implementation,\n\t// runs would be tagged with the candidate that produced them; here we\n\t// evaluate against the most recently added candidate.\n\tlastIdx := len(o.Population.Candidates) - 1\n\tlastID := o.Population.Candidates[lastIdx].ID\n\n\tif err := o.Population.EvaluateRun(lastID, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"evaluating run: %w\", err)\n\t}\n\n\t// Check if any candidate meets promotion criteria\n\twinner := o.Population.FindPromotable()\n\tif winner == nil {\n\t\treturn nil, nil\n\t}\n\n\tif err := o.Population.Promote(winner); err != nil {\n\t\treturn nil, fmt.Errorf(\"promoting candidate: %w\", err)\n\t}\n\n\treturn winner, nil\n}\n","numLines":304,"startLine":1,"totalLines":304}}}
