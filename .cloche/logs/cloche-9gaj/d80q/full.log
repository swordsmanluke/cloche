\n    42→\tWorkflowName   string   `json:\"workflow_name\"`\n    43→\tTriggerRunID   string   `json:\"trigger_run_id\"`\n    44→\tTimestamp      string   `json:\"timestamp\"`\n    45→\tClassification string   `json:\"classification\"`\n    46→\tChanges        []Change `json:\"changes\"`\n    47→\tKnowledgeDelta string   `json:\"knowledge_delta\"`\n    48→}\n    49→\n    50→// Change describes a single file modification made by evolution.\n    51→type Change struct {\n    52→\tType     string `json:\"type\"`\n    53→\tFile     string `json:\"file\"`\n    54→\tReason   string `json:\"reason\"`\n    55→\tSnapshot string `json:\"snapshot\"`\n    56→}\n    57→"}]},"parent_tool_use_id":null,"session_id":"f7e0d0a9-9907-4df1-a980-7e0c554bc17f","uuid":"02308247-1cd5-4184-8cf3-3bdfa1da2c42","timestamp":"2026-03-17T14:09:33.510Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/types.go","content":"package evolution\n\nimport (\n\t\"context\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n)\n\n// LLMClient abstracts LLM calls for evolution stages.\ntype LLMClient interface {\n\tComplete(ctx context.Context, systemPrompt, userPrompt string) (string, error)\n}\n\n// CollectedData is the input to the Classifier and Reflector.\ntype CollectedData struct {\n\tRuns            []*domain.Run\n\tCaptures        map[string][]*domain.StepExecution // run_id -> step executions\n\tKnowledgeBase   string                             // contents of knowledge/<workflow>.jsonl\n\tCurrentPrompts  map[string]string                  // relative path -> content\n\tCurrentWorkflow string                             // .cloche file content\n\tWorkflowPath    string                             // path to .cloche file\n\tProjectDir      string\n\tWorkflowName    string\n}\n\n// Lesson is a structured insight extracted by the Reflector.\ntype Lesson struct {\n\tID              string   `json:\"id\"`\n\tCategory        string   `json:\"category\"`\n\tStepType        string   `json:\"step_type,omitempty\"`\n\tTarget          string   `json:\"target,omitempty\"`\n\tInsight         string   `json:\"insight\"`\n\tSuggestedAction string   `json:\"suggested_action\"`\n\tEvidence        []string `json:\"evidence\"`\n\tConfidence      string   `json:\"confidence\"`\n}\n\n// EvolutionResult records what an evolution pass produced.\ntype EvolutionResult struct {\n\tID             string   `json:\"id\"`\n\tProjectDir     string   `json:\"project_dir\"`\n\tWorkflowName   string   `json:\"workflow_name\"`\n\tTriggerRunID   string   `json:\"trigger_run_id\"`\n\tTimestamp      string   `json:\"timestamp\"`\n\tClassification string   `json:\"classification\"`\n\tChanges        []Change `json:\"changes\"`\n\tKnowledgeDelta string   `json:\"knowledge_delta\"`\n}\n\n// Change describes a single file modification made by evolution.\ntype Change struct {\n\tType     string `json:\"type\"`\n\tFile     string `json:\"file\"`\n\tReason   string `json:\"reason\"`\n\tSnapshot string `json:\"snapshot\"`\n}\n","numLines":57,"startLine":1,"totalLines":57}}}
[2026-03-17T14:13:27Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018ePV9QYsCFLhjCGGGLo5SW","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"regexp\"\n     9→\t\"strings\"\n    10→)\n    11→\n    12→// Curator merges lessons into prompt files using ACE-style curation.\n    13→type Curator struct {\n    14→\tLLM   LLMClient\n    15→\tAudit *AuditLogger\n    16→}\n    17→\n    18→// lessonAlreadyPresent checks whether the lesson's key insight or action is\n    19→// already present in the current prompt text (case-insensitive substring match).\n    20→func lessonAlreadyPresent(currentPrompt string, lesson *Lesson) bool {\n    21→\tlower := strings.ToLower(currentPrompt)\n    22→\tif lesson.Insight != \"\" && strings.Contains(lower, strings.ToLower(lesson.Insight)) {\n    23→\t\treturn true\n    24→\t}\n    25→\tif lesson.SuggestedAction != \"\" && strings.Contains(lower, strings.ToLower(lesson.SuggestedAction)) {\n    26→\t\treturn true\n    27→\t}\n    28→\treturn false\n    29→}\n    30→\n    31→// Apply curates a lesson into the target prompt file.\n    32→func (c *Curator) Apply(ctx context.Context, projectDir string, lesson *Lesson) (*Change, error) {\n    33→\ttargetPath := filepath.Join(projectDir, lesson.Target)\n    34→\tcurrent, err := os.ReadFile(targetPath)\n    35→\tif err != nil {\n    36→\t\treturn nil, fmt.Errorf(\"reading target prompt %s: %w\", lesson.Target, err)\n    37→\t}\n    38→\n    39→\t// Guard: skip if the lesson is already incorporated in the prompt\n    40→\tif lessonAlreadyPresent(string(current), lesson) {\n    41→\t\treturn nil, nil\n    42→\t}\n    43→\n    44→\tsystemPrompt := `You are a prompt curator using ACE (Agentic Context Engineering) principles.\n    45→Your job is to merge a new lesson into an existing prompt document.\n    46→\n    47→Rules:\n    48→- Append the lesson as a structured bullet/rule in a \"## Learned Rules\" section\n    49→- If a \"## Learned Rules\" section already exists, add to it\n    50→- If the lesson refines or duplicates an existing rule, update in place rather than appending\n    51→- Preserve ALL existing content exactly as-is\n    52→- Keep rules concise and actionable\n    53→- Do not add commentary — return only the updated prompt content`\n    54→\n    55→\tuserPrompt := fmt.Sprintf(\"## Current Prompt Content\\n```\\n%s\\n```\\n\\n## Lesson to Merge\\nInsight: %s\\nSuggested Action: %s\",\n    56→\t\tstring(current), lesson.Insight, lesson.SuggestedAction)\n    57→\n    58→\traw, err := c.LLM.Complete(ctx, systemPrompt, userPrompt)\n    59→\tif err != nil {\n    60→\t\treturn nil, fmt.Errorf(\"curator LLM call: %w\", err)\n    61→\t}\n    62→\n    63→\tupdated := stripCodeFences(raw)\n    64→\n    65→\t// Validate that the LLM output is actual prompt content, not meta-conversation\n    66→\tif isConversationalResponse(updated) {\n    67→\t\t// Fallback: append the lesson directly rather than trusting the LLM\n    68→\t\tupdated = appendLessonDirectly(string(current), lesson)\n    69→\t}\n    70→\n    71→\t// Snapshot before writing\n    72→\tvar snapName string\n    73→\tif c.Audit != nil {\n    74→\t\tsnapName, _ = c.Audit.Snapshot(lesson.Target)\n    75→\t}\n    76→\n    77→\tif err := os.WriteFile(targetPath, []byte(updated), 0644); err != nil {\n    78→\t\treturn nil, fmt.Errorf(\"writing updated prompt: %w\", err)\n    79→\t}\n    80→\n    81→\t// Post-write sanity check: re-read and validate the written content\n    82→\twritten, err := os.ReadFile(targetPath)\n    83→\tif err != nil {\n    84→\t\treturn nil, fmt.Errorf(\"re-reading written prompt: %w\", err)\n    85→\t}\n    86→\n    87→\tif !promptSanityCheck(string(written)) {\n    88→\t\t// Rollback: restore from snapshot\n    89→\t\tif c.Audit != nil && snapName != \"\" {\n    90→\t\t\tif restoreErr := c.Audit.Restore(lesson.Target, snapName); restoreErr != nil {\n    91→\t\t\t\treturn nil, fmt.Errorf(\"rollback failed after sanity check: %w\", restoreErr)\n    92→\t\t\t}\n    93→\t\t}\n    94→\t\treturn &Change{\n    95→\t\t\tType:     \"prompt_update_rollback\",\n    96→\t\t\tFile:     lesson.Target,\n    97→\t\t\tReason:   fmt.Sprintf(\"curation rolled back: written content failed sanity check (lesson: %s)\", lesson.Insight),\n    98→\t\t\tSnapshot: snapName,\n    99→\t\t}, nil\n   100→\t}\n   101→\n   102→\treturn &Change{\n   103→\t\tType:     \"prompt_update\",\n   104→\t\tFile:     lesson.Target,\n   105→\t\tReason:   lesson.Insight,\n   106→\t\tSnapshot: snapName,\n   107→\t}, nil\n   108→}\n   109→\n   110→// promptSanityCheck performs basic validation on prompt content to detect corruption.\n   111→// Returns true if the content looks like a valid prompt file.\n   112→func promptSanityCheck(content string) bool {\n   113→\ttrimmed := strings.TrimSpace(content)\n   114→\n   115→\t// Empty content is never valid\n   116→\tif trimmed == \"\" {\n   117→\t\treturn false\n   118→\t}\n   119→\n   120→\t// Must not start with conversational phrases\n   121→\tif isConversationalResponse(trimmed) {\n   122→\t\treturn false\n   123→\t}\n   124→\n   125→\t// Must either start with '#' (markdown heading) or contain at least\n   126→\t// one section header somewhere in the content\n   127→\thasHeading := strings.HasPrefix(trimmed, \"#\") || strings.Contains(trimmed, \"\\n#\")\n   128→\tif !hasHeading {\n   129→\t\treturn false\n   130→\t}\n   131→\n   132→\treturn true\n   133→}\n   134→\n   135→// conversationalMarkers are patterns that indicate the LLM returned\n   136→// meta-conversation text instead of prompt content.\n   137→var conversationalMarkers = regexp.MustCompile(\n   138→\t`(?i)^(I need |I can't |I cannot |Could you |Please grant |` +\n   139→\t\t`I don't have |I do not have |permission|write access|blocked by|` +\n   140→\t\t`Here is the updated|Here's the updated|I've updated|I have updated|` +\n   141→\t\t`Let me |I'll |I will )`)\n   142→\n   143→// isConversationalResponse checks whether the LLM output appears to be\n   144→// meta-conversation text rather than actual prompt content.\n   145→func isConversationalResponse(s string) bool {\n   146→\ttrimmed := strings.TrimSpace(s)\n   147→\tif trimmed == \"\" {\n   148→\t\treturn true\n   149→\t}\n   150→\t// Check the first non-empty line for conversational markers\n   151→\tfirstLine := trimmed\n   152→\tif idx := strings.Index(trimmed, \"\\n\"); idx != -1 {\n   153→\t\tfirstLine = trimmed[:idx]\n   154→\t}\n   155→\treturn conversationalMarkers.MatchString(strings.TrimSpace(firstLine))\n   156→}\n   157→\n   158→// appendLessonDirectly adds a lesson to the prompt content without LLM help,\n   159→// used as a fallback when the LLM returns conversational text.\n   160→func appendLessonDirectly(current string, lesson *Lesson) string {\n   161→\tcurrent = strings.TrimRight(current, \"\\n\")\n   162→\tif strings.Contains(current, \"## Learned Rules\") {\n   163→\t\treturn current + fmt.Sprintf(\"\\n- %s: %s\\n\", lesson.Insight, lesson.SuggestedAction)\n   164→\t}\n   165→\treturn current + fmt.Sprintf(\"\\n\\n## Learned Rules\\n\\n- %s: %s\\n\", lesson.Insight, lesson.SuggestedAction)\n   166→}\n   167→\n   168→// stripCodeFences removes markdown code fences from an LLM response,\n   169→// extracting just the content between them. If no fences are found,\n   170→// the input is returned unchanged (trimmed).\n   171→func stripCodeFences(s string) string {\n   172→\ts = strings.TrimSpace(s)\n   173→\n   174→\topenIdx := strings.Index(s, \"```\")\n   175→\tif openIdx == -1 {\n   176→\t\treturn s\n   177→\t}\n   178→\n   179→\t// Skip the opening fence line (may include language hint like ```markdown)\n   180→\tafterOpen := s[openIdx+3:]\n   181→\tnewlineIdx := strings.Index(afterOpen, \"\\n\")\n   182→\tif newlineIdx == -1 {\n   183→\t\treturn s\n   184→\t}\n   185→\tcontentStart := openIdx + 3 + newlineIdx + 1\n   186→\n   187→\t// Find the closing fence (last ``` in the string)\n   188→\tcloseIdx := strings.LastIndex(s, \"```\")\n   189→\tif closeIdx <= openIdx {\n   190→\t\treturn s\n   191→\t}\n   192→\n   193→\treturn s[contentStart:closeIdx]\n   194→}\n   195→"}]},"parent_tool_use_id":null,"session_id":"f7e0d0a9-9907-4df1-a980-7e0c554bc17f","uuid":"ed9a34ea-edcf-4ebe-9836-90d2dfe94e0c","timestamp":"2026-03-17T14:09:33.515Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/curator.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"strings\"\n)\n\n// Curator merges lessons into prompt files using ACE-style curation.\ntype Curator struct {\n\tLLM   LLMClient\n\tAudit *AuditLogger\n}\n\n// lessonAlreadyPresent checks whether the lesson's key insight or action is\n// already present in the current prompt text (case-insensitive substring match).\nfunc lessonAlreadyPresent(currentPrompt string, lesson *Lesson) bool {\n\tlower := strings.ToLower(currentPrompt)\n\tif lesson.Insight != \"\" && strings.Contains(lower, strings.ToLower(lesson.Insight)) {\n\t\treturn true\n\t}\n\tif lesson.SuggestedAction != \"\" && strings.Contains(lower, strings.ToLower(lesson.SuggestedAction)) {\n\t\treturn true\n\t}\n\treturn false\n}\n\n// Apply curates a lesson into the target prompt file.\nfunc (c *Curator) Apply(ctx context.Context, projectDir string, lesson *Lesson) (*Change, error) {\n\ttargetPath := filepath.Join(projectDir, lesson.Target)\n\tcurrent, err := os.ReadFile(targetPath)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading target prompt %s: %w\", lesson.Target, err)\n\t}\n\n\t// Guard: skip if the lesson is already incorporated in the prompt\n\tif lessonAlreadyPresent(string(current), lesson) {\n\t\treturn nil, nil\n\t}\n\n\tsystemPrompt := `You are a prompt curator using ACE (Agentic Context Engineering) principles.\nYour job is to merge a new lesson into an existing prompt document.\n\nRules:\n- Append the lesson as a structured bullet/rule in a \"## Learned Rules\" section\n- If a \"## Learned Rules\" section already exists, add to it\n- If the lesson refines or duplicates an existing rule, update in place rather than appending\n- Preserve ALL existing content exactly as-is\n- Keep rules concise and actionable\n- Do not add commentary — return only the updated prompt content`\n\n\tuserPrompt := fmt.Sprintf(\"## Current Prompt Content\\n```\\n%s\\n```\\n\\n## Lesson to Merge\\nInsight: %s\\nSuggested Action: %s\",\n\t\tstring(current), lesson.Insight, lesson.SuggestedAction)\n\n\traw, err := c.LLM.Complete(ctx, systemPrompt, userPrompt)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"curator LLM call: %w\", err)\n\t}\n\n\tupdated := stripCodeFences(raw)\n\n\t// Validate that the LLM output is actual prompt content, not meta-conversation\n\tif isConversationalResponse(updated) {\n\t\t// Fallback: append the lesson directly rather than trusting the LLM\n\t\tupdated = appendLessonDirectly(string(current), lesson)\n\t}\n\n\t// Snapshot before writing\n\tvar snapName string\n\tif c.Audit != nil {\n\t\tsnapName, _ = c.Audit.Snapshot(lesson.Target)\n\t}\n\n\tif err := os.WriteFile(targetPath, []byte(updated), 0644); err != nil {\n\t\treturn nil, fmt.Errorf(\"writing updated prompt: %w\", err)\n\t}\n\n\t// Post-write sanity check: re-read and validate the written content\n\twritten, err := os.ReadFile(targetPath)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"re-reading written prompt: %w\", err)\n\t}\n\n\tif !promptSanityCheck(string(written)) {\n\t\t// Rollback: restore from snapshot\n\t\tif c.Audit != nil && snapName != \"\" {\n\t\t\tif restoreErr := c.Audit.Restore(lesson.Target, snapName); restoreErr != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"rollback failed after sanity check: %w\", restoreErr)\n\t\t\t}\n\t\t}\n\t\treturn &Change{\n\t\t\tType:     \"prompt_update_rollback\",\n\t\t\tFile:     lesson.Target,\n\t\t\tReason:   fmt.Sprintf(\"curation rolled back: written content failed sanity check (lesson: %s)\", lesson.Insight),\n\t\t\tSnapshot: snapName,\n\t\t}, nil\n\t}\n\n\treturn &Change{\n\t\tType:     \"prompt_update\",\n\t\tFile:     lesson.Target,\n\t\tReason:   lesson.Insight,\n\t\tSnapshot: snapName,\n\t}, nil\n}\n\n// promptSanityCheck performs basic validation on prompt content to detect corruption.\n// Returns true if the content looks like a valid prompt file.\nfunc promptSanityCheck(content string) bool {\n\ttrimmed := strings.TrimSpace(content)\n\n\t// Empty content is never valid\n\tif trimmed == \"\" {\n\t\treturn false\n\t}\n\n\t// Must not start with conversational phrases\n\tif isConversationalResponse(trimmed) {\n\t\treturn false\n\t}\n\n\t// Must either start with '#' (markdown heading) or contain at least\n\t// one section header somewhere in the content\n\thasHeading := strings.HasPrefix(trimmed, \"#\") || strings.Contains(trimmed, \"\\n#\")\n\tif !hasHeading {\n\t\treturn false\n\t}\n\n\treturn true\n}\n\n// conversationalMarkers are patterns that indicate the LLM returned\n// meta-conversation text instead of prompt content.\nvar conversationalMarkers = regexp.MustCompile(\n\t`(?i)^(I need |I can't |I cannot |Could you |Please grant |` +\n\t\t`I don't have |I do not have |permission|write access|blocked by|` +\n\t\t`Here is the updated|Here's the updated|I've updated|I have updated|` +\n\t\t`Let me |I'll |I will )`)\n\n// isConversationalResponse checks whether the LLM output appears to be\n// meta-conversation text rather than actual prompt content.\nfunc isConversationalResponse(s string) bool {\n\ttrimmed := strings.TrimSpace(s)\n\tif trimmed == \"\" {\n\t\treturn true\n\t}\n\t// Check the first non-empty line for conversational markers\n\tfirstLine := trimmed\n\tif idx := strings.Index(trimmed, \"\\n\"); idx != -1 {\n\t\tfirstLine = trimmed[:idx]\n\t}\n\treturn conversationalMarkers.MatchString(strings.TrimSpace(firstLine))\n}\n\n// appendLessonDirectly adds a lesson to the prompt content without LLM help,\n// used as a fallback when the LLM returns conversational text.\nfunc appendLessonDirectly(current string, lesson *Lesson) string {\n\tcurrent = strings.TrimRight(current, \"\\n\")\n\tif strings.Contains(current, \"## Learned Rules\") {\n\t\treturn current + fmt.Sprintf(\"\\n- %s: %s\\n\", lesson.Insight, lesson.SuggestedAction)\n\t}\n\treturn current + fmt.Sprintf(\"\\n\\n## Learned Rules\\n\\n- %s: %s\\n\", lesson.Insight, lesson.SuggestedAction)\n}\n\n// stripCodeFences removes markdown code fences from an LLM response,\n// extracting just the content between them. If no fences are found,\n// the input is returned unchanged (trimmed).\nfunc stripCodeFences(s string) string {\n\ts = strings.TrimSpace(s)\n\n\topenIdx := strings.Index(s, \"```\")\n\tif openIdx == -1 {\n\t\treturn s\n\t}\n\n\t// Skip the opening fence line (may include language hint like ```markdown)\n\tafterOpen := s[openIdx+3:]\n\tnewlineIdx := strings.Index(afterOpen, \"\\n\")\n\tif newlineIdx == -1 {\n\t\treturn s\n\t}\n\tcontentStart := openIdx + 3 + newlineIdx + 1\n\n\t// Find the closing fence (last ``` in the string)\n\tcloseIdx := strings.LastIndex(s, \"```\")\n\tif closeIdx <= openIdx {\n\t\treturn s\n\t}\n\n\treturn s[contentStart:closeIdx]\n}\n","numLines":195,"startLine":1,"totalLines":195}}}
