tring) error {\n    52â†’\tdelete(f.runs, id)\n    53â†’\treturn nil\n    54â†’}\n    55â†’func (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n    56â†’\treturn nil, nil\n    57â†’}\n    58â†’func (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n    59â†’\treturn nil, nil\n    60â†’}\n    61â†’func (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n    62â†’\treturn nil, nil\n    63â†’}\n    64â†’\n    65â†’func TestExecutor_ScriptStep_Success(t *testing.T) {\n    66â†’\ttmpDir := t.TempDir()\n    67â†’\toutputDir := filepath.Join(tmpDir, \"output\")\n    68â†’\n    69â†’\texecutor := &Executor{\n    70â†’\t\tProjectDir: tmpDir,\n    71â†’\t\tOutputDir:  outputDir,\n    72â†’\t}\n    73â†’\n    74â†’\tstep := &domain.Step{\n    75â†’\t\tName:    \"greet\",\n    76â†’\t\tType:    domain.StepTypeScript,\n    77â†’\t\tResults: []string{\"success\", \"fail\"},\n    78â†’\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n    79â†’\t}\n    80â†’\n    81â†’\tresult, err := executor.Execute(context.Background(), step)\n    82â†’\trequire.NoError(t, err)\n    83â†’\tassert.Equal(t, \"success\", result)\n    84â†’\n    85â†’\t// Check output was written\n    86â†’\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n    87â†’\trequire.NoError(t, err)\n    88â†’\tassert.Contains(t, string(data), \"hello\")\n    89â†’}\n    90â†’\n    91â†’func TestExecutor_ScriptStep_Failure(t *testing.T) {\n    92â†’\ttmpDir := t.TempDir()\n    93â†’\toutputDir := filepath.Join(tmpDir, \"output\")\n    94â†’\n    95â†’\texecutor := &Executor{\n    96â†’\t\tProjectDir: tmpDir,\n    97â†’\t\tOutputDir:  outputDir,\n    98â†’\t}\n    99â†’\n   100â†’\tstep := &domain.Step{\n   101â†’\t\tName:    \"bad\",\n   102â†’\t\tType:    domain.StepTypeScript,\n   103â†’\t\tResults: []string{\"success\", \"fail\"},\n   104â†’\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   105â†’\t}\n   106â†’\n   107â†’\tresult, err := executor.Execute(context.Background(), step)\n   108â†’\trequire.NoError(t, err)\n   109â†’\tassert.Equal(t, \"fail\", result)\n   110â†’}\n   111â†’\n   112â†’func TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n   113â†’\ttmpDir := t.TempDir()\n   114â†’\toutputDir := filepath.Join(tmpDir, \"output\")\n   115â†’\n   116â†’\texecutor := &Executor{\n   117â†’\t\tProjectDir: tmpDir,\n   118â†’\t\tOutputDir:  outputDir,\n   119â†’\t}\n   120â†’\n   121â†’\tstep := &domain.Step{\n   122â†’\t\tName:    \"marker\",\n   123â†’\t\tType:    domain.StepTypeScript,\n   124â†’\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n   125â†’\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n   126â†’\t}\n   127â†’\n   128â†’\tresult, err := executor.Execute(context.Background(), step)\n   129â†’\trequire.NoError(t, err)\n   130â†’\tassert.Equal(t, \"custom\", result)\n   131â†’\n   132â†’\t// Marker line should be stripped from output\n   133â†’\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n   134â†’\trequire.NoError(t, err)\n   135â†’\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n   136â†’\tassert.Contains(t, string(data), \"some output\")\n   137â†’}\n   138â†’\n   139â†’func TestExecutor_WorkflowStep_Success(t *testing.T) {\n   140â†’\ttmpDir := t.TempDir()\n   141â†’\toutputDir := filepath.Join(tmpDir, \"output\")\n   142â†’\t_ = os.MkdirAll(outputDir, 0755)\n   143â†’\n   144â†’\tstore := &fakeStore{runs: map[string]*domain.Run{\n   145â†’\t\t\"develop-test-run\": {\n   146â†’\t\t\tID:    \"develop-test-run\",\n   147â†’\t\t\tState: domain.RunStateSucceeded,\n   148â†’\t\t},\n   149â†’\t}}\n   150â†’\n   151â†’\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   152â†’\n   153â†’\texecutor := &Executor{\n   154â†’\t\tProjectDir: tmpDir,\n   155â†’\t\tDispatcher: dispatcher,\n   156â†’\t\tStore:      store,\n   157â†’\t\tOutputDir:  outputDir,\n   158â†’\t}\n   159â†’\n   160â†’\tstep := &domain.Step{\n   161â†’\t\tName:    \"develop\",\n   162â†’\t\tType:    domain.StepTypeWorkflow,\n   163â†’\t\tResults: []string{\"success\", \"fail\"},\n   164â†’\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   165â†’\t}\n   166â†’\n   167â†’\tresult, err := executor.Execute(context.Background(), step)\n   168â†’\trequire.NoError(t, err)\n   169â†’\tassert.Equal(t, \"success\", result)\n   170â†’\tassert.Len(t, dispatcher.calls, 1)\n   171â†’\tassert.Equal(t, \"develop\", dispatcher.calls[0].WorkflowName)\n   172â†’\tassert.Equal(t, tmpDir, dispatcher.calls[0].ProjectDir)\n   173â†’}\n   174â†’\n   175â†’func TestExecutor_WorkflowStep_Failure(t *testing.T) {\n   176â†’\ttmpDir := t.TempDir()\n   177â†’\toutputDir := filepath.Join(tmpDir, \"output\")\n   178â†’\t_ = os.MkdirAll(outputDir, 0755)\n   179â†’\n   180â†’\tstore := &fakeStore{runs: map[string]*domain.Run{\n   181â†’\t\t\"develop-test-run\": {\n   182â†’\t\t\tID:    \"develop-test-run\",\n   183â†’\t\t\tState: domain.RunStateFailed,\n   184â†’\t\t},\n   185â†’\t}}\n   186â†’\n   187â†’\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   188â†’\n   189â†’\texecutor := &Executor{\n   190â†’\t\tProjectDir: tmpDir,\n   191â†’\t\tDispatcher: dispatcher,\n   192â†’\t\tStore:      store,\n   193â†’\t\tOutputDir:  outputDir,\n   194â†’\t}\n   195â†’\n   196â†’\tstep := &domain.Step{\n   197â†’\t\tName:    \"develop\",\n   198â†’\t\tType:    domain.StepTypeWorkflow,\n   199â†’\t\tResults: []string{\"success\", \"fail\"},\n   200â†’\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   201â†’\t}\n   202â†’\n   203â†’\tresult, err := executor.Execute(context.Background(), step)\n   204â†’\trequire.NoError(t, err)\n   205â†’\tassert.Equal(t, \"fail\", result)\n   206â†’}\n   207â†’\n   208â†’func TestExecutor_WorkflowStep_PassesPrompt(t *testing.T) {\n   209â†’\ttmpDir := t.TempDir()\n   210â†’\toutputDir := filepath.Join(tmpDir, \"output\")\n   211â†’\t_ = os.MkdirAll(outputDir, 0755)\n   212â†’\n   213â†’\t// Write a previous step's output\n   214â†’\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n   215â†’\n   216â†’\tstore := &fakeStore{runs: map[string]*domain.Run{\n   217â†’\t\t\"develop-test-run\": {\n   218â†’\t\t\tID:    \"develop-test-run\",\n   219â†’\t\t\tState: domain.RunStateSucceeded,\n   220â†’\t\t},\n   221â†’\t}}\n   222â†’\n   223â†’\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   224â†’\n   225â†’\texecutor := &Executor{\n   226â†’\t\tProjectDir: tmpDir,\n   227â†’\t\tDispatcher: dispatcher,\n   228â†’\t\tStore:      store,\n   229â†’\t\tOutputDir:  outputDir,\n   230â†’\t}\n   231â†’\n   232â†’\tstep := &domain.Step{\n   233â†’\t\tName:    \"develop\",\n   234â†’\t\tType:    domain.StepTypeWorkflow,\n   235â†’\t\tResults: []string{\"success\", \"fail\"},\n   236â†’\t\tConfig: map[string]string{\n   237â†’\t\t\t\"workflow_name\": \"develop\",\n   238â†’\t\t\t\"prompt_step\":   \"prepare-prompt\",\n   239â†’\t\t},\n   240â†’\t}\n   241â†’\n   242â†’\tresult, err := executor.Execute(context.Background(), step)\n   243â†’\trequire.NoError(t, err)\n   244â†’\tassert.Equal(t, \"success\", result)\n   245â†’\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n   246â†’}\n   247â†’\n   248â†’func TestEngine_HostWorkflow_Linear(t *testing.T) {\n   249â†’\ttmpDir := t.TempDir()\n   250â†’\toutputDir := filepath.Join(tmpDir, \"output\")\n   251â†’\n   252â†’\tstore := &fakeStore{runs: map[string]*domain.Run{\n   253â†’\t\t\"develop-test-run\": {\n   254â†’\t\t\tID:    \"develop-test-run\",\n   255â†’\t\t\tState: domain.RunStateSucceeded,\n   256â†’\t\t},\n   257â†’\t}}\n   258â†’\n   259â†’\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   260â†’\n   261â†’\texecutor := &Executor{\n   262â†’\t\tProjectDir: tmpDir,\n   263â†’\t\tDispatcher: dispatcher,\n   264â†’\t\tStore:      store,\n   265â†’\t\tOutputDir:  outputDir,\n   266â†’\t}\n   267â†’\n   268â†’\twf := &domain.Workflow{\n   269â†’\t\tName: \"main\",\n   270â†’\t\tSteps: map[string]*domain.Step{\n   271â†’\t\t\t\"prepare\": {\n   272â†’\t\t\t\tName:    \"prepare\",\n   273â†’\t\t\t\tType:    domain.StepTypeScript,\n   274â†’\t\t\t\tResults: []string{\"success\", \"fail\"},\n   275â†’\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n   276â†’\t\t\t},\n   277â†’\t\t\t\"develop\": {\n   278â†’\t\t\t\tName:    \"develop\",\n   279â†’\t\t\t\tType:    domain.StepTypeWorkflow,\n   280â†’\t\t\t\tResults: []string{\"success\", \"fail\"},\n   281â†’\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   282â†’\t\t\t},\n   283â†’\t\t\t\"merge\": {\n   284â†’\t\t\t\tName:    \"merge\",\n   285â†’\t\t\t\tType:    domain.StepTypeScript,\n   286â†’\t\t\t\tResults: []string{\"success\", \"fail\"},\n   287â†’\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n   288â†’\t\t\t},\n   289â†’\t\t},\n   290â†’\t\tWiring: []domain.Wire{\n   291â†’\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   292â†’\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   293â†’\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n   294â†’\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   295â†’\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n   296â†’\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n   297â†’\t\t},\n   298â†’\t\tEntryStep: \"prepare\",\n   299â†’\t}\n   300â†’\n   301â†’\teng := engine.New(executor)\n   302â†’\trun, err := eng.Run(context.Background(), wf)\n   303â†’\trequire.NoError(t, err)\n   304â†’\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   305â†’\tassert.Len(t, dispatcher.calls, 1)\n   306â†’}\n   307â†’\n   308â†’func TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n   309â†’\ttmpDir := t.TempDir()\n   310â†’\toutputDir := filepath.Join(tmpDir, \"output\")\n   311â†’\n   312â†’\texecutor := &Executor{\n   313â†’\t\tProjectDir: tmpDir,\n   314â†’\t\tOutputDir:  outputDir,\n   315â†’\t}\n   316â†’\n   317â†’\twf := &domain.Workflow{\n   318â†’\t\tName: \"main\",\n   319â†’\t\tSteps: map[string]*domain.Step{\n   320â†’\t\t\t\"prepare\": {\n   321â†’\t\t\t\tName:    \"prepare\",\n   322â†’\t\t\t\tType:    domain.StepTypeScript,\n   323â†’\t\t\t\tResults: []string{\"success\", \"fail\"},\n   324â†’\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   325â†’\t\t\t},\n   326â†’\t\t\t\"develop\": {\n   327â†’\t\t\t\tName:    \"develop\",\n   328â†’\t\t\t\tType:    domain.StepTypeWorkflow,\n   329â†’\t\t\t\tResults: []string{\"success\", \"fail\"},\n   330â†’\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   331â†’\t\t\t},\n   332â†’\t\t},\n   333â†’\t\tWiring: []domain.Wire{\n   334â†’\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   335â†’\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   336â†’\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n   337â†’\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   338â†’\t\t},\n   339â†’\t\tEntryStep: \"prepare\",\n   340â†’\t}\n   341â†’\n   342â†’\teng := engine.New(executor)\n   343â†’\trun, err := eng.Run(context.Background(), wf)\n   344â†’\trequire.NoError(t, err)\n   345â†’\tassert.Equal(t, domain.RunStateFailed, run.State)\n   346â†’}\n   347â†’\n   348â†’func TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n   349â†’\ttmpDir := t.TempDir()\n   350â†’\toutputDir := filepath.Join(tmpDir, \"output\")\n   351â†’\n   352â†’\texecutor := &Executor{\n   353â†’\t\tProjectDir: tmpDir,\n   354â†’\t\tOutputDir:  outputDir,\n   355â†’\t}\n   356â†’\n   357â†’\tstep := &domain.Step{\n   358â†’\t\tName:    \"env-check\",\n   359â†’\t\tType:    domain.StepTypeScript,\n   360â†’\t\tResults: []string{\"success\", \"fail\"},\n   361â†’\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n   362â†’\t}\n   363â†’\n   364â†’\tresult, err := executor.Execute(context.Background(), step)\n   365â†’\trequire.NoError(t, err)\n   366â†’\tassert.Equal(t, \"success\", result)\n   367â†’\n   368â†’\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n   369â†’\trequire.NoError(t, err)\n   370â†’\tassert.Contains(t, string(data), tmpDir)\n   371â†’}\n   372â†’"}]},"parent_tool_use_id":null,"session_id":"bc0d6504-f99d-4d8f-a0a8-090dcdb6a5d4","uuid":"a6fe4c8b-ae5b-4a6f-b9b1-e416d6059c5c","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor_test.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// fakeDispatcher records dispatch calls and returns a predetermined run ID.\ntype fakeDispatcher struct {\n\tcalls     []*pb.RunWorkflowRequest\n\trunID     string\n\treturnErr error\n}\n\nfunc (f *fakeDispatcher) RunWorkflow(_ context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tf.calls = append(f.calls, req)\n\tif f.returnErr != nil {\n\t\treturn nil, f.returnErr\n\t}\n\treturn &pb.RunWorkflowResponse{RunId: f.runID}, nil\n}\n\n// fakeStore returns a predetermined run on GetRun.\ntype fakeStore struct {\n\truns map[string]*domain.Run\n}\n\nfunc (f *fakeStore) CreateRun(_ context.Context, run *domain.Run) error {\n\tf.runs[run.ID] = run\n\treturn nil\n}\nfunc (f *fakeStore) GetRun(_ context.Context, id string) (*domain.Run, error) {\n\tif r, ok := f.runs[id]; ok {\n\t\treturn r, nil\n\t}\n\treturn nil, os.ErrNotExist\n}\nfunc (f *fakeStore) UpdateRun(_ context.Context, run *domain.Run) error {\n\tf.runs[run.ID] = run\n\treturn nil\n}\nfunc (f *fakeStore) DeleteRun(_ context.Context, id string) error {\n\tdelete(f.runs, id)\n\treturn nil\n}\nfunc (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n\treturn nil, nil\n}\n\nfunc TestExecutor_ScriptStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"greet\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Check output was written\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"hello\")\n}\n\nfunc TestExecutor_ScriptStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"bad\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"marker\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"custom\", result)\n\n\t// Marker line should be stripped from output\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n\trequire.NoError(t, err)\n\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n\tassert.Contains(t, string(data), \"some output\")\n}\n\nfunc TestExecutor_WorkflowStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\tassert.Len(t, dispatcher.calls, 1)\n\tassert.Equal(t, \"develop\", dispatcher.calls[0].WorkflowName)\n\tassert.Equal(t, tmpDir, dispatcher.calls[0].ProjectDir)\n}\n\nfunc TestExecutor_WorkflowStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateFailed,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_WorkflowStep_PassesPrompt(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\t// Write a previous step's output\n\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"workflow_name\": \"develop\",\n\t\t\t\"prompt_step\":   \"prepare-prompt\",\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n}\n\nfunc TestEngine_HostWorkflow_Linear(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n\t\t\t},\n\t\t\t\"develop\": {\n\t\t\t\tName:    \"develop\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t\t\"merge\": {\n\t\t\t\tName:    \"merge\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\tassert.Len(t, dispatcher.calls, 1)\n}\n\nfunc TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n\t\t\t},\n\t\t\t\"develop\": {\n\t\t\t\tName:    \"develop\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n}\n\nfunc TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"env-check\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), tmpDir)\n}\n","numLines":372,"startLine":1,"totalLines":372}}}
