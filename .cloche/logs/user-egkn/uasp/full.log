[2026-03-09T23:04:52Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RH3WQsd7tZ11GBNGGmfFh8","type":"tool_result","content":"     1â†’package domain\n     2â†’\n     3â†’import (\n     4â†’\t\"encoding/json\"\n     5â†’\t\"fmt\"\n     6â†’\t\"strings\"\n     7â†’)\n     8â†’\n     9â†’const (\n    10â†’\tStepDone  = \"done\"\n    11â†’\tStepAbort = \"abort\"\n    12â†’)\n    13â†’\n    14â†’type StepType string\n    15â†’\n    16â†’const (\n    17â†’\tStepTypeAgent    StepType = \"agent\"\n    18â†’\tStepTypeScript   StepType = \"script\"\n    19â†’\tStepTypeWorkflow StepType = \"workflow\"\n    20â†’)\n    21â†’\n    22â†’// WorkflowLocation indicates where a workflow is intended to run.\n    23â†’type WorkflowLocation string\n    24â†’\n    25â†’const (\n    26â†’\t// LocationContainer is for workflows that run inside a Docker container.\n    27â†’\t// These are all .cloche/*.cloche files except host.cloche.\n    28â†’\tLocationContainer WorkflowLocation = \"container\"\n    29â†’\n    30â†’\t// LocationHost is for workflows that run on the host machine.\n    31â†’\t// Only .cloche/host.cloche uses this location.\n    32â†’\tLocationHost WorkflowLocation = \"host\"\n    33â†’)\n    34â†’\n    35â†’type Step struct {\n    36â†’\tName    string\n    37â†’\tType    StepType\n    38â†’\tResults []string\n    39â†’\tConfig  map[string]string\n    40â†’}\n    41â†’\n    42â†’type Wire struct {\n    43â†’\tFrom      string\n    44â†’\tResult    string\n    45â†’\tTo        string\n    46â†’\tOutputMap []OutputMapping\n    47â†’}\n    48â†’\n    49â†’type SegmentKind int\n    50â†’\n    51â†’const (\n    52â†’\tSegmentField SegmentKind = iota\n    53â†’\tSegmentIndex\n    54â†’)\n    55â†’\n    56â†’type PathSegment struct {\n    57â†’\tKind  SegmentKind\n    58â†’\tField string // for SegmentField\n    59â†’\tIndex int    // for SegmentIndex\n    60â†’}\n    61â†’\n    62â†’type OutputPath struct {\n    63â†’\tSegments []PathSegment\n    64â†’}\n    65â†’\n    66â†’type OutputMapping struct {\n    67â†’\tEnvVar string\n    68â†’\tPath   OutputPath\n    69â†’}\n    70â†’\n    71â†’// Evaluate navigates the raw output bytes using the path segments.\n    72â†’// With no segments, it returns the raw output as a string.\n    73â†’// With segments, it parses the raw bytes as JSON and navigates using\n    74â†’// field access (SegmentField) and array indexing (SegmentIndex).\n    75â†’func (p OutputPath) Evaluate(raw []byte) (string, error) {\n    76â†’\tif len(p.Segments) == 0 {\n    77â†’\t\treturn string(raw), nil\n    78â†’\t}\n    79â†’\n    80â†’\tvar val any\n    81â†’\tif err := json.Unmarshal(raw, &val); err != nil {\n    82â†’\t\treturn \"\", fmt.Errorf(\"output is not valid JSON\")\n    83â†’\t}\n    84â†’\n    85â†’\tfor _, seg := range p.Segments {\n    86â†’\t\tswitch seg.Kind {\n    87â†’\t\tcase SegmentField:\n    88â†’\t\t\tm, ok := val.(map[string]any)\n    89â†’\t\t\tif !ok {\n    90â†’\t\t\t\treturn \"\", fmt.Errorf(\"expected object for .%s\", seg.Field)\n    91â†’\t\t\t}\n    92â†’\t\t\tval, ok = m[seg.Field]\n    93â†’\t\t\tif !ok {\n    94â†’\t\t\t\treturn \"\", fmt.Errorf(\"field %q not found\", seg.Field)\n    95â†’\t\t\t}\n    96â†’\t\tcase SegmentIndex:\n    97â†’\t\t\tarr, ok := val.([]any)\n    98â†’\t\t\tif !ok {\n    99â†’\t\t\t\treturn \"\", fmt.Errorf(\"expected array for [%d]\", seg.Index)\n   100â†’\t\t\t}\n   101â†’\t\t\tif seg.Index < 0 || seg.Index >= len(arr) {\n   102â†’\t\t\t\treturn \"\", fmt.Errorf(\"index %d out of range (len %d)\", seg.Index, len(arr))\n   103â†’\t\t\t}\n   104â†’\t\t\tval = arr[seg.Index]\n   105â†’\t\t}\n   106â†’\t}\n   107â†’\n   108â†’\tswitch v := val.(type) {\n   109â†’\tcase string:\n   110â†’\t\treturn v, nil\n   111â†’\tdefault:\n   112â†’\t\tb, _ := json.Marshal(v)\n   113â†’\t\treturn string(b), nil\n   114â†’\t}\n   115â†’}\n   116â†’\n   117â†’type CollectMode string\n   118â†’\n   119â†’const (\n   120â†’\tCollectAll CollectMode = \"all\"\n   121â†’\tCollectAny CollectMode = \"any\"\n   122â†’)\n   123â†’\n   124â†’type WireCondition struct {\n   125â†’\tStep   string\n   126â†’\tResult string\n   127â†’}\n   128â†’\n   129â†’type Collect struct {\n   130â†’\tMode       CollectMode\n   131â†’\tConditions []WireCondition\n   132â†’\tTo         string\n   133â†’}\n   134â†’\n   135â†’type Workflow struct {\n   136â†’\tName      string\n   137â†’\tLocation  WorkflowLocation  // host or container\n   138â†’\tSteps     map[string]*Step\n   139â†’\tWiring    []Wire\n   140â†’\tCollects  []Collect\n   141â†’\tEntryStep string\n   142â†’\tConfig    map[string]string // workflow-level config (e.g. \"container.image\")\n   143â†’}\n   144â†’\n   145â†’func (w *Workflow) Validate() error {\n   146â†’\tif w.EntryStep == \"\" {\n   147â†’\t\treturn fmt.Errorf(\"workflow %q: no entry step defined\", w.Name)\n   148â†’\t}\n   149â†’\tif _, ok := w.Steps[w.EntryStep]; !ok {\n   150â†’\t\treturn fmt.Errorf(\"workflow %q: entry step %q not found\", w.Name, w.EntryStep)\n   151â†’\t}\n   152â†’\n   153â†’\twired := make(map[string]map[string]bool)\n   154â†’\treachable := map[string]bool{w.EntryStep: true}\n   155â†’\tfor _, wire := range w.Wiring {\n   156â†’\t\tif wired[wire.From] == nil {\n   157â†’\t\t\twired[wire.From] = make(map[string]bool)\n   158â†’\t\t}\n   159â†’\t\twired[wire.From][wire.Result] = true\n   160â†’\t\tif wire.To != StepDone && wire.To != StepAbort {\n   161â†’\t\t\treachable[wire.To] = true\n   162â†’\t\t}\n   163â†’\t}\n   164â†’\n   165â†’\t// Validate collects and count their results as wired\n   166â†’\tfor _, c := range w.Collects {\n   167â†’\t\t// Validate target step exists\n   168â†’\t\tif c.To != StepDone && c.To != StepAbort {\n   169â†’\t\t\tif _, ok := w.Steps[c.To]; !ok {\n   170â†’\t\t\t\treturn fmt.Errorf(\"workflow %q: collect target step %q not found\", w.Name, c.To)\n   171â†’\t\t\t}\n   172â†’\t\t\treachable[c.To] = true\n   173â†’\t\t}\n   174â†’\n   175â†’\t\tfor _, cond := range c.Conditions {\n   176â†’\t\t\t// Validate condition step exists\n   177â†’\t\t\tstep, ok := w.Steps[cond.Step]\n   178â†’\t\t\tif !ok {\n   179â†’\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references unknown step %q\", w.Name, cond.Step)\n   180â†’\t\t\t}\n   181â†’\t\t\t// Validate condition result is declared\n   182â†’\t\t\tfound := false\n   183â†’\t\t\tfor _, r := range step.Results {\n   184â†’\t\t\t\tif r == cond.Result {\n   185â†’\t\t\t\t\tfound = true\n   186â†’\t\t\t\t\tbreak\n   187â†’\t\t\t\t}\n   188â†’\t\t\t}\n   189â†’\t\t\tif !found {\n   190â†’\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references undeclared result %q on step %q\", w.Name, cond.Result, cond.Step)\n   191â†’\t\t\t}\n   192â†’\t\t\t// Mark as wired so the \"every result must be wired\" check passes\n   193â†’\t\t\tif wired[cond.Step] == nil {\n   194â†’\t\t\t\twired[cond.Step] = make(map[string]bool)\n   195â†’\t\t\t}\n   196â†’\t\t\twired[cond.Step][cond.Result] = true\n   197â†’\t\t}\n   198â†’\t}\n   199â†’\n   200â†’\tfor name, step := range w.Steps {\n   201â†’\t\tfor _, result := range step.Results {\n   202â†’\t\t\tif !wired[name][result] {\n   203â†’\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q result %q is not wired\", w.Name, name, result)\n   204â†’\t\t\t}\n   205â†’\t\t}\n   206â†’\t}\n   207â†’\n   208â†’\tfor name := range w.Steps {\n   209â†’\t\tif !reachable[name] {\n   210â†’\t\t\treturn fmt.Errorf(\"workflow %q: step %q is orphaned (unreachable)\", w.Name, name)\n   211â†’\t\t}\n   212â†’\t}\n   213â†’\n   214â†’\treturn nil\n   215â†’}\n   216â†’\n   217â†’// ValidateLocation checks that step types are compatible with the workflow location.\n   218â†’// workflow_name steps are only allowed in host workflows.\n   219â†’func (w *Workflow) ValidateLocation() error {\n   220â†’\tif w.Location == LocationContainer {\n   221â†’\t\tfor name, step := range w.Steps {\n   222â†’\t\t\tif step.Type == StepTypeWorkflow {\n   223â†’\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q uses workflow_name, which is only allowed in host workflows (host.cloche)\", w.Name, name)\n   224â†’\t\t\t}\n   225â†’\t\t}\n   226â†’\t}\n   227â†’\treturn nil\n   228â†’}\n   229â†’\n   230â†’// knownStepConfigKeys lists recognized step-level config keys.\n   231â†’// Keys with a \"container.\" prefix are also allowed.\n   232â†’var knownStepConfigKeys = map[string]bool{\n   233â†’\t\"prompt\":        true,\n   234â†’\t\"run\":           true,\n   235â†’\t\"max_attempts\":  true,\n   236â†’\t\"timeout\":       true,\n   237â†’\t\"agent_command\": true,\n   238â†’\t\"agent_args\":    true,\n   239â†’\t\"results\":       true,\n   240â†’\t\"feedback\":      true,\n   241â†’\t\"workflow_name\": true,\n   242â†’\t\"prompt_step\":   true,\n   243â†’}\n   244â†’\n   245â†’// ValidateConfig checks step config keys against known keys and returns\n   246â†’// warnings for any unrecognized keys (likely typos).\n   247â†’func (w *Workflow) ValidateConfig() []string {\n   248â†’\tvar warnings []string\n   249â†’\tfor name, step := range w.Steps {\n   250â†’\t\tfor key := range step.Config {\n   251â†’\t\t\tif knownStepConfigKeys[key] {\n   252â†’\t\t\t\tcontinue\n   253â†’\t\t\t}\n   254â†’\t\t\tif strings.HasPrefix(key, \"container.\") {\n   255â†’\t\t\t\tcontinue\n   256â†’\t\t\t}\n   257â†’\t\t\twarnings = append(warnings, fmt.Sprintf(\n   258â†’\t\t\t\t\"workflow %q: step %q has unrecognized config key %q\", w.Name, name, key))\n   259â†’\t\t}\n   260â†’\t}\n   261â†’\treturn warnings\n   262â†’}\n   263â†’\n   264â†’// NextSteps returns all target step names wired from the given (stepName, result) pair.\n   265â†’// Multiple targets indicate fanout â€” parallel branches launched by the engine.\n   266â†’func (w *Workflow) NextSteps(stepName, result string) ([]string, error) {\n   267â†’\tvar targets []string\n   268â†’\tfor _, wire := range w.Wiring {\n   269â†’\t\tif wire.From == stepName && wire.Result == result {\n   270â†’\t\t\ttargets = append(targets, wire.To)\n   271â†’\t\t}\n   272â†’\t}\n   273â†’\tif len(targets) == 0 {\n   274â†’\t\treturn nil, fmt.Errorf(\"workflow %q: no wiring for step %q result %q\", w.Name, stepName, result)\n   275â†’\t}\n   276â†’\treturn targets, nil\n   277â†’}\n   278â†’\n   279â†’// Deprecated: NextStep returns the first target only. Use NextSteps for fanout support.\n   280â†’func (w *Workflow) NextStep(stepName, result string) (string, error) {\n   281â†’\ttargets, err := w.NextSteps(stepName, result)\n   282â†’\tif err != nil {\n   283â†’\t\treturn \"\", err\n   284â†’\t}\n   285â†’\treturn targets[0], nil\n   286â†’}\n   287â†’"}]},"parent_tool_use_id":null,"session_id":"bc0d6504-f99d-4d8f-a0a8-090dcdb6a5d4","uuid":"e977f06c-c12f-41cf-9a0a-d13d87d1738c","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/domain/workflow.go","content":"package domain\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"strings\"\n)\n\nconst (\n\tStepDone  = \"done\"\n\tStepAbort = \"abort\"\n)\n\ntype StepType string\n\nconst (\n\tStepTypeAgent    StepType = \"agent\"\n\tStepTypeScript   StepType = \"script\"\n\tStepTypeWorkflow StepType = \"workflow\"\n)\n\n// WorkflowLocation indicates where a workflow is intended to run.\ntype WorkflowLocation string\n\nconst (\n\t// LocationContainer is for workflows that run inside a Docker container.\n\t// These are all .cloche/*.cloche files except host.cloche.\n\tLocationContainer WorkflowLocation = \"container\"\n\n\t// LocationHost is for workflows that run on the host machine.\n\t// Only .cloche/host.cloche uses this location.\n\tLocationHost WorkflowLocation = \"host\"\n)\n\ntype Step struct {\n\tName    string\n\tType    StepType\n\tResults []string\n\tConfig  map[string]string\n}\n\ntype Wire struct {\n\tFrom      string\n\tResult    string\n\tTo        string\n\tOutputMap []OutputMapping\n}\n\ntype SegmentKind int\n\nconst (\n\tSegmentField SegmentKind = iota\n\tSegmentIndex\n)\n\ntype PathSegment struct {\n\tKind  SegmentKind\n\tField string // for SegmentField\n\tIndex int    // for SegmentIndex\n}\n\ntype OutputPath struct {\n\tSegments []PathSegment\n}\n\ntype OutputMapping struct {\n\tEnvVar string\n\tPath   OutputPath\n}\n\n// Evaluate navigates the raw output bytes using the path segments.\n// With no segments, it returns the raw output as a string.\n// With segments, it parses the raw bytes as JSON and navigates using\n// field access (SegmentField) and array indexing (SegmentIndex).\nfunc (p OutputPath) Evaluate(raw []byte) (string, error) {\n\tif len(p.Segments) == 0 {\n\t\treturn string(raw), nil\n\t}\n\n\tvar val any\n\tif err := json.Unmarshal(raw, &val); err != nil {\n\t\treturn \"\", fmt.Errorf(\"output is not valid JSON\")\n\t}\n\n\tfor _, seg := range p.Segments {\n\t\tswitch seg.Kind {\n\t\tcase SegmentField:\n\t\t\tm, ok := val.(map[string]any)\n\t\t\tif !ok {\n\t\t\t\treturn \"\", fmt.Errorf(\"expected object for .%s\", seg.Field)\n\t\t\t}\n\t\t\tval, ok = m[seg.Field]\n\t\t\tif !ok {\n\t\t\t\treturn \"\", fmt.Errorf(\"field %q not found\", seg.Field)\n\t\t\t}\n\t\tcase SegmentIndex:\n\t\t\tarr, ok := val.([]any)\n\t\t\tif !ok {\n\t\t\t\treturn \"\", fmt.Errorf(\"expected array for [%d]\", seg.Index)\n\t\t\t}\n\t\t\tif seg.Index < 0 || seg.Index >= len(arr) {\n\t\t\t\treturn \"\", fmt.Errorf(\"index %d out of range (len %d)\", seg.Index, len(arr))\n\t\t\t}\n\t\t\tval = arr[seg.Index]\n\t\t}\n\t}\n\n\tswitch v := val.(type) {\n\tcase string:\n\t\treturn v, nil\n\tdefault:\n\t\tb, _ := json.Marshal(v)\n\t\treturn string(b), nil\n\t}\n}\n\ntype CollectMode string\n\nconst (\n\tCollectAll CollectMode = \"all\"\n\tCollectAny CollectMode = \"any\"\n)\n\ntype WireCondition struct {\n\tStep   string\n\tResult string\n}\n\ntype Collect struct {\n\tMode       CollectMode\n\tConditions []WireCondition\n\tTo         string\n}\n\ntype Workflow struct {\n\tName      string\n\tLocation  WorkflowLocation  // host or container\n\tSteps     map[string]*Step\n\tWiring    []Wire\n\tCollects  []Collect\n\tEntryStep string\n\tConfig    map[string]string // workflow-level config (e.g. \"container.image\")\n}\n\nfunc (w *Workflow) Validate() error {\n\tif w.EntryStep == \"\" {\n\t\treturn fmt.Errorf(\"workflow %q: no entry step defined\", w.Name)\n\t}\n\tif _, ok := w.Steps[w.EntryStep]; !ok {\n\t\treturn fmt.Errorf(\"workflow %q: entry step %q not found\", w.Name, w.EntryStep)\n\t}\n\n\twired := make(map[string]map[string]bool)\n\treachable := map[string]bool{w.EntryStep: true}\n\tfor _, wire := range w.Wiring {\n\t\tif wired[wire.From] == nil {\n\t\t\twired[wire.From] = make(map[string]bool)\n\t\t}\n\t\twired[wire.From][wire.Result] = true\n\t\tif wire.To != StepDone && wire.To != StepAbort {\n\t\t\treachable[wire.To] = true\n\t\t}\n\t}\n\n\t// Validate collects and count their results as wired\n\tfor _, c := range w.Collects {\n\t\t// Validate target step exists\n\t\tif c.To != StepDone && c.To != StepAbort {\n\t\t\tif _, ok := w.Steps[c.To]; !ok {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: collect target step %q not found\", w.Name, c.To)\n\t\t\t}\n\t\t\treachable[c.To] = true\n\t\t}\n\n\t\tfor _, cond := range c.Conditions {\n\t\t\t// Validate condition step exists\n\t\t\tstep, ok := w.Steps[cond.Step]\n\t\t\tif !ok {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references unknown step %q\", w.Name, cond.Step)\n\t\t\t}\n\t\t\t// Validate condition result is declared\n\t\t\tfound := false\n\t\t\tfor _, r := range step.Results {\n\t\t\t\tif r == cond.Result {\n\t\t\t\t\tfound = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !found {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references undeclared result %q on step %q\", w.Name, cond.Result, cond.Step)\n\t\t\t}\n\t\t\t// Mark as wired so the \"every result must be wired\" check passes\n\t\t\tif wired[cond.Step] == nil {\n\t\t\t\twired[cond.Step] = make(map[string]bool)\n\t\t\t}\n\t\t\twired[cond.Step][cond.Result] = true\n\t\t}\n\t}\n\n\tfor name, step := range w.Steps {\n\t\tfor _, result := range step.Results {\n\t\t\tif !wired[name][result] {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q result %q is not wired\", w.Name, name, result)\n\t\t\t}\n\t\t}\n\t}\n\n\tfor name := range w.Steps {\n\t\tif !reachable[name] {\n\t\t\treturn fmt.Errorf(\"workflow %q: step %q is orphaned (unreachable)\", w.Name, name)\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// ValidateLocation checks that step types are compatible with the workflow location.\n// workflow_name steps are only allowed in host workflows.\nfunc (w *Workflow) ValidateLocation() error {\n\tif w.Location == LocationContainer {\n\t\tfor name, step := range w.Steps {\n\t\t\tif step.Type == StepTypeWorkflow {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q uses workflow_name, which is only allowed in host workflows (host.cloche)\", w.Name, name)\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\n// knownStepConfigKeys lists recognized step-level config keys.\n// Keys with a \"container.\" prefix are also allowed.\nvar knownStepConfigKeys = map[string]bool{\n\t\"prompt\":        true,\n\t\"run\":           true,\n\t\"max_attempts\":  true,\n\t\"timeout\":       true,\n\t\"agent_command\": true,\n\t\"agent_args\":    true,\n\t\"results\":       true,\n\t\"feedback\":      true,\n\t\"workflow_name\": true,\n\t\"prompt_step\":   true,\n}\n\n// ValidateConfig checks step config keys against known keys and returns\n// warnings for any unrecognized keys (likely typos).\nfunc (w *Workflow) ValidateConfig() []string {\n\tvar warnings []string\n\tfor name, step := range w.Steps {\n\t\tfor key := range step.Config {\n\t\t\tif knownStepConfigKeys[key] {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif strings.HasPrefix(key, \"container.\") {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\twarnings = append(warnings, fmt.Sprintf(\n\t\t\t\t\"workflow %q: step %q has unrecognized config key %q\", w.Name, name, key))\n\t\t}\n\t}\n\treturn warnings\n}\n\n// NextSteps returns all target step names wired from the given (stepName, result) pair.\n// Multiple targets indicate fanout â€” parallel branches launched by the engine.\nfunc (w *Workflow) NextSteps(stepName, result string) ([]string, error) {\n\tvar targets []string\n\tfor _, wire := range w.Wiring {\n\t\tif wire.From == stepName && wire.Result == result {\n\t\t\ttargets = append(targets, wire.To)\n\t\t}\n\t}\n\tif len(targets) == 0 {\n\t\treturn nil, fmt.Errorf(\"workflow %q: no wiring for step %q result %q\", w.Name, stepName, result)\n\t}\n\treturn targets, nil\n}\n\n// Deprecated: NextStep returns the first target only. Use NextSteps for fanout support.\nfunc (w *Workflow) NextStep(stepName, result string) (string, error) {\n\ttargets, err := w.NextSteps(stepName, result)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn targets[0], nil\n}\n","numLines":287,"startLine":1,"totalLines":287}}}
