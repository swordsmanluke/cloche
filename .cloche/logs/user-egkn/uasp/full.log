[2026-03-09T23:06:38Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MQVjCjRbFw7S3R9wvQ3H8R","type":"tool_result","content":"     1â†’package host\n     2â†’\n     3â†’import (\n     4â†’\t\"context\"\n     5â†’\t\"fmt\"\n     6â†’\t\"log\"\n     7â†’\t\"os\"\n     8â†’\t\"os/exec\"\n     9â†’\t\"path/filepath\"\n    10â†’\t\"time\"\n    11â†’\n    12â†’\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    13â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14â†’\t\"github.com/cloche-dev/cloche/internal/engine\"\n    15â†’\t\"github.com/cloche-dev/cloche/internal/ports\"\n    16â†’\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17â†’)\n    18â†’\n    19â†’// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    20â†’// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    21â†’// strings suitable for adding to a command's environment.\n    22â†’func (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    23â†’\tvar env []string\n    24â†’\tfor _, w := range wires {\n    25â†’\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    26â†’\t\t\tcontinue\n    27â†’\t\t}\n    28â†’\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    29â†’\t\tif err != nil {\n    30â†’\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    31â†’\t\t}\n    32â†’\t\tfor _, m := range w.OutputMap {\n    33â†’\t\t\tval, err := m.Path.Evaluate(data)\n    34â†’\t\t\tif err != nil {\n    35â†’\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    36â†’\t\t\t}\n    37â†’\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    38â†’\t\t}\n    39â†’\t}\n    40â†’\treturn env, nil\n    41â†’}\n    42â†’\n    43â†’// RunDispatcher dispatches a container workflow run and returns the run ID.\n    44â†’type RunDispatcher interface {\n    45â†’\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    46â†’}\n    47â†’\n    48â†’// Executor implements engine.StepExecutor for host workflow steps.\n    49â†’type Executor struct {\n    50â†’\tProjectDir string\n    51â†’\tDispatcher RunDispatcher\n    52â†’\tStore      ports.RunStore\n    53â†’\tOutputDir  string         // directory for step output files\n    54â†’\tWires      []domain.Wire  // workflow wiring (for output mappings)\n    55â†’}\n    56â†’\n    57â†’var _ engine.StepExecutor = (*Executor)(nil)\n    58â†’\n    59â†’// Execute runs a single host workflow step.\n    60â†’func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    61â†’\tswitch step.Type {\n    62â†’\tcase domain.StepTypeScript:\n    63â†’\t\treturn e.executeScript(ctx, step)\n    64â†’\tcase domain.StepTypeWorkflow:\n    65â†’\t\treturn e.executeWorkflow(ctx, step)\n    66â†’\tdefault:\n    67â†’\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    68â†’\t}\n    69â†’}\n    70â†’\n    71â†’// executeScript runs a shell command on the host.\n    72â†’func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    73â†’\tcmdStr := step.Config[\"run\"]\n    74â†’\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    75â†’\tcmd.Dir = e.ProjectDir\n    76â†’\tcmd.Env = append(os.Environ(),\n    77â†’\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    78â†’\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    79â†’\t)\n    80â†’\n    81â†’\t// Pass previous step output if available\n    82â†’\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n    83â†’\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n    84â†’\t}\n    85â†’\n    86â†’\t// Resolve output mappings from wires and add as env vars\n    87â†’\tif len(e.Wires) > 0 {\n    88â†’\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n    89â†’\t\tif err != nil {\n    90â†’\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n    91â†’\t\t}\n    92â†’\t\tcmd.Env = append(cmd.Env, mapped...)\n    93â†’\t}\n    94â†’\n    95â†’\toutput, err := cmd.CombinedOutput()\n    96â†’\n    97â†’\t// Extract result marker\n    98â†’\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n    99â†’\n   100â†’\t// Write output to file\n   101â†’\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   102â†’\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   103â†’\t}\n   104â†’\n   105â†’\tif err != nil {\n   106â†’\t\tif _, ok := err.(*exec.ExitError); ok {\n   107â†’\t\t\tresult := \"fail\"\n   108â†’\t\t\tif found {\n   109â†’\t\t\t\tresult = markerResult\n   110â†’\t\t\t}\n   111â†’\t\t\treturn result, nil\n   112â†’\t\t}\n   113â†’\t\treturn \"\", err\n   114â†’\t}\n   115â†’\n   116â†’\tresult := \"success\"\n   117â†’\tif found {\n   118â†’\t\tresult = markerResult\n   119â†’\t}\n   120â†’\treturn result, nil\n   121â†’}\n   122â†’\n   123â†’// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   124â†’func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   125â†’\tworkflowName := step.Config[\"workflow_name\"]\n   126â†’\tif workflowName == \"\" {\n   127â†’\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   128â†’\t}\n   129â†’\n   130â†’\t// Read prompt from previous step output or prompt_step override\n   131â†’\tvar promptContent string\n   132â†’\tpromptSource := step.Config[\"prompt_step\"]\n   133â†’\tif promptSource != \"\" {\n   134â†’\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   135â†’\t\tif err == nil {\n   136â†’\t\t\tpromptContent = string(data)\n   137â†’\t\t}\n   138â†’\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   139â†’\t\tdata, err := os.ReadFile(prev)\n   140â†’\t\tif err == nil {\n   141â†’\t\t\tpromptContent = string(data)\n   142â†’\t\t}\n   143â†’\t}\n   144â†’\n   145â†’\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   146â†’\t\tWorkflowName: workflowName,\n   147â†’\t\tProjectDir:   e.ProjectDir,\n   148â†’\t\tPrompt:       promptContent,\n   149â†’\t})\n   150â†’\tif err != nil {\n   151â†’\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   152â†’\t}\n   153â†’\n   154â†’\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   155â†’\n   156â†’\t// Poll until the run reaches a terminal state\n   157â†’\tstate, err := e.waitForRun(ctx, resp.RunId)\n   158â†’\tif err != nil {\n   159â†’\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   160â†’\t}\n   161â†’\n   162â†’\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   163â†’\n   164â†’\t// Map run state to step result\n   165â†’\tif state == domain.RunStateSucceeded {\n   166â†’\t\treturn \"success\", nil\n   167â†’\t}\n   168â†’\treturn \"fail\", nil\n   169â†’}\n   170â†’\n   171â†’// waitForRun polls the store until the run reaches a terminal state.\n   172â†’func (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   173â†’\tticker := time.NewTicker(2 * time.Second)\n   174â†’\tdefer ticker.Stop()\n   175â†’\n   176â†’\tfor {\n   177â†’\t\tselect {\n   178â†’\t\tcase <-ctx.Done():\n   179â†’\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   180â†’\t\tcase <-ticker.C:\n   181â†’\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   182â†’\t\t\tif err != nil {\n   183â†’\t\t\t\tcontinue // transient error, retry\n   184â†’\t\t\t}\n   185â†’\t\t\tswitch run.State {\n   186â†’\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   187â†’\t\t\t\treturn run.State, nil\n   188â†’\t\t\t}\n   189â†’\t\t\t// Still pending or running, continue polling\n   190â†’\t\t}\n   191â†’\t}\n   192â†’}\n   193â†’\n   194â†’// stepOutputPath returns the path for a step's output file.\n   195â†’func (e *Executor) stepOutputPath(stepName string) string {\n   196â†’\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   197â†’}\n   198â†’\n   199â†’// findPrevOutput looks for the most recent output file from any previously completed step.\n   200â†’// This is a simplified approach â€” the engine doesn't expose ordering info,\n   201â†’// so we check for common output files that might exist.\n   202â†’func (e *Executor) findPrevOutput(step *domain.Step) string {\n   203â†’\t// Check if there's a prompt_step config\n   204â†’\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   205â†’\t\tpath := e.stepOutputPath(ps)\n   206â†’\t\tif _, err := os.Stat(path); err == nil {\n   207â†’\t\t\treturn path\n   208â†’\t\t}\n   209â†’\t}\n   210â†’\treturn \"\"\n   211â†’}\n   212â†’"}]},"parent_tool_use_id":null,"session_id":"97a77a59-727f-4b73-aabd-a95c79f375a5","uuid":"976f0556-3c0d-4967-8ed4-12c5d418e701","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\n// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n// reads the source step's output, evaluates each mapping path, and returns KEY=value\n// strings suitable for adding to a command's environment.\nfunc (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n\tvar env []string\n\tfor _, w := range wires {\n\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n\t\t}\n\t\tfor _, m := range w.OutputMap {\n\t\t\tval, err := m.Path.Evaluate(data)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n\t\t\t}\n\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n\t\t}\n\t}\n\treturn env, nil\n}\n\n// RunDispatcher dispatches a container workflow run and returns the run ID.\ntype RunDispatcher interface {\n\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n}\n\n// Executor implements engine.StepExecutor for host workflow steps.\ntype Executor struct {\n\tProjectDir string\n\tDispatcher RunDispatcher\n\tStore      ports.RunStore\n\tOutputDir  string         // directory for step output files\n\tWires      []domain.Wire  // workflow wiring (for output mappings)\n}\n\nvar _ engine.StepExecutor = (*Executor)(nil)\n\n// Execute runs a single host workflow step.\nfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\treturn e.executeScript(ctx, step)\n\tcase domain.StepTypeWorkflow:\n\t\treturn e.executeWorkflow(ctx, step)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n\t}\n}\n\n// executeScript runs a shell command on the host.\nfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n\tcmdStr := step.Config[\"run\"]\n\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n\tcmd.Dir = e.ProjectDir\n\tcmd.Env = append(os.Environ(),\n\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n\t)\n\n\t// Pass previous step output if available\n\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n\t}\n\n\t// Resolve output mappings from wires and add as env vars\n\tif len(e.Wires) > 0 {\n\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n\t\t}\n\t\tcmd.Env = append(cmd.Env, mapped...)\n\t}\n\n\toutput, err := cmd.CombinedOutput()\n\n\t// Extract result marker\n\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n\n\t// Write output to file\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n\t}\n\n\tif err != nil {\n\t\tif _, ok := err.(*exec.ExitError); ok {\n\t\t\tresult := \"fail\"\n\t\t\tif found {\n\t\t\t\tresult = markerResult\n\t\t\t}\n\t\t\treturn result, nil\n\t\t}\n\t\treturn \"\", err\n\t}\n\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, nil\n}\n\n// executeWorkflow dispatches a container workflow run and blocks until it completes.\nfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n\tworkflowName := step.Config[\"workflow_name\"]\n\tif workflowName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n\t}\n\n\t// Read prompt from previous step output or prompt_step override\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tdata, err := os.ReadFile(prev)\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName: workflowName,\n\t\tProjectDir:   e.ProjectDir,\n\t\tPrompt:       promptContent,\n\t})\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n\t}\n\n\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n\n\t// Poll until the run reaches a terminal state\n\tstate, err := e.waitForRun(ctx, resp.RunId)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n\t}\n\n\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n\n\t// Map run state to step result\n\tif state == domain.RunStateSucceeded {\n\t\treturn \"success\", nil\n\t}\n\treturn \"fail\", nil\n}\n\n// waitForRun polls the store until the run reaches a terminal state.\nfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n\tticker := time.NewTicker(2 * time.Second)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n\t\tcase <-ticker.C:\n\t\t\trun, err := e.Store.GetRun(ctx, runID)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // transient error, retry\n\t\t\t}\n\t\t\tswitch run.State {\n\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n\t\t\t\treturn run.State, nil\n\t\t\t}\n\t\t\t// Still pending or running, continue polling\n\t\t}\n\t}\n}\n\n// stepOutputPath returns the path for a step's output file.\nfunc (e *Executor) stepOutputPath(stepName string) string {\n\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n}\n\n// findPrevOutput looks for the most recent output file from any previously completed step.\n// This is a simplified approach â€” the engine doesn't expose ordering info,\n// so we check for common output files that might exist.\nfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n\t// Check if there's a prompt_step config\n\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n\t\tpath := e.stepOutputPath(ps)\n\t\tif _, err := os.Stat(path); err == nil {\n\t\t\treturn path\n\t\t}\n\t}\n\treturn \"\"\n}\n","numLines":212,"startLine":1,"totalLines":212}}}
[2026-03-09T23:06:38Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014LWd2xL3yqrHAMWWgoe4HK","type":"tool_result","content":"     1â†’package host\n     2â†’\n     3â†’import (\n     4â†’\t\"context\"\n     5â†’\t\"os\"\n     6â†’\t\"path/filepath\"\n     7â†’\t\"testing\"\n     8â†’\t\"time\"\n     9â†’\n    10â†’\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    11â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    12â†’\t\"github.com/cloche-dev/cloche/internal/engine\"\n    13â†’\t\"github.com/stretchr/testify/assert\"\n    14â†’\t\"github.com/stretchr/testify/require\"\n    15â†’)\n    16â†’\n    17â†’// fakeDispatcher records dispatch calls and returns a predetermined run ID.\n    18â†’type fakeDispatcher struct {\n    19â†’\tcalls     []*pb.RunWorkflowRequest\n    20â†’\trunID     string\n    21â†’\treturnErr error\n    22â†’}\n    23â†’\n    24â†’func (f *fakeDispatcher) RunWorkflow(_ context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    25â†’\tf.calls = append(f.calls, req)\n    26â†’\tif f.returnErr != nil {\n    27â†’\t\treturn nil, f.returnErr\n    28â†’\t}\n    29â†’\treturn &pb.RunWorkflowResponse{RunId: f.runID}, nil\n    30â†’}\n    31â†’\n    32â†’// fakeStore returns a predetermined run on GetRun.\n    33â†’type fakeStore struct {\n    34â†’\truns map[string]*domain.Run\n    35â†’}\n    36â†’\n    37â†’func (f *fakeStore) CreateRun(_ context.Context, run *domain.Run) error {\n    38â†’\tf.runs[run.ID] = run\n    39â†’\treturn nil\n    40â†’}\n    41â†’func (f *fakeStore) GetRun(_ context.Context, id string) (*domain.Run, error) {\n    42â†’\tif r, ok := f.runs[id]; ok {\n    43â†’\t\treturn r, nil\n    44â†’\t}\n    45â†’\treturn nil, os.ErrNotExist\n    46â†’}\n    47â†’func (f *fakeStore) UpdateRun(_ context.Context, run *domain.Run) error {\n    48â†’\tf.runs[run.ID] = run\n    49â†’\treturn nil\n    50â†’}\n    51â†’func (f *fakeStore) DeleteRun(_ context.Context, id string) error {\n    52â†’\tdelete(f.runs, id)\n    53â†’\treturn nil\n    54â†’}\n    55â†’func (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n    56â†’\treturn nil, nil\n    57â†’}\n    58â†’func (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n    59â†’\treturn nil, nil\n    60â†’}\n    61â†’func (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n    62â†’\treturn nil, nil\n    63â†’}\n    64â†’\n    65â†’func TestExecutor_ScriptStep_Success(t *testing.T) {\n    66â†’\ttmpDir := t.TempDir()\n    67â†’\toutputDir := filepath.Join(tmpDir, \"output\")\n    68â†’\n    69â†’\texecutor := &Executor{\n    70â†’\t\tProjectDir: tmpDir,\n    71â†’\t\tOutputDir:  outputDir,\n    72â†’\t}\n    73â†’\n    74â†’\tstep := &domain.Step{\n    75â†’\t\tName:    \"greet\",\n    76â†’\t\tType:    domain.StepTypeScript,\n    77â†’\t\tResults: []string{\"success\", \"fail\"},\n    78â†’\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n    79â†’\t}\n    80â†’\n    81â†’\tresult, err := executor.Execute(context.Background(), step)\n    82â†’\trequire.NoError(t, err)\n    83â†’\tassert.Equal(t, \"success\", result)\n    84â†’\n    85â†’\t// Check output was written\n    86â†’\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n    87â†’\trequire.NoError(t, err)\n    88â†’\tassert.Contains(t, string(data), \"hello\")\n    89â†’}\n    90â†’\n    91â†’func TestExecutor_ScriptStep_Failure(t *testing.T) {\n    92â†’\ttmpDir := t.TempDir()\n    93â†’\toutputDir := filepath.Join(tmpDir, \"output\")\n    94â†’\n    95â†’\texecutor := &Executor{\n    96â†’\t\tProjectDir: tmpDir,\n    97â†’\t\tOutputDir:  outputDir,\n    98â†’\t}\n    99â†’\n   100â†’\tstep := &domain.Step{\n   101â†’\t\tName:    \"bad\",\n   102â†’\t\tType:    domain.StepTypeScript,\n   103â†’\t\tResults: []string{\"success\", \"fail\"},\n   104â†’\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   105â†’\t}\n   106â†’\n   107â†’\tresult, err := executor.Execute(context.Background(), step)\n   108â†’\trequire.NoError(t, err)\n   109â†’\tassert.Equal(t, \"fail\", result)\n   110â†’}\n   111â†’\n   112â†’func TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n   113â†’\ttmpDir := t.TempDir()\n   114â†’\toutputDir := filepath.Join(tmpDir, \"output\")\n   115â†’\n   116â†’\texecutor := &Executor{\n   117â†’\t\tProjectDir: tmpDir,\n   118â†’\t\tOutputDir:  outputDir,\n   119â†’\t}\n   120â†’\n   121â†’\tstep := &domain.Step{\n   122â†’\t\tName:    \"marker\",\n   123â†’\t\tType:    domain.StepTypeScript,\n   124â†’\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n   125â†’\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n   126â†’\t}\n   127â†’\n   128â†’\tresult, err := executor.Execute(context.Background(), step)\n   129â†’\trequire.NoError(t, err)\n   130â†’\tassert.Equal(t, \"custom\", result)\n   131â†’\n   132â†’\t// Marker line should be stripped from output\n   133â†’\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n   134â†’\trequire.NoError(t, err)\n   135â†’\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n   136â†’\tassert.Contains(t, string(data), \"some output\")\n   137â†’}\n   138â†’\n   139â†’func TestExecutor_WorkflowStep_Success(t *testing.T) {\n   140â†’\ttmpDir := t.TempDir()\n   141â†’\toutputDir := filepath.Join(tmpDir, \"output\")\n   142â†’\t_ = os.MkdirAll(outputDir, 0755)\n   143â†’\n   144â†’\tstore := &fakeStore{runs: map[string]*domain.Run{\n   145â†’\t\t\"develop-test-run\": {\n   146â†’\t\t\tID:    \"develop-test-run\",\n   147â†’\t\t\tState: domain.RunStateSucceeded,\n   148â†’\t\t},\n   149â†’\t}}\n   150â†’\n   151â†’\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   152â†’\n   153â†’\texecutor := &Executor{\n   154â†’\t\tProjectDir: tmpDir,\n   155â†’\t\tDispatcher: dispatcher,\n   156â†’\t\tStore:      store,\n   157â†’\t\tOutputDir:  outputDir,\n   158â†’\t}\n   159â†’\n   160â†’\tstep := &domain.Step{\n   161â†’\t\tName:    \"develop\",\n   162â†’\t\tType:    domain.StepTypeWorkflow,\n   163â†’\t\tResults: []string{\"success\", \"fail\"},\n   164â†’\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   165â†’\t}\n   166â†’\n   167â†’\tresult, err := executor.Execute(context.Background(), step)\n   168â†’\trequire.NoError(t, err)\n   169â†’\tassert.Equal(t, \"success\", result)\n   170â†’\tassert.Len(t, dispatcher.calls, 1)\n   171â†’\tassert.Equal(t, \"develop\", dispatcher.calls[0].WorkflowName)\n   172â†’\tassert.Equal(t, tmpDir, dispatcher.calls[0].ProjectDir)\n   173â†’}\n   174â†’\n   175â†’func TestExecutor_WorkflowStep_Failure(t *testing.T) {\n   176â†’\ttmpDir := t.TempDir()\n   177â†’\toutputDir := filepath.Join(tmpDir, \"output\")\n   178â†’\t_ = os.MkdirAll(outputDir, 0755)\n   179â†’\n   180â†’\tstore := &fakeStore{runs: map[string]*domain.Run{\n   181â†’\t\t\"develop-test-run\": {\n   182â†’\t\t\tID:    \"develop-test-run\",\n   183â†’\t\t\tState: domain.RunStateFailed,\n   184â†’\t\t},\n   185â†’\t}}\n   186â†’\n   187â†’\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   188â†’\n   189â†’\texecutor := &Executor{\n   190â†’\t\tProjectDir: tmpDir,\n   191â†’\t\tDispatcher: dispatcher,\n   192â†’\t\tStore:      store,\n   193â†’\t\tOutputDir:  outputDir,\n   194â†’\t}\n   195â†’\n   196â†’\tstep := &domain.Step{\n   197â†’\t\tName:    \"develop\",\n   198â†’\t\tType:    domain.StepTypeWorkflow,\n   199â†’\t\tResults: []string{\"success\", \"fail\"},\n   200â†’\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   201â†’\t}\n   202â†’\n   203â†’\tresult, err := executor.Execute(context.Background(), step)\n   204â†’\trequire.NoError(t, err)\n   205â†’\tassert.Equal(t, \"fail\", result)\n   206â†’}\n   207â†’\n   208â†’func TestExecutor_WorkflowStep_PassesPrompt(t *testing.T) {\n   209â†’\ttmpDir := t.TempDir()\n   210â†’\toutputDir := filepat