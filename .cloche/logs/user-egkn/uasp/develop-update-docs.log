{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MQVjCjRbFw7S3R9wvQ3H8R","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"time\"\n    11→\n    12→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    15→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    16→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17→)\n    18→\n    19→// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    20→// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    21→// strings suitable for adding to a command's environment.\n    22→func (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    23→\tvar env []string\n    24→\tfor _, w := range wires {\n    25→\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    26→\t\t\tcontinue\n    27→\t\t}\n    28→\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    29→\t\tif err != nil {\n    30→\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    31→\t\t}\n    32→\t\tfor _, m := range w.OutputMap {\n    33→\t\t\tval, err := m.Path.Evaluate(data)\n    34→\t\t\tif err != nil {\n    35→\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    36→\t\t\t}\n    37→\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    38→\t\t}\n    39→\t}\n    40→\treturn env, nil\n    41→}\n    42→\n    43→// RunDispatcher dispatches a container workflow run and returns the run ID.\n    44→type RunDispatcher interface {\n    45→\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    46→}\n    47→\n    48→// Executor implements engine.StepExecutor for host workflow steps.\n    49→type Executor struct {\n    50→\tProjectDir string\n    51→\tDispatcher RunDispatcher\n    52→\tStore      ports.RunStore\n    53→\tOutputDir  string         // directory for step output files\n    54→\tWires      []domain.Wire  // workflow wiring (for output mappings)\n    55→}\n    56→\n    57→var _ engine.StepExecutor = (*Executor)(nil)\n    58→\n    59→// Execute runs a single host workflow step.\n    60→func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    61→\tswitch step.Type {\n    62→\tcase domain.StepTypeScript:\n    63→\t\treturn e.executeScript(ctx, step)\n    64→\tcase domain.StepTypeWorkflow:\n    65→\t\treturn e.executeWorkflow(ctx, step)\n    66→\tdefault:\n    67→\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    68→\t}\n    69→}\n    70→\n    71→// executeScript runs a shell command on the host.\n    72→func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    73→\tcmdStr := step.Config[\"run\"]\n    74→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    75→\tcmd.Dir = e.ProjectDir\n    76→\tcmd.Env = append(os.Environ(),\n    77→\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    78→\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    79→\t)\n    80→\n    81→\t// Pass previous step output if available\n    82→\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n    83→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n    84→\t}\n    85→\n    86→\t// Resolve output mappings from wires and add as env vars\n    87→\tif len(e.Wires) > 0 {\n    88→\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n    89→\t\tif err != nil {\n    90→\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n    91→\t\t}\n    92→\t\tcmd.Env = append(cmd.Env, mapped...)\n    93→\t}\n    94→\n    95→\toutput, err := cmd.CombinedOutput()\n    96→\n    97→\t// Extract result marker\n    98→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n    99→\n   100→\t// Write output to file\n   101→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   102→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   103→\t}\n   104→\n   105→\tif err != nil {\n   106→\t\tif _, ok := err.(*exec.ExitError); ok {\n   107→\t\t\tresult := \"fail\"\n   108→\t\t\tif found {\n   109→\t\t\t\tresult = markerResult\n   110→\t\t\t}\n   111→\t\t\treturn result, nil\n   112→\t\t}\n   113→\t\treturn \"\", err\n   114→\t}\n   115→\n   116→\tresult := \"success\"\n   117→\tif found {\n   118→\t\tresult = markerResult\n   119→\t}\n   120→\treturn result, nil\n   121→}\n   122→\n   123→// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   124→func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   125→\tworkflowName := step.Config[\"workflow_name\"]\n   126→\tif workflowName == \"\" {\n   127→\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   128→\t}\n   129→\n   130→\t// Read prompt from previous step output or prompt_step override\n   131→\tvar promptContent string\n   132→\tpromptSource := step.Config[\"prompt_step\"]\n   133→\tif promptSource != \"\" {\n   134→\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   135→\t\tif err == nil {\n   136→\t\t\tpromptContent = string(data)\n   137→\t\t}\n   138→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   139→\t\tdata, err := os.ReadFile(prev)\n   140→\t\tif err == nil {\n   141→\t\t\tpromptContent = string(data)\n   142→\t\t}\n   143→\t}\n   144→\n   145→\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   146→\t\tWorkflowName: workflowName,\n   147→\t\tProjectDir:   e.ProjectDir,\n   148→\t\tPrompt:       promptContent,\n   149→\t})\n   150→\tif err != nil {\n   151→\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   152→\t}\n   153→\n   154→\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   155→\n   156→\t// Poll until the run reaches a terminal state\n   157→\tstate, err := e.waitForRun(ctx, resp.RunId)\n   158→\tif err != nil {\n   159→\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   160→\t}\n   161→\n   162→\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   163→\n   164→\t// Map run state to step result\n   165→\tif state == domain.RunStateSucceeded {\n   166→\t\treturn \"success\", nil\n   167→\t}\n   168→\treturn \"fail\", nil\n   169→}\n   170→\n   171→// waitForRun polls the store until the run reaches a terminal state.\n   172→func (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   173→\tticker := time.NewTicker(2 * time.Second)\n   174→\tdefer ticker.Stop()\n   175→\n   176→\tfor {\n   177→\t\tselect {\n   178→\t\tcase <-ctx.Done():\n   179→\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   180→\t\tcase <-ticker.C:\n   181→\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   182→\t\t\tif err != nil {\n   183→\t\t\t\tcontinue // transient error, retry\n   184→\t\t\t}\n   185→\t\t\tswitch run.State {\n   186→\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   187→\t\t\t\treturn run.State, nil\n   188→\t\t\t}\n   189→\t\t\t// Still pending or running, continue polling\n   190→\t\t}\n   191→\t}\n   192→}\n   193→\n   194→// stepOutputPath returns the path for a step's output file.\n   195→func (e *Executor) stepOutputPath(stepName string) string {\n   196→\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   197→}\n   198→\n   199→// findPrevOutput looks for the most recent output file from any previously completed step.\n   200→// This is a simplified approach — the engine doesn't expose ordering info,\n   201→// so we check for common output files that might exist.\n   202→func (e *Executor) findPrevOutput(step *domain.Step) string {\n   203→\t// Check if there's a prompt_step config\n   204→\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   205→\t\tpath := e.stepOutputPath(ps)\n   206→\t\tif _, err := os.Stat(path); err == nil {\n   207→\t\t\treturn path\n   208→\t\t}\n   209→\t}\n   210→\treturn \"\"\n   211→}\n   212→"}]},"parent_tool_use_id":null,"session_id":"97a77a59-727f-4b73-aabd-a95c79f375a5","uuid":"976f0556-3c0d-4967-8ed4-12c5d418e701","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\n// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n// reads the source step's output, evaluates each mapping path, and returns KEY=value\n// strings suitable for adding to a command's environment.\nfunc (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n\tvar env []string\n\tfor _, w := range wires {\n\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n\t\t}\n\t\tfor _, m := range w.OutputMap {\n\t\t\tval, err := m.Path.Evaluate(data)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n\t\t\t}\n\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n\t\t}\n\t}\n\treturn env, nil\n}\n\n// RunDispatcher dispatches a container workflow run and returns the run ID.\ntype RunDispatcher interface {\n\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n}\n\n// Executor implements engine.StepExecutor for host workflow steps.\ntype Executor struct {\n\tProjectDir string\n\tDispatcher RunDispatcher\n\tStore      ports.RunStore\n\tOutputDir  string         // directory for step output files\n\tWires      []domain.Wire  // workflow wiring (for output mappings)\n}\n\nvar _ engine.StepExecutor = (*Executor)(nil)\n\n// Execute runs a single host workflow step.\nfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\treturn e.executeScript(ctx, step)\n\tcase domain.StepTypeWorkflow:\n\t\treturn e.executeWorkflow(ctx, step)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n\t}\n}\n\n// executeScript runs a shell command on the host.\nfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n\tcmdStr := step.Config[\"run\"]\n\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n\tcmd.Dir = e.ProjectDir\n\tcmd.Env = append(os.Environ(),\n\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n\t)\n\n\t// Pass previous step output if available\n\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n\t}\n\n\t// Resolve output mappings from wires and add as env vars\n\tif len(e.Wires) > 0 {\n\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n\t\t}\n\t\tcmd.Env = append(cmd.Env, mapped...)\n\t}\n\n\toutput, err := cmd.CombinedOutput()\n\n\t// Extract result marker\n\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n\n\t// Write output to file\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n\t}\n\n\tif err != nil {\n\t\tif _, ok := err.(*exec.ExitError); ok {\n\t\t\tresult := \"fail\"\n\t\t\tif found {\n\t\t\t\tresult = markerResult\n\t\t\t}\n\t\t\treturn result, nil\n\t\t}\n\t\treturn \"\", err\n\t}\n\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, nil\n}\n\n// executeWorkflow dispatches a container workflow run and blocks until it completes.\nfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n\tworkflowName := step.Config[\"workflow_name\"]\n\tif workflowName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n\t}\n\n\t// Read prompt from previous step output or prompt_step override\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tdata, err := os.ReadFile(prev)\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName: workflowName,\n\t\tProjectDir:   e.ProjectDir,\n\t\tPrompt:       promptContent,\n\t})\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n\t}\n\n\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n\n\t// Poll until the run reaches a terminal state\n\tstate, err := e.waitForRun(ctx, resp.RunId)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n\t}\n\n\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n\n\t// Map run state to step result\n\tif state == domain.RunStateSucceeded {\n\t\treturn \"success\", nil\n\t}\n\treturn \"fail\", nil\n}\n\n// waitForRun polls the store until the run reaches a terminal state.\nfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n\tticker := time.NewTicker(2 * time.Second)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n\t\tcase <-ticker.C:\n\t\t\trun, err := e.Store.GetRun(ctx, runID)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // transient error, retry\n\t\t\t}\n\t\t\tswitch run.State {\n\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n\t\t\t\treturn run.State, nil\n\t\t\t}\n\t\t\t// Still pending or running, continue polling\n\t\t}\n\t}\n}\n\n// stepOutputPath returns the path for a step's output file.\nfunc (e *Executor) stepOutputPath(stepName string) string {\n\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n}\n\n// findPrevOutput looks for the most recent output file from any previously completed step.\n// This is a simplified approach — the engine doesn't expose ordering info,\n// so we check for common output files that might exist.\nfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n\t// Check if there's a prompt_step config\n\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n\t\tpath := e.stepOutputPath(ps)\n\t\tif _, err := os.Stat(path); err == nil {\n\t\t\treturn path\n\t\t}\n\t}\n\treturn \"\"\n}\n","numLines":212,"startLine":1,"totalLines":212}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014LWd2xL3yqrHAMWWgoe4HK","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"os\"\n     6→\t\"path/filepath\"\n     7→\t\"testing\"\n     8→\t\"time\"\n     9→\n    10→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    11→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    12→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    13→\t\"github.com/stretchr/testify/assert\"\n    14→\t\"github.com/stretchr/testify/require\"\n    15→)\n    16→\n    17→// fakeDispatcher records dispatch calls and returns a predetermined run ID.\n    18→type fakeDispatcher struct {\n    19→\tcalls     []*pb.RunWorkflowRequest\n    20→\trunID     string\n    21→\treturnErr error\n    22→}\n    23→\n    24→func (f *fakeDispatcher) RunWorkflow(_ context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    25→\tf.calls = append(f.calls, req)\n    26→\tif f.returnErr != nil {\n    27→\t\treturn nil, f.returnErr\n    28→\t}\n    29→\treturn &pb.RunWorkflowResponse{RunId: f.runID}, nil\n    30→}\n    31→\n    32→// fakeStore returns a predetermined run on GetRun.\n    33→type fakeStore struct {\n    34→\truns map[string]*domain.Run\n    35→}\n    36→\n    37→func (f *fakeStore) CreateRun(_ context.Context, run *domain.Run) error {\n    38→\tf.runs[run.ID] = run\n    39→\treturn nil\n    40→}\n    41→func (f *fakeStore) GetRun(_ context.Context, id string) (*domain.Run, error) {\n    42→\tif r, ok := f.runs[id]; ok {\n    43→\t\treturn r, nil\n    44→\t}\n    45→\treturn nil, os.ErrNotExist\n    46→}\n    47→func (f *fakeStore) UpdateRun(_ context.Context, run *domain.Run) error {\n    48→\tf.runs[run.ID] = run\n    49→\treturn nil\n    50→}\n    51→func (f *fakeStore) DeleteRun(_ context.Context, id string) error {\n    52→\tdelete(f.runs, id)\n    53→\treturn nil\n    54→}\n    55→func (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n    56→\treturn nil, nil\n    57→}\n    58→func (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n    59→\treturn nil, nil\n    60→}\n    61→func (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n    62→\treturn nil, nil\n    63→}\n    64→\n    65→func TestExecutor_ScriptStep_Success(t *testing.T) {\n    66→\ttmpDir := t.TempDir()\n    67→\toutputDir := filepath.Join(tmpDir, \"output\")\n    68→\n    69→\texecutor := &Executor{\n    70→\t\tProjectDir: tmpDir,\n    71→\t\tOutputDir:  outputDir,\n    72→\t}\n    73→\n    74→\tstep := &domain.Step{\n    75→\t\tName:    \"greet\",\n    76→\t\tType:    domain.StepTypeScript,\n    77→\t\tResults: []string{\"success\", \"fail\"},\n    78→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n    79→\t}\n    80→\n    81→\tresult, err := executor.Execute(context.Background(), step)\n    82→\trequire.NoError(t, err)\n    83→\tassert.Equal(t, \"success\", result)\n    84→\n    85→\t// Check output was written\n    86→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n    87→\trequire.NoError(t, err)\n    88→\tassert.Contains(t, string(data), \"hello\")\n    89→}\n    90→\n    91→func TestExecutor_ScriptStep_Failure(t *testing.T) {\n    92→\ttmpDir := t.TempDir()\n    93→\toutputDir := filepath.Join(tmpDir, \"output\")\n    94→\n    95→\texecutor := &Executor{\n    96→\t\tProjectDir: tmpDir,\n    97→\t\tOutputDir:  outputDir,\n    98→\t}\n    99→\n   100→\tstep := &domain.Step{\n   101→\t\tName:    \"bad\",\n   102→\t\tType:    domain.StepTypeScript,\n   103→\t\tResults: []string{\"success\", \"fail\"},\n   104→\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   105→\t}\n   106→\n   107→\tresult, err := executor.Execute(context.Background(), step)\n   108→\trequire.NoError(t, err)\n   109→\tassert.Equal(t, \"fail\", result)\n   110→}\n   111→\n   112→func TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n   113→\ttmpDir := t.TempDir()\n   114→\toutputDir := filepath.Join(tmpDir, \"output\")\n   115→\n   116→\texecutor := &Executor{\n   117→\t\tProjectDir: tmpDir,\n   118→\t\tOutputDir:  outputDir,\n   119→\t}\n   120→\n   121→\tstep := &domain.Step{\n   122→\t\tName:    \"marker\",\n   123→\t\tType:    domain.StepTypeScript,\n   124→\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n   125→\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n   126→\t}\n   127→\n   128→\tresult, err := executor.Execute(context.Background(), step)\n   129→\trequire.NoError(t, err)\n   130→\tassert.Equal(t, \"custom\", result)\n   131→\n   132→\t// Marker line should be stripped from output\n   133→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n   134→\trequire.NoError(t, err)\n   135→\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n   136→\tassert.Contains(t, string(data), \"some output\")\n   137→}\n   138→\n   139→func TestExecutor_WorkflowStep_Success(t *testing.T) {\n   140→\ttmpDir := t.TempDir()\n   141→\toutputDir := filepath.Join(tmpDir, \"output\")\n   142→\t_ = os.MkdirAll(outputDir, 0755)\n   143→\n   144→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   145→\t\t\"develop-test-run\": {\n   146→\t\t\tID:    \"develop-test-run\",\n   147→\t\t\tState: domain.RunStateSucceeded,\n   148→\t\t},\n   149→\t}}\n   150→\n   151→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   152→\n   153→\texecutor := &Executor{\n   154→\t\tProjectDir: tmpDir,\n   155→\t\tDispatcher: dispatcher,\n   156→\t\tStore:      store,\n   157→\t\tOutputDir:  outputDir,\n   158→\t}\n   159→\n   160→\tstep := &domain.Step{\n   161→\t\tName:    \"develop\",\n   162→\t\tType:    domain.StepTypeWorkflow,\n   163→\t\tResults: []string{\"success\", \"fail\"},\n   164→\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   165→\t}\n   166→\n   167→\tresult, err := executor.Execute(context.Background(), step)\n   168→\trequire.NoError(t, err)\n   169→\tassert.Equal(t, \"success\", result)\n   170→\tassert.Len(t, dispatcher.calls, 1)\n   171→\tassert.Equal(t, \"develop\", dispatcher.calls[0].WorkflowName)\n   172→\tassert.Equal(t, tmpDir, dispatcher.calls[0].ProjectDir)\n   173→}\n   174→\n   175→func TestExecutor_WorkflowStep_Failure(t *testing.T) {\n   176→\ttmpDir := t.TempDir()\n   177→\toutputDir := filepath.Join(tmpDir, \"output\")\n   178→\t_ = os.MkdirAll(outputDir, 0755)\n   179→\n   180→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   181→\t\t\"develop-test-run\": {\n   182→\t\t\tID:    \"develop-test-run\",\n   183→\t\t\tState: domain.RunStateFailed,\n   184→\t\t},\n   185→\t}}\n   186→\n   187→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   188→\n   189→\texecutor := &Executor{\n   190→\t\tProjectDir: tmpDir,\n   191→\t\tDispatcher: dispatcher,\n   192→\t\tStore:      store,\n   193→\t\tOutputDir:  outputDir,\n   194→\t}\n   195→\n   196→\tstep := &domain.Step{\n   197→\t\tName:    \"develop\",\n   198→\t\tType:    domain.StepTypeWorkflow,\n   199→\t\tResults: []string{\"success\", \"fail\"},\n   200→\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   201→\t}\n   202→\n   203→\tresult, err := executor.Execute(context.Background(), step)\n   204→\trequire.NoError(t, err)\n   205→\tassert.Equal(t, \"fail\", result)\n   206→}\n   207→\n   208→func TestExecutor_WorkflowStep_PassesPrompt(t *testing.T) {\n   209→\ttmpDir := t.TempDir()\n   210→\toutputDir := filepath.Join(tmpDir, \"output\")\n   211→\t_ = os.MkdirAll(outputDir, 0755)\n   212→\n   213→\t// Write a previous step's output\n   214→\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n   215→\n   216→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   217→\t\t\"develop-test-run\": {\n   218→\t\t\tID:    \"develop-test-run\",\n   219→\t\t\tState: domain.RunStateSucceeded,\n   220→\t\t},\n   221→\t}}\n   222→\n   223→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   224→\n   225→\texecutor := &Executor{\n   226→\t\tProjectDir: tmpDir,\n   227→\t\tDispatcher: dispatcher,\n   228→\t\tStore:      store,\n   229→\t\tOutputDir:  outputDir,\n   230→\t}\n   231→\n   232→\tstep := &domain.Step{\n   233→\t\tName:    \"develop\",\n   234→\t\tType:    domain.StepTypeWorkflow,\n   235→\t\tResults: []string{\"success\", \"fail\"},\n   236→\t\tConfig: map[string]string{\n   237→\t\t\t\"workflow_name\": \"develop\",\n   238→\t\t\t\"prompt_step\":   \"prepare-prompt\",\n   239→\t\t},\n   240→\t}\n   241→\n   242→\tresult, err := executor.Execute(context.Background(), step)\n   243→\trequire.NoError(t, err)\n   244→\tassert.Equal(t, \"success\", result)\n   245→\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n   246→}\n   247→\n   248→func TestEngine_HostWorkflow_Linear(t *testing.T) {\n   249→\ttmpDir := t.TempDir()\n   250→\toutputDir := filepath.Join(tmpDir, \"output\")\n   251→\n   252→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   253→\t\t\"develop-test-run\": {\n   254→\t\t\tID:    \"develop-test-run\",\n   255→\t\t\tState: domain.RunStateSucceeded,\n   256→\t\t},\n   257→\t}}\n   258→\n   259→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   260→\n   261→\texecutor := &Executor{\n   262→\t\tProjectDir: tmpDir,\n   263→\t\tDispatcher: dispatcher,\n   264→\t\tStore:      store,\n   265→\t\tOutputDir:  outputDir,\n   266→\t}\n   267→\n   268→\twf := &domain.Workflow{\n   269→\t\tName: \"main\",\n   270→\t\tSteps: map[string]*domain.Step{\n   271→\t\t\t\"prepare\": {\n   272→\t\t\t\tName:    \"prepare\",\n   273→\t\t\t\tType:    domain.StepTypeScript,\n   274→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   275→\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n   276→\t\t\t},\n   277→\t\t\t\"develop\": {\n   278→\t\t\t\tName:    \"develop\",\n   279→\t\t\t\tType:    domain.StepTypeWorkflow,\n   280→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   281→\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   282→\t\t\t},\n   283→\t\t\t\"merge\": {\n   284→\t\t\t\tName:    \"merge\",\n   285→\t\t\t\tType:    domain.StepTypeScript,\n   286→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   287→\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n   288→\t\t\t},\n   289→\t\t},\n   290→\t\tWiring: []domain.Wire{\n   291→\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   292→\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   293→\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n   294→\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   295→\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n   296→\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n   297→\t\t},\n   298→\t\tEntryStep: \"prepare\",\n   299→\t}\n   300→\n   301→\teng := engine.New(executor)\n   302→\trun, err := eng.Run(context.Background(), wf)\n   303→\trequire.NoError(t, err)\n   304→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   305→\tassert.Len(t, dispatcher.calls, 1)\n   306→}\n   307→\n   308→func TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n   309→\ttmpDir := t.TempDir()\n   310→\toutputDir := filepath.Join(tmpDir, \"output\")\n   311→\n   312→\texecutor := &Executor{\n   313→\t\tProjectDir: tmpDir,\n   314→\t\tOutputDir:  outputDir,\n   315→\t}\n   316→\n   317→\twf := &domain.Workflow{\n   318→\t\tName: \"main\",\n   319→\t\tSteps: map[string]*domain.Step{\n   320→\t\t\t\"prepare\": {\n   321→\t\t\t\tName:    \"prepare\",\n   322→\t\t\t\tType:    domain.StepTypeScript,\n   323→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   324→\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   325→\t\t\t},\n   326→\t\t\t\"develop\": {\n   327→\t\t\t\tName:    \"develop\",\n   328→\t\t\t\tType:    domain.StepTypeWorkflow,\n   329→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   330→\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   331→\t\t\t},\n   332→\t\t},\n   333→\t\tWiring: []domain.Wire{\n   334→\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   335→\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   336→\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n   337→\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   338→\t\t},\n   339→\t\tEntryStep: \"prepare\",\n   340→\t}\n   341→\n   342→\teng := engine.New(executor)\n   343→\trun, err := eng.Run(context.Background(), wf)\n   344→\trequire.NoError(t, err)\n   345→\tassert.Equal(t, domain.RunStateFailed, run.State)\n   346→}\n   347→\n   348→func TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n   349→\ttmpDir := t.TempDir()\n   350→\toutputDir := filepath.Join(tmpDir, \"output\")\n   351→\n   352→\texecutor := &Executor{\n   353→\t\tProjectDir: tmpDir,\n   354→\t\tOutputDir:  outputDir,\n   355→\t}\n   356→\n   357→\tstep := &domain.Step{\n   358→\t\tName:    \"env-check\",\n   359→\t\tType:    domain.StepTypeScript,\n   360→\t\tResults: []string{\"success\", \"fail\"},\n   361→\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n   362→\t}\n   363→\n   364→\tresult, err := executor.Execute(context.Background(), step)\n   365→\trequire.NoError(t, err)\n   366→\tassert.Equal(t, \"success\", result)\n   367→\n   368→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n   369→\trequire.NoError(t, err)\n   370→\tassert.Contains(t, string(data), tmpDir)\n   371→}\n   372→\n   373→func TestExecutor_ScriptStep_NoOutputMappings(t *testing.T) {\n   374→\ttmpDir := t.TempDir()\n   375→\toutputDir := filepath.Join(tmpDir, \"output\")\n   376→\n   377→\texecutor := &Executor{\n   378→\t\tProjectDir: tmpDir,\n   379→\t\tOutputDir:  outputDir,\n   380→\t\tWires: []domain.Wire{\n   381→\t\t\t{From: \"step-a\", Result: \"success\", To: \"step-b\"},\n   382→\t\t},\n   383→\t}\n   384→\n   385→\tstep := &domain.Step{\n   386→\t\tName:    \"step-b\",\n   387→\t\tType:    domain.StepTypeScript,\n   388→\t\tResults: []string{\"success\", \"fail\"},\n   389→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   390→\t}\n   391→\n   392→\tresult, err := executor.Execute(context.Background(), step)\n   393→\trequire.NoError(t, err)\n   394→\tassert.Equal(t, \"success\", result)\n   395→}\n   396→\n   397→func TestExecutor_ScriptStep_OutputMappings_JSONFields(t *testing.T) {\n   398→\ttmpDir := t.TempDir()\n   399→\toutputDir := filepath.Join(tmpDir, \"output\")\n   400→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   401→\n   402→\t// Write source step output as JSON\n   403→\tsourceJSON := `{\"title\": \"Fix bug\", \"priority\": \"high\"}`\n   404→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"get-tasks.out\"), []byte(sourceJSON), 0644))\n   405→\n   406→\texecutor := &Executor{\n   407→\t\tProjectDir: tmpDir,\n   408→\t\tOutputDir:  outputDir,\n   409→\t\tWires: []domain.Wire{\n   410→\t\t\t{\n   411→\t\t\t\tFrom:   \"get-tasks\",\n   412→\t\t\t\tResult: \"success\",\n   413→\t\t\t\tTo:     \"use-tasks\",\n   414→\t\t\t\tOutputMap: []domain.OutputMapping{\n   415→\t\t\t\t\t{\n   416→\t\t\t\t\t\tEnvVar: \"TASK_TITLE\",\n   417→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"title\"}}},\n   418→\t\t\t\t\t},\n   419→\t\t\t\t\t{\n   420→\t\t\t\t\t\tEnvVar: \"TASK_PRIORITY\",\n   421→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"priority\"}}},\n   422→\t\t\t\t\t},\n   423→\t\t\t\t},\n   424→\t\t\t},\n   425→\t\t},\n   426→\t}\n   427→\n   428→\tstep := &domain.Step{\n   429→\t\tName:    \"use-tasks\",\n   430→\t\tType:    domain.StepTypeScript,\n   431→\t\tResults: []string{\"success\", \"fail\"},\n   432→\t\tConfig:  map[string]string{\"run\": \"echo $TASK_TITLE $TASK_PRIORITY\"},\n   433→\t}\n   434→\n   435→\tresult, err := executor.Execute(context.Background(), step)\n   436→\trequire.NoError(t, err)\n   437→\tassert.Equal(t, \"success\", result)\n   438→\n   439→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"use-tasks.out\"))\n   440→\trequire.NoError(t, err)\n   441→\tassert.Contains(t, string(data), \"Fix bug\")\n   442→\tassert.Contains(t, string(data), \"high\")\n   443→}\n   444→\n   445→func TestExecutor_ScriptStep_OutputMappings_ArrayIndex(t *testing.T) {\n   446→\ttmpDir := t.TempDir()\n   447→\toutputDir := filepath.Join(tmpDir, \"output\")\n   448→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   449→\n   450→\t// Write source step output as JSON array\n   451→\tsourceJSON := `[{\"id\": \"task-1\", \"title\": \"First\"}, {\"id\": \"task-2\", \"title\": \"Second\"}]`\n   452→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"list-tasks.out\"), []byte(sourceJSON), 0644))\n   453→\n   454→\texecutor := &Executor{\n   455→\t\tProjectDir: tmpDir,\n   456→\t\tOutputDir:  outputDir,\n   457→\t\tWires: []domain.Wire{\n   458→\t\t\t{\n   459→\t\t\t\tFrom:   \"list-tasks\",\n   460→\t\t\t\tResult: \"success\",\n   461→\t\t\t\tTo:     \"process\",\n   462→\t\t\t\tOutputMap: []domain.OutputMapping{\n   463→\t\t\t\t\t{\n   464→\t\t\t\t\t\tEnvVar: \"FIRST_ID\",\n   465→\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n   466→\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 0},\n   467→\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"id\"},\n   468→\t\t\t\t\t\t}},\n   469→\t\t\t\t\t},\n   470→\t\t\t\t\t{\n   471→\t\t\t\t\t\tEnvVar: \"SECOND_TITLE\",\n   472→\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n   473→\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 1},\n   474→\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"title\"},\n   475→\t\t\t\t\t\t}},\n   476→\t\t\t\t\t},\n   477→\t\t\t\t},\n   478→\t\t\t},\n   479→\t\t},\n   480→\t}\n   481→\n   482→\tstep := &domain.Step{\n   483→\t\tName:    \"process\",\n   484→\t\tType:    domain.StepTypeScript,\n   485→\t\tResults: []string{\"success\", \"fail\"},\n   486→\t\tConfig:  map[string]string{\"run\": \"echo $FIRST_ID $SECOND_TITLE\"},\n   487→\t}\n   488→\n   489→\tresult, err := executor.Execute(context.Background(), step)\n   490→\trequire.NoError(t, err)\n   491→\tassert.Equal(t, \"success\", result)\n   492→\n   493→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"process.out\"))\n   494→\trequire.NoError(t, err)\n   495→\tassert.Contains(t, string(data), \"task-1\")\n   496→\tassert.Contains(t, string(data), \"Second\")\n   497→}\n   498→\n   499→func TestExecutor_ScriptStep_OutputMappings_MissingSourceOutput(t *testing.T) {\n   500→\ttmpDir := t.TempDir()\n   501→\toutputDir := filepath.Join(tmpDir, \"output\")\n   502→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   503→\n   504→\t// No source output file written\n   505→\n   506→\texecutor := &Executor{\n   507→\t\tProjectDir: tmpDir,\n   508→\t\tOutputDir:  outputDir,\n   509→\t\tWires: []domain.Wire{\n   510→\t\t\t{\n   511→\t\t\t\tFrom:   \"missing-step\",\n   512→\t\t\t\tResult: \"success\",\n   513→\t\t\t\tTo:     \"consumer\",\n   514→\t\t\t\tOutputMap: []domain.OutputMapping{\n   515→\t\t\t\t\t{\n   516→\t\t\t\t\t\tEnvVar: \"VAL\",\n   517→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n   518→\t\t\t\t\t},\n   519→\t\t\t\t},\n   520→\t\t\t},\n   521→\t\t},\n   522→\t}\n   523→\n   524→\tstep := &domain.Step{\n   525→\t\tName:    \"consumer\",\n   526→\t\tType:    domain.StepTypeScript,\n   527→\t\tResults: []string{\"success\", \"fail\"},\n   528→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   529→\t}\n   530→\n   531→\t_, err := executor.Execute(context.Background(), step)\n   532→\trequire.Error(t, err)\n   533→\tassert.Contains(t, err.Error(), \"reading output of missing-step\")\n   534→}\n   535→\n   536→func TestExecutor_ScriptStep_OutputMappings_NotJSON(t *testing.T) {\n   537→\ttmpDir := t.TempDir()\n   538→\toutputDir := filepath.Join(tmpDir, \"output\")\n   539→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   540→\n   541→\t// Write non-JSON output\n   542→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"plain.out\"), []byte(\"not json\"), 0644))\n   543→\n   544→\texecutor := &Executor{\n   545→\t\tProjectDir: tmpDir,\n   546→\t\tOutputDir:  outputDir,\n   547→\t\tWires: []domain.Wire{\n   548→\t\t\t{\n   549→\t\t\t\tFrom:   \"plain\",\n   550→\t\t\t\tResult: \"success\",\n   551→\t\t\t\tTo:     \"consumer\",\n   552→\t\t\t\tOutputMap: []domain.OutputMapping{\n   553→\t\t\t\t\t{\n   554→\t\t\t\t\t\tEnvVar: \"VAL\",\n   555→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n   556→\t\t\t\t\t},\n   557→\t\t\t\t},\n   558→\t\t\t},\n   559→\t\t},\n   560→\t}\n   561→\n   562→\tstep := &domain.Step{\n   563→\t\tName:    \"consumer\",\n   564→\t\tType:    domain.StepTypeScript,\n   565→\t\tResults: []string{\"success\", \"fail\"},\n   566→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   567→\t}\n   568→\n   569→\t_, err := executor.Execute(context.Background(), step)\n   570→\trequire.Error(t, err)\n   571→\tassert.Contains(t, err.Error(), \"not valid JSON\")\n   572→}\n   573→"}]},"parent_tool_use_id":null,"session_id":"97a77a59-727f-4b73-aabd-a95c79f375a5","uuid":"95613bb6-229e-4735-8b54-1623c1818fb5","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor_test.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// fakeDispatcher records dispatch calls and returns a predetermined run ID.\ntype fakeDispatcher struct {\n\tcalls     []*pb.RunWorkflowRequest\n\trunID     string\n\treturnErr error\n}\n\nfunc (f *fakeDispatcher) RunWorkflow(_ context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tf.calls = append(f.calls, req)\n\tif f.returnErr != nil {\n\t\treturn nil, f.returnErr\n\t}\n\treturn &pb.RunWorkflowResponse{RunId: f.runID}, nil\n}\n\n// fakeStore returns a predetermined run on GetRun.\ntype fakeStore struct {\n\truns map[string]*domain.Run\n}\n\nfunc (f *fakeStore) CreateRun(_ context.Context, run *domain.Run) error {\n\tf.runs[run.ID] = run\n\treturn nil\n}\nfunc (f *fakeStore) GetRun(_ context.Context, id string) (*domain.Run, error) {\n\tif r, ok := f.runs[id]; ok {\n\t\treturn r, nil\n\t}\n\treturn nil, os.ErrNotExist\n}\nfunc (f *fakeStore) UpdateRun(_ context.Context, run *domain.Run) error {\n\tf.runs[run.ID] = run\n\treturn nil\n}\nfunc (f *fakeStore) DeleteRun(_ context.Context, id string) error {\n\tdelete(f.runs, id)\n\treturn nil\n}\nfunc (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n\treturn nil, nil\n}\n\nfunc TestExecutor_ScriptStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"greet\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Check output was written\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"hello\")\n}\n\nfunc TestExecutor_ScriptStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"bad\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"marker\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"custom\", result)\n\n\t// Marker line should be stripped from output\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n\trequire.NoError(t, err)\n\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n\tassert.Contains(t, string(data), \"some output\")\n}\n\nfunc TestExecutor_WorkflowStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\tassert.Len(t, dispatcher.calls, 1)\n\tassert.Equal(t, \"develop\", dispatcher.calls[0].WorkflowName)\n\tassert.Equal(t, tmpDir, dispatcher.calls[0].ProjectDir)\n}\n\nfunc TestExecutor_WorkflowStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateFailed,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_WorkflowStep_PassesPrompt(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\t// Write a previous step's output\n\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"workflow_name\": \"develop\",\n\t\t\t\"prompt_step\":   \"prepare-prompt\",\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n}\n\nfunc TestEngine_HostWorkflow_Linear(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n\t\t\t},\n\t\t\t\"develop\": {\n\t\t\t\tName:    \"develop\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t\t\"merge\": {\n\t\t\t\tName:    \"merge\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\tassert.Len(t, dispatcher.calls, 1)\n}\n\nfunc TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n\t\t\t},\n\t\t\t\"develop\": {\n\t\t\t\tName:    \"develop\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n}\n\nfunc TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"env-check\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), tmpDir)\n}\n\nfunc TestExecutor_ScriptStep_NoOutputMappings(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{From: \"step-a\", Result: \"success\", To: \"step-b\"},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"step-b\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_JSONFields(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write source step output as JSON\n\tsourceJSON := `{\"title\": \"Fix bug\", \"priority\": \"high\"}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"get-tasks.out\"), []byte(sourceJSON), 0644))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"get-tasks\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"use-tasks\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"TASK_TITLE\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"title\"}}},\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"TASK_PRIORITY\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"priority\"}}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"use-tasks\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $TASK_TITLE $TASK_PRIORITY\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"use-tasks.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"Fix bug\")\n\tassert.Contains(t, string(data), \"high\")\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_ArrayIndex(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write source step output as JSON array\n\tsourceJSON := `[{\"id\": \"task-1\", \"title\": \"First\"}, {\"id\": \"task-2\", \"title\": \"Second\"}]`\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"list-tasks.out\"), []byte(sourceJSON), 0644))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"list-tasks\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"process\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"FIRST_ID\",\n\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 0},\n\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"id\"},\n\t\t\t\t\t\t}},\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"SECOND_TITLE\",\n\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 1},\n\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"title\"},\n\t\t\t\t\t\t}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"process\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $FIRST_ID $SECOND_TITLE\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"process.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"task-1\")\n\tassert.Contains(t, string(data), \"Second\")\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_MissingSourceOutput(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// No source output file written\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"missing-step\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"consumer\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"VAL\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"consumer\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\t_, err := executor.Execute(context.Background(), step)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"reading output of missing-step\")\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_NotJSON(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write non-JSON output\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"plain.out\"), []byte(\"not json\"), 0644))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"plain\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"consumer\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"VAL\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"consumer\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\t_, err := executor.Execute(context.Background(), step)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"not valid JSON\")\n}\n","numLines":573,"startLine":1,"totalLines":573}}}
