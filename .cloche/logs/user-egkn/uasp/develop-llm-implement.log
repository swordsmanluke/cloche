{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014gAURoxUh5QYeWJXUZ9UrS","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"os\"\n     6→\t\"path/filepath\"\n     7→\t\"testing\"\n     8→\t\"time\"\n     9→\n    10→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    11→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    12→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    13→\t\"github.com/stretchr/testify/assert\"\n    14→\t\"github.com/stretchr/testify/require\"\n    15→)\n    16→\n    17→// fakeDispatcher records dispatch calls and returns a predetermined run ID.\n    18→type fakeDispatcher struct {\n    19→\tcalls     []*pb.RunWorkflowRequest\n    20→\trunID     string\n    21→\treturnErr error\n    22→}\n    23→\n    24→func (f *fakeDispatcher) RunWorkflow(_ context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    25→\tf.calls = append(f.calls, req)\n    26→\tif f.returnErr != nil {\n    27→\t\treturn nil, f.returnErr\n    28→\t}\n    29→\treturn &pb.RunWorkflowResponse{RunId: f.runID}, nil\n    30→}\n    31→\n    32→// fakeStore returns a predetermined run on GetRun.\n    33→type fakeStore struct {\n    34→\truns map[string]*domain.Run\n    35→}\n    36→\n    37→func (f *fakeStore) CreateRun(_ context.Context, run *domain.Run) error {\n    38→\tf.runs[run.ID] = run\n    39→\treturn nil\n    40→}\n    41→func (f *fakeStore) GetRun(_ context.Context, id string) (*domain.Run, error) {\n    42→\tif r, ok := f.runs[id]; ok {\n    43→\t\treturn r, nil\n    44→\t}\n    45→\treturn nil, os.ErrNotExist\n    46→}\n    47→func (f *fakeStore) UpdateRun(_ context.Context, run *domain.Run) error {\n    48→\tf.runs[run.ID] = run\n    49→\treturn nil\n    50→}\n    51→func (f *fakeStore) DeleteRun(_ context.Context, id string) error {\n    52→\tdelete(f.runs, id)\n    53→\treturn nil\n    54→}\n    55→func (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n    56→\treturn nil, nil\n    57→}\n    58→func (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n    59→\treturn nil, nil\n    60→}\n    61→func (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n    62→\treturn nil, nil\n    63→}\n    64→\n    65→func TestExecutor_ScriptStep_Success(t *testing.T) {\n    66→\ttmpDir := t.TempDir()\n    67→\toutputDir := filepath.Join(tmpDir, \"output\")\n    68→\n    69→\texecutor := &Executor{\n    70→\t\tProjectDir: tmpDir,\n    71→\t\tOutputDir:  outputDir,\n    72→\t}\n    73→\n    74→\tstep := &domain.Step{\n    75→\t\tName:    \"greet\",\n    76→\t\tType:    domain.StepTypeScript,\n    77→\t\tResults: []string{\"success\", \"fail\"},\n    78→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n    79→\t}\n    80→\n    81→\tresult, err := executor.Execute(context.Background(), step)\n    82→\trequire.NoError(t, err)\n    83→\tassert.Equal(t, \"success\", result)\n    84→\n    85→\t// Check output was written\n    86→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n    87→\trequire.NoError(t, err)\n    88→\tassert.Contains(t, string(data), \"hello\")\n    89→}\n    90→\n    91→func TestExecutor_ScriptStep_Failure(t *testing.T) {\n    92→\ttmpDir := t.TempDir()\n    93→\toutputDir := filepath.Join(tmpDir, \"output\")\n    94→\n    95→\texecutor := &Executor{\n    96→\t\tProjectDir: tmpDir,\n    97→\t\tOutputDir:  outputDir,\n    98→\t}\n    99→\n   100→\tstep := &domain.Step{\n   101→\t\tName:    \"bad\",\n   102→\t\tType:    domain.StepTypeScript,\n   103→\t\tResults: []string{\"success\", \"fail\"},\n   104→\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   105→\t}\n   106→\n   107→\tresult, err := executor.Execute(context.Background(), step)\n   108→\trequire.NoError(t, err)\n   109→\tassert.Equal(t, \"fail\", result)\n   110→}\n   111→\n   112→func TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n   113→\ttmpDir := t.TempDir()\n   114→\toutputDir := filepath.Join(tmpDir, \"output\")\n   115→\n   116→\texecutor := &Executor{\n   117→\t\tProjectDir: tmpDir,\n   118→\t\tOutputDir:  outputDir,\n   119→\t}\n   120→\n   121→\tstep := &domain.Step{\n   122→\t\tName:    \"marker\",\n   123→\t\tType:    domain.StepTypeScript,\n   124→\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n   125→\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n   126→\t}\n   127→\n   128→\tresult, err := executor.Execute(context.Background(), step)\n   129→\trequire.NoError(t, err)\n   130→\tassert.Equal(t, \"custom\", result)\n   131→\n   132→\t// Marker line should be stripped from output\n   133→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n   134→\trequire.NoError(t, err)\n   135→\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n   136→\tassert.Contains(t, string(data), \"some output\")\n   137→}\n   138→\n   139→func TestExecutor_WorkflowStep_Success(t *testing.T) {\n   140→\ttmpDir := t.TempDir()\n   141→\toutputDir := filepath.Join(tmpDir, \"output\")\n   142→\t_ = os.MkdirAll(outputDir, 0755)\n   143→\n   144→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   145→\t\t\"develop-test-run\": {\n   146→\t\t\tID:    \"develop-test-run\",\n   147→\t\t\tState: domain.RunStateSucceeded,\n   148→\t\t},\n   149→\t}}\n   150→\n   151→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   152→\n   153→\texecutor := &Executor{\n   154→\t\tProjectDir: tmpDir,\n   155→\t\tDispatcher: dispatcher,\n   156→\t\tStore:      store,\n   157→\t\tOutputDir:  outputDir,\n   158→\t}\n   159→\n   160→\tstep := &domain.Step{\n   161→\t\tName:    \"develop\",\n   162→\t\tType:    domain.StepTypeWorkflow,\n   163→\t\tResults: []string{\"success\", \"fail\"},\n   164→\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   165→\t}\n   166→\n   167→\tresult, err := executor.Execute(context.Background(), step)\n   168→\trequire.NoError(t, err)\n   169→\tassert.Equal(t, \"success\", result)\n   170→\tassert.Len(t, dispatcher.calls, 1)\n   171→\tassert.Equal(t, \"develop\", dispatcher.calls[0].WorkflowName)\n   172→\tassert.Equal(t, tmpDir, dispatcher.calls[0].ProjectDir)\n   173→}\n   174→\n   175→func TestExecutor_WorkflowStep_Failure(t *testing.T) {\n   176→\ttmpDir := t.TempDir()\n   177→\toutputDir := filepath.Join(tmpDir, \"output\")\n   178→\t_ = os.MkdirAll(outputDir, 0755)\n   179→\n   180→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   181→\t\t\"develop-test-run\": {\n   182→\t\t\tID:    \"develop-test-run\",\n   183→\t\t\tState: domain.RunStateFailed,\n   184→\t\t},\n   185→\t}}\n   186→\n   187→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   188→\n   189→\texecutor := &Executor{\n   190→\t\tProjectDir: tmpDir,\n   191→\t\tDispatcher: dispatcher,\n   192→\t\tStore:      store,\n   193→\t\tOutputDir:  outputDir,\n   194→\t}\n   195→\n   196→\tstep := &domain.Step{\n   197→\t\tName:    \"develop\",\n   198→\t\tType:    domain.StepTypeWorkflow,\n   199→\t\tResults: []string{\"success\", \"fail\"},\n   200→\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   201→\t}\n   202→\n   203→\tresult, err := executor.Execute(context.Background(), step)\n   204→\trequire.NoError(t, err)\n   205→\tassert.Equal(t, \"fail\", result)\n   206→}\n   207→\n   208→func TestExecutor_WorkflowStep_PassesPrompt(t *testing.T) {\n   209→\ttmpDir := t.TempDir()\n   210→\toutputDir := filepath.Join(tmpDir, \"output\")\n   211→\t_ = os.MkdirAll(outputDir, 0755)\n   212→\n   213→\t// Write a previous step's output\n   214→\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n   215→\n   216→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   217→\t\t\"develop-test-run\": {\n   218→\t\t\tID:    \"develop-test-run\",\n   219→\t\t\tState: domain.RunStateSucceeded,\n   220→\t\t},\n   221→\t}}\n   222→\n   223→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   224→\n   225→\texecutor := &Executor{\n   226→\t\tProjectDir: tmpDir,\n   227→\t\tDispatcher: dispatcher,\n   228→\t\tStore:      store,\n   229→\t\tOutputDir:  outputDir,\n   230→\t}\n   231→\n   232→\tstep := &domain.Step{\n   233→\t\tName:    \"develop\",\n   234→\t\tType:    domain.StepTypeWorkflow,\n   235→\t\tResults: []string{\"success\", \"fail\"},\n   236→\t\tConfig: map[string]string{\n   237→\t\t\t\"workflow_name\": \"develop\",\n   238→\t\t\t\"prompt_step\":   \"prepare-prompt\",\n   239→\t\t},\n   240→\t}\n   241→\n   242→\tresult, err := executor.Execute(context.Background(), step)\n   243→\trequire.NoError(t, err)\n   244→\tassert.Equal(t, \"success\", result)\n   245→\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n   246→}\n   247→\n   248→func TestEngine_HostWorkflow_Linear(t *testing.T) {\n   249→\ttmpDir := t.TempDir()\n   250→\toutputDir := filepath.Join(tmpDir, \"output\")\n   251→\n   252→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   253→\t\t\"develop-test-run\": {\n   254→\t\t\tID:    \"develop-test-run\",\n   255→\t\t\tState: domain.RunStateSucceeded,\n   256→\t\t},\n   257→\t}}\n   258→\n   259→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   260→\n   261→\texecutor := &Executor{\n   262→\t\tProjectDir: tmpDir,\n   263→\t\tDispatcher: dispatcher,\n   264→\t\tStore:      store,\n   265→\t\tOutputDir:  outputDir,\n   266→\t}\n   267→\n   268→\twf := &domain.Workflow{\n   269→\t\tName: \"main\",\n   270→\t\tSteps: map[string]*domain.Step{\n   271→\t\t\t\"prepare\": {\n   272→\t\t\t\tName:    \"prepare\",\n   273→\t\t\t\tType:    domain.StepTypeScript,\n   274→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   275→\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n   276→\t\t\t},\n   277→\t\t\t\"develop\": {\n   278→\t\t\t\tName:    \"develop\",\n   279→\t\t\t\tType:    domain.StepTypeWorkflow,\n   280→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   281→\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   282→\t\t\t},\n   283→\t\t\t\"merge\": {\n   284→\t\t\t\tName:    \"merge\",\n   285→\t\t\t\tType:    domain.StepTypeScript,\n   286→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   287→\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n   288→\t\t\t},\n   289→\t\t},\n   290→\t\tWiring: []domain.Wire{\n   291→\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   292→\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   293→\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n   294→\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   295→\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n   296→\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n   297→\t\t},\n   298→\t\tEntryStep: \"prepare\",\n   299→\t}\n   300→\n   301→\teng := engine.New(executor)\n   302→\trun, err := eng.Run(context.Background(), wf)\n   303→\trequire.NoError(t, err)\n   304→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   305→\tassert.Len(t, dispatcher.calls, 1)\n   306→}\n   307→\n   308→func TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n   309→\ttmpDir := t.TempDir()\n   310→\toutputDir := filepath.Join(tmpDir, \"output\")\n   311→\n   312→\texecutor := &Executor{\n   313→\t\tProjectDir: tmpDir,\n   314→\t\tOutputDir:  outputDir,\n   315→\t}\n   316→\n   317→\twf := &domain.Workflow{\n   318→\t\tName: \"main\",\n   319→\t\tSteps: map[string]*domain.Step{\n   320→\t\t\t\"prepare\": {\n   321→\t\t\t\tName:    \"prepare\",\n   322→\t\t\t\tType:    domain.StepTypeScript,\n   323→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   324→\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   325→\t\t\t},\n   326→\t\t\t\"develop\": {\n   327→\t\t\t\tName:    \"develop\",\n   328→\t\t\t\tType:    domain.StepTypeWorkflow,\n   329→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   330→\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   331→\t\t\t},\n   332→\t\t},\n   333→\t\tWiring: []domain.Wire{\n   334→\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   335→\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   336→\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n   337→\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   338→\t\t},\n   339→\t\tEntryStep: \"prepare\",\n   340→\t}\n   341→\n   342→\teng := engine.New(executor)\n   343→\trun, err := eng.Run(context.Background(), wf)\n   344→\trequire.NoError(t, err)\n   345→\tassert.Equal(t, domain.RunStateFailed, run.State)\n   346→}\n   347→\n   348→func TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n   349→\ttmpDir := t.TempDir()\n   350→\toutputDir := filepath.Join(tmpDir, \"output\")\n   351→\n   352→\texecutor := &Executor{\n   353→\t\tProjectDir: tmpDir,\n   354→\t\tOutputDir:  outputDir,\n   355→\t}\n   356→\n   357→\tstep := &domain.Step{\n   358→\t\tName:    \"env-check\",\n   359→\t\tType:    domain.StepTypeScript,\n   360→\t\tResults: []string{\"success\", \"fail\"},\n   361→\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n   362→\t}\n   363→\n   364→\tresult, err := executor.Execute(context.Background(), step)\n   365→\trequire.NoError(t, err)\n   366→\tassert.Equal(t, \"success\", result)\n   367→\n   368→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n   369→\trequire.NoError(t, err)\n   370→\tassert.Contains(t, string(data), tmpDir)\n   371→}\n   372→"}]},"parent_tool_use_id":null,"session_id":"bc0d6504-f99d-4d8f-a0a8-090dcdb6a5d4","uuid":"a6fe4c8b-ae5b-4a6f-b9b1-e416d6059c5c","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor_test.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// fakeDispatcher records dispatch calls and returns a predetermined run ID.\ntype fakeDispatcher struct {\n\tcalls     []*pb.RunWorkflowRequest\n\trunID     string\n\treturnErr error\n}\n\nfunc (f *fakeDispatcher) RunWorkflow(_ context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tf.calls = append(f.calls, req)\n\tif f.returnErr != nil {\n\t\treturn nil, f.returnErr\n\t}\n\treturn &pb.RunWorkflowResponse{RunId: f.runID}, nil\n}\n\n// fakeStore returns a predetermined run on GetRun.\ntype fakeStore struct {\n\truns map[string]*domain.Run\n}\n\nfunc (f *fakeStore) CreateRun(_ context.Context, run *domain.Run) error {\n\tf.runs[run.ID] = run\n\treturn nil\n}\nfunc (f *fakeStore) GetRun(_ context.Context, id string) (*domain.Run, error) {\n\tif r, ok := f.runs[id]; ok {\n\t\treturn r, nil\n\t}\n\treturn nil, os.ErrNotExist\n}\nfunc (f *fakeStore) UpdateRun(_ context.Context, run *domain.Run) error {\n\tf.runs[run.ID] = run\n\treturn nil\n}\nfunc (f *fakeStore) DeleteRun(_ context.Context, id string) error {\n\tdelete(f.runs, id)\n\treturn nil\n}\nfunc (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n\treturn nil, nil\n}\n\nfunc TestExecutor_ScriptStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"greet\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Check output was written\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"hello\")\n}\n\nfunc TestExecutor_ScriptStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"bad\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"marker\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"custom\", result)\n\n\t// Marker line should be stripped from output\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n\trequire.NoError(t, err)\n\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n\tassert.Contains(t, string(data), \"some output\")\n}\n\nfunc TestExecutor_WorkflowStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\tassert.Len(t, dispatcher.calls, 1)\n\tassert.Equal(t, \"develop\", dispatcher.calls[0].WorkflowName)\n\tassert.Equal(t, tmpDir, dispatcher.calls[0].ProjectDir)\n}\n\nfunc TestExecutor_WorkflowStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateFailed,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_WorkflowStep_PassesPrompt(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\t// Write a previous step's output\n\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"workflow_name\": \"develop\",\n\t\t\t\"prompt_step\":   \"prepare-prompt\",\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n}\n\nfunc TestEngine_HostWorkflow_Linear(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n\t\t\t},\n\t\t\t\"develop\": {\n\t\t\t\tName:    \"develop\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t\t\"merge\": {\n\t\t\t\tName:    \"merge\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\tassert.Len(t, dispatcher.calls, 1)\n}\n\nfunc TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n\t\t\t},\n\t\t\t\"develop\": {\n\t\t\t\tName:    \"develop\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n}\n\nfunc TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"env-check\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), tmpDir)\n}\n","numLines":372,"startLine":1,"totalLines":372}}}
