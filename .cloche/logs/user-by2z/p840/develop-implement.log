{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018DibykHkfFE3nh1DnK9vic","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n     3→\n     4→<div class=\"run-history\" style=\"margin-bottom:1rem\">\n     5→    {{range .RecentRuns}}\n     6→    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n     7→    {{end}}\n     8→    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n     9→    {{if .ContainerCount}}\n    10→    <button class=\"btn btn-danger btn-sm\" id=\"delete-containers-btn\" onclick=\"deleteAllContainers()\" style=\"margin-left:0.5rem\">Delete {{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}</button>\n    11→    {{end}}\n    12→</div>\n    13→\n    14→<!-- Panel 1: Project Info -->\n    15→<div class=\"panel\" id=\"info-panel\">\n    16→    <div class=\"panel-header\">Project Info</div>\n    17→    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n    18→</div>\n    19→\n    20→<!-- Panel 3: Workflow View -->\n    21→<div class=\"panel\" id=\"workflow-panel\">\n    22→    <div class=\"panel-header\">Workflows</div>\n    23→    <div class=\"panel-body\">\n    24→        <div id=\"location-tabs\" class=\"tab-bar\"></div>\n    25→        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n    26→        <div id=\"workflow-dag\"></div>\n    27→    </div>\n    28→</div>\n    29→\n    30→<!-- Step Drawer -->\n    31→<div class=\"drawer\" id=\"step-drawer\">\n    32→    <div class=\"drawer-header\">\n    33→        <span id=\"drawer-title\"></span>\n    34→        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    35→    </div>\n    36→    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n    37→</div>\n    38→{{end}}\n    39→\n    40→{{define \"scripts\"}}\n    41→<script>\n    42→var projectLabel = {{.Label}};\n    43→\n    44→function loadProjectInfo() {\n    45→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n    46→        .then(function(r) { return r.json(); })\n    47→        .then(function(data) {\n    48→            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n    49→            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n    50→            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n    51→            html += '</dl>';\n    52→\n    53→            if (data.prompt_files && data.prompt_files.length > 0) {\n    54→                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n    55→                data.prompt_files.forEach(function(pf) {\n    56→                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n    57→                    if (pf.history && pf.history.length > 0) {\n    58→                        html += '<div style=\"margin:0.5rem 0\">';\n    59→                        pf.history.forEach(function(h) {\n    60→                            html += '<div class=\"prompt-commit\" data-file=\"' + pf.path + '\" data-sha=\"' + h.sha + '\" onclick=\"toggleDiff(this)\" style=\"cursor:pointer;padding:0.25rem 0;font-size:0.85rem\">';\n    61→                            html += '<span class=\"mono\" style=\"color:var(--link)\">' + h.sha + '</span> ';\n    62→                            html += '<span style=\"color:var(--text-muted)\">' + h.date + '</span> ';\n    63→                            html += h.message;\n    64→                            html += '</div>';\n    65→                        });\n    66→                        html += '</div>';\n    67→                    } else {\n    68→                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">No history</p>';\n    69→                    }\n    70→                    html += '</details>';\n    71→                });\n    72→            }\n    73→\n    74→            document.getElementById('project-info').innerHTML = html;\n    75→        });\n    76→}\n    77→\n    78→function toggleDiff(el) {\n    79→    var existing = el.nextElementSibling;\n    80→    if (existing && existing.classList.contains('diff-block')) {\n    81→        existing.remove();\n    82→        return;\n    83→    }\n    84→    var file = el.getAttribute('data-file');\n    85→    var sha = el.getAttribute('data-sha');\n    86→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n    87→        .then(function(r) { return r.text(); })\n    88→        .then(function(text) {\n    89→            var pre = document.createElement('pre');\n    90→            pre.className = 'diff-block';\n    91→            pre.textContent = text || '(no diff available)';\n    92→            el.parentNode.insertBefore(pre, el.nextSibling);\n    93→        });\n    94→}\n    95→\n    96→var workflowsData = [];\n    97→var activeLocation = 'container';\n    98→\n    99→function loadWorkflows() {\n   100→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n   101→        .then(function(r) { return r.json(); })\n   102→        .then(function(data) {\n   103→            workflowsData = data || [];\n   104→            if (workflowsData.length === 0) {\n   105→                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n   106→                return;\n   107→            }\n   108→\n   109→            // Check which locations exist\n   110→            var hasContainer = workflowsData.some(function(wf) { return wf.location === 'container'; });\n   111→            var hasHost = workflowsData.some(function(wf) { return wf.location === 'host'; });\n   112→\n   113→            // Render location tabs if both types exist\n   114→            var locationTabs = document.getElementById('location-tabs');\n   115→            if (hasContainer && hasHost) {\n   116→                var html = '';\n   117→                html += '<button class=\"tab-btn tab-active\" onclick=\"switchLocation(\\'container\\')\">Container</button>';\n   118→                html += '<button class=\"tab-btn\" onclick=\"switchLocation(\\'host\\')\">Host</button>';\n   119→                locationTabs.innerHTML = html;\n   120→            } else {\n   121→                locationTabs.innerHTML = '';\n   122→            }\n   123→\n   124→            // Default to whichever location exists\n   125→            activeLocation = hasContainer ? 'container' : 'host';\n   126→            renderWorkflowTabs();\n   127→        });\n   128→}\n   129→\n   130→function switchLocation(loc) {\n   131→    activeLocation = loc;\n   132→    var btns = document.querySelectorAll('#location-tabs .tab-btn');\n   133→    btns.forEach(function(b) {\n   134→        b.classList.toggle('tab-active', b.textContent === (loc === 'container' ? 'Container' : 'Host'));\n   135→    });\n   136→    renderWorkflowTabs();\n   137→}\n   138→\n   139→function renderWorkflowTabs() {\n   140→    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n   141→    var tabs = document.getElementById('workflow-tabs');\n   142→\n   143→    if (filtered.length === 0) {\n   144→        tabs.innerHTML = '';\n   145→        document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No ' + activeLocation + ' workflows found</p>';\n   146→        return;\n   147→    }\n   148→\n   149→    if (filtered.length > 1) {\n   150→        var html = '';\n   151→        filtered.forEach(function(wf, i) {\n   152→            html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showFilteredWorkflow(' + i + ')\">' + wf.name + '</button>';\n   153→        });\n   154→        tabs.innerHTML = html;\n   155→    } else {\n   156→        tabs.innerHTML = '';\n   157→    }\n   158→    showFilteredWorkflow(0);\n   159→}\n   160→\n   161→function showFilteredWorkflow(idx) {\n   162→    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n   163→    var btns = document.querySelectorAll('#workflow-tabs .tab-btn');\n   164→    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n   165→    showWorkflow(filtered[idx]);\n   166→}\n   167→\n   168→function showWorkflow(wf) {\n   169→    var dagEl = document.getElementById('workflow-dag');\n   170→\n   171→    // Build step order via topological sort from entry\n   172→    var ordered = [];\n   173→    var visited = {};\n   174→    function visit(name) {\n   175→        if (visited[name] || name === 'done' || name === 'abort') return;\n   176→        visited[name] = true;\n   177→        ordered.push(name);\n   178→        wf.wires.forEach(function(wire) {\n   179→            if (wire.from === name) visit(wire.to);\n   180→        });\n   181→    }\n   182→    if (wf.entry_step) visit(wf.entry_step);\n   183→    // Add any unvisited steps\n   184→    wf.steps.forEach(function(s) { if (!visited[s.name]) { ordered.push(s.name); visited[s.name] = true; } });\n   185→\n   186→    // Collect terminal targets\n   187→    var terminals = {};\n   188→    wf.wires.forEach(function(wire) {\n   189→        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n   190→    });\n   191→\n   192→    var stepMap = {};\n   193→    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n   194→\n   195→    var nodeH = 48, nodeW = 180, gapY = 24, gapX = 40, padTop = 20, padLeft = 30;\n   196→\n   197→    // Assign positions\n   198→    var positions = {};\n   199→    ordered.forEach(function(name, i) {\n   200→        positions[name] = {x: padLeft, y: padTop + i * (nodeH + gapY)};\n   201→    });\n   202→    var termIdx = ordered.length;\n   203→    for (var t in terminals) {\n   204→        positions[t] = {x: padLeft, y: padTop + termIdx * (nodeH + gapY)};\n   205→        termIdx++;\n   206→    }\n   207→\n   208→    var totalH = padTop + termIdx * (nodeH + gapY) + 10;\n   209→    var totalW = padLeft + nodeW + gapX + 80;\n   210→\n   211→    var html = '<svg class=\"dag-svg\" width=\"' + totalW + '\" height=\"' + totalH + '\">';\n   212→    html += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n   213→\n   214→    // Draw wires\n   215→    wf.wires.forEach(function(wire) {\n   216→        var from = positions[wire.from];\n   217→        var to = positions[wire.to];\n   218→        if (!from || !to) return;\n   219→        var x1 = from.x + nodeW;\n   220→        var y1 = from.y + nodeH / 2;\n   221→        var x2 = to.x;\n   222→        var y2 = to.y + nodeH / 2;\n   223→        var cx = x1 + gapX / 2;\n   224→        html += '<path d=\"M' + x1 + ' ' + y1 + ' C' + cx + ' ' + y1 + ' ' + cx + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n   225→        var lx = (x1 + x2) / 2, ly = (y1 + y2) / 2 - 6;\n   226→        html += '<text x=\"' + lx + '\" y=\"' + ly + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n   227→    });\n   228→\n   229→    // Draw step nodes\n   230→    ordered.forEach(function(name) {\n   231→        var pos = positions[name];\n   232→        var s = stepMap[name];\n   233→        var icon = '\\u{1F4DC}';\n   234→        if (s) {\n   235→            if (s.type === 'agent') icon = '\\u{1F916}';\n   236→            else if (s.type === 'workflow') icon = '\\u{1F501}';\n   237→        }\n   238→        html += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + name + '\\')\" style=\"cursor:pointer\">';\n   239→        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n   240→        html += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + name + '</text>';\n   241→        html += '</g>';\n   242→    });\n   243→\n   244→    // Draw terminal nodes\n   245→    for (var t in terminals) {\n   246→        var pos = positions[t];\n   247→        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n   248→        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n   249→        html += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n   250→    }\n   251→\n   252→    html += '</svg>';\n   253→    dagEl.innerHTML = html;\n   254→}\n   255→\n   256→function openDrawer(workflowName, stepName) {\n   257→    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n   258→    if (!wf) return;\n   259→    var step = wf.steps.find(function(s) { return s.name === stepName; });\n   260→    if (!step) return;\n   261→\n   262→    document.getElementById('drawer-title').textContent = stepName;\n   263→    var body = '<dl class=\"run-meta\">';\n   264→    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n   265→    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n   266→    if (step.config) {\n   267→        for (var k in step.config) {\n   268→            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script' || k === 'run' || k === 'workflow_name') {\n   269→                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n   270→            }\n   271→        }\n   272→    }\n   273→    body += '</dl>';\n   274→    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n   275→\n   276→    document.getElementById('drawer-body').innerHTML = body;\n   277→    document.getElementById('step-drawer').classList.add('drawer-open');\n   278→\n   279→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n   280→        .then(function(r) { if (r.ok) return r.text(); return ''; })\n   281→        .then(function(text) {\n   282→            var el = document.getElementById('drawer-content');\n   283→            if (text) {\n   284→                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n   285→            } else {\n   286→                el.innerHTML = '<p style=\"color:var(--text-muted)\">No content available</p>';\n   287→            }\n   288→        });\n   289→}\n   290→\n   291→function closeDrawer() {\n   292→    document.getElementById('step-drawer').classList.remove('drawer-open');\n   293→}\n   294→\n   295→document.addEventListener('keydown', function(e) {\n   296→    if (e.key === 'Escape') closeDrawer();\n   297→});\n   298→\n   299→window.deleteAllContainers = function() {\n   300→    var btn = document.getElementById('delete-containers-btn');\n   301→    if (btn) btn.disabled = true;\n   302→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/containers', { method: 'DELETE' })\n   303→        .then(function(r) { return r.json(); })\n   304→        .then(function(data) {\n   305→            if (btn) {\n   306→                btn.textContent = 'Deleted ' + (data.deleted || 0) + ' container' + (data.deleted !== 1 ? 's' : '');\n   307→                btn.classList.remove('btn-danger');\n   308→                btn.classList.add('btn-secondary');\n   309→            }\n   310→        })\n   311→        .catch(function() {\n   312→            if (btn) {\n   313→                btn.textContent = 'Delete failed';\n   314→                btn.disabled = false;\n   315→            }\n   316→        });\n   317→};\n   318→\n   319→// Load all panels\n   320→loadProjectInfo();\n   321→loadWorkflows();\n   322→</script>\n   323→{{end}}\n   324→"}]},"parent_tool_use_id":null,"session_id":"375d7957-8c54-424f-9ca1-8e8227d8c94d","uuid":"6dee76c9-e904-4d65-914a-30d44cdde0bd","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/project_detail.html","content":"{{define \"content\"}}\n<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n\n<div class=\"run-history\" style=\"margin-bottom:1rem\">\n    {{range .RecentRuns}}\n    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n    {{end}}\n    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n    {{if .ContainerCount}}\n    <button class=\"btn btn-danger btn-sm\" id=\"delete-containers-btn\" onclick=\"deleteAllContainers()\" style=\"margin-left:0.5rem\">Delete {{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}</button>\n    {{end}}\n</div>\n\n<!-- Panel 1: Project Info -->\n<div class=\"panel\" id=\"info-panel\">\n    <div class=\"panel-header\">Project Info</div>\n    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n</div>\n\n<!-- Panel 3: Workflow View -->\n<div class=\"panel\" id=\"workflow-panel\">\n    <div class=\"panel-header\">Workflows</div>\n    <div class=\"panel-body\">\n        <div id=\"location-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-dag\"></div>\n    </div>\n</div>\n\n<!-- Step Drawer -->\n<div class=\"drawer\" id=\"step-drawer\">\n    <div class=\"drawer-header\">\n        <span id=\"drawer-title\"></span>\n        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    </div>\n    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n</div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\nvar projectLabel = {{.Label}};\n\nfunction loadProjectInfo() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n            html += '</dl>';\n\n            if (data.prompt_files && data.prompt_files.length > 0) {\n                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n                data.prompt_files.forEach(function(pf) {\n                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n                    if (pf.history && pf.history.length > 0) {\n                        html += '<div style=\"margin:0.5rem 0\">';\n                        pf.history.forEach(function(h) {\n                            html += '<div class=\"prompt-commit\" data-file=\"' + pf.path + '\" data-sha=\"' + h.sha + '\" onclick=\"toggleDiff(this)\" style=\"cursor:pointer;padding:0.25rem 0;font-size:0.85rem\">';\n                            html += '<span class=\"mono\" style=\"color:var(--link)\">' + h.sha + '</span> ';\n                            html += '<span style=\"color:var(--text-muted)\">' + h.date + '</span> ';\n                            html += h.message;\n                            html += '</div>';\n                        });\n                        html += '</div>';\n                    } else {\n                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">No history</p>';\n                    }\n                    html += '</details>';\n                });\n            }\n\n            document.getElementById('project-info').innerHTML = html;\n        });\n}\n\nfunction toggleDiff(el) {\n    var existing = el.nextElementSibling;\n    if (existing && existing.classList.contains('diff-block')) {\n        existing.remove();\n        return;\n    }\n    var file = el.getAttribute('data-file');\n    var sha = el.getAttribute('data-sha');\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n        .then(function(r) { return r.text(); })\n        .then(function(text) {\n            var pre = document.createElement('pre');\n            pre.className = 'diff-block';\n            pre.textContent = text || '(no diff available)';\n            el.parentNode.insertBefore(pre, el.nextSibling);\n        });\n}\n\nvar workflowsData = [];\nvar activeLocation = 'container';\n\nfunction loadWorkflows() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            workflowsData = data || [];\n            if (workflowsData.length === 0) {\n                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n                return;\n            }\n\n            // Check which locations exist\n            var hasContainer = workflowsData.some(function(wf) { return wf.location === 'container'; });\n            var hasHost = workflowsData.some(function(wf) { return wf.location === 'host'; });\n\n            // Render location tabs if both types exist\n            var locationTabs = document.getElementById('location-tabs');\n            if (hasContainer && hasHost) {\n                var html = '';\n                html += '<button class=\"tab-btn tab-active\" onclick=\"switchLocation(\\'container\\')\">Container</button>';\n                html += '<button class=\"tab-btn\" onclick=\"switchLocation(\\'host\\')\">Host</button>';\n                locationTabs.innerHTML = html;\n            } else {\n                locationTabs.innerHTML = '';\n            }\n\n            // Default to whichever location exists\n            activeLocation = hasContainer ? 'container' : 'host';\n            renderWorkflowTabs();\n        });\n}\n\nfunction switchLocation(loc) {\n    activeLocation = loc;\n    var btns = document.querySelectorAll('#location-tabs .tab-btn');\n    btns.forEach(function(b) {\n        b.classList.toggle('tab-active', b.textContent === (loc === 'container' ? 'Container' : 'Host'));\n    });\n    renderWorkflowTabs();\n}\n\nfunction renderWorkflowTabs() {\n    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n    var tabs = document.getElementById('workflow-tabs');\n\n    if (filtered.length === 0) {\n        tabs.innerHTML = '';\n        document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No ' + activeLocation + ' workflows found</p>';\n        return;\n    }\n\n    if (filtered.length > 1) {\n        var html = '';\n        filtered.forEach(function(wf, i) {\n            html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showFilteredWorkflow(' + i + ')\">' + wf.name + '</button>';\n        });\n        tabs.innerHTML = html;\n    } else {\n        tabs.innerHTML = '';\n    }\n    showFilteredWorkflow(0);\n}\n\nfunction showFilteredWorkflow(idx) {\n    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n    var btns = document.querySelectorAll('#workflow-tabs .tab-btn');\n    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n    showWorkflow(filtered[idx]);\n}\n\nfunction showWorkflow(wf) {\n    var dagEl = document.getElementById('workflow-dag');\n\n    // Build step order via topological sort from entry\n    var ordered = [];\n    var visited = {};\n    function visit(name) {\n        if (visited[name] || name === 'done' || name === 'abort') return;\n        visited[name] = true;\n        ordered.push(name);\n        wf.wires.forEach(function(wire) {\n            if (wire.from === name) visit(wire.to);\n        });\n    }\n    if (wf.entry_step) visit(wf.entry_step);\n    // Add any unvisited steps\n    wf.steps.forEach(function(s) { if (!visited[s.name]) { ordered.push(s.name); visited[s.name] = true; } });\n\n    // Collect terminal targets\n    var terminals = {};\n    wf.wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n    });\n\n    var stepMap = {};\n    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n\n    var nodeH = 48, nodeW = 180, gapY = 24, gapX = 40, padTop = 20, padLeft = 30;\n\n    // Assign positions\n    var positions = {};\n    ordered.forEach(function(name, i) {\n        positions[name] = {x: padLeft, y: padTop + i * (nodeH + gapY)};\n    });\n    var termIdx = ordered.length;\n    for (var t in terminals) {\n        positions[t] = {x: padLeft, y: padTop + termIdx * (nodeH + gapY)};\n        termIdx++;\n    }\n\n    var totalH = padTop + termIdx * (nodeH + gapY) + 10;\n    var totalW = padLeft + nodeW + gapX + 80;\n\n    var html = '<svg class=\"dag-svg\" width=\"' + totalW + '\" height=\"' + totalH + '\">';\n    html += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n\n    // Draw wires\n    wf.wires.forEach(function(wire) {\n        var from = positions[wire.from];\n        var to = positions[wire.to];\n        if (!from || !to) return;\n        var x1 = from.x + nodeW;\n        var y1 = from.y + nodeH / 2;\n        var x2 = to.x;\n        var y2 = to.y + nodeH / 2;\n        var cx = x1 + gapX / 2;\n        html += '<path d=\"M' + x1 + ' ' + y1 + ' C' + cx + ' ' + y1 + ' ' + cx + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n        var lx = (x1 + x2) / 2, ly = (y1 + y2) / 2 - 6;\n        html += '<text x=\"' + lx + '\" y=\"' + ly + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n    });\n\n    // Draw step nodes\n    ordered.forEach(function(name) {\n        var pos = positions[name];\n        var s = stepMap[name];\n        var icon = '\\u{1F4DC}';\n        if (s) {\n            if (s.type === 'agent') icon = '\\u{1F916}';\n            else if (s.type === 'workflow') icon = '\\u{1F501}';\n        }\n        html += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + name + '\\')\" style=\"cursor:pointer\">';\n        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n        html += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + name + '</text>';\n        html += '</g>';\n    });\n\n    // Draw terminal nodes\n    for (var t in terminals) {\n        var pos = positions[t];\n        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n        html += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n    }\n\n    html += '</svg>';\n    dagEl.innerHTML = html;\n}\n\nfunction openDrawer(workflowName, stepName) {\n    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n    if (!wf) return;\n    var step = wf.steps.find(function(s) { return s.name === stepName; });\n    if (!step) return;\n\n    document.getElementById('drawer-title').textContent = stepName;\n    var body = '<dl class=\"run-meta\">';\n    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n    if (step.config) {\n        for (var k in step.config) {\n            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script' || k === 'run' || k === 'workflow_name') {\n                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n            }\n        }\n    }\n    body += '</dl>';\n    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n\n    document.getElementById('drawer-body').innerHTML = body;\n    document.getElementById('step-drawer').classList.add('drawer-open');\n\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n        .then(function(r) { if (r.ok) return r.text(); return ''; })\n        .then(function(text) {\n            var el = document.getElementById('drawer-content');\n            if (text) {\n                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n            } else {\n                el.innerHTML = '<p style=\"color:var(--text-muted)\">No content available</p>';\n            }\n        });\n}\n\nfunction closeDrawer() {\n    document.getElementById('step-drawer').classList.remove('drawer-open');\n}\n\ndocument.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') closeDrawer();\n});\n\nwindow.deleteAllContainers = function() {\n    var btn = document.getElementById('delete-containers-btn');\n    if (btn) btn.disabled = true;\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/containers', { method: 'DELETE' })\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            if (btn) {\n                btn.textContent = 'Deleted ' + (data.deleted || 0) + ' container' + (data.deleted !== 1 ? 's' : '');\n                btn.classList.remove('btn-danger');\n                btn.classList.add('btn-secondary');\n            }\n        })\n        .catch(function() {\n            if (btn) {\n                btn.textContent = 'Delete failed';\n                btn.disabled = false;\n            }\n        });\n};\n\n// Load all panels\nloadProjectInfo();\nloadWorkflows();\n</script>\n{{end}}\n","numLines":324,"startLine":1,"totalLines":324}}}
