\n  1264→\t\treturn\n  1265→\t}\n  1266→\n  1267→\t// Try to read the referenced file from step config\n  1268→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1269→\n  1270→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1271→\t\tcontent, err := resolveFileRef(prompt, dir)\n  1272→\t\tif err == nil {\n  1273→\t\t\tw.Write([]byte(content))\n  1274→\t\t\treturn\n  1275→\t\t}\n  1276→\t}\n  1277→\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n  1278→\t\tcontent, _ := resolveFileRef(cmd, dir)\n  1279→\t\tw.Write([]byte(content))\n  1280→\t\treturn\n  1281→\t}\n  1282→\tif script := step.Config[\"script\"]; script != \"\" {\n  1283→\t\tcontent, _ := resolveFileRef(script, dir)\n  1284→\t\tw.Write([]byte(content))\n  1285→\t\treturn\n  1286→\t}\n  1287→\tif run := step.Config[\"run\"]; run != \"\" {\n  1288→\t\tcontent, _ := resolveFileRef(run, dir)\n  1289→\t\tw.Write([]byte(content))\n  1290→\t\treturn\n  1291→\t}\n  1292→\tif wfName := step.Config[\"workflow_name\"]; wfName != \"\" {\n  1293→\t\tw.Write([]byte(\"Dispatches workflow: \" + wfName))\n  1294→\t\treturn\n  1295→\t}\n  1296→\n  1297→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1298→}\n  1299→\n  1300→// --- Template helpers ---\n  1301→\n  1302→// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n  1303→// If the value uses file() syntax, the referenced file is read from disk.\n  1304→// Otherwise the value is returned as-is.\n  1305→func resolveFileRef(value, baseDir string) (string, error) {\n  1306→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n  1307→\t\tpath := value[6 : len(value)-2]\n  1308→\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n  1309→\t\tif err != nil {\n  1310→\t\t\treturn \"\", err\n  1311→\t\t}\n  1312→\t\treturn string(data), nil\n  1313→\t}\n  1314→\treturn value, nil\n  1315→}\n  1316→\n  1317→func stateColor(state domain.RunState) string {\n  1318→\tswitch state {\n  1319→\tcase domain.RunStatePending:\n  1320→\t\treturn \"pending\"\n  1321→\tcase domain.RunStateRunning:\n  1322→\t\treturn \"running\"\n  1323→\tcase domain.RunStateSucceeded:\n  1324→\t\treturn \"succeeded\"\n  1325→\tcase domain.RunStateFailed:\n  1326→\t\treturn \"failed\"\n  1327→\tcase domain.RunStateCancelled:\n  1328→\t\treturn \"cancelled\"\n  1329→\tdefault:\n  1330→\t\treturn \"pending\"\n  1331→\t}\n  1332→}\n  1333→\n  1334→func healthColor(status domain.HealthStatus) string {\n  1335→\tswitch status {\n  1336→\tcase domain.HealthGreen:\n  1337→\t\treturn \"green\"\n  1338→\tcase domain.HealthYellow:\n  1339→\t\treturn \"yellow\"\n  1340→\tcase domain.HealthRed:\n  1341→\t\treturn \"red\"\n  1342→\tcase domain.HealthBlue:\n  1343→\t\treturn \"blue\"\n  1344→\tdefault:\n  1345→\t\treturn \"grey\"\n  1346→\t}\n  1347→}\n  1348→\n  1349→func formatTime(t time.Time) string {\n  1350→\tif t.IsZero() {\n  1351→\t\treturn \"\"\n  1352→\t}\n  1353→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1354→}\n  1355→\n  1356→func formatDuration(start, end time.Time) string {\n  1357→\tif start.IsZero() || end.IsZero() {\n  1358→\t\treturn \"\"\n  1359→\t}\n  1360→\td := end.Sub(start)\n  1361→\tif d < time.Second {\n  1362→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1363→\t}\n  1364→\tif d < time.Minute {\n  1365→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1366→\t}\n  1367→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1368→}\n  1369→\n  1370→// formatSmartDuration formats a duration into a human-friendly short string.\n  1371→// Examples: \"3s\", \"2m\", \"1h20m\", \"3h\".\n  1372→func formatSmartDuration(d time.Duration) string {\n  1373→\tif d < time.Minute {\n  1374→\t\treturn fmt.Sprintf(\"%ds\", int(d.Seconds()))\n  1375→\t}\n  1376→\th := int(d.Hours())\n  1377→\tm := int(d.Minutes()) % 60\n  1378→\tif h == 0 {\n  1379→\t\treturn fmt.Sprintf(\"%dm\", m)\n  1380→\t}\n  1381→\tif m == 0 {\n  1382→\t\treturn fmt.Sprintf(\"%dh\", h)\n  1383→\t}\n  1384→\treturn fmt.Sprintf(\"%dh%dm\", h, m)\n  1385→}\n  1386→\n  1387→// roundRelativeTime rounds a duration to neat display units:\n  1388→// <1m -> \"<1m ago\", then 1m,5m,10m,15m,30m,45m,1h,2h,3h,...24h,\n  1389→// then days.\n  1390→func roundRelativeTime(d time.Duration) string {\n  1391→\tif d < time.Minute {\n  1392→\t\treturn \"<1m ago\"\n  1393→\t}\n  1394→\tmins := int(d.Minutes())\n  1395→\thours := int(d.Hours())\n  1396→\tdays := hours / 24\n  1397→\n  1398→\tif days > 0 {\n  1399→\t\tif days == 1 {\n  1400→\t\t\treturn \"1 day ago\"\n  1401→\t\t}\n  1402→\t\treturn fmt.Sprintf(\"%d days ago\", days)\n  1403→\t}\n  1404→\tif hours >= 1 {\n  1405→\t\tif hours == 1 {\n  1406→\t\t\treturn \"1 hour ago\"\n  1407→\t\t}\n  1408→\t\treturn fmt.Sprintf(\"%d hours ago\", hours)\n  1409→\t}\n  1410→\t// Round minutes to neat breakpoints\n  1411→\tswitch {\n  1412→\tcase mins < 3:\n  1413→\t\treturn \"1m ago\"\n  1414→\tcase mins < 8:\n  1415→\t\treturn \"5m ago\"\n  1416→\tcase mins < 13:\n  1417→\t\treturn \"10m ago\"\n  1418→\tcase mins < 20:\n  1419→\t\treturn \"15m ago\"\n  1420→\tcase mins < 38:\n  1421→\t\treturn \"30m ago\"\n  1422→\tcase mins < 53:\n  1423→\t\treturn \"45m ago\"\n  1424→\tdefault:\n  1425→\t\treturn \"1 hour ago\"\n  1426→\t}\n  1427→}\n  1428→\n  1429→// formatRunTiming returns a smart timing string for display on the Runs page.\n  1430→// Running: \"5m\" (just duration so far)\n  1431→// Completed: \"20m, 1 hour ago\"\n  1432→// Pending: \"\"\n  1433→func formatRunTiming(state domain.RunState, startedAt, completedAt time.Time) string {\n  1434→\treturn formatRunTimingAt(state, startedAt, completedAt, time.Now())\n  1435→}\n  1436→\n  1437→// formatRunTimingAt is the testable version of formatRunTiming with an explicit \"now\".\n  1438→func formatRunTimingAt(state domain.RunState, startedAt, completedAt, now time.Time) string {\n  1439→\tif startedAt.IsZero() {\n  1440→\t\treturn \"\"\n  1441→\t}\n  1442→\tswitch state {\n  1443→\tcase domain.RunStateRunning:\n  1444→\t\td := now.Sub(startedAt)\n  1445→\t\treturn formatSmartDuration(d)\n  1446→\tdefault:\n  1447→\t\tif completedAt.IsZero() {\n  1448→\t\t\treturn \"\"\n  1449→\t\t}\n  1450→\t\td := completedAt.Sub(startedAt)\n  1451→\t\tago := now.Sub(completedAt)\n  1452→\t\treturn formatSmartDuration(d) + \", \" + roundRelativeTime(ago)\n  1453→\t}\n  1454→}\n  1455→\n  1456→func truncate(s string, n int) string {\n  1457→\tif len(s) <= n {\n  1458→\t\treturn s\n  1459→\t}\n  1460→\treturn s[:n] + \"...\"\n  1461→}\n  1462→\n  1463→func shortContainerID(id string) string {\n  1464→\tif len(id) > 12 {\n  1465→\t\treturn id[:12]\n  1466→\t}\n  1467→\treturn id\n  1468→}\n  1469→\n  1470→// projectLabels builds a mapping from full project directory paths to short\n  1471→// display labels. Each label is the final directory component (e.g.\n  1472→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1473→// the same final name, the parent directory is prepended to disambiguate\n  1474→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1475→func projectLabels(dirs []string) map[string]string {\n  1476→\tlabels := make(map[string]string, len(dirs))\n  1477→\t// Group dirs by their base name to detect conflicts.\n  1478→\tbyBase := map[string][]string{}\n  1479→\tfor _, d := range dirs {\n  1480→\t\tbase := filepath.Base(d)\n  1481→\t\tbyBase[base] = append(byBase[base], d)\n  1482→\t}\n  1483→\tfor base, paths := range byBase {\n  1484→\t\tif len(paths) == 1 {\n  1485→\t\t\tlabels[paths[0]] = base\n  1486→\t\t} else {\n  1487→\t\t\tfor _, p := range paths {\n  1488→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1489→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1490→\t\t\t}\n  1491→\t\t}\n  1492→\t}\n  1493→\treturn labels\n  1494→}\n  1495→\n  1496→type projectEntry struct {\n  1497→\tDir            string\n  1498→\tLabel          string\n  1499→\tContainerCount int"}]},"parent_tool_use_i