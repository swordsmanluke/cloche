open store: %v\\n\", err)\n    45→\t\tos.Exit(1)\n    46→\t}\n    47→\tdefer store.Close()\n    48→\n    49→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    50→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    51→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    52→\t} else if n > 0 {\n    53→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    54→\t}\n    55→\n    56→\truntime, err := initRuntime(globalCfg)\n    57→\tif err != nil {\n    58→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    59→\t\tos.Exit(1)\n    60→\t}\n    61→\n    62→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    63→\n    64→\tbroadcaster := logstream.NewBroadcaster()\n    65→\n    66→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    67→\tsrv.SetLogStore(store)\n    68→\tsrv.SetLogBroadcaster(broadcaster)\n    69→\n    70→\t// Set up evolution trigger\n    71→\tevoTrigger := initEvolution(globalCfg, store, store)\n    72→\tif evoTrigger != nil {\n    73→\t\tsrv.SetEvolution(evoTrigger)\n    74→\t}\n    75→\n    76→\t// Set up orchestrator\n    77→\torch := initOrchestrator(globalCfg, store, srv)\n    78→\tif orch != nil {\n    79→\t\tsrv.SetOnRunComplete(func(ctx context.Context, projectDir string, runID string, state domain.RunState) {\n    80→\t\t\torch.OnRunComplete(ctx, projectDir, runID, state)\n    81→\t\t})\n    82→\t\tsrv.SetOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n    83→\t\t\tif projectDir != \"\" {\n    84→\t\t\t\treturn orch.Run(ctx, projectDir)\n    85→\t\t\t}\n    86→\t\t\treturn orch.TriggerAll(ctx), nil\n    87→\t\t})\n    88→\t}\n    89→\n    90→\tgrpcServer := grpc.NewServer()\n    91→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    92→\n    93→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    94→\n    95→\tlis, err := listen(listenAddr)\n    96→\tif err != nil {\n    97→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    98→\t\tos.Exit(1)\n    99→\t}\n   100→\n   101→\tvar httpServer *http.Server\n   102→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n   103→\t\twebOpts := []web.HandlerOption{\n   104→\t\t\tweb.WithContainerLogger(runtime),\n   105→\t\t\tweb.WithLogStore(store),\n   106→\t\t\tweb.WithLogBroadcaster(broadcaster),\n   107→\t\t}\n   108→\t\tif orch != nil {\n   109→\t\t\twebOpts = append(webOpts, web.WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   110→\t\t\t\treturn orch.Run(ctx, projectDir)\n   111→\t\t\t}))\n   112→\t\t\twebOpts = append(webOpts, web.WithOrchestrator(orch))\n   113→\t\t}\n   114→\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n   115→\t\tif err != nil {\n   116→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n   117→\t\t\tos.Exit(1)\n   118→\t\t}\n   119→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n   120→\t\tgo func() {\n   121→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   122→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   123→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   124→\t\t\t}\n   125→\t\t}()\n   126→\t}\n   127→\n   128→\tsigCh := make(chan os.Signal, 1)\n   129→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   130→\tgo func() {\n   131→\t\t<-sigCh\n   132→\t\tif httpServer != nil {\n   133→\t\t\thttpServer.Close()\n   134→\t\t}\n   135→\t\tgrpcServer.GracefulStop()\n   136→\t}()\n   137→\n   138→\t// Trigger orchestration on startup\n   139→\tif orch != nil {\n   140→\t\tgo func() {\n   141→\t\t\tn := orch.TriggerAll(context.Background())\n   142→\t\t\tif n > 0 {\n   143→\t\t\t\tfmt.Fprin