class=\"mono\">' + cid + '</td>' +\n                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                        '</tr>';\n                }\n                tbody.innerHTML = html;\n            })\n            .catch(function() {});\n    }\n    function escapeHtml(s) {\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n    setInterval(poll, 3000);\n})();\n</script>\n{{end}}\n","structuredPatch":[{"oldStart":6,"oldLines":7,"newStart":6,"newLines":7,"lines":["     <select id=\"project-select\" onchange=\"filterByProject(this.value)\">","         <option value=\"\">All projects</option>","         {{range .Projects}}","-        <option value=\"{{.Dir}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>","+        <option value=\"{{.Label}}\"{{if eq .Label $.ProjectLabel}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>","         {{end}}","     </select>"," </div>"]},{"oldStart":48,"oldLines":11,"newStart":48,"newLines":11,"lines":[" {{define \"scripts\"}}"," <script>"," (function() {","-    var currentProject = '{{.ProjectFilter}}';","+    var currentProjectLabel = '{{.ProjectLabel}}';"," ","-    function filterByProject(dir) {","-        if (dir) {","-            window.location.href = '/runs?project=' + encodeURIComponent(dir);","+    function filterByProject(label) {","+        if (label) {","+            window.location.href = '/projects/' + encodeURIComponent(label) + '/runs';","         } else {","             window.location.href = '/runs';","         }"]},{"oldStart":61,"oldLines":8,"newStart":61,"newLines":8,"lines":[" ","     function poll() {","         var url = '/api/runs';","-        if (currentProject) {","-            url += '?project=' + encodeURIComponent(currentProject);","+        if (currentProjectLabel) {","+            url = '/api/projects/' + encodeURIComponent(currentProjectLabel) + '/runs';","         }","         fetch(url)","             .then(function(r) { return r.json(); })"]}],"originalFile":"{{define \"content\"}}\n<h1>Runs</h1>\n{{if .Projects}}\n<div class=\"project-filter\">\n    <label for=\"project-select\">Project:</label>\n    <select id=\"project-select\" onchange=\"filterByProject(this.value)\">\n        <option value=\"\">All projects</option>\n        {{range .Projects}}\n        <option value=\"{{.Dir}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>\n        {{end}}\n    </select>\n</div>\n{{end}}\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Run ID</th>\n            <th>Project</th>\n            <th>Workflow</th>\n            <th>State</th>\n            <th>Started</th>\n            <th>Completed</th>\n            <th>Container</th>\n            <th>Error</th>\n        </tr>\n    </thead>\n    <tbody id=\"runs-body\">\n    {{if .Runs}}\n        {{range .Runs}}\n        <tr>\n            <td><a href=\"/runs/{{.ID}}\">{{.ID}}</a></td>\n            <td>{{index $.ProjectLabels .ProjectDir}}</td>\n            <td>{{.WorkflowName}}</td>\n            <td><span class=\"badge badge-{{stateColor .State}}\">{{.State}}</span></td>\n            <td>{{formatTime .StartedAt}}</td>\n            <td>{{formatTime .CompletedAt}}</td>\n            <td class=\"mono\">{{shortContainerID .ContainerID}}</td>\n            <td class=\"error-cell\">{{truncate .ErrorMessage 80}}</td>\n        </tr>\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"8\" class=\"empty\">No runs yet.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var currentProject = '{{.ProjectFilter}}';\n\n    function filterByProject(dir) {\n        if (dir) {\n            window.location.href = '/runs?project=' + encodeURIComponent(dir);\n        } else {\n            window.location.href = '/runs';\n        }\n    }\n    window.filterByProject = filterByProject;\n\n    function poll() {\n        var url = '/api/runs';\n        if (currentProject) {\n            url += '?project=' + encodeURIComponent(currentProject);\n        }\n        fetch(url)\n            .then(function(r) { return r.json(); })\n            .then(function(runs) {\n                var tbody = document.getElementById('runs-body');\n                if (!runs || runs.length === 0) {\n                    tbody.innerHTML = '<tr><td colspan=\"8\" class=\"empty\">No runs yet.</td></tr>';\n                    return;\n                }\n                var html = '';\n                for (var i = 0; i < runs.length; i++) {\n                    var r = runs[i];\n                    var cid = r.container_id || '';\n                    if (cid.length > 12) cid = cid.substring(0, 12);\n                    var err = r.error_message || '';\n                    if (err.length > 80) err = err.substring(0, 80) + '...';\n                    var proj = r.project_label || '';\n                    html += '<tr>' +\n                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n                        '<td>' + escapeHtml(proj) + '</td>' +\n                        '<td>' + r.workflow_name + '</td>' +\n                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n                        '<td>' + r.started_at + '</td>' +\n                        '<td>' + r.completed_at + '</td>' +\n                        '<td class=\"mono\">' + cid + '</td>' +\n                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                        '</tr>';\n                }\n                tbody.innerHTML = html;\n            })\n            .catch(function() {});\n    }\n    function escapeHtml(s) {\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n    setInterval(poll, 3000);\n})();\n</script>\n{{end}}\n"}}
