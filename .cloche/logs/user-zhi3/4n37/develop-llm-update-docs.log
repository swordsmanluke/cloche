{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ThhcvH4daGuP546o4nGfAJ","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"os/exec\"\n    14→\t\"path/filepath\"\n    15→\t\"regexp\"\n    16→\t\"sort\"\n    17→\t\"strconv\"\n    18→\t\"strings\"\n    19→\t\"time\"\n    20→\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→)\n    26→\n    27→// HandlerOption configures optional Handler dependencies.\n    28→type HandlerOption func(*Handler)\n    29→\n    30→// WithContainerLogger sets the container runtime for fetching live logs.\n    31→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32→\treturn func(h *Handler) { h.container = c }\n    33→}\n    34→\n    35→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36→func WithContainerManager(c ContainerManager) HandlerOption {\n    37→\treturn func(h *Handler) { h.container = c }\n    38→}\n    39→\n    40→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42→\treturn func(h *Handler) { h.logBroadcast = b }\n    43→}\n    44→\n    45→// WithLogStore sets the log store for indexed log file lookups.\n    46→func WithLogStore(ls ports.LogStore) HandlerOption {\n    47→\treturn func(h *Handler) { h.logStore = ls }\n    48→}\n    49→\n    50→// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    51→func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    52→\treturn func(h *Handler) { h.orchestrateFn = fn }\n    53→}\n    54→\n    55→// OrchestratorController provides per-project orchestrator control.\n    56→type OrchestratorController interface {\n    57→\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    58→\tSetEnabled(dir string, enabled bool)\n    59→\tSetConcurrency(dir string, concurrency int)\n    60→}\n    61→\n    62→// WithOrchestrator sets the orchestrator controller for project-level control.\n    63→func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    64→\treturn func(h *Handler) { h.orchestrator = oc }\n    65→}\n    66→\n    67→//go:embed templates/*.html static/*\n    68→var content embed.FS\n    69→\n    70→// Handler serves the web dashboard.\n    71→// ContainerLogger can retrieve logs from a container by ID.\n    72→type ContainerLogger interface {\n    73→\tLogs(ctx context.Context, containerID string) (string, error)\n    74→}\n    75→\n    76→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    77→type ContainerManager interface {\n    78→\tContainerLogger\n    79→\tRemove(ctx context.Context, containerID string) error\n    80→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    81→}\n    82→\n    83→type Handler struct {\n    84→\tstore         ports.RunStore\n    85→\tcaptures      ports.CaptureStore\n    86→\tlogStore      ports.LogStore\n    87→\tcontainer     ContainerLogger\n    88→\tlogBroadcast  *logstream.Broadcaster\n    89→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    90→\torchestrator  OrchestratorController\n    91→\tpages         map[string]*template.Template\n    92→\tmux           *http.ServeMux\n    93→}\n    94→\n    95→// NewHandler creates a web dashboard handler.\n    96→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    97→\tfuncMap := template.FuncMap{\n    98→\t\t\"stateColor\":       stateColor,\n    99→\t\t\"healthColor\":      healthColor,\n   100→\t\t\"formatTime\":       formatTime,\n   101→\t\t\"formatDuration\":   formatDuration,\n   102→\t\t\"truncate\":         truncate,\n   103→\t\t\"shortContainerID\": shortContainerID,\n   104→\t}\n   105→\n   106→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   107→\tif err != nil {\n   108→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   109→\t}\n   110→\n   111→\tpages := map[string]*template.Template{}\n   112→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   113→\t\tclone, err := base.Clone()\n   114→\t\tif err != nil {\n   115→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   116→\t\t}\n   117→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   118→\t\tif err != nil {\n   119→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   120→\t\t}\n   121→\t\tpages[page] = clone\n   122→\t}\n   123→\n   124→\th := &Handler{\n   125→\t\tstore:    store,\n   126→\t\tcaptures: captures,\n   127→\t\tpages:    pages,\n   128→\t\tmux:      http.NewServeMux(),\n   129→\t}\n   130→\tfor _, opt := range opts {\n   131→\t\topt(h)\n   132→\t}\n   133→\n   134→\tstaticFS, err := fs.Sub(content, \"static\")\n   135→\tif err != nil {\n   136→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   137→\t}\n   138→\n   139→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   140→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   141→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   142→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   143→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   144→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   145→\th.mux.HandleFunc(\"GET /api/projects/{name}/runs\", h.handleAPIProjectRuns)\n   146→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   147→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   148→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   149→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   150→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   151→\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   152→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   153→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   154→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   155→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   156→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   157→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   158→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   159→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   160→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   161→\n   162→\treturn h, nil\n   163→}\n   164→\n   165→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   166→\th.mux.ServeHTTP(w, r)\n   167→}\n   168→\n   169→// --- HTML handlers ---\n   170→\n   171→// projectOverviewEntry holds data for a single project card on the landing page.\n   172→type projectOverviewEntry struct {\n   173→\tDir         string\n   174→\tLabel       string\n   175→\tHealth      domain.HealthResult\n   176→\tRecentRuns  []recentRunDot\n   177→\tActiveCount int\n   178→}\n   179→\n   180→// recentRunDot is a minimal representation of a run for the mini history display.\n   181→type recentRunDot struct {\n   182→\tID    string\n   183→\tState string\n   184→}\n   185→\n   186→const healthWindowSize = 10\n   187→\n   188→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   189→\tprojects, _ := h.store.ListProjects(r.Context())\n   190→\tlabels := projectLabels(projects)\n   191→\n   192→\tvar entries []projectOverviewEntry\n   193→\tfor _, dir := range projects {\n   194→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   195→\t\tif err != nil {\n   196→\t\t\tcontinue\n   197→\t\t}\n   198→\n   199→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   200→\t\trunValues := make([]domain.Run, len(runs))\n   201→\t\tfor i, rr := range runs {\n   202→\t\t\trunValues[i] = *rr\n   203→\t\t}\n   204→\n   205→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   206→\n   207→\t\t// Take the last N runs for the mini history (most recent first).\n   208→\t\tn := healthWindowSize\n   209→\t\tif n > len(runs) {\n   210→\t\t\tn = len(runs)\n   211→\t\t}\n   212→\t\tdots := make([]recentRunDot, n)\n   213→\t\tfor i := 0; i < n; i++ {\n   214→\t\t\tdots[i] = recentRunDot{\n   215→\t\t\t\tID:    runs[i].ID,\n   216→\t\t\t\tState: string(runs[i].State),\n   217→\t\t\t}\n   218→\t\t}\n   219→\n   220→\t\tvar activeCount int\n   221→\t\tfor _, rr := range runs {\n   222→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   223→\t\t\t\tactiveCount++\n   224→\t\t\t}\n   225→\t\t}\n   226→\n   227→\t\tentries = append(entries, projectOverviewEntry{\n   228→\t\t\tDir:         dir,\n   229→\t\t\tLabel:       labels[dir],\n   230→\t\t\tHealth:      health,\n   231→\t\t\tRecentRuns:  dots,\n   232→\t\t\tActiveCount: activeCount,\n   233→\t\t})\n   234→\t}\n   235→\n   236→\tsort.Slice(entries, func(i, j int) bool {\n   237→\t\treturn entries[i].Label < entries[j].Label\n   238→\t})\n   239→\n   240→\tdata := map[string]any{\n   241→\t\t\"Title\":    \"Projects\",\n   242→\t\t\"Projects\": entries,\n   243→\t}\n   244→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   245→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   246→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   247→\t}\n   248→}\n   249→\n   250→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   251→\tprojectFilter := r.URL.Query().Get(\"project\")\n   252→\n   253→\tvar runs []*domain.Run\n   254→\tvar err error\n   255→\tif projectFilter != \"\" {\n   256→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   257→\t} else {\n   258→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   259→\t}\n   260→\tif err != nil {\n   261→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   262→\t\treturn\n   263→\t}\n   264→\n   265→\tprojects, _ := h.store.ListProjects(r.Context())\n   266→\tlabels := projectLabels(projects)\n   267→\n   268→\t// Count retained containers per project\n   269→\tcontainerCounts := map[string]int{}\n   270→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   271→\tfor _, run := range allRuns {\n   272→\t\tif run.ContainerKept {\n   273→\t\t\tcontainerCounts[run.ProjectDir]++\n   274→\t\t}\n   275→\t}\n   276→\n   277→\tvar projectList []projectEntry\n   278→\tfor _, dir := range projects {\n   279→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   280→\t}\n   281→\tsort.Slice(projectList, func(i, j int) bool {\n   282→\t\treturn projectList[i].Label < projectList[j].Label\n   283→\t})\n   284→\n   285→\tvar projectLabel string\n   286→\tif projectFilter != \"\" {\n   287→\t\tprojectLabel = labels[projectFilter]\n   288→\t}\n   289→\n   290→\tdata := map[string]any{\n   291→\t\t\"Title\":         \"Runs\",\n   292→\t\t\"Runs\":          runs,\n   293→\t\t\"Projects\":      projectList,\n   294→\t\t\"ProjectFilter\": projectFilter,\n   295→\t\t\"ProjectLabel\":  projectLabel,\n   296→\t\t\"ProjectLabels\": labels,\n   297→\t}\n   298→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   299→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   300→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   301→\t}\n   302→}\n   303→\n   304→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   305→\tdir, label, ok := h.resolveProjectDir(w, r)\n   306→\tif !ok {\n   307→\t\treturn\n   308→\t}\n   309→\n   310→\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   311→\tif err != nil {\n   312→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   313→\t\treturn\n   314→\t}\n   315→\n   316→\tprojects, _ := h.store.ListProjects(r.Context())\n   317→\tlabels := projectLabels(projects)\n   318→\n   319→\t// Count retained containers per project\n   320→\tcontainerCounts := map[string]int{}\n   321→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   322→\tfor _, run := range allRuns {\n   323→\t\tif run.ContainerKept {\n   324→\t\t\tcontainerCounts[run.ProjectDir]++\n   325→\t\t}\n   326→\t}\n   327→\n   328→\tvar projectList []projectEntry\n   329→\tfor _, d := range projects {\n   330→\t\tprojectList = append(projectList, projectEntry{Dir: d, Label: labels[d], ContainerCount: containerCounts[d]})\n   331→\t}\n   332→\tsort.Slice(projectList, func(i, j int) bool {\n   333→\t\treturn projectList[i].Label < projectList[j].Label\n   334→\t})\n   335→\n   336→\tdata := map[string]any{\n   337→\t\t\"Title\":         label + \" – Runs\",\n   338→\t\t\"Runs\":          runs,\n   339→\t\t\"Projects\":      projectList,\n   340→\t\t\"ProjectFilter\": dir,\n   341→\t\t\"ProjectLabel\":  label,\n   342→\t\t\"ProjectLabels\": labels,\n   343→\t}\n   344→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   345→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   346→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   347→\t}\n   348→}\n   349→\n   350→// stepEntry is a merged view of a step execution for the template.\n   351→type stepEntry struct {\n   352→\tIndex     int\n   353→\tStepName  string\n   354→\tResult    string\n   355→\tStartedAt time.Time\n   356→\tDuration  string\n   357→}\n   358→\n   359→// mergeCaptures collapses started/completed capture pairs into single entries.\n   360→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   361→\tvar entries []stepEntry\n   362→\t// Track pending started rows by step name (LIFO for retries)\n   363→\tpending := map[string]*domain.StepExecution{}\n   364→\n   365→\tfor _, c := range caps {\n   366→\t\tif c.Result == \"\" {\n   367→\t\t\t// step_started row\n   368→\t\t\tpending[c.StepName] = c\n   369→\t\t\tcontinue\n   370→\t\t}\n   371→\t\t// step_completed row — merge with pending started if available\n   372→\t\tstartedAt := c.StartedAt\n   373→\t\tif started := pending[c.StepName]; started != nil {\n   374→\t\t\tstartedAt = started.StartedAt\n   375→\t\t\tdelete(pending, c.StepName)\n   376→\t\t}\n   377→\t\tentries = append(entries, stepEntry{\n   378→\t\t\tIndex:     len(entries),\n   379→\t\t\tStepName:  c.StepName,\n   380→\t\t\tResult:    c.Result,\n   381→\t\t\tStartedAt: startedAt,\n   382→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   383→\t\t})\n   384→\t}\n   385→\n   386→\t// Append any started-but-not-completed steps (still running)\n   387→\tfor _, c := range caps {\n   388→\t\tif c.Result == \"\" {\n   389→\t\t\tif _, used := pending[c.StepName]; !used {\n   390→\t\t\t\tcontinue\n   391→\t\t\t}\n   392→\t\t\tentries = append(entries, stepEntry{\n   393→\t\t\t\tIndex:     len(entries),\n   394→\t\t\t\tStepName:  c.StepName,\n   395→\t\t\t\tStartedAt: c.StartedAt,\n   396→\t\t\t})\n   397→\t\t\tdelete(pending, c.StepName)\n   398→\t\t}\n   399→\t}\n   400→\n   401→\treturn entries\n   402→}\n   403→\n   404→// containerState inspects the container for a run and returns one of:\n   405→//   - \"running\"   – container exists and is running\n   406→//   - \"stopped\"   – container exists, not running, not kept\n   407→//   - \"available\" – container exists, not running, kept (can be deleted)\n   408→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   409→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   410→\tif run.ContainerID == \"\" {\n   411→\t\treturn \"removed\"\n   412→\t}\n   413→\tmgr, ok := h.container.(ContainerManager)\n   414→\tif !ok {\n   415→\t\treturn \"removed\"\n   416→\t}\n   417→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   418→\tif err != nil {\n   419→\t\treturn \"removed\"\n   420→\t}\n   421→\tif status.Running {\n   422→\t\treturn \"running\"\n   423→\t}\n   424→\tif run.ContainerKept {\n   425→\t\treturn \"available\"\n   426→\t}\n   427→\treturn \"stopped\"\n   428→}\n   429→\n   430→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   431→\tid := r.PathValue(\"id\")\n   432→\n   433→\trun, err := h.store.GetRun(r.Context(), id)\n   434→\tif err != nil {\n   435→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   436→\t\treturn\n   437→\t}\n   438→\n   439→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   440→\tif err != nil {\n   441→\t\tcaps = nil // non-fatal\n   442→\t}\n   443→\n   444→\tsteps := mergeCaptures(caps)\n   445→\n   446→\tdata := map[string]any{\n   447→\t\t\"Title\":          \"Run \" + run.ID,\n   448→\t\t\"Run\":            run,\n   449→\t\t\"Steps\":          steps,\n   450→\t\t\"Page\":           \"detail\",\n   451→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   452→\t}\n   453→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   454→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   455→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   456→\t}\n   457→}\n   458→\n   459→// --- JSON API handlers ---\n   460→\n   461→type apiRun struct {\n   462→\tID           string `json:\"id\"`\n   463→\tWorkflowName string `json:\"workflow_name\"`\n   464→\tProjectDir   string `json:\"project_dir\"`\n   465→\tProjectLabel string `json:\"project_label\"`\n   466→\tState        string `json:\"state\"`\n   467→\tStartedAt    string `json:\"started_at\"`\n   468→\tCompletedAt  string `json:\"completed_at\"`\n   469→\tContainerID  string `json:\"container_id\"`\n   470→\tErrorMessage string `json:\"error_message\"`\n   471→}\n   472→\n   473→type apiStep struct {\n   474→\tStepName    string `json:\"step_name\"`\n   475→\tResult      string `json:\"result\"`\n   476→\tStartedAt   string `json:\"started_at\"`\n   477→\tCompletedAt string `json:\"completed_at\"`\n   478→\tDuration    string `json:\"duration\"`\n   479→}\n   480→\n   481→type apiRunDetail struct {\n   482→\tapiRun\n   483→\tContainerState string    `json:\"container_state\"`\n   484→\tSteps          []apiStep `json:\"steps\"`\n   485→}\n   486→\n   487→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   488→\treturn apiRun{\n   489→\t\tID:           r.ID,\n   490→\t\tWorkflowName: r.WorkflowName,\n   491→\t\tProjectDir:   r.ProjectDir,\n   492→\t\tProjectLabel: labels[r.ProjectDir],\n   493→\t\tState:        string(r.State),\n   494→\t\tStartedAt:    formatTime(r.StartedAt),\n   495→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   496→\t\tContainerID:  r.ContainerID,\n   497→\t\tErrorMessage: r.ErrorMessage,\n   498→\t}\n   499→}\n   500→\n   501→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   502→\tprojectFilter := r.URL.Query().Get(\"project\")\n   503→\n   504→\tvar runs []*domain.Run\n   505→\tvar err error\n   506→\tif projectFilter != \"\" {\n   507→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   508→\t} else {\n   509→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   510→\t}\n   511→\tif err != nil {\n   512→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   513→\t\treturn\n   514→\t}\n   515→\n   516→\tprojects, _ := h.store.ListProjects(r.Context())\n   517→\tlabels := projectLabels(projects)\n   518→\n   519→\tresult := make([]apiRun, len(runs))\n   520→\tfor i, run := range runs {\n   521→\t\tresult[i] = toAPIRun(run, labels)\n   522→\t}\n   523→\n   524→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   525→\tjson.NewEncoder(w).Encode(result)\n   526→}\n   527→\n   528→func (h *Handler) handleAPIProjectRuns(w http.ResponseWriter, r *http.Request) {\n   529→\tdir, _, ok := h.resolveProjectDir(w, r)\n   530→\tif !ok {\n   531→\t\treturn\n   532→\t}\n   533→\n   534→\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   535→\tif err != nil {\n   536→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   537→\t\treturn\n   538→\t}\n   539→\n   540→\tprojects, _ := h.store.ListProjects(r.Context())\n   541→\tlabels := projectLabels(projects)\n   542→\n   543→\tresult := make([]apiRun, len(runs))\n   544→\tfor i, run := range runs {\n   545→\t\tresult[i] = toAPIRun(run, labels)\n   546→\t}\n   547→\n   548→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   549→\tjson.NewEncoder(w).Encode(result)\n   550→}\n   551→\n   552→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   553→\tprojects, err := h.store.ListProjects(r.Context())\n   554→\tif err != nil {\n   555→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   556→\t\treturn\n   557→\t}\n   558→\tlabels := projectLabels(projects)\n   559→\n   560→\ttype apiHealth struct {\n   561→\t\tStatus string `json:\"status\"`\n   562→\t\tPassed int    `json:\"passed\"`\n   563→\t\tFailed int    `json:\"failed\"`\n   564→\t\tTotal  int    `json:\"total\"`\n   565→\t}\n   566→\ttype apiProject struct {\n   567→\t\tDir         string    `json:\"dir\"`\n   568→\t\tLabel       string    `json:\"label\"`\n   569→\t\tHealth      apiHealth `json:\"health\"`\n   570→\t\tActiveCount int       `json:\"active_count\"`\n   571→\t}\n   572→\tresult := make([]apiProject, len(projects))\n   573→\tfor i, dir := range projects {\n   574→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   575→\t\trunValues := make([]domain.Run, len(runs))\n   576→\t\tfor j, rr := range runs {\n   577→\t\t\trunValues[j] = *rr\n   578→\t\t}\n   579→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   580→\t\tvar activeCount int\n   581→\t\tfor _, rr := range runs {\n   582→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   583→\t\t\t\tactiveCount++\n   584→\t\t\t}\n   585→\t\t}\n   586→\t\tresult[i] = apiProject{\n   587→\t\t\tDir:   dir,\n   588→\t\t\tLabel: labels[dir],\n   589→\t\t\tHealth: apiHealth{\n   590→\t\t\t\tStatus: string(health.Status),\n   591→\t\t\t\tPassed: health.Passed,\n   592→\t\t\t\tFailed: health.Failed,\n   593→\t\t\t\tTotal:  health.Total,\n   594→\t\t\t},\n   595→\t\t\tActiveCount: activeCount,\n   596→\t\t}\n   597→\t}\n   598→\n   599→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   600→\tjson.NewEncoder(w).Encode(result)\n   601→}\n   602→\n   603→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   604→\tid := r.PathValue(\"id\")\n   605→\n   606→\trun, err := h.store.GetRun(r.Context(), id)\n   607→\tif err != nil {\n   608→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   609→\t\treturn\n   610→\t}\n   611→\n   612→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   613→\tif err != nil {\n   614→\t\tcaps = nil\n   615→\t}\n   616→\n   617→\tprojects, _ := h.store.ListProjects(r.Context())\n   618→\tlabels := projectLabels(projects)\n   619→\n   620→\tmerged := mergeCaptures(caps)\n   621→\tsteps := make([]apiStep, len(merged))\n   622→\tfor i, e := range merged {\n   623→\t\tsteps[i] = apiStep{\n   624→\t\t\tStepName:  e.StepName,\n   625→\t\t\tResult:    e.Result,\n   626→\t\t\tStartedAt: formatTime(e.StartedAt),\n   627→\t\t\tDuration:  e.Duration,\n   628→\t\t}\n   629→\t}\n   630→\n   631→\tdetail := apiRunDetail{\n   632→\t\tapiRun:         toAPIRun(run, labels),\n   633→\t\tContainerState: h.containerState(r.Context(), run),\n   634→\t\tSteps:          steps,\n   635→\t}\n   636→\n   637→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   638→\tjson.NewEncoder(w).Encode(detail)\n   639→}\n   640→\n   641→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   642→\tid := r.PathValue(\"id\")\n   643→\tstep := r.PathValue(\"step\")\n   644→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   645→\n   646→\trun, err := h.store.GetRun(r.Context(), id)\n   647→\tif err != nil {\n   648→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   649→\t\treturn\n   650→\t}\n   651→\n   652→\t// Try log index first for fast lookup\n   653→\tif h.logStore != nil {\n   654→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   655→\t\tif err == nil && len(logFiles) > 0 {\n   656→\t\t\t// If type filter specified, narrow results\n   657→\t\t\tfor _, lf := range logFiles {\n   658→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   659→\t\t\t\t\tcontinue\n   660→\t\t\t\t}\n   661→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   662→\t\t\t\tif readErr == nil && len(data) > 0 {\n   663→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   664→\t\t\t\t\tw.Write(data)\n   665→\t\t\t\t\treturn\n   666→\t\t\t\t}\n   667→\t\t\t}\n   668→\t\t}\n   669→\t}\n   670→\n   671→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   672→\n   673→\t// Fall back to file path conventions\n   674→\t// If type is \"llm\", try llm-<step>.log\n   675→\tif logType == \"llm\" {\n   676→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   677→\t\tdata, err := os.ReadFile(llmPath)\n   678→\t\tif err == nil && len(data) > 0 {\n   679→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   680→\t\t\tw.Write(data)\n   681→\t\t\treturn\n   682→\t\t}\n   683→\t}\n   684→\n   685→\t// Try per-step output first, fall back to container.log, then live docker logs\n   686→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   687→\tdata, err := os.ReadFile(outputPath)\n   688→\tif err == nil && len(data) > 0 {\n   689→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   690→\t\tw.Write(data)\n   691→\t\treturn\n   692→\t}\n   693→\n   694→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   695→\tdata, err = os.ReadFile(containerLog)\n   696→\tif err == nil && len(data) > 0 {\n   697→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   698→\t\tw.Write(data)\n   699→\t\treturn\n   700→\t}\n   701→\n   702→\t// Last resort: try live docker logs from still-existing container\n   703→\tif h.container != nil && run.ContainerID != \"\" {\n   704→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   705→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   706→\t\t\tw.Write([]byte(logs))\n   707→\t\t\treturn\n   708→\t\t}\n   709→\t}\n   710→\n   711→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   712→}\n   713→\n   714→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   715→\tid := r.PathValue(\"id\")\n   716→\n   717→\trun, err := h.store.GetRun(r.Context(), id)\n   718→\tif err != nil {\n   719→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   720→\t\tw.WriteHeader(http.StatusNotFound)\n   721→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   722→\t\treturn\n   723→\t}\n   724→\n   725→\tmgr, ok := h.container.(ContainerManager)\n   726→\tif !ok || run.ContainerID == \"\" {\n   727→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   728→\t\tw.WriteHeader(http.StatusBadRequest)\n   729→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   730→\t\treturn\n   731→\t}\n   732→\n   733→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   734→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   735→\t\tw.WriteHeader(http.StatusInternalServerError)\n   736→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   737→\t\treturn\n   738→\t}\n   739→\n   740→\trun.ContainerKept = false\n   741→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   742→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   743→\t\tw.WriteHeader(http.StatusInternalServerError)\n   744→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   745→\t\treturn\n   746→\t}\n   747→\n   748→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   749→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   750→}\n   751→\n   752→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   753→\tlabel := r.PathValue(\"name\")\n   754→\n   755→\t// Resolve label back to project directory via the store.\n   756→\tprojects, _ := h.store.ListProjects(r.Context())\n   757→\tlabels := projectLabels(projects)\n   758→\tvar projectDir string\n   759→\tfor dir, l := range labels {\n   760→\t\tif l == label {\n   761→\t\t\tprojectDir = dir\n   762→\t\t\tbreak\n   763→\t\t}\n   764→\t}\n   765→\tif projectDir == \"\" {\n   766→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   767→\t\tw.WriteHeader(http.StatusNotFound)\n   768→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   769→\t\treturn\n   770→\t}\n   771→\n   772→\tif h.orchestrateFn == nil {\n   773→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   774→\t\tw.WriteHeader(http.StatusNotImplemented)\n   775→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   776→\t\treturn\n   777→\t}\n   778→\n   779→\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   780→\tif err != nil {\n   781→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   782→\t\tw.WriteHeader(http.StatusInternalServerError)\n   783→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   784→\t\treturn\n   785→\t}\n   786→\n   787→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   788→\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   789→}\n   790→\n   791→// handleAPIStream serves an SSE stream of log lines for a run.\n   792→// For active runs, it subscribes to the live broadcaster.\n   793→// For completed runs, it serves the archived full.log then closes.\n   794→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   795→\tid := r.PathValue(\"id\")\n   796→\n   797→\trun, err := h.store.GetRun(r.Context(), id)\n   798→\tif err != nil {\n   799→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   800→\t\treturn\n   801→\t}\n   802→\n   803→\tflusher, ok := w.(http.Flusher)\n   804→\tif !ok {\n   805→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   806→\t\treturn\n   807→\t}\n   808→\n   809→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   810→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   811→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   812→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   813→\n   814→\tisComplete := run.State == domain.RunStateSucceeded ||\n   815→\t\trun.State == domain.RunStateFailed ||\n   816→\t\trun.State == domain.RunStateCancelled\n   817→\n   818→\tif isComplete {\n   819→\t\t// Serve archived full.log\n   820→\t\th.streamFullLog(w, flusher, run)\n   821→\t\t// Send done event\n   822→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   823→\t\tflusher.Flush()\n   824→\t\treturn\n   825→\t}\n   826→\n   827→\t// Active run: subscribe to live broadcaster\n   828→\tif h.logBroadcast == nil {\n   829→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   830→\t\treturn\n   831→\t}\n   832→\n   833→\tsub := h.logBroadcast.Subscribe(id)\n   834→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   835→\n   836→\tctx := r.Context()\n   837→\tfor {\n   838→\t\tselect {\n   839→\t\tcase <-ctx.Done():\n   840→\t\t\treturn\n   841→\t\tcase line, ok := <-sub.C:\n   842→\t\t\tif !ok {\n   843→\t\t\t\t// Stream finished (run completed)\n   844→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   845→\t\t\t\tflusher.Flush()\n   846→\t\t\t\treturn\n   847→\t\t\t}\n   848→\t\t\tdata, _ := json.Marshal(line)\n   849→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   850→\t\t\tflusher.Flush()\n   851→\t\t}\n   852→\t}\n   853→}\n   854→\n   855→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   856→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   857→\n   858→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   859→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   860→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   861→\tf, err := os.Open(logPath)\n   862→\tif err != nil {\n   863→\t\treturn\n   864→\t}\n   865→\tdefer f.Close()\n   866→\n   867→\tscanner := bufio.NewScanner(f)\n   868→\tfor scanner.Scan() {\n   869→\t\ttext := scanner.Text()\n   870→\t\tline := parseFullLogLine(text)\n   871→\t\tdata, _ := json.Marshal(line)\n   872→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   873→\t\tflusher.Flush()\n   874→\t}\n   875→}\n   876→\n   877→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   878→func parseFullLogLine(text string) logstream.LogLine {\n   879→\tm := logLineRegex.FindStringSubmatch(text)\n   880→\tif m == nil {\n   881→\t\treturn logstream.LogLine{\n   882→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   883→\t\t\tType:      \"script\",\n   884→\t\t\tContent:   text,\n   885→\t\t}\n   886→\t}\n   887→\treturn logstream.LogLine{\n   888→\t\tTimestamp: m[1],\n   889→\t\tType:      m[2],\n   890→\t\tContent:   m[3],\n   891→\t}\n   892→}\n   893→\n   894→// --- Project detail handlers ---\n   895→\n   896→// resolveProjectDir resolves a project label from the URL to its directory path.\n   897→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   898→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   899→\tlabel := r.PathValue(\"name\")\n   900→\tprojects, _ := h.store.ListProjects(r.Context())\n   901→\tlabels := projectLabels(projects)\n   902→\tfor dir, l := range labels {\n   903→\t\tif l == label {\n   904→\t\t\treturn dir, label, true\n   905→\t\t}\n   906→\t}\n   907→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   908→\tw.WriteHeader(http.StatusNotFound)\n   909→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   910→\treturn \"\", \"\", false\n   911→}\n   912→\n   913→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   914→\tdir, label, ok := h.resolveProjectDir(w, r)\n   915→\tif !ok {\n   916→\t\treturn\n   917→\t}\n   918→\n   919→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   920→\tn := 10\n   921→\tif n > len(runs) {\n   922→\t\tn = len(runs)\n   923→\t}\n   924→\tdots := make([]recentRunDot, n)\n   925→\tfor i := 0; i < n; i++ {\n   926→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   927→\t}\n   928→\n   929→\tdata := map[string]any{\n   930→\t\t\"Title\":      label,\n   931→\t\t\"Label\":      label,\n   932→\t\t\"Dir\":        dir,\n   933→\t\t\"RecentRuns\": dots,\n   934→\t}\n   935→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   936→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   937→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   938→\t}\n   939→}\n   940→\n   941→func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   942→\tdir, _, ok := h.resolveProjectDir(w, r)\n   943→\tif !ok {\n   944→\t\treturn\n   945→\t}\n   946→\tif h.orchestrator == nil {\n   947→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   948→\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   949→\t\treturn\n   950→\t}\n   951→\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   952→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   953→\tjson.NewEncoder(w).Encode(map[string]any{\n   954→\t\t\"enabled\":     enabled,\n   955→\t\t\"in_flight\":   inFlight,\n   956→\t\t\"concurrency\": concurrency,\n   957→\t})\n   958→}\n   959→\n   960→func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   961→\tdir, _, ok := h.resolveProjectDir(w, r)\n   962→\tif !ok {\n   963→\t\treturn\n   964→\t}\n   965→\tif h.orchestrator == nil {\n   966→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   967→\t\tw.WriteHeader(http.StatusNotImplemented)\n   968→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   969→\t\treturn\n   970→\t}\n   971→\th.orchestrator.SetEnabled(dir, true)\n   972→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   973→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   974→}\n   975→\n   976→func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   977→\tdir, _, ok := h.resolveProjectDir(w, r)\n   978→\tif !ok {\n   979→\t\treturn\n   980→\t}\n   981→\tif h.orchestrator == nil {\n   982→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   983→\t\tw.WriteHeader(http.StatusNotImplemented)\n   984→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   985→\t\treturn\n   986→\t}\n   987→\th.orchestrator.SetEnabled(dir, false)\n   988→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   989→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   990→}\n   991→\n   992→func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   993→\tdir, _, ok := h.resolveProjectDir(w, r)\n   994→\tif !ok {\n   995→\t\treturn\n   996→\t}\n   997→\tif h.orchestrator == nil {\n   998→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   999→\t\tw.WriteHeader(http.StatusNotImplemented)\n  1000→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n  1001→\t\treturn\n  1002→\t}\n  1003→\tvar body struct {\n  1004→\t\tConcurrency int `json:\"concurrency\"`\n  1005→\t}\n  1006→\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n  1007→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1008→\t\tw.WriteHeader(http.StatusBadRequest)\n  1009→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n  1010→\t\treturn\n  1011→\t}\n  1012→\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n  1013→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1014→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n  1015→}\n  1016→\n  1017→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n  1018→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1019→\tif !ok {\n  1020→\t\treturn\n  1021→\t}\n  1022→\n  1023→\t// Docker image: read FROM line from Dockerfile\n  1024→\tdockerImage := \"\"\n  1025→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n  1026→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n  1027→\t\t// Find the last FROM line (final stage)\n  1028→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n  1029→\t\t\ttrimmed := strings.TrimSpace(line)\n  1030→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n  1031→\t\t\t\tparts := strings.Fields(trimmed)\n  1032→\t\t\t\tif len(parts) >= 2 {\n  1033→\t\t\t\t\tdockerImage = parts[1]\n  1034→\t\t\t\t}\n  1035→\t\t\t}\n  1036→\t\t}\n  1037→\t}\n  1038→\n  1039→\t// Version\n  1040→\tversion := 0\n  1041→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n  1042→\tif data, err := os.ReadFile(versionPath); err == nil {\n  1043→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n  1044→\t\t\tversion = v\n  1045→\t\t}\n  1046→\t}\n  1047→\n  1048→\t// Prompt files history\n  1049→\ttype commitEntry struct {\n  1050→\t\tSHA     string `json:\"sha\"`\n  1051→\t\tDate    string `json:\"date\"`\n  1052→\t\tMessage string `json:\"message\"`\n  1053→\t}\n  1054→\ttype promptFile struct {\n  1055→\t\tPath    string        `json:\"path\"`\n  1056→\t\tHistory []commitEntry `json:\"history\"`\n  1057→\t}\n  1058→\n  1059→\tvar promptFiles []promptFile\n  1060→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n  1061→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n  1062→\t\tfor _, e := range entries {\n  1063→\t\t\tif e.IsDir() {\n  1064→\t\t\t\tcontinue\n  1065→\t\t\t}\n  1066→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n  1067→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n  1068→\t\t\tcmd.Dir = dir\n  1069→\t\t\tout, err := cmd.Output()\n  1070→\t\t\tif err != nil {\n  1071→\t\t\t\tcontinue\n  1072→\t\t\t}\n  1073→\t\t\tvar history []commitEntry\n  1074→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n  1075→\t\t\t\tif line == \"\" {\n  1076→\t\t\t\t\tcontinue\n  1077→\t\t\t\t}\n  1078→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1079→\t\t\t\tif len(parts) < 3 {\n  1080→\t\t\t\t\tcontinue\n  1081→\t\t\t\t}\n  1082→\t\t\t\t// Parse date to short form\n  1083→\t\t\t\tdateStr := parts[1]\n  1084→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1085→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1086→\t\t\t\t}\n  1087→\t\t\t\thistory = append(history, commitEntry{\n  1088→\t\t\t\t\tSHA:     parts[0][:7],\n  1089→\t\t\t\t\tDate:    dateStr,\n  1090→\t\t\t\t\tMessage: parts[2],\n  1091→\t\t\t\t})\n  1092→\t\t\t}\n  1093→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1094→\t\t}\n  1095→\t}\n  1096→\n  1097→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1098→\tjson.NewEncoder(w).Encode(map[string]any{\n  1099→\t\t\"docker_image\": dockerImage,\n  1100→\t\t\"version\":      version,\n  1101→\t\t\"prompt_files\": promptFiles,\n  1102→\t})\n  1103→}\n  1104→\n  1105→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1106→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1107→\tif !ok {\n  1108→\t\treturn\n  1109→\t}\n  1110→\tfile := r.URL.Query().Get(\"file\")\n  1111→\tsha := r.URL.Query().Get(\"sha\")\n  1112→\tif file == \"\" || sha == \"\" {\n  1113→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1114→\t\treturn\n  1115→\t}\n  1116→\n  1117→\t// Validate sha is alphanumeric to prevent injection\n  1118→\tfor _, c := range sha {\n  1119→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1120→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1121→\t\t\treturn\n  1122→\t\t}\n  1123→\t}\n  1124→\n  1125→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1126→\tcmd.Dir = dir\n  1127→\tout, err := cmd.Output()\n  1128→\tif err != nil {\n  1129→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1130→\t\treturn\n  1131→\t}\n  1132→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1133→\tw.Write(out)\n  1134→}\n  1135→\n  1136→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1137→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1138→\tif !ok {\n  1139→\t\treturn\n  1140→\t}\n  1141→\n  1142→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1143→\tentries, err := os.ReadDir(clocheDir)\n  1144→\tif err != nil {\n  1145→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1146→\t\tjson.NewEncoder(w).Encode([]any{})\n  1147→\t\treturn\n  1148→\t}\n  1149→\n  1150→\ttype apiWire struct {\n  1151→\t\tFrom   string `json:\"from\"`\n  1152→\t\tResult string `json:\"result\"`\n  1153→\t\tTo     string `json:\"to\"`\n  1154→\t}\n  1155→\ttype apiStepDef struct {\n  1156→\t\tName    string            `json:\"name\"`\n  1157→\t\tType    string            `json:\"type\"`\n  1158→\t\tResults []string          `json:\"results\"`\n  1159→\t\tConfig  map[string]string `json:\"config\"`\n  1160→\t}\n  1161→\ttype apiWorkflow struct {\n  1162→\t\tName      string       `json:\"name\"`\n  1163→\t\tFile      string       `json:\"file\"`\n  1164→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1165→\t\tWires     []apiWire    `json:\"wires\"`\n  1166→\t\tEntryStep string       `json:\"entry_step\"`\n  1167→\t}\n  1168→\n  1169→\tvar workflows []apiWorkflow\n  1170→\tfor _, e := range entries {\n  1171→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1172→\t\t\tcontinue\n  1173→\t\t}\n  1174→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1175→\t\tif err != nil {\n  1176→\t\t\tcontinue\n  1177→\t\t}\n  1178→\t\twf, err := dsl.Parse(string(data))\n  1179→\t\tif err != nil {\n  1180→\t\t\tcontinue\n  1181→\t\t}\n  1182→\t\tvar steps []apiStepDef\n  1183→\t\tfor _, s := range wf.Steps {\n  1184→\t\t\tsteps = append(steps, apiStepDef{\n  1185→\t\t\t\tName:    s.Name,\n  1186→\t\t\t\tType:    string(s.Type),\n  1187→\t\t\t\tResults: s.Results,\n  1188→\t\t\t\tConfig:  s.Config,\n  1189→\t\t\t})\n  1190→\t\t}\n  1191→\t\t// Sort steps by name for consistent ordering\n  1192→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1193→\n  1194→\t\tvar wires []apiWire\n  1195→\t\tfor _, wire := range wf.Wiring {\n  1196→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1197→\t\t}\n  1198→\n  1199→\t\tworkflows = append(workflows, apiWorkflow{\n  1200→\t\t\tName:      wf.Name,\n  1201→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1202→\t\t\tSteps:     steps,\n  1203→\t\t\tWires:     wires,\n  1204→\t\t\tEntryStep: wf.EntryStep,\n  1205→\t\t})\n  1206→\t}\n  1207→\n  1208→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1209→\tjson.NewEncoder(w).Encode(workflows)\n  1210→}\n  1211→\n  1212→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1213→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1214→\tif !ok {\n  1215→\t\treturn\n  1216→\t}\n  1217→\tworkflowName := r.PathValue(\"workflow\")\n  1218→\tstepName := r.PathValue(\"step\")\n  1219→\n  1220→\t// Find the workflow file\n  1221→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1222→\tvar wf *domain.Workflow\n  1223→\tentries, _ := os.ReadDir(clocheDir)\n  1224→\tfor _, e := range entries {\n  1225→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1226→\t\t\tcontinue\n  1227→\t\t}\n  1228→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1229→\t\tif err != nil {\n  1230→\t\t\tcontinue\n  1231→\t\t}\n  1232→\t\tparsed, err := dsl.Parse(string(data))\n  1233→\t\tif err != nil {\n  1234→\t\t\tcontinue\n  1235→\t\t}\n  1236→\t\tif parsed.Name == workflowName {\n  1237→\t\t\twf = parsed\n  1238→\t\t\tbreak\n  1239→\t\t}\n  1240→\t}\n  1241→\tif wf == nil {\n  1242→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1243→\t\treturn\n  1244→\t}\n  1245→\n  1246→\tstep, ok := wf.Steps[stepName]\n  1247→\tif !ok {\n  1248→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1249→\t\treturn\n  1250→\t}\n  1251→\n  1252→\t// Try to read the referenced file from step config\n  1253→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1254→\n  1255→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1256→\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1257→\t\tif err == nil {\n  1258→\t\t\tw.Write(data)\n  1259→\t\t\treturn\n  1260→\t\t}\n  1261→\t}\n  1262→\tif script := step.Config[\"command\"]; script != \"\" {\n  1263→\t\tw.Write([]byte(script))\n  1264→\t\treturn\n  1265→\t}\n  1266→\tif script := step.Config[\"script\"]; script != \"\" {\n  1267→\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1268→\t\tif err == nil {\n  1269→\t\t\tw.Write(data)\n  1270→\t\t\treturn\n  1271→\t\t}\n  1272→\t\tw.Write([]byte(script))\n  1273→\t\treturn\n  1274→\t}\n  1275→\n  1276→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1277→}\n  1278→\n  1279→// --- Template helpers ---\n  1280→\n  1281→func stateColor(state domain.RunState) string {\n  1282→\tswitch state {\n  1283→\tcase domain.RunStatePending:\n  1284→\t\treturn \"pending\"\n  1285→\tcase domain.RunStateRunning:\n  1286→\t\treturn \"running\"\n  1287→\tcase domain.RunStateSucceeded:\n  1288→\t\treturn \"succeeded\"\n  1289→\tcase domain.RunStateFailed:\n  1290→\t\treturn \"failed\"\n  1291→\tcase domain.RunStateCancelled:\n  1292→\t\treturn \"cancelled\"\n  1293→\tdefault:\n  1294→\t\treturn \"pending\"\n  1295→\t}\n  1296→}\n  1297→\n  1298→func healthColor(status domain.HealthStatus) string {\n  1299→\tswitch status {\n  1300→\tcase domain.HealthGreen:\n  1301→\t\treturn \"green\"\n  1302→\tcase domain.HealthYellow:\n  1303→\t\treturn \"yellow\"\n  1304→\tcase domain.HealthRed:\n  1305→\t\treturn \"red\"\n  1306→\tcase domain.HealthBlue:\n  1307→\t\treturn \"blue\"\n  1308→\tdefault:\n  1309→\t\treturn \"grey\"\n  1310→\t}\n  1311→}\n  1312→\n  1313→func formatTime(t time.Time) string {\n  1314→\tif t.IsZero() {\n  1315→\t\treturn \"\"\n  1316→\t}\n  1317→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1318→}\n  1319→\n  1320→func formatDuration(start, end time.Time) string {\n  1321→\tif start.IsZero() || end.IsZero() {\n  1322→\t\treturn \"\"\n  1323→\t}\n  1324→\td := end.Sub(start)\n  1325→\tif d < time.Second {\n  1326→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1327→\t}\n  1328→\tif d < time.Minute {\n  1329→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1330→\t}\n  1331→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1332→}\n  1333→\n  1334→func truncate(s string, n int) string {\n  1335→\tif len(s) <= n {\n  1336→\t\treturn s\n  1337→\t}\n  1338→\treturn s[:n] + \"...\"\n  1339→}\n  1340→\n  1341→func shortContainerID(id string) string {\n  1342→\tif len(id) > 12 {\n  1343→\t\treturn id[:12]\n  1344→\t}\n  1345→\treturn id\n  1346→}\n  1347→\n  1348→// projectLabels builds a mapping from full project directory paths to short\n  1349→// display labels. Each label is the final directory component (e.g.\n  1350→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1351→// the same final name, the parent directory is prepended to disambiguate\n  1352→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1353→func projectLabels(dirs []string) map[string]string {\n  1354→\tlabels := make(map[string]string, len(dirs))\n  1355→\t// Group dirs by their base name to detect conflicts.\n  1356→\tbyBase := map[string][]string{}\n  1357→\tfor _, d := range dirs {\n  1358→\t\tbase := filepath.Base(d)\n  1359→\t\tbyBase[base] = append(byBase[base], d)\n  1360→\t}\n  1361→\tfor base, paths := range byBase {\n  1362→\t\tif len(paths) == 1 {\n  1363→\t\t\tlabels[paths[0]] = base\n  1364→\t\t} else {\n  1365→\t\t\tfor _, p := range paths {\n  1366→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1367→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1368→\t\t\t}\n  1369→\t\t}\n  1370→\t}\n  1371→\treturn labels\n  1372→}\n  1373→\n  1374→type projectEntry struct {\n  1375→\tDir            string\n  1376→\tLabel          string\n  1377→\tContainerCount int\n  1378→}\n  1379→"}]},"parent_tool_use_id":null,"session_id":"7bb04f91-48f6-482b-bb28-d1b340cab139","uuid":"f6747e27-bb5d-44df-b649-80b240c140de","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\nfunc WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n\treturn func(h *Handler) { h.orchestrateFn = fn }\n}\n\n// OrchestratorController provides per-project orchestrator control.\ntype OrchestratorController interface {\n\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n\tSetEnabled(dir string, enabled bool)\n\tSetConcurrency(dir string, concurrency int)\n}\n\n// WithOrchestrator sets the orchestrator controller for project-level control.\nfunc WithOrchestrator(oc OrchestratorController) HandlerOption {\n\treturn func(h *Handler) { h.orchestrator = oc }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore         ports.RunStore\n\tcaptures      ports.CaptureStore\n\tlogStore      ports.LogStore\n\tcontainer     ContainerLogger\n\tlogBroadcast  *logstream.Broadcaster\n\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n\torchestrator  OrchestratorController\n\tpages         map[string]*template.Template\n\tmux           *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/runs\", h.handleAPIProjectRuns)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tvar projectLabel string\n\tif projectFilter != \"\" {\n\t\tprojectLabel = labels[projectFilter]\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabel\":  projectLabel,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, d := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: d, Label: labels[d], ContainerCount: containerCounts[d]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         label + \" – Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": dir,\n\t\t\"ProjectLabel\":  label,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjectRuns(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\n\t// Resolve label back to project directory via the store.\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tvar projectDir string\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\tprojectDir = dir\n\t\t\tbreak\n\t\t}\n\t}\n\tif projectDir == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\t\treturn\n\t}\n\n\tif h.orchestrateFn == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\n\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n\t\treturn\n\t}\n\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"enabled\":     enabled,\n\t\t\"in_flight\":   inFlight,\n\t\t\"concurrency\": concurrency,\n\t})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, true)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, false)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\tvar body struct {\n\t\tConcurrency int `json:\"concurrency\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n\t\treturn\n\t}\n\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\tif script := step.Config[\"command\"]; script != \"\" {\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1379,"startLine":1,"totalLines":1379}}}
