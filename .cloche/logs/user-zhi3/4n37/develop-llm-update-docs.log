    65→\t\tcmdList(ctx, client, os.Args[2:])\n    66→\tcase \"stop\":\n    67→\t\tcmdStop(ctx, client, os.Args[2:])\n    68→\tcase \"delete\":\n    69→\t\tcmdDelete(ctx, client, os.Args[2:])\n    70→\tcase \"orchestrate\":\n    71→\t\tcmdOrchestrate(ctx, client)\n    72→\tcase \"shutdown\":\n    73→\t\tcmdShutdown(ctx, client)\n    74→\tdefault:\n    75→\t\tusage()\n    76→\t\tos.Exit(1)\n    77→\t}\n    78→}\n    79→\n    80→func usage() {\n    81→\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n    82→\n    83→Commands:\n    84→  init [--workflow <name>] [--base-image <image>]\n    85→                                             Initialize a Cloche project\n    86→  health                                   Show project health summary\n    87→  run --workflow <name> [--prompt \"...\"] [--keep-container]\n    88→                                             Launch a workflow run\n    89→  status <run-id>                            Check run status\n    90→  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n    91→                                             Show logs for a run\n    92→  poll <run-id>                              Wait for a run to finish\n    93→  list [--all]                                List runs (last hour by default)\n    94→  stop <run-id>                              Stop a running workflow\n    95→  delete <container-or-run-id>               Delete a retained container\n    96→  orchestrate                                Dispatch ready workflow runs\n    97→  shutdown                                   Shut down the daemon\n    98→`)\n    99→}\n   100→\n   101→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   102→\tvar workflow, prompt string\n   103→\tvar keepContainer bool\n   104→\n   105→\tfor i := 0; i < len(args); i++ {\n   106→\t\tswitch args[i] {\n   107→\t\tcase \"--workflow\":\n   108→\t\t\tif i+1 < len(args) {\n   109→\t\t\t\ti++\n   110→\t\t\t\tworkflow = args[i]\n   111→\t\t\t}\n   112→\t\tcase \"--prompt\", \"-p\":\n   113→\t\t\tif i+1 < len(args) {\n   114→\t\t\t\ti++\n   115→\t\t\t\tprompt = args[i]\n   116→\t\t\t}\n   117→\t\tcase \"--keep-container\":\n   118→\t\t\tkeepContainer = true\n   119→\t\tdefault:\n   120→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   121→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   122→\t\t\t\tworkflow = args[i]\n   123→\t\t\t}\n   124→\t\t}\n   125→\t}\n   126→\n   127→\tif workflow == \"\" {\n   128→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"]\\n\")\n   129→\t\tos.Exit(1)\n   130→\t}\n   131→\n   132→\tcwd, _ := os.Getwd()\n   133→\n   134→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   135→\tvar image string\n   136→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   137→\tif data, err := os.ReadFile(wfPath); err == nil {\n   138→\t\tif wf, err := dsl.Parse(string(data)); err == nil {\n   139→\t\t\timage = wf.Config[\"container.image\"]\n   140→\t\t}\n   141→\t}\n   142→\n   143→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   144→\t\tWorkflowName:  workflow,\n   145→\t\tProjectDir:    cwd,\n   146→\t\tImage:         image,\n   147→\t\tPrompt:        prompt,\n   148→\t\tKeepContainer: keepContainer,\n   149→\t})\n   150→\tif err != nil {\n   151→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   152→\t\tos.Exit(1)\n   153→\t}\n   154→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   155→}\n   156→\n   157→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   158→\tif len(args) < 1 {\n   159→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   160→\t\tos.Exit(1)\n   161→\t}\n   162→\n   163→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   164→\tif err != nil {\n   165→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   166→\t\tos.Exit(1)\n   167→\t}\n   168→\n   169→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   170→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   171→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   172→\tif resp.ContainerId != \"\" {\n   173→\t\tcid := resp.ContainerId\n   174→\t\tif len(cid) > 12 {\n   175→\t\t\tcid = cid[:12]\n   176→\t\t}\n   177→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   178→\t}\n   179→\tif resp.ErrorMessage != \"\" {\n   180→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   181→\t}\n   182→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   183→\tfor _, exec := range resp.StepExecutions {\n   184→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   185→\t}\n   186→}\n   187→\n   188→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   189→\tvar all bool\n   190→\tfor _, arg := range args {\n   191→\t\tif arg == \"--all\" {\n   192→\t\t\tall = true\n   193→\t\t}\n   194→\t}\n   195→\n   196→\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n   197→\tif err != nil {\n   198→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   199→\t\tos.Exit(1)\n   200→\t}\n   201→\n   202→\tif len(resp.Runs) == 0 {\n   203→\t\tfmt.Println(\"No runs found.\")\n   204→\t\treturn\n   205→\t}\n   206→\n   207→\tfor _, run := range resp.Runs {\n   208→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s\", run.RunId, run.WorkflowName, run.State)\n   209→\t\tif run.ContainerId != \"\" {\n   210→\t\t\tline += \"  \" + run.ContainerId\n   211→\t\t}\n   212→\t\tif run.ErrorMessage != \"\" {\n   213→\t\t\terrMsg := run.ErrorMessage\n   214→\t\t\tif len(errMsg) > 60 {\n   215→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   216→\t\t\t}\n   217→\t\t\tline += \"  \" + errMsg\n   218→\t\t}\n   219→\t\tfmt.Println(line)\n   220→\t}\n   221→}\n   222→\n   223→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   224→\tif len(args) < 1 {\n   225→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n   226→\t\tos.Exit(1)\n   227→\t}\n   228→\n   229→\tvar stepFilter, typeFilter string\n   230→\tvar follow bool\n   231→\trunID := args[0]\n   232→\n   233→\tfor i := 1; i < len(args); i++ {\n   234→\t\tswitch args[i] {\n   235→\t\tcase \"--step\":\n   236→\t\t\tif i+1 < len(args) {\n   237→\t\t\t\ti++\n   238→\t\t\t\tstepFilter = args[i]\n   239→\t\t\t}\n   240→\t\tcase \"--type\":\n   241→\t\t\tif i+1 < len(args) {\n   242→\t\t\t\ti++\n   243→\t\t\t\ttypeFilter = args[i]\n   244→\t\t\t}\n   245→\t\tcase \"--follow\", \"-f\":\n   246→\t\t\tfollow = true\n   247→\t\t}\n   248→\t}\n   249→\n   250→\tif follow {\n   251→\t\tcmdLogsFollow(runID)\n   252→\t\treturn\n   253→\t}\n   254→\n   255→\t// Use background context — log output can be large\n   256→\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n   257→\t\tRunId:    runID,\n   258→\t\tStepName: stepFilter,\n   259→\t\tLogType:  typeFilter,\n   260→\t})\n   261→\tif err != nil {\n   262→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   263→\t\tos.Exit(1)\n   264→\t}\n   265→\n   266→\tfor {\n   267→\t\tentry, err := stream.Recv()\n   268→\t\tif err != nil {\n   269→\t\t\tif errors.Is(err, io.EOF) {\n   270→\t\t\t\tbreak\n   271→\t\t\t}\n   272→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   273→\t\t\tos.Exit(1)\n   274→\t\t}\n   275→\n   276→\t\tswitch entry.Type {\n   277→\t\tcase \"step_started\":\n   278→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   279→\t\t\tif entry.Message != \"\" {\n   280→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   281→\t\t\t}\n   282→\t\tcase \"step_completed\":\n   283→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   284→\t\t\tif entry.Message != \"\" {\n   285→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   286→\t\t\t}\n   287→\t\tcase \"run_completed\":\n   288→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   289→\t\t\tif entry.Message != \"\" {\n   290→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   291→\t\t\t}\n   292→\t\tcase \"full_log\":\n   293→\t\t\tfmt.Print(entry.Message)\n   294→\t\tdefault:\n   295→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   296→\t\t\tif entry.StepName != \"\" {\n   297→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   298→\t\t\t}\n   299→\t\t\tif entry.Message != \"\" {\n   300→\t\t\t\tfmt.Print(entry.Message)\n   301→\t\t\t}\n   302→\t\t}\n   303→\t}\n   304→}\n   305→\n   306→func cmdLogsFollow(runID string) {\n   307→\t// Determine HTTP address from env\n   308→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   309→\tif httpAddr == \"\" {\n   310→\t\thttpAddr = \"localhost:8080\"\n   311→\t}\n   312→\t// Strip protocol prefix if present\n   313→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   314→\n   315→\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n   316→\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n   317→\tif err != nil {\n   318→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   319→\t\tos.Exit(1)\n   320→\t}\n   321→\treq.Header.Set(\"Accept\", \"text/event-stream\")\n   322→\n   323→\tresp, err := http.DefaultClient.Do(req)\n   324→\tif err != nil {\n   325→\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n   326→\t\tos.Exit(1)\n   327→\t}\n   328→\tdefer resp.Body.Close()\n   329→\n   330→\tif resp.StatusCode != 200 {\n   331→\t\tbody, _ := io.ReadAll(resp.Body)\n   332→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   333→\t\tos.Exit(1)\n   334→\t}\n   335→\n   336→\tscanner := bufio.NewScanner(resp.Body)\n   337→\tfor scanner.Scan() {\n   338→\t\tline := scanner.Text()\n   339→\t\tif strings.HasPrefix(line, \"event: done\") {\n   340→\t\t\tbreak\n   341→\t\t}\n   342→\t\tif !strings.HasPrefix(line, \"data: \") {\n   343→\t\t\tcontinue\n   344→\t\t}\n   345→\t\tdata := strings.TrimPrefix(line, \"data: \")\n   346→\n   347→\t\tvar entry struct {\n   348→\t\t\tTimestamp string `json:\"timestamp\"`\n   349→\t\t\tType      string `json:\"type\"`\n   350→\t\t\tContent   string `json:\"content\"`\n   351→\t\t}\n   352→\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n   353→\t\t\tcontinue\n   354→\t\t}\n   355→\n   356→\t\t// Color-code by type\n   357→\t\tswitch entry.Type {\n   358→\t\tcase \"status\":\n   359→\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   360→\t\tcase \"llm\":\n   361→\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   362→\t\tdefault:\n   363→\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n   364→\t\t}\n   365→\t}\n   366→}\n   367→\n   368→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   369→\tif len(args) < 1 {\n   370→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   371→\t\tos.Exit(1)\n   372→\t}\n   373→\n   374→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   375→\tif err != nil {\n   376→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   377→\t\tos.Exit(1)\n   378→\t}\n   379→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   380→}\n   381→\n   382→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   383→\tif len(args) < 1 {\n   384→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   385→\t\tos.Exit(1)\n   386→\t}\n   387→\n   388→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   389→\tif err != nil {\n   390→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   391→\t\tos.Exit(1)\n   392→\t}\n   393→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   394→}\n   395→\n   396→func cmdOrchestrate(ctx context.Context, client pb.ClocheServiceClient) {\n   397→\tcwd, _ := os.Getwd()\n   398→\tresp, err := client.Orchestrate(ctx, &pb.OrchestrateRequest{ProjectDir: cwd})\n   399→\tif err != nil {\n   400→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   401→\t\tos.Exit(1)\n   402→\t}\n   403→\tif resp.Dispatched == 0 {\n   404→\t\tfmt.Println(\"No ready work found.\")\n   405→\t} else {\n   406→\t\tfmt.Printf(\"Dispatched %d run(s).\\n\", resp.Dispatched)\n   407→\t}\n   408→}\n   409→\n   410→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   411→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   412→\tif err != nil {\n   413→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   414→\t\tos.Exit(1)\n   415→\t}\n   416→\tfmt.Println(\"Daemon shutting down.\")\n   417→}\n   418→"}]},"parent_tool_use_id":null,"session_id":"7bb04f91-48f6-482b-bb28-d1b340cab139","uuid":"e25decbd-6317-4897-8e1b-db1130ac6356","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"orchestrate\":\n\t\tcmdOrchestrate(ctx, client)\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client)\n\tdefault:\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n}\n\nfunc usage() {\n\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n\nCommands:\n  init [--workflow <name>] [--base-image <image>]\n                                             Initialize a Cloche project\n  health                                   Show project health summary\n  run --workflow <name> [--prompt \"...\"] [--keep-container]\n                                             Launch a workflow run\n  status <run-id>                            Check run status\n  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n                                             Show logs for a run\n  poll <run-id>                              Wait for a run to finish\n  list [--all]                                List runs (last hour by default)\n  stop <run-id>                              Stop a running workflow\n  delete <container-or-run-id>               Delete a retained container\n  orchestrate                                Dispatch ready workflow runs\n  shutdown                                   Shut down the daemon\n`)\n}\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n\tvar image string\n\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n\tif data, err := os.ReadFile(wfPath); err == nil {\n\t\tif wf, err := dsl.Parse(string(data)); err == nil {\n\t\t\timage = wf.Config[\"container.image\"]\n\t\t}\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t}\n\t}\n\n\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s\", run.RunId, run.WorkflowName, run.State)\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\t}\n\t}\n\n\tif follow {\n\t\tcmdLogsFollow(runID)\n\t\treturn\n\t}\n\n\t// Use background context — log output can be large\n\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(entry.Message)\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdLogsFollow(runID string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\t// Strip protocol prefix if present\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\treq.Header.Set(\"Accept\", \"text/event-stream\")\n\n\tresp, err := http.DefaultClient.Do(req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\tscanner := bufio.NewScanner(resp.Body)\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"event: done\") {\n\t\t\tbreak\n\t\t}\n\t\tif !strings.HasPrefix(line, \"data: \") {\n\t\t\tcontinue\n\t\t}\n\t\tdata := strings.TrimPrefix(line, \"data: \")\n\n\t\tvar entry struct {\n\t\t\tTimestamp string `json:\"timestamp\"`\n\t\t\tType      string `json:\"type\"`\n\t\t\tContent   string `json:\"content\"`\n\t\t}\n\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Color-code by type\n\t\tswitch entry.Type {\n\t\tcase \"status\":\n\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tcase \"llm\":\n\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tdefault:\n\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdOrchestrate(ctx context.Context, client pb.ClocheServiceClient) {\n\tcwd, _ := os.Getwd()\n\tresp, err := client.Orchestrate(ctx, &pb.OrchestrateRequest{ProjectDir: cwd})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif resp.Dispatched == 0 {\n\t\tfmt.Println(\"No ready work found.\")\n\t} else {\n\t\tfmt.Printf(\"Dispatched %d run(s).\\n\", resp.Dispatched)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n","numLines":418,"startLine":1,"totalLines":418}}}
