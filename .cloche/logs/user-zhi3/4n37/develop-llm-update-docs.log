n    65→\n    66→var fixPrompt = `Fix the code based on the validation failures below.\n    67→Only modify files that need fixing. Do not rewrite the entire project.\n    68→\n    69→## Validation Output\n    70→(Contents of .cloche/output/*.log will be injected here by the adapter)\n    71→`\n    72→\n    73→var defaultConfigTOML = `# Cloche project configuration\n    74→\n    75→[orchestration]\n    76→enabled     = false\n    77→concurrency = 1\n    78→workflow    = \"develop\"\n    79→# tracker = \"beads\"\n    80→\n    81→[evolution]\n    82→enabled            = true\n    83→debounce_seconds   = 30\n    84→min_confidence     = \"medium\"\n    85→max_prompt_bullets = 50\n    86→`\n    87→\n    88→var updateDocsPrompt = `Review the CLI source code and update usage documentation to reflect any changes.\n    89→\n    90→## What to check\n    91→1. Read cmd/cloche/main.go and cmd/cloche/init.go to understand the current CLI surface\n    92→2. Compare against docs/USAGE.md\n    93→\n    94→## Sections to keep in sync\n    95→- CLI Reference: subcommands, flags, usage examples\n    96→- Setting Up a New Project: scaffolding steps, workflow template\n    97→- Daemon Configuration: environment variables\n    98→- Build Commands: Makefile targets\n    99→\n   100→## Rules\n   101→- Only modify docs/USAGE.md (and docs/workflows.md if workflow DSL syntax changed)\n   102→- Only make changes when there are actual discrepancies — do not rewrite for style\n   103→- If everything is already accurate, make no changes and report success\n   104→`\n   105→\n   106→var versionContent = \"1\\n\"\n   107→\n   108→var hostWorkflowTemplate = `# host.cloche — orchestration workflow (runs on host, not in container)\n   109→# Steps here execute as the daemon user. Keep operations simple and safe.\n   110→\n   111→workflow \"orchestrate\" {\n   112→  step prepare-prompt {\n   113→    run     = \"bash .cloche/scripts/prepare-prompt.sh\"\n   114→    results = [success, fail]\n   115→  }\n   116→\n   117→  step develop {\n   118→    workflow_name = \"develop\"\n   119→    results       = [success, fail]\n   120→  }\n   121→\n   122→  prepare-prompt:success -> develop\n   123→  prepare-prompt:fail    -> abort\n   124→  develop:success        -> done\n   125→  develop:fail           -> done\n   126→}\n   127→`\n   128→\n   129→var preparePromptScript = `#!/usr/bin/env bash\n   130→# Default prompt generator.\n   131→# Writes the task prompt to stdout and to $CLOCHE_STEP_OUTPUT.\n   132→set -euo pipefail\n   133→\n   134→prompt=\"## Task: ${CLOCHE_TASK_TITLE}\n   135→\n   136→${CLOCHE_TASK_BODY}\"\n   137→\n   138→echo \"$prompt\"\n   139→[ -n \"${CLOCHE_STEP_OUTPUT:-}\" ] && echo \"$prompt\" > \"$CLOCHE_STEP_OUTPUT\"\n   140→`\n   141→\n   142→func cmdInit(args []string) {\n   143→\tworkflow := \"develop\"\n   144→\tbaseImage := \"cloche-base:latest\"\n   145→\n   146→\tfor i := 0; i < len(args); i++ {\n   147→\t\tswitch args[i] {\n   148→\t\tcase \"--workflow\":\n   149→\t\t\tif i+1 < len(args) {\n   150→\t\t\t\ti++\n   151→\t\t\t\tworkflow = args[i]\n   152→\t\t\t}\n   153→\t\tcase \"--base-image\":\n   154→\t\t\tif i+1 < len(args) {\n   155→\t\t\t\ti++\n   156→\t\t\t\tbaseImage = args[i]\n   157→\t\t\t}\n   158→\t\t}\n   159→\t}\n   160→\n   161→\tclocheDir := \".cloche\"\n   162→\tworkflowFile := filepath.Join(clocheDir, workflow+\".cloche\")\n   163→\n   164→\t// Refuse to overwrite existing workflow\n   165→\tif _, err := os.Stat(workflowFile); err == nil {\n   166→\t\tfmt.Fprintf(os.Stderr, \"error: %s already exists\\n\", workflowFile)\n   167→\t\tos.Exit(1)\n   168→\t}\n   169→\n   170→\t// Create directories\n   171→\tfor _, dir := range []string{\n   172→\t\tclocheDir,\n   173→\t\tfilepath.Join(clocheDir, \"prompts\"),\n   174→\t\tfilepath.Join(clocheDir, \"overrides\"),\n   175→\t\tfilepath.Join(clocheDir, \"scripts\"),\n   176→\t} {\n   177→\t\tif err := os.MkdirAll(dir, 0755); err != nil {\n   178→\t\t\tfmt.Fprintf(os.Stderr, \"error creating %s/: %v\\n\", dir, err)\n   179→\t\t\tos.Exit(1)\n   180→\t\t}\n   181→\t}\n   182→\n   183→\t// Write all files, skipping any that already exist\n   184→\tfiles := []struct {\n   185→\t\tpath    string\n   186→\t\tcontent string\n   187→\t\tmode    os.FileMode\n   188→\t}{\n   189→\t\t{workflowFile, fmt.Sprintf(workflowTemplate, workflow), 0644},\n   190→\t\t{filepath.Join(clocheDir, \"Dockerfile\"), fmt.Sprintf(dockerfileTemplate, baseImage), 0644},\n   191→\t\t{filepath.Join(clocheDir, \"config.toml\"), defaultConfigTOML, 0644},\n   192→\t\t{filepath.Join(clocheDir, \"prompts\", \"implement.md\"), implementPrompt, 0644},\n   193→\t\t{filepath.Join(clocheDir, \"prompts\", \"fix.md\"), fixPrompt, 0644},\n   194→\t\t{filepath.Join(clocheDir, \"prompts\", \"update-docs.md\"), updateDocsPrompt, 0644},\n   195→\t\t{filepath.Join(clocheDir, \"version\"), versionContent, 0644},\n   196→\t\t{filepath.Join(clocheDir, \"host.cloche\"), hostWorkflowTemplate, 0644},\n   197→\t\t{filepath.Join(clocheDir, \"scripts\", \"prepare-prompt.sh\"), preparePromptScript, 0755},\n   198→\t}\n   199→\n   200→\tfor _, f := range files {\n   201→\t\tif _, err := os.Stat(f.path); err == nil {\n   202→\t\t\tfmt.Fprintf(os.Stderr, \"  skip %s (already exists)\\n\", f.path)\n   203→\t\t\tcontinue\n   204→\t\t}\n   205→\t\tif err := os.WriteFile(f.path, []byte(f.content), f.mode); err != nil {\n   206→\t\t\tfmt.Fprintf(os.Stderr, \"error writing %s: %v\\n\", f.path, err)\n   207→\t\t\tos.Exit(1)\n   208→\t\t}\n   209→\t\tfmt.Fprintf(os.Stderr, \"  create %s\\n\", f.path)\n   210→\t}\n   211→\n   212→\tremoveGitignoreEntries([]string{\n   213→\t\t\".cloche/*/\",\n   214→\t\t\"!.cloche/prompts/\",\n   215→\t\t\"!.cloche/overrides/\",\n   216→\t\t\"!.cloche/evolution/\",\n   217→\t})\n   218→\n   219→\taddGitignoreEntries([]string{\n   220→\t\t\".cloche/*-*-*/\",\n   221→\t\t\".cloche/run-*/\",\n   222→\t\t\".cloche/attempt_count/\",\n   223→\t\t\".gitworktrees/\",\n   224→\t})\n   225→\n   226→