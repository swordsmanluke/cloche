{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TF1WKA6eDcLkPoBPTM1mN3","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1>Projects</h1>\n     3→{{if .Projects}}\n     4→<div class=\"project-cards\">\n     5→    {{range .Projects}}\n     6→    <div class=\"project-card\">\n     7→        <div class=\"project-header\">\n     8→            <span class=\"health-dot health-{{healthColor .Health.Status}}\" title=\"{{.Health.Status}}\"></span>\n     9→            <a href=\"/projects/{{.Label}}\" class=\"project-name\">{{.Label}}</a>\n    10→        </div>\n    11→        <div class=\"project-stats\">\n    12→            <div class=\"stat\">\n    13→                <span class=\"stat-value\">{{.Health.Passed}}/{{.Health.Total}}</span>\n    14→                <span class=\"stat-label\">recent passed</span>\n    15→            </div>\n    16→            <div class=\"stat\">\n    17→                <span class=\"stat-value\">{{.ActiveCount}}</span>\n    18→                <span class=\"stat-label\">active</span>\n    19→            </div>\n    20→        </div>\n    21→        <div class=\"run-history\">\n    22→            {{range .RecentRuns}}\n    23→            <span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span>\n    24→            {{end}}\n    25→        </div>\n    26→        <div class=\"project-actions\">\n    27→            <a href=\"/runs?project={{.Dir}}\" class=\"btn btn-secondary\">View Runs</a>\n    28→            <button class=\"btn btn-primary\" onclick=\"triggerOrchestrator('{{.Label}}', '{{.Dir}}')\">Trigger Orchestrator</button>\n    29→        </div>\n    30→    </div>\n    31→    {{end}}\n    32→</div>\n    33→{{else}}\n    34→<p class=\"empty\">No projects yet. Start a workflow run to see projects here.</p>\n    35→{{end}}\n    36→{{end}}\n    37→\n    38→{{define \"scripts\"}}\n    39→<script>\n    40→function triggerOrchestrator(label, dir) {\n    41→    var btn = event.target;\n    42→    btn.disabled = true;\n    43→    btn.textContent = 'Triggering...';\n    44→    fetch('/api/projects/' + encodeURIComponent(label) + '/trigger', {method: 'POST'})\n    45→        .then(function(r) {\n    46→            if (r.ok) {\n    47→                r.json().then(function(data) {\n    48→                    if (data.dispatched > 0) {\n    49→                        btn.textContent = 'Dispatched ' + data.dispatched;\n    50→                    } else {\n    51→                        btn.textContent = 'No tasks ready';\n    52→                    }\n    53→                    setTimeout(function() {\n    54→                        btn.disabled = false;\n    55→                        btn.textContent = 'Trigger Orchestrator';\n    56→                    }, 2000);\n    57→                });\n    58→            } else {\n    59→                r.json().then(function(data) {\n    60→                    btn.textContent = 'Failed: ' + (data.error || 'unknown');\n    61→                }).catch(function() {\n    62→                    btn.textContent = 'Failed';\n    63→                });\n    64→                setTimeout(function() {\n    65→                    btn.disabled = false;\n    66→                    btn.textContent = 'Trigger Orchestrator';\n    67→                }, 4000);\n    68→            }\n    69→        })\n    70→        .catch(function() {\n    71→            btn.textContent = 'Failed';\n    72→            setTimeout(function() {\n    73→                btn.disabled = false;\n    74→                btn.textContent = 'Trigger Orchestrator';\n    75→            }, 2000);\n    76→        });\n    77→}\n    78→</script>\n    79→{{end}}\n    80→"}]},"parent_tool_use_id":null,"session_id":"5417fe53-38fc-4081-a53f-ab0580b28d18","uuid":"c4a1990f-bc22-47bf-a347-9792b5bc4e6f","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/projects.html","content":"{{define \"content\"}}\n<h1>Projects</h1>\n{{if .Projects}}\n<div class=\"project-cards\">\n    {{range .Projects}}\n    <div class=\"project-card\">\n        <div class=\"project-header\">\n            <span class=\"health-dot health-{{healthColor .Health.Status}}\" title=\"{{.Health.Status}}\"></span>\n            <a href=\"/projects/{{.Label}}\" class=\"project-name\">{{.Label}}</a>\n        </div>\n        <div class=\"project-stats\">\n            <div class=\"stat\">\n                <span class=\"stat-value\">{{.Health.Passed}}/{{.Health.Total}}</span>\n                <span class=\"stat-label\">recent passed</span>\n            </div>\n            <div class=\"stat\">\n                <span class=\"stat-value\">{{.ActiveCount}}</span>\n                <span class=\"stat-label\">active</span>\n            </div>\n        </div>\n        <div class=\"run-history\">\n            {{range .RecentRuns}}\n            <span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span>\n            {{end}}\n        </div>\n        <div class=\"project-actions\">\n            <a href=\"/runs?project={{.Dir}}\" class=\"btn btn-secondary\">View Runs</a>\n            <button class=\"btn btn-primary\" onclick=\"triggerOrchestrator('{{.Label}}', '{{.Dir}}')\">Trigger Orchestrator</button>\n        </div>\n    </div>\n    {{end}}\n</div>\n{{else}}\n<p class=\"empty\">No projects yet. Start a workflow run to see projects here.</p>\n{{end}}\n{{end}}\n\n{{define \"scripts\"}}\n<script>\nfunction triggerOrchestrator(label, dir) {\n    var btn = event.target;\n    btn.disabled = true;\n    btn.textContent = 'Triggering...';\n    fetch('/api/projects/' + encodeURIComponent(label) + '/trigger', {method: 'POST'})\n        .then(function(r) {\n            if (r.ok) {\n                r.json().then(function(data) {\n                    if (data.dispatched > 0) {\n                        btn.textContent = 'Dispatched ' + data.dispatched;\n                    } else {\n                        btn.textContent = 'No tasks ready';\n                    }\n                    setTimeout(function() {\n                        btn.disabled = false;\n                        btn.textContent = 'Trigger Orchestrator';\n                    }, 2000);\n                });\n            } else {\n                r.json().then(function(data) {\n                    btn.textContent = 'Failed: ' + (data.error || 'unknown');\n                }).catch(function() {\n                    btn.textContent = 'Failed';\n                });\n                setTimeout(function() {\n                    btn.disabled = false;\n                    btn.textContent = 'Trigger Orchestrator';\n                }, 4000);\n            }\n        })\n        .catch(function() {\n            btn.textContent = 'Failed';\n            setTimeout(function() {\n                btn.disabled = false;\n                btn.textContent = 'Trigger Orchestrator';\n            }, 2000);\n        });\n}\n</script>\n{{end}}\n","numLines":80,"startLine":1,"totalLines":80}}}
