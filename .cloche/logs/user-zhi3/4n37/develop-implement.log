→\treturn func(h *Handler) { h.orchestrateFn = fn }\n    53→}\n    54→\n    55→// OrchestratorController provides per-project orchestrator control.\n    56→type OrchestratorController interface {\n    57→\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    58→\tSetEnabled(dir string, enabled bool)\n    59→\tSetConcurrency(dir string, concurrency int)\n    60→}\n    61→\n    62→// WithOrchestrator sets the orchestrator controller for project-level control.\n    63→func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    64→\treturn func(h *Handler) { h.orchestrator = oc }\n    65→}\n    66→\n    67→//go:embed templates/*.html static/*\n    68→var content embed.FS\n    69→\n    70→// Handler serves the web dashboard.\n    71→// ContainerLogger can retrieve logs from a container by ID.\n    72→type ContainerLogger interface {\n    73→\tLogs(ctx context.Context, containerID string) (string, error)\n    74→}\n    75→\n    76→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    77→type ContainerManager interface {\n    78→\tContainerLogger\n    79→\tRemove(ctx context.Context, containerID string) error\n    80→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    81→}\n    82→\n    83→type Handler struct {\n    84→\tstore         ports.RunStore\n    85→\tcaptures      ports.CaptureStore\n    86→\tlogStore      ports.LogStore\n    87→\tcontainer     ContainerLogger\n    88→\tlogBroadcast  *logstream.Broadcaster\n    89→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    90→\torchestrator  OrchestratorController\n    91→\tpages         map[string]*template.Template\n    92→\tmux           *http.ServeMux\n    93→}\n    94→\n    95→// NewHandler creates a web dashboard handler.\n    96→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    97→\tfuncMap := template.FuncMap{\n    98→\t\t\"stateColor\":       stateColor,\n    99→\t\t\"healthColor\":      healthColor,\n   100→\t\t\"formatTime\":       formatTime,\n   101→\t\t\"formatDuration\":   formatDuration,\n   102→\t\t\"truncate\":         truncate,\n   103→\t\t\"shortContainerID\": shortContainerID,\n   104→\t}\n   105→\n   106→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   107→\tif err != nil {\n   108→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   109→\t}\n   110→\n   111→\tpages := map[string]*template.Template{}\n   112→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   113→\t\tclone, err := base.Clone()\n   114→\t\tif err != nil {\n   115→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   116→\t\t}\n   117→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   118→\t\tif err != nil {\n   119→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   120→\t\t}\n   121→\t\tpages[page] = clone\n   122→\t}\n   123→\n   124→\th := &Handler{\n   125→\t\tstore:    store,\n   126→\t\tcaptures: captures,\n   127→\t\tpages:    pages,\n   128→\t\tmux:      http.NewServeMux(),\n   129→\t}\n   130→\tfor _, opt := range opts {\n   131→\t\topt(h)\n   132→\t}\n   133→\n   134→\tstaticFS, err := fs.Sub(content, \"static\")\n   135→\tif err != nil {\n   136→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   137→\t}\n   138→\n   139→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   140→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   141→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   142→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   143→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   144→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   145→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   146→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   147→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   148→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   149→\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   150→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   151→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   152→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   153→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   154→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   155→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   156→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   157→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   158→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   159→\n   160→\treturn h, nil\n   161→}\n   162→\n   163→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   164→\th.mux.ServeHTTP(w, r)\n   165→}\n   166→\n   167→// --- HTML handlers ---\n   168→\n   169→// projectOverviewEntry holds data for a single project card on the landing page.\n   170→type projectOverviewEntry struct {\n   171→\tDir         string\n   172→\tLabel       string\n   173→\tHealth      domain.HealthResult\n   174→\tRecentRuns  []recentRunDot\n   175→\tActiveCount int\n   176→}\n   177→\n   178→// recentRunDot is a minimal representation of a run for the mini history display.\n   179→type recentRunDot struct {\n   180→\tID    string\n   181→\tState string\n   182→}\n   183→\n   184→const healthWindowSize = 10\n   185→\n   186→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   187→\tprojects, _ := h.store.ListProjects(r.Context())\n   188→\tlabels := projectLabels(projects)\n   189→\n   190→\tvar entries []projectOverviewEntry\n   191→\tfor _, dir := range projects {\n   192→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   193→\t\tif err != nil {\n   194→\t\t\tcontinue\n   195→\t\t}\n   196→\n   197→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   198→\t\trunValues := make([]domain.Run, len(runs))\n   199→\t\tfor i, rr := range runs {\n   200→\t\t\trunValues[i] = *rr\n   201→\t\t}\n   202→\n   203→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   204→\n   205→\t\t// Take the last N runs for the mini history (most recent first).\n   206→\t\tn := healthWindowSize\n   207→\t\tif n > len(runs) {\n   208→\t\t\tn = len(runs)\n   209→\t\t}\n   210→\t\tdots := make([]recentRunDot, n)\n   211→\t\tfor i := 0; i < n; i++ {\n   212→\t\t\tdots[i] = recentRunDot{\n   213→\t\t\t\tID:    runs[i].ID,\n   214→\t\t\t\tState: string(runs[i].State),\n   215→\t\t\t}\n   216→\t\t}\n   217→\n   218→\t\tvar activeCount int\n   219→\t\tfor _, rr := range runs {\n   220→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   221→\t\t\t\tactiveCount++\n   222→\t\t\t}\n   223→\t\t}\n   224→\n   225→\t\tentries = append(entries, projectOverviewEntry{\n   226→\t\t\tDir:         dir,\n   227→\t\t\tLabel:       labels[dir],\n   228→\t\t\tHealth:      health,\n   229→\t\t\tRecentRuns:  dots,\n   230→\t\t\tActiveCount: activeCount,\n   231→\t\t})\n   232→\t}\n   233→\n   234→\tsort.Slice(entries, func(i, j int) bool {\n   235→\t\treturn entries[i].Label < entries[j].Label\n   236→\t})\n   237→\n   238→\tdata := map[string]any{\n   239→\t\t\"Title\":    \"Projects\",\n   240→\t\t\"Projects\": entries,\n   241→\t}\n   242→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   243→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   244→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   245→\t}\n   246→}\n   247→\n   248→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   249→\tprojectFilter := r.URL.Query().Get(\"project\")\n   250→\n   251→\tvar runs []*domain.Run\n   252→\tvar err error\n   253→\tif projectFilter != \"\" {\n   254→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   255→\t} else {\n   256→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   257→\t}\n   258→\tif err != nil {\n   259→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   260→\t\treturn\n   261→\t}\n   262→\n   263→\tprojects, _ := h.store.ListProjects(r.Context())\n   264→\tlabels := projectLabels(projects)\n   265→\n   266→\t// Count retained containers per project\n   267→\tcontainerCounts := map[string]int{}\n   268→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   269→\tfor _, run := range allRuns {\n   270→\t\tif run.ContainerKept {\n   271→\t\t\tcontainerCounts[run.ProjectDir]++\n   272→\t\t}\n   273→\t}\n   274→\n   275→\tvar projectList []projectEntry\n   276→\tfor _, dir := range projects {\n   277→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   278→\t}\n   279→\tsort.Slice(projectList, func(i, j int) bool {\n   280→\t\treturn projectList[i].Label < projectList[j].Label\n   281→\t})\n   282→\n   283→\tdata := map[string]any{\n   284→\t\t\"Title\":         \"Runs\",\n   285→\t\t\"Runs\":          runs,\n   286→\t\t\"Projects\":      projectList,\n   287→\t\t\"ProjectFilter\": projectFilter,\n   288→\t\t\"ProjectLabels\": labels,\n   289→\t}\n   290→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   291→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   292→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   293→\t}\n   294→}\n   295→\n   296→// stepEntry is a merged view of a step execution for the template.\n   297→type stepEntry struct {\n   298→\tIndex     int\n   299→\tStepName  string\n   300→\tResult    string\n   301→\tStartedAt time.Time\n   302→\tDuration  string\n   303→}\n   304→\n   305→// mergeCaptures collapses started/completed capture pairs into single entries.\n   306→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   307→\tvar entries []stepEntry\n   308→\t// Track pending started rows by step name (LIFO for retries)\n   309→\tpending := map[string]*domain.StepExecution{}\n   310→\n   311→\tfor _, c := range caps {\n   312→\t\tif c.Result == \"\" {\n   313→\t\t\t// step_started row\n   314→\t\t\tpending[c.StepName] = c\n   315→\t\t\tcontinue\n   316→\t\t}\n   317→\t\t// step_completed row — merge with pending started if available\n   318→\t\tstartedAt := c.StartedAt\n   319→\t\tif started := pending[c.StepName]; started != nil {\n   320→\t\t\tstartedAt = started.StartedAt\n   321→\t\t\tdelete(pending, c.StepName)\n   322→\t\t}\n   323→\t\tentries = append(entries, stepEntry{\n   324→\t\t\tIndex:     len(entries),\n   325→\t\t\tStepName:  c.StepName,\n   326→\t\t\tResult:    c.Result,\n   327→\t\t\tStartedAt: startedAt,\n   328→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   329→\t\t})\n   330→\t}\n   331→\n   332→\t// Append any started-but-not-completed steps (still running)\n   333→\tfor _, c := range caps {\n   334→\t\tif c.Result == \"\" {\n   335→\t\t\tif _, used := pending[c.StepName]; !used {\n   336→\t\t\t\tcontinue\n   337→\t\t\t}\n   338→\t\t\tentries = append(entries, stepEntry{\n   339→\t\t\t\tIndex:     len(entries),\n   340→\t\t\t\tStepName:  c.StepName,\n   341→\t\t\t\tStartedAt: c.StartedAt,\n   342→\t\t\t})\n   343→\t\t\tdelete(pending, c.StepName)\n   344→\t\t}\n   345→\t}\n   346→\n   347→\treturn entries\n   348→}\n   349→\n   350→// containerState inspects the container for a run and returns one of:\n   351→//   - \"running\"   – container exists and is running\n   352→//   - \"stopped\"   – container exists, not running, not kept\n   353→//   - \"available\" – container exists, not running, kept (can be deleted)\n   354→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   355→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   356→\tif run.ContainerID == \"\" {\n   357→\t\treturn \"removed\"\n   358→\t}\n   359→\tmgr, ok := h.container.(ContainerManager)\n   360→\tif !ok {\n   361→\t\treturn \"removed\"\n   362→\t}\n   363→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   364→\tif err != nil {\n   365→\t\treturn \"removed\"\n   366→\t}\n   367→\tif status.Running {\n   368→\t\treturn \"running\"\n   369→\t}\n   370→\tif run.ContainerKept {\n   371→\t\treturn \"available\"\n   372→\t}\n   373→\treturn \"stopped\"\n   374→}\n   375→\n   376→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   377→\tid := r.PathValue(\"id\")\n   378→\n   379→\trun, err := h.store.GetRun(r.Context(), id)\n   380→\tif err != nil {\n   381→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   382→\t\treturn\n   383→\t}\n   384→\n   385→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   386→\tif err != nil {\n   387→\t\tcaps = nil // non-fatal\n   388→\t}\n   389→\n   390→\tsteps := mergeCaptures(caps)\n   391→\n   392→\tdata := map[string]any{\n   393→\t\t\"Title\":          \"Run \" + run.ID,\n   394→\t\t\"Run\":            run,\n   395→\t\t\"Steps\":          steps,\n   396→\t\t\"Page\":           \"detail\",\n   397→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   398→\t}\n   399→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   400→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   401→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   402→\t}\n   403→}\n   404→\n   405→// --- JSON API handlers ---\n   406→\n   407→type apiRun struct {\n   408→\tID           string `json:\"id\"`\n   409→\tWorkflowName string `json:\"workflow_name\"`\n   410→\tProjectDir   string `json:\"project_dir\"`\n   411→\tProjectLabel string `json:\"project_label\"`\n   412→\tState        string `json:\"state\"`\n   413→\tStartedAt    string `json:\"started_at\"`\n   414→\tCompletedAt  string `json:\"completed_at\"`\n   415→\tContainerID  string `json:\"container_id\"`\n   416→\tErrorMessage string `json:\"error_message\"`\n   417→}\n   418→\n   419→type apiStep struct {\n   420→\tStepName    string `json:\"step_name\"`\n   421→\tResult      string `json:\"result\"`\n   422→\tStartedAt   string `json:\"started_at\"`\n   423→\tCompletedAt string `json:\"completed_at\"`\n   424→\tDuration    string `json:\"duration\"`\n   425→}\n   426→\n   427→type apiRunDetail struct {\n   428→\tapiRun\n   429→\tContainerState string    `json:\"container_state\"`\n   430→\tSteps          []apiStep `json:\"steps\"`\n   431→}\n   432→\n   433→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   434→\treturn apiRun{\n   435→\t\tID:           r.ID,\n   436→\t\tWorkflowName: r.WorkflowName,\n   437→\t\tProjectDir:   r.ProjectDir,\n   438→\t\tProjectLabel: labels[r.ProjectDir],\n   439→\t\tState:        string(r.State),\n   440→\t\tStartedAt:    formatTime(r.StartedAt),\n   441→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   442→\t\tContainerID:  r.ContainerID,\n   443→\t\tErrorMessage: r.ErrorMessage,\n   444→\t}\n   445→}\n   446→\n   447→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   448→\tprojectFilter := r.URL.Query().Get(\"project\")\n   449→\n   450→\tvar runs []*domain.Run\n   451→\tvar err error\n   452→\tif projectFilter != \"\" {\n   453→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   454→\t} else {\n   455→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   456→\t}\n   457→\tif err != nil {\n   458→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   459→\t\treturn\n   460→\t}\n   461→\n   462→\tprojects, _ := h.store.ListProjects(r.Context())\n   463→\tlabels := projectLabels(projects)\n   464→\n   465→\tresult := make([]apiRun, len(runs))\n   466→\tfor i, run := range runs {\n   467→\t\tresult[i] = toAPIRun(run, labels)\n   468→\t}\n   469→\n   470→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   471→\tjson.NewEncoder(w).Encode(result)\n   472→}\n   473→\n   474→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   475→\tprojects, err := h.store.ListProjects(r.Context())\n   476→\tif err != nil {\n   477→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   478→\t\treturn\n   479→\t}\n   480→\tlabels := projectLabels(projects)\n   481→\n   482→\ttype apiHealth struct {\n   483→\t\tStatus string `json:\"status\"`\n   484→\t\tPassed int    `json:\"passed\"`\n   485→\t\tFailed int    `json:\"failed\"`\n   486→\t\tTotal  int    `json:\"total\"`\n   487→\t}\n   488→\ttype apiProject struct {\n   489→\t\tDir         string    `json:\"dir\"`\n   490→\t\tLabel       string    `json:\"label\"`\n   491→\t\tHealth      apiHealth `json:\"health\"`\n   492→\t\tActiveCount int       `json:\"active_count\"`\n   493→\t}\n   494→\tresult := make([]apiProject, len(projects))\n   495→\tfor i, dir := range projects {\n   496→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   497→\t\trunValues := make([]domain.Run, len(runs))\n   498→\t\tfor j, rr := range runs {\n   499→\t\t\trunValues[j] = *rr\n   500→\t\t}\n   501→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   502→\t\tvar activeCount int\n   503→\t\tfor _, rr := range runs {\n   504→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   505→\t\t\t\tactiveCount++\n   506→\t\t\t}\n   507→\t\t}\n   508→\t\tresult[i] = apiProject{\n   509→\t\t\tDir:   dir,\n   510→\t\t\tLabel: labels[dir],\n   511→\t\t\tHealth: apiHealth{\n   512→\t\t\t\tStatus: string(health.Status),\n   513→\t\t\t\tPassed: health.Passed,\n   514→\t\t\t\tFailed: health.Failed,\n   515→\t\t\t\tTotal:  health.Total,\n   516→\t\t\t},\n   517→\t\t\tActiveCount: activeCount,\n   518→\t\t}\n   519→\t}\n   520→\n   521→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   522→\tjson.NewEncoder(w).Encode(result)\n   523→}\n   524→\n   525→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   526→\tid := r.PathValue(\"id\")\n   527→\n   528→\trun, err := h.store.GetRun(r.Context(), id)\n   529→\tif err != nil {\n   530→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   531→\t\treturn\n   532→\t}\n   533→\n   534→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   535→\tif err != nil {\n   536→\t\tcaps = nil\n   537→\t}\n   538→\n   539→\tprojects, _ := h.store.ListProjects(r.Context())\n   540→\tlabels := projectLabels(projects)\n   541→\n   542→\tmerged := mergeCaptures(caps)\n   543→\tsteps := make([]apiStep, len(merged))\n   544→\tfor i, e := range merged {\n   545→\t\tsteps[i] = apiStep{\n   546→\t\t\tStepName:  e.StepName,\n   547→\t\t\tResult:    e.Result,\n   548→\t\t\tStartedAt: formatTime(e.StartedAt),\n   549→\t\t\tDuration:  e.Duration,\n   550→\t\t}\n   551→\t}\n   552→\n   553→\tdetail := apiRunDetail{\n   554→\t\tapiRun:         toAPIRun(run, labels),\n   555→\t\tContainerState: h.containerState(r.Context(), run),\n   556→\t\tSteps:          steps,\n   557→\t}\n   558→\n   559→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   560→\tjson.NewEncoder(w).Encode(detail)\n   561→}\n   562→\n   563→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   564→\tid := r.PathValue(\"id\")\n   565→\tstep := r.PathValue(\"step\")\n   566→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   567→\n   568→\trun, err := h.store.GetRun(r.Context(), id)\n   569→\tif err != nil {\n   570→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   571→\t\treturn\n   572→\t}\n   573→\n   574→\t// Try log index first for fast lookup\n   575→\tif h.logStore != nil {\n   576→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   577→\t\tif err == nil && len(logFiles) > 0 {\n   578→\t\t\t// If type filter specified, narrow results\n   579→\t\t\tfor _, lf := range logFiles {\n   580→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   581→\t\t\t\t\tcontinue\n   582→\t\t\t\t}\n   583→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   584→\t\t\t\tif readErr == nil && len(data) > 0 {\n   585→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   586→\t\t\t\t\tw.Write(data)\n   587→\t\t\t\t\treturn\n   588→\t\t\t\t}\n   589→\t\t\t}\n   590→\t\t}\n   591→\t}\n   592→\n   593→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   594→\n   595→\t// Fall back to file path conventions\n   596→\t// If type is \"llm\", try llm-<step>.log\n   597→\tif logType == \"llm\" {\n   598→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   599→\t\tdata, err := os.ReadFile(llmPath)\n   600→\t\tif err == nil && len(data) > 0 {\n   601→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   602→\t\t\tw.Write(data)\n   603→\t\t\treturn\n   604→\t\t}\n   605→\t}\n   606→\n   607→\t// Try per-step output first, fall back to container.log, then live docker logs\n   608→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   609→\tdata, err := os.ReadFile(outputPath)\n   610→\tif err == nil && len(data) > 0 {\n   611→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   612→\t\tw.Write(data)\n   613→\t\treturn\n   614→\t}\n   615→\n   616→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   617→\tdata, err = os.ReadFile(containerLog)\n   618→\tif err == nil && len(data) > 0 {\n   619→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   620→\t\tw.Write(data)\n   621→\t\treturn\n   622→\t}\n   623→\n   624→\t// Last resort: try live docker logs from still-existing container\n   625→\tif h.container != nil && run.ContainerID != \"\" {\n   626→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   627→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   628→\t\t\tw.Write([]byte(logs))\n   629→\t\t\treturn\n   630→\t\t}\n   631→\t}\n   632→\n   633→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   634→}\n   635→\n   636→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   637→\tid := r.PathValue(\"id\")\n   638→\n   639→\trun, err := h.store.GetRun(r.Context(), id)\n   640→\tif err != nil {\n   641→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   642→\t\tw.WriteHeader(http.StatusNotFound)\n   643→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   644→\t\treturn\n   645→\t}\n   646→\n   647→\tmgr, ok := h.container.(ContainerManager)\n   648→\tif !ok || run.ContainerID == \"\" {\n   649→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   650→\t\tw.WriteHeader(http.StatusBadRequest)\n   651→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   652→\t\treturn\n   653→\t}\n   654→\n   655→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   656→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   657→\t\tw.WriteHeader(http.StatusInternalServerError)\n   658→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   659→\t\treturn\n   660→\t}\n   661→\n   662→\trun.ContainerKept = false\n   663→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   664→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   665→\t\tw.WriteHeader(http.StatusInternalServerError)\n   666→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   667→\t\treturn\n   668→\t}\n   669→\n   670→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   671→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   672→}\n   673→\n   674→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   675→\tlabel := r.PathValue(\"name\")\n   676→\n   677→\t// Resolve label back to project directory via the store.\n   678→\tprojects, _ := h.store.ListProjects(r.Context())\n   679→\tlabels := projectLabels(projects)\n   680→\tvar projectDir string\n   681→\tfor dir, l := range labels {\n   682→\t\tif l == label {\n   683→\t\t\tprojectDir = dir\n   684→\t\t\tbreak\n   685→\t\t}\n   686→\t}\n   687→\tif projectDir == \"\" {\n   688→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   689→\t\tw.WriteHeader(http.StatusNotFound)\n   690→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   691→\t\treturn\n   692→\t}\n   693→\n   694→\tif h.orchestrateFn == nil {\n   695→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   696→\t\tw.WriteHeader(http.StatusNotImplemented)\n   697→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   698→\t\treturn\n   699→\t}\n   700→\n   701→\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   702→\tif err != nil {\n   703→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   704→\t\tw.WriteHeader(http.StatusInternalServerError)\n   705→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   706→\t\treturn\n   707→\t}\n   708→\n   709→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   710→\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   711→}\n   712→\n   713→// handleAPIStream serves an SSE stream of log lines for a run.\n   714→// For active runs, it subscribes to the live broadcaster.\n   715→// For completed runs, it serves the archived full.log then closes.\n   716→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   717→\tid := r.PathValue(\"id\")\n   718→\n   719→\trun, err := h.store.GetRun(r.Context(), id)\n   720→\tif err != nil {\n   721→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   722→\t\treturn\n   723→\t}\n   724→\n   725→\tflusher, ok := w.(http.Flusher)\n   726→\tif !ok {\n   727→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   728→\t\treturn\n   729→\t}\n   730→\n   731→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   732→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   733→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   734→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   735→\n   736→\tisComplete := run.State == domain.RunStateSucceeded ||\n   737→\t\trun.State == domain.RunStateFailed ||\n   738→\t\trun.State == domain.RunStateCancelled\n   739→\n   740→\tif isComplete {\n   741→\t\t// Serve archived full.log\n   742→\t\th.streamFullLog(w, flusher, run)\n   743→\t\t// Send done event\n   744→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   745→\t\tflusher.Flush()\n   746→\t\treturn\n   747→\t}\n   748→\n   749→\t// Active run: subscribe to live broadcaster\n   750→\tif h.logBroadcast == nil {\n   751→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   752→\t\treturn\n   753→\t}\n   754→\n   755→\tsub := h.logBroadcast.Subscribe(id)\n   756→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   757→\n   758→\tctx := r.Context()\n   759→\tfor {\n   760→\t\tselect {\n   761→\t\tcase <-ctx.Done():\n   762→\t\t\treturn\n   763→\t\tcase line, ok := <-sub.C:\n   764→\t\t\tif !ok {\n   765→\t\t\t\t// Stream finished (run completed)\n   766→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   767→\t\t\t\tflusher.Flush()\n   768→\t\t\t\treturn\n   769→\t\t\t}\n   770→\t\t\tdata, _ := json.Marshal(line)\n   771→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   772→\t\t\tflusher.Flush()\n   773→\t\t}\n   774→\t}\n   775→}\n   776→\n   777→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   778→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   779→\n   780→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   781→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   782→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   783→\tf, err := os.Open(logPath)\n   784→\tif err != nil {\n   785→\t\treturn\n   786→\t}\n   787→\tdefer f.Close()\n   788→\n   789→\tscanner := bufio.NewScanner(f)\n   790→\tfor scanner.Scan() {\n   791→\t\ttext := scanner.Text()\n   792→\t\tline := parseFullLogLine(text)\n   793→\t\tdata, _ := json.Marshal(line)\n   794→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   795→\t\tflusher.Flush()\n   796→\t}\n   797→}\n   798→\n   799→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   800→func parseFullLogLine(text string) logstream.LogLine {\n   801→\tm := logLineRegex.FindStringSubmatch(text)\n   802→\tif m == nil {\n   803→\t\treturn logstream.LogLine{\n   804→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   805→\t\t\tType:      \"script\",\n   806→\t\t\tContent:   text,\n   807→\t\t}\n   808→\t}\n   809→\treturn logstream.LogLine{\n   810→\t\tTimestamp: m[1],\n   811→\t\tType:      m[2],\n   812→\t\tContent:   m[3],\n   813→\t}\n   814→}\n   815→\n   816→// --- Project detail handlers ---\n   817→\n   818→// resolveProjectDir resolves a project label from the URL to its directory path.\n   819→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   820→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   821→\tlabel := r.PathValue(\"name\")\n   822→\tprojects, _ := h.store.ListProjects(r.Context())\n   823→\tlabels := projectLabels(projects)\n   824→\tfor dir, l := range labels {\n   825→\t\tif l == label {\n   826→\t\t\treturn dir, label, true\n   827→\t\t}\n   828→\t}\n   829→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   830→\tw.WriteHeader(http.StatusNotFound)\n   831→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   832→\treturn \"\", \"\", false\n   833→}\n   834→\n   835→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   836→\tdir, label, ok := h.resolveProjectDir(w, r)\n   837→\tif !ok {\n   838→\t\treturn\n   839→\t}\n   840→\n   841→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   842→\tn := 10\n   843→\tif n > len(runs) {\n   844→\t\tn = len(runs)\n   845→\t}\n   846→\tdots := make([]recentRunDot, n)\n   847→\tfor i := 0; i < n; i++ {\n   848→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   849→\t}\n   850→\n   851→\tdata := map[string]any{\n   852→\t\t\"Title\":      label,\n   853→\t\t\"Label\":      label,\n   854→\t\t\"Dir\":        dir,\n   855→\t\t\"RecentRuns\": dots,\n   856→\t}\n   857→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   858→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   859→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   860→\t}\n   861→}\n   862→\n   863→func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   864→\tdir, _, ok := h.resolveProjectDir(w, r)\n   865→\tif !ok {\n   866→\t\treturn\n   867→\t}\n   868→\tif h.orchestrator == nil {\n   869→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   870→\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   871→\t\treturn\n   872→\t}\n   873→\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   874→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   875→\tjson.NewEncoder(w).Encode(map[string]any{\n   876→\t\t\"enabled\":     enabled,\n   877→\t\t\"in_flight\":   inFlight,\n   878→\t\t\"concurrency\": concurrency,\n   879→\t})\n   880→}\n   881→\n   882→func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   883→\tdir, _, ok := h.resolveProjectDir(w, r)\n   884→\tif !ok {\n   885→\t\treturn\n   886→\t}\n   887→\tif h.orchestrator == nil {\n   888→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   889→\t\tw.WriteHeader(http.StatusNotImplemented)\n   890→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   891→\t\treturn\n   892→\t}\n   893→\th.orchestrator.SetEnabled(dir, true)\n   894→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   895→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   896→}\n   897→\n   898→func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   899→\tdir, _, ok := h.resolveProjectDir(w, r)\n   900→\tif !ok {\n   901→\t\treturn\n   902→\t}\n   903→\tif h.orchestrator == nil {\n   904→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   905→\t\tw.WriteHeader(http.StatusNotImplemented)\n   906→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   907→\t\treturn\n   908→\t}\n   909→\th.orchestrator.SetEnabled(dir, false)\n   910→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   911→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   912→}\n   913→\n   914→func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   915→\tdir, _, ok := h.resolveProjectDir(w, r)\n   916→\tif !ok {\n   917→\t\treturn\n   918→\t}\n   919→\tif h.orchestrator == nil {\n   920→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   921→\t\tw.WriteHeader(http.StatusNotImplemented)\n   922→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   923→\t\treturn\n   924→\t}\n   925→\tvar body struct {\n   926→\t\tConcurrency int `json:\"concurrency\"`\n   927→\t}\n   928→\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n   929→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   930→\t\tw.WriteHeader(http.StatusBadRequest)\n   931→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n   932→\t\treturn\n   933→\t}\n   934→\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n   935→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   936→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   937→}\n   938→\n   939→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   940→\tdir, _, ok := h.resolveProjectDir(w, r)\n   941→\tif !ok {\n   942→\t\treturn\n   943→\t}\n   944→\n   945→\t// Docker image: read FROM line from Dockerfile\n   946→\tdockerImage := \"\"\n   947→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   948→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   949→\t\t// Find the last FROM line (final stage)\n   950→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   951→\t\t\ttrimmed := strings.TrimSpace(line)\n   952→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   953→\t\t\t\tparts := strings.Fields(trimmed)\n   954→\t\t\t\tif len(parts) >= 2 {\n   955→\t\t\t\t\tdockerImage = parts[1]\n   956→\t\t\t\t}\n   957→\t\t\t}\n   958→\t\t}\n   959→\t}\n   960→\n   961→\t// Version\n   962→\tversion := 0\n   963→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   964→\tif data, err := os.ReadFile(versionPath); err == nil {\n   965→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   966→\t\t\tversion = v\n   967→\t\t}\n   968→\t}\n   969→\n   970→\t// Prompt files history\n   971→\ttype commitEntry struct {\n   972→\t\tSHA     string `json:\"sha\"`\n   973→\t\tDate    string `json:\"date\"`\n   974→\t\tMessage string `json:\"message\"`\n   975→\t}\n   976→\ttype promptFile struct {\n   977→\t\tPath    string        `json:\"path\"`\n   978→\t\tHistory []commitEntry `json:\"history\"`\n   979→\t}\n   980→\n   981→\tvar promptFiles []promptFile\n   982→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   983→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n   984→\t\tfor _, e := range entries {\n   985→\t\t\tif e.IsDir() {\n   986→\t\t\t\tcontinue\n   987→\t\t\t}\n   988→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n   989→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n   990→\t\t\tcmd.Dir = dir\n   991→\t\t\tout, err := cmd.Output()\n   992→\t\t\tif err != nil {\n   993→\t\t\t\tcontinue\n   994→\t\t\t}\n   995→\t\t\tvar history []commitEntry\n   996→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n   997→\t\t\t\tif line == \"\" {\n   998→\t\t\t\t\tcontinue\n   999→\t\t\t\t}\n  1000→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1001→\t\t\t\tif len(parts) < 3 {\n  1002→\t\t\t\t\tcontinue\n  1003→\t\t\t\t}\n  1004→\t\t\t\t// Parse date to short form\n  1005→\t\t\t\tdateStr := parts[1]\n  1006→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1007→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1008→\t\t\t\t}\n  1009→\t\t\t\thistory = append(history, commitEntry{\n  1010→\t\t\t\t\tSHA:     parts[0][:7],\n  1011→\t\t\t\t\tDate:    dateStr,\n  1012→\t\t\t\t\tMessage: parts[2],\n  1013→\t\t\t\t})\n  1014→\t\t\t}\n  1015→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1016→\t\t}\n  1017→\t}\n  1018→\n  1019→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1020→\tjson.NewEncoder(w).Encode(map[string]any{\n  1021→\t\t\"docker_image\": dockerImage,\n  1022→\t\t\"version\":      version,\n  1023→\t\t\"prompt_files\": promptFiles,\n  1024→\t})\n  1025→}\n  1026→\n  1027→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1028→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1029→\tif !ok {\n  1030→\t\treturn\n  1031→\t}\n  1032→\tfile := r.URL.Query().Get(\"file\")\n  1033→\tsha := r.URL.Query().Get(\"sha\")\n  1034→\tif file == \"\" || sha == \"\" {\n  1035→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1036→\t\treturn\n  1037→\t}\n  1038→\n  1039→\t// Validate sha is alphanumeric to prevent injection\n  1040→\tfor _, c := range sha {\n  1041→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1042→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1043→\t\t\treturn\n  1044→\t\t}\n  1045→\t}\n  1046→\n  1047→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1048→\tcmd.Dir = dir\n  1049→\tout, err := cmd.Output()\n  1050→\tif err != nil {\n  1051→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1052→\t\treturn\n  1053→\t}\n  1054→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1055→\tw.Write(out)\n  1056→}\n  1057→\n  1058→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1059→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1060→\tif !ok {\n  1061→\t\treturn\n  1062→\t}\n  1063→\n  1064→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1065→\tentries, err := os.ReadDir(clocheDir)\n  1066→\tif err != nil {\n  1067→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1068→\t\tjson.NewEncoder(w).Encode([]any{})\n  1069→\t\treturn\n  1070→\t}\n  1071→\n  1072→\ttype apiWire struct {\n  1073→\t\tFrom   string `json:\"from\"`\n  1074→\t\tResult string `json:\"result\"`\n  1075→\t\tTo     string `json:\"to\"`\n  1076→\t}\n  1077→\ttype apiStepDef struct {\n  1078→\t\tName    string            `json:\"name\"`\n  1079→\t\tType    string            `json:\"type\"`\n  1080→\t\tResults []string          `json:\"results\"`\n  1081→\t\tConfig  map[string]string `json:\"config\"`\n  1082→\t}\n  1083→\ttype apiWorkflow struct {\n  1084→\t\tName      string       `json:\"name\"`\n  1085→\t\tFile      string       `json:\"file\"`\n  1086→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1087→\t\tWires     []apiWire    `json:\"wires\"`\n  1088→\t\tEntryStep string       `json:\"entry_step\"`\n  1089→\t}\n  1090→\n  1091→\tvar workflows []apiWorkflow\n  1092→\tfor _, e := range entries {\n  1093→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1094→\t\t\tcontinue\n  1095→\t\t}\n  1096→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1097→\t\tif err != nil {\n  1098→\t\t\tcontinue\n  1099→\t\t}\n  1100→\t\twf, err := dsl.Parse(string(data))\n  1101→\t\tif err != nil {\n  1102→\t\t\tcontinue\n  1103→\t\t}\n  1104→\t\tvar steps []apiStepDef\n  1105→\t\tfor _, s := range wf.Steps {\n  1106→\t\t\tsteps = append(steps, apiStepDef{\n  1107→\t\t\t\tName:    s.Name,\n  1108→\t\t\t\tType:    string(s.Type),\n  1109→\t\t\t\tResults: s.Results,\n  1110→\t\t\t\tConfig:  s.Config,\n  1111→\t\t\t})\n  1112→\t\t}\n  1113→\t\t// Sort steps by name for consistent ordering\n  1114→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1115→\n  1116→\t\tvar wires []apiWire\n  1117→\t\tfor _, wire := range wf.Wiring {\n  1118→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1119→\t\t}\n  1120→\n  1121→\t\tworkflows = append(workflows, apiWorkflow{\n  1122→\t\t\tName:      wf.Name,\n  1123→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1124→\t\t\tSteps:     steps,\n  1125→\t\t\tWires:     wires,\n  1126→\t\t\tEntryStep: wf.EntryStep,\n  1127→\t\t})\n  1128→\t}\n  1129→\n  1130→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1131→\tjson.NewEncoder(w).Encode(workflows)\n  1132→}\n  1133→\n  1134→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1135→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1136→\tif !ok {\n  1137→\t\treturn\n  1138→\t}\n  1139→\tworkflowName := r.PathValue(\"workflow\")\n  1140→\tstepName := r.PathValue(\"step\")\n  1141→\n  1142→\t// Find the workflow file\n  1143→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1144→\tvar wf *domain.Workflow\n  1145→\tentries, _ := os.ReadDir(clocheDir)\n  1146→\tfor _, e := range entries {\n  1147→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1148→\t\t\tcontinue\n  1149→\t\t}\n  1150→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1151→\t\tif err != nil {\n  1152→\t\t\tcontinue\n  1153→\t\t}\n  1154→\t\tparsed, err := dsl.Parse(string(data))\n  1155→\t\tif err != nil {\n  1156→\t\t\tcontinue\n  1157→\t\t}\n  1158→\t\tif parsed.Name == workflowName {\n  1159→\t\t\twf = parsed\n  1160→\t\t\tbreak\n  1161→\t\t}\n  1162→\t}\n  1163→\tif wf == nil {\n  1164→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1165→\t\treturn\n  1166→\t}\n  1167→\n  1168→\tstep, ok := wf.Steps[stepName]\n  1169→\tif !ok {\n  1170→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1171→\t\treturn\n  1172→\t}\n  1173→\n  1174→\t// Try to read the referenced file from step config\n  1175→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1176→\n  1177→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1178→\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1179→\t\tif err == nil {\n  1180→\t\t\tw.Write(data)\n  1181→\t\t\treturn\n  1182→\t\t}\n  1183→\t}\n  1184→\tif script := step.Config[\"command\"]; script != \"\" {\n  1185→\t\tw.Write([]byte(script))\n  1186→\t\treturn\n  1187→\t}\n  1188→\tif script := step.Config[\"script\"]; script != \"\" {\n  1189→\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1190→\t\tif err == nil {\n  1191→\t\t\tw.Write(data)\n  1192→\t\t\treturn\n  1193→\t\t}\n  1194→\t\tw.Write([]byte(script))\n  1195→\t\treturn\n  1196→\t}\n  1197→\n  1198→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1199→}\n  1200→\n  1201→// --- Template helpers ---\n  1202→\n  1203→func stateColor(state domain.RunState) string {\n  1204→\tswitch state {\n  1205→\tcase domain.RunStatePending:\n  1206→\t\treturn \"pending\"\n  1207→\tcase domain.RunStateRunning:\n  1208→\t\treturn \"running\"\n  1209→\tcase domain.RunStateSucceeded:\n  1210→\t\treturn \"succeeded\"\n  1211→\tcase domain.RunStateFailed:\n  1212→\t\treturn \"failed\"\n  1213→\tcase domain.RunStateCancelled:\n  1214→\t\treturn \"cancelled\"\n  1215→\tdefault:\n  1216→\t\treturn \"pending\"\n  1217→\t}\n  1218→}\n  1219→\n  1220→func healthColor(status domain.HealthStatus) string {\n  1221→\tswitch status {\n  1222→\tcase domain.HealthGreen:\n  1223→\t\treturn \"green\"\n  1224→\tcase domain.HealthYellow:\n  1225→\t\treturn \"yellow\"\n  1226→\tcase domain.HealthRed:\n  1227→\t\treturn \"red\"\n  1228→\tcase domain.HealthBlue:\n  1229→\t\treturn \"blue\"\n  1230→\tdefault:\n  1231→\t\treturn \"grey\"\n  1232→\t}\n  1233→}\n  1234→\n  1235→func formatTime(t time.Time) string {\n  1236→\tif t.IsZero() {\n  1237→\t\treturn \"\"\n  1238→\t}\n  1239→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1240→}\n  1241→\n  1242→func formatDuration(start, end time.Time) string {\n  1243→\tif start.IsZero() || end.IsZero() {\n  1244→\t\treturn \"\"\n  1245→\t}\n  1246→\td := end.Sub(start)\n  1247→\tif d < time.Second {\n  1248→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1249→\t}\n  1250→\tif d < time.Minute {\n  1251→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1252→\t}\n  1253→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1254→}\n  1255→\n  1256→func truncate(s string, n int) string {\n  1257→\tif len(s) <= n {\n  1258→\t\treturn s\n  1259→\t}\n  1260→\treturn s[:n] + \"...\"\n  1261→}\n  1262→\n  1263→func shortContainerID(id string) string {\n  1264→\tif len(id) > 12 {\n  1265→\t\treturn id[:12]\n  1266→\t}\n  1267→\treturn id\n  1268→}\n  1269→\n  1270→// projectLabels builds a mapping from full project directory paths to short\n  1271→// display labels. Each label is the final directory component (e.g.\n  1272→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1273→// the same final name, the parent directory is prepended to disambiguate\n  1274→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1275→func projectLabels(dirs []string) map[string]string {\n  1276→\tlabels := make(map[string]string, len(dirs))\n  1277→\t// Group dirs by their base name to detect conflicts.\n  1278→\tbyBase := map[string][]string{}\n  1279→\tfor _, d := range dirs {\n  1280→\t\tbase := filepath.Base(d)\n  1281→\t\tbyBase[base] = append(byBase[base], d)\n  1282→\t}\n  1283→\tfor base, paths := range byBase {\n  1284→\t\tif len(paths) == 1 {\n  1285→\t\t\tlabels[paths[0]] = base\n  1286→\t\t} else {\n  1287→\t\t\tfor _, p := range paths {\n  1288→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1289→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1290→\t\t\t}\n  1291→\t\t}\n  1292→\t}\n  1293→\treturn labels\n  1294→}\n  1295→\n  1296→type projectEntry struct {\n  1297→\tDir            string\n  1298→\tLabel          string\n  1299→\tContainerCount int\n  1300→}\n  1301→"}]},"parent_tool_use_id":"toolu_01XYC7icoCRqW2gyD33ayddi","session_id":"5417fe53-38fc-4081-a53f-ab0580b28d18","uuid":"f3e4e2bd-3755-4dcb-b31e-d42b696b8ebe"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016742THo6bRKxGyqqmhL2Uk","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    19→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    20→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    21→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    22→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    23→\trpcgrpc \"google.golang.org/grpc\"\n    24→)\n    25→\n    26→// OnRunCompleteFunc is called after a workflow run finishes.\n    27→// It receives the project directory, run ID, and the final run state.\n    28→type OnRunCompleteFunc func(ctx context.Context, projectDir string, runID string, state domain.RunState)\n    29→\n    30→type ClocheServer struct {\n    31→\tpb.UnimplementedClocheServiceServer\n    32→\tstore         ports.RunStore\n    33→\tcaptures      ports.CaptureStore\n    34→\tlogStore      ports.LogStore\n    35→\tcontainer     ports.ContainerRuntime\n    36→\tdefaultImage  string\n    37→\tevolution     *evolution.Trigger\n    38→\tlogBroadcast  *logstream.Broadcaster\n    39→\tshutdownFn    func()\n    40→\tonRunComplete OnRunCompleteFunc\n    41→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    42→\tmu            sync.Mutex\n    43→\trunIDs        map[string]string // run_id -> container_id\n    44→}\n    45→\n    46→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    47→\treturn &ClocheServer{\n    48→\t\tstore:     store,\n    49→\t\tcontainer: container,\n    50→\t\trunIDs:    make(map[string]string),\n    51→\t}\n    52→}\n    53→\n    54→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    55→\treturn &ClocheServer{\n    56→\t\tstore:        store,\n    57→\t\tcaptures:     captures,\n    58→\t\tcontainer:    container,\n    59→\t\tdefaultImage: defaultImage,\n    60→\t\trunIDs:       make(map[string]string),\n    61→\t}\n    62→}\n    63→\n    64→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    65→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    66→\ts.logStore = ls\n    67→}\n    68→\n    69→\n    70→// SetEvolution attaches an evolution trigger to the server.\n    71→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    72→\ts.evolution = trigger\n    73→}\n    74→\n    75→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    76→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    77→\ts.logBroadcast = b\n    78→}\n    79→\n    80→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    81→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    82→\ts.shutdownFn = fn\n    83→}\n    84→\n    85→// SetOnRunComplete sets a callback invoked after each workflow run completes.\n    86→func (s *ClocheServer) SetOnRunComplete(fn OnRunCompleteFunc) {\n    87→\ts.onRunComplete = fn\n    88→}\n    89→\n    90→\n    91→// SetOrchestrateFunc sets the function invoked by the Orchestrate RPC.\n    92→func (s *ClocheServer) SetOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) {\n    93→\ts.orchestrateFn = fn\n    94→}\n    95→\n    96→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    97→\tif s.container == nil {\n    98→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    99→\t}\n   100→\n   101→\t// Generate a unique run ID, retrying on collision\n   102→\tvar runID string\n   103→\tfor attempts := 0; attempts < 10; attempts++ {\n   104→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n   105→\t\texisting, err := s.store.GetRun(ctx, runID)\n   106→\t\tif err != nil {\n   107→\t\t\tbreak // ID is free\n   108→\t\t}\n   109→\t\t// Reuse if completed more than 1 hour ago\n   110→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   111→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   112→\t\t\tbreak\n   113→\t\t}\n   114→\t}\n   115→\n   116→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   117→\tif req.Prompt != \"\" {\n   118→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   119→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   120→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   121→\t\t}\n   122→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   123→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   124→\t\t}\n   125→\t}\n   126→\trun := domain.NewRun(runID, req.WorkflowName)\n   127→\trun.ProjectDir = req.ProjectDir\n   128→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   129→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   130→\t}\n   131→\n   132→\t// Resolve image: request-level override, then server default\n   133→\timage := req.Image\n   134→\tif image == \"\" {\n   135→\t\timage = s.defaultImage\n   136→\t}\n   137→\n   138→\t// Launch container start + tracking in background so the RPC returns immediately.\n   139→\t// The run stays in \"pending\" state until the container is up.\n   140→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   141→\n   142→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   143→}\n   144→\n   145→// launchAndTrack starts the container and then tracks it to completion.\n   146→// It runs in a background goroutine with its own context, independent of the\n   147→// RPC context which may be cancelled after RunWorkflow returns.\n   148→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   149→\tctx := context.Background()\n   150→\n   151→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   152→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   153→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   154→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   155→\t\t\tif run != nil {\n   156→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   157→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   158→\t\t\t}\n   159→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   160→\t\t\treturn\n   161→\t\t}\n   162→\t}\n   163→\n   164→\tbaseSHA := gitHEAD(req.ProjectDir)\n   165→\n   166→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   167→\t\tImage:        image,\n   168→\t\tWorkflowName: req.WorkflowName,\n   169→\t\tProjectDir:   req.ProjectDir,\n   170→\t\tRunID:        runID,\n   171→\t\tNetworkAllow: []string{\"*\"},\n   172→\t})\n   173→\tif err != nil {\n   174→\t\trun, _ := s.store.GetRun(ctx, runID)\n   175→\t\tif run != nil {\n   176→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   177→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   178→\t\t}\n   179→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   180→\t\treturn\n   181→\t}\n   182→\n   183→\ts.mu.Lock()\n   184→\ts.runIDs[runID] = containerID\n   185→\ts.mu.Unlock()\n   186→\n   187→\trun, _ := s.store.GetRun(ctx, runID)\n   188→\tif run != nil {\n   189→\t\trun.Start()\n   190→\t\trun.ContainerID = containerID\n   191→\t\trun.BaseSHA = baseSHA\n   192→\t\t_ = s.store.UpdateRun(ctx, run)\n   193→\t}\n   194→\n   195→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   196→}\n   197→\n   198→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   199→\tctx := context.Background()\n   200→\n   201→\t// Attach to agent output\n   202→\treader, err := s.container.AttachOutput(ctx, containerID)\n   203→\tif err != nil {\n   204→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   205→\t\treturn\n   206→\t}\n   207→\n   208→\t// Parse JSON-lines status messages\n   209→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   210→\tscanner := bufio.NewScanner(reader)\n   211→\tfor scanner.Scan() {\n   212→\t\tvar msg protocol.StatusMessage\n   213→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   214→\t\t\tcontinue\n   215→\t\t}\n   216→\n   217→\t\t// Fast path: log messages don't need store interaction.\n   218→\t\tif msg.Type == protocol.MsgLog {\n   219→\t\t\tif s.logBroadcast != nil {\n   220→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   221→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   222→\t\t\t\t\tType:      \"llm\",\n   223→\t\t\t\t\tContent:   msg.Message,\n   224→\t\t\t\t})\n   225→\t\t\t}\n   226→\t\t\tcontinue\n   227→\t\t}\n   228→\n   229→\t\trun, err := s.store.GetRun(ctx, runID)\n   230→\t\tif err != nil {\n   231→\t\t\tcontinue\n   232→\t\t}\n   233→\n   234→\t\tswitch msg.Type {\n   235→\t\tcase protocol.MsgStepStarted:\n   236→\t\t\trun.RecordStepStart(msg.StepName)\n   237→\t\t\tif s.captures != nil {\n   238→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   239→\t\t\t\t\tStepName:  msg.StepName,\n   240→\t\t\t\t\tStartedAt: msg.Timestamp,\n   241→\t\t\t\t})\n   242→\t\t\t}\n   243→\t\tcase protocol.MsgStepCompleted:\n   244→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   245→\t\t\tif s.captures != nil {\n   246→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   247→\t\t\t\t\tStepName:    msg.StepName,\n   248→\t\t\t\t\tResult:      msg.Result,\n   249→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   250→\t\t\t\t})\n   251→\t\t\t}\n   252→\t\tcase protocol.MsgRunCompleted:\n   253→\t\t\treportedResult = msg.Result\n   254→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   255→\t\t}\n   256→\n   257→\t\t_ = s.store.UpdateRun(ctx, run)\n   258→\t}\n   259→\treader.Close()\n   260→\n   261→\t// Signal live-stream subscribers that this run is done.\n   262→\tif s.logBroadcast != nil {\n   263→\t\ts.logBroadcast.Finish(runID)\n   264→\t}\n   265→\n   266→\t// Wait for process exit\n   267→\texitCode, err := s.container.Wait(ctx, containerID)\n   268→\tif err != nil {\n   269→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   270→\t}\n   271→\n   272→\t// Extract step output files from container before it's removed\n   273→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   274→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   275→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   276→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   277→\t\t}\n   278→\t}\n   279→\n   280→\t// Capture full container stdout/stderr before the container is removed\n   281→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   282→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   283→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   284→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   285→\t\t}\n   286→\t}\n   287→\n   288→\t// Index extracted log files in the log store\n   289→\tif s.logStore != nil {\n   290→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   291→\t}\n   292→\n   293→\t// Extract results to git branch BEFORE finalizing state, so that\n   294→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   295→\t// before the run is marked complete.\n   296→\tresultLabel := reportedResult\n   297→\tif resultLabel == \"\" {\n   298→\t\tif exitCode == 0 {\n   299→\t\t\tresultLabel = \"succeeded\"\n   300→\t\t} else {\n   301→\t\t\tresultLabel = \"failed\"\n   302→\t\t}\n   303→\t}\n   304→\t{\n   305→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   306→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   307→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   308→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   309→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   310→\t\t\t} else {\n   311→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   312→\t\t\t}\n   313→\t\t} else {\n   314→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   315→\t\t}\n   316→\t}\n   317→\n   318→\t// Now finalize run state\n   319→\trun, err := s.store.GetRun(ctx, runID)\n   320→\tif err != nil {\n   321→\t\treturn\n   322→\t}\n   323→\tif run.State == domain.RunStateRunning {\n   324→\t\tif reportedResult == \"succeeded\" {\n   325→\t\t\trun.Complete(domain.RunStateSucceeded)\n   326→\t\t} else if reportedResult != \"\" {\n   327→\t\t\trun.Complete(domain.RunStateFailed)\n   328→\t\t} else if exitCode == 0 {\n   329→\t\t\trun.Complete(domain.RunStateSucceeded)\n   330→\t\t} else {\n   331→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   332→\t\t}\n   333→\t\t_ = s.store.UpdateRun(ctx, run)\n   334→\t}\n   335→\n   336→\t// Fire evolution trigger if configured\n   337→\tif s.evolution != nil {\n   338→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   339→\t}\n   340→\n   341→\t// Fire on-run-complete callback (orchestrator trigger)\n   342→\tif s.onRunComplete != nil {\n   343→\t\trunForCallback, _ := s.store.GetRun(ctx, runID)\n   344→\t\tif runForCallback != nil {\n   345→\t\t\ts.onRunComplete(ctx, projectDir, runID, runForCallback.State)\n   346→\t\t}\n   347→\t}\n   348→\n   349→\t// Merge is handled as a workflow step in host.cloche, not here.\n   350→\n   351→\t// Container retention policy:\n   352→\t// - Failed runs: always keep the container for debugging\n   353→\t// - Successful runs + --keep-container: keep the container\n   354→\t// - Successful runs without --keep-container: remove the container\n   355→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   356→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   357→\n   358→\tif keepContainer || runFailed {\n   359→\t\treason := \"--keep-container\"\n   360→\t\tif runFailed {\n   361→\t\t\treason = \"run failed\"\n   362→\t\t}\n   363→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   364→\t\tif runFinal != nil {\n   365→\t\t\trunFinal.ContainerKept = true\n   366→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   367→\t\t}\n   368→\t} else {\n   369→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   370→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   371→\t\t} else {\n   372→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   373→\t\t}\n   374→\t}\n   375→\n   376→\t// Cleanup mapping\n   377→\ts.mu.Lock()\n   378→\tdelete(s.runIDs, runID)\n   379→\ts.mu.Unlock()\n   380→}\n   381→\n   382→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   383→\tvar since time.Time\n   384→\tif !req.All {\n   385→\t\tsince = time.Now().Add(-1 * time.Hour)\n   386→\t}\n   387→\truns, err := s.store.ListRuns(ctx, since)\n   388→\tif err != nil {\n   389→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   390→\t}\n   391→\n   392→\tresp := &pb.ListRunsResponse{}\n   393→\tfor _, run := range runs {\n   394→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   395→\t\t\tRunId:        run.ID,\n   396→\t\t\tWorkflowName: run.WorkflowName,\n   397→\t\t\tState:        string(run.State),\n   398→\t\t\tStartedAt:    run.StartedAt.String(),\n   399→\t\t\tErrorMessage: run.ErrorMessage,\n   400→\t\t\tContainerId:  run.ContainerID,\n   401→\t\t})\n   402→\t}\n   403→\treturn resp, nil\n   404→}\n   405→\n   406→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   407→\trun, err := s.store.GetRun(ctx, req.RunId)\n   408→\tif err != nil {\n   409→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   410→\t}\n   411→\n   412→\tresp := &pb.GetStatusResponse{\n   413→\t\tRunId:        run.ID,\n   414→\t\tWorkflowName: run.WorkflowName,\n   415→\t\tState:        string(run.State),\n   416→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   417→\t\tErrorMessage: run.ErrorMessage,\n   418→\t\tContainerId:  run.ContainerID,\n   419→\t}\n   420→\n   421→\t// Check container liveness\n   422→\tif run.ContainerID != \"\" && s.container != nil {\n   423→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   424→\t\t\tresp.ContainerAlive = cs.Running\n   425→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   426→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   427→\t\t\t}\n   428→\t\t}\n   429→\t}\n   430→\n   431→\t// Load step executions from captures store if available\n   432→\tif s.captures != nil {\n   433→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   434→\t\tif err == nil {\n   435→\t\t\tfor _, exec := range captures {\n   436→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   437→\t\t\t\t\tStepName:    exec.StepName,\n   438→\t\t\t\t\tResult:      exec.Result,\n   439→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   440→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   441→\t\t\t\t})\n   442→\t\t\t}\n   443→\t\t}\n   444→\t} else {\n   445→\t\tfor _, exec := range run.StepExecutions {\n   446→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   447→\t\t\t\tStepName:    exec.StepName,\n   448→\t\t\t\tResult:      exec.Result,\n   449→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   450→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   451→\t\t\t})\n   452→\t\t}\n   453→\t}\n   454→\n   455→\treturn resp, nil\n   456→}\n   457→\n   458→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   459→\tctx := stream.Context()\n   460→\n   461→\t// Verify run exists\n   462→\trun, err := s.store.GetRun(ctx, req.RunId)\n   463→\tif err != nil {\n   464→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   465→\t}\n   466→\n   467→\t// If step_name or log_type filter is set, serve content directly from the log index\n   468→\tif req.StepName != \"\" || req.LogType != \"\" {\n   469→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   470→\t}\n   471→\n   472→\tif s.captures == nil {\n   473→\t\treturn fmt.Errorf(\"captures store not configured\")\n   474→\t}\n   475→\n   476→\t// Check for full.log first — if it exists, serve it as the unified log\n   477→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   478→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   479→\t\tif err := stream.Send(&pb.LogEntry{\n   480→\t\t\tType:    \"full_log\",\n   481→\t\t\tMessage: string(data),\n   482→\t\t}); err != nil {\n   483→\t\t\treturn err\n   484→\t\t}\n   485→\t\t// Still send run completion entry\n   486→\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   487→\t\t\tif err := stream.Send(&pb.LogEntry{\n   488→\t\t\t\tType:      \"run_completed\",\n   489→\t\t\t\tResult:    string(run.State),\n   490→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   491→\t\t\t\tMessage:   run.ErrorMessage,\n   492→\t\t\t}); err != nil {\n   493→\t\t\t\treturn err\n   494→\t\t\t}\n   495→\t\t}\n   496→\t\treturn nil\n   497→\t}\n   498→\n   499→\t// Fall back to capture-based streaming\n   500→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   501→\tif err != nil {\n   502→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   503→\t}\n   504→\n   505→\tfor _, exec := range captures {\n   506→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   507→\t\t// and one for step_completed (has Result).\n   508→\t\tif exec.Result == \"\" {\n   509→\t\t\tentry := &pb.LogEntry{\n   510→\t\t\t\tType:      \"step_started\",\n   511→\t\t\t\tStepName:  exec.StepName,\n   512→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   513→\t\t\t}\n   514→\t\t\tif err := stream.Send(entry); err != nil {\n   515→\t\t\t\treturn err\n   516→\t\t\t}\n   517→\t\t} else {\n   518→\t\t\t// Read step output from file, falling back to container.log\n   519→\t\t\tvar output string\n   520→\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   521→\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   522→\t\t\t\toutput = string(data)\n   523→\t\t\t} else {\n   524→\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n   525→\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n   526→\t\t\t\t\toutput = string(data)\n   527→\t\t\t\t}\n   528→\t\t\t}\n   529→\t\t\tentry := &pb.LogEntry{\n   530→\t\t\t\tType:      \"step_completed\",\n   531→\t\t\t\tStepName:  exec.StepName,\n   532→\t\t\t\tResult:    exec.Result,\n   533→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   534→\t\t\t\tMessage:   output,\n   535→\t\t\t}\n   536→\t\t\tif err := stream.Send(entry); err != nil {\n   537→\t\t\t\treturn err\n   538→\t\t\t}\n   539→\t\t}\n   540→\t}\n   541→\n   542→\t// Send run completion entry\n   543→\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   544→\t\tif err := stream.Send(&pb.LogEntry{\n   545→\t\t\tType:      \"run_completed\",\n   546→\t\t\tResult:    string(run.State),\n   547→\t\t\tTimestamp: run.CompletedAt.String(),\n   548→\t\t\tMessage:   run.ErrorMessage,\n   549→\t\t}); err != nil {\n   550→\t\t\treturn err\n   551→\t\t}\n   552→\t}\n   553→\n   554→\treturn nil\n   555→}\n   556→\n   557→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   558→// It uses the log index when available, falling back to file path conventions.\n   559→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   560→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   561→\n   562→\t// Try log index first\n   563→\tif s.logStore != nil {\n   564→\t\tvar logFiles []*ports.LogFileEntry\n   565→\t\tvar err error\n   566→\n   567→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   568→\t\t\t// Filter by both step and type\n   569→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   570→\t\t\tif err == nil {\n   571→\t\t\t\tfiltered := logFiles[:0]\n   572→\t\t\t\tfor _, lf := range logFiles {\n   573→\t\t\t\t\tif lf.FileType == req.LogType {\n   574→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   575→\t\t\t\t\t}\n   576→\t\t\t\t}\n   577→\t\t\t\tlogFiles = filtered\n   578→\t\t\t}\n   579→\t\t} else if req.StepName != \"\" {\n   580→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   581→\t\t} else {\n   582→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   583→\t\t}\n   584→\n   585→\t\tif err == nil && len(logFiles) > 0 {\n   586→\t\t\tfor _, lf := range logFiles {\n   587→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   588→\t\t\t\tif readErr != nil {\n   589→\t\t\t\t\tcontinue\n   590→\t\t\t\t}\n   591→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   592→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   593→\t\t\t\t\tStepName: lf.StepName,\n   594→\t\t\t\t\tMessage:  string(data),\n   595→\t\t\t\t}); err != nil {\n   596→\t\t\t\t\treturn err\n   597→\t\t\t\t}\n   598→\t\t\t}\n   599→\t\t\treturn nil\n   600→\t\t}\n   601→\t}\n   602→\n   603→\t// Fall back to file path conventions\n   604→\tif req.StepName != \"\" {\n   605→\t\tvar logPath string\n   606→\t\tswitch req.LogType {\n   607→\t\tcase \"llm\":\n   608→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   609→\t\tdefault:\n   610→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   611→\t\t}\n   612→\n   613→\t\tdata, err := os.ReadFile(logPath)\n   614→\t\tif err != nil {\n   615→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   616→\t\t}\n   617→\t\treturn stream.Send(&pb.LogEntry{\n   618→\t\t\tType:     \"step_log\",\n   619→\t\t\tStepName: req.StepName,\n   620→\t\t\tMessage:  string(data),\n   621→\t\t})\n   622→\t}\n   623→\n   624→\treturn fmt.Errorf(\"no log files found matching filter\")\n   625→}\n   626→\n   627→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   628→\ts.mu.Lock()\n   629→\tcontainerID, ok := s.runIDs[req.RunId]\n   630→\ts.mu.Unlock()\n   631→\n   632→\tif !ok {\n   633→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   634→\t}\n   635→\n   636→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   637→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   638→\t}\n   639→\n   640→\t// Mark as cancelled in store\n   641→\trun, err := s.store.GetRun(ctx, req.RunId)\n   642→\tif err == nil {\n   643→\t\trun.Complete(domain.RunStateCancelled)\n   644→\t\t_ = s.store.UpdateRun(ctx, run)\n   645→\t}\n   646→\n   647→\treturn &pb.StopRunResponse{}, nil\n   648→}\n   649→\n   650→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   651→\tif s.container == nil {\n   652→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   653→\t}\n   654→\n   655→\tid := req.Id\n   656→\tif id == \"\" {\n   657→\t\treturn nil, fmt.Errorf(\"id is required\")\n   658→\t}\n   659→\n   660→\t// Try to resolve as a run ID first\n   661→\tcontainerID := id\n   662→\trun, err := s.store.GetRun(ctx, id)\n   663→\tif err == nil {\n   664→\t\t// It's a run ID — use the container ID from the run record\n   665→\t\tif run.ContainerID == \"\" {\n   666→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   667→\t\t}\n   668→\t\tcontainerID = run.ContainerID\n   669→\t}\n   670→\n   671→\t// Remove the container\n   672→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   673→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   674→\t}\n   675→\n   676→\t// If we resolved a run, clear the container_kept flag\n   677→\tif run != nil {\n   678→\t\trun.ContainerKept = false\n   679→\t\t_ = s.store.UpdateRun(ctx, run)\n   680→\t}\n   681→\n   682→\treturn &pb.DeleteContainerResponse{}, nil\n   683→}\n   684→\n   685→func (s *ClocheServer) Orchestrate(ctx context.Context, req *pb.OrchestrateRequest) (*pb.OrchestrateResponse, error) {\n   686→\tif s.orchestrateFn == nil {\n   687→\t\treturn nil, fmt.Errorf(\"orchestrator not configured\")\n   688→\t}\n   689→\tdispatched, err := s.orchestrateFn(ctx, req.ProjectDir)\n   690→\tif err != nil {\n   691→\t\treturn nil, fmt.Errorf(\"orchestration failed: %w\", err)\n   692→\t}\n   693→\treturn &pb.OrchestrateResponse{Dispatched: int32(dispatched)}, nil\n   694→}\n   695→\n   696→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n   697→\tif s.shutdownFn == nil {\n   698→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n   699→\t}\n   700→\tgo s.shutdownFn()\n   701→\treturn &pb.ShutdownResponse{}, nil\n   702→}\n   703→\n   704→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n   705→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n   706→\tentries, err := os.ReadDir(outputDir)\n   707→\tif err != nil {\n   708→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n   709→\t\treturn\n   710→\t}\n   711→\n   712→\tnow := time.Now()\n   713→\tfor _, entry := range entries {\n   714→\t\tif entry.IsDir() {\n   715→\t\t\tcontinue\n   716→\t\t}\n   717→\t\tname := entry.Name()\n   718→\t\tif !strings.HasSuffix(name, \".log\") {\n   719→\t\t\tcontinue\n   720→\t\t}\n   721→\n   722→\t\tvar fileType, stepName string\n   723→\t\tbase := strings.TrimSuffix(name, \".log\")\n   724→\n   725→\t\tswitch {\n   726→\t\tcase name == \"full.log\":\n   727→\t\t\tfileType = \"full\"\n   728→\t\tcase name == \"container.log\":\n   729→\t\t\t// container.log is internal, not indexed as a user-facing log type\n   730→\t\t\tcontinue\n   731→\t\tcase strings.HasPrefix(name, \"llm-\"):\n   732→\t\t\tfileType = \"llm\"\n   733→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n   734→\t\tdefault:\n   735→\t\t\tfileType = \"script\"\n   736→\t\t\tstepName = base\n   737→\t\t}\n   738→\n   739→\t\tinfo, _ := entry.Info()\n   740→\t\tvar fileSize int64\n   741→\t\tif info != nil {\n   742→\t\t\tfileSize = info.Size()\n   743→\t\t}\n   744→\n   745→\t\tlogEntry := &ports.LogFileEntry{\n   746→\t\t\tRunID:     runID,\n   747→\t\t\tStepName:  stepName,\n   748→\t\t\tFileType:  fileType,\n   749→\t\t\tFilePath:  filepath.Join(outputDir, name),\n   750→\t\t\tFileSize:  fileSize,\n   751→\t\t\tCreatedAt: now,\n   752→\t\t}\n   753→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n   754→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n   755→\t\t}\n   756→\t}\n   757→}\n   758→\n   759→func gitHEAD(dir string) string {\n   760→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n   761→\tcmd.Dir = dir\n   762→\tout, err := cmd.Output()\n   763→\tif err != nil {\n   764→\t\treturn \"\"\n   765→\t}\n   766→\treturn strings.TrimSpace(string(out))\n   767→}\n   768→"}]},"parent_tool_use_id":"toolu_01XYC7icoCRqW2gyD33ayddi","session_id":"5417fe53-38fc-4081-a53f-ab0580b28d18","uuid":"35f15459-caa6-4b0a-b5dd-ba6ad10ea475"}
