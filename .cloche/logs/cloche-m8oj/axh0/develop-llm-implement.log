{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J5mPKgaUuwKUHLStNq8wN3","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→)\n    11→\n    12→// ScriptGenerator creates new checker/linter scripts via LLM code generation.\n    13→type ScriptGenerator struct {\n    14→\tLLM LLMClient\n    15→}\n    16→\n    17→type scriptResponse struct {\n    18→\tPath    string `json:\"path\"`\n    19→\tContent string `json:\"content\"`\n    20→}\n    21→\n    22→// GeneratedScript holds the result of script generation.\n    23→type GeneratedScript struct {\n    24→\tPath    string\n    25→\tContent string\n    26→}\n    27→\n    28→// Generate creates a script file based on the lesson.\n    29→func (g *ScriptGenerator) Generate(ctx context.Context, projectDir string, lesson *Lesson) (*GeneratedScript, error) {\n    30→\tsystemPrompt := `You are a script generator for software validation workflows.\n    31→Given a description of what needs to be checked, generate a shell script that performs the check.\n    32→\n    33→Rules:\n    34→- The script should exit 0 on success, non-zero on failure\n    35→- Keep it simple and focused on one check\n    36→- Use standard tools available in a typical development container\n    37→- Include a shebang line (#!/bin/bash or #!/bin/sh)\n    38→\n    39→Respond with JSON: {\"path\": \"scripts/<name>.sh\", \"content\": \"<script content>\"}\n    40→Use \\n for newlines in the content field.\n    41→Do not include any other text.`\n    42→\n    43→\tuserPrompt := fmt.Sprintf(\"Check needed: %s\\nDetails: %s\", lesson.Insight, lesson.SuggestedAction)\n    44→\n    45→\tresponse, err := g.LLM.Complete(ctx, systemPrompt, userPrompt)\n    46→\tif err != nil {\n    47→\t\treturn nil, fmt.Errorf(\"script generator LLM call: %w\", err)\n    48→\t}\n    49→\n    50→\tvar resp scriptResponse\n    51→\tresponse = strings.TrimSpace(response)\n    52→\tif err := json.Unmarshal([]byte(response), &resp); err != nil {\n    53→\t\treturn nil, fmt.Errorf(\"parsing script generator response: %w\", err)\n    54→\t}\n    55→\n    56→\tif resp.Path == \"\" || resp.Content == \"\" {\n    57→\t\treturn nil, fmt.Errorf(\"script generator returned empty path or content\")\n    58→\t}\n    59→\n    60→\t// Create parent directories\n    61→\tfullPath := filepath.Join(projectDir, resp.Path)\n    62→\tif err := os.MkdirAll(filepath.Dir(fullPath), 0755); err != nil {\n    63→\t\treturn nil, fmt.Errorf(\"creating script directory: %w\", err)\n    64→\t}\n    65→\n    66→\t// Write with executable permissions\n    67→\tif err := os.WriteFile(fullPath, []byte(resp.Content), 0755); err != nil {\n    68→\t\treturn nil, fmt.Errorf(\"writing script file: %w\", err)\n    69→\t}\n    70→\n    71→\treturn &GeneratedScript{Path: resp.Path, Content: resp.Content}, nil\n    72→}\n    73→"}]},"parent_tool_use_id":null,"session_id":"961c4f69-cff1-4ff4-b5d0-2a15f037846d","uuid":"469c013b-1cb0-4f4e-a22b-3c2a1a05058c","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/scriptgen.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n)\n\n// ScriptGenerator creates new checker/linter scripts via LLM code generation.\ntype ScriptGenerator struct {\n\tLLM LLMClient\n}\n\ntype scriptResponse struct {\n\tPath    string `json:\"path\"`\n\tContent string `json:\"content\"`\n}\n\n// GeneratedScript holds the result of script generation.\ntype GeneratedScript struct {\n\tPath    string\n\tContent string\n}\n\n// Generate creates a script file based on the lesson.\nfunc (g *ScriptGenerator) Generate(ctx context.Context, projectDir string, lesson *Lesson) (*GeneratedScript, error) {\n\tsystemPrompt := `You are a script generator for software validation workflows.\nGiven a description of what needs to be checked, generate a shell script that performs the check.\n\nRules:\n- The script should exit 0 on success, non-zero on failure\n- Keep it simple and focused on one check\n- Use standard tools available in a typical development container\n- Include a shebang line (#!/bin/bash or #!/bin/sh)\n\nRespond with JSON: {\"path\": \"scripts/<name>.sh\", \"content\": \"<script content>\"}\nUse \\n for newlines in the content field.\nDo not include any other text.`\n\n\tuserPrompt := fmt.Sprintf(\"Check needed: %s\\nDetails: %s\", lesson.Insight, lesson.SuggestedAction)\n\n\tresponse, err := g.LLM.Complete(ctx, systemPrompt, userPrompt)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"script generator LLM call: %w\", err)\n\t}\n\n\tvar resp scriptResponse\n\tresponse = strings.TrimSpace(response)\n\tif err := json.Unmarshal([]byte(response), &resp); err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing script generator response: %w\", err)\n\t}\n\n\tif resp.Path == \"\" || resp.Content == \"\" {\n\t\treturn nil, fmt.Errorf(\"script generator returned empty path or content\")\n\t}\n\n\t// Create parent directories\n\tfullPath := filepath.Join(projectDir, resp.Path)\n\tif err := os.MkdirAll(filepath.Dir(fullPath), 0755); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating script directory: %w\", err)\n\t}\n\n\t// Write with executable permissions\n\tif err := os.WriteFile(fullPath, []byte(resp.Content), 0755); err != nil {\n\t\treturn nil, fmt.Errorf(\"writing script file: %w\", err)\n\t}\n\n\treturn &GeneratedScript{Path: resp.Path, Content: resp.Content}, nil\n}\n","numLines":73,"startLine":1,"totalLines":73}}}
