  45→\t\tos.Exit(1)\n    46→\t}\n    47→\tdefer store.Close()\n    48→\n    49→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    50→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {"}]},"parent_tool_use_id":"toolu_01F4ZZ8hQ4uSfaU5KxM9nyZ1","session_id":"c74eec70-10cc-489a-bef5-b2195fdf4510","uuid":"361e8d3d-2c8a-4962-b05a-9ab69329b279"}
