ternal/adapters/web/handler.go:154:\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\ninternal/adapters/web/handler.go:155:\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\ninternal/adapters/web/handler.go:156:\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\ninternal/adapters/web/handler.go:157:\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\ninternal/adapters/web/handler.go:158:\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))"}]},"parent_tool_use_id":"toolu_01F4ZZ8hQ4uSfaU5KxM9nyZ1","session_id":"c74eec70-10cc-489a-bef5-b2195fdf4510","uuid":"a2ccec03-dba0-42bc-867f-be97bc482a51"}
