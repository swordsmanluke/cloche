on.md","/workspace/docs/plans/2026-03-01-subdirectory-layout-and-poll-design.md","/workspace/docs/plans/2026-03-01-subdirectory-layout-and-poll-impl.md","/workspace/docs/plans/2026-03-04-step-timeout-design.md","/workspace/docs/INSTALL.md","/workspace/docs/plans/2026-03-06-project-pages-design.md","/workspace/docs/plans/2026-03-06-cloche-base-docker-design.md","/workspace/docs/plans/2026-03-06-project-versioning-design.md","/workspace/docs/plans/2026-03-06-host-workflow-design.md","/workspace/docs/plans/2026-03-06-cloche-init-design.md","/workspace/docs/plans/2026-03-09-wire-output-mapping-design.md","/workspace/docs/plans/2026-03-03-next-features-design.md","/workspace/docs/plans/2026-03-06-config-toml-design.md","/workspace/docs/workflows.md","/workspace/docs/USAGE.md"],"durationMs":65,"numFiles":22,"truncated":false}}
