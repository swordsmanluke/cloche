{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TEi8cuNfD9W2rTUMfGeKvK","type":"tool_result","content":"     1→package generic\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"bytes\"\n     6→\t\"context\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    12→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    13→)\n    14→\n    15→type Adapter struct {\n    16→\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n    17→}\n    18→\n    19→func New() *Adapter {\n    20→\treturn &Adapter{}\n    21→}\n    22→\n    23→func (a *Adapter) Name() string {\n    24→\treturn \"generic\"\n    25→}\n    26→\n    27→func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    28→\tcmdStr := step.Config[\"run\"]\n    29→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    30→\tcmd.Dir = workDir\n    31→\n    32→\tvar output []byte\n    33→\tvar err error\n    34→\n    35→\tif a.StatusWriter != nil {\n    36→\t\toutput, err = a.executeStreaming(cmd, step.Name)\n    37→\t} else {\n    38→\t\toutput, err = cmd.CombinedOutput()\n    39→\t}\n    40→\n    41→\t// Extract result marker before writing logs\n    42→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n    43→\n    44→\t// Write cleaned output to log file\n    45→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n    46→\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n    47→\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), cleanOutput, 0644)\n    48→\t}\n    49→\n    50→\tisAgent := step.Type == domain.StepTypeAgent\n    51→\n    52→\tif err != nil {\n    53→\t\tif _, ok := err.(*exec.ExitError); ok {\n    54→\t\t\tresult := \"fail\"\n    55→\t\t\tif found {\n    56→\t\t\t\tresult = markerResult\n    57→\t\t\t}\n    58→\t\t\tprotocol.AppendHistory(workDir, step.Name, result, isAgent, cleanOutput)\n    59→\t\t\treturn result, nil\n    60→\t\t}\n    61→\t\treturn \"\", err\n    62→\t}\n    63→\n    64→\tresult := \"success\"\n    65→\tif found {\n    66→\t\tresult = markerResult\n    67→\t}\n    68→\tprotocol.AppendHistory(workDir, step.Name, result, isAgent, cleanOutput)\n    69→\treturn result, nil\n    70→}\n    71→\n    72→// executeStreaming runs the command and streams output lines through StatusWriter\n    73→// in real-time. Returns the full accumulated output.\n    74→func (a *Adapter) executeStreaming(cmd *exec.Cmd, stepName string) ([]byte, error) {\n    75→\tpipe, err := cmd.StdoutPipe()\n    76→\tif err != nil {\n    77→\t\treturn nil, err\n    78→\t}\n    79→\tcmd.Stderr = cmd.Stdout // merge stderr into stdout pipe\n    80→\n    81→\tif err := cmd.Start(); err != nil {\n    82→\t\treturn nil, err\n    83→\t}\n    84→\n    85→\tvar buf bytes.Buffer\n    86→\tscanner := bufio.NewScanner(pipe)\n    87→\tfor scanner.Scan() {\n    88→\t\tline := scanner.Text()\n    89→\t\tbuf.WriteString(line)\n    90→\t\tbuf.WriteByte('\\n')\n    91→\t\ta.StatusWriter.Log(stepName, line)\n    92→\t}\n    93→\n    94→\twaitErr := cmd.Wait()\n    95→\treturn buf.Bytes(), waitErr\n    96→}\n    97→"}]},"parent_tool_use_id":"toolu_01J6r4TFSa4erK367qsRCDGD","session_id":"6146b7bf-a511-4374-8899-2af97fce0332","uuid":"1aeb1f87-c0e5-412e-a930-7be8d1efa6f4"}
