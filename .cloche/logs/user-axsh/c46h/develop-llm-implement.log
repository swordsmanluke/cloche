{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T27X2s7nQVtyevHikz5nnY","type":"tool_result","content":"     1→package sqlite\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"database/sql\"\n     6→\t\"fmt\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11→\t_ \"modernc.org/sqlite\"\n    12→)\n    13→\n    14→type Store struct {\n    15→\tdb *sql.DB\n    16→}\n    17→\n    18→func NewStore(dsn string) (*Store, error) {\n    19→\tdb, err := sql.Open(\"sqlite\", dsn)\n    20→\tif err != nil {\n    21→\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n    22→\t}\n    23→\n    24→\t// Enable WAL mode for concurrent read/write access\n    25→\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n    26→\n    27→\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n    28→\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n    29→\n    30→\t// Serialize all Go-side access through a single connection so SQLite\n    31→\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n    32→\tdb.SetMaxOpenConns(1)\n    33→\n    34→\tif err := migrate(db); err != nil {\n    35→\t\tdb.Close()\n    36→\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n    37→\t}\n    38→\n    39→\treturn &Store{db: db}, nil\n    40→}\n    41→\n    42→func (s *Store) Close() error {\n    43→\treturn s.db.Close()\n    44→}\n    45→\n    46→func migrate(db *sql.DB) error {\n    47→\t_, err := db.Exec(`\n    48→\t\tCREATE TABLE IF NOT EXISTS runs (\n    49→\t\t\tid TEXT PRIMARY KEY,\n    50→\t\t\tworkflow_name TEXT NOT NULL,\n    51→\t\t\tstate TEXT NOT NULL,\n    52→\t\t\tactive_steps TEXT,\n    53→\t\t\tstarted_at TEXT,\n    54→\t\t\tcompleted_at TEXT\n    55→\t\t);\n    56→\t\tCREATE TABLE IF NOT EXISTS step_executions (\n    57→\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    58→\t\t\trun_id TEXT NOT NULL,\n    59→\t\t\tstep_name TEXT NOT NULL,\n    60→\t\t\tresult TEXT,\n    61→\t\t\tstarted_at TEXT NOT NULL,\n    62→\t\t\tcompleted_at TEXT,\n    63→\t\t\tlogs TEXT,\n    64→\t\t\tgit_ref TEXT,\n    65→\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    66→\t\t);\n    67→\t`)\n    68→\tif err != nil {\n    69→\t\treturn err\n    70→\t}\n    71→\n    72→\t// Evolution schema additions (idempotent)\n    73→\talterStmts := []string{\n    74→\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n    75→\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n    76→\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n    77→\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n    78→\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n    79→\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n    80→\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n    81→\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n    82→\t\t`ALTER TABLE runs ADD COLUMN title TEXT NOT NULL DEFAULT ''`,\n    83→\t\t`ALTER TABLE runs ADD COLUMN is_host INTEGER NOT NULL DEFAULT 0`,\n    84→\t\t`ALTER TABLE runs ADD COLUMN parent_run_id TEXT NOT NULL DEFAULT ''`,\n    85→\t}\n    86→\tfor _, stmt := range alterStmts {\n    87→\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n    88→\t}\n    89→\n    90→\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n    91→\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    92→\t\trun_id TEXT NOT NULL,\n    93→\t\tstep_name TEXT,\n    94→\t\tfile_type TEXT NOT NULL,\n    95→\t\tfile_path TEXT NOT NULL,\n    96→\t\tfile_size INTEGER,\n    97→\t\tcreated_at TEXT NOT NULL,\n    98→\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    99→\t)`)\n   100→\tif errLog != nil {\n   101→\t\treturn errLog\n   102→\t}\n   103→\n   104→\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n   105→\t\trun_id TEXT PRIMARY KEY,\n   106→\t\tbranch TEXT NOT NULL,\n   107→\t\tproject TEXT NOT NULL,\n   108→\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n   109→\t\tenqueued_at TEXT NOT NULL,\n   110→\t\tcompleted_at TEXT\n   111→\t)`)\n   112→\tif errMQ != nil {\n   113→\t\treturn errMQ\n   114→\t}\n   115→\n   116→\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n   117→\t\tid TEXT PRIMARY KEY,\n   118→\t\tproject_dir TEXT NOT NULL,\n   119→\t\tworkflow_name TEXT NOT NULL,\n   120→\t\ttrigger_run_id TEXT NOT NULL,\n   121→\t\tcreated_at TEXT NOT NULL,\n   122→\t\tclassification TEXT,\n   123→\t\tchanges_json TEXT NOT NULL,\n   124→\t\tknowledge_delta TEXT\n   125→\t)`)\n   126→\tif err2 != nil {\n   127→\t\treturn err2\n   128→\t}\n   129→\n   130→\treturn nil\n   131→}\n   132→\n   133→func (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n   134→\t_, err := s.db.ExecContext(ctx,\n   135→\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept, title, is_host, parent_run_id)\n   136→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   137→\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n   138→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, run.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID,\n   139→\t)\n   140→\treturn err\n   141→}\n   142→\n   143→// runSelectCols is the standard column list for scanning a Run row.\n   144→const runSelectCols = `id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,''), COALESCE(is_host,0), COALESCE(parent_run_id,'')`\n   145→\n   146→// scanRun scans a single row into a *domain.Run.\n   147→func scanRun(scanner interface{ Scan(...any) error }) (*domain.Run, error) {\n   148→\trun := &domain.Run{}\n   149→\tvar activeSteps, startedAt, completedAt string\n   150→\tvar containerKept, isHost int"}]},"parent_tool_use_id":"toolu_01J6r4TFSa4erK367qsRCDGD","session_id":"6146b7bf-a511-4374-8899-2af97fce0332","uuid":"29b75c95-bebd-4d52-afd4-d8fd0cb3c161"}
