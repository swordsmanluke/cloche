n\trequire.Len(t, tokens, len(expected))\n\tfor i, tok := range tokens {\n\t\tassert.Equal(t, expected[i], tok.Type, \"token %d\", i)\n\t}\n\tassert.Equal(t, \"output\", tokens[0].Literal)\n\tassert.Equal(t, \"0\", tokens[2].Literal)\n\tassert.Equal(t, \"id\", tokens[5].Literal)\n}\n\nfunc lexAll(l *dsl.Lexer) []dsl.Token {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":610,"cache_read_input_tokens":19950,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":610},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"6c40a1e8-2848-47bb-9e51-bc1c5fa53fe0","uuid":"ce84ae1b-2938-4a49-8939-c831206eb63a"}
