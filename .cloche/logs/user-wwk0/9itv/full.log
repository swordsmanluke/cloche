l(ctx), nil\n    94→\t\t})\n    95→\t}\n    96→\n    97→\tgrpcServer := grpc.NewServer()\n    98→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    99→\n   100→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n   101→\n   102→\tlis, err := listen(listenAddr)\n   103→\tif err != nil {\n   104→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n   105→\t\tos.Exit(1)\n   106→\t}\n   107→\n   108→\tvar httpServer *http.Server\n   109→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n   110→\t\twebHandler, err := web.NewHandler(store, store, web.WithContainerLogger(runtime), web.WithLogStore(store), web.WithLogBroadcaster(broadcaster))\n   111→\t\tif err != nil {\n   112→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n   113→\t\t\tos.Exit(1)\n   114→\t\t}\n   115→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n   116→\t\tgo func() {\n   117→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   118→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   119→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   120→\t\t\t}\n   121→\t\t}()\n   122→\t}\n   123→\n   124→\tsigCh := make(chan os.Signal, 1)\n   125→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   126→\tgo func() {\n   127→\t\t<-sigCh\n   128→\t\tif httpServer != nil {\n   129→\t\t\thttpServer.Close()\n   130→\t\t}\n   131→\t\tgrpcServer.GracefulStop()\n   132→\t}()\n   133→\n   134→\t// Trigger orchestration on startup\n   135→\tif orch != nil {\n   136→\t\tgo func() {\n   137→\t\t\tn := orch.TriggerAll(context.Background())\n   138→\t\t\tif n > 0 {\n   139→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: orchestrator dispatched %d run(s)\\n\", n)\n   140→\t\t\t}\n   141→\t\t}()\n   142→\t}\n   143→\n   144→\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   145→\tif er