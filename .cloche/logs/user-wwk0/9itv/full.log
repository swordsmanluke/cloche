[2026-03-05T00:35:41Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019hZqZVkv2BmtjhKgwofsBQ","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"path/filepath\"\n    14→\t\"regexp\"\n    15→\t\"sort\"\n    16→\t\"time\"\n    17→\n    18→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    19→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    20→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    21→)\n    22→\n    23→// HandlerOption configures optional Handler dependencies.\n    24→type HandlerOption func(*Handler)\n    25→\n    26→// WithContainerLogger sets the container runtime for fetching live logs.\n    27→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    28→\treturn func(h *Handler) { h.container = c }\n    29→}\n    30→\n    31→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    32→func WithContainerManager(c ContainerManager) HandlerOption {\n    33→\treturn func(h *Handler) { h.container = c }\n    34→}\n    35→\n    36→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    37→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    38→\treturn func(h *Handler) { h.logBroadcast = b }\n    39→}\n    40→\n    41→// WithLogStore sets the log store for indexed log file lookups.\n    42→func WithLogStore(ls ports.LogStore) HandlerOption {\n    43→\treturn func(h *Handler) { h.logStore = ls }\n    44→}\n    45→\n    46→//go:embed templates/*.html static/*\n    47→var content embed.FS\n    48→\n    49→// Handler serves the web dashboard.\n    50→// ContainerLogger can retrieve logs from a container by ID.\n    51→type ContainerLogger interface {\n    52→\tLogs(ctx context.Context, containerID string) (string, error)\n    53→}\n    54→\n    55→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    56→type ContainerManager interface {\n    57→\tContainerLogger\n    58→\tRemove(ctx context.Context, containerID string) error\n    59→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    60→}\n    61→\n    62→type Handler struct {\n    63→\tstore        ports.RunStore\n    64→\tcaptures     ports.CaptureStore\n    65→\tlogStore     ports.LogStore\n    66→\tcontainer    ContainerLogger\n    67→\tlogBroadcast *logstream.Broadcaster\n    68→\tpages        map[string]*template.Template\n    69→\tmux          *http.ServeMux\n    70→}\n    71→\n    72→// NewHandler creates a web dashboard handler.\n    73→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    74→\tfuncMap := template.FuncMap{\n    75→\t\t\"stateColor\":       stateColor,\n    76→\t\t\"healthColor\":      healthColor,\n    77→\t\t\"formatTime\":       formatTime,\n    78→\t\t\"formatDuration\":   formatDuration,\n    79→\t\t\"truncate\":         truncate,\n    80→\t\t\"shortContainerID\": shortContainerID,\n    81→\t}\n    82→\n    83→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n    84→\tif err != nil {\n    85→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n    86→\t}\n    87→\n    88→\tpages := map[string]*template.Template{}\n    89→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\"} {\n    90→\t\tclone, err := base.Clone()\n    91→\t\tif err != nil {\n    92→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n    93→\t\t}\n    94→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n    95→\t\tif err != nil {\n    96→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n    97→\t\t}\n    98→\t\tpages[page] = clone\n    99→\t}\n   100→\n   101→\th := &Handler{\n   102→\t\tstore:    store,\n   103→\t\tcaptures: captures,\n   104→\t\tpages:    pages,\n   105→\t\tmux:      http.NewServeMux(),\n   106→\t}\n   107→\tfor _, opt := range opts {\n   108→\t\topt(h)\n   109→\t}\n   110→\n   111→\tstaticFS, err := fs.Sub(content, \"static\")\n   112→\tif err != nil {\n   113→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   114→\t}\n   115→\n   116→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   117→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   118→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   119→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   120→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   121→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   122→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   123→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   124→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   125→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   126→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   127→\n   128→\treturn h, nil\n   129→}\n   130→\n   131→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   132→\th.mux.ServeHTTP(w, r)\n   133→}\n   134→\n   135→// --- HTML handlers ---\n   136→\n   137→// projectOverviewEntry holds data for a single project card on the landing page.\n   138→type projectOverviewEntry struct {\n   139→\tDir        string\n   140→\tLabel      string\n   141→\tHealth     domain.HealthResult\n   142→\tRecentRuns []recentRunDot\n   143→\tActiveCount int\n   144→}\n   145→\n   146→// recentRunDot is a minimal representation of a run for the mini history display.\n   147→type recentRunDot struct {\n   148→\tID    string\n   149→\tState string\n   150→}\n   151→\n   152→const healthWindowSize = 10\n   153→\n   154→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   155→\tprojects, _ := h.store.ListProjects(r.Context())\n   156→\tlabels := projectLabels(projects)\n   157→\n   158→\tvar entries []projectOverviewEntry\n   159→\tfor _, dir := range projects {\n   160→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   161→\t\tif err != nil {\n   162→\t\t\tcontinue\n   163→\t\t}\n   164→\n   165→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   166→\t\trunValues := make([]domain.Run, len(runs))\n   167→\t\tfor i, rr := range runs {\n   168→\t\t\trunValues[i] = *rr\n   169→\t\t}\n   170→\n   171→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   172→\n   173→\t\t// Take the last N runs for the mini history (most recent first).\n   174→\t\tn := healthWindowSize\n   175→\t\tif n > len(runs) {\n   176→\t\t\tn = len(runs)\n   177→\t\t}\n   178→\t\tdots := make([]recentRunDot, n)\n   179→\t\tfor i := 0; i < n; i++ {\n   180→\t\t\tdots[i] = recentRunDot{\n   181→\t\t\t\tID:    runs[i].ID,\n   182→\t\t\t\tState: string(runs[i].State),\n   183→\t\t\t}\n   184→\t\t}\n   185→\n   186→\t\tvar activeCount int\n   187→\t\tfor _, rr := range runs {\n   188→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   189→\t\t\t\tactiveCount++\n   190→\t\t\t}\n   191→\t\t}\n   192→\n   193→\t\tentries = append(entries, projectOverviewEntry{\n   194→\t\t\tDir:         dir,\n   195→\t\t\tLabel:       labels[dir],\n   196→\t\t\tHealth:      health,\n   197→\t\t\tRecentRuns:  dots,\n   198→\t\t\tActiveCount: activeCount,\n   199→\t\t})\n   200→\t}\n   201→\n   202→\tsort.Slice(entries, func(i, j int) bool {\n   203→\t\treturn entries[i].Label < entries[j].Label\n   204→\t})\n   205→\n   206→\tdata := map[string]any{\n   207→\t\t\"Title\":    \"Projects\",\n   208→\t\t\"Projects\": entries,\n   209→\t}\n   210→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   211→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   212→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   213→\t}\n   214→}\n   215→\n   216→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   217→\tprojectFilter := r.URL.Query().Get(\"project\")\n   218→\n   219→\tvar runs []*domain.Run\n   220→\tvar err error\n   221→\tif projectFilter != \"\" {\n   222→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   223→\t} else {\n   224→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   225→\t}\n   226→\tif err != nil {\n   227→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   228→\t\treturn\n   229→\t}\n   230→\n   231→\tprojects, _ := h.store.ListProjects(r.Context())\n   232→\tlabels := projectLabels(projects)\n   233→\n   234→\t// Count retained containers per project\n   235→\tcontainerCounts := map[string]int{}\n   236→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   237→\tfor _, run := range allRuns {\n   238→\t\tif run.ContainerKept {\n   239→\t\t\tcontainerCounts[run.ProjectDir]++\n   240→\t\t}\n   241→\t}\n   242→\n   243→\tvar projectList []projectEntry\n   244→\tfor _, dir := range projects {\n   245→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   246→\t}\n   247→\tsort.Slice(projectList, func(i, j int) bool {\n   248→\t\treturn projectList[i].Label < projectList[j].Label\n   249→\t})\n   250→\n   251→\tdata := map[string]any{\n   252→\t\t\"Title\":         \"Runs\",\n   253→\t\t\"Runs\":          runs,\n   254→\t\t\"Projects\":      projectList,\n   255→\t\t\"ProjectFilter\": projectFilter,\n   256→\t\t\"ProjectLabels\": labels,\n   257→\t}\n   258→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   259→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   260→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   261→\t}\n   262→}\n   263→\n   264→// stepEntry is a merged view of a step execution for the template.\n   265→type stepEntry struct {\n   266→\tIndex     int\n   267→\tStepName  string\n   268→\tResult    string\n   269→\tStartedAt time.Time\n   270→\tDuration  string\n   271→}\n   272→\n   273→// mergeCaptures collapses started/completed capture pairs into single entries.\n   274→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   275→\tvar entries []stepEntry\n   276→\t// Track pending started rows by step name (LIFO for retries)\n   277→\tpending := map[string]*domain.StepExecution{}\n   278→\n   279→\tfor _, c := range caps {\n   280→\t\tif c.Result == \"\" {\n   281→\t\t\t// step_started row\n   282→\t\t\tpending[c.StepName] = c\n   283→\t\t\tcontinue\n   284→\t\t}\n   285→\t\t// step_completed row — merge with pending started if available\n   286→\t\tstartedAt := c.StartedAt\n   287→\t\tif started := pending[c.StepName]; started != nil {\n   288→\t\t\tstartedAt = started.StartedAt\n   289→\t\t\tdelete(pending, c.StepName)\n   290→\t\t}\n   291→\t\tentries = append(entries, stepEntry{\n   292→\t\t\tIndex:     len(entries),\n   293→\t\t\tStepName:  c.StepName,\n   294→\t\t\tResult:    c.Result,\n   295→\t\t\tStartedAt: startedAt,\n   296→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   297→\t\t})\n   298→\t}\n   299→\n   300→\t// Append any started-but-not-completed steps (still running)\n   301→\tfor _, c := range caps {\n   302→\t\tif c.Result == \"\" {\n   303→\t\t\tif _, used := pending[c.StepName]; !used {\n   304→\t\t\t\tcontinue\n   305→\t\t\t}\n   306→\t\t\tentries = append(entries, stepEntry{\n   307→\t\t\t\tIndex:     len(entries),\n   308→\t\t\t\tStepName:  c.StepName,\n   309→\t\t\t\tStartedAt: c.StartedAt,\n   310→\t\t\t})\n   311→\t\t\tdelete(pending, c.StepName)\n   312→\t\t}\n   313→\t}\n   314→\n   315→\treturn entries\n   316→}\n   317→\n   318→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   319→\tid := r.PathValue(\"id\")\n   320→\n   321→\trun, err := h.store.GetRun(r.Context(), id)\n   322→\tif err != nil {\n   323→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   324→\t\treturn\n   325→\t}\n   326→\n   327→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   328→\tif err != nil {\n   329→\t\tcaps = nil // non-fatal\n   330→\t}\n   331→\n   332→\tsteps := mergeCaptures(caps)\n   333→\n   334→\tcontainerAvailable := false\n   335→\tif run.ContainerKept && run.ContainerID != \"\" {\n   336→\t\tif mgr, ok := h.container.(ContainerManager); ok {\n   337→\t\t\tif _, err := mgr.Inspect(r.Context(), run.ContainerID); err == nil {\n   338→\t\t\t\tcontainerAvailable = true\n   339→\t\t\t}\n   340→\t\t}\n   341→\t}\n   342→\n   343→\tdata := map[string]any{\n   344→\t\t\"Title\":              \"Run \" + run.ID,\n   345→\t\t\"Run\":                run,\n   346→\t\t\"Steps\":              steps,\n   347→\t\t\"Page\":               \"detail\",\n   348→\t\t\"ContainerAvailable\": containerAvailable,\n   349→\t}\n   350→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   351→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   352→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   353→\t}\n   354→}\n   355→\n   356→// --- JSON API handlers ---\n   357→\n   358→type apiRun struct {\n   359→\tID           string `json:\"id\"`\n   360→\tWorkflowName string `json:\"workflow_name\"`\n   361→\tProjectDir   string `json:\"project_dir\"`\n   362→\tProjectLabel string `json:\"project_label\"`\n   363→\tState        string `json:\"state\"`\n   364→\tStartedAt    string `json:\"started_at\"`\n   365→\tCompletedAt  string `json:\"completed_at\"`\n   366→\tContainerID  string `json:\"container_id\"`\n   367→\tErrorMessage string `json:\"error_message\"`\n   368→}\n   369→\n   370→type apiStep struct {\n   371→\tStepName    string `json:\"step_name\"`\n   372→\tResult      string `json:\"result\"`\n   373→\tStartedAt   string `json:\"started_at\"`\n   374→\tCompletedAt string `json:\"completed_at\"`\n   375→\tDuration    string `json:\"duration\"`\n   376→}\n   377→\n   378→type apiRunDetail struct {\n   379→\tapiRun\n   380→\tSteps []apiStep `json:\"steps\"`\n   381→}\n   382→\n   383→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   384→\treturn apiRun{\n   385→\t\tID:           r.ID,\n   386→\t\tWorkflowName: r.WorkflowName,\n   387→\t\tProjectDir:   r.ProjectDir,\n   388→\t\tProjectLabel: labels[r.ProjectDir],\n   389→\t\tState:        string(r.State),\n   390→\t\tStartedAt:    formatTime(r.StartedAt),\n   391→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   392→\t\tContainerID:  r.ContainerID,\n   393→\t\tErrorMessage: r.ErrorMessage,\n   394→\t}\n   395→}\n   396→\n   397→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   398→\tprojectFilter := r.URL.Query().Get(\"project\")\n   399→\n   400→\tvar runs []*domain.Run\n   401→\tvar err error\n   402→\tif projectFilter != \"\" {\n   403→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   404→\t} else {\n   405→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   406→\t}\n   407→\tif err != nil {\n   408→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   409→\t\treturn\n   410→\t}\n   411→\n   412→\tprojects, _ := h.store.ListProjects(r.Context())\n   413→\tlabels := projectLabels(projects)\n   414→\n   415→\tresult := make([]apiRun, len(runs))\n   416→\tfor i, run := range runs {\n   417→\t\tresult[i] = toAPIRun(run, labels)\n   418→\t}\n   419→\n   420→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   421→\tjson.NewEncoder(w).Encode(result)\n   422→}\n   423→\n   424→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   425→\tprojects, err := h.store.ListProjects(r.Context())\n   426→\tif err != nil {\n   427→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   428→\t\treturn\n   429→\t}\n   430→\tlabels := projectLabels(projects)\n   431→\n   432→\ttype apiHealth struct {\n   433→\t\tStatus string `json:\"status\"`\n   434→\t\tPassed int    `json:\"passed\"`\n   435→\t\tFailed int    `json:\"failed\"`\n   436→\t\tTotal  int    `json:\"total\"`\n   437→\t}\n   438→\ttype apiProject struct {\n   439→\t\tDir         string    `json:\"dir\"`\n   440→\t\tLabel       string    `json:\"label\"`\n   441→\t\tHealth      apiHealth `json:\"health\"`\n   442→\t\tActiveCount int       `json:\"active_count\"`\n   443→\t}\n   444→\tresult := make([]apiProject, len(projects))\n   445→\tfor i, dir := range projects {\n   446→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   447→\t\trunValues := make([]domain.Run, len(runs))\n   448→\t\tfor j, rr := range runs {\n   449→\t\t\trunValues[j] = *rr\n   450→\t\t}\n   451→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   452→\t\tvar activeCount int\n   453→\t\tfor _, rr := range runs {\n   454→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   455→\t\t\t\tactiveCount++\n   456→\t\t\t}\n   457→\t\t}\n   458→\t\tresult[i] = apiProject{\n   459→\t\t\tDir:   dir,\n   460→\t\t\tLabel: labels[dir],\n   461→\t\t\tHealth: apiHealth{\n   462→\t\t\t\tStatus: string(health.Status),\n   463→\t\t\t\tPassed: health.Passed,\n   464→\t\t\t\tFailed: health.Failed,\n   465→\t\t\t\tTotal:  health.Total,\n   466→\t\t\t},\n   467→\t\t\tActiveCount: activeCount,\n   468→\t\t}\n   469→\t}\n   470→\n   471→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   472→\tjson.NewEncoder(w).Encode(result)\n   473→}\n   474→\n   475→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   476→\tid := r.PathValue(\"id\")\n   477→\n   478→\trun, err := h.store.GetRun(r.Context(), id)\n   479→\tif err != nil {\n   480→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   481→\t\treturn\n   482→\t}\n   483→\n   484→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   485→\tif err != nil {\n   486→\t\tcaps = nil\n   487→\t}\n   488→\n   489→\tprojects, _ := h.store.ListProjects(r.Context())\n   490→\tlabels := projectLabels(projects)\n   491→\n   492→\tmerged := mergeCaptures(caps)\n   493→\tsteps := make([]apiStep, len(merged))\n   494→\tfor i, e := range merged {\n   495→\t\tsteps[i] = apiStep{\n   496→\t\t\tStepName:  e.StepName,\n   497→\t\t\tResult:    e.Result,\n   498→\t\t\tStartedAt: formatTime(e.StartedAt),\n   499→\t\t\tDuration:  e.Duration,\n   500→\t\t}\n   501→\t}\n   502→\n   503→\tdetail := apiRunDetail{\n   504→\t\tapiRun: toAPIRun(run, labels),\n   505→\t\tSteps:  steps,\n   506→\t}\n   507→\n   508→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   509→\tjson.NewEncoder(w).Encode(detail)\n   510→}\n   511→\n   512→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   513→\tid := r.PathValue(\"id\")\n   514→\tstep := r.PathValue(\"step\")\n   515→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   516→\n   517→\trun, err := h.store.GetRun(r.Context(), id)\n   518→\tif err != nil {\n   519→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   520→\t\treturn\n   521→\t}\n   522→\n   523→\t// Try log index first for fast lookup\n   524→\tif h.logStore != nil {\n   525→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   526→\t\tif err == nil && len(logFiles) > 0 {\n   527→\t\t\t// If type filter specified, narrow results\n   528→\t\t\tfor _, lf := range logFiles {\n   529→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   530→\t\t\t\t\tcontinue\n   531→\t\t\t\t}\n   532→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   533→\t\t\t\tif readErr == nil && len(data) > 0 {\n   534→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   535→\t\t\t\t\tw.Write(data)\n   536→\t\t\t\t\treturn\n   537→\t\t\t\t}\n   538→\t\t\t}\n   539→\t\t}\n   540→\t}\n   541→\n   542→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   543→\n   544→\t// Fall back to file path conventions\n   545→\t// If type is \"llm\", try llm-<step>.log\n   546→\tif logType == \"llm\" {\n   547→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   548→\t\tdata, err := os.ReadFile(llmPath)\n   549→\t\tif err == nil && len(data) > 0 {\n   550→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   551→\t\t\tw.Write(data)\n   552→\t\t\treturn\n   553→\t\t}\n   554→\t}\n   555→\n   556→\t// Try per-step output first, fall back to container.log, then live docker logs\n   557→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   558→\tdata, err := os.ReadFile(outputPath)\n   559→\tif err == nil && len(data) > 0 {\n   560→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   561→\t\tw.Write(data)\n   562→\t\treturn\n   563→\t}\n   564→\n   565→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   566→\tdata, err = os.ReadFile(containerLog)\n   567→\tif err == nil && len(data) > 0 {\n   568→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   569→\t\tw.Write(data)\n   570→\t\treturn\n   571→\t}\n   572→\n   573→\t// Last resort: try live docker logs from still-existing container\n   574→\tif h.container != nil && run.ContainerID != \"\" {\n   575→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   576→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   577→\t\t\tw.Write([]byte(logs))\n   578→\t\t\treturn\n   579→\t\t}\n   580→\t}\n   581→\n   582→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   583→}\n   584→\n   585→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   586→\tid := r.PathValue(\"id\")\n   587→\n   588→\trun, err := h.store.GetRun(r.Context(), id)\n   589→\tif err != nil {\n   590→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   591→\t\tw.WriteHeader(http.StatusNotFound)\n   592→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   593→\t\treturn\n   594→\t}\n   595→\n   596→\tmgr, ok := h.container.(ContainerManager)\n   597→\tif !ok || run.ContainerID == \"\" {\n   598→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   599→\t\tw.WriteHeader(http.StatusBadRequest)\n   600→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   601→\t\treturn\n   602→\t}\n   603→\n   604→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   605→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   606→\t\tw.WriteHeader(http.StatusInternalServerError)\n   607→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   608→\t\treturn\n   609→\t}\n   610→\n   611→\trun.ContainerKept = false\n   612→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   613→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   614→\t\tw.WriteHeader(http.StatusInternalServerError)\n   615→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   616→\t\treturn\n   617→\t}\n   618→\n   619→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   620→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   621→}\n   622→\n   623→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   624→\t// Placeholder endpoint — orchestrator integration is a separate feature.\n   625→\t// Returns 202 Accepted to indicate the request was received.\n   626→\tname := r.PathValue(\"name\")\n   627→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   628→\tw.WriteHeader(http.StatusAccepted)\n   629→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"accepted\", \"project\": name})\n   630→}\n   631→\n   632→// handleAPIStream serves an SSE stream of log lines for a run.\n   633→// For active runs, it subscribes to the live broadcaster.\n   634→// For completed runs, it serves the archived full.log then closes.\n   635→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   636→\tid := r.PathValue(\"id\")\n   637→\n   638→\trun, err := h.store.GetRun(r.Context(), id)\n   639→\tif err != nil {\n   640→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   641→\t\treturn\n   642→\t}\n   643→\n   644→\tflusher, ok := w.(http.Flusher)\n   645→\tif !ok {\n   646→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   647→\t\treturn\n   648→\t}\n   649→\n   650→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   651→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   652→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   653→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   654→\n   655→\tisComplete := run.State == domain.RunStateSucceeded ||\n   656→\t\trun.State == domain.RunStateFailed ||\n   657→\t\trun.State == domain.RunStateCancelled\n   658→\n   659→\tif isComplete {\n   660→\t\t// Serve archived full.log\n   661→\t\th.streamFullLog(w, flusher, run)\n   662→\t\t// Send done event\n   663→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   664→\t\tflusher.Flush()\n   665→\t\treturn\n   666→\t}\n   667→\n   668→\t// Active run: subscribe to live broadcaster\n   669→\tif h.logBroadcast == nil {\n   670→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   671→\t\treturn\n   672→\t}\n   673→\n   674→\tsub := h.logBroadcast.Subscribe(id)\n   675→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   676→\n   677→\tctx := r.Context()\n   678→\tfor {\n   679→\t\tselect {\n   680→\t\tcase <-ctx.Done():\n   681→\t\t\treturn\n   682→\t\tcase line, ok := <-sub.C:\n   683→\t\t\tif !ok {\n   684→\t\t\t\t// Stream finished (run completed)\n   685→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   686→\t\t\t\tflusher.Flush()\n   687→\t\t\t\treturn\n   688→\t\t\t}\n   689→\t\t\tdata, _ := json.Marshal(line)\n   690→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   691→\t\t\tflusher.Flush()\n   692→\t\t}\n   693→\t}\n   694→}\n   695→\n   696→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   697→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   698→\n   699→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   700→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   701→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   702→\tf, err := os.Open(logPath)\n   703→\tif err != nil {\n   704→\t\treturn\n   705→\t}\n   706→\tdefer f.Close()\n   707→\n   708→\tscanner := bufio.NewScanner(f)\n   709→\tfor scanner.Scan() {\n   710→\t\ttext := scanner.Text()\n   711→\t\tline := parseFullLogLine(text)\n   712→\t\tdata, _ := json.Marshal(line)\n   713→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   714→\t\tflusher.Flush()\n   715→\t}\n   716→}\n   717→\n   718→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   719→func parseFullLogLine(text string) logstream.LogLine {\n   720→\tm := logLineRegex.FindStringSubmatch(text)\n   721→\tif m == nil {\n   722→\t\treturn logstream.LogLine{\n   723→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   724→\t\t\tType:      \"script\",\n   725→\t\t\tContent:   text,\n   726→\t\t}\n   727→\t}\n   728→\treturn logstream.LogLine{\n   729→\t\tTimestamp: m[1],\n   730→\t\tType:      m[2],\n   731→\t\tContent:   m[3],\n   732→\t}\n   733→}\n   734→\n   735→// --- Template helpers ---\n   736→\n   737→func stateColor(state domain.RunState) string {\n   738→\tswitch state {\n   739→\tcase domain.RunStatePending:\n   740→\t\treturn \"pending\"\n   741→\tcase domain.RunStateRunning:\n   742→\t\treturn \"running\"\n   743→\tcase domain.RunStateSucceeded:\n   744→\t\treturn \"succeeded\"\n   745→\tcase domain.RunStateFailed:\n   746→\t\treturn \"failed\"\n   747→\tcase domain.RunStateCancelled:\n   748→\t\treturn \"cancelled\"\n   749→\tdefault:\n   750→\t\treturn \"pending\"\n   751→\t}\n   752→}\n   753→\n   754→func healthColor(status domain.HealthStatus) string {\n   755→\tswitch status {\n   756→\tcase domain.HealthGreen:\n   757→\t\treturn \"green\"\n   758→\tcase domain.HealthYellow:\n   759→\t\treturn \"yellow\"\n   760→\tcase domain.HealthRed:\n   761→\t\treturn \"red\"\n   762→\tcase domain.HealthBlue:\n   763→\t\treturn \"blue\"\n   764→\tdefault:\n   765→\t\treturn \"grey\"\n   766→\t}\n   767→}\n   768→\n   769→func formatTime(t time.Time) string {\n   770→\tif t.IsZero() {\n   771→\t\treturn \"\"\n   772→\t}\n   773→\treturn t.Format(\"2006-01-02 15:04:05\")\n   774→}\n   775→\n   776→func formatDuration(start, end time.Time) string {\n   777→\tif start.IsZero() || end.IsZero() {\n   778→\t\treturn \"\"\n   779→\t}\n   780→\td := end.Sub(start)\n   781→\tif d < time.Second {\n   782→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n   783→\t}\n   784→\tif d < time.Minute {\n   785→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n   786→\t}\n   787→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n   788→}\n   789→\n   790→func truncate(s string, n int) string {\n   791→\tif len(s) <= n {\n   792→\t\treturn s\n   793→\t}\n   794→\treturn s[:n] + \"...\"\n   795→}\n   796→\n   797→func shortContainerID(id string) string {\n   798→\tif len(id) > 12 {\n   799→\t\treturn id[:12]\n   800→\t}\n   801→\treturn id\n   802→}\n   803→\n   804→// projectLabels builds a mapping from full project directory paths to short\n   805→// display labels. Each label is the final directory component (e.g.\n   806→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n   807→// the same final name, the parent directory is prepended to disambiguate\n   808→// (e.g. \"foo/bar\" vs \"baz/bar\").\n   809→func projectLabels(dirs []string) map[string]string {\n   810→\tlabels := make(map[string]string, len(dirs))\n   811→\t// Group dirs by their base name to detect conflicts.\n   812→\tbyBase := map[string][]string{}\n   813→\tfor _, d := range dirs {\n   814→\t\tbase := filepath.Base(d)\n   815→\t\tbyBase[base] = append(byBase[base], d)\n   816→\t}\n   817→\tfor base, paths := range byBase {\n   818→\t\tif len(paths) == 1 {\n   819→\t\t\tlabels[paths[0]] = base\n   820→\t\t} else {\n   821→\t\t\tfor _, p := range paths {\n   822→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n   823→\t\t\t\tlabels[p] = parent + \"/\" + base\n   824→\t\t\t}\n   825→\t\t}\n   826→\t}\n   827→\treturn labels\n   828→}\n   829→\n   830→type projectEntry struct {\n   831→\tDir            string\n   832→\tLabel          string\n   833→\tContainerCount int\n   834→}\n   835→"}]},"parent_tool_use_id":null,"session_id":"809aa992-b695-4dca-b1d0-b9d1f49bc865","uuid":"8165fb24-4c93-47f2-aa9e-bee9aed3473d","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogStore     ports.LogStore\n\tcontainer    ContainerLogger\n\tlogBroadcast *logstream.Broadcaster\n\tpages        map[string]*template.Template\n\tmux          *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir        string\n\tLabel      string\n\tHealth     domain.HealthResult\n\tRecentRuns []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tcontainerAvailable := false\n\tif run.ContainerKept && run.ContainerID != \"\" {\n\t\tif mgr, ok := h.container.(ContainerManager); ok {\n\t\t\tif _, err := mgr.Inspect(r.Context(), run.ContainerID); err == nil {\n\t\t\t\tcontainerAvailable = true\n\t\t\t}\n\t\t}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":              \"Run \" + run.ID,\n\t\t\"Run\":                run,\n\t\t\"Steps\":              steps,\n\t\t\"Page\":               \"detail\",\n\t\t\"ContainerAvailable\": containerAvailable,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tSteps []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun: toAPIRun(run, labels),\n\t\tSteps:  steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n\t// Placeholder endpoint — orchestrator integration is a separate feature.\n\t// Returns 202 Accepted to indicate the request was received.\n\tname := r.PathValue(\"name\")\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusAccepted)\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"accepted\", \"project\": name})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Template helpers ---\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":835,"startLine":1,"totalLines":835}}}
