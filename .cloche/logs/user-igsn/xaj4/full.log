script := step.Config[\"script\"]; script != \"\" {\n  1189→\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1190→\t\tif err == nil {\n  1191→\t\t\tw.Write(data)\n  1192→\t\t\treturn\n  1193→\t\t}\n  1194→\t\tw.Write([]byte(script))\n  1195→\t\treturn\n  1196→\t}\n  1197→\n  1198→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1199→}\n  1200→\n  1201→// --- Template helpers ---\n  1202→\n  1203→func stateColor(state domain.RunState) string {"}]},"parent_tool_use_id":"toolu_01GMM9FNZGXHWEirR3BMoUoo","session_id":"052fc540-1ffc-410e-aea3-964a1bf4fcbd","uuid":"29d8b3f0-fc5a-4217-b964-ae8db725cc79"}
