Status computes the most important state across a set of runs.\n   529→// Priority: succeeded < cancelled < pending < running < failed.\n   530→func taskAggregateStatus(runs []*domain.Run) string {\n   531→\tpriority := map[domain.RunState]int{\n   532→\t\tdomain.RunStateSucceeded: 0,\n   533→\t\tdomain.RunStateCancelled: 1,\n   534→\t\tdomain.RunStatePending:   2,\n   535→\t\tdomain.RunStateRunning:   3,\n   536→\t\tdomain.RunStateFailed:    4,\n   537→\t}\n   538→\tbest := -1\n   539→\tbestState := domain.RunStatePending\n   540→\tfor _, r := range runs {\n   541→\t\tp, ok := priority[r.State]\n   542→\t\tif !ok {\n   543→\t\t\tp = 2 // treat unknown as pending\n   544→\t\t}\n   545→\t\tif p > best {\n   546→\t\t\tbest = p\n   547→\t\t\tbestState = r.State\n   548→\t\t}\n   549→\t}\n   550→\treturn string(bestState)\n   551→}\n   552→\n   553→// groupAndSortRuns filters, sorts, and groups runs by task, mirroring the\n   554→// logic previously done client-side. Returns a flat list of grouped entries\n   555→// suitable for both HTML template rendering and JSON API responses.\n   556→func groupAndSortRuns(runs []*domain.Run, labels map[string]string) []apiGroupedEntry {\n   557→\t// Filter out list-tasks runs\n   558→\tvar filtered []*domain.Run\n   559→\tfor _, r := range runs {\n   560→\t\tif r.WorkflowName != \"list-tasks\" {\n   561→\t\t\tfiltered = append(filtered, r)\n   562→\t\t}\n   563→\t}\n   564→"}]},"parent_tool_use_id":null,"session_id":"672a244f-d306-4bfb-8514-5ea42ce22c11","uuid":"87d1d751-e8df-43b2-b3e3-7e196f873829","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n\tChildRuns      []apiRun  `json:\"child_runs,omitempty\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tTiming:       formatRunTiming(r.State, r.StartedAt, r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t\tTitle:        r.Title,\n\t\tIsHost:       r.IsHost,\n\t\tParentRunID:  r.ParentRunID,\n\t\tTaskID:       r.TaskID,\n\t}\n}\n\n// apiGroupedEntry is a single entry in the grouped runs response.\n// Either a task header (TaskHeader true, Run nil) or a run entry.\ntype apiGroupedEntry struct {\n\tTaskHeader bool    `json:\"task_header,omitempty\"`\n\tTaskID     string  `json:\"task_id,omitempty\"`\n\tTaskStatus string  `json:\"task_status,omitempty\"` // aggregate status for task header\n\tIsParent   bool    `json:\"is_parent,omitempty\"`\n\tIsChild    bool    `json:\"is_child,omitempty\"`\n\tRun        *apiRun `json:\"run,omitempty\"`\n}\n\n// taskAggregateStatus computes the most important state across a set of runs.\n// Priority: succeeded < cancelled < pending < running < failed.\nfunc taskAggregateStatus(runs []*domain.Run) string {\n\tpriority := map[domain.RunState]int{\n\t\tdomain.RunStateSucceeded: 0,\n\t\tdomain.RunStateCancelled: 1,\n\t\tdomain.RunStatePending:   2,\n\t\tdomain.RunStateRunning:   3,\n\t\tdomain.RunStateFailed:    4,\n\t}\n\tbest := -1\n\tbestState := domain.RunStatePending\n\tfor _, r := range runs {\n\t\tp, ok := priority[r.State]\n\t\tif !ok {\n\t\t\tp = 2 // treat unknown as pending\n\t\t}\n\t\tif p > best {\n\t\t\tbest = p\n\t\t\tbestState = r.State\n\t\t}\n\t}\n\treturn string(bestState)\n}\n\n// groupAndSortRuns filters, sorts, and groups runs by task, mirroring the\n// logic previously done client-side. Returns a flat list of grouped entries\n// suitable for both HTML template rendering and JSON API responses.\nfunc groupAndSortRuns(runs []*domain.Run, labels map[string]string) []apiGroupedEntry {\n\t// Filter out list-tasks runs\n\tvar filtered []*domain.Run\n\tfor _, r := range runs {\n\t\tif r.WorkflowName != \"list-tasks\" {\n\t\t\tfiltered = append(filtered, r)\n\t\t}\n\t}\n","numLines":80,"startLine":485,"totalLines":1862}}}
