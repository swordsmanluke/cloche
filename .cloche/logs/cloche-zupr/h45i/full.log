 239→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   240→\texec.mu.Lock()\n   241→\tassert.Contains(t, exec.called, \"quick\")\n   242→\texec.mu.Unlock()\n   243→}\n   244→\n   245→func TestEngine_UndeclaredResultAborts(t *testing.T) {\n   246→\twf := &domain.Workflow{\n   247→\t\tName: \"undeclared\",\n   248→\t\tSteps: map[string]*domain.Step{\n   249→\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n   250→\t\t},\n   251→\t\tWiring: []domain.Wire{\n   252→\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n   253→\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n   254→\t\t},\n   255→\t\tEntryStep: \"code\",\n   256→\t}\n   257→\n   258→\texec := &fakeExecutor{results: map[string]string{\"code\": \"unknown\"}}\n   259→\teng := engine.New(exec)\n   260→\n   261→\trun, err := eng.Run(context.Background(), wf)\n   262→\trequire.Error(t, err)\n   263→\tassert.Equal(t, domain.RunStateFailed, run.State)\n   264→\tassert.Contains(t, err.Error(), \"undeclared\")\n   265→}\n   266→\n   267→// slowExecutor blocks until the context is cancelled, simulating a hanging agent.\n   268→type slowExecutor struct {\n   269→\tmu     sync.Mutex\n   270→\tcalled []string\n   271→}\n   272→\n   273→func (s *slowExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n   274→\ts.mu.Lock()\n   275→\ts.called = append(s.called, step.Name)\n   276→\ts.mu.Unlock()\n   277→\t<-ctx.Done()\n   278→\treturn \"\", fmt.Errorf(\"step %q timed out: %w\", step.Name, ctx.Err())\n   279→}\n   280→\n   281→func TestEngine_StepTimeout(t *testing.T) {\n   282→\twf := &domain.Workflow{\n   283→\t\tName: \"timeout-test\",\n   284→\t\tSteps: map[string]*domain.Step{\n   285→\t\t\t\"hang\": {\n   286→\t\t\t\tName:    \"hang\",\n   287→\t\t\t\tType:    domain.StepTypeAgent,\n   288→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   289→\t\t\t\tConfig:  map[string]string{\"prompt\": \"do stuff