[2026-03-13T17:54:42Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Es2CgVtmA2M7m3qcFgEGQt","type":"tool_result","content":"     1→package engine\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"sync\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11→)\n    12→\n    13→const DefaultStepTimeout = 30 * time.Minute\n    14→\n    15→// StepExecutor executes a single step and returns the result name.\n    16→type StepExecutor interface {\n    17→\tExecute(ctx context.Context, step *domain.Step) (string, error)\n    18→}\n    19→\n    20→// StepExecutorFunc adapts a function to the StepExecutor interface.\n    21→type StepExecutorFunc func(ctx context.Context, step *domain.Step) (string, error)\n    22→\n    23→func (f StepExecutorFunc) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    24→\treturn f(ctx, step)\n    25→}\n    26→\n    27→// StatusHandler receives notifications about workflow execution progress.\n    28→type StatusHandler interface {\n    29→\tOnStepStart(run *domain.Run, step *domain.Step)\n    30→\tOnStepComplete(run *domain.Run, step *domain.Step, result string)\n    31→\tOnRunComplete(run *domain.Run)\n    32→}\n    33→\n    34→type noopStatus struct{}\n    35→\n    36→func (noopStatus) OnStepStart(*domain.Run, *domain.Step)            {}\n    37→func (noopStatus) OnStepComplete(*domain.Run, *domain.Step, string) {}\n    38→func (noopStatus) OnRunComplete(*domain.Run)                        {}\n    39→\n    40→type Engine struct {\n    41→\texecutor       StepExecutor\n    42→\tstatus         StatusHandler\n    43→\tmaxSteps       int\n    44→\tdefaultTimeout time.Duration\n    45→}\n    46→\n    47→func New(executor StepExecutor) *Engine {\n    48→\treturn &Engine{\n    49→\t\texecutor:       executor,\n    50→\t\tstatus:         noopStatus{},\n    51→\t\tmaxSteps:       1000,\n    52→\t\tdefaultTimeout: DefaultStepTimeout,\n    53→\t}\n    54→}\n    55→\n    56→func (e *Engine) SetStatusHandler(h StatusHandler) {\n    57→\te.status = h\n    58→}\n    59→\n    60→func (e *Engine) SetMaxSteps(n int) {\n    61→\te.maxSteps = n\n    62→}\n    63→\n    64→// SetDefaultTimeout sets the default timeout for steps that don't specify one.\n    65→func (e *Engine) SetDefaultTimeout(d time.Duration) {\n    66→\te.defaultTimeout = d\n    67→}\n    68→\n    69→// stepResult is sent from worker goroutines back to the main event loop.\n    70→type stepResult struct {\n    71→\tstepName string\n    72→\tresult   string\n    73→\terr      error\n    74→}\n    75→\n    76→// collectState tracks the satisfaction state of a single Collect clause.\n    77→type collectState struct {\n    78→\tcollect   *domain.Collect\n    79→\tsatisfied map[int]bool\n    80→\tfired     bool\n    81→}\n    82→\n    83→func (e *Engine) Run(ctx context.Context, wf *domain.Workflow) (*domain.Run, error) {\n    84→\tif err := wf.Validate(); err != nil {\n    85→\t\treturn nil, fmt.Errorf(\"invalid workflow: %w\", err)\n    86→\t}\n    87→\tfor _, w := range wf.ValidateConfig() {\n    88→\t\tlog.Printf(\"WARNING: %s\", w)\n    89→\t}\n    90→\n    91→\trun := domain.NewRun(generateRunID(), wf.Name)\n    92→\trun.Start()\n    93→\n    94→\t// Check context cancellation before starting.\n    95→\tif err := ctx.Err(); err != nil {\n    96→\t\trun.Complete(domain.RunStateCancelled)\n    97→\t\treturn run, fmt.Errorf(\"workflow cancelled: %w\", err)\n    98→\t}\n    99→\n   100→\t// Build a set of (step, result) pairs that are handled by collects,\n   101→\t// so we know when a missing wire is acceptable.\n   102→\tcollectHandled := make(map[string]map[string]bool)\n   103→\tfor _, c := range wf.Collects {\n   104→\t\tfor _, cond := range c.Conditions {\n   105→\t\t\tif collectHandled[cond.Step] == nil {\n   106→\t\t\t\tcollectHandled[cond.Step] = make(map[string]bool)\n   107→\t\t\t}\n   108→\t\t\tcollectHandled[cond.Step][cond.Result] = true\n   109→\t\t}\n   110→\t}\n   111→\n   112→\t// Initialize collect states.\n   113→\tcStates := make([]*collectState, len(wf.Collects))\n   114→\tfor i := range wf.Collects {\n   115→\t\tcStates[i] = &collectState{\n   116→\t\t\tcollect:   &wf.Collects[i],\n   117→\t\t\tsatisfied: make(map[int]bool),\n   118→\t\t}\n   119→\t}\n   120→\n   121→\tresults := make(chan stepResult, e.maxSteps)\n   122→\tactiveCount := 0\n   123→\tstepCount := 0\n   124→\tdoneCount := 0\n   125→\taborted := false\n   126→\tvar runErr error\n   127→\n   128→\t// Use a mutex to protect run state from concurrent goroutine access.\n   129→\t// Only the main loop should touch the Run, but we record step start before\n   130→\t// launching the goroutine, so this is safe without a mutex for now.\n   131→\t// The goroutines only read the step and send on the channel.\n   132→\n   133→\tlaunchStep := func(stepName string) error {\n   134→\t\tstepCount++\n   135→\t\tif stepCount > e.maxSteps {\n   136→\t\t\treturn fmt.Errorf(\"workflow exceeded maximum step count (%d)\", e.maxSteps)\n   137→\t\t}\n   138→\n   139→\t\tstep, ok := wf.Steps[stepName]\n   140→\t\tif !ok {\n   141→\t\t\treturn fmt.Errorf(\"step %q not found in workflow\", stepName)\n   142→\t\t}\n   143→\n   144→\t\tactiveCount++\n   145→\t\trun.RecordStepStart(step.Name)\n   146→\t\te.status.OnStepStart(run, step)\n   147→\n   148→\t\tgo func(s *domain.Step) {\n   149→\t\t\tstepCtx := ctx\n   150→\t\t\tif d := stepTimeout(s, e.defaultTimeout); d > 0 {\n   151→\t\t\t\tvar cancel context.CancelFunc\n   152→\t\t\t\tstepCtx, cancel = context.WithTimeout(ctx, d)\n   153→\t\t\t\tdefer cancel()\n   154→\t\t\t}\n   155→\t\t\tresult, err := e.executor.Execute(stepCtx, s)\n   156→\t\t\tresults <- stepResult{stepName: s.Name, result: result, err: err}\n   157→\t\t}(step)\n   158→\n   159→\t\treturn nil\n   160→\t}\n   161→\n   162→\t// Launch entry step.\n   163→\tif err := launchStep(wf.EntryStep); err != nil {\n   164→\t\trun.Complete(domain.RunStateFailed)\n   165→\t\treturn run, err\n   166→\t}\n   167→\n   168→\t// Main event loop.\n   169→\tfor activeCount > 0 {\n   170→\t\tselect {\n   171→\t\tcase <-ctx.Done():\n   172→\t\t\trun.Complete(domain.RunStateCancelled)\n   173→\t\t\treturn run, fmt.Errorf(\"workflow cancelled: %w\", ctx.Err())\n   174→\n   175→\t\tcase sr := <-results:\n   176→\t\t\tactiveCount--\n   177→\n   178→\t\t\t// Step execution error.\n   179→\t\t\tif sr.err != nil {\n   180→\t\t\t\trun.RecordStepComplete(sr.stepName, \"error\")\n   181→\t\t\t\trun.Complete(domain.RunStateFailed)\n   182→\t\t\t\te.status.OnRunComplete(run)\n   183→\t\t\t\treturn run, fmt.Errorf(\"step %q execution failed: %w\", sr.stepName, sr.err)\n   184→\t\t\t}\n   185→\n   186→\t\t\t// Validate result is declared in the step's Results list.\n   187→\t\t\tstep := wf.Steps[sr.stepName]\n   188→\t\t\tif !isResultDeclared(step, sr.result) {\n   189→\t\t\t\trun.RecordStepComplete(sr.stepName, sr.result)\n   190→\t\t\t\trun.Complete(domain.RunStateFailed)\n   191→\t\t\t\te.status.OnRunComplete(run)\n   192→\t\t\t\treturn run, fmt.Errorf(\"step %q returned undeclared result %q\", sr.stepName, sr.result)\n   193→\t\t\t}\n   194→\n   195→\t\t\trun.RecordStepComplete(sr.stepName, sr.result)\n   196→\t\t\te.status.OnStepComplete(run, step, sr.result)\n   197→\n   198→\t\t\t// Process wiring: get next steps for this (step, result) pair.\n   199→\t\t\tnextSteps, wireErr := wf.NextSteps(sr.stepName, sr.result)\n   200→\t\t\tif wireErr != nil {\n   201→\t\t\t\t// No wire found. Check if any collect handles this (step, result).\n   202→\t\t\t\tif !collectHandled[sr.stepName][sr.result] {\n   203→\t\t\t\t\t// Neither wires nor collects handle this result.\n   204→\t\t\t\t\trun.Complete(domain.RunStateFailed)\n   205→\t\t\t\t\te.status.OnRunComplete(run)\n   206→\t\t\t\t\treturn run, wireErr\n   207→\t\t\t\t}\n   208→\t\t\t\t// Collect handles it; no wire targets to launch.\n   209→\t\t\t} else {\n   210→\t\t\t\t// Process wire targets.\n   211→\t\t\t\tfor _, target := range nextSteps {\n   212→\t\t\t\t\tswitch target {\n   213→\t\t\t\t\tcase domain.StepDone:\n   214→\t\t\t\t\t\tdoneCount++\n   215→\t\t\t\t\tcase domain.StepAbort:\n   216→\t\t\t\t\t\taborted = true\n   217→\t\t\t\t\tdefault:\n   218→\t\t\t\t\t\tif err := launchStep(target); err != nil {\n   219→\t\t\t\t\t\t\trun.Complete(domain.RunStateFailed)\n   220→\t\t\t\t\t\t\te.status.OnRunComplete(run)\n   221→\t\t\t\t\t\t\treturn run, err\n   222→\t\t\t\t\t\t}\n   223→\t\t\t\t\t}\n   224→\t\t\t\t}\n   225→\t\t\t}\n   226→\n   227→\t\t\t// Check and fire collect conditions.\n   228→\t\t\tfor _, cs := range cStates {\n   229→\t\t\t\tif cs.fired {\n   230→\t\t\t\t\tcontinue\n   231→\t\t\t\t}\n   232→\t\t\t\tfor i, cond := range cs.collect.Conditions {\n   233→\t\t\t\t\tif cond.Step == sr.stepName && cond.Result == sr.result {\n   234→\t\t\t\t\t\tcs.satisfied[i] = true\n   235→\t\t\t\t\t}\n   236→\t\t\t\t}\n   237→\n   238→\t\t\t\tshouldFire := false\n   239→\t\t\t\tswitch cs.collect.Mode {\n   240→\t\t\t\tcase domain.CollectAll:\n   241→\t\t\t\t\tshouldFire = len(cs.satisfied) == len(cs.collect.Conditions)\n   242→\t\t\t\tcase domain.CollectAny:\n   243→\t\t\t\t\tshouldFire = len(cs.satisfied) > 0\n   244→\t\t\t\t}\n   245→\n   246→\t\t\t\tif shouldFire {\n   247→\t\t\t\t\tcs.fired = true\n   248→\t\t\t\t\ttarget := cs.collect.To\n   249→\t\t\t\t\tswitch target {\n   250→\t\t\t\t\tcase domain.StepDone:\n   251→\t\t\t\t\t\tdoneCount++\n   252→\t\t\t\t\tcase domain.StepAbort:\n   253→\t\t\t\t\t\taborted = true\n   254→\t\t\t\t\tdefault:\n   255→\t\t\t\t\t\tif err := launchStep(target); err != nil {\n   256→\t\t\t\t\t\t\trun.Complete(domain.RunStateFailed)\n   257→\t\t\t\t\t\t\te.status.OnRunComplete(run)\n   258→\t\t\t\t\t\t\treturn run, err\n   259→\t\t\t\t\t\t}\n   260→\t\t\t\t\t}\n   261→\t\t\t\t}\n   262→\t\t\t}\n   263→\t\t}\n   264→\t}\n   265→\n   266→\t// Determine final state.\n   267→\tif aborted || runErr != nil {\n   268→\t\trun.Complete(domain.RunStateFailed)\n   269→\t} else if doneCount > 0 {\n   270→\t\trun.Complete(domain.RunStateSucceeded)\n   271→\t} else {\n   272→\t\trun.Complete(domain.RunStateFailed)\n   273→\t\trunErr = fmt.Errorf(\"workflow %q: no branches reached done\", wf.Name)\n   274→\t}\n   275→\n   276→\te.status.OnRunComplete(run)\n   277→\treturn run, runErr\n   278→}\n   279→\n   280→// isResultDeclared checks whether the given result is in the step's declared Results list.\n   281→func isResultDeclared(step *domain.Step, result string) bool {\n   282→\tfor _, r := range step.Results {\n   283→\t\tif r == result {\n   284→\t\t\treturn true\n   285→\t\t}\n   286→\t}\n   287→\treturn false\n   288→}\n   289→\n   290→var (\n   291→\trunCounter int\n   292→\trunMu      sync.Mutex\n   293→)\n   294→\n   295→func generateRunID() string {\n   296→\trunMu.Lock()\n   297→\tdefer runMu.Unlock()\n   298→\trunCounter++\n   299→\treturn fmt.Sprintf(\"run-%d\", runCounter)\n   300→}\n   301→\n   302→// stepTimeout returns the timeout for a step. It checks step.Config[\"timeout\"]\n   303→// first, falling back to the provided default.\n   304→func stepTimeout(step *domain.Step, defaultTimeout time.Duration) time.Duration {\n   305→\tif raw, ok := step.Config[\"timeout\"]; ok {\n   306→\t\tif d, err := time.ParseDuration(raw); err == nil {\n   307→\t\t\treturn d\n   308→\t\t}\n   309→\t}\n   310→\treturn defaultTimeout\n   311→}\n   312→"}]},"parent_tool_use_id":null,"session_id":"672a244f-d306-4bfb-8514-5ea42ce22c11","uuid":"029af859-62be-4c17-bbc7-6bbdeb46991a","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/engine/engine.go","content":"package engine\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n)\n\nconst DefaultStepTimeout = 30 * time.Minute\n\n// StepExecutor executes a single step and returns the result name.\ntype StepExecutor interface {\n\tExecute(ctx context.Context, step *domain.Step) (string, error)\n}\n\n// StepExecutorFunc adapts a function to the StepExecutor interface.\ntype StepExecutorFunc func(ctx context.Context, step *domain.Step) (string, error)\n\nfunc (f StepExecutorFunc) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\treturn f(ctx, step)\n}\n\n// StatusHandler receives notifications about workflow execution progress.\ntype StatusHandler interface {\n\tOnStepStart(run *domain.Run, step *domain.Step)\n\tOnStepComplete(run *domain.Run, step *domain.Step, result string)\n\tOnRunComplete(run *domain.Run)\n}\n\ntype noopStatus struct{}\n\nfunc (noopStatus) OnStepStart(*domain.Run, *domain.Step)            {}\nfunc (noopStatus) OnStepComplete(*domain.Run, *domain.Step, string) {}\nfunc (noopStatus) OnRunComplete(*domain.Run)                        {}\n\ntype Engine struct {\n\texecutor       StepExecutor\n\tstatus         StatusHandler\n\tmaxSteps       int\n\tdefaultTimeout time.Duration\n}\n\nfunc New(executor StepExecutor) *Engine {\n\treturn &Engine{\n\t\texecutor:       executor,\n\t\tstatus:         noopStatus{},\n\t\tmaxSteps:       1000,\n\t\tdefaultTimeout: DefaultStepTimeout,\n\t}\n}\n\nfunc (e *Engine) SetStatusHandler(h StatusHandler) {\n\te.status = h\n}\n\nfunc (e *Engine) SetMaxSteps(n int) {\n\te.maxSteps = n\n}\n\n// SetDefaultTimeout sets the default timeout for steps that don't specify one.\nfunc (e *Engine) SetDefaultTimeout(d time.Duration) {\n\te.defaultTimeout = d\n}\n\n// stepResult is sent from worker goroutines back to the main event loop.\ntype stepResult struct {\n\tstepName string\n\tresult   string\n\terr      error\n}\n\n// collectState tracks the satisfaction state of a single Collect clause.\ntype collectState struct {\n\tcollect   *domain.Collect\n\tsatisfied map[int]bool\n\tfired     bool\n}\n\nfunc (e *Engine) Run(ctx context.Context, wf *domain.Workflow) (*domain.Run, error) {\n\tif err := wf.Validate(); err != nil {\n\t\treturn nil, fmt.Errorf(\"invalid workflow: %w\", err)\n\t}\n\tfor _, w := range wf.ValidateConfig() {\n\t\tlog.Printf(\"WARNING: %s\", w)\n\t}\n\n\trun := domain.NewRun(generateRunID(), wf.Name)\n\trun.Start()\n\n\t// Check context cancellation before starting.\n\tif err := ctx.Err(); err != nil {\n\t\trun.Complete(domain.RunStateCancelled)\n\t\treturn run, fmt.Errorf(\"workflow cancelled: %w\", err)\n\t}\n\n\t// Build a set of (step, result) pairs that are handled by collects,\n\t// so we know when a missing wire is acceptable.\n\tcollectHandled := make(map[string]map[string]bool)\n\tfor _, c := range wf.Collects {\n\t\tfor _, cond := range c.Conditions {\n\t\t\tif collectHandled[cond.Step] == nil {\n\t\t\t\tcollectHandled[cond.Step] = make(map[string]bool)\n\t\t\t}\n\t\t\tcollectHandled[cond.Step][cond.Result] = true\n\t\t}\n\t}\n\n\t// Initialize collect states.\n\tcStates := make([]*collectState, len(wf.Collects))\n\tfor i := range wf.Collects {\n\t\tcStates[i] = &collectState{\n\t\t\tcollect:   &wf.Collects[i],\n\t\t\tsatisfied: make(map[int]bool),\n\t\t}\n\t}\n\n\tresults := make(chan stepResult, e.maxSteps)\n\tactiveCount := 0\n\tstepCount := 0\n\tdoneCount := 0\n\taborted := false\n\tvar runErr error\n\n\t// Use a mutex to protect run state from concurrent goroutine access.\n\t// Only the main loop should touch the Run, but we record step start before\n\t// launching the goroutine, so this is safe without a mutex for now.\n\t// The goroutines only read the step and send on the channel.\n\n\tlaunchStep := func(stepName string) error {\n\t\tstepCount++\n\t\tif stepCount > e.maxSteps {\n\t\t\treturn fmt.Errorf(\"workflow exceeded maximum step count (%d)\", e.maxSteps)\n\t\t}\n\n\t\tstep, ok := wf.Steps[stepName]\n\t\tif !ok {\n\t\t\treturn fmt.Errorf(\"step %q not found in workflow\", stepName)\n\t\t}\n\n\t\tactiveCount++\n\t\trun.RecordStepStart(step.Name)\n\t\te.status.OnStepStart(run, step)\n\n\t\tgo func(s *domain.Step) {\n\t\t\tstepCtx := ctx\n\t\t\tif d := stepTimeout(s, e.defaultTimeout); d > 0 {\n\t\t\t\tvar cancel context.CancelFunc\n\t\t\t\tstepCtx, cancel = context.WithTimeout(ctx, d)\n\t\t\t\tdefer cancel()\n\t\t\t}\n\t\t\tresult, err := e.executor.Execute(stepCtx, s)\n\t\t\tresults <- stepResult{stepName: s.Name, result: result, err: err}\n\t\t}(step)\n\n\t\treturn nil\n\t}\n\n\t// Launch entry step.\n\tif err := launchStep(wf.EntryStep); err != nil {\n\t\trun.Complete(domain.RunStateFailed)\n\t\treturn run, err\n\t}\n\n\t// Main event loop.\n\tfor activeCount > 0 {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\trun.Complete(domain.RunStateCancelled)\n\t\t\treturn run, fmt.Errorf(\"workflow cancelled: %w\", ctx.Err())\n\n\t\tcase sr := <-results:\n\t\t\tactiveCount--\n\n\t\t\t// Step execution error.\n\t\t\tif sr.err != nil {\n\t\t\t\trun.RecordStepComplete(sr.stepName, \"error\")\n\t\t\t\trun.Complete(domain.RunStateFailed)\n\t\t\t\te.status.OnRunComplete(run)\n\t\t\t\treturn run, fmt.Errorf(\"step %q execution failed: %w\", sr.stepName, sr.err)\n\t\t\t}\n\n\t\t\t// Validate result is declared in the step's Results list.\n\t\t\tstep := wf.Steps[sr.stepName]\n\t\t\tif !isResultDeclared(step, sr.result) {\n\t\t\t\trun.RecordStepComplete(sr.stepName, sr.result)\n\t\t\t\trun.Complete(domain.RunStateFailed)\n\t\t\t\te.status.OnRunComplete(run)\n\t\t\t\treturn run, fmt.Errorf(\"step %q returned undeclared result %q\", sr.stepName, sr.result)\n\t\t\t}\n\n\t\t\trun.RecordStepComplete(sr.stepName, sr.result)\n\t\t\te.status.OnStepComplete(run, step, sr.result)\n\n\t\t\t// Process wiring: get next steps for this (step, result) pair.\n\t\t\tnextSteps, wireErr := wf.NextSteps(sr.stepName, sr.result)\n\t\t\tif wireErr != nil {\n\t\t\t\t// No wire found. Check if any collect handles this (step, result).\n\t\t\t\tif !collectHandled[sr.stepName][sr.result] {\n\t\t\t\t\t// Neither wires nor collects handle this result.\n\t\t\t\t\trun.Complete(domain.RunStateFailed)\n\t\t\t\t\te.status.OnRunComplete(run)\n\t\t\t\t\treturn run, wireErr\n\t\t\t\t}\n\t\t\t\t// Collect handles it; no wire targets to launch.\n\t\t\t} else {\n\t\t\t\t// Process wire targets.\n\t\t\t\tfor _, target := range nextSteps {\n\t\t\t\t\tswitch target {\n\t\t\t\t\tcase domain.StepDone:\n\t\t\t\t\t\tdoneCount++\n\t\t\t\t\tcase domain.StepAbort:\n\t\t\t\t\t\taborted = true\n\t\t\t\t\tdefault:\n\t\t\t\t\t\tif err := launchStep(target); err != nil {\n\t\t\t\t\t\t\trun.Complete(domain.RunStateFailed)\n\t\t\t\t\t\t\te.status.OnRunComplete(run)\n\t\t\t\t\t\t\treturn run, err\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// Check and fire collect conditions.\n\t\t\tfor _, cs := range cStates {\n\t\t\t\tif cs.fired {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tfor i, cond := range cs.collect.Conditions {\n\t\t\t\t\tif cond.Step == sr.stepName && cond.Result == sr.result {\n\t\t\t\t\t\tcs.satisfied[i] = true\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tshouldFire := false\n\t\t\t\tswitch cs.collect.Mode {\n\t\t\t\tcase domain.CollectAll:\n\t\t\t\t\tshouldFire = len(cs.satisfied) == len(cs.collect.Conditions)\n\t\t\t\tcase domain.CollectAny:\n\t\t\t\t\tshouldFire = len(cs.satisfied) > 0\n\t\t\t\t}\n\n\t\t\t\tif shouldFire {\n\t\t\t\t\tcs.fired = true\n\t\t\t\t\ttarget := cs.collect.To\n\t\t\t\t\tswitch target {\n\t\t\t\t\tcase domain.StepDone:\n\t\t\t\t\t\tdoneCount++\n\t\t\t\t\tcase domain.StepAbort:\n\t\t\t\t\t\taborted = true\n\t\t\t\t\tdefault:\n\t\t\t\t\t\tif err := launchStep(target); err != nil {\n\t\t\t\t\t\t\trun.Complete(domain.RunStateFailed)\n\t\t\t\t\t\t\te.status.OnRunComplete(run)\n\t\t\t\t\t\t\treturn run, err\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Determine final state.\n\tif aborted || runErr != nil {\n\t\trun.Complete(domain.RunStateFailed)\n\t} else if doneCount > 0 {\n\t\trun.Complete(domain.RunStateSucceeded)\n\t} else {\n\t\trun.Complete(domain.RunStateFailed)\n\t\trunErr = fmt.Errorf(\"workflow %q: no branches reached done\", wf.Name)\n\t}\n\n\te.status.OnRunComplete(run)\n\treturn run, runErr\n}\n\n// isResultDeclared checks whether the given result is in the step's declared Results list.\nfunc isResultDeclared(step *domain.Step, result string) bool {\n\tfor _, r := range step.Results {\n\t\tif r == result {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\nvar (\n\trunCounter int\n\trunMu      sync.Mutex\n)\n\nfunc generateRunID() string {\n\trunMu.Lock()\n\tdefer runMu.Unlock()\n\trunCounter++\n\treturn fmt.Sprintf(\"run-%d\", runCounter)\n}\n\n// stepTimeout returns the timeout for a step. It checks step.Config[\"timeout\"]\n// first, falling back to the provided default.\nfunc stepTimeout(step *domain.Step, defaultTimeout time.Duration) time.Duration {\n\tif raw, ok := step.Config[\"timeout\"]; ok {\n\t\tif d, err := time.ParseDuration(raw); err == nil {\n\t\t\treturn d\n\t\t}\n\t}\n\treturn defaultTimeout\n}\n","numLines":312,"startLine":1,"totalLines":312}}}
