tring) (*RunResult, error) {\n    43→\treturn r.RunWithID(ctx, projectDir, domain.GenerateRunID(\"main\"))\n    44→}\n    45→\n    46→// RunWithID is like Run but uses the provided run ID instead of generating one.\n    47→func (r *Runner) RunWithID(ctx context.Context, projectDir string, orchRunID string) (*RunResult, error) {\n    48→\treturn r.runNamedWorkflow(ctx, projectDir, \"main\", orchRunID)\n    49→}\n    50→\n    51→// RunNamed parses .cloche/host.cloche from projectDir and executes the workflow\n    52→// with the given name. The host.cloche file may contain multiple workflows (e.g.\n    53→// \"list-tasks\", \"main\", \"finalize\"). Returns an error if the named workflow is\n    54→// not found.\n    55→func (r *Runner) RunNamed(ctx context.Context, projectDir string, workflowName string) (*RunResult, error) {\n    56→\torchRunID := domain.GenerateRunID(workflowName)\n    57→\treturn r.runNamedWorkflow(ctx, projectDir, workflowName, orchRunID)\n    58→}\n    59→\n    60→// runNamedWorkflow is the internal implementation that runs a specific named\n    61→// workflow from host.cloche.\n    62→func (r *Runner) runNamedWorkflow(ctx context.Context, projectDir string, workflowName string, orchRunID string) (*RunResult, error) {\n    63→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n    64→\tdata, err := os.ReadFile(hostPath)\n    65→\tif err != nil {\n    66→\t\treturn nil, fmt.Errorf(\"reading host.cloche: %w\", err)\n    67→\t}\n    68→\n    69→\tworkflows, err := dsl.ParseAllForHost(string(data))\n    70→\tif err != nil {\n    71→\t\treturn nil, fmt.Errorf(\"parsing host.cloche: %w\", err)\n    72→\t}\n    73→\n    74→\twf, ok := workflows[workflowName]\n    75→\tif !ok {\n    76→\t\treturn nil, fmt.Errorf(\"host.cloche has no workflow %q\", workflowName)\n    77→\t}\n    78→\n    79→\t// Create output directory for step outputs\n    80→\toutputDir := filepath.Join(projectDir, \".cloche\", orchRunID, \"output\")\n    81→\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n    82→\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n    83→\t}\n    84→\n    85→\tlog.Printf(\"host workflow: starting %q for project %s (run %s)\", wf.Name, projectDir, orchRunID)\n    86→\n    87→\t// Persist the host run in the store so it appears in list/status/logs.\n    88→\t// When SkipRunRecord is set (e.g. for list-tasks polling), skip creating\n    89→\t// the record to avoid cluttering the run history.\n    90→\tif !r.SkipRunRecord {\n    91→\t\thostRun := domain.NewRun(orchRunID, wf.Name)\n    92→\t\thostRun.ProjectDir = projectDir\n    93→\t\thostRun.IsHost = true\n    94→\t\thostRun.TaskID = r.TaskID\n    95→\t\tif err := r.Store.CreateRun(ctx, hostRun); err != nil {\n    96→\t\t\treturn nil, fmt.Errorf(\"creating host run record: %w\", err)\n    97→\t\t}\n    98→\t\thostRun.Start()\n    99→\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n   100→\t}\n   101→\n   102→\texecutor := &Executor{\n   103→\t\tProjectDir: projectDir,\n   104→\t\tMainDir:    MainWorktreeDir(projectDir),\n   105→\t\tDispatcher: r.Dispatcher,\n   106→\t\tStore:      r.Store,\n   107→\t\tOutputDir:  outputDir,\n   108→\t\tWires:      wf.Wiring,\n   109→\t\tHostRunID:  orchRunID,\n   110→\t\tTaskID:     r.TaskID,\n   111→\t\tExtraEnv:   r.ExtraEnv,\n   112→\t}\n   113→\n   114→\t// Configure agent from workflow-level host config\n   115→\tif cmd := wf.Config[\"host.agent_command\"]; cmd != \"\" {\n   116→\t\texecutor.AgentCommands = prompt.ParseCommands(cmd)\n   117→\t}\n   118→\tif args := wf.Config[\"host.agent_args\"]; args != \"\" {\n   119→\t\texecutor.AgentArgs = strings.Fields(args)\n   120→\t}\n   121→\n   122→\teng := engine.New(executor)\n   123→\teng.SetStatusHandler(&hostStatusHandler{\n   124→\t\tprojectDir:   projectDir,\n   125→\t\torchRunID:    orchRunID,\n   126→\t\tstore:        r.Store,\n   127→\t\tcaptures:     r.Captures,\n   128→\t\tlogBroadcast: r.LogBroadcast,\n   129→\t\toutputDir:    outputDir,\n   130→\t})\n   131→\n   132→\trun, runErr := eng.Run(ctx, wf)\n   133→\n   134→\tresult := &RunResult{\n   135→\t\tRunID:     orchRunID,\n   136→\t\tState:     domain.RunStateFailed,\n   137→\t\tOutputDir: outputDir,\n   138→\t}\n   139→\tif run != nil {\n   140→\t\tresult.State = run.State\n   141→\t}\n   142→\n   143→\t// Persist final state.\n   144→\tif !r.SkipRunRecord {\n   145→\t\thostRun, _ := r.Store.GetRun(ctx, orchRunID)\n   146→\t\tif hostRun != nil {\n   147→\t\t\tif runErr != nil {\n   148→\t\t\t\thostRun.Fail(runErr.Error())\n   149→\t\t\t} else {\n   150→\t\t\t\thostRun.Complete(result.State)\n   151→\t\t\t}\n   152→\t\t\thostRun.ActiveSteps = nil\n   153→\t\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n   154→\t\t}\n   155→\t}\n   156→\n   157→\tif runErr != nil {\n   158→\t\tlog.Printf(\"host workflow: %q failed for %s: %v\", wf.Name, projectDir, runErr)\n   159→\t\treturn result, runErr\n   160→\t}\n   161→\n   162→\tlog.Printf(\"host workflow: %q completed for %s with state %s\", wf.Name, projectDir, run.State)\n   163→\treturn result, nil\n   164→}\n   165→\n   166→// RunListTasksWorkflow executes the list-tasks workflow and returns the\n   167→// discovered tasks. No run record is created for list-tasks executions since\n   168→// they are polling operations that would otherwise clutter the run history.\n   169→func RunListTasksWorkflow(ctx context.Context, runner *Runner, projectDir string) ([]Task, *RunResult, error) {\n   170→\trunner.SkipRunRecord = true\n   171→\tresult, err := runner.RunNamed(ctx, projectDir, \"list-tasks\")\n   172→\tif err != nil {\n   173→\t\treturn nil, nil, err\n   174→\t}\n   175→\tif result.State != domain.RunStateSucceeded {\n   176→\t\treturn nil, result, fmt.Errorf(\"list-tasks workflow failed with state %s\", result.State)\n   177→\t}\n   178→\ttasks, err := ReadListTasksOutput(result.OutputDir)\n   179→\tif err != nil {\n   180→\t\treturn nil, result, err\n   181→\t}\n   182→\treturn tasks, result, nil\n   183→}\n   184→\n   185→// hostStatusHandler logs host workflow step events and persists them to the store.\n   186→// It mirrors the container-side status pipeline: saving captures and publishing\n   187→// to the log broadcaster so that cloche logs works identically for host runs.\n   188→type hostStatusHandler struct {\n   189→\tprojectDir   string\n   190→\torchRunID    string\n   191→\tstore        ports.RunStore\n   192→\tcaptures     ports.CaptureStore\n   193→\tlogBroadcast *logstream.Broadcaster\n   194→\toutputDir    string\n   195→}\n   196→\n   197→func (h *hostStatusHandler) OnStepStart(_ *domain.Run, step *domain.Step) {\n   198→\tnow := time.Now()\n   199→\tlog.Printf(\"host workflow [%s]: step %q started\", h.orchRunID, step.Name)\n   200→\tif h.store != nil {\n   201→\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n   202→\t\t\tr.RecordStepStart(step.Name)\n   203→\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n   204→\t\t}\n   205→\t}\n   206→\tif h.captures != nil {\n   207→\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n   208→\t\t\tStepName:  step.Name,\n   209→\t\t\tStartedAt: now,\n   210→\t\t})\n   211→\t}\n   212→\tif h.logBroadcast != nil {\n   213→\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n   214→\t\t\tTimestamp: now.Format(time.RFC3339),\n   215→\t\t\tType:      \"status\",\n   216→\t\t\tContent:   \"step_started: \" + step.Name,\n   217→\t\t\tStepName:  step.Name,\n   218→\t\t})\n   219→\t}\n   220→}\n   221→\n   222→func (h *hostStatusHandler) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   223→\tnow := time.Now()\n   224→\tlog.Printf(\"host workflow [%s]: step %q completed with result %q\", h.orchRunID, step.Name, result)\n   225→\tif h.store != nil {\n   226→\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n   227→\t\t\tr.RecordStepComplete(step.Name, result)\n   228→\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n   229→\t\t}\n   230→\t}\n   231→\tif h.captures != nil {\n   232→\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n   233→\t\t\tStepName:    step.Name,\n   234→\t\t\tResult:      result,\n   235→\t\t\tCompletedAt: now,\n   236→\t\t})\n   237→\t}\n   238→\tif h.logBroadcast != nil {\n   239→\t\t// Read step output and publish it before the completion event.\n   240→\t\toutputPath := filepath.Join(h.outputDir, step.Name+\".out\")\n   241→\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   242→\t\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n   243→\t\t\t\tTimestamp: now.Format(time.RFC3339),\n   244→\t\t\t\tType:      \"script\",\n   245→\t\t\t\tContent:   string(data),\n   246→\t\t\t\tStepName:  step.Name,\n   247→\t\t\t})\n   248→\t\t}\n   249→\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n   250→\t\t\tTimestamp: now.Format(time.RFC3339),\n   251→\t\t\tType:      \"status\",\n   252→\t\t\tContent:   \"step_completed: \" + step.Name + \" -> \" + result,\n   253→\t\t\tStepName:  step.Name,\n   254→\t\t})\n   255→\t}\n   256→}\n   257→\n   258→func (h *hostStatusHandler) OnRunComplete(run *domain.Run) {\n   259→\tlog.Printf(\"host workflow [%s]: run completed with state %s\", h.orchRunID, run.State)\n   260→}\n   261→"}]},"parent_tool_use_id":null,"session_id":"672a244f-d306-4bfb-8514-5ea42ce22c11","uuid":"ab633033-1280-4c90-bb11-bbb707684d07","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/runner.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// Ensure hostStatusHandler implements engine.StatusHandler.\nvar _ engine.StatusHandler = (*hostStatusHandler)(nil)\n\n// Runner executes a host workflow by parsing host.cloche and walking the step graph.\ntype Runner struct {\n\tDispatcher    RunDispatcher\n\tStore         ports.RunStore\n\tCaptures      ports.CaptureStore       // optional: saves step captures for cloche logs\n\tLogBroadcast  *logstream.Broadcaster   // optional: publishes live log lines\n\tTaskID        string                   // optional task ID assigned by the daemon loop\n\tExtraEnv      []string                 // additional KEY=VALUE env vars passed to all steps\n\tSkipRunRecord bool                     // when true, don't persist a run record to the store\n}\n\n// RunResult contains the outcome of a host workflow execution.\ntype RunResult struct {\n\tRunID     string\n\tState     domain.RunState\n\tOutputDir string // path to the step output directory\n}\n\n// Run parses .cloche/host.cloche from projectDir and executes the \"main\" workflow.\nfunc (r *Runner) Run(ctx context.Context, projectDir string) (*RunResult, error) {\n\treturn r.RunWithID(ctx, projectDir, domain.GenerateRunID(\"main\"))\n}\n\n// RunWithID is like Run but uses the provided run ID instead of generating one.\nfunc (r *Runner) RunWithID(ctx context.Context, projectDir string, orchRunID string) (*RunResult, error) {\n\treturn r.runNamedWorkflow(ctx, projectDir, \"main\", orchRunID)\n}\n\n// RunNamed parses .cloche/host.cloche from projectDir and executes the workflow\n// with the given name. The host.cloche file may contain multiple workflows (e.g.\n// \"list-tasks\", \"main\", \"finalize\"). Returns an error if the named workflow is\n// not found.\nfunc (r *Runner) RunNamed(ctx context.Context, projectDir string, workflowName string) (*RunResult, error) {\n\torchRunID := domain.GenerateRunID(workflowName)\n\treturn r.runNamedWorkflow(ctx, projectDir, workflowName, orchRunID)\n}\n\n// runNamedWorkflow is the internal implementation that runs a specific named\n// workflow from host.cloche.\nfunc (r *Runner) runNamedWorkflow(ctx context.Context, projectDir string, workflowName string, orchRunID string) (*RunResult, error) {\n\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n\tdata, err := os.ReadFile(hostPath)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading host.cloche: %w\", err)\n\t}\n\n\tworkflows, err := dsl.ParseAllForHost(string(data))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing host.cloche: %w\", err)\n\t}\n\n\twf, ok := workflows[workflowName]\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"host.cloche has no workflow %q\", workflowName)\n\t}\n\n\t// Create output directory for step outputs\n\toutputDir := filepath.Join(projectDir, \".cloche\", orchRunID, \"output\")\n\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n\t}\n\n\tlog.Printf(\"host workflow: starting %q for project %s (run %s)\", wf.Name, projectDir, orchRunID)\n\n\t// Persist the host run in the store so it appears in list/status/logs.\n\t// When SkipRunRecord is set (e.g. for list-tasks polling), skip creating\n\t// the record to avoid cluttering the run history.\n\tif !r.SkipRunRecord {\n\t\thostRun := domain.NewRun(orchRunID, wf.Name)\n\t\thostRun.ProjectDir = projectDir\n\t\thostRun.IsHost = true\n\t\thostRun.TaskID = r.TaskID\n\t\tif err := r.Store.CreateRun(ctx, hostRun); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating host run record: %w\", err)\n\t\t}\n\t\thostRun.Start()\n\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n\t}\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tMainDir:    MainWorktreeDir(projectDir),\n\t\tDispatcher: r.Dispatcher,\n\t\tStore:      r.Store,\n\t\tOutputDir:  outputDir,\n\t\tWires:      wf.Wiring,\n\t\tHostRunID:  orchRunID,\n\t\tTaskID:     r.TaskID,\n\t\tExtraEnv:   r.ExtraEnv,\n\t}\n\n\t// Configure agent from workflow-level host config\n\tif cmd := wf.Config[\"host.agent_command\"]; cmd != \"\" {\n\t\texecutor.AgentCommands = prompt.ParseCommands(cmd)\n\t}\n\tif args := wf.Config[\"host.agent_args\"]; args != \"\" {\n\t\texecutor.AgentArgs = strings.Fields(args)\n\t}\n\n\teng := engine.New(executor)\n\teng.SetStatusHandler(&hostStatusHandler{\n\t\tprojectDir:   projectDir,\n\t\torchRunID:    orchRunID,\n\t\tstore:        r.Store,\n\t\tcaptures:     r.Captures,\n\t\tlogBroadcast: r.LogBroadcast,\n\t\toutputDir:    outputDir,\n\t})\n\n\trun, runErr := eng.Run(ctx, wf)\n\n\tresult := &RunResult{\n\t\tRunID:     orchRunID,\n\t\tState:     domain.RunStateFailed,\n\t\tOutputDir: outputDir,\n\t}\n\tif run != nil {\n\t\tresult.State = run.State\n\t}\n\n\t// Persist final state.\n\tif !r.SkipRunRecord {\n\t\thostRun, _ := r.Store.GetRun(ctx, orchRunID)\n\t\tif hostRun != nil {\n\t\t\tif runErr != nil {\n\t\t\t\thostRun.Fail(runErr.Error())\n\t\t\t} else {\n\t\t\t\thostRun.Complete(result.State)\n\t\t\t}\n\t\t\thostRun.ActiveSteps = nil\n\t\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n\t\t}\n\t}\n\n\tif runErr != nil {\n\t\tlog.Printf(\"host workflow: %q failed for %s: %v\", wf.Name, projectDir, runErr)\n\t\treturn result, runErr\n\t}\n\n\tlog.Printf(\"host workflow: %q completed for %s with state %s\", wf.Name, projectDir, run.State)\n\treturn result, nil\n}\n\n// RunListTasksWorkflow executes the list-tasks workflow and returns the\n// discovered tasks. No run record is created for list-tasks executions since\n// they are polling operations that would otherwise clutter the run history.\nfunc RunListTasksWorkflow(ctx context.Context, runner *Runner, projectDir string) ([]Task, *RunResult, error) {\n\trunner.SkipRunRecord = true\n\tresult, err := runner.RunNamed(ctx, projectDir, \"list-tasks\")\n\tif err != nil {\n\t\treturn nil, nil, err\n\t}\n\tif result.State != domain.RunStateSucceeded {\n\t\treturn nil, result, fmt.Errorf(\"list-tasks workflow failed with state %s\", result.State)\n\t}\n\ttasks, err := ReadListTasksOutput(result.OutputDir)\n\tif err != nil {\n\t\treturn nil, result, err\n\t}\n\treturn tasks, result, nil\n}\n\n// hostStatusHandler logs host workflow step events and persists them to the store.\n// It mirrors the container-side status pipeline: saving captures and publishing\n// to the log broadcaster so that cloche logs works identically for host runs.\ntype hostStatusHandler struct {\n\tprojectDir   string\n\torchRunID    string\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogBroadcast *logstream.Broadcaster\n\toutputDir    string\n}\n\nfunc (h *hostStatusHandler) OnStepStart(_ *domain.Run, step *domain.Step) {\n\tnow := time.Now()\n\tlog.Printf(\"host workflow [%s]: step %q started\", h.orchRunID, step.Name)\n\tif h.store != nil {\n\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n\t\t\tr.RecordStepStart(step.Name)\n\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n\t\t}\n\t}\n\tif h.captures != nil {\n\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n\t\t\tStepName:  step.Name,\n\t\t\tStartedAt: now,\n\t\t})\n\t}\n\tif h.logBroadcast != nil {\n\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n\t\t\tTimestamp: now.Format(time.RFC3339),\n\t\t\tType:      \"status\",\n\t\t\tContent:   \"step_started: \" + step.Name,\n\t\t\tStepName:  step.Name,\n\t\t})\n\t}\n}\n\nfunc (h *hostStatusHandler) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n\tnow := time.Now()\n\tlog.Printf(\"host workflow [%s]: step %q completed with result %q\", h.orchRunID, step.Name, result)\n\tif h.store != nil {\n\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n\t\t\tr.RecordStepComplete(step.Name, result)\n\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n\t\t}\n\t}\n\tif h.captures != nil {\n\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n\t\t\tStepName:    step.Name,\n\t\t\tResult:      result,\n\t\t\tCompletedAt: now,\n\t\t})\n\t}\n\tif h.logBroadcast != nil {\n\t\t// Read step output and publish it before the completion event.\n\t\toutputPath := filepath.Join(h.outputDir, step.Name+\".out\")\n\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n\t\t\t\tTimestamp: now.Format(time.RFC3339),\n\t\t\t\tType:      \"script\",\n\t\t\t\tContent:   string(data),\n\t\t\t\tStepName:  step.Name,\n\t\t\t})\n\t\t}\n\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n\t\t\tTimestamp: now.Format(time.RFC3339),\n\t\t\tType:      \"status\",\n\t\t\tContent:   \"step_completed: \" + step.Name + \" -> \" + result,\n\t\t\tStepName:  step.Name,\n\t\t})\n\t}\n}\n\nfunc (h *hostStatusHandler) OnRunComplete(run *domain.Run) {\n\tlog.Printf(\"host workflow [%s]: run completed with state %s\", h.orchRunID, run.State)\n}\n","numLines":261,"startLine":1,"totalLines":261}}}
[2026-03-13T17:54:42Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Dhjdi4sL7gsdvs5yC9LnDP","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01YEPUzYvu6ttPamzaXGvotf","name":"Read","input":{"file_path":"/workspace/internal/host/executor.go"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":22763,"cache_read_input_tokens":25229,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":22763},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"672a244f-d306-4bfb-8514-5ea42ce22c11","uuid":"380a9925-5ceb-4bef-b0bd-da960ce28d3f"}
[2026-03-13T17:54:42Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YEPUzYvu6ttPamzaXGvotf","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"strings\"\n    11→\t\"time\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    17→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    19→\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    20→)\n    21→\n    22→// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    23→// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    24→// strings suitable for adding to a command's environment.\n    25→func (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    26→\tvar env []string\n    27→\tfor _, w := range wires {\n    28→\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    29→\t\t\tcontinue\n    30→\t\t}\n    31→\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    32→\t\tif err != nil {\n    33→\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    34→\t\t}\n    35→\t\tfor _, m := range w.OutputMap {\n    36→\t\t\tval, err := m.Path.Evaluate(data)\n    37→\t\t\tif err != nil {\n    38→\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    39→\t\t\t}\n    40→\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    41→\t\t}\n    42→\t}\n    43→\treturn env, nil\n    44→}\n    45→\n    46→// RunDispatcher dispatches a container workflow run and returns the run ID.\n    47→type RunDispatcher interface {\n    48→\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    49→}\n    50→\n    51→// Executor implements engine.StepExecutor for host workflow steps.\n    52→type Executor struct {\n    53→\tProjectDir    string\n    54→\tMainDir       string         // main branch worktree dir; scripts execute from here\n    55→\tDispatcher    RunDispatcher\n    56→\tStore         ports.RunStore\n    57→\tOutputDir     string         // directory for step output files\n    58→\tWires         []domain.Wire  // workflow wiring (for output mappings)\n    59→\tHostRunID     string         // ID of the parent host run (set on child runs)\n    60→\tAgentCommands []string       // workflow-level agent command fallback chain\n    61→\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n    62→\tTaskID        string         // optional task ID assigned by the daemon loop\n    63→\tExtraEnv      []string       // additional KEY=VALUE env vars for all steps\n    64→}\n    65→\n    66→// scriptDir returns the directory from which scripts should execute.\n    67→// Uses MainDir if set, otherwise falls back to ProjectDir.\n    68→func (e *Executor) scriptDir() string {\n    69→\tif e.MainDir != \"\" {\n    70→\t\treturn e.MainDir\n    71→\t}\n    72→\treturn e.ProjectDir\n    73→}\n    74→\n    75→var _ engine.StepExecutor = (*Executor)(nil)\n    76→\n    77→// Execute runs a single host workflow step.\n    78→func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    79→\tswitch step.Type {\n    80→\tcase domain.StepTypeScript:\n    81→\t\treturn e.executeScript(ctx, step)\n    82→\tcase domain.StepTypeWorkflow:\n    83→\t\treturn e.executeWorkflow(ctx, step)\n    84→\tcase domain.StepTypeAgent:\n    85→\t\treturn e.executeAgent(ctx, step)\n    86→\tdefault:\n    87→\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    88→\t}\n    89→}\n    90→\n    91→// executeScript runs a shell command on the host.\n    92→func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    93→\tcmdStr := step.Config[\"run\"]\n    94→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    95→\tcmd.Dir = e.scriptDir()\n    96→\tcmd.Env = append(os.Environ(),\n    97→\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    98→\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    99→\t)\n   100→\n   101→\t// Pass run ID so steps can access .cloche/<run-id>/ and context.json\n   102→\tif e.HostRunID != \"\" {\n   103→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_RUN_ID=\"+e.HostRunID)\n   104→\t}\n   105→\n   106→\t// Pass daemon-assigned task ID if available\n   107→\tif e.TaskID != \"\" {\n   108→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_TASK_ID=\"+e.TaskID)\n   109→\t}\n   110→\n   111→\t// Pass extra env vars (e.g. finalize phase outcome vars)\n   112→\tif len(e.ExtraEnv) > 0 {\n   113→\t\tcmd.Env = append(cmd.Env, e.ExtraEnv...)\n   114→\t}\n   115→\n   116→\t// Pass previous step output if available\n   117→\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n   118→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n   119→\t}\n   120→\n   121→\t// Resolve output mappings from wires and add as env vars\n   122→\tif len(e.Wires) > 0 {\n   123→\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n   124→\t\tif err != nil {\n   125→\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n   126→\t\t}\n   127→\t\tcmd.Env = append(cmd.Env, mapped...)\n   128→\t}\n   129→\n   130→\toutput, err := cmd.CombinedOutput()\n   131→\n   132→\t// Extract result marker\n   133→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n   134→\n   135→\t// Write output to file\n   136→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   137→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   138→\t}\n   139→\n   140→\tif err != nil {\n   141→\t\tif _, ok := err.(*exec.ExitError); ok {\n   142→\t\t\tresult := \"fail\"\n   143→\t\t\tif found {\n   144→\t\t\t\tresult = markerResult\n   145→\t\t\t}\n   146→\t\t\treturn result, nil\n   147→\t\t}\n   148→\t\treturn \"\", err\n   149→\t}\n   150→\n   151→\tresult := \"success\"\n   152→\tif found {\n   153→\t\tresult = markerResult\n   154→\t}\n   155→\treturn result, nil\n   156→}\n   157→\n   158→// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   159→func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   160→\tworkflowName := step.Config[\"workflow_name\"]\n   161→\tif workflowName == \"\" {\n   162→\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   163→\t}\n   164→\n   165→\t// Read prompt from previous step output or prompt_step override\n   166→\tvar promptContent string\n   167→\tpromptSource := step.Config[\"prompt_step\"]\n   168→\tif promptSource != \"\" {\n   169→\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   170→\t\tif err == nil {\n   171→\t\t\tpromptContent = string(data)\n   172→\t\t}\n   173→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   174→\t\tdata, err := os.ReadFile(prev)\n   175→\t\tif err == nil {\n   176→\t\t\tpromptContent = string(data)\n   177→\t\t}\n   178→\t}\n   179→\n   180→\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   181→\t\tWorkflowName: workflowName,\n   182→\t\tProjectDir:   e.ProjectDir,\n   183→\t\tPrompt:       promptContent,\n   184→\t})\n   185→\tif err != nil {\n   186→\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   187→\t}\n   188→\n   189→\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   190→\n   191→\t// Link child run to parent host run and store in run context\n   192→\tif e.HostRunID != \"\" {\n   193→\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n   194→\t\t\tchildRun.ParentRunID = e.HostRunID\n   195→\t\t\tchildRun.TaskID = e.TaskID\n   196→\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n   197→\t\t}\n   198→\t\t// Store child run ID in context so downstream steps can retrieve it\n   199→\t\t// via \"cloche get child_run_id\"\n   200→\t\t_ = runcontext.Set(e.ProjectDir, e.HostRunID, \"child_run_id\", resp.RunId)\n   201→\t}\n   202→\n   203→\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n   204→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   205→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n   206→\t}\n   207→\n   208→\t// Poll until the run reaches a terminal state\n   209→\tstate, err := e.waitForRun(ctx, resp.RunId)\n   210→\tif err != nil {\n   211→\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   212→\t}\n   213→\n   214→\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   215→\n   216→\t// Map run state to step result\n   217→\tif state == domain.RunStateSucceeded {\n   218→\t\treturn \"success\", nil\n   219→\t}\n   220→\treturn \"fail\", nil\n   221→}\n   222→\n   223→// executeAgent runs an agent command on the host using the prompt adapter.\n   224→func (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n   225→\tadapter := prompt.New()\n   226→\n   227→\t// Apply workflow-level agent config\n   228→\tif len(e.AgentCommands) > 0 {\n   229→\t\tadapter.Commands = e.AgentCommands\n   230→\t}\n   231→\tif len(e.AgentArgs) > 0 {\n   232→\t\tadapter.ExplicitArgs = e.AgentArgs\n   233→\t}\n   234→\n   235→\t// Step-level overrides\n   236→\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   237→\t\tadapter.Commands = prompt.ParseCommands(cmd)\n   238→\t}\n   239→\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   240→\t\tadapter.ExplicitArgs = strings.Fields(args)\n   241→\t}\n   242→\n   243→\tadapter.RunID = e.HostRunID\n   244→\n   245→\t// Write previous step output as user prompt so the adapter can pick it up.\n   246→\tvar promptContent string\n   247→\tpromptSource := step.Config[\"prompt_step\"]\n   248→\tif promptSource != \"\" {\n   249→\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n   250→\t\t\tpromptContent = string(data)\n   251→\t\t}\n   252→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   253→\t\tif data, err := os.ReadFile(prev); err == nil {\n   254→\t\t\tpromptContent = string(data)\n   255→\t\t}\n   256→\t}\n   257→\n   258→\tif promptContent != \"\" {\n   259→\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n   260→\t\t_ = os.MkdirAll(promptDir, 0755)\n   261→\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n   262→\t}\n   263→\n   264→\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n   265→\tif err != nil {\n   266→\t\treturn \"\", err\n   267→\t}\n   268→\n   269→\t// Copy output from adapter's output location to executor's output path\n   270→\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n   271→\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n   272→\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   273→\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n   274→\t\t}\n   275→\t}\n   276→\n   277→\treturn result, nil\n   278→}\n   279→\n   280→// waitForRun polls the store until the run reaches a terminal state.\n   281→func (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   282→\tticker := time.NewTicker(2 * time.Second)\n   283→\tdefer ticker.Stop()\n   284→\n   285→\tfor {\n   286→\t\tselect {\n   287→\t\tcase <-ctx.Done():\n   288→\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   289→\t\tcase <-ticker.C:\n   290→\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   291→\t\t\tif err != nil {\n   292→\t\t\t\tcontinue // transient error, retry\n   293→\t\t\t}\n   294→\t\t\tswitch run.State {\n   295→\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   296→\t\t\t\treturn run.State, nil\n   297→\t\t\t}\n   298→\t\t\t// Still pending or running, continue polling\n   299→\t\t}\n   300→\t}\n   301→}\n   302→\n   303→// stepOutputPath returns the path for a step's output file.\n   304→func (e *Executor) stepOutputPath(stepName string) string {\n   305→\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   306→}\n   307→\n   308→// findPrevOutput finds the output file from the step that wires into this one.\n   309→// It checks prompt_step config first, then walks the wiring graph to find the\n   310→// source step.\n   311→func (e *Executor) findPrevOutput(step *domain.Step) string {\n   312→\t// Explicit prompt_step config takes priority\n   313→\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   314→\t\tpath := e.stepOutputPath(ps)\n   315→\t\tif _, err := os.Stat(path); err == nil {\n   316→\t\t\treturn path\n   317→\t\t}\n   318→\t}\n   319→\n   320→\t// Walk wiring to find the step that feeds into this one\n   321→\tfor _, w := range e.Wires {\n   322→\t\tif w.To == step.Name {\n   323→\t\t\tpath := e.stepOutputPath(w.From)\n   324→\t\t\tif _, err := os.Stat(path); err == nil {\n   325→\t\t\t\treturn path\n   326→\t\t\t}\n   327→\t\t}\n   328→\t}\n   329→\treturn \"\"\n   330→}\n   331→\n   332→// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n   333→// the repository containing projectDir. If projectDir is already the main\n   334→// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n   335→// error (e.g. not a git repo).\n   336→func MainWorktreeDir(projectDir string) string {\n   337→\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n   338→\tout, err := cmd.Output()\n   339→\tif err != nil {\n   340→\t\treturn projectDir\n   341→\t}\n   342→\t// The first \"worktree <path>\" line is always the main worktree.\n   343→\tfor _, line := range strings.Split(string(out), \"\\n\") {\n   344→\t\tif strings.HasPrefix(line, \"worktree \") {\n   345→\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n   346→\t\t}\n   347→\t}\n   348→\treturn projectDir\n   349→}\n   350→"}]},"parent_tool_use_id":null,"session_id":"672a244f-d306-4bfb-8514-5ea42ce22c11","uuid":"afaa5805-b18e-4e09-aca6-a9a0771e46dd","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n)\n\n// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n// reads the source step's output, evaluates each mapping path, and returns KEY=value\n// strings suitable for adding to a command's environment.\nfunc (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n\tvar env []string\n\tfor _, w := range wires {\n\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n\t\t}\n\t\tfor _, m := range w.OutputMap {\n\t\t\tval, err := m.Path.Evaluate(data)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n\t\t\t}\n\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n\t\t}\n\t}\n\treturn env, nil\n}\n\n// RunDispatcher dispatches a container workflow run and returns the run ID.\ntype RunDispatcher interface {\n\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n}\n\n// Executor implements engine.StepExecutor for host workflow steps.\ntype Executor struct {\n\tProjectDir    string\n\tMainDir       string         // main branch worktree dir; scripts execute from here\n\tDispatcher    RunDispatcher\n\tStore         ports.RunStore\n\tOutputDir     string         // directory for step output files\n\tWires         []domain.Wire  // workflow wiring (for output mappings)\n\tHostRunID     string         // ID of the parent host run (set on child runs)\n\tAgentCommands []string       // workflow-level agent command fallback chain\n\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n\tTaskID        string         // optional task ID assigned by the daemon loop\n\tExtraEnv      []string       // additional KEY=VALUE env vars for all steps\n}\n\n// scriptDir returns the directory from which scripts should execute.\n// Uses MainDir if set, otherwise falls back to ProjectDir.\nfunc (e *Executor) scriptDir() string {\n\tif e.MainDir != \"\" {\n\t\treturn e.MainDir\n\t}\n\treturn e.ProjectDir\n}\n\nvar _ engine.StepExecutor = (*Executor)(nil)\n\n// Execute runs a single host workflow step.\nfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\treturn e.executeScript(ctx, step)\n\tcase domain.StepTypeWorkflow:\n\t\treturn e.executeWorkflow(ctx, step)\n\tcase domain.StepTypeAgent:\n\t\treturn e.executeAgent(ctx, step)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n\t}\n}\n\n// executeScript runs a shell command on the host.\nfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n\tcmdStr := step.Config[\"run\"]\n\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n\tcmd.Dir = e.scriptDir()\n\tcmd.Env = append(os.Environ(),\n\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n\t)\n\n\t// Pass run ID so steps can access .cloche/<run-id>/ and context.json\n\tif e.HostRunID != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_RUN_ID=\"+e.HostRunID)\n\t}\n\n\t// Pass daemon-assigned task ID if available\n\tif e.TaskID != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_TASK_ID=\"+e.TaskID)\n\t}\n\n\t// Pass extra env vars (e.g. finalize phase outcome vars)\n\tif len(e.ExtraEnv) > 0 {\n\t\tcmd.Env = append(cmd.Env, e.ExtraEnv...)\n\t}\n\n\t// Pass previous step output if available\n\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n\t}\n\n\t// Resolve output mappings from wires and add as env vars\n\tif len(e.Wires) > 0 {\n\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n\t\t}\n\t\tcmd.Env = append(cmd.Env, mapped...)\n\t}\n\n\toutput, err := cmd.CombinedOutput()\n\n\t// Extract result marker\n\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n\n\t// Write output to file\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n\t}\n\n\tif err != nil {\n\t\tif _, ok := err.(*exec.ExitError); ok {\n\t\t\tresult := \"fail\"\n\t\t\tif found {\n\t\t\t\tresult = markerResult\n\t\t\t}\n\t\t\treturn result, nil\n\t\t}\n\t\treturn \"\", err\n\t}\n\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, nil\n}\n\n// executeWorkflow dispatches a container workflow run and blocks until it completes.\nfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n\tworkflowName := step.Config[\"workflow_name\"]\n\tif workflowName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n\t}\n\n\t// Read prompt from previous step output or prompt_step override\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tdata, err := os.ReadFile(prev)\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName: workflowName,\n\t\tProjectDir:   e.ProjectDir,\n\t\tPrompt:       promptContent,\n\t})\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n\t}\n\n\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n\n\t// Link child run to parent host run and store in run context\n\tif e.HostRunID != \"\" {\n\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n\t\t\tchildRun.ParentRunID = e.HostRunID\n\t\t\tchildRun.TaskID = e.TaskID\n\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n\t\t}\n\t\t// Store child run ID in context so downstream steps can retrieve it\n\t\t// via \"cloche get child_run_id\"\n\t\t_ = runcontext.Set(e.ProjectDir, e.HostRunID, \"child_run_id\", resp.RunId)\n\t}\n\n\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n\t}\n\n\t// Poll until the run reaches a terminal state\n\tstate, err := e.waitForRun(ctx, resp.RunId)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n\t}\n\n\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n\n\t// Map run state to step result\n\tif state == domain.RunStateSucceeded {\n\t\treturn \"success\", nil\n\t}\n\treturn \"fail\", nil\n}\n\n// executeAgent runs an agent command on the host using the prompt adapter.\nfunc (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n\tadapter := prompt.New()\n\n\t// Apply workflow-level agent config\n\tif len(e.AgentCommands) > 0 {\n\t\tadapter.Commands = e.AgentCommands\n\t}\n\tif len(e.AgentArgs) > 0 {\n\t\tadapter.ExplicitArgs = e.AgentArgs\n\t}\n\n\t// Step-level overrides\n\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n\t\tadapter.Commands = prompt.ParseCommands(cmd)\n\t}\n\tif args := step.Config[\"agent_args\"]; args != \"\" {\n\t\tadapter.ExplicitArgs = strings.Fields(args)\n\t}\n\n\tadapter.RunID = e.HostRunID\n\n\t// Write previous step output as user prompt so the adapter can pick it up.\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tif data, err := os.ReadFile(prev); err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tif promptContent != \"\" {\n\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n\t\t_ = os.MkdirAll(promptDir, 0755)\n\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n\t}\n\n\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\t// Copy output from adapter's output location to executor's output path\n\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\n// waitForRun polls the store until the run reaches a terminal state.\nfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n\tticker := time.NewTicker(2 * time.Second)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n\t\tcase <-ticker.C:\n\t\t\trun, err := e.Store.GetRun(ctx, runID)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // transient error, retry\n\t\t\t}\n\t\t\tswitch run.State {\n\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n\t\t\t\treturn run.State, nil\n\t\t\t}\n\t\t\t// Still pending or running, continue polling\n\t\t}\n\t}\n}\n\n// stepOutputPath returns the path for a step's output file.\nfunc (e *Executor) stepOutputPath(stepName string) string {\n\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n}\n\n// findPrevOutput finds the output file from the step that wires into this one.\n// It checks prompt_step config first, then walks the wiring graph to find the\n// source step.\nfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n\t// Explicit prompt_step config takes priority\n\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n\t\tpath := e.stepOutputPath(ps)\n\t\tif _, err := os.Stat(path); err == nil {\n\t\t\treturn path\n\t\t}\n\t}\n\n\t// Walk wiring to find the step that feeds into this one\n\tfor _, w := range e.Wires {\n\t\tif w.To == step.Name {\n\t\t\tpath := e.stepOutputPath(w.From)\n\t\t\tif _, err := os.Stat(path); err == nil {\n\t\t\t\treturn path\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n// the repository containing projectDir. If projectDir is already the main\n// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n// error (e.g. not a git repo).\nfunc MainWorktreeDir(projectDir string) string {\n\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn projectDir\n\t}\n\t// The first \"worktree <path>\" line is always the main worktree.\n\tfor _, line := range strings.Split(string(out), \"\\n\") {\n\t\tif strings.HasPrefix(line, \"worktree \") {\n\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n\t\t}\n\t}\n\treturn projectDir\n}\n","numLines":350,"startLine":1,"totalLines":350}}}
