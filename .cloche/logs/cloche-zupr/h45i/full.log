[2026-03-13T17:54:42Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J1H1LpPJj5xEcBsXMpa51v","type":"tool_result","content":"     1→package prompt\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"bytes\"\n     6→\t\"context\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strconv\"\n    13→\t\"strings\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17→)\n    18→\n    19→// defaultAgentArgs maps known agent commands to their default arguments.\n    20→// Commands not in this map receive no default arguments (prompt on stdin only).\n    21→var defaultAgentArgs = map[string][]string{\n    22→\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n    23→}\n    24→\n    25→type Adapter struct {\n    26→\tCommands     []string // ordered fallback chain of agent commands\n    27→\tExplicitArgs []string // if non-nil, overrides default args for all commands\n    28→\tRunID        string\n    29→\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n    30→}\n    31→\n    32→func New() *Adapter {\n    33→\treturn &Adapter{\n    34→\t\tCommands: []string{\"claude\"},\n    35→\t}\n    36→}\n    37→\n    38→func (a *Adapter) Name() string {\n    39→\treturn \"prompt\"\n    40→}\n    41→\n    42→// argsFor returns the arguments for the given command. If ExplicitArgs is set,\n    43→// it is used for all commands. Otherwise, known agents get their default args.\n    44→func (a *Adapter) argsFor(command string) []string {\n    45→\tif a.ExplicitArgs != nil {\n    46→\t\treturn a.ExplicitArgs\n    47→\t}\n    48→\tif args, ok := defaultAgentArgs[command]; ok {\n    49→\t\treturn args\n    50→\t}\n    51→\treturn nil\n    52→}\n    53→\n    54→// ParseCommands splits a comma-separated agent_command string into individual\n    55→// command names, trimming whitespace from each entry.\n    56→func ParseCommands(s string) []string {\n    57→\tparts := strings.Split(s, \",\")\n    58→\tvar cmds []string\n    59→\tfor _, p := range parts {\n    60→\t\tp = strings.TrimSpace(p)\n    61→\t\tif p != \"\" {\n    62→\t\t\tcmds = append(cmds, p)\n    63→\t\t}\n    64→\t}\n    65→\treturn cmds\n    66→}\n    67→\n    68→func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    69→\t// Check attempt count for retry limiting\n    70→\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n    71→\t\tmax, err := strconv.Atoi(maxStr)\n    72→\t\tif err == nil {\n    73→\t\t\tcount := readAttemptCount(workDir, step.Name)\n    74→\t\t\tif count >= max {\n    75→\t\t\t\treturn \"give-up\", nil\n    76→\t\t\t}\n    77→\t\t}\n    78→\t}\n    79→\tincrementAttemptCount(workDir, step.Name)\n    80→\n    81→\t// Build the full prompt\n    82→\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n    83→\tif err != nil {\n    84→\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n    85→\t}\n    86→\n    87→\t// Try each command in the fallback chain\n    88→\tvar lastResult string\n    89→\tvar lastStdout []byte\n    90→\tvar lastErr error\n    91→\tran := false\n    92→\n    93→\tfor _, command := range a.Commands {\n    94→\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n    95→\t\tlastResult = result\n    96→\t\tlastStdout = stdout\n    97→\t\tlastErr = fallbackErr\n    98→\n    99→\t\tif fallbackErr == nil {\n   100→\t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n   101→\t\t\tbreak\n   102→\t\t}\n   103→\t\tif stdout != nil {\n   104→\t\t\tran = true\n   105→\t\t}\n   106→\t\t// Fallback-eligible — try next command\n   107→\t}\n   108→\n   109→\tif lastErr != nil && !ran && lastStdout == nil {\n   110→\t\t// All commands failed to produce any output (e.g., all not found)\n   111→\t\treturn \"\", lastErr\n   112→\t}\n   113→\n   114→\tresult := lastResult\n   115→\tif lastErr != nil {\n   116→\t\t// Last command in chain crashed without a result marker\n   117→\t\tresult = \"fail\"\n   118→\t}\n   119→\n   120→\t// Reset attempt counter on success so give-up only triggers after\n   121→\t// consecutive failures, not after successful fixes whose downstream\n   122→\t// tests fail for unrelated reasons.\n   123→\tif result == \"success\" {\n   124→\t\tresetAttemptCount(workDir, step.Name)\n   125→\t}\n   126→\n   127→\t// Write output file\n   128→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   129→\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n   130→\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n   131→\t}\n   132→\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n   133→\treturn result, nil\n   134→}\n   135→\n   136→// tryCommand executes a single agent command and returns:\n   137→//   - result: the step result name (e.g. \"success\", \"fail\")\n   138→//   - stdout: captured stdout bytes\n   139→//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n   140→//\n   141→// Fallback-eligible conditions:\n   142→//   - Command not found or failed to start (stdout will be nil)\n   143→//   - Command exited non-zero without a CLOCHE_RESULT marker\n   144→//\n   145→// Definitive (non-fallback) conditions:\n   146→//   - Command exited 0\n   147→//   - Command exited non-zero but produced a CLOCHE_RESULT marker\n   148→func (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n   149→\targs := a.argsFor(command)\n   150→\tcmd := exec.CommandContext(ctx, command, args...)\n   151→\tcmd.Dir = workDir\n   152→\tcmd.Stdin = strings.NewReader(prompt)\n   153→\n   154→\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n   155→\tif a.StatusWriter == nil {\n   156→\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n   157→\t\tcmd.Stdout = &stdoutBuf\n   158→\t\tcmd.Stderr = &stderrBuf\n   159→\n   160→\t\trunErr := cmd.Run()\n   161→\t\tstdoutBytes := stdoutBuf.Bytes()\n   162→\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n   163→\t}\n   164→\n   165→\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n   166→\tpipe, err := cmd.StdoutPipe()\n   167→\tif err != nil {\n   168→\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n   169→\t}\n   170→\tcmd.Stderr = nil // discard stderr\n   171→\n   172→\tif err := cmd.Start(); err != nil {\n   173→\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n   174→\t}\n   175→\n   176→\t// textBuf accumulates extracted text content for result extraction.\n   177→\t// rawBuf accumulates raw stdout for the output log file.\n   178→\tvar textBuf, rawBuf bytes.Buffer\n   179→\t// lineBuf accumulates text deltas into lines for streaming.\n   180→\tvar lineBuf strings.Builder\n   181→\n   182→\tscanner := bufio.NewScanner(pipe)\n   183→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n   184→\tfor scanner.Scan() {\n   185→\t\traw := scanner.Bytes()\n   186→\t\trawBuf.Write(raw)\n   187→\t\trawBuf.WriteByte('\\n')\n   188→\n   189→\t\ttext := extractStreamText(raw)\n   190→\t\tif text == \"\" {\n   191→\t\t\tcontinue\n   192→\t\t}\n   193→\t\ttextBuf.WriteString(text)\n   194→\n   195→\t\t// Stream complete lines to StatusWriter as they form.\n   196→\t\tlineBuf.WriteString(text)\n   197→\t\tfor {\n   198→\t\t\ts := lineBuf.String()\n   199→\t\t\tidx := strings.IndexByte(s, '\\n')\n   200→\t\t\tif idx < 0 {\n   201→\t\t\t\tbreak\n   202→\t\t\t}\n   203→\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n   204→\t\t\tlineBuf.Reset()\n   205→\t\t\tlineBuf.WriteString(s[idx+1:])\n   206→\t\t}\n   207→\t}\n   208→\t// Flush any remaining partial line.\n   209→\tif lineBuf.Len() > 0 {\n   210→\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n   211→\t}\n   212→\tif scanErr := scanner.Err(); scanErr != nil {\n   213→\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n   214→\t}\n   215→\n   216→\twaitErr := cmd.Wait()\n   217→\t// Prefer extracted text (stream-json) for result classification; fall back\n   218→\t// to raw output for non-JSON commands (scripts, non-claude agents).\n   219→\tclassifyBuf := textBuf.Bytes()\n   220→\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n   221→\t\tclassifyBuf = rawBuf.Bytes()\n   222→\t}\n   223→\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n   224→\treturn result, rawBuf.Bytes(), fallbackErr\n   225→}\n   226→\n   227→// classifyResult interprets the command's exit status and stdout to determine\n   228→// the step result.\n   229→func (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n   230→\tif runErr != nil {\n   231→\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n   232→\t\t\t// Command failed to start (not found, permission denied, etc.)\n   233→\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n   234→\t\t}\n   235→\t\t// Command ran but exited non-zero\n   236→\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   237→\t\tif found {\n   238→\t\t\treturn markerResult, stdoutBytes, nil\n   239→\t\t}\n   240→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n   241→\t}\n   242→\n   243→\t// Command succeeded (exit 0)\n   244→\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n   245→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n   246→\t}\n   247→\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   248→\tresult := \"success\"\n   249→\tif found {\n   250→\t\tresult = markerResult\n   251→\t}\n   252→\treturn result, stdoutBytes, nil\n   253→}\n   254→\n   255→// extractStreamText parses a Claude Code stream-json line and returns text content.\n   256→//\n   257→// Claude Code's stream-json emits these event types:\n   258→//   - \"assistant\": one per turn, contains message.content[] with text and tool_use blocks\n   259→//   - \"result\": final event with the full result text (contains CLOCHE_RESULT marker)\n   260→//\n   261→// For assistant events, we extract text blocks and summarize tool_use blocks\n   262→// (e.g. \"--- Tool: Read('path') ---\"). Each assistant event has a unique uuid\n   263→// for dedup by the caller.\n   264→func extractStreamText(line []byte) string {\n   265→\t// Fast path: skip lines that can't contain content we care about.\n   266→\tif !bytes.Contains(line, []byte(`\"type\"`)) {\n   267→\t\treturn \"\"\n   268→\t}\n   269→\n   270→\tvar envelope struct {\n   271→\t\tType string `json:\"type\"`\n   272→\t}\n   273→\tif json.Unmarshal(line, &envelope) != nil {\n   274→\t\treturn \"\"\n   275→\t}\n   276→\n   277→\tswitch envelope.Type {\n   278→\tcase \"assistant\":\n   279→\t\treturn extractAssistantText(line)\n   280→\tcase \"result\":\n   281→\t\treturn extractResultText(line)\n   282→\t}\n   283→\treturn \"\"\n   284→}\n   285→\n   286→// extractAssistantText extracts text and tool-use summaries from an assistant event.\n   287→func extractAssistantText(line []byte) string {\n   288→\tvar event struct {\n   289→\t\tMessage struct {\n   290→\t\t\tContent []struct {\n   291→\t\t\t\tType  string          `json:\"type\"`\n   292→\t\t\t\tText  string          `json:\"text\"`\n   293→\t\t\t\tName  string          `json:\"name\"`\n   294→\t\t\t\tInput json.RawMessage `json:\"input\"`\n   295→\t\t\t} `json:\"content\"`\n   296→\t\t} `json:\"message\"`\n   297→\t}\n   298→\tif json.Unmarshal(line, &event) != nil {\n   299→\t\treturn \"\"\n   300→\t}\n   301→\n   302→\tvar b strings.Builder\n   303→\tfor _, c := range event.Message.Content {\n   304→\t\tswitch c.Type {\n   305→\t\tcase \"text\":\n   306→\t\t\tif c.Text != \"\" {\n   307→\t\t\t\tb.WriteString(c.Text)\n   308→\t\t\t\tif !strings.HasSuffix(c.Text, \"\\n\") {\n   309→\t\t\t\t\tb.WriteByte('\\n')\n   310→\t\t\t\t}\n   311→\t\t\t}\n   312→\t\tcase \"tool_use\":\n   313→\t\t\tb.WriteString(\"--- Tool: \")\n   314→\t\t\tb.WriteString(c.Name)\n   315→\t\t\tb.WriteString(toolInputSummary(c.Input))\n   316→\t\t\tb.WriteString(\" ---\\n\")\n   317→\t\t}\n   318→\t}\n   319→\treturn b.String()\n   320→}\n   321→\n   322→// extractResultText extracts the final result text (contains CLOCHE_RESULT marker).\n   323→func extractResultText(line []byte) string {\n   324→\tif !bytes.Contains(line, []byte(`\"subtype\"`)) {\n   325→\t\treturn \"\"\n   326→\t}\n   327→\tvar event struct {\n   328→\t\tType   string `json:\"type\"`\n   329→\t\tResult string `json:\"result\"`\n   330→\t}\n   331→\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n   332→\t\treturn event.Result\n   333→\t}\n   334→\treturn \"\"\n   335→}\n   336→\n   337→// toolInputSummary returns a short parenthesized summary of a tool's input.\n   338→func toolInputSummary(input json.RawMessage) string {\n   339→\tif len(input) == 0 {\n   340→\t\treturn \"\"\n   341→\t}\n   342→\tvar m map[string]json.RawMessage\n   343→\tif json.Unmarshal(input, &m) != nil {\n   344→\t\treturn \"\"\n   345→\t}\n   346→\t// Pick the most informative single argument to show.\n   347→\tfor _, key := range []string{\"file_path\", \"command\", \"pattern\", \"prompt\", \"skill\"} {\n   348→\t\tif v, ok := m[key]; ok {\n   349→\t\t\tvar s string\n   350→\t\t\tif json.Unmarshal(v, &s) == nil {\n   351→\t\t\t\tif len(s) > 60 {\n   352→\t\t\t\t\ts = s[:57] + \"...\"\n   353→\t\t\t\t}\n   354→\t\t\t\treturn \"('\" + s + \"')\"\n   355→\t\t\t}\n   356→\t\t}\n   357→\t}\n   358→\treturn \"\"\n   359→}\n   360→\n   361→func assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n   362→\tvar parts []string\n   363→\n   364→\t// 1. Read system template from step config\n   365→\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n   366→\t\tcontent, err := resolveContent(tmpl, workDir)\n   367→\t\tif err != nil {\n   368→\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n   369→\t\t}\n   370→\t\tparts = append(parts, content)\n   371→\t}\n   372→\n   373→\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n   374→\tuserPrompt := readUserPrompt(workDir, runID)\n   375→\tif userPrompt != \"\" {\n   376→\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n   377→\t}\n   378→\n   379→\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n   380→\tif step.Config[\"feedback\"] == \"true\" {\n   381→\t\tfeedback := readFeedback(workDir)\n   382→\t\tif feedback != \"\" {\n   383→\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n   384→\t\t}\n   385→\t}\n   386→\n   387→\t// 4. Result selection instructions\n   388→\tif len(step.Results) > 0 {\n   389→\t\tvar resultLines []string\n   390→\t\tresultLines = append(resultLines, \"## Result Selection\")\n   391→\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n   392→\t\tfor _, r := range step.Results {\n   393→\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n   394→\t\t}\n   395→\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n   396→\t}\n   397→\n   398→\treturn strings.Join(parts, \"\\n\\n\"), nil\n   399→}\n   400→\n   401→// resolveContent handles file(\"path\") syntax or returns the string directly.\n   402→func resolveContent(value string, workDir string) (string, error) {\n   403→\t// Check for file(\"path\") syntax from DSL parser\n   404→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n   405→\t\tpath := value[6 : len(value)-2]\n   406→\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n   407→\t\tif err != nil {\n   408→\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n   409→\t\t}\n   410→\t\treturn string(data), nil\n   411→\t}\n   412→\treturn value, nil\n   413→}\n   414→\n   415→func readFeedback(workDir string) string {\n   416→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   417→\tentries, err := os.ReadDir(outputDir)\n   418→\tif err != nil {\n   419→\t\treturn \"\"\n   420→\t}\n   421→\n   422→\tvar parts []string\n   423→\tfor _, entry := range entries {\n   424→\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n   425→\t\t\tcontinue\n   426→\t\t}\n   427→\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n   428→\t\tif err != nil {\n   429→\t\t\tcontinue\n   430→\t\t}\n   431→\t\tcontent := strings.TrimSpace(string(data))\n   432→\t\tif content != \"\" {\n   433→\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n   434→\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n   435→\t\t}\n   436→\t}\n   437→\n   438→\treturn strings.Join(parts, \"\\n\\n\")\n   439→}\n   440→\n   441→func readAttemptCount(workDir, stepName string) int {\n   442→\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n   443→\tdata, err := os.ReadFile(path)\n   444→\tif err != nil {\n   445→\t\treturn 0\n   446→\t}\n   447→\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n   448→\treturn n\n   449→}\n   450→\n   451→// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\n   452→func readUserPrompt(workDir, runID string) string {\n   453→\tif runID == \"\" {\n   454→\t\treturn \"\"\n   455→\t}\n   456→\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   457→\tif data, err := os.ReadFile(path); err == nil {\n   458→\t\treturn string(data)\n   459→\t}\n   460→\treturn \"\"\n   461→}\n   462→\n   463→func resetAttemptCount(workDir, stepName string) {\n   464→\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n   465→\t_ = os.Remove(path)\n   466→}\n   467→\n   468→func incrementAttemptCount(workDir, stepName string) {\n   469→\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n   470→\t_ = os.MkdirAll(dir, 0755)\n   471→\tcount := readAttemptCount(workDir, stepName) + 1\n   472→\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n   473→}\n   474→"}]},"parent_tool_use_id":"toolu_01B8gtzd7E3PAhdFbSDHDaCG","session_id":"672a244f-d306-4bfb-8514-5ea42ce22c11","uuid":"792c5290-4772-4f4c-8077-f5e1d6d36bd0"}
