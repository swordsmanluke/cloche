[2026-03-13T17:54:42Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Up3nXnjRmQdVoazNfGJZ4L","type":"tool_result","content":"     1→package engine_test\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"sync\"\n     7→\t\"testing\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    12→\t\"github.com/stretchr/testify/assert\"\n    13→\t\"github.com/stretchr/testify/require\"\n    14→)\n    15→\n    16→type fakeExecutor struct {\n    17→\tmu      sync.Mutex\n    18→\tresults map[string]string\n    19→\tcalled  []string\n    20→}\n    21→\n    22→func (f *fakeExecutor) Execute(_ context.Context, step *domain.Step) (string, error) {\n    23→\tf.mu.Lock()\n    24→\tdefer f.mu.Unlock()\n    25→\tf.called = append(f.called, step.Name)\n    26→\treturn f.results[step.Name], nil\n    27→}\n    28→\n    29→func TestEngine_LinearWorkflow(t *testing.T) {\n    30→\twf := &domain.Workflow{\n    31→\t\tName: \"linear\",\n    32→\t\tSteps: map[string]*domain.Step{\n    33→\t\t\t\"build\": {Name: \"build\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n    34→\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n    35→\t\t},\n    36→\t\tWiring: []domain.Wire{\n    37→\t\t\t{From: \"build\", Result: \"success\", To: \"test\"},\n    38→\t\t\t{From: \"test\", Result: \"pass\", To: domain.StepDone},\n    39→\t\t},\n    40→\t\tEntryStep: \"build\",\n    41→\t}\n    42→\n    43→\texec := &fakeExecutor{results: map[string]string{\"build\": \"success\", \"test\": \"pass\"}}\n    44→\teng := engine.New(exec)\n    45→\n    46→\trun, err := eng.Run(context.Background(), wf)\n    47→\trequire.NoError(t, err)\n    48→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n    49→\tassert.Equal(t, []string{\"build\", \"test\"}, exec.called)\n    50→}\n    51→\n    52→func TestEngine_RetryLoop(t *testing.T) {\n    53→\twf := &domain.Workflow{\n    54→\t\tName: \"retry\",\n    55→\t\tSteps: map[string]*domain.Step{\n    56→\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n    57→\t\t\t\"check\": {Name: \"check\", Type: domain.StepTypeScript, Results: []string{\"pass\", \"fail\"}},\n    58→\t\t},\n    59→\t\tWiring: []domain.Wire{\n    60→\t\t\t{From: \"code\", Result: \"success\", To: \"check\"},\n    61→\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n    62→\t\t\t{From: \"check\", Result: \"pass\", To: domain.StepDone},\n    63→\t\t\t{From: \"check\", Result: \"fail\", To: \"code\"},\n    64→\t\t},\n    65→\t\tEntryStep: \"code\",\n    66→\t}\n    67→\n    68→\tcallCount := 0\n    69→\tdynamicExec := engine.StepExecutorFunc(func(_ context.Context, step *domain.Step) (string, error) {\n    70→\t\tcallCount++\n    71→\t\tif step.Name == \"check\" && callCount <= 2 {\n    72→\t\t\treturn \"fail\", nil\n    73→\t\t}\n    74→\t\tif step.Name == \"code\" {\n    75→\t\t\treturn \"success\", nil\n    76→\t\t}\n    77→\t\treturn \"pass\", nil\n    78→\t})\n    79→\n    80→\teng := engine.New(dynamicExec)\n    81→\trun, err := eng.Run(context.Background(), wf)\n    82→\trequire.NoError(t, err)\n    83→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n    84→}\n    85→\n    86→func TestEngine_Abort(t *testing.T) {\n    87→\twf := &domain.Workflow{\n    88→\t\tName: \"abort-test\",\n    89→\t\tSteps: map[string]*domain.Step{\n    90→\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n    91→\t\t},\n    92→\t\tWiring: []domain.Wire{\n    93→\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n    94→\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n    95→\t\t},\n    96→\t\tEntryStep: \"code\",\n    97→\t}\n    98→\n    99→\texec := &fakeExecutor{results: map[string]string{\"code\": \"fail\"}}\n   100→\teng := engine.New(exec)\n   101→\n   102→\trun, err := eng.Run(context.Background(), wf)\n   103→\trequire.NoError(t, err)\n   104→\tassert.Equal(t, domain.RunStateFailed, run.State)\n   105→}\n   106→\n   107→func TestEngine_ContextCancellation(t *testing.T) {\n   108→\twf := &domain.Workflow{\n   109→\t\tName: \"cancel-test\",\n   110→\t\tSteps: map[string]*domain.Step{\n   111→\t\t\t\"slow\": {Name: \"slow\", Type: domain.StepTypeScript, Results: []string{\"done\"}},\n   112→\t\t},\n   113→\t\tWiring: []domain.Wire{\n   114→\t\t\t{From: \"slow\", Result: \"done\", To: domain.StepDone},\n   115→\t\t},\n   116→\t\tEntryStep: \"slow\",\n   117→\t}\n   118→\n   119→\tctx, cancel := context.WithCancel(context.Background())\n   120→\tcancel()\n   121→\n   122→\texec := &fakeExecutor{results: map[string]string{\"slow\": \"done\"}}\n   123→\teng := engine.New(exec)\n   124→\n   125→\trun, err := eng.Run(ctx, wf)\n   126→\trequire.Error(t, err)\n   127→\tassert.Equal(t, domain.RunStateCancelled, run.State)\n   128→}\n   129→\n   130→func TestEngine_Fanout(t *testing.T) {\n   131→\twf := &domain.Workflow{\n   132→\t\tName: \"fanout\",\n   133→\t\tSteps: map[string]*domain.Step{\n   134→\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   135→\t\t\t\"test\": {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   136→\t\t\t\"lint\": {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   137→\t\t},\n   138→\t\tWiring: []domain.Wire{\n   139→\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n   140→\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n   141→\t\t\t{From: \"test\", Result: \"success\", To: domain.StepDone},\n   142→\t\t\t{From: \"lint\", Result: \"success\", To: domain.StepDone},\n   143→\t\t},\n   144→\t\tEntryStep: \"code\",\n   145→\t}\n   146→\n   147→\texec := &fakeExecutor{results: map[string]string{\n   148→\t\t\"code\": \"success\", \"test\": \"success\", \"lint\": \"success\",\n   149→\t}}\n   150→\teng := engine.New(exec)\n   151→\n   152→\trun, err := eng.Run(context.Background(), wf)\n   153→\trequire.NoError(t, err)\n   154→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   155→\t// All three steps must have been called\n   156→\texec.mu.Lock()\n   157→\tassert.Contains(t, exec.called, \"code\")\n   158→\tassert.Contains(t, exec.called, \"test\")\n   159→\tassert.Contains(t, exec.called, \"lint\")\n   160→\texec.mu.Unlock()\n   161→}\n   162→\n   163→func TestEngine_CollectAll(t *testing.T) {\n   164→\twf := &domain.Workflow{\n   165→\t\tName: \"collect-all\",\n   166→\t\tSteps: map[string]*domain.Step{\n   167→\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   168→\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   169→\t\t\t\"lint\":  {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   170→\t\t\t\"merge\": {Name: \"merge\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   171→\t\t},\n   172→\t\tWiring: []domain.Wire{\n   173→\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n   174→\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n   175→\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n   176→\t\t},\n   177→\t\tCollects: []domain.Collect{\n   178→\t\t\t{\n   179→\t\t\t\tMode: domain.CollectAll,\n   180→\t\t\t\tConditions: []domain.WireCondition{\n   181→\t\t\t\t\t{Step: \"test\", Result: \"success\"},\n   182→\t\t\t\t\t{Step: \"lint\", Result: \"success\"},\n   183→\t\t\t\t},\n   184→\t\t\t\tTo: \"merge\",\n   185→\t\t\t},\n   186→\t\t},\n   187→\t\tEntryStep: \"code\",\n   188→\t}\n   189→\n   190→\texec := &fakeExecutor{results: map[string]string{\n   191→\t\t\"code\": \"success\", \"test\": \"success\", \"lint\": \"success\", \"merge\": \"success\",\n   192→\t}}\n   193→\teng := engine.New(exec)\n