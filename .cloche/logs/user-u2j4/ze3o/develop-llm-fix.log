{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018gbsPZY2EUW5K4vJG31AJm","type":"tool_result","content":"     1→package config\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"os\"\n     6→\t\"path/filepath\"\n     7→\t\"strconv\"\n     8→\t\"strings\"\n     9→\n    10→\t\"github.com/BurntSushi/toml\"\n    11→)\n    12→\n    13→type DaemonConfig struct {\n    14→\tListen     string `toml:\"listen\"`\n    15→\tHTTP       string `toml:\"http\"`\n    16→\tImage      string `toml:\"image\"`\n    17→\tDB         string `toml:\"db\"`\n    18→\tRuntime    string `toml:\"runtime\"`\n    19→\tAgentPath  string `toml:\"agent_path\"`\n    20→\tLLMCommand string `toml:\"llm_command\"`\n    21→}\n    22→\n    23→type EvolutionConfig struct {\n    24→\tEnabled          bool   `toml:\"enabled\"`\n    25→\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n    26→\tMinConfidence    string `toml:\"min_confidence\"`\n    27→\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n    28→}\n    29→\n    30→type OrchestrationConfig struct {\n    31→\tEnabled     bool   `toml:\"enabled\"`\n    32→\tTracker     string `toml:\"tracker\"`\n    33→\tConcurrency int    `toml:\"concurrency\"`\n    34→\tWorkflow    string `toml:\"workflow\"`\n    35→}\n    36→\n    37→type Config struct {\n    38→\tDaemon        DaemonConfig        `toml:\"daemon\"`\n    39→\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n    40→\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n    41→}\n    42→\n    43→func defaults() Config {\n    44→\treturn Config{\n    45→\t\tEvolution: EvolutionConfig{\n    46→\t\t\tEnabled:          true,\n    47→\t\t\tDebounceSeconds:  30,\n    48→\t\t\tMinConfidence:    \"medium\",\n    49→\t\t\tMaxPromptBullets: 50,\n    50→\t\t},\n    51→\t\tOrchestration: OrchestrationConfig{\n    52→\t\t\tTracker:     \"beads\",\n    53→\t\t\tConcurrency: 1,\n    54→\t\t\tWorkflow:     \"develop\",\n    55→\t\t},\n    56→\t}\n    57→}\n    58→\n    59→// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    60→func Load(projectDir string) (*Config, error) {\n    61→\tcfg := defaults()\n    62→\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    63→\n    64→\tdata, err := os.ReadFile(path)\n    65→\tif os.IsNotExist(err) {\n    66→\t\treturn &cfg, nil\n    67→\t}\n    68→\tif err != nil {\n    69→\t\treturn nil, err\n    70→\t}\n    71→\n    72→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    73→\t\treturn nil, err\n    74→\t}\n    75→\treturn &cfg, nil\n    76→}\n    77→\n    78→// LoadVersion reads the project version from .cloche/version.\n    79→// Returns 1 if the file does not exist.\n    80→func LoadVersion(projectDir string) (int, error) {\n    81→\tpath := filepath.Join(projectDir, \".cloche\", \"version\")\n    82→\tdata, err := os.ReadFile(path)\n    83→\tif os.IsNotExist(err) {\n    84→\t\treturn 1, nil\n    85→\t}\n    86→\tif err != nil {\n    87→\t\treturn 0, err\n    88→\t}\n    89→\tv, err := strconv.Atoi(strings.TrimSpace(string(data)))\n    90→\tif err != nil {\n    91→\t\treturn 0, fmt.Errorf(\"parsing version: %w\", err)\n    92→\t}\n    93→\treturn v, nil\n    94→}\n    95→\n    96→// IncrementProjectVersion reads .cloche/version, increments the integer, and\n    97→// writes it back atomically. If the file does not exist, it writes 2 (treating\n    98→// the missing file as implicit version 1).\n    99→func IncrementProjectVersion(projectDir string) error {\n   100→\tv, err := LoadVersion(projectDir)\n   101→\tif err != nil {\n   102→\t\treturn err\n   103→\t}\n   104→\tv++\n   105→\n   106→\tdir := filepath.Join(projectDir, \".cloche\")\n   107→\ttmp, err := os.CreateTemp(dir, \"version-*.tmp\")\n   108→\tif err != nil {\n   109→\t\treturn fmt.Errorf(\"creating temp file: %w\", err)\n   110→\t}\n   111→\ttmpName := tmp.Name()\n   112→\n   113→\tif _, err := fmt.Fprintf(tmp, \"%d\\n\", v); err != nil {\n   114→\t\ttmp.Close()