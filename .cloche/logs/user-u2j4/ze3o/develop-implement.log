→\n    59→// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    60→func Load(projectDir string) (*Config, error) {\n    61→\tcfg := defaults()\n    62→\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    63→\n    64→\tdata, err := os.ReadFile(path)\n    65→\tif os.IsNotExist(err) {\n    66→\t\treturn &cfg, nil\n    67→\t}\n    68→\tif err != nil {\n    69→\t\treturn nil, err\n    70→\t}\n    71→\n    72→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    73→\t\treturn nil, err\n    74→\t}\n    75→\treturn &cfg, nil\n    76→}\n    77→\n    78→// LoadVersion reads the project version from .cloche/version.\n    79→// Returns 1 if the file does not exist.\n    80→func LoadVersion(projectDir string) (int, error) {\n    81→\tpath := filepath.Join(projectDir, \".cloche\", \"version\")\n    82→\tdata, err := os.ReadFile(path)\n    83→\tif os.IsNotExist(err) {\n    84→\t\treturn 1, nil\n    85→\t}\n    86→\tif err != nil {\n    87→\t\treturn 0, err\n    88→\t}\n    89→\tv, err := strconv.Atoi(strings.TrimSpace(string(data)))\n    90→\tif err != nil {\n    91→\t\treturn 0, fmt.Errorf(\"parsing version: %w\", err)\n    92→\t}\n    93→\treturn v, nil\n    94→}\n    95→\n    96→// IncrementProjectVersion reads .cloche/version, increments the integer, and\n    97→// writes it back atomically. If the file does not exist, it writes 2 (treating\n    98→// the missing file as implicit version 1).\n    99→func IncrementProjectVersion(projectDir string) error {\n   100→\tv, err := LoadVersion(projectDir)\n   101→\tif err != nil {\n   102→\t\treturn err\n   103→\t}\n   104→\tv++\n   105→\n   106→\tdir := filepath.Join(projectDir, \".cloche\")\n   107→\ttmp, err := os.CreateTemp(dir, \"version-*.tmp\")\n   108→\tif err != nil {\n   109→\t\treturn fmt.Errorf(\"creating temp file: %w\", err)\n   110→\t}\n   111→\ttmpName := tmp.Name()\n   112→\n   113→\tif _, err := fmt.Fprintf(tmp, \"%d\\n\", v); err != nil {\n   114→\t\ttmp.Close()\n   115→\t\tos.Remove(tmpName)\n   116→\t\treturn err\n   117→\t}\n   118→\tif err := tmp.Close(); err != nil {\n   119→\t\tos.Remove(tmpName)\n   120→\t\treturn err\n   121→\t}\n   122→\n   123→\ttarget := filepath.Join(dir, \"version\")\n   124→\tif err := os.Rename(tmpName, target); err != nil {\n   125→\t\tos.Remove(tmpName)\n   126→\t\treturn err\n   127→\t}\n   128→\treturn nil\n   129→}\n   130→\n   131→// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n   132→// Returns defaults if the file does not exist.\n   133→func LoadGlobal() (*Config, error) {\n   134→\tcfg := defaults()\n   135→\n   136→\thome, err := os.UserHomeDir()\n   137→\tif err != nil {\n   138→\t\treturn &cfg, nil\n   139→\t}\n   140→\n   141→\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n   142→\tdata, err := os.ReadFile(path)\n   143→\tif os.IsNotExist(err) {\n   144→\t\treturn &cfg, nil\n   145→\t}\n   146→\tif err != nil {\n   147→\t\treturn nil, err\n   148→\t}\n   149→\n   150→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   151→\t\treturn nil, err\n   152→\t}\n   153→\treturn &cfg, nil\n   154→}\n   155→\n   156→// LoadGlobalFrom reads the global config from a specific path.\n   157→// Useful for testing.\n   158→func LoadGlobalFrom(path string) (*Config, error) {\n   159→\tcfg := defaults()\n   160→\n   161→\tdata, err := os.ReadFile(path)\n   162→\tif os.IsNotExist(err) {\n   163→\t\treturn &cfg, nil\n   164→\t}\n   165→\tif err != nil {\n   166→\t\treturn nil, err\n   167→\t}\n   168→\n   169→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   170→\t\treturn nil, err\n   171→\t}\n   172→\treturn &cfg, nil\n   173→}\n   174→"}]},"parent_tool_use_id":null,"session_id":"41fe16d7-27b5-4856-aff1-bf807e48cd39","uuid":"ed24051e-8bf6-470b-aade-30021a45df77","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/config/config.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/BurntSushi/toml\"\n)\n\ntype DaemonConfig struct {\n\tListen     string `toml:\"listen\"`\n\tHTTP       string `toml:\"http\"`\n\tImage      string `toml:\"image\"`\n\tDB         string `toml:\"db\"`\n\tRuntime    string `toml:\"runtime\"`\n\tAgentPath  string `toml:\"agent_path\"`\n\tLLMCommand string `toml:\"llm_command\"`\n}\n\ntype EvolutionConfig struct {\n\tEnabled          bool   `toml:\"enabled\"`\n\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n\tMinConfidence    string `toml:\"min_confidence\"`\n\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n}\n\ntype OrchestrationConfig struct {\n\tEnabled     bool   `toml:\"enabled\"`\n\tTracker     string `toml:\"tracker\"`\n\tConcurrency int    `toml:\"concurrency\"`\n\tWorkflow    string `toml:\"workflow\"`\n}\n\ntype Config struct {\n\tDaemon        DaemonConfig        `toml:\"daemon\"`\n\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n}\n\nfunc defaults() Config {\n\treturn Config{\n\t\tEvolution: EvolutionConfig{\n\t\t\tEnabled:          true,\n\t\t\tDebounceSeconds:  30,\n\t\t\tMinConfidence:    \"medium\",\n\t\t\tMaxPromptBullets: 50,\n\t\t},\n\t\tOrchestration: OrchestrationConfig{\n\t\t\tTracker:     \"beads\",\n\t\t\tConcurrency: 1,\n\t\t\tWorkflow:     \"develop\",\n\t\t},\n\t}\n}\n\n// Load reads a per-project config from <projectDir>/.cloche/config.toml.\nfunc Load(projectDir string) (*Config, error) {\n\tcfg := defaults()\n\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadVersion reads the project version from .cloche/version.\n// Returns 1 if the file does not exist.\nfunc LoadVersion(projectDir string) (int, error) {\n\tpath := filepath.Join(projectDir, \".cloche\", \"version\")\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn 1, nil\n\t}\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\tv, err := strconv.Atoi(strings.TrimSpace(string(data)))\n\tif err != nil {\n\t\treturn 0, fmt.Errorf(\"parsing version: %w\", err)\n\t}\n\treturn v, nil\n}\n\n// IncrementProjectVersion reads .cloche/version, increments the integer, and\n// writes it back atomically. If the file does not exist, it writes 2 (treating\n// the missing file as implicit version 1).\nfunc IncrementProjectVersion(projectDir string) error {\n\tv, err := LoadVersion(projectDir)\n\tif err != nil {\n\t\treturn err\n\t}\n\tv++\n\n\tdir := filepath.Join(projectDir, \".cloche\")\n\ttmp, err := os.CreateTemp(dir, \"version-*.tmp\")\n\tif err != nil {\n\t\treturn fmt.Errorf(\"creating temp file: %w\", err)\n\t}\n\ttmpName := tmp.Name()\n\n\tif _, err := fmt.Fprintf(tmp, \"%d\\n\", v); err != nil {\n\t\ttmp.Close()\n\t\tos.Remove(tmpName)\n\t\treturn err\n\t}\n\tif err := tmp.Close(); err != nil {\n\t\tos.Remove(tmpName)\n\t\treturn err\n\t}\n\n\ttarget := filepath.Join(dir, \"version\")\n\tif err := os.Rename(tmpName, target); err != nil {\n\t\tos.Remove(tmpName)\n\t\treturn err\n\t}\n\treturn nil\n}\n\n// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n// Returns defaults if the file does not exist.\nfunc LoadGlobal() (*Config, error) {\n\tcfg := defaults()\n\n\thome, err := os.UserHomeDir()\n\tif err != nil {\n\t\treturn &cfg, nil\n\t}\n\n\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadGlobalFrom reads the global config from a specific path.\n// Useful for testing.\nfunc LoadGlobalFrom(path string) (*Config, error) {\n\tcfg := defaults()\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n","numLines":174,"startLine":1,"totalLines":174}}}
