Store, capStore ports.CaptureStore) (*EvolutionResult, error) {\n    52→\t// Stage 1: Collect\n    53→\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n    54→\tif err != nil {\n    55→\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n    56→\t}\n    57→\n    58→\t// Stage 2: Classify the triggering run\n    59→\tclassification, err := o.classifier.Classify(ctx, \"\")\n    60→\tif err != nil {\n    61→\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n    62→\t}\n    63→\n    64→\t// Stage 3: Reflect\n    65→\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n    66→\tif err != nil {\n    67→\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n    68→\t}\n    69→\n    70→\tresult := &EvolutionResult{\n    71→\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n    72→\t\tProjectDir:     o.cfg.ProjectDir,\n    73→\t\tWorkflowName:   o.cfg.WorkflowName,\n    74→\t\tTriggerRunID:   triggerRunID,\n    75→\t\tTimestamp:      time.Now().Format(time.RFC3339),\n    76→\t\tClassification: classification,\n    77→\t}\n    78→\n    79→\tif len(lessons) == 0 {\n    80→\t\t// No actionable lessons — log and return\n    81→\t\to.audit.Log(result)\n    82→\t\treturn result, nil\n    83→\t}\n    84→\n    85→\t// Stage 4: Execute branches based on lesson category\n    86→\tfor _, lesson := range lessons {\n    87→\t\tswitch lesson.Category {\n    88→\t\tcase \"prompt_improvement\":\n    89→\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n    90→\t\t\tif err != nil {\n    91→\t\t\t\tcontinue // log but don't fail the whole pipeline\n    92→\t\t\t}\n    93→\t\t\tresult.Changes = append(result.Changes, *change)\n    94→\n    95→\t\tcase \"new_step\":\n    96→\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n    97→\t\t\t\tcontinue\n    98→\t\t\t}\n    99→\t\t}\n   100→\t}\n   101→\n   102→\t// Stage 5: Audit\n   103→\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n   104→\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n   105→\to.audit.Log(result)\n   106→\n   107→\t// Increment project version when changes were made\n   108→\tif len(result.Changes) > 0 {\n   109→\t\tif err := config.IncrementProjectVersion(o.cfg.ProjectDir); err != nil {\n   110→\t\t\treturn nil, fmt.Errorf(\"incrementing project version: %w\", err)\n   111→\t\t}\n   112→\t}\n   113→\n   114→\t// Save to store if available\n   115→\tif evoStore != nil {\n   116→\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n   117→\t\t\tID:             result.ID,\n   118→\t\t\tProjectDir:     result.ProjectDir,\n   119→\t\t\tWorkflowName:   result.WorkflowName,\n   120→\t\t\tTriggerRunID:   result.TriggerRunID,\n   121→\t\t\tCreatedAt:      time.Now(),\n   122→\t\t\tClassification: result.Classification,\n   123→\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n   124→\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n   125→\t\t})\n   126→\t}\n   127→\n   128→\treturn result, nil\n   129→}\n   130→\n   131→// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\n   132→func (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n   133→\t// Generate the script or prompt file\n   134→\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n   135→\tif err != nil {\n   136→\t\treturn err\n   137→\t}\n   138→\n   139→\tresult.Changes = append(result.Changes, Change{\n   140→\t\tType:   \"add_script\",\n   141→\t\tFile:   generated.Path,\n   142→\t\tReason: lesson.Insight,\n   143→\t})\n   144→\n   145→\t// Add step and wiring to the workflow file\n   146→\tif data.WorkflowPath == \"\" {\n   147→\t\treturn nil\n   148→\t}\n   149→\n   150→\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n   151→\tif err != nil {\n   152→\t\treturn err\n   153→\t}\n   154→\n   155→\t// Snapshot the workflow\n   156→\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n   157→\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n   158→\n   159→\t// Derive step name from the script path\n   160→\tstepName := filepath.Base(generated.Path)\n   161→\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n   162→\n   163→\t// Determine the config based on step type\n   164→\tconfig := map[string]string{}\n   165→\tswitch lesson.StepType {\n   166→\tcase \"agent\":\n   167→\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n   168→\tdefault: // script\n   169→\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n   170→\t}\n   171→\n   172→\t// Add the step\n   173→\tupdated, err := o.mutator.AddStep(string(workflowContent), dsl.StepDef{\n   174→\t\tName:    stepName,\n   175→\t\tType:    lesson.StepType,\n   176→\t\tConfig:  config,\n   177→\t\tResults: []string{\"success\", \"fail\"},\n   178→\t})\n   179→\tif err != nil {\n   180→\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n   181→\t}\n   182→\n   183→\t// Add wiring: wire the new step's fail to the fix step (if it exists),\n   184→\t// and success to done\n   185→\twires := []dsl.WireDef{\n   186→\t\t{From: stepName, Result: \"success\", To: \"done\"},\n   187→\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n   188→\t}\n   189→\tupdated, err = o.mutator.AddWiring(updated, wires)\n   190→\tif err != nil {\n   191→\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n   192→\t}\n   193→\n   194→\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n   195→\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n   196→\t}\n   197→\n   198→\tresult.Changes = append(result.Changes, Change{\n   199→\t\tType:     \"add_step\",\n   200→\t\tFile:     wfRelPath,\n   201→\t\tReason:   lesson.Insight,\n   202→\t\tSnapshot: snapName,\n   203→\t})\n   204→\n   205→\treturn nil\n   206→}\n   207→"}]},"parent_tool_use_id":null,"session_id":"41fe16d7-27b5-4856-aff1-