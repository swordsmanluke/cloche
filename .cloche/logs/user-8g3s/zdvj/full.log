inConfidence:    \"medium\",\n    47Ôćĺ\t\t\tMaxPromptBullets: 50,\n    48Ôćĺ\t\t},\n    49Ôćĺ\t\tOrchestration: OrchestrationConfig{\n    50Ôćĺ\t\t\tConcurrency:    1,\n    51Ôćĺ\t\t\tStaggerSeconds: 1.0,\n    52Ôćĺ\t\t},\n    53Ôćĺ\t}\n    54Ôćĺ}\n    55Ôćĺ\n    56Ôćĺ// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    57Ôćĺfunc Load(projectDir string) (*Config, error) {\n    58Ôćĺ\tcfg := defaults()\n    59Ôćĺ\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    60Ôćĺ\n    61Ôćĺ\tdata, err := os.ReadFile(path)\n    62Ôćĺ\tif os.IsNotExist(err) {\n    63Ôćĺ\t\treturn &cfg, nil\n    64Ôćĺ\t}\n    65Ôćĺ\tif err != nil {\n    66Ôćĺ\t\treturn nil, err\n    67Ôćĺ\t}\n    68Ôćĺ\n    69Ôćĺ\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    70Ôćĺ\t\treturn nil, err\n    71Ôćĺ\t}\n    72Ôćĺ\treturn &cfg, nil\n    73Ôćĺ}\n    74Ôćĺ\n    75Ôćĺ// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n    76Ôćĺ// Returns defaults if the file does not exist.\n    77Ôćĺfunc LoadGlobal() (*Config, error) {\n    78Ôćĺ\tcfg := defaults()\n    79Ôćĺ\n    80Ôćĺ\thome, err := os.UserHomeDir()\n    81Ôćĺ\tif err != nil {\n    82Ôćĺ\t\treturn &cfg, nil\n    83Ôćĺ\t}\n    84Ôćĺ\n    85Ôćĺ\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n    86Ôćĺ\tdata, err := os.ReadFile(path)\n    87Ôćĺ\tif os.IsNotExist(err) {\n    88Ôćĺ\t\treturn &cfg, nil\n    89Ôćĺ\t}\n    90Ôćĺ\tif err != nil {\n    91Ôćĺ\t\treturn nil, err\n    92Ôćĺ\t}\n    93Ôćĺ\n    94Ôćĺ\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    95Ôćĺ\t\treturn nil, err\n    96Ôćĺ\t}\n    97Ôćĺ\treturn &cfg, nil\n    98Ôćĺ}\n    99Ôćĺ\n   100Ôćĺ// LoadGlobalFrom reads the global config from a specific path.\n   101Ôćĺ// Useful for testing.\n   102Ôćĺfunc LoadGlobalFrom(path string) (*Config, error) {\n   103Ôćĺ\tcfg := defaults()\n   104Ôćĺ\n   105Ôćĺ\tdata, err := os.ReadFile(path)\n   106Ôćĺ\tif os.IsNotExist(err) {\n   107Ôćĺ\t\treturn &cfg, nil\n   108Ôćĺ\t}\n   109Ôćĺ\tif err != nil {\n   110Ôćĺ\t\treturn nil, err\n   111Ôćĺ\t}\n   112Ôćĺ\n   113Ôćĺ\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   114Ôćĺ\t\treturn nil, err\n   115Ôćĺ\t}\n   116Ôćĺ\treturn &cfg, nil\n   117Ôćĺ}\n   118Ôćĺ"}]},"parent_tool_use_id":null,"session_id":"b83aa53c-b539-403e-957d-d27f065bd09c","uuid":"3deac8a4-10cf-492c-a311-161dae5ff4f4","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/config/config.go","content":"package config\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\n\t\"github.com/BurntSushi/toml\"\n)\n\ntype DaemonConfig struct {\n\tListen     string `toml:\"listen\"`\n\tHTTP       string `toml:\"http\"`\n\tImage      string `toml:\"image\"`\n\tDB         string `toml:\"db\"`\n\tRuntime    string `toml:\"runtime\"`\n\tAgentPath  string `toml:\"agent_path\"`\n\tLLMCommand string `toml:\"llm_command\"`\n}\n\ntype EvolutionConfig struct {\n\tEnabled          bool   `toml:\"enabled\"`\n\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n\tMinConfidence    string `toml:\"min_confidence\"`\n\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n}\n\ntype OrchestrationConfig struct {\n\tConcurrency      int     `toml:\"concurrency\"`\n\tStaggerSeconds   float64 `toml:\"stagger_seconds\"`\n\tListTasksCommand string  `toml:\"list_tasks_command\"` // shell command to list open tasks (JSON array output)\n\tDedupSeconds     float64 `toml:\"dedup_seconds\"`      // dedup window for task assignment (default: 300)\n}\n\ntype Config struct {\n\tActive        bool                `toml:\"active\"`\n\tDaemon        DaemonConfig        `toml:\"daemon\"`\n\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n}\n\nfunc defaults() Config {\n\treturn Config{\n\t\tEvolution: EvolutionConfig{\n\t\t\tEnabled:          true,\n\t\t\tDebounceSeconds:  30,\n\t\t\tMinConfidence:    \"medium\",\n\t\t\tMaxPromptBullets: 50,\n\t\t},\n\t\tOrchestration: OrchestrationConfig{\n\t\t\tConcurrency:    1,\n\t\t\tStaggerSeconds: 1.0,\n\t\t},\n\t}\n}\n\n// Load reads a per-project config from <projectDir>/.cloche/config.toml.\nfunc Load(projectDir string) (*Config, error) {\n\tcfg := defaults()\n\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n// Returns defaults if the file does not exist.\nfunc LoadGlobal() (*Config, error) {\n\tcfg := defaults()\n\n\thome, err := os.UserHomeDir()\n\tif err != nil {\n\t\treturn &cfg, nil\n\t}\n\n\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadGlobalFrom reads the global config from a specific path.\n// Useful for testing.\nfunc LoadGlobalFrom(path string) (*Config, error) {\n\tcfg := defaults()\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n","numLines":118,"startLine":1,"totalLines":118}}}
