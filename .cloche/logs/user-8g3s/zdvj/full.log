[2026-03-11T00:27:32Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VujzrfaAaXpq1zko3e8PX7","type":"tool_result","content":"   100Ôćĺ\t\t\tbreak\n   101Ôćĺ\t\t}\n   102Ôćĺ\t}\n   103Ôćĺ\n   104Ôćĺ\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   105Ôćĺ\tif req.Prompt != \"\" {\n   106Ôćĺ\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   107Ôćĺ\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   108Ôćĺ\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   109Ôćĺ\t\t}\n   110Ôćĺ\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   111Ôćĺ\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   112Ôćĺ\t\t}\n   113Ôćĺ\t}\n   114Ôćĺ\trun := domain.NewRun(runID, req.WorkflowName)\n   115Ôćĺ\trun.ProjectDir = req.ProjectDir\n   116Ôćĺ\trun.Title = req.Title\n   117Ôćĺ\tif err := s.store.CreateRun(ctx, run); err != nil {\n   118Ôćĺ\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   119Ôćĺ\t}\n   120Ôćĺ\n   121Ôćĺ\t// Resolve image: request-level override, then server default\n   122Ôćĺ\timage := req.Image\n   123Ôćĺ\tif image == \"\" {\n   124Ôćĺ\t\timage = s.defaultImage\n   125Ôćĺ\t}\n   126Ôćĺ\n   127Ôćĺ\t// Launch container start + tracking in background so the RPC returns immediately.\n   128Ôćĺ\t// The run stays in \"pending\" state until the container is up.\n   129Ôćĺ\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   130Ôćĺ\n   131Ôćĺ\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   132Ôćĺ}\n   133Ôćĺ\n   134Ôćĺ// launchAndTrack starts the container and then tracks it to completion.\n   135Ôćĺ// It runs in a background goroutine with its own context, independent of the\n   136Ôćĺ// RPC context which may be cancelled after RunWorkflow returns.\n   137Ôćĺfunc (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   138Ôćĺ\tctx := context.Background()\n   139Ôćĺ\n   140Ôćĺ\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   141Ôćĺ\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   142Ôćĺ\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   143Ôćĺ\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   144Ôćĺ\t\t\tif run != nil {\n   145Ôćĺ\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   146Ôćĺ\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   147Ôćĺ\t\t\t}\n   148Ôćĺ\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   149Ôćĺ\t\t\t\treturn\n   150Ôćĺ\t\t}\n   151Ôćĺ\t}\n   152Ôćĺ\n   153Ôćĺ\tbaseSHA := gitHEAD(req.ProjectDir)\n   154Ôćĺ\n   155Ôćĺ\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   156Ôćĺ\t\tImage:        image,\n   157Ôćĺ\t\tWorkflowName: req.WorkflowName,\n   158Ôćĺ\t\tProjectDir:   req.ProjectDir,\n   159Ôćĺ\t\tRunID:        runID,\n   160Ôćĺ\t\tNetworkAllow: []string{\"*\"},\n   161Ôćĺ\t})\n   162Ôćĺ\tif err != nil {\n   163Ôćĺ\t\trun, _ := s.store.GetRun(ctx, runID)\n   164Ôćĺ\t\tif run != nil {\n   165Ôćĺ\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   166Ôćĺ\t\t\t_ = s.store.UpdateRun(ctx, run)\n   167Ôćĺ\t\t}\n   168Ôćĺ\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   169Ôćĺ\t\treturn\n   170Ôćĺ\t}\n   171Ôćĺ\n   172Ôćĺ\ts.mu.Lock()\n   173Ôćĺ\ts.runIDs[runID] = containerID\n   174Ôćĺ\ts.mu.Unlock()\n   175Ôćĺ\n   176Ôćĺ\trun, _ := s.store.GetRun(ctx, runID)\n   177Ôćĺ\tif run != nil {\n   178Ôćĺ\t\trun.Start()\n   179Ôćĺ\t\trun.ContainerID = containerID\n   180Ôćĺ\t\trun.BaseSHA = baseSHA\n   181Ôćĺ\t\t_ = s.store.UpdateRun(ctx, run)\n   182Ôćĺ\t}\n   183Ôćĺ\n   184Ôćĺ\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   185Ôćĺ}\n   186Ôćĺ\n   187Ôćĺfunc (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   188Ôćĺ\tctx := context.Background()\n   189Ôćĺ\n   190Ôćĺ\t// Attach to agent output\n   191Ôćĺ\treader, err := s.container.AttachOutput(ctx, containerID)\n   192Ôćĺ\tif err != nil {\n   193Ôćĺ\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   194Ôćĺ\t\t\treturn\n   195Ôćĺ\t}\n   196Ôćĺ\n   197Ôćĺ\t// Parse JSON-lines status messages\n   198Ôćĺ\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   199Ôćĺ\tscanner := bufio.NewScanner(reader)\n   200Ôćĺ\tfor scanner.Scan() {\n   201Ôćĺ\t\tvar msg protocol.StatusMessage\n   202Ôćĺ\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   203Ôćĺ\t\t\tcontinue\n   204Ôćĺ\t\t}\n   205Ôćĺ\n   206Ôćĺ\t\t// Fast path: log messages don't need store interaction.\n   207Ôćĺ\t\tif msg.Type == protocol.MsgLog {\n   208Ôćĺ\t\t\tif s.logBroadcast != nil {\n   209Ôćĺ\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   210Ôćĺ\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   211Ôćĺ\t\t\t\t\tType:      \"llm\",\n   212Ôćĺ\t\t\t\t\tContent:   msg.Message,\n   213Ôćĺ\t\t\t\t\tStepName:  msg.StepName,\n   214Ôćĺ\t\t\t\t})\n   215Ôćĺ\t\t\t}\n   216Ôćĺ\t\t\tcontinue\n   217Ôćĺ\t\t}\n   218Ôćĺ\n   219Ôćĺ\t\trun, err := s.store.GetRun(ctx, runID)\n   220Ôćĺ\t\tif err != nil {\n   221Ôćĺ\t\t\tcontinue\n   222Ôćĺ\t\t}\n   223Ôćĺ\n   224Ôćĺ\t\tswitch msg.Type {\n   225Ôćĺ\t\tcase protocol.MsgStepStarted:\n   226Ôćĺ\t\t\trun.RecordStepStart(msg.StepName)\n   227Ôćĺ\t\t\tif s.captures != nil {\n   228Ôćĺ\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   229Ôćĺ\t\t\t\t\tStepName:  msg.StepName,\n   230Ôćĺ\t\t\t\t\tStartedAt: msg.Timestamp,\n   231Ôćĺ\t\t\t\t})\n   232Ôćĺ\t\t\t}\n   233Ôćĺ\t\t\tif s.logBroadcast != nil {\n   234Ôćĺ\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   235Ôćĺ\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   236Ôćĺ\t\t\t\t\tType:      \"status\",\n   237Ôćĺ\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   238Ôćĺ\t\t\t\t\tStepName:  msg.StepName,\n   239Ôćĺ\t\t\t\t})\n   240Ôćĺ\t\t\t}\n   241Ôćĺ\t\tcase protocol.MsgStepCompleted:\n   242Ôćĺ\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   243Ôćĺ\t\t\tif s.captures != nil {\n   244Ôćĺ\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   245Ôćĺ\t\t\t\t\tStepName:    msg.StepName,\n   246Ôćĺ\t\t\t\t\tResult:      msg.Result,\n   247Ôćĺ\t\t\t\t\tCompletedAt: msg.Timestamp,\n   248Ôćĺ\t\t\t\t})\n   249Ôćĺ\t\t\t}\n   250Ôćĺ\t\t\tif s.logBroadcast != nil {\n   251Ôćĺ\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   252Ôćĺ\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   253Ôćĺ\t\t\t\t\tType:      \"status\",\n   254Ôćĺ\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   255Ôćĺ\t\t\t\t\tStepName:  msg.StepName,\n   256Ôćĺ\t\t\t\t})\n   257Ôćĺ\t\t\t}\n   258Ôćĺ\t\tcase protocol.MsgRunTitle:\n   259Ôćĺ\t\t\tif run.Title == \"\" {\n   260Ôćĺ\t\t\t\trun.Title = msg.Message\n   261Ôćĺ\t\t\t}\n   262Ôćĺ\t\tcase protocol.MsgRunCompleted:\n   263Ôćĺ\t\t\treportedResult = msg.Result\n   264Ôćĺ\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   265Ôćĺ\t\t}\n   266Ôćĺ\n   267Ôćĺ\t\t_ = s.store.UpdateRun(ctx, run)\n   268Ôćĺ\t}\n   269Ôćĺ\treader.Close()\n   270Ôćĺ\n   271Ôćĺ\t// Signal live-stream subscribers that this run is done.\n   272Ôćĺ\tif s.logBroadcast != nil {\n   273Ôćĺ\t\ts.logBroadcast.Finish(runID)\n   274Ôćĺ\t}\n   275Ôćĺ\n   276Ôćĺ\t// Wait for process exit\n   277Ôćĺ\texitCode, err := s.container.Wait(ctx, containerID)\n   278Ôćĺ\tif err != nil {\n   279Ôćĺ\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   280Ôćĺ\t}\n   281Ôćĺ\n   282Ôćĺ\t// Extract step output files from container before it's removed\n   283Ôćĺ\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   284Ôćĺ\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   285Ôćĺ\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   286Ôćĺ\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   287Ôćĺ\t\t}\n   288Ôćĺ\t}\n   289Ôćĺ\n   290Ôćĺ\t// Capture full container stdout/stderr before the container is removed\n   291Ôćĺ\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   292Ôćĺ\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   293Ôćĺ\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   294Ôćĺ\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   295Ôćĺ\t\t}\n   296Ôćĺ\t}\n   297Ôćĺ\n   298Ôćĺ\t// Index extracted log files in the log store\n   299Ôćĺ\tif s.logStore != nil {\n   300Ôćĺ\t\ts.indexLogFiles(ctx, runID, outputDst)\n   301Ôćĺ\t}\n   302Ôćĺ\n   303Ôćĺ\t// Extract results to git branch BEFORE finalizing state, so that\n   304Ôćĺ\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   305Ôćĺ\t// before the run is marked complete.\n   306Ôćĺ\tresultLabel := reportedResult\n   307Ôćĺ\tif resultLabel == \"\" {\n   308Ôćĺ\t\tif exitCode == 0 {\n   309Ôćĺ\t\t\tresultLabel = \"succeeded\"\n   310Ôćĺ\t\t} else {\n   311Ôćĺ\t\t\tresultLabel = \"failed\"\n   312Ôćĺ\t\t}\n   313Ôćĺ\t}\n   314Ôćĺ\t{\n   315Ôćĺ\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   316Ôćĺ\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   317Ôćĺ\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   318Ôćĺ\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   319Ôćĺ\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   320Ôćĺ\t\t\t} else {\n   321Ôćĺ\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   322Ôćĺ\t\t\t}\n   323Ôćĺ\t\t} else {\n   324Ôćĺ\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   325Ôćĺ\t\t}\n   326Ôćĺ\t}\n   327Ôćĺ\n   328Ôćĺ\t// Now finalize run state\n   329Ôćĺ\trun, err := s.store.GetRun(ctx, runID)\n   330Ôćĺ\tif err != nil {\n   331Ôćĺ\t\treturn\n   332Ôćĺ\t}\n   333Ôćĺ\tif run.State == domain.RunStateRunning {\n   334Ôćĺ\t\tif reportedResult == \"succeeded\" {\n   335Ôćĺ\t\t\trun.Complete(domain.RunStateSucceeded)\n   336Ôćĺ\t\t} else if reportedResult != \"\" {\n   337Ôćĺ\t\t\trun.Complete(domain.RunStateFailed)\n   338Ôćĺ\t\t} else if exitCode == 0 {\n   339Ôćĺ\t\t\trun.Complete(domain.RunStateSucceeded)\n   340Ôćĺ\t\t} else {\n   341Ôćĺ\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   342Ôćĺ\t\t}\n   343Ôćĺ\t\t_ = s.store.UpdateRun(ctx, run)\n   344Ôćĺ\t}\n   345Ôćĺ\n   346Ôćĺ\t// Fire evolution trigger if configured\n   347Ôćĺ\tif s.evolution != nil {\n   348Ôćĺ\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   349Ôćĺ\t}\n   350Ôćĺ\n   351Ôćĺ\t// Merge is handled as a workflow step in host.cloche, not here.\n   352Ôćĺ\n   353Ôćĺ\t// Container retention policy:\n   354Ôćĺ\t// - Failed runs: always keep the container for debugging\n   355Ôćĺ\t// - Successful runs + --keep-container: keep the container\n   356Ôćĺ\t// - Successful runs without --keep-container: remove the container\n   357Ôćĺ\trunFinal, _ := s.store.GetRun(ctx, runID)\n   358Ôćĺ\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   359Ôćĺ\n   360Ôćĺ\tif keepContainer || runFailed {\n   361Ôćĺ\t\treason := \"--keep-container\"\n   362Ôćĺ\t\tif runFailed {\n   363Ôćĺ\t\t\treason = \"run failed\"\n   364Ôćĺ\t\t}\n   365Ôćĺ\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   366Ôćĺ\t\tif runFinal != nil {\n   367Ôćĺ\t\t\trunFinal.ContainerKept = true\n   368Ôćĺ\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   369Ôćĺ\t\t}\n   370Ôćĺ\t} else {\n   371Ôćĺ\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   372Ôćĺ\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   373Ôćĺ\t\t} else {\n   374Ôćĺ\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   375Ôćĺ\t\t}\n   376Ôćĺ\t}\n   377Ôćĺ\n   378Ôćĺ\t// Cleanup mapping\n   379Ôćĺ\ts.mu.Lock()\n   380Ôćĺ\tdelete(s.runIDs, runID)\n   381Ôćĺ\ts.mu.Unlock()\n   382Ôćĺ}\n   383Ôćĺ\n   384Ôćĺfunc (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   385Ôćĺ\tvar since time.Time\n   386Ôćĺ\tif !req.All {\n   387Ôćĺ\t\tsince = time.Now().Add(-1 * time.Hour)\n   388Ôćĺ\t}\n   389Ôćĺ\truns, err := s.store.ListRuns(ctx, since)\n   390Ôćĺ\tif err != nil {\n   391Ôćĺ\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   392Ôćĺ\t}\n   393Ôćĺ\n   394Ôćĺ\tresp := &pb.ListRunsResponse{}\n   395Ôćĺ\tfor _, run := range runs {\n   396Ôćĺ\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   397Ôćĺ\t\t\tRunId:        run.ID,\n   398Ôćĺ\t\t\tWorkflowName: run.WorkflowName,\n   399Ôćĺ\t\t\tState:        string(run.State),"}]},"parent_tool_use_id":"toolu_01Dpfoc28ynQqDwHgSbSci6o","session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"ad47a61b-e3de-41b3-ac3a-95ebde7def91"}
