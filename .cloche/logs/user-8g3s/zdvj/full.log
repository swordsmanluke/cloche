(_ context.Context, id string) error {\n    53Ôćĺ\tdelete(f.runs, id)\n    54Ôćĺ\treturn nil\n    55Ôćĺ}\n    56Ôćĺfunc (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n    57Ôćĺ\treturn nil, nil\n    58Ôćĺ}\n    59Ôćĺfunc (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n    60Ôćĺ\treturn nil, nil\n    61Ôćĺ}\n    62Ôćĺfunc (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n    63Ôćĺ\treturn nil, nil\n    64Ôćĺ}\n    65Ôćĺfunc (f *fakeStore) ListChildRuns(_ context.Context, parentRunID string) ([]*domain.Run, error) {\n    66Ôćĺ\tvar children []*domain.Run\n    67Ôćĺ\tfor _, r := range f.runs {\n    68Ôćĺ\t\tif r.ParentRunID == parentRunID {\n    69Ôćĺ\t\t\tchildren = append(children, r)\n    70Ôćĺ\t\t}\n    71Ôćĺ\t}\n    72Ôćĺ\treturn children, nil\n    73Ôćĺ}\n    74Ôćĺ\n    75Ôćĺfunc TestExecutor_ScriptStep_Success(t *testing.T) {\n    76Ôćĺ\ttmpDir := t.TempDir()\n    77Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n    78Ôćĺ\n    79Ôćĺ\texecutor := &Executor{\n    80Ôćĺ\t\tProjectDir: tmpDir,\n    81Ôćĺ\t\tOutputDir:  outputDir,\n    82Ôćĺ\t}\n    83Ôćĺ\n    84Ôćĺ\tstep := &domain.Step{\n    85Ôćĺ\t\tName:    \"greet\",\n    86Ôćĺ\t\tType:    domain.StepTypeScript,\n    87Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n    88Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n    89Ôćĺ\t}\n    90Ôćĺ\n    91Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n    92Ôćĺ\trequire.NoError(t, err)\n    93Ôćĺ\tassert.Equal(t, \"success\", result)\n    94Ôćĺ\n    95Ôćĺ\t// Check output was written\n    96Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n    97Ôćĺ\trequire.NoError(t, err)\n    98Ôćĺ\tassert.Contains(t, string(data), \"hello\")\n    99Ôćĺ}\n   100Ôćĺ\n   101Ôćĺfunc TestExecutor_ScriptStep_Failure(t *testing.T) {\n   102Ôćĺ\ttmpDir := t.TempDir()\n   103Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   104Ôćĺ\n   105Ôćĺ\texecutor := &Executor{\n   106Ôćĺ\t\tProjectDir: tmpDir,\n   107Ôćĺ\t\tOutputDir:  outputDir,\n   108Ôćĺ\t}\n   109Ôćĺ\n   110Ôćĺ\tstep := &domain.Step{\n   111Ôćĺ\t\tName:    \"bad\",\n   112Ôćĺ\t\tType:    domain.StepTypeScript,\n   113Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   114Ôćĺ\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   115Ôćĺ\t}\n   116Ôćĺ\n   117Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   118Ôćĺ\trequire.NoError(t, err)\n   119Ôćĺ\tassert.Equal(t, \"fail\", result)\n   120Ôćĺ}\n   121Ôćĺ\n   122Ôćĺfunc TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n   123Ôćĺ\ttmpDir := t.TempDir()\n   124Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   125Ôćĺ\n   126Ôćĺ\texecutor := &Executor{\n   127Ôćĺ\t\tProjectDir: tmpDir,\n   128Ôćĺ\t\tOutputDir:  outputDir,\n   129Ôćĺ\t}\n   130Ôćĺ\n   131Ôćĺ\tstep := &domain.Step{\n   132Ôćĺ\t\tName:    \"marker\",\n   133Ôćĺ\t\tType:    domain.StepTypeScript,\n   134Ôćĺ\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n   135Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n   136Ôćĺ\t}\n   137Ôćĺ\n   138Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   139Ôćĺ\trequire.NoError(t, err)\n   140Ôćĺ\tassert.Equal(t, \"custom\", result)\n   141Ôćĺ\n   142Ôćĺ\t// Marker line should be stripped from output\n   143Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n   144Ôćĺ\trequire.NoError(t, err)\n   145Ôćĺ\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n   146Ôćĺ\tassert.Contains(t, string(data), \"some output\")\n   147Ôćĺ}\n   148Ôćĺ\n   149Ôćĺfunc TestExecutor_WorkflowStep_Success(t *testing.T) {\n   150Ôćĺ\ttmpDir := t.TempDir()\n   151Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   152Ôćĺ\t_ = os.MkdirAll(outputDir, 0755)\n   153Ôćĺ\n   154Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{\n   155Ôćĺ\t\t\"develop-test-run\": {\n   156Ôćĺ\t\t\tID:    \"develop-test-run\",\n   157Ôćĺ\t\t\tState: domain.RunStateSucceeded,\n   158Ôćĺ\t\t},\n   159Ôćĺ\t}}\n   160Ôćĺ\n   161Ôćĺ\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   162Ôćĺ\n   163Ôćĺ\texecutor := &Executor{\n   164Ôćĺ\t\tProjectDir: tmpDir,\n   165Ôćĺ\t\tDispatcher: dispatcher,\n   166Ôćĺ\t\tStore:      store,\n   167Ôćĺ\t\tOutputDir:  outputDir,\n   168Ôćĺ\t}\n   169Ôćĺ\n   170Ôćĺ\tstep := &domain.Step{\n   171Ôćĺ\t\tName:    \"develop\",\n   172Ôćĺ\t\tType:    domain.StepTypeWorkflow,\n   173Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   174Ôćĺ\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   175Ôćĺ\t}\n   176Ôćĺ\n   177Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   178Ôćĺ\trequire.NoError(t, err)\n   179Ôćĺ\tassert.Equal(t, \"success\", result)\n   180Ôćĺ\tassert.Len(t, dispatcher.calls, 1)\n   181Ôćĺ\tassert.Equal(t, \"develop\", dispatcher.calls[0].WorkflowName)\n   182Ôćĺ\tassert.Equal(t, tmpDir, dispatcher.calls[0].ProjectDir)\n   183Ôćĺ}\n   184Ôćĺ\n   185Ôćĺfunc TestExecutor_WorkflowStep_Failure(t *testing.T) {\n   186Ôćĺ\ttmpDir := t.TempDir()\n   187Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   188Ôćĺ\t_ = os.MkdirAll(outputDir, 0755)\n   189Ôćĺ\n   190Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{\n   191Ôćĺ\t\t\"develop-test-run\": {\n   192Ôćĺ\t\t\tID:    \"develop-test-run\",\n   193Ôćĺ\t\t\tState: domain.RunStateFailed,\n   194Ôćĺ\t\t},\n   195Ôćĺ\t}}\n   196Ôćĺ\n   197Ôćĺ\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   198Ôćĺ\n   199Ôćĺ\texecutor := &Executor{\n   200Ôćĺ\t\tProjectDir: tmpDir,\n   201Ôćĺ\t\tDispatcher: dispatcher,\n   202Ôćĺ\t\tStore:      store,\n   203Ôćĺ\t\tOutputDir:  outputDir,\n   204Ôćĺ\t}\n   205Ôćĺ\n   206Ôćĺ\tstep := &domain.Step{\n   207Ôćĺ\t\tName:    \"develop\",\n   208Ôćĺ\t\tType:    domain.StepTypeWorkflow,\n   209Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   210Ôćĺ\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   211Ôćĺ\t}\n   212Ôćĺ\n   213Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   214Ôćĺ\trequire.NoError(t, err)\n   215Ôćĺ\tassert.Equal(t, \"fail\", result)\n   216Ôćĺ}\n   217Ôćĺ\n   218Ôćĺfunc TestExecutor_WorkflowStep_PassesPrompt(t *testing.T) {\n   219Ôćĺ\ttmpDir := t.TempDir()\n   220Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   221Ôćĺ\t_ = os.MkdirAll(outputDir, 0755)\n   222Ôćĺ\n   223Ôćĺ\t// Write a previous step's output\n   224Ôćĺ\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n   225Ôćĺ\n   226Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{\n   227Ôćĺ\t\t\"develop-test-run\": {\n   228Ôćĺ\t\t\tID:    \"develop-test-run\",\n   229Ôćĺ\t\t\tState: domain.RunStateSucceeded,\n   230Ôćĺ\t\t},\n   231Ôćĺ\t}}\n   232Ôćĺ\n   233Ôćĺ\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   234Ôćĺ\n   235Ôćĺ\texecutor := &Executor{\n   236Ôćĺ\t\tProjectDir: tmpDir,\n   237Ôćĺ\t\tDispatcher: dispatcher,\n   238Ôćĺ\t\tStore:      store,\n   239Ôćĺ\t\tOutputDir:  outputDir,\n   240Ôćĺ\t}\n   241Ôćĺ\n   242Ôćĺ\tstep := &domain.Step{\n   243Ôćĺ\t\tName:    \"develop\",\n   244Ôćĺ\t\tType:    domain.StepTypeWorkflow,\n   245Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   246Ôćĺ\t\tConfig: map[string]string{\n   247Ôćĺ\t\t\t\"workflow_name\": \"develop\",\n   248Ôćĺ\t\t\t\"prompt_step\":   \"prepare-prompt\",\n   249Ôćĺ\t\t},\n   250Ôćĺ\t}\n   251Ôćĺ\n   252Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   253Ôćĺ\trequire.NoError(t, err)\n   254Ôćĺ\tassert.Equal(t, \"success\", result)\n   255Ôćĺ\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n   256Ôćĺ}\n   257Ôćĺ\n   258Ôćĺfunc TestEngine_HostWorkflow_Linear(t *testing.T) {\n   259Ôćĺ\ttmpDir := t.TempDir()\n   260Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   261Ôćĺ\n   262Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{\n   263Ôćĺ\t\t\"develop-test-run\": {\n   264Ôćĺ\t\t\tID:    \"develop-test-run\",\n   265Ôćĺ\t\t\tState: domain.RunStateSucceeded,\n   266Ôćĺ\t\t},\n   267Ôćĺ\t}}\n   268Ôćĺ\n   269Ôćĺ\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   270Ôćĺ\n   271Ôćĺ\texecutor := &Executor{\n   272Ôćĺ\t\tProjectDir: tmpDir,\n   273Ôćĺ\t\tDispatcher: dispatcher,\n   274Ôćĺ\t\tStore:      store,\n   275Ôćĺ\t\tOutputDir:  outputDir,\n   276Ôćĺ\t}\n   277Ôćĺ\n   278Ôćĺ\twf := &domain.Workflow{\n   279Ôćĺ\t\tName: \"main\",\n   280Ôćĺ\t\tSteps: map[string]*domain.Step{\n   281Ôćĺ\t\t\t\"prepare\": {\n   282Ôćĺ\t\t\t\tName:    \"prepare\",\n   283Ôćĺ\t\t\t\tType:    domain.StepTypeScript,\n   284Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n   285Ôćĺ\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n   286Ôćĺ\t\t\t},\n   287Ôćĺ\t\t\t\"develop\": {\n   288Ôćĺ\t\t\t\tName:    \"develop\",\n   289Ôćĺ\t\t\t\tType:    domain.StepTypeWorkflow,\n   290Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n   291Ôćĺ\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   292Ôćĺ\t\t\t},\n   293Ôćĺ\t\t\t\"merge\": {\n   294Ôćĺ\t\t\t\tName:    \"merge\",\n   295Ôćĺ\t\t\t\tType:    domain.StepTypeScript,\n   296Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n   297Ôćĺ\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n   298Ôćĺ\t\t\t},\n   299Ôćĺ\t\t},\n   300Ôćĺ\t\tWiring: []domain.Wire{\n   301Ôćĺ\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   302Ôćĺ\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   303Ôćĺ\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n   304Ôćĺ\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   305Ôćĺ\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n   306Ôćĺ\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n   307Ôćĺ\t\t},\n   308Ôćĺ\t\tEntryStep: \"prepare\",\n   309Ôćĺ\t}\n   310Ôćĺ\n   311Ôćĺ\teng := engine.New(executor)\n   312Ôćĺ\trun, err := eng.Run(context.Background(), wf)\n   313Ôćĺ\trequire.NoError(t, err)\n   314Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   315Ôćĺ\tassert.Len(t, dispatcher.calls, 1)\n   316Ôćĺ}\n   317Ôćĺ\n   318Ôćĺfunc TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n   319Ôćĺ\ttmpDir := t.TempDir()\n   320Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   321Ôćĺ\n   322Ôćĺ\texecutor := &Executor{\n   323Ôćĺ\t\tProjectDir: tmpDir,\n   324Ôćĺ\t\tOutputDir:  outputDir,\n   325Ôćĺ\t}\n   326Ôćĺ\n   327Ôćĺ\twf := &domain.Workflow{\n   328Ôćĺ\t\tName: \"main\",\n   329Ôćĺ\t\tSteps: map[string]*domain.Step{\n   330Ôćĺ\t\t\t\"prepare\": {\n   331Ôćĺ\t\t\t\tName:    \"prepare\",\n   332Ôćĺ\t\t\t\tType:    domain.StepTypeScript,\n   333Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n   334Ôćĺ\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   335Ôćĺ\t\t\t},\n   336Ôćĺ\t\t\t\"develop\": {\n   337Ôćĺ\t\t\t\tName:    \"develop\",\n   338Ôćĺ\t\t\t\tType:    domain.StepTypeWorkflow,\n   339Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n   340Ôćĺ\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   341Ôćĺ\t\t\t},\n   342Ôćĺ\t\t},\n   343Ôćĺ\t\tWiring: []domain.Wire{\n   344Ôćĺ\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   345Ôćĺ\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   346Ôćĺ\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n   347Ôćĺ\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   348Ôćĺ\t\t},\n   349Ôćĺ\t\tEntryStep: \"prepare\",\n   350Ôćĺ\t}\n   351Ôćĺ\n   352Ôćĺ\teng := engine.New(executor)\n   353Ôćĺ\trun, err := eng.Run(context.Background(), wf)\n   354Ôćĺ\trequire.NoError(t, err)\n   355Ôćĺ\tassert.Equal(t, domain.RunStateFailed, run.State)\n   356Ôćĺ}\n   357Ôćĺ\n   358Ôćĺfunc TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n   359Ôćĺ\ttmpDir := t.TempDir()\n   360Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   361Ôćĺ\n   362Ôćĺ\texecutor := &Executor{\n   363Ôćĺ\t\tProjectDir: tmpDir,\n   364Ôćĺ\t\tOutputDir:  outputDir,\n   365Ôćĺ\t}\n   366Ôćĺ\n   367Ôćĺ\tstep := &domain.Step{\n   368Ôćĺ\t\tName:    \"env-check\",\n   369Ôćĺ\t\tType:    domain.StepTypeScript,\n   370Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   371Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n   372Ôćĺ\t}\n   373Ôćĺ\n   374Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   375Ôćĺ\trequire.NoError(t, err)\n   376Ôćĺ\tassert.Equal(t, \"success\", result)\n   377Ôćĺ\n   378Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n   379Ôćĺ\trequire.NoError(t, err)\n   380Ôćĺ\tassert.Contains(t, string(data), tmpDir)\n   381Ôćĺ}\n   382Ôćĺ\n   383Ôćĺfunc TestExecutor_ScriptStep_NoOutputMappings(t *testing.T) {\n   384Ôćĺ\ttmpDir := t.TempDir()\n   385Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   386Ôćĺ\n   387Ôćĺ\texecutor := &Executor{\n   388Ôćĺ\t\tProjectDir: tmpDir,\n   389Ôćĺ\t\tOutputDir:  outputDir,\n   390Ôćĺ\t\tWires: []domain.Wire{\n   391Ôćĺ\t\t\t{From: \"step-a\", Result: \"success\", To: \"step-b\"},\n   392Ôćĺ\t\t},\n   393Ôćĺ\t}\n   394Ôćĺ\n   395Ôćĺ\tstep := &domain.Step{\n   396Ôćĺ\t\tName:    \"step-b\",\n   397Ôćĺ\t\tType:    domain.StepTypeScript,\n   398Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   399Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   400Ôćĺ\t}\n   401Ôćĺ\n   402Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   403Ôćĺ\trequire.NoError(t, err)\n   404Ôćĺ\tassert.Equal(t, \"success\", result)\n   405Ôćĺ}\n   406Ôćĺ\n   407Ôćĺfunc TestExecutor_ScriptStep_OutputMappings_JSONFields(t *testing.T) {\n   408Ôćĺ\ttmpDir := t.TempDir()\n   409Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   410Ôćĺ\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   411Ôćĺ\n   412Ôćĺ\t// Write source step output as JSON\n   413Ôćĺ\tsourceJSON := `{\"title\": \"Fix bug\", \"priority\": \"high\"}`\n   414Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"get-tasks.out\"), []byte(sourceJSON), 0644))\n   415Ôćĺ\n   416Ôćĺ\texecutor := &Executor{\n   417Ôćĺ\t\tProjectDir: tmpDir,\n   418Ôćĺ\t\tOutputDir:  outputDir,\n   419Ôćĺ\t\tWires: []domain.Wire{\n   420Ôćĺ\t\t\t{\n   421Ôćĺ\t\t\t\tFrom:   \"get-tasks\",\n   422Ôćĺ\t\t\t\tResult: \"success\",\n   423Ôćĺ\t\t\t\tTo:     \"use-tasks\",\n   424Ôćĺ\t\t\t\tOutputMap: []domain.OutputMapping{\n   425Ôćĺ\t\t\t\t\t{\n   426Ôćĺ\t\t\t\t\t\tEnvVar: \"TASK_TITLE\",\n   427Ôćĺ\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"title\"}}},\n   428Ôćĺ\t\t\t\t\t},\n   429Ôćĺ\t\t\t\t\t{\n   430Ôćĺ\t\t\t\t\t\tEnvVar: \"TASK_PRIORITY\",\n   431Ôćĺ\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"priority\"}}},\n   432Ôćĺ\t\t\t\t\t},\n   433Ôćĺ\t\t\t\t},\n   434Ôćĺ\t\t\t},\n   435Ôćĺ\t\t},\n   436Ôćĺ\t}\n   437Ôćĺ\n   438Ôćĺ\tstep := &domain.Step{\n   439Ôćĺ\t\tName:    \"use-tasks\",\n   440Ôćĺ\t\tType:    domain.StepTypeScript,\n   441Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   442Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo $TASK_TITLE $TASK_PRIORITY\"},\n   443Ôćĺ\t}\n   444Ôćĺ\n   445Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   446Ôćĺ\trequire.NoError(t, err)\n   447Ôćĺ\tassert.Equal(t, \"success\", result)\n   448Ôćĺ\n   449Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"use-tasks.out\"))\n   450Ôćĺ\trequire.NoError(t, err)\n   451Ôćĺ\tassert.Contains(t, string(data), \"Fix bug\")\n   452Ôćĺ\tassert.Contains(t, string(data), \"high\")\n   453Ôćĺ}\n   454Ôćĺ\n   455Ôćĺfunc TestExecutor_ScriptStep_OutputMappings_ArrayIndex(t *testing.T) {\n   456Ôćĺ\ttmpDir := t.TempDir()\n   457Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   458Ôćĺ\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   459Ôćĺ\n   460Ôćĺ\t// Write source step output as JSON array\n   461Ôćĺ\tsourceJSON := `[{\"id\": \"task-1\", \"title\": \"First\"}, {\"id\": \"task-2\", \"title\": \"Second\"}]`\n   462Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"list-tasks.out\"), []byte(sourceJSON), 0644))\n   463Ôćĺ\n   464Ôćĺ\texecutor := &Executor{\n   465Ôćĺ\t\tProjectDir: tmpDir,\n   466Ôćĺ\t\tOutputDir:  outputDir,\n   467Ôćĺ\t\tWires: []domain.Wire{\n   468Ôćĺ\t\t\t{\n   469Ôćĺ\t\t\t\tFrom:   \"list-tasks\",\n   470Ôćĺ\t\t\t\tResult: \"success\",\n   471Ôćĺ\t\t\t\tTo:     \"process\",\n   472Ôćĺ\t\t\t\tOutputMap: []domain.OutputMapping{\n   473Ôćĺ\t\t\t\t\t{\n   474Ôćĺ\t\t\t\t\t\tEnvVar: \"FIRST_ID\",\n   475Ôćĺ\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n   476Ôćĺ\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 0},\n   477Ôćĺ\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"id\"},\n   478Ôćĺ\t\t\t\t\t\t}},\n   479Ôćĺ\t\t\t\t\t},\n   480Ôćĺ\t\t\t\t\t{\n   481Ôćĺ\t\t\t\t\t\tEnvVar: \"SECOND_TITLE\",\n   482Ôćĺ\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n   483Ôćĺ\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 1},\n   484Ôćĺ\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"title\"},\n   485Ôćĺ\t\t\t\t\t\t}},\n   486Ôćĺ\t\t\t\t\t},\n   487Ôćĺ\t\t\t\t},\n   488Ôćĺ\t\t\t},\n   489Ôćĺ\t\t},\n   490Ôćĺ\t}\n   491Ôćĺ\n   492Ôćĺ\tstep := &domain.Step{\n   493Ôćĺ\t\tName:    \"process\",\n   494Ôćĺ\t\tType:    domain.StepTypeScript,\n   495Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   496Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo $FIRST_ID $SECOND_TITLE\"},\n   497Ôćĺ\t}\n   498Ôćĺ\n   499Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   500Ôćĺ\trequire.NoError(t, err)\n   501Ôćĺ\tassert.Equal(t, \"success\", result)\n   502Ôćĺ\n   503Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"process.out\"))\n   504Ôćĺ\trequire.NoError(t, err)\n   505Ôćĺ\tassert.Contains(t, string(data), \"task-1\")\n   506Ôćĺ\tassert.Contains(t, string(data), \"Second\")\n   507Ôćĺ}\n   508Ôćĺ\n   509Ôćĺfunc TestExecutor_ScriptStep_OutputMappings_MissingSourceOutput(t *testing.T) {\n   510Ôćĺ\ttmpDir := t.TempDir()\n   511Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   512Ôćĺ\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   513Ôćĺ\n   514Ôćĺ\t// No source output file written\n   515Ôćĺ\n   516Ôćĺ\texecutor := &Executor{\n   517Ôćĺ\t\tProjectDir: tmpDir,\n   518Ôćĺ\t\tOutputDir:  outputDir,\n   519Ôćĺ\t\tWires: []domain.Wire{\n   520Ôćĺ\t\t\t{\n   521Ôćĺ\t\t\t\tFrom:   \"missing-step\",\n   522Ôćĺ\t\t\t\tResult: \"success\",\n   523Ôćĺ\t\t\t\tTo:     \"consumer\",\n   524Ôćĺ\t\t\t\tOutputMap: []domain.OutputMapping{\n   525Ôćĺ\t\t\t\t\t{\n   526Ôćĺ\t\t\t\t\t\tEnvVar: \"VAL\",\n   527Ôćĺ\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n   528Ôćĺ\t\t\t\t\t},\n   529Ôćĺ\t\t\t\t},\n   530Ôćĺ\t\t\t},\n   531Ôćĺ\t\t},\n   532Ôćĺ\t}\n   533Ôćĺ\n   534Ôćĺ\tstep := &domain.Step{\n   535Ôćĺ\t\tName:    \"consumer\",\n   536Ôćĺ\t\tType:    domain.StepTypeScript,\n   537Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   538Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   539Ôćĺ\t}\n   540Ôćĺ\n   541Ôćĺ\t_, err := executor.Execute(context.Background(), step)\n   542Ôćĺ\trequire.Error(t, err)\n   543Ôćĺ\tassert.Contains(t, err.Error(), \"reading output of missing-step\")\n   544Ôćĺ}\n   545Ôćĺ\n   546Ôćĺfunc TestExecutor_ScriptStep_OutputMappings_NotJSON(t *testing.T) {\n   547Ôćĺ\ttmpDir := t.TempDir()\n   548Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   549Ôćĺ\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   550Ôćĺ\n   551Ôćĺ\t// Write non-JSON output\n   552Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"plain.out\"), []byte(\"not json\"), 0644))\n   553Ôćĺ\n   554Ôćĺ\texecutor := &Executor{\n   555Ôćĺ\t\tProjectDir: tmpDir,\n   556Ôćĺ\t\tOutputDir:  outputDir,\n   557Ôćĺ\t\tWires: []domain.Wire{\n   558Ôćĺ\t\t\t{\n   559Ôćĺ\t\t\t\tFrom:   \"plain\",\n   560Ôćĺ\t\t\t\tResult: \"success\",\n   561Ôćĺ\t\t\t\tTo:     \"consumer\",\n   562Ôćĺ\t\t\t\tOutputMap: []domain.OutputMapping{\n   563Ôćĺ\t\t\t\t\t{\n   564Ôćĺ\t\t\t\t\t\tEnvVar: \"VAL\",\n   565Ôćĺ\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n   566Ôćĺ\t\t\t\t\t},\n   567Ôćĺ\t\t\t\t},\n   568Ôćĺ\t\t\t},\n   569Ôćĺ\t\t},\n   570Ôćĺ\t}\n   571Ôćĺ\n   572Ôćĺ\tstep := &domain.Step{\n   573Ôćĺ\t\tName:    \"consumer\",\n   574Ôćĺ\t\tType:    domain.StepTypeScript,\n   575Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   576Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   577Ôćĺ\t}\n   578Ôćĺ\n   579Ôćĺ\t_, err := executor.Execute(context.Background(), step)\n   580Ôćĺ\trequire.Error(t, err)\n   581Ôćĺ\tassert.Contains(t, err.Error(), \"not valid JSON\")\n   582Ôćĺ}\n   583Ôćĺ\n   584Ôćĺfunc TestRunner_RunWithID(t *testing.T) {\n   585Ôćĺ\ttmpDir := t.TempDir()\n   586Ôćĺ\n   587Ôćĺ\t// Write a simple host.cloche\n   588Ôćĺ\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   589Ôćĺ\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   590Ôćĺ\thostCloche := `workflow \"main\" {\n   591Ôćĺ  step greet {\n   592Ôćĺ    run     = \"echo hi\"\n   593Ôćĺ    results = [success, fail]\n   594Ôćĺ  }\n   595Ôćĺ\n   596Ôćĺ  greet:success -> done\n   597Ôćĺ  greet:fail    -> abort\n   598Ôćĺ}`\n   599Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   600Ôćĺ\n   601Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   602Ôćĺ\n   603Ôćĺ\trunner := &Runner{\n   604Ôćĺ\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   605Ôćĺ\t\tStore:      store,\n   606Ôćĺ\t}\n   607Ôćĺ\n   608Ôćĺ\tcustomID := \"my-custom-run-id\"\n   609Ôćĺ\tresult, err := runner.RunWithID(context.Background(), tmpDir, customID)\n   610Ôćĺ\trequire.NoError(t, err)\n   611Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n   612Ôćĺ\tassert.Equal(t, customID, result.RunID, \"RunWithID should use the provided ID\")\n   613Ôćĺ\n   614Ôćĺ\t// Verify the run was persisted with the custom ID\n   615Ôćĺ\thostRun, err := store.GetRun(context.Background(), customID)\n   616Ôćĺ\trequire.NoError(t, err)\n   617Ôćĺ\tassert.True(t, hostRun.IsHost)\n   618Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n   619Ôćĺ}\n   620Ôćĺ\n   621Ôćĺfunc TestRunner_PersistsHostRun(t *testing.T) {\n   622Ôćĺ\ttmpDir := t.TempDir()\n   623Ôćĺ\n   624Ôćĺ\t// Write a simple host.cloche\n   625Ôćĺ\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   626Ôćĺ\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   627Ôćĺ\thostCloche := `workflow \"main\" {\n   628Ôćĺ  step prepare {\n   629Ôćĺ    run     = \"echo prepared\"\n   630Ôćĺ    results = [success, fail]\n   631Ôćĺ  }\n   632Ôćĺ\n   633Ôćĺ  prepare:success -> done\n   634Ôćĺ  prepare:fail    -> abort\n   635Ôćĺ}`\n   636Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   637Ôćĺ\n   638Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   639Ôćĺ\n   640Ôćĺ\trunner := &Runner{\n   641Ôćĺ\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   642Ôćĺ\t\tStore:      store,\n   643Ôćĺ\t}\n   644Ôćĺ\n   645Ôćĺ\tresult, err := runner.Run(context.Background(), tmpDir)\n   646Ôćĺ\trequire.NoError(t, err)\n   647Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n   648Ôćĺ\tassert.NotEmpty(t, result.RunID)\n   649Ôćĺ\n   650Ôćĺ\t// Verify the host run was persisted in the store\n   651Ôćĺ\thostRun, err := store.GetRun(context.Background(), result.RunID)\n   652Ôćĺ\trequire.NoError(t, err)\n   653Ôćĺ\tassert.True(t, hostRun.IsHost, \"host run should have IsHost=true\")\n   654Ôćĺ\tassert.Equal(t, tmpDir, hostRun.ProjectDir)\n   655Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n   656Ôćĺ\tassert.False(t, hostRun.StartedAt.IsZero())\n   657Ôćĺ\tassert.False(t, hostRun.CompletedAt.IsZero())\n   658Ôćĺ}\n   659Ôćĺ\n   660Ôćĺfunc TestExecutor_ScriptStep_UsesMainDir(t *testing.T) {\n   661Ôćĺ\t// ProjectDir has no script; MainDir has the script.\n   662Ôćĺ\tprojectDir := t.TempDir()\n   663Ôćĺ\tmainDir := t.TempDir()\n   664Ôćĺ\toutputDir := filepath.Join(projectDir, \"output\")\n   665Ôćĺ\n   666Ôćĺ\t// Create a script only in mainDir\n   667Ôćĺ\tscriptDir := filepath.Join(mainDir, \".cloche\", \"scripts\")\n   668Ôćĺ\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n   669Ôćĺ\trequire.NoError(t, os.WriteFile(\n   670Ôćĺ\t\tfilepath.Join(scriptDir, \"greet.sh\"),\n   671Ôćĺ\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n   672Ôćĺ\t\t0755,\n   673Ôćĺ\t))\n   674Ôćĺ\n   675Ôćĺ\texecutor := &Executor{\n   676Ôćĺ\t\tProjectDir: projectDir,\n   677Ôćĺ\t\tMainDir:    mainDir,\n   678Ôćĺ\t\tOutputDir:  outputDir,\n   679Ôćĺ\t}\n   680Ôćĺ\n   681Ôćĺ\tstep := &domain.Step{\n   682Ôćĺ\t\tName:    \"greet\",\n   683Ôćĺ\t\tType:    domain.StepTypeScript,\n   684Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   685Ôćĺ\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/greet.sh\"},\n   686Ôćĺ\t}\n   687Ôćĺ\n   688Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   689Ôćĺ\trequire.NoError(t, err)\n   690Ôćĺ\tassert.Equal(t, \"success\", result)\n   691Ôćĺ\n   692Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n   693Ôćĺ\trequire.NoError(t, err)\n   694Ôćĺ\tassert.Contains(t, string(data), \"from-main\")\n   695Ôćĺ}\n   696Ôćĺ\n   697Ôćĺfunc TestExecutor_ScriptStep_MainDirOverridesProjectDir(t *testing.T) {\n   698Ôćĺ\t// Both dirs have a script with different content; MainDir's version wins.\n   699Ôćĺ\tprojectDir := t.TempDir()\n   700Ôćĺ\tmainDir := t.TempDir()\n   701Ôćĺ\toutputDir := filepath.Join(projectDir, \"output\")\n   702Ôćĺ\n   703Ôćĺ\t// Create script in both dirs with different content\n   704Ôćĺ\tfor _, dir := range []string{projectDir, mainDir} {\n   705Ôćĺ\t\tscriptDir := filepath.Join(dir, \".cloche\", \"scripts\")\n   706Ôćĺ\t\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n   707Ôćĺ\t}\n   708Ôćĺ\trequire.NoError(t, os.WriteFile(\n   709Ôćĺ\t\tfilepath.Join(projectDir, \".cloche\", \"scripts\", \"hello.sh\"),\n   710Ôćĺ\t\t[]byte(\"#!/bin/sh\\necho from-branch\"),\n   711Ôćĺ\t\t0755,\n   712Ôćĺ\t))\n   713Ôćĺ\trequire.NoError(t, os.WriteFile(\n   714Ôćĺ\t\tfilepath.Join(mainDir, \".cloche\", \"scripts\", \"hello.sh\"),\n   715Ôćĺ\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n   716Ôćĺ\t\t0755,\n   717Ôćĺ\t))\n   718Ôćĺ\n   719Ôćĺ\texecutor := &Executor{\n   720Ôćĺ\t\tProjectDir: projectDir,\n   721Ôćĺ\t\tMainDir:    mainDir,\n   722Ôćĺ\t\tOutputDir:  outputDir,\n   723Ôćĺ\t}\n   724Ôćĺ\n   725Ôćĺ\tstep := &domain.Step{\n   726Ôćĺ\t\tName:    \"hello\",\n   727Ôćĺ\t\tType:    domain.StepTypeScript,\n   728Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   729Ôćĺ\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/hello.sh\"},\n   730Ôćĺ\t}\n   731Ôćĺ\n   732Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   733Ôćĺ\trequire.NoError(t, err)\n   734Ôćĺ\tassert.Equal(t, \"success\", result)\n   735Ôćĺ\n   736Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"hello.out\"))\n   737Ôćĺ\trequire.NoError(t, err)\n   738Ôćĺ\tassert.Contains(t, string(data), \"from-main\")\n   739Ôćĺ\tassert.NotContains(t, string(data), \"from-branch\")\n   740Ôćĺ}\n   741Ôćĺ\n   742Ôćĺfunc TestExecutor_ScriptStep_FallsBackToProjectDir(t *testing.T) {\n   743Ôćĺ\t// When MainDir is empty, scripts resolve from ProjectDir.\n   744Ôćĺ\tprojectDir := t.TempDir()\n   745Ôćĺ\toutputDir := filepath.Join(projectDir, \"output\")\n   746Ôćĺ\n   747Ôćĺ\texecutor := &Executor{\n   748Ôćĺ\t\tProjectDir: projectDir,\n   749Ôćĺ\t\tOutputDir:  outputDir,\n   750Ôćĺ\t}\n   751Ôćĺ\n   752Ôćĺ\tstep := &domain.Step{\n   753Ôćĺ\t\tName:    \"pwd-check\",\n   754Ôćĺ\t\tType:    domain.StepTypeScript,\n   755Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   756Ôćĺ\t\tConfig:  map[string]string{\"run\": \"pwd\"},\n   757Ôćĺ\t}\n   758Ôćĺ\n   759Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   760Ôćĺ\trequire.NoError(t, err)\n   761Ôćĺ\tassert.Equal(t, \"success\", result)\n   762Ôćĺ\n   763Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"pwd-check.out\"))\n   764Ôćĺ\trequire.NoError(t, err)\n   765Ôćĺ\tassert.Contains(t, string(data), projectDir)\n   766Ôćĺ}\n   767Ôćĺ\n   768Ôćĺfunc TestExecutor_ScriptStep_ProjectDirEnvVar(t *testing.T) {\n   769Ôćĺ\t// CLOCHE_PROJECT_DIR should always point to ProjectDir, not MainDir.\n   770Ôćĺ\tprojectDir := t.TempDir()\n   771Ôćĺ\tmainDir := t.TempDir()\n   772Ôćĺ\toutputDir := filepath.Join(projectDir, \"output\")\n   773Ôćĺ\n   774Ôćĺ\texecutor := &Executor{\n   775Ôćĺ\t\tProjectDir: projectDir,\n   776Ôćĺ\t\tMainDir:    mainDir,\n   777Ôćĺ\t\tOutputDir:  outputDir,\n   778Ôćĺ\t}\n   779Ôćĺ\n   780Ôćĺ\tstep := &domain.Step{\n   781Ôćĺ\t\tName:    \"env-check\",\n   782Ôćĺ\t\tType:    domain.StepTypeScript,\n   783Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   784Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n   785Ôćĺ\t}\n   786Ôćĺ\n   787Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   788Ôćĺ\trequire.NoError(t, err)\n   789Ôćĺ\tassert.Equal(t, \"success\", result)\n   790Ôćĺ\n   791Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n   792Ôćĺ\trequire.NoError(t, err)\n   793Ôćĺ\tassert.Contains(t, string(data), projectDir)\n   794Ôćĺ\tassert.NotContains(t, string(data), mainDir)\n   795Ôćĺ}\n   796Ôćĺ\n   797Ôćĺfunc TestMainWorktreeDir_NonGitDir(t *testing.T) {\n   798Ôćĺ\ttmpDir := t.TempDir()\n   799Ôćĺ\t// Non-git directory should fall back to projectDir.\n   800Ôćĺ\tresult := MainWorktreeDir(tmpDir)\n   801Ôćĺ\tassert.Equal(t, tmpDir, result)\n   802Ôćĺ}\n   803Ôćĺ\n   804Ôćĺfunc TestMainWorktreeDir_WithWorktree(t *testing.T) {\n   805Ôćĺ\t// Set up a real git repo with a linked worktree.\n   806Ôćĺ\tmainDir := t.TempDir()\n   807Ôćĺ\n   808Ôćĺ\t// Initialize git repo\n   809Ôćĺ\trun := func(dir string, args ...string) {\n   810Ôćĺ\t\tt.Helper()\n   811Ôćĺ\t\tcmd := exec.Command(args[0], args[1:]...)\n   812Ôćĺ\t\tcmd.Dir = dir\n   813Ôćĺ\t\tout, err := cmd.CombinedOutput()\n   814Ôćĺ\t\trequire.NoError(t, err, \"command %v failed: %s\", args, out)\n   815Ôćĺ\t}\n   816Ôćĺ\n   817Ôćĺ\trun(mainDir, \"git\", \"init\")\n   818Ôćĺ\trun(mainDir, \"git\", \"config\", \"user.email\", \"test@test.com\")\n   819Ôćĺ\trun(mainDir, \"git\", \"config\", \"user.name\", \"Test\")\n   820Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(mainDir, \"file.txt\"), []byte(\"hello\"), 0644))\n   821Ôćĺ\trun(mainDir, \"git\", \"add\", \".\")\n   822Ôćĺ\trun(mainDir, \"git\", \"commit\", \"-m\", \"initial\")\n   823Ôćĺ\n   824Ôćĺ\t// Create a branch and worktree\n   825Ôćĺ\tworktreeDir := filepath.Join(t.TempDir(), \"wt\")\n   826Ôćĺ\trun(mainDir, \"git\", \"worktree\", \"add\", worktreeDir, \"-b\", \"feature\")\n   827Ôćĺ\n   828Ôćĺ\t// MainWorktreeDir from the linked worktree should return mainDir.\n   829Ôćĺ\tresult := MainWorktreeDir(worktreeDir)\n   830Ôćĺ\tassert.Equal(t, mainDir, result)\n   831Ôćĺ\n   832Ôćĺ\t// MainWorktreeDir from main should return mainDir.\n   833Ôćĺ\tresult = MainWorktreeDir(mainDir)\n   834Ôćĺ\tassert.Equal(t, mainDir, result)\n   835Ôćĺ}\n   836Ôćĺ\n   837Ôćĺfunc TestExecutor_AgentStep_Success(t *testing.T) {\n   838Ôćĺ\ttmpDir := t.TempDir()\n   839Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   840Ôćĺ\n   841Ôćĺ\t// Create a mock agent script that reads stdin and produces output\n   842Ôćĺ\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n   843Ôćĺ\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent did the work'\\n\"), 0755))\n   844Ôćĺ\n   845Ôćĺ\texecutor := &Executor{\n   846Ôćĺ\t\tProjectDir: tmpDir,\n   847Ôćĺ\t\tOutputDir:  outputDir,\n   848Ôćĺ\t\tHostRunID:  \"test-host-run\",\n   849Ôćĺ\t}\n   850Ôćĺ\n   851Ôćĺ\tstep := &domain.Step{\n   852Ôćĺ\t\tName:    \"implement\",\n   853Ôćĺ\t\tType:    domain.StepTypeAgent,\n   854Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   855Ôćĺ\t\tConfig: map[string]string{\n   856Ôćĺ\t\t\t\"prompt\":        \"You are a coding assistant.\",\n   857Ôćĺ\t\t\t\"agent_command\": mockAgent,\n   858Ôćĺ\t\t},\n   859Ôćĺ\t}\n   860Ôćĺ\n   861Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   862Ôćĺ\trequire.NoError(t, err)\n   863Ôćĺ\tassert.Equal(t, \"success\", result)\n   864Ôćĺ\n   865Ôćĺ\t// Check output was copied to executor's output path\n   866Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n   867Ôćĺ\trequire.NoError(t, err)\n   868Ôćĺ\tassert.Contains(t, string(data), \"agent did the work\")\n   869Ôćĺ}\n   870Ôćĺ\n   871Ôćĺfunc TestExecutor_AgentStep_Failure(t *testing.T) {\n   872Ôćĺ\ttmpDir := t.TempDir()\n   873Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   874Ôćĺ\n   875Ôćĺ\t// Create a mock agent that reports failure via result marker\n   876Ôćĺ\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n   877Ôćĺ\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'something went wrong'\\necho 'CLOCHE_RESULT:fail'\\n\"), 0755))\n   878Ôćĺ\n   879Ôćĺ\texecutor := &Executor{\n   880Ôćĺ\t\tProjectDir: tmpDir,\n   881Ôćĺ\t\tOutputDir:  outputDir,\n   882Ôćĺ\t\tHostRunID:  \"test-host-run\",\n   883Ôćĺ\t}\n   884Ôćĺ\n   885Ôćĺ\tstep := &domain.Step{\n   886Ôćĺ\t\tName:    \"implement\",\n   887Ôćĺ\t\tType:    domain.StepTypeAgent,\n   888Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   889Ôćĺ\t\tConfig: map[string]string{\n   890Ôćĺ\t\t\t\"prompt\":        \"You are a coding assistant.\",\n   891Ôćĺ\t\t\t\"agent_command\": mockAgent,\n   892Ôćĺ\t\t},\n   893Ôćĺ\t}\n   894Ôćĺ\n   895Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   896Ôćĺ\trequire.NoError(t, err)\n   897Ôćĺ\tassert.Equal(t, \"fail\", result)\n   898Ôćĺ}\n   899Ôćĺ\n   900Ôćĺfunc TestExecutor_AgentStep_WorkflowLevelCommand(t *testing.T) {\n   901Ôćĺ\ttmpDir := t.TempDir()\n   902Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   903Ôćĺ\n   904Ôćĺ\t// Create a mock agent\n   905Ôćĺ\tmockAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n   906Ôćĺ\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow agent ran'\\n\"), 0755))\n   907Ôćĺ\n   908Ôćĺ\texecutor := &Executor{\n   909Ôćĺ\t\tProjectDir:    tmpDir,\n   910Ôćĺ\t\tOutputDir:     outputDir,\n   911Ôćĺ\t\tHostRunID:     \"test-host-run\",\n   912Ôćĺ\t\tAgentCommands: []string{mockAgent},\n   913Ôćĺ\t}\n   914Ôćĺ\n   915Ôćĺ\tstep := &domain.Step{\n   916Ôćĺ\t\tName:    \"implement\",\n   917Ôćĺ\t\tType:    domain.StepTypeAgent,\n   918Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   919Ôćĺ\t\tConfig: map[string]string{\n   920Ôćĺ\t\t\t\"prompt\": \"Write some code.\",\n   921Ôćĺ\t\t},\n   922Ôćĺ\t}\n   923Ôćĺ\n   924Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   925Ôćĺ\trequire.NoError(t, err)\n   926Ôćĺ\tassert.Equal(t, \"success\", result)\n   927Ôćĺ\n   928Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n   929Ôćĺ\trequire.NoError(t, err)\n   930Ôćĺ\tassert.Contains(t, string(data), \"workflow agent ran\")\n   931Ôćĺ}\n   932Ôćĺ\n   933Ôćĺfunc TestExecutor_AgentStep_StepLevelOverridesWorkflow(t *testing.T) {\n   934Ôćĺ\ttmpDir := t.TempDir()\n   935Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   936Ôćĺ\n   937Ôćĺ\t// Create two mock agents\n   938Ôćĺ\tworkflowAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n   939Ôćĺ\trequire.NoError(t, os.WriteFile(workflowAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow agent'\\n\"), 0755))\n   940Ôćĺ\n   941Ôćĺ\tstepAgent := filepath.Join(tmpDir, \"step-agent.sh\")\n   942Ôćĺ\trequire.NoError(t, os.WriteFile(stepAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'step agent'\\n\"), 0755))\n   943Ôćĺ\n   944Ôćĺ\texecutor := &Executor{\n   945Ôćĺ\t\tProjectDir:    tmpDir,\n   946Ôćĺ\t\tOutputDir:     outputDir,\n   947Ôćĺ\t\tHostRunID:     \"test-host-run\",\n   948Ôćĺ\t\tAgentCommands: []string{workflowAgent},\n   949Ôćĺ\t}\n   950Ôćĺ\n   951Ôćĺ\tstep := &domain.Step{\n   952Ôćĺ\t\tName:    \"implement\",\n   953Ôćĺ\t\tType:    domain.StepTypeAgent,\n   954Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   955Ôćĺ\t\tConfig: map[string]string{\n   956Ôćĺ\t\t\t\"prompt\":        \"Write some code.\",\n   957Ôćĺ\t\t\t\"agent_command\": stepAgent,\n   958Ôćĺ\t\t},\n   959Ôćĺ\t}\n   960Ôćĺ\n   961Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   962Ôćĺ\trequire.NoError(t, err)\n   963Ôćĺ\tassert.Equal(t, \"success\", result)\n   964Ôćĺ\n   965Ôćĺ\t// Step-level agent should have run, not workflow-level\n   966Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n   967Ôćĺ\trequire.NoError(t, err)\n   968Ôćĺ\tassert.Contains(t, string(data), \"step agent\")\n   969Ôćĺ\tassert.NotContains(t, string(data), \"workflow agent\")\n   970Ôćĺ}\n   971Ôćĺ\n   972Ôćĺfunc TestExecutor_AgentStep_FallbackChain(t *testing.T) {\n   973Ôćĺ\ttmpDir := t.TempDir()\n   974Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   975Ôćĺ\n   976Ôćĺ\t// Create a good agent\n   977Ôćĺ\tgoodAgent := filepath.Join(tmpDir, \"good-agent.sh\")\n   978Ôćĺ\trequire.NoError(t, os.WriteFile(goodAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'fallback agent ran'\\n\"), 0755))\n   979Ôćĺ\n   980Ôćĺ\texecutor := &Executor{\n   981Ôćĺ\t\tProjectDir: tmpDir,\n   982Ôćĺ\t\tOutputDir:  outputDir,\n   983Ôćĺ\t\tHostRunID:  \"test-host-run\",\n   984Ôćĺ\t}\n   985Ôćĺ\n   986Ôćĺ\t// Use nonexistent command as primary, good agent as fallback\n   987Ôćĺ\tstep := &domain.Step{\n   988Ôćĺ\t\tName:    \"implement\",\n   989Ôćĺ\t\tType:    domain.StepTypeAgent,\n   990Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   991Ôćĺ\t\tConfig: map[string]string{\n   992Ôćĺ\t\t\t\"prompt\":        \"Write some code.\",\n   993Ôćĺ\t\t\t\"agent_command\": \"nonexistent-agent-xyz,\" + goodAgent,\n   994Ôćĺ\t\t},\n   995Ôćĺ\t}\n   996Ôćĺ\n   997Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   998Ôćĺ\trequire.NoError(t, err)\n   999Ôćĺ\tassert.Equal(t, \"success\", result)\n  1000Ôćĺ\n  1001Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n  1002Ôćĺ\trequire.NoError(t, err)\n  1003Ôćĺ\tassert.Contains(t, string(data), \"fallback agent ran\")\n  1004Ôćĺ}\n  1005Ôćĺ\n  1006Ôćĺfunc TestExecutor_AgentStep_PrevOutput(t *testing.T) {\n  1007Ôćĺ\ttmpDir := t.TempDir()\n  1008Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n  1009Ôćĺ\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n  1010Ôćĺ\n  1011Ôćĺ\t// Write previous step output\n  1012Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"prepare.out\"), []byte(\"the task description\"), 0644))\n  1013Ôćĺ\n  1014Ôćĺ\t// Create a mock agent that echoes stdin (the prompt) to verify it received it\n  1015Ôćĺ\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1016Ôćĺ\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'processed prompt'\\n\"), 0755))\n  1017Ôćĺ\n  1018Ôćĺ\texecutor := &Executor{\n  1019Ôćĺ\t\tProjectDir: tmpDir,\n  1020Ôćĺ\t\tOutputDir:  outputDir,\n  1021Ôćĺ\t\tHostRunID:  \"test-host-run\",\n  1022Ôćĺ\t\tWires: []domain.Wire{\n  1023Ôćĺ\t\t\t{From: \"prepare\", Result: \"success\", To: \"implement\"},\n  1024Ôćĺ\t\t},\n  1025Ôćĺ\t}\n  1026Ôćĺ\n  1027Ôćĺ\tstep := &domain.Step{\n  1028Ôćĺ\t\tName:    \"implement\",\n  1029Ôćĺ\t\tType:    domain.StepTypeAgent,\n  1030Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n  1031Ôćĺ\t\tConfig: map[string]string{\n  1032Ôćĺ\t\t\t\"prompt\":        \"You are a coding assistant.\",\n  1033Ôćĺ\t\t\t\"agent_command\": mockAgent,\n  1034Ôćĺ\t\t},\n  1035Ôćĺ\t}\n  1036Ôćĺ\n  1037Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n  1038Ôćĺ\trequire.NoError(t, err)\n  1039Ôćĺ\tassert.Equal(t, \"success\", result)\n  1040Ôćĺ\n  1041Ôćĺ\t// Verify prompt.txt was written with previous step's output\n  1042Ôćĺ\tpromptPath := filepath.Join(tmpDir, \".cloche\", \"test-host-run\", \"prompt.txt\")\n  1043Ôćĺ\tdata, err := os.ReadFile(promptPath)\n  1044Ôćĺ\trequire.NoError(t, err)\n  1045Ôćĺ\tassert.Equal(t, \"the task description\", string(data))\n  1046Ôćĺ}\n  1047Ôćĺ\n  1048Ôćĺfunc TestExecutor_AgentStep_PromptStep(t *testing.T) {\n  1049Ôćĺ\ttmpDir := t.TempDir()\n  1050Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n  1051Ôćĺ\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n  1052Ôćĺ\n  1053Ôćĺ\t// Write a specific step's output\n  1054Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"custom-source.out\"), []byte(\"custom prompt content\"), 0644))\n  1055Ôćĺ\n  1056Ôćĺ\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1057Ôćĺ\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'done'\\n\"), 0755))\n  1058Ôćĺ\n  1059Ôćĺ\texecutor := &Executor{\n  1060Ôćĺ\t\tProjectDir: tmpDir,\n  1061Ôćĺ\t\tOutputDir:  outputDir,\n  1062Ôćĺ\t\tHostRunID:  \"test-host-run\",\n  1063Ôćĺ\t}\n  1064Ôćĺ\n  1065Ôćĺ\tstep := &domain.Step{\n  1066Ôćĺ\t\tName:    \"implement\",\n  1067Ôćĺ\t\tType:    domain.StepTypeAgent,\n  1068Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n  1069Ôćĺ\t\tConfig: map[string]string{\n  1070Ôćĺ\t\t\t\"prompt\":        \"You are a coding assistant.\",\n  1071Ôćĺ\t\t\t\"agent_command\": mockAgent,\n  1072Ôćĺ\t\t\t\"prompt_step\":   \"custom-source\",\n  1073Ôćĺ\t\t},\n  1074Ôćĺ\t}\n  1075Ôćĺ\n  1076Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n  1077Ôćĺ\trequire.NoError(t, err)\n  1078Ôćĺ\tassert.Equal(t, \"success\", result)\n  1079Ôćĺ\n  1080Ôćĺ\t// Verify prompt.txt was written with the prompt_step output\n  1081Ôćĺ\tpromptPath := filepath.Join(tmpDir, \".cloche\", \"test-host-run\", \"prompt.txt\")\n  1082Ôćĺ\tdata, err := os.ReadFile(promptPath)\n  1083Ôćĺ\trequire.NoError(t, err)\n  1084Ôćĺ\tassert.Equal(t, \"custom prompt content\", string(data))\n  1085Ôćĺ}\n  1086Ôćĺ\n  1087Ôćĺfunc TestEngine_HostWorkflow_WithAgentStep(t *testing.T) {\n  1088Ôćĺ\ttmpDir := t.TempDir()\n  1089Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n  1090Ôćĺ\n  1091Ôćĺ\t// Create a mock agent\n  1092Ôćĺ\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1093Ôćĺ\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent output'\\n\"), 0755))\n  1094Ôćĺ\n  1095Ôćĺ\texecutor := &Executor{\n  1096Ôćĺ\t\tProjectDir: tmpDir,\n  1097Ôćĺ\t\tOutputDir:  outputDir,\n  1098Ôćĺ\t\tHostRunID:  \"test-host-run\",\n  1099Ôćĺ\t}\n  1100Ôćĺ\n  1101Ôćĺ\twf := &domain.Workflow{\n  1102Ôćĺ\t\tName: \"main\",\n  1103Ôćĺ\t\tSteps: map[string]*domain.Step{\n  1104Ôćĺ\t\t\t\"prepare\": {\n  1105Ôćĺ\t\t\t\tName:    \"prepare\",\n  1106Ôćĺ\t\t\t\tType:    domain.StepTypeScript,\n  1107Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n  1108Ôćĺ\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'task prompt'\"},\n  1109Ôćĺ\t\t\t},\n  1110Ôćĺ\t\t\t\"implement\": {\n  1111Ôćĺ\t\t\t\tName:    \"implement\",\n  1112Ôćĺ\t\t\t\tType:    domain.StepTypeAgent,\n  1113Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n  1114Ôćĺ\t\t\t\tConfig: map[string]string{\n  1115Ôćĺ\t\t\t\t\t\"prompt\":        \"You are a coding assistant.\",\n  1116Ôćĺ\t\t\t\t\t\"agent_command\": mockAgent,\n  1117Ôćĺ\t\t\t\t},\n  1118Ôćĺ\t\t\t},\n  1119Ôćĺ\t\t\t\"verify\": {\n  1120Ôćĺ\t\t\t\tName:    \"verify\",\n  1121Ôćĺ\t\t\t\tType:    domain.StepTypeScript,\n  1122Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n  1123Ôćĺ\t\t\t\tConfig:  map[string]string{\"run\": \"echo verified\"},\n  1124Ôćĺ\t\t\t},\n  1125Ôćĺ\t\t},\n  1126Ôćĺ\t\tWiring: []domain.Wire{\n  1127Ôćĺ\t\t\t{From: \"prepare\", Result: \"success\", To: \"implement\"},\n  1128Ôćĺ\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n  1129Ôćĺ\t\t\t{From: \"implement\", Result: \"success\", To: \"verify\"},\n  1130Ôćĺ\t\t\t{From: \"implement\", Result: \"fail\", To: domain.StepAbort},\n  1131Ôćĺ\t\t\t{From: \"verify\", Result: \"success\", To: domain.StepDone},\n  1132Ôćĺ\t\t\t{From: \"verify\", Result: \"fail\", To: domain.StepAbort},\n  1133Ôćĺ\t\t},\n  1134Ôćĺ\t\tEntryStep: \"prepare\",\n  1135Ôćĺ\t}\n  1136Ôćĺ\n  1137Ôćĺ\teng := engine.New(executor)\n  1138Ôćĺ\trun, err := eng.Run(context.Background(), wf)\n  1139Ôćĺ\trequire.NoError(t, err)\n  1140Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n  1141Ôćĺ}\n  1142Ôćĺ\n  1143Ôćĺfunc TestRunner_HostWorkflow_AgentStep(t *testing.T) {\n  1144Ôćĺ\ttmpDir := t.TempDir()\n  1145Ôćĺ\n  1146Ôćĺ\t// Create a mock agent\n  1147Ôćĺ\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1148Ôćĺ\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent implemented'\\n\"), 0755))\n  1149Ôćĺ\n  1150Ôćĺ\t// Write a host.cloche with an agent step\n  1151Ôćĺ\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n  1152Ôćĺ\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n  1153Ôćĺ\thostCloche := `workflow \"main\" {\n  1154Ôćĺ  host {\n  1155Ôćĺ    agent_command = \"` + mockAgent + `\"\n  1156Ôćĺ  }\n  1157Ôćĺ\n  1158Ôćĺ  step implement {\n  1159Ôćĺ    prompt = \"Implement the feature.\"\n  1160Ôćĺ    results = [success, fail]\n  1161Ôćĺ  }\n  1162Ôćĺ\n  1163Ôćĺ  implement:success -> done\n  1164Ôćĺ  implement:fail    -> abort\n  1165Ôćĺ}`\n  1166Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n  1167Ôćĺ\n  1168Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n  1169Ôćĺ\n  1170Ôćĺ\trunner := &Runner{\n  1171Ôćĺ\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n  1172Ôćĺ\t\tStore:      store,\n  1173Ôćĺ\t}\n  1174Ôćĺ\n  1175Ôćĺ\tresult, err := runner.Run(context.Background(), tmpDir)\n  1176Ôćĺ\trequire.NoError(t, err)\n  1177Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n  1178Ôćĺ\n  1179Ôćĺ\t// Verify the run completed\n  1180Ôćĺ\thostRun, err := store.GetRun(context.Background(), result.RunID)\n  1181Ôćĺ\trequire.NoError(t, err)\n  1182Ôćĺ\tassert.True(t, hostRun.IsHost)\n  1183Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n  1184Ôćĺ}\n  1185Ôćĺ\n  1186Ôćĺfunc TestRunner_HostWorkflow_AgentStepOverridesWorkflowCommand(t *testing.T) {\n  1187Ôćĺ\ttmpDir := t.TempDir()\n  1188Ôćĺ\n  1189Ôćĺ\t// Create two mock agents\n  1190Ôćĺ\tworkflowAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n  1191Ôćĺ\trequire.NoError(t, os.WriteFile(workflowAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow level'\\n\"), 0755))\n  1192Ôćĺ\n  1193Ôćĺ\tstepAgent := filepath.Join(tmpDir, \"step-agent.sh\")\n  1194Ôćĺ\trequire.NoError(t, os.WriteFile(stepAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'step level'\\n\"), 0755))\n  1195Ôćĺ\n  1196Ôćĺ\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n  1197Ôćĺ\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n  1198Ôćĺ\thostCloche := `workflow \"main\" {\n  1199Ôćĺ  host {\n  1200Ôćĺ    agent_command = \"` + workflowAgent + `\"\n  1201Ôćĺ  }\n  1202Ôćĺ\n  1203Ôćĺ  step implement {\n  1204Ôćĺ    agent_command = \"` + stepAgent + `\"\n  1205Ôćĺ    prompt = \"Implement the feature.\"\n  1206Ôćĺ    results = [success, fail]\n  1207Ôćĺ  }\n  1208Ôćĺ\n  1209Ôćĺ  implement:success -> done\n  1210Ôćĺ  implement:fail    -> abort\n  1211Ôćĺ}`\n  1212Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n  1213Ôćĺ\n  1214Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n  1215Ôćĺ\trunner := &Runner{\n  1216Ôćĺ\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n  1217Ôćĺ\t\tStore:      store,\n  1218Ôćĺ\t}\n  1219Ôćĺ\n  1220Ôćĺ\tresult, err := runner.Run(context.Background(), tmpDir)\n  1221Ôćĺ\trequire.NoError(t, err)\n  1222Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n  1223Ôćĺ}\n  1224Ôćĺ\n  1225Ôćĺfunc TestRunner_PersistsHostRunOnFailure(t *testing.T) {\n  1226Ôćĺ\ttmpDir := t.TempDir()\n  1227Ôćĺ\n  1228Ôćĺ\t// Write a host.cloche that will fail\n  1229Ôćĺ\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n  1230Ôćĺ\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n  1231Ôćĺ\thostCloche := `workflow \"main\" {\n  1232Ôćĺ  step bad {\n  1233Ôćĺ    run     = \"exit 1\"\n  1234Ôćĺ    results = [success, fail]\n  1235Ôćĺ  }\n  1236Ôćĺ\n  1237Ôćĺ  bad:success -> done\n  1238Ôćĺ  bad:fail    -> abort\n  1239Ôćĺ}`\n  1240Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n  1241Ôćĺ\n  1242Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n  1243Ôćĺ\n  1244Ôćĺ\trunner := &Runner{\n  1245Ôćĺ\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n  1246Ôćĺ\t\tStore:      store,\n  1247Ôćĺ\t}\n  1248Ôćĺ\n  1249Ôćĺ\tresult, err := runner.Run(context.Background(), tmpDir)\n  1250Ôćĺ\trequire.NoError(t, err)\n  1251Ôćĺ\tassert.Equal(t, domain.RunStateFailed, result.State)\n  1252Ôćĺ\n  1253Ôćĺ\t// Verify the host run was persisted with failed state\n  1254Ôćĺ\thostRun, err := store.GetRun(context.Background(), result.RunID)\n  1255Ôćĺ\trequire.NoError(t, err)\n  1256Ôćĺ\tassert.True(t, hostRun.IsHost)\n  1257Ôćĺ\tassert.Equal(t, domain.RunStateFailed, hostRun.State)\n  1258Ôćĺ\tassert.False(t, hostRun.CompletedAt.IsZero())\n  1259Ôćĺ}\n  1260Ôćĺ"}]},"parent_tool_use_id":null,"session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"fe251748-6d3c-4b26-b995-e3315a1d46bf","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor_test.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// fakeDispatcher records dispatch calls and returns a predetermined run ID.\ntype fakeDispatcher struct {\n\tcalls     []*pb.RunWorkflowRequest\n\trunID     string\n\treturnErr error\n}\n\nfunc (f *fakeDispatcher) RunWorkflow(_ context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tf.calls = append(f.calls, req)\n\tif f.returnErr != nil {\n\t\treturn nil, f.returnErr\n\t}\n\treturn &pb.RunWorkflowResponse{RunId: f.runID}, nil\n}\n\n// fakeStore returns a predetermined run on GetRun.\ntype fakeStore struct {\n\truns map[string]*domain.Run\n}\n\nfunc (f *fakeStore) CreateRun(_ context.Context, run *domain.Run) error {\n\tf.runs[run.ID] = run\n\treturn nil\n}\nfunc (f *fakeStore) GetRun(_ context.Context, id string) (*domain.Run, error) {\n\tif r, ok := f.runs[id]; ok {\n\t\treturn r, nil\n\t}\n\treturn nil, os.ErrNotExist\n}\nfunc (f *fakeStore) UpdateRun(_ context.Context, run *domain.Run) error {\n\tf.runs[run.ID] = run\n\treturn nil\n}\nfunc (f *fakeStore) DeleteRun(_ context.Context, id string) error {\n\tdelete(f.runs, id)\n\treturn nil\n}\nfunc (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListChildRuns(_ context.Context, parentRunID string) ([]*domain.Run, error) {\n\tvar children []*domain.Run\n\tfor _, r := range f.runs {\n\t\tif r.ParentRunID == parentRunID {\n\t\t\tchildren = append(children, r)\n\t\t}\n\t}\n\treturn children, nil\n}\n\nfunc TestExecutor_ScriptStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"greet\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Check output was written\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"hello\")\n}\n\nfunc TestExecutor_ScriptStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"bad\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"marker\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"custom\", result)\n\n\t// Marker line should be stripped from output\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n\trequire.NoError(t, err)\n\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n\tassert.Contains(t, string(data), \"some output\")\n}\n\nfunc TestExecutor_WorkflowStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\tassert.Len(t, dispatcher.calls, 1)\n\tassert.Equal(t, \"develop\", dispatcher.calls[0].WorkflowName)\n\tassert.Equal(t, tmpDir, dispatcher.calls[0].ProjectDir)\n}\n\nfunc TestExecutor_WorkflowStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateFailed,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_WorkflowStep_PassesPrompt(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\t// Write a previous step's output\n\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"workflow_name\": \"develop\",\n\t\t\t\"prompt_step\":   \"prepare-prompt\",\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n}\n\nfunc TestEngine_HostWorkflow_Linear(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n\t\t\t},\n\t\t\t\"develop\": {\n\t\t\t\tName:    \"develop\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t\t\"merge\": {\n\t\t\t\tName:    \"merge\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\tassert.Len(t, dispatcher.calls, 1)\n}\n\nfunc TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n\t\t\t},\n\t\t\t\"develop\": {\n\t\t\t\tName:    \"develop\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n}\n\nfunc TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"env-check\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), tmpDir)\n}\n\nfunc TestExecutor_ScriptStep_NoOutputMappings(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{From: \"step-a\", Result: \"success\", To: \"step-b\"},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"step-b\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_JSONFields(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write source step output as JSON\n\tsourceJSON := `{\"title\": \"Fix bug\", \"priority\": \"high\"}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"get-tasks.out\"), []byte(sourceJSON), 0644))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"get-tasks\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"use-tasks\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"TASK_TITLE\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"title\"}}},\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"TASK_PRIORITY\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"priority\"}}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"use-tasks\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $TASK_TITLE $TASK_PRIORITY\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"use-tasks.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"Fix bug\")\n\tassert.Contains(t, string(data), \"high\")\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_ArrayIndex(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write source step output as JSON array\n\tsourceJSON := `[{\"id\": \"task-1\", \"title\": \"First\"}, {\"id\": \"task-2\", \"title\": \"Second\"}]`\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"list-tasks.out\"), []byte(sourceJSON), 0644))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"list-tasks\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"process\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"FIRST_ID\",\n\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 0},\n\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"id\"},\n\t\t\t\t\t\t}},\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"SECOND_TITLE\",\n\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 1},\n\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"title\"},\n\t\t\t\t\t\t}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"process\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $FIRST_ID $SECOND_TITLE\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"process.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"task-1\")\n\tassert.Contains(t, string(data), \"Second\")\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_MissingSourceOutput(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// No source output file written\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"missing-step\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"consumer\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"VAL\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"consumer\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\t_, err := executor.Execute(context.Background(), step)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"reading output of missing-step\")\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_NotJSON(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write non-JSON output\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"plain.out\"), []byte(\"not json\"), 0644))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"plain\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"consumer\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"VAL\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"consumer\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\t_, err := executor.Execute(context.Background(), step)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"not valid JSON\")\n}\n\nfunc TestRunner_RunWithID(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Write a simple host.cloche\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  step greet {\n    run     = \"echo hi\"\n    results = [success, fail]\n  }\n\n  greet:success -> done\n  greet:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tcustomID := \"my-custom-run-id\"\n\tresult, err := runner.RunWithID(context.Background(), tmpDir, customID)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n\tassert.Equal(t, customID, result.RunID, \"RunWithID should use the provided ID\")\n\n\t// Verify the run was persisted with the custom ID\n\thostRun, err := store.GetRun(context.Background(), customID)\n\trequire.NoError(t, err)\n\tassert.True(t, hostRun.IsHost)\n\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n}\n\nfunc TestRunner_PersistsHostRun(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Write a simple host.cloche\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  step prepare {\n    run     = \"echo prepared\"\n    results = [success, fail]\n  }\n\n  prepare:success -> done\n  prepare:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tresult, err := runner.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n\tassert.NotEmpty(t, result.RunID)\n\n\t// Verify the host run was persisted in the store\n\thostRun, err := store.GetRun(context.Background(), result.RunID)\n\trequire.NoError(t, err)\n\tassert.True(t, hostRun.IsHost, \"host run should have IsHost=true\")\n\tassert.Equal(t, tmpDir, hostRun.ProjectDir)\n\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n\tassert.False(t, hostRun.StartedAt.IsZero())\n\tassert.False(t, hostRun.CompletedAt.IsZero())\n}\n\nfunc TestExecutor_ScriptStep_UsesMainDir(t *testing.T) {\n\t// ProjectDir has no script; MainDir has the script.\n\tprojectDir := t.TempDir()\n\tmainDir := t.TempDir()\n\toutputDir := filepath.Join(projectDir, \"output\")\n\n\t// Create a script only in mainDir\n\tscriptDir := filepath.Join(mainDir, \".cloche\", \"scripts\")\n\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n\trequire.NoError(t, os.WriteFile(\n\t\tfilepath.Join(scriptDir, \"greet.sh\"),\n\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n\t\t0755,\n\t))\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tMainDir:    mainDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"greet\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/greet.sh\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"from-main\")\n}\n\nfunc TestExecutor_ScriptStep_MainDirOverridesProjectDir(t *testing.T) {\n\t// Both dirs have a script with different content; MainDir's version wins.\n\tprojectDir := t.TempDir()\n\tmainDir := t.TempDir()\n\toutputDir := filepath.Join(projectDir, \"output\")\n\n\t// Create script in both dirs with different content\n\tfor _, dir := range []string{projectDir, mainDir} {\n\t\tscriptDir := filepath.Join(dir, \".cloche\", \"scripts\")\n\t\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n\t}\n\trequire.NoError(t, os.WriteFile(\n\t\tfilepath.Join(projectDir, \".cloche\", \"scripts\", \"hello.sh\"),\n\t\t[]byte(\"#!/bin/sh\\necho from-branch\"),\n\t\t0755,\n\t))\n\trequire.NoError(t, os.WriteFile(\n\t\tfilepath.Join(mainDir, \".cloche\", \"scripts\", \"hello.sh\"),\n\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n\t\t0755,\n\t))\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tMainDir:    mainDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"hello\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/hello.sh\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"hello.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"from-main\")\n\tassert.NotContains(t, string(data), \"from-branch\")\n}\n\nfunc TestExecutor_ScriptStep_FallsBackToProjectDir(t *testing.T) {\n\t// When MainDir is empty, scripts resolve from ProjectDir.\n\tprojectDir := t.TempDir()\n\toutputDir := filepath.Join(projectDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"pwd-check\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"pwd\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"pwd-check.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), projectDir)\n}\n\nfunc TestExecutor_ScriptStep_ProjectDirEnvVar(t *testing.T) {\n\t// CLOCHE_PROJECT_DIR should always point to ProjectDir, not MainDir.\n\tprojectDir := t.TempDir()\n\tmainDir := t.TempDir()\n\toutputDir := filepath.Join(projectDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tMainDir:    mainDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"env-check\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), projectDir)\n\tassert.NotContains(t, string(data), mainDir)\n}\n\nfunc TestMainWorktreeDir_NonGitDir(t *testing.T) {\n\ttmpDir := t.TempDir()\n\t// Non-git directory should fall back to projectDir.\n\tresult := MainWorktreeDir(tmpDir)\n\tassert.Equal(t, tmpDir, result)\n}\n\nfunc TestMainWorktreeDir_WithWorktree(t *testing.T) {\n\t// Set up a real git repo with a linked worktree.\n\tmainDir := t.TempDir()\n\n\t// Initialize git repo\n\trun := func(dir string, args ...string) {\n\t\tt.Helper()\n\t\tcmd := exec.Command(args[0], args[1:]...)\n\t\tcmd.Dir = dir\n\t\tout, err := cmd.CombinedOutput()\n\t\trequire.NoError(t, err, \"command %v failed: %s\", args, out)\n\t}\n\n\trun(mainDir, \"git\", \"init\")\n\trun(mainDir, \"git\", \"config\", \"user.email\", \"test@test.com\")\n\trun(mainDir, \"git\", \"config\", \"user.name\", \"Test\")\n\trequire.NoError(t, os.WriteFile(filepath.Join(mainDir, \"file.txt\"), []byte(\"hello\"), 0644))\n\trun(mainDir, \"git\", \"add\", \".\")\n\trun(mainDir, \"git\", \"commit\", \"-m\", \"initial\")\n\n\t// Create a branch and worktree\n\tworktreeDir := filepath.Join(t.TempDir(), \"wt\")\n\trun(mainDir, \"git\", \"worktree\", \"add\", worktreeDir, \"-b\", \"feature\")\n\n\t// MainWorktreeDir from the linked worktree should return mainDir.\n\tresult := MainWorktreeDir(worktreeDir)\n\tassert.Equal(t, mainDir, result)\n\n\t// MainWorktreeDir from main should return mainDir.\n\tresult = MainWorktreeDir(mainDir)\n\tassert.Equal(t, mainDir, result)\n}\n\nfunc TestExecutor_AgentStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\t// Create a mock agent script that reads stdin and produces output\n\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent did the work'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tHostRunID:  \"test-host-run\",\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\":        \"You are a coding assistant.\",\n\t\t\t\"agent_command\": mockAgent,\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Check output was copied to executor's output path\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"agent did the work\")\n}\n\nfunc TestExecutor_AgentStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\t// Create a mock agent that reports failure via result marker\n\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'something went wrong'\\necho 'CLOCHE_RESULT:fail'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tHostRunID:  \"test-host-run\",\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\":        \"You are a coding assistant.\",\n\t\t\t\"agent_command\": mockAgent,\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_AgentStep_WorkflowLevelCommand(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\t// Create a mock agent\n\tmockAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow agent ran'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir:    tmpDir,\n\t\tOutputDir:     outputDir,\n\t\tHostRunID:     \"test-host-run\",\n\t\tAgentCommands: []string{mockAgent},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\": \"Write some code.\",\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"workflow agent ran\")\n}\n\nfunc TestExecutor_AgentStep_StepLevelOverridesWorkflow(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\t// Create two mock agents\n\tworkflowAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n\trequire.NoError(t, os.WriteFile(workflowAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow agent'\\n\"), 0755))\n\n\tstepAgent := filepath.Join(tmpDir, \"step-agent.sh\")\n\trequire.NoError(t, os.WriteFile(stepAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'step agent'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir:    tmpDir,\n\t\tOutputDir:     outputDir,\n\t\tHostRunID:     \"test-host-run\",\n\t\tAgentCommands: []string{workflowAgent},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\":        \"Write some code.\",\n\t\t\t\"agent_command\": stepAgent,\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Step-level agent should have run, not workflow-level\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"step agent\")\n\tassert.NotContains(t, string(data), \"workflow agent\")\n}\n\nfunc TestExecutor_AgentStep_FallbackChain(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\t// Create a good agent\n\tgoodAgent := filepath.Join(tmpDir, \"good-agent.sh\")\n\trequire.NoError(t, os.WriteFile(goodAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'fallback agent ran'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tHostRunID:  \"test-host-run\",\n\t}\n\n\t// Use nonexistent command as primary, good agent as fallback\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\":        \"Write some code.\",\n\t\t\t\"agent_command\": \"nonexistent-agent-xyz,\" + goodAgent,\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"fallback agent ran\")\n}\n\nfunc TestExecutor_AgentStep_PrevOutput(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write previous step output\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"prepare.out\"), []byte(\"the task description\"), 0644))\n\n\t// Create a mock agent that echoes stdin (the prompt) to verify it received it\n\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'processed prompt'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tHostRunID:  \"test-host-run\",\n\t\tWires: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"implement\"},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\":        \"You are a coding assistant.\",\n\t\t\t\"agent_command\": mockAgent,\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Verify prompt.txt was written with previous step's output\n\tpromptPath := filepath.Join(tmpDir, \".cloche\", \"test-host-run\", \"prompt.txt\")\n\tdata, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"the task description\", string(data))\n}\n\nfunc TestExecutor_AgentStep_PromptStep(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write a specific step's output\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"custom-source.out\"), []byte(\"custom prompt content\"), 0644))\n\n\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'done'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tHostRunID:  \"test-host-run\",\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\":        \"You are a coding assistant.\",\n\t\t\t\"agent_command\": mockAgent,\n\t\t\t\"prompt_step\":   \"custom-source\",\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Verify prompt.txt was written with the prompt_step output\n\tpromptPath := filepath.Join(tmpDir, \".cloche\", \"test-host-run\", \"prompt.txt\")\n\tdata, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"custom prompt content\", string(data))\n}\n\nfunc TestEngine_HostWorkflow_WithAgentStep(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\t// Create a mock agent\n\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent output'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tHostRunID:  \"test-host-run\",\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'task prompt'\"},\n\t\t\t},\n\t\t\t\"implement\": {\n\t\t\t\tName:    \"implement\",\n\t\t\t\tType:    domain.StepTypeAgent,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig: map[string]string{\n\t\t\t\t\t\"prompt\":        \"You are a coding assistant.\",\n\t\t\t\t\t\"agent_command\": mockAgent,\n\t\t\t\t},\n\t\t\t},\n\t\t\t\"verify\": {\n\t\t\t\tName:    \"verify\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo verified\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"implement\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"implement\", Result: \"success\", To: \"verify\"},\n\t\t\t{From: \"implement\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"verify\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"verify\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n}\n\nfunc TestRunner_HostWorkflow_AgentStep(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Create a mock agent\n\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent implemented'\\n\"), 0755))\n\n\t// Write a host.cloche with an agent step\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  host {\n    agent_command = \"` + mockAgent + `\"\n  }\n\n  step implement {\n    prompt = \"Implement the feature.\"\n    results = [success, fail]\n  }\n\n  implement:success -> done\n  implement:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tresult, err := runner.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n\n\t// Verify the run completed\n\thostRun, err := store.GetRun(context.Background(), result.RunID)\n\trequire.NoError(t, err)\n\tassert.True(t, hostRun.IsHost)\n\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n}\n\nfunc TestRunner_HostWorkflow_AgentStepOverridesWorkflowCommand(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Create two mock agents\n\tworkflowAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n\trequire.NoError(t, os.WriteFile(workflowAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow level'\\n\"), 0755))\n\n\tstepAgent := filepath.Join(tmpDir, \"step-agent.sh\")\n\trequire.NoError(t, os.WriteFile(stepAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'step level'\\n\"), 0755))\n\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  host {\n    agent_command = \"` + workflowAgent + `\"\n  }\n\n  step implement {\n    agent_command = \"` + stepAgent + `\"\n    prompt = \"Implement the feature.\"\n    results = [success, fail]\n  }\n\n  implement:success -> done\n  implement:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tresult, err := runner.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n}\n\nfunc TestRunner_PersistsHostRunOnFailure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Write a host.cloche that will fail\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  step bad {\n    run     = \"exit 1\"\n    results = [success, fail]\n  }\n\n  bad:success -> done\n  bad:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tresult, err := runner.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, result.State)\n\n\t// Verify the host run was persisted with failed state\n\thostRun, err := store.GetRun(context.Background(), result.RunID)\n\trequire.NoError(t, err)\n\tassert.True(t, hostRun.IsHost)\n\tassert.Equal(t, domain.RunStateFailed, hostRun.State)\n\tassert.False(t, hostRun.CompletedAt.IsZero())\n}\n","numLines":1260,"startLine":1,"totalLines":1260}}}
