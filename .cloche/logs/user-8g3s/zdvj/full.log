[2026-03-11T00:27:32Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ChQE5dGPNaHVbTpMsJ4yy7","type":"tool_result","content":"     1Ôćĺpackage host\n     2Ôćĺ\n     3Ôćĺimport (\n     4Ôćĺ\t\"context\"\n     5Ôćĺ\t\"log\"\n     6Ôćĺ\t\"sync\"\n     7Ôćĺ\t\"time\"\n     8Ôćĺ\n     9Ôćĺ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10Ôćĺ\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11Ôćĺ)\n    12Ôćĺ\n    13Ôćĺconst (\n    14Ôćĺ\tdefaultMaxConcurrent = 1\n    15Ôćĺ\tidlePollInterval     = 30 * time.Second\n    16Ôćĺ\tcapacityPollInterval = 5 * time.Second\n    17Ôćĺ)\n    18Ôćĺ\n    19Ôćĺ// LoopConfig holds configuration for an orchestration loop.\n    20Ôćĺtype LoopConfig struct {\n    21Ôćĺ\tProjectDir    string\n    22Ôćĺ\tMaxConcurrent int\n    23Ôćĺ\tStaggerDelay  time.Duration // delay between launching consecutive runs\n    24Ôćĺ}\n    25Ôćĺ\n    26Ôćĺ// Loop manages a continuous orchestration loop for a project, keeping up to\n    27Ôćĺ// MaxConcurrent host workflow runs active at all times when work is available.\n    28Ôćĺtype Loop struct {\n    29Ôćĺ\tconfig     LoopConfig\n    30Ôćĺ\trunner     func(ctx context.Context, projectDir string) (*RunResult, error)\n    31Ôćĺ\tstore      ports.RunStore\n    32Ôćĺ\tstopCh     chan struct{}\n    33Ôćĺ\tmu         sync.Mutex\n    34Ôćĺ\trunning    bool\n    35Ôćĺ}\n    36Ôćĺ\n    37Ôćĺ// NewLoop creates an orchestration loop. The runFn is called to start each\n    38Ôćĺ// orchestration run and should block until the run completes.\n    39Ôćĺfunc NewLoop(cfg LoopConfig, store ports.RunStore, runFn func(ctx context.Context, projectDir string) (*RunResult, error)) *Loop {\n    40Ôćĺ\tif cfg.MaxConcurrent <= 0 {\n    41Ôćĺ\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n    42Ôćĺ\t}\n    43Ôćĺ\treturn &Loop{\n    44Ôćĺ\t\tconfig: cfg,\n    45Ôćĺ\t\trunner: runFn,\n    46Ôćĺ\t\tstore:  store,\n    47Ôćĺ\t}\n    48Ôćĺ}\n    49Ôćĺ\n    50Ôćĺ// Start begins the orchestration loop. No-op if already running.\n    51Ôćĺfunc (l *Loop) Start() {\n    52Ôćĺ\tl.mu.Lock()\n    53Ôćĺ\tdefer l.mu.Unlock()\n    54Ôćĺ\tif l.running {\n    55Ôćĺ\t\treturn\n    56Ôćĺ\t}\n    57Ôćĺ\tl.running = true\n    58Ôćĺ\tl.stopCh = make(chan struct{})\n    59Ôćĺ\tgo l.run()\n    60Ôćĺ\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n    61Ôćĺ}\n    62Ôćĺ\n    63Ôćĺ// Stop signals the loop to stop. Active runs continue to completion.\n    64Ôćĺfunc (l *Loop) Stop() {\n    65Ôćĺ\tl.mu.Lock()\n    66Ôćĺ\tdefer l.mu.Unlock()\n    67Ôćĺ\tif !l.running {\n    68Ôćĺ\t\treturn\n    69Ôćĺ\t}\n    70Ôćĺ\tl.running = false\n    71Ôćĺ\tclose(l.stopCh)\n    72Ôćĺ\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n    73Ôćĺ}\n    74Ôćĺ\n    75Ôćĺ// Running returns whether the loop is currently active.\n    76Ôćĺfunc (l *Loop) Running() bool {\n    77Ôćĺ\tl.mu.Lock()\n    78Ôćĺ\tdefer l.mu.Unlock()\n    79Ôćĺ\treturn l.running\n    80Ôćĺ}\n    81Ôćĺ\n    82Ôćĺfunc (l *Loop) run() {\n    83Ôćĺ\ttype result struct {\n    84Ôćĺ\t\tstate domain.RunState\n    85Ôćĺ\t}\n    86Ôćĺ\n    87Ôćĺ\tcompletions := make(chan result, l.config.MaxConcurrent)\n    88Ôćĺ\tinFlight := 0\n    89Ôćĺ\n    90Ôćĺ\tfor {\n    91Ôćĺ\t\t// Fill up to max concurrent slots.\n    92Ôćĺ\t\tlaunched := 0\n    93Ôćĺ\t\tfor inFlight < l.config.MaxConcurrent {\n    94Ôćĺ\t\t\tselect {\n    95Ôćĺ\t\t\tcase <-l.stopCh:\n    96Ôćĺ\t\t\t\treturn\n    97Ôćĺ\t\t\tdefault:\n    98Ôćĺ\t\t\t}\n    99Ôćĺ\n   100Ôćĺ\t\t\t// Check how many host runs are active for this project (in case of\n   101Ôćĺ\t\t\t// leftover runs from previous loops).\n   102Ôćĺ\t\t\tactive := l.countActiveHostRuns()\n   103Ôćĺ\t\t\tif active >= l.config.MaxConcurrent {\n   104Ôćĺ\t\t\t\tbreak\n   105Ôćĺ\t\t\t}\n   106Ôćĺ\n   107Ôćĺ\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n   108Ôćĺ\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   109Ôćĺ\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   110Ôćĺ\t\t\t\t\treturn\n   111Ôćĺ\t\t\t\t}\n   112Ôćĺ\t\t\t}\n   113Ôćĺ\n   114Ôćĺ\t\t\t// Launch a new orchestration run in a goroutine.\n   115Ôćĺ\t\t\tinFlight++\n   116Ôćĺ\t\t\tlaunched++\n   117Ôćĺ\t\t\tgo func() {\n   118Ôćĺ\t\t\t\tres, err := l.runner(context.Background(), l.config.ProjectDir)\n   119Ôćĺ\t\t\t\tif err != nil {\n   120Ôćĺ\t\t\t\t\tlog.Printf(\"orchestration loop: run failed for %s: %v\", l.config.ProjectDir, err)\n   121Ôćĺ\t\t\t\t\tcompletions <- result{state: domain.RunStateFailed}\n   122Ôćĺ\t\t\t\t\treturn\n   123Ôćĺ\t\t\t\t}\n   124Ôćĺ\t\t\t\tcompletions <- result{state: res.State}\n   125Ôćĺ\t\t\t}()\n   126Ôćĺ\t\t}\n   127Ôćĺ\n   128Ôćĺ\t\tif inFlight == 0 {\n   129Ôćĺ\t\t\t// Nothing in flight and at capacity ÔÇö wait before checking again.\n   130Ôćĺ\t\t\tif !l.sleep(capacityPollInterval) {\n   131Ôćĺ\t\t\t\treturn\n   132Ôćĺ\t\t\t}\n   133Ôćĺ\t\t\tcontinue\n   134Ôćĺ\t\t}\n   135Ôćĺ\n   136Ôćĺ\t\t// Wait for any run to complete.\n   137Ôćĺ\t\tselect {\n   138Ôćĺ\t\tcase r := <-completions:\n   139Ôćĺ\t\t\tinFlight--\n   140Ôćĺ\t\t\tif r.state == domain.RunStateSucceeded {\n   141Ôćĺ\t\t\t\t// Work was done ÔÇö try to fill slots immediately.\n   142Ôćĺ\t\t\t\tcontinue\n   143Ôćĺ\t\t\t}\n   144Ôćĺ\t\t\t// Run failed or aborted (no tasks available). Back off.\n   145Ôćĺ\t\t\tif !l.sleep(idlePollInterval) {\n   146Ôćĺ\t\t\t\treturn\n   147Ôćĺ\t\t\t}\n   148Ôćĺ\t\tcase <-l.stopCh:\n   149Ôćĺ\t\t\treturn\n   150Ôćĺ\t\t}\n   151Ôćĺ\t}\n   152Ôćĺ}\n   153Ôćĺ\n   154Ôćĺ// countActiveHostRuns counts running or pending host runs for the project.\n   155Ôćĺfunc (l *Loop) countActiveHostRuns() int {\n   156Ôćĺ\tctx := context.Background()\n   157Ôćĺ\truns, err := l.store.ListRunsByProject(ctx, l.config.ProjectDir, time.Time{})\n   158Ôćĺ\tif err != nil {\n   159Ôćĺ\t\treturn 0\n   160Ôćĺ\t}\n   161Ôćĺ\tcount := 0\n   162Ôćĺ\tfor _, r := range runs {\n   163Ôćĺ\t\tif r.IsHost && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n   164Ôćĺ\t\t\tcount++\n   165Ôćĺ\t\t}\n   166Ôćĺ\t}\n   167Ôćĺ\treturn count\n   168Ôćĺ}\n   169Ôćĺ\n   170Ôćĺ// sleep waits for the given duration or until the loop is stopped.\n   171Ôćĺ// Returns false if the loop was stopped.\n   172Ôćĺfunc (l *Loop) sleep(d time.Duration) bool {\n   173Ôćĺ\tselect {\n   174Ôćĺ\tcase <-time.After(d):\n   175Ôćĺ\t\treturn true\n   176Ôćĺ\tcase <-l.stopCh:\n   177Ôćĺ\t\treturn false\n   178Ôćĺ\t}\n   179Ôćĺ}\n   180Ôćĺ"}]},"parent_tool_use_id":null,"session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"7f7e7425-847b-459d-a300-a7fbbe648345","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/loop.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"log\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\nconst (\n\tdefaultMaxConcurrent = 1\n\tidlePollInterval     = 30 * time.Second\n\tcapacityPollInterval = 5 * time.Second\n)\n\n// LoopConfig holds configuration for an orchestration loop.\ntype LoopConfig struct {\n\tProjectDir    string\n\tMaxConcurrent int\n\tStaggerDelay  time.Duration // delay between launching consecutive runs\n}\n\n// Loop manages a continuous orchestration loop for a project, keeping up to\n// MaxConcurrent host workflow runs active at all times when work is available.\ntype Loop struct {\n\tconfig     LoopConfig\n\trunner     func(ctx context.Context, projectDir string) (*RunResult, error)\n\tstore      ports.RunStore\n\tstopCh     chan struct{}\n\tmu         sync.Mutex\n\trunning    bool\n}\n\n// NewLoop creates an orchestration loop. The runFn is called to start each\n// orchestration run and should block until the run completes.\nfunc NewLoop(cfg LoopConfig, store ports.RunStore, runFn func(ctx context.Context, projectDir string) (*RunResult, error)) *Loop {\n\tif cfg.MaxConcurrent <= 0 {\n\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n\t}\n\treturn &Loop{\n\t\tconfig: cfg,\n\t\trunner: runFn,\n\t\tstore:  store,\n\t}\n}\n\n// Start begins the orchestration loop. No-op if already running.\nfunc (l *Loop) Start() {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\tif l.running {\n\t\treturn\n\t}\n\tl.running = true\n\tl.stopCh = make(chan struct{})\n\tgo l.run()\n\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n}\n\n// Stop signals the loop to stop. Active runs continue to completion.\nfunc (l *Loop) Stop() {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\tif !l.running {\n\t\treturn\n\t}\n\tl.running = false\n\tclose(l.stopCh)\n\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n}\n\n// Running returns whether the loop is currently active.\nfunc (l *Loop) Running() bool {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\treturn l.running\n}\n\nfunc (l *Loop) run() {\n\ttype result struct {\n\t\tstate domain.RunState\n\t}\n\n\tcompletions := make(chan result, l.config.MaxConcurrent)\n\tinFlight := 0\n\n\tfor {\n\t\t// Fill up to max concurrent slots.\n\t\tlaunched := 0\n\t\tfor inFlight < l.config.MaxConcurrent {\n\t\t\tselect {\n\t\t\tcase <-l.stopCh:\n\t\t\t\treturn\n\t\t\tdefault:\n\t\t\t}\n\n\t\t\t// Check how many host runs are active for this project (in case of\n\t\t\t// leftover runs from previous loops).\n\t\t\tactive := l.countActiveHostRuns()\n\t\t\tif active >= l.config.MaxConcurrent {\n\t\t\t\tbreak\n\t\t\t}\n\n\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// Launch a new orchestration run in a goroutine.\n\t\t\tinFlight++\n\t\t\tlaunched++\n\t\t\tgo func() {\n\t\t\t\tres, err := l.runner(context.Background(), l.config.ProjectDir)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlog.Printf(\"orchestration loop: run failed for %s: %v\", l.config.ProjectDir, err)\n\t\t\t\t\tcompletions <- result{state: domain.RunStateFailed}\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t\tcompletions <- result{state: res.State}\n\t\t\t}()\n\t\t}\n\n\t\tif inFlight == 0 {\n\t\t\t// Nothing in flight and at capacity ÔÇö wait before checking again.\n\t\t\tif !l.sleep(capacityPollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t// Wait for any run to complete.\n\t\tselect {\n\t\tcase r := <-completions:\n\t\t\tinFlight--\n\t\t\tif r.state == domain.RunStateSucceeded {\n\t\t\t\t// Work was done ÔÇö try to fill slots immediately.\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\t// Run failed or aborted (no tasks available). Back off.\n\t\t\tif !l.sleep(idlePollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\tcase <-l.stopCh:\n\t\t\treturn\n\t\t}\n\t}\n}\n\n// countActiveHostRuns counts running or pending host runs for the project.\nfunc (l *Loop) countActiveHostRuns() int {\n\tctx := context.Background()\n\truns, err := l.store.ListRunsByProject(ctx, l.config.ProjectDir, time.Time{})\n\tif err != nil {\n\t\treturn 0\n\t}\n\tcount := 0\n\tfor _, r := range runs {\n\t\tif r.IsHost && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n\t\t\tcount++\n\t\t}\n\t}\n\treturn count\n}\n\n// sleep waits for the given duration or until the loop is stopped.\n// Returns false if the loop was stopped.\nfunc (l *Loop) sleep(d time.Duration) bool {\n\tselect {\n\tcase <-time.After(d):\n\t\treturn true\n\tcase <-l.stopCh:\n\t\treturn false\n\t}\n}\n","numLines":180,"startLine":1,"totalLines":180}}}
