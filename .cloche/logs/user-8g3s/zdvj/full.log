[2026-03-11T00:27:32Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BDjFUWMeJUXdFfLoGyzTEW","type":"tool_result","content":"     1Ôćĺpackage dsl\n     2Ôćĺ\n     3Ôćĺimport (\n     4Ôćĺ\t\"fmt\"\n     5Ôćĺ\t\"strconv\"\n     6Ôćĺ\t\"strings\"\n     7Ôćĺ\n     8Ôćĺ\t\"github.com/cloche-dev/cloche/internal/domain\"\n     9Ôćĺ)\n    10Ôćĺ\n    11Ôćĺtype Parser struct {\n    12Ôćĺ\tlexer    *Lexer\n    13Ôćĺ\tcurrent  Token\n    14Ôćĺ\tpeek     Token\n    15Ôćĺ\tlocation domain.WorkflowLocation\n    16Ôćĺ}\n    17Ôćĺ\n    18Ôćĺ// ParseOption configures the parser.\n    19Ôćĺtype ParseOption func(*Parser)\n    20Ôćĺ\n    21Ôćĺ// WithLocation sets the workflow location, enabling location-based validation.\n    22Ôćĺfunc WithLocation(loc domain.WorkflowLocation) ParseOption {\n    23Ôćĺ\treturn func(p *Parser) {\n    24Ôćĺ\t\tp.location = loc\n    25Ôćĺ\t}\n    26Ôćĺ}\n    27Ôćĺ\n    28Ôćĺfunc Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n    29Ôćĺ\tp := &Parser{lexer: NewLexer(input)}\n    30Ôćĺ\tfor _, opt := range opts {\n    31Ôćĺ\t\topt(p)\n    32Ôćĺ\t}\n    33Ôćĺ\tp.advance() // load current\n    34Ôćĺ\tp.advance() // load peek\n    35Ôćĺ\treturn p.parseWorkflow()\n    36Ôćĺ}\n    37Ôćĺ\n    38Ôćĺ// ParseForHost parses a host.cloche file.\n    39Ôćĺfunc ParseForHost(input string) (*domain.Workflow, error) {\n    40Ôćĺ\treturn Parse(input, WithLocation(domain.LocationHost))\n    41Ôćĺ}\n    42Ôćĺ\n    43Ôćĺ// ParseForContainer parses a container workflow file.\n    44Ôćĺfunc ParseForContainer(input string) (*domain.Workflow, error) {\n    45Ôćĺ\treturn Parse(input, WithLocation(domain.LocationContainer))\n    46Ôćĺ}\n    47Ôćĺ\n    48Ôćĺfunc (p *Parser) advance() {\n    49Ôćĺ\tp.current = p.peek\n    50Ôćĺ\tp.peek = p.lexer.NextToken()\n    51Ôćĺ}\n    52Ôćĺ\n    53Ôćĺfunc (p *Parser) expect(typ TokenType) (Token, error) {\n    54Ôćĺ\tif p.current.Type != typ {\n    55Ôćĺ\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n    56Ôćĺ\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n    57Ôćĺ\t}\n    58Ôćĺ\ttok := p.current\n    59Ôćĺ\tp.advance()\n    60Ôćĺ\treturn tok, nil\n    61Ôćĺ}\n    62Ôćĺ\n    63Ôćĺfunc (p *Parser) expectIdent(value string) (Token, error) {\n    64Ôćĺ\tif p.current.Type != TokenIdent || p.current.Literal != value {\n    65Ôćĺ\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n    66Ôćĺ\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n    67Ôćĺ\t}\n    68Ôćĺ\ttok := p.current\n    69Ôćĺ\tp.advance()\n    70Ôćĺ\treturn tok, nil\n    71Ôćĺ}\n    72Ôćĺ\n    73Ôćĺfunc (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n    74Ôćĺ\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n    75Ôćĺ\t\treturn nil, err\n    76Ôćĺ\t}\n    77Ôćĺ\n    78Ôćĺ\tnameTok, err := p.expect(TokenString)\n    79Ôćĺ\tif err != nil {\n    80Ôćĺ\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n    81Ôćĺ\t}\n    82Ôćĺ\n    83Ôćĺ\tif _, err := p.expect(TokenLBrace); err != nil {\n    84Ôćĺ\t\treturn nil, err\n    85Ôćĺ\t}\n    86Ôćĺ\n    87Ôćĺ\twf := &domain.Workflow{\n    88Ôćĺ\t\tName:     nameTok.Literal,\n    89Ôćĺ\t\tLocation: p.location,\n    90Ôćĺ\t\tSteps:    make(map[string]*domain.Step),\n    91Ôćĺ\t\tConfig:   make(map[string]string),\n    92Ôćĺ\t}\n    93Ôćĺ\n    94Ôćĺ\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n    95Ôćĺ\t\tif p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n    96Ôćĺ\t\t\tstep, err := p.parseStep()\n    97Ôćĺ\t\t\tif err != nil {\n    98Ôćĺ\t\t\t\treturn nil, err\n    99Ôćĺ\t\t\t}\n   100Ôćĺ\t\t\twf.Steps[step.Name] = step\n   101Ôćĺ\t\t\tif wf.EntryStep == \"\" {\n   102Ôćĺ\t\t\t\twf.EntryStep = step.Name\n   103Ôćĺ\t\t\t}\n   104Ôćĺ\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n   105Ôćĺ\t\t\tcollect, err := p.parseCollect()\n   106Ôćĺ\t\t\tif err != 