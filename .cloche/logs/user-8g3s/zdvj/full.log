[2026-03-11T00:29:45Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HS5Ar2T4AYyESQn6MbDCAR","type":"tool_result","content":"     1Ôćĺpackage host\n     2Ôćĺ\n     3Ôćĺimport (\n     4Ôćĺ\t\"context\"\n     5Ôćĺ\t\"log\"\n     6Ôćĺ\t\"sync\"\n     7Ôćĺ\t\"time\"\n     8Ôćĺ\n     9Ôćĺ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10Ôćĺ\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11Ôćĺ)\n    12Ôćĺ\n    13Ôćĺconst (\n    14Ôćĺ\tdefaultMaxConcurrent = 1\n    15Ôćĺ\tdefaultDedupTimeout  = 5 * time.Minute\n    16Ôćĺ\tidlePollInterval     = 30 * time.Second\n    17Ôćĺ\tcapacityPollInterval = 5 * time.Second\n    18Ôćĺ)\n    19Ôćĺ\n    20Ôćĺ// LoopConfig holds configuration for an orchestration loop.\n    21Ôćĺtype LoopConfig struct {\n    22Ôćĺ\tProjectDir    string\n    23Ôćĺ\tMaxConcurrent int\n    24Ôćĺ\tStaggerDelay  time.Duration // delay between launching consecutive runs\n    25Ôćĺ\tDedupTimeout  time.Duration // how long to suppress reassignment of the same task ID\n    26Ôćĺ}\n    27Ôćĺ\n    28Ôćĺ// RunFunc is the function signature for launching a host workflow run.\n    29Ôćĺ// When taskID is non-empty, the runner should propagate it as CLOCHE_TASK_ID.\n    30Ôćĺtype RunFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n    31Ôćĺ\n    32Ôćĺ// Loop manages a continuous orchestration loop for a project, keeping up to\n    33Ôćĺ// MaxConcurrent host workflow runs active at all times when work is available.\n    34Ôćĺtype Loop struct {\n    35Ôćĺ\tconfig   LoopConfig\n    36Ôćĺ\trunner   RunFunc\n    37Ôćĺ\tstore    ports.RunStore\n    38Ôćĺ\tassigner TaskAssigner // optional; when set, daemon picks tasks\n    39Ôćĺ\tstopCh   chan struct{}\n    40Ôćĺ\tmu       sync.Mutex\n    41Ôćĺ\trunning  bool\n    42Ôćĺ\tdedupMu  sync.Mutex\n    43Ôćĺ\tdedup    map[string]time.Time // task ID -> last assignment time\n    44Ôćĺ}\n    45Ôćĺ\n    46Ôćĺ// NewLoop creates an orchestration loop. The runFn is called to start each\n    47Ôćĺ// orchestration run and should block until the run completes.\n    48Ôćĺfunc NewLoop(cfg LoopConfig, store ports.RunStore, runFn RunFunc) *Loop {\n    49Ôćĺ\tif cfg.MaxConcurrent <= 0 {\n    50Ôćĺ\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n    51Ôćĺ\t}\n    52Ôćĺ\tif cfg.DedupTimeout <= 0 {\n    53Ôćĺ\t\tcfg.DedupTimeout = defaultDedupTimeout\n    54Ôćĺ\t}\n    55Ôćĺ\treturn &Loop{\n    56Ôćĺ\t\tconfig: cfg,\n    57Ôćĺ\t\trunner: runFn,\n    58Ôćĺ\t\tstore:  store,\n    59Ôćĺ\t\tdedup:  make(map[string]time.Time),\n    60Ôćĺ\t}\n    61Ôćĺ}\n    62Ôćĺ\n    63Ôćĺ// SetTaskAssigner configures a TaskAssigner for daemon-managed task assignment.\n    64Ôćĺ// When set, the loop will query for available tasks and pass the selected task\n    65Ôćĺ// ID to the runner, preventing concurrent assignment of the same task.\n    66Ôćĺfunc (l *Loop) SetTaskAssigner(a TaskAssigner) {\n    67Ôćĺ\tl.assigner = a\n    68Ôćĺ}\n    69Ôćĺ\n    70Ôćĺ// Start begins the orchestration loop. No-op if already running.\n    71Ôćĺfunc (l *Loop) Start() {\n    72Ôćĺ\tl.mu.Lock()\n    73Ôćĺ\tdefer l.mu.Unlock()\n    74Ôćĺ\tif l.running {\n    75Ôćĺ\t\treturn\n    76Ôćĺ\t}\n    77Ôćĺ\tl.running = true\n    78Ôćĺ\tl.stopCh = make(chan struct{})\n    79Ôćĺ\tgo l.run()\n    80Ôćĺ\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n    81Ôćĺ}\n    82Ôćĺ\n    83Ôćĺ// Stop signals the loop to stop. Active runs continue to completion.\n    84Ôćĺfunc (l *Loop) Stop() {\n    85Ôćĺ\tl.mu.Lock()\n    86Ôćĺ\tdefer l.mu.Unlock()\n    87Ôćĺ\tif !l.running {\n    88Ôćĺ\t\treturn\n    89Ôćĺ\t}\n    90Ôćĺ\tl.running = false\n    91Ôćĺ\tclose(l.stopCh)\n    92Ôćĺ\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n    93Ôćĺ}\n    94Ôćĺ\n    95Ôćĺ// Running returns whether the loop is currently active.\n    96Ôćĺfunc (l *Loop) Running() bool {\n    97Ôćĺ\tl.mu.Lock()\n    98Ôćĺ\tdefer l.mu.Unlock()\n    99Ôćĺ\treturn l.running\n   100Ôćĺ}\n   101Ôćĺ\n   102Ôćĺfunc (l *Loop) run() {\n   103Ôćĺ\ttype result struct {\n   104Ôćĺ\t\tstate domain.RunState\n   105Ôćĺ\t}\n   106Ôćĺ\n   107Ôćĺ\tcompletions := make(chan result, l.config.MaxConcurrent)\n   108Ôćĺ\tinFlight := 0\n   109Ôćĺ\n   110Ôćĺ\tfor {\n   111Ôćĺ\t\t// Fill up to max concurrent slots.\n   112Ôćĺ\t\tlaunched := 0\n   113Ôćĺ\t\tfor inFlight < l.config.MaxConcurrent {\n   114Ôćĺ\t\t\tselect {\n   115Ôćĺ\t\t\tcase <-l.stopCh:\n   116Ôćĺ\t\t\t\treturn\n   117Ôćĺ\t\t\tdefault:\n   118Ôćĺ\t\t\t}\n   119Ôćĺ\n   120Ôćĺ\t\t\t// Check how many host runs are active for this project (in case of\n   121Ôćĺ\t\t\t// leftover runs from previous loops).\n   122Ôćĺ\t\t\tactive := l.countActiveHostRuns()\n   123Ôćĺ\t\t\tif active >= l.config.MaxConcurrent {\n   124Ôćĺ\t\t\t\tbreak\n   125Ôćĺ\t\t\t}\n   126Ôćĺ\n   127Ôćĺ\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n   128Ôćĺ\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   129Ôćĺ\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   130Ôćĺ\t\t\t\t\treturn\n   131Ôćĺ\t\t\t\t}\n   132Ôćĺ\t\t\t}\n   133Ôćĺ\n   134Ôćĺ\t\t\t// Determine task ID (if task assigner is configured).\n   135Ôćĺ\t\t\ttaskID := \"\"\n   136Ôćĺ\t\t\tif l.assigner != nil {\n   137Ôćĺ\t\t\t\tvar ok bool\n   138Ôćĺ\t\t\t\ttaskID, ok = l.pickTask()\n   139Ôćĺ\t\t\t\tif !ok {\n   140Ôćĺ\t\t\t\t\t// No assignable tasks available.\n   141Ôćĺ\t\t\t\t\tbreak\n   142Ôćĺ\t\t\t\t}\n   143Ôćĺ\t\t\t}\n   144Ôćĺ\n   145Ôćĺ\t\t\t// Launch a new orchestration run in a goroutine.\n   146Ôćĺ\t\t\tinFlight++\n   147Ôćĺ\t\t\tlaunched++\n   148Ôćĺ\t\t\ttid := taskID // capture for goroutine\n   149Ôćĺ\t\t\tgo func() {\n   150Ôćĺ\t\t\t\tres, err := l.runner(context.Background(), l.config.ProjectDir, tid)\n   151Ôćĺ\t\t\t\tif err != nil {\n   152Ôćĺ\t\t\t\t\tlog.Printf(\"orchestration loop: run failed for %s: %v\", l.config.ProjectDir, err)\n   153Ôćĺ\t\t\t\t\tcompletions <- result{state: domain.RunStateFailed}\n   154Ôćĺ\t\t\t\t\treturn\n   155Ôćĺ\t\t\t\t}\n   156Ôćĺ\t\t\t\tcompletions <- result{state: res.State}\n   157Ôćĺ\t\t\t}()\n   158Ôćĺ\t\t}\n   159Ôćĺ\n   160Ôćĺ\t\tif inFlight == 0 {\n   161Ôćĺ\t\t\t// Nothing in flight and at capacity ÔÇö wait before checking again.\n   162Ôćĺ\t\t\tif !l.sleep(capacityPollInterval) {\n   163Ôćĺ\t\t\t\treturn\n   164Ôćĺ\t\t\t}\n   165Ôćĺ\t\t\tcontinue\n   166Ôćĺ\t\t}\n   167Ôćĺ\n   168Ôćĺ\t\t// Wait for any run to complete.\n   169Ôćĺ\t\tselect {\n   170Ôćĺ\t\tcase r := <-completions:\n   171Ôćĺ\t\t\tinFlight--\n   172Ôćĺ\t\t\tif r.state == domain.RunStateSucceeded {\n   173Ôćĺ\t\t\t\t// Work was done ÔÇö try to fill slots immediately.\n   174Ôćĺ\t\t\t\tcontinue\n   175Ôćĺ\t\t\t}\n   176Ôćĺ\t\t\t// Run failed or aborted (no tasks available). Back off.\n   177Ôćĺ\t\t\tif !l.sleep(idlePollInterval) {\n   178Ôćĺ\t\t\t\treturn\n   179Ôćĺ\t\t\t}\n   180Ôćĺ\t\tcase <-l.stopCh:\n   181Ôćĺ\t\t\treturn\n   182Ôćĺ\t\t}\n   183Ôćĺ\t}\n   184Ôćĺ}\n   185Ôćĺ\n   186Ôćĺ// pickTask queries the task assigner for available tasks, filters out those\n   187Ôćĺ// within the dedup timeout window, and returns the first assignable task ID.\n   188Ôćĺ// It records the assignment time so the same task won't be picked again until\n   189Ôćĺ// the dedup timeout expires. Returns (\"\", false) if no tasks are available.\n   190Ôćĺfunc (l *Loop) pickTask() (string, bool) {\n   191Ôćĺ\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   192Ôćĺ\tdefer cancel()\n   193Ôćĺ\n   194Ôćĺ\ttasks, err := l.assigner.ListTasks(ctx, l.config.ProjectDir)\n   195Ôćĺ\tif err != nil {\n   196Ôćĺ\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n   197Ôćĺ\t\treturn \"\", false\n   198Ôćĺ\t}\n   199Ôćĺ\n   200Ôćĺ\tnow := time.Now()\n   201Ôćĺ\tl.dedupMu.Lock()\n   202Ôćĺ\tdefer l.dedupMu.Unlock()\n   203Ôćĺ\n   204Ôćĺ\t// Expire old dedup entries while we're here.\n   205Ôćĺ\tfor id, ts := range l.dedup {\n   206Ôćĺ\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n   207Ôćĺ\t\t\tdelete(l.dedup, id)\n   208Ôćĺ\t\t}\n   209Ôćĺ\t}\n   210Ôćĺ\n   211Ôćĺ\tfor _, task := range tasks {\n   212Ôćĺ\t\tif task.ID == \"\" {\n   213Ôćĺ\t\t\tcontinue\n   214Ôćĺ\t\t}\n   215Ôćĺ\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   216Ôćĺ\t\t\tcontinue // still within dedup window\n   217Ôćĺ\t\t}\n   218Ôćĺ\t\t// Assign this task.\n   219Ôćĺ\t\tl.dedup[task.ID] = now\n   220Ôćĺ\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n   221Ôćĺ\t\treturn task.ID, true\n   222Ôćĺ\t}\n   223Ôćĺ\n   224Ôćĺ\treturn \"\", false\n   225Ôćĺ}\n   226Ôćĺ\n   227Ôćĺ// countActiveHostRuns counts running or pending host runs for the project.\n   228Ôćĺfunc (l *Loop) countActiveHostRuns() int {\n   229Ôćĺ\tctx := context.Background()\n   230Ôćĺ\truns, err := l.store.ListRunsByProject(ctx, l.config.ProjectDir, time.Time{})\n   231Ôćĺ\tif err != nil {\n   232Ôćĺ\t\treturn 0\n   233Ôćĺ\t}\n   234Ôćĺ\tcount := 0\n   235Ôćĺ\tfor _, r := range runs {\n   236Ôćĺ\t\tif r.IsHost && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n   237Ôćĺ\t\t\tcount++\n   238Ôćĺ\t\t}\n   239Ôćĺ\t}\n   240Ôćĺ\treturn count\n   241Ôćĺ}\n   242Ôćĺ\n   243Ôćĺ// sleep waits for the given duration or until the loop is stopped.\n   244Ôćĺ// Returns false if the loop was stopped.\n   245Ôćĺfunc (l *Loop) sleep(d time.Duration) bool {\n   246Ôćĺ\tselect {\n   247Ôćĺ\tcase <-time.After(d):\n   248Ôćĺ\t\treturn true\n   249Ôćĺ\tcase <-l.stopCh:\n   250Ôćĺ\t\treturn false\n   251Ôćĺ\t}\n   252Ôćĺ}\n   253Ôćĺ"}]},"parent_tool_use_id":null,"session_id":"b83aa53c-b539-403e-957d-d27f065bd09c","uuid":"de6eb02b-55b0-4039-b5e0-035c849ee51d","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/loop.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"log\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\nconst (\n\tdefaultMaxConcurrent = 1\n\tdefaultDedupTimeout  = 5 * time.Minute\n\tidlePollInterval     = 30 * time.Second\n\tcapacityPollInterval = 5 * time.Second\n)\n\n// LoopConfig holds configuration for an orchestration loop.\ntype LoopConfig struct {\n\tProjectDir    string\n\tMaxConcurrent int\n\tStaggerDelay  time.Duration // delay between launching consecutive runs\n\tDedupTimeout  time.Duration // how long to suppress reassignment of the same task ID\n}\n\n// RunFunc is the function signature for launching a host workflow run.\n// When taskID is non-empty, the runner should propagate it as CLOCHE_TASK_ID.\ntype RunFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n\n// Loop manages a continuous orchestration loop for a project, keeping up to\n// MaxConcurrent host workflow runs active at all times when work is available.\ntype Loop struct {\n\tconfig   LoopConfig\n\trunner   RunFunc\n\tstore    ports.RunStore\n\tassigner TaskAssigner // optional; when set, daemon picks tasks\n\tstopCh   chan struct{}\n\tmu       sync.Mutex\n\trunning  bool\n\tdedupMu  sync.Mutex\n\tdedup    map[string]time.Time // task ID -> last assignment time\n}\n\n// NewLoop creates an orchestration loop. The runFn is called to start each\n// orchestration run and should block until the run completes.\nfunc NewLoop(cfg LoopConfig, store ports.RunStore, runFn RunFunc) *Loop {\n\tif cfg.MaxConcurrent <= 0 {\n\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n\t}\n\tif cfg.DedupTimeout <= 0 {\n\t\tcfg.DedupTimeout = defaultDedupTimeout\n\t}\n\treturn &Loop{\n\t\tconfig: cfg,\n\t\trunner: runFn,\n\t\tstore:  store,\n\t\tdedup:  make(map[string]time.Time),\n\t}\n}\n\n// SetTaskAssigner configures a TaskAssigner for daemon-managed task assignment.\n// When set, the loop will query for available tasks and pass the selected task\n// ID to the runner, preventing concurrent assignment of the same task.\nfunc (l *Loop) SetTaskAssigner(a TaskAssigner) {\n\tl.assigner = a\n}\n\n// Start begins the orchestration loop. No-op if already running.\nfunc (l *Loop) Start() {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\tif l.running {\n\t\treturn\n\t}\n\tl.running = true\n\tl.stopCh = make(chan struct{})\n\tgo l.run()\n\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n}\n\n// Stop signals the loop to stop. Active runs continue to completion.\nfunc (l *Loop) Stop() {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\tif !l.running {\n\t\treturn\n\t}\n\tl.running = false\n\tclose(l.stopCh)\n\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n}\n\n// Running returns whether the loop is currently active.\nfunc (l *Loop) Running() bool {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\treturn l.running\n}\n\nfunc (l *Loop) run() {\n\ttype result struct {\n\t\tstate domain.RunState\n\t}\n\n\tcompletions := make(chan result, l.config.MaxConcurrent)\n\tinFlight := 0\n\n\tfor {\n\t\t// Fill up to max concurrent slots.\n\t\tlaunched := 0\n\t\tfor inFlight < l.config.MaxConcurrent {\n\t\t\tselect {\n\t\t\tcase <-l.stopCh:\n\t\t\t\treturn\n\t\t\tdefault:\n\t\t\t}\n\n\t\t\t// Check how many host runs are active for this project (in case of\n\t\t\t// leftover runs from previous loops).\n\t\t\tactive := l.countActiveHostRuns()\n\t\t\tif active >= l.config.MaxConcurrent {\n\t\t\t\tbreak\n\t\t\t}\n\n\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// Determine task ID (if task assigner is configured).\n\t\t\ttaskID := \"\"\n\t\t\tif l.assigner != nil {\n\t\t\t\tvar ok bool\n\t\t\t\ttaskID, ok = l.pickTask()\n\t\t\t\tif !ok {\n\t\t\t\t\t// No assignable tasks available.\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// Launch a new orchestration run in a goroutine.\n\t\t\tinFlight++\n\t\t\tlaunched++\n\t\t\ttid := taskID // capture for goroutine\n\t\t\tgo func() {\n\t\t\t\tres, err := l.runner(context.Background(), l.config.ProjectDir, tid)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlog.Printf(\"orchestration loop: run failed for %s: %v\", l.config.ProjectDir, err)\n\t\t\t\t\tcompletions <- result{state: domain.RunStateFailed}\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t\tcompletions <- result{state: res.State}\n\t\t\t}()\n\t\t}\n\n\t\tif inFlight == 0 {\n\t\t\t// Nothing in flight and at capacity ÔÇö wait before checking again.\n\t\t\tif !l.sleep(capacityPollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t// Wait for any run to complete.\n\t\tselect {\n\t\tcase r := <-completions:\n\t\t\tinFlight--\n\t\t\tif r.state == domain.RunStateSucceeded {\n\t\t\t\t// Work was done ÔÇö try to fill slots immediately.\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\t// Run failed or aborted (no tasks available). Back off.\n\t\t\tif !l.sleep(idlePollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\tcase <-l.stopCh:\n\t\t\treturn\n\t\t}\n\t}\n}\n\n// pickTask queries the task assigner for available tasks, filters out those\n// within the dedup timeout window, and returns the first assignable task ID.\n// It records the assignment time so the same task won't be picked again until\n// the dedup timeout expires. Returns (\"\", false) if no tasks are available.\nfunc (l *Loop) pickTask() (string, bool) {\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\ttasks, err := l.assigner.ListTasks(ctx, l.config.ProjectDir)\n\tif err != nil {\n\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n\t\treturn \"\", false\n\t}\n\n\tnow := time.Now()\n\tl.dedupMu.Lock()\n\tdefer l.dedupMu.Unlock()\n\n\t// Expire old dedup entries while we're here.\n\tfor id, ts := range l.dedup {\n\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n\t\t\tdelete(l.dedup, id)\n\t\t}\n\t}\n\n\tfor _, task := range tasks {\n\t\tif task.ID == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n\t\t\tcontinue // still within dedup window\n\t\t}\n\t\t// Assign this task.\n\t\tl.dedup[task.ID] = now\n\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n\t\treturn task.ID, true\n\t}\n\n\treturn \"\", false\n}\n\n// countActiveHostRuns counts running or pending host runs for the project.\nfunc (l *Loop) countActiveHostRuns() int {\n\tctx := context.Background()\n\truns, err := l.store.ListRunsByProject(ctx, l.config.ProjectDir, time.Time{})\n\tif err != nil {\n\t\treturn 0\n\t}\n\tcount := 0\n\tfor _, r := range runs {\n\t\tif r.IsHost && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n\t\t\tcount++\n\t\t}\n\t}\n\treturn count\n}\n\n// sleep waits for the given duration or until the loop is stopped.\n// Returns false if the loop was stopped.\nfunc (l *Loop) sleep(d time.Duration) bool {\n\tselect {\n\tcase <-time.After(d):\n\t\treturn true\n\tcase <-l.stopCh:\n\t\treturn false\n\t}\n}\n","numLines":253,"startLine":1,"totalLines":253}}}
