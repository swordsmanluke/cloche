lisecond)\n    57Ôćĺ\t\t// First 3 succeed, then fail (no more work).\n    58Ôćĺ\t\tif n <= 3 {\n    59Ôćĺ\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n    60Ôćĺ\t\t}\n    61Ôćĺ\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    62Ôćĺ\t}\n    63Ôćĺ\n    64Ôćĺ\tloop := NewLoop(LoopConfig{\n    65Ôćĺ\t\tProjectDir:    \"/tmp/test-project\",\n    66Ôćĺ\t\tMaxConcurrent: 1,\n    67Ôćĺ\t}, store, runFn)\n    68Ôćĺ\n    69Ôćĺ\tloop.Start()\n    70Ôćĺ\t// With no backoff between successes, 3 successful + 1 failed should happen fast.\n    71Ôćĺ\ttime.Sleep(300 * time.Millisecond)\n    72Ôćĺ\tloop.Stop()\n    73Ôćĺ\n    74Ôćĺ\tif called.Load() < 4 {\n    75Ôćĺ\t\tt.Fatalf(\"expected at least 4 runs, got %d\", called.Load())\n    76Ôćĺ\t}\n    77Ôćĺ}\n    78Ôćĺ\n    79Ôćĺfunc TestLoop_DoubleStartIsNoop(t *testing.T) {\n    80Ôćĺ\tstore := &fakeStore{}\n    81Ôćĺ\trunFn := func(ctx context.Context, projectDir string) (*RunResult, error) {\n    82Ôćĺ\t\ttime.Sleep(100 * time.Millisecond)\n    83Ôćĺ\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    84Ôćĺ\t}\n    85Ôćĺ\n    86Ôćĺ\tloop := NewLoop(LoopConfig{\n    87Ôćĺ\t\tProjectDir:    \"/tmp/test-project\",\n    88Ôćĺ\t\tMaxConcurrent: 1,\n    89Ôćĺ\t}, store, runFn)\n    90Ôćĺ\n    91Ôćĺ\tloop.Start()\n    92Ôćĺ\tloop.Start() // Should be a no-op.\n    93Ôćĺ\tloop.Stop()\n    94Ôćĺ}\n    95Ôćĺ"}]},"parent_tool_use_id":"toolu_01PBzqGrRSxSxC8pWZNjvguQ","session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"407ed16d-e7ba-4964-add2-76e812e09272"}
