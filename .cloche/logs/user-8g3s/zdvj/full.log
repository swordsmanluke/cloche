  48Ôćĺ\t\tloops:     make(map[string]*host.Loop),\n    49Ôćĺ\t}\n    50Ôćĺ}\n    51Ôćĺ\n    52Ôćĺfunc NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    53Ôćĺ\treturn &ClocheServer{\n    54Ôćĺ\t\tstore:        store,\n    55Ôćĺ\t\tcaptures:     captures,\n    56Ôćĺ\t\tcontainer:    container,\n    57Ôćĺ\t\tdefaultImage: defaultImage,\n    58Ôćĺ\t\trunIDs:       make(map[string]string),\n    59Ôćĺ\t\tloops:        make(map[string]*host.Loop),\n    60Ôćĺ\t}\n    61Ôćĺ}\n    62Ôćĺ\n    63Ôćĺ// SetLogStore attaches a log store to the server for indexing extracted log files.\n    64Ôćĺfunc (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    65Ôćĺ\ts.logStore = ls\n    66Ôćĺ}\n    67Ôćĺ\n    68Ôćĺ\n    69Ôćĺ// SetEvolution attaches an evolution trigger to the server.\n    70Ôćĺfunc (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    71Ôćĺ\ts.evolution = trigger\n    72Ôćĺ}\n    73Ôćĺ\n    74Ôćĺ// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    75Ôćĺfunc (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    76Ôćĺ\ts.logBroadcast = b\n    77Ôćĺ}\n    78Ôćĺ\n    79Ôćĺ// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    80Ôćĺfunc (s *ClocheServer) SetShutdownFunc(fn func()) {\n    81Ôćĺ\ts.shutdownFn = fn\n    82Ôćĺ}\n    83Ôćĺ\n    84Ôćĺfunc (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    85Ôćĺ\tif s.container == nil {\n    86Ôćĺ\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    87Ôćĺ\t}\n    88Ôćĺ\n    89Ôćĺ\t// Generate a unique run ID, retrying on collision\n    90Ôćĺ\tvar runID string\n    91Ôćĺ\tfor attempts := 0; attempts < 10; attempts++ {\n    92Ôćĺ\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    93Ôćĺ\t\texisting, err := s.store.GetRun(ctx, runID)\n    94Ôćĺ\t\tif err != nil {\n    95Ôćĺ\t\t\tbreak // ID is free\n    96Ôćĺ\t\t}\n    97Ôćĺ\t\t// Reuse if completed more than 1 hour ago\n    98Ôćĺ\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n    99Ôćĺ\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   100Ôćĺ\t\t\tbreak\n   101Ôćĺ\t\t}\n   102Ôćĺ\t}\n   103Ôćĺ\n   104Ôćĺ\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   105Ôćĺ\tif req.Prompt != \"\" {\n   106Ôćĺ\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   107Ôćĺ\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   108Ôćĺ\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   109Ôćĺ\t\t}\n   110Ôćĺ\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   111Ôćĺ\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   112Ôćĺ\t\t}\n   113Ôćĺ\t}\n   114Ôćĺ\trun := domain.NewRun(runID, req.WorkflowName)\n   115Ôćĺ\trun.ProjectDir = req.ProjectDir\n   116Ôćĺ\trun.Title = req.Title\n   117Ôćĺ\tif err := s.store.CreateRun(ctx, run); err != nil {\n   118Ôćĺ\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   119Ôćĺ\t}\n   120Ôćĺ\n   121Ôćĺ\t// Resolve image: request-level override, then server default\n   122Ôćĺ\timage := req.Image\n   123Ôćĺ\tif image == \"\" {\n   124Ôćĺ\t\timage = s.defaultImage\n   125Ôćĺ\t}\n   126Ôćĺ\n   127Ôćĺ\t// Launch container start + tracking in background so the RPC returns immediately.\n   128Ôćĺ\t// The run stays in \"pending\" state until the container is up.\n   129Ôćĺ\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   130Ôćĺ\n   131Ôćĺ\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   132Ôćĺ}\n   133Ôćĺ\n   134Ôćĺ// launchAndTrack starts the container and then tracks it to completion.\n   135Ôćĺ// It runs in a background goroutine with its own context, independent of the\n   136Ôćĺ// RPC context which may be cancelled after RunWorkflow returns.\n   137Ôćĺfunc (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   138Ôćĺ\tctx := context.Background()\n   139Ôćĺ\n   140Ôćĺ\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   141Ôćĺ\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   142Ôćĺ\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   143Ôćĺ\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   144Ôćĺ\t\t\tif run != nil {\n   145Ôćĺ\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   146Ôćĺ\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   147Ôćĺ\t\t\t}\n   148Ôćĺ\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   149Ôćĺ\t\t\t\treturn\n   150Ôćĺ\t\t}\n   151Ôćĺ\t}\n   152Ôćĺ\n   153Ôćĺ\tbaseSHA := gitHEAD(req.ProjectDir)\n   154Ôćĺ\n   155Ôćĺ\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   156Ôćĺ\t\tImage:        image,\n   157Ôćĺ\t\tWorkflowName: req.WorkflowName,\n   158Ôćĺ\t\tProjectDir:   req.ProjectDir,\n   159Ôćĺ\t\tRunID:        runID,\n   160Ôćĺ\t\tNetworkAllow: []string{\"*\"},\n   161Ôćĺ\t})\n   162Ôćĺ\tif err != nil {\n   163Ôćĺ\t\trun, _ := s.store.GetRun(ctx, runID)\n   164Ôćĺ\t\tif run != nil {\n   165Ôćĺ\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   166Ôćĺ\t\t\t_ = s.store.UpdateRun(ctx, run)\n   167Ôćĺ\t\t}\n   168Ôćĺ\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   169Ôćĺ\t\treturn\n   170Ôćĺ\t}\n   171Ôćĺ\n   172Ôćĺ\ts.mu.Lock()\n   173Ôćĺ\ts.runIDs[runID] = containerID\n   174Ôćĺ\ts.mu.Unlock()\n   175Ôćĺ\n   176Ôćĺ\trun, _ := s.store.GetRun(ctx, runID)\n   177Ôćĺ\tif run != nil {\n   178Ôćĺ\t\trun.Start()\n   179Ôćĺ\t\trun.ContainerID = containerID\n   180Ôćĺ\t\trun.BaseSHA = baseSHA\n   181Ôćĺ\t\t_ = s.store.UpdateRun(ctx, run)\n   182Ôćĺ\t}\n   183Ôćĺ\n   184Ôćĺ\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   185Ôćĺ}\n   186Ôćĺ\n   187Ôćĺfunc (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   188Ôćĺ\tctx := context.Background()\n   189Ôćĺ\n   190Ôćĺ\t// Attach to agent output\n   191Ôćĺ\treader, err := s.container.AttachOutput(ctx, containerID)\n   192Ôćĺ\tif err != nil {\n   193Ôćĺ\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   194Ôćĺ\t\t\treturn\n   195Ôćĺ\t}\n   196Ôćĺ\n   197Ôćĺ\t// Parse JSON-lines status messages\n   198Ôćĺ\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   199Ôćĺ\tscanner := bufio.NewScanner(reader)\n   200Ôćĺ\tfor scanner.Scan() {\n   201Ôćĺ\t\tvar msg protocol.StatusMessage\n   202Ôćĺ\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   203Ôćĺ\t\t\tcontinue\n   204Ôćĺ\t\t}\n   205Ôćĺ\n   206Ôćĺ\t\t// Fast path: log messages don't need store interaction.\n   207Ôćĺ\t\tif msg.Type == protocol.MsgLog {\n   208Ôćĺ\t\t\tif s.logBroadcast != nil {\n   209Ôćĺ\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   210Ôćĺ\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   211Ôćĺ\t\t\t\t\tType:      \"llm\",\n   212Ôćĺ\t\t\t\t\tContent:   msg.Message,\n   213Ôćĺ\t\t\t\t\tStepName:  msg.StepName,\n   214Ôćĺ\t\t\t\t})\n   215Ôćĺ\t\t\t}\n   216Ôćĺ\t\t\tcontinue\n   217Ôćĺ\t\t}\n   218Ôćĺ\n   219Ôćĺ\t\trun, err := s.store.GetRun(ctx, runID)\n   220Ôćĺ\t\tif err != nil {\n   221Ôćĺ\t\t\tcontinue\n   222Ôćĺ\t\t}\n   223Ôćĺ\n   224Ôćĺ\t\tswitch msg.Type {\n   225Ôćĺ\t\tcase protocol.MsgStepStarted:\n   226Ôćĺ\t\t\trun.RecordStepStart(msg.StepName)\n   227Ôćĺ\t\t\tif s.captures != nil {\n   228Ôćĺ\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   229Ôćĺ\t\t\t\t\tStepName:  msg.StepName,\n   230Ôćĺ\t\t\t\t\tStartedAt: msg.Timestamp,\n   231Ôćĺ\t\t\t\t})\n   232Ôćĺ\t\t\t}\n   233Ôćĺ\t\t\tif s.logBroadcast != nil {\n   234Ôćĺ\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   235Ôćĺ\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   236Ôćĺ\t\t\t\t\tType:      \"status\",\n   237Ôćĺ\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   238Ôćĺ\t\t\t\t\tStepName:  msg.StepName,\n   239Ôćĺ\t\t\t\t})\n   240Ôćĺ\t\t\t}\n   241Ôćĺ\t\tcase protocol.MsgStepCompleted:\n   242Ôćĺ\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   243Ôćĺ\t\t\tif s.captures != nil {\n   244Ôćĺ\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   245Ôćĺ\t\t\t\t\tStepName:    msg.StepName,\n   246Ôćĺ\t\t\t\t\tResult:      msg.Result,\n   247Ôćĺ\t\t\t\t\tCompletedAt: msg.Timestamp,\n   248Ôćĺ\t\t\t\t})\n   249Ôćĺ\t\t\t}\n   250Ôćĺ\t\t\tif s.logBroadcast != nil {\n   251Ôćĺ\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   252Ôćĺ\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   253Ôćĺ\t\t\t\t\tType:      \"status\",\n   254Ôćĺ\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   255Ôćĺ\t\t\t\t\tStepName:  msg.StepName,\n   256Ôćĺ\t\t\t\t})\n   257Ôćĺ\t\t\t}\n   258Ôćĺ\t\tcase protocol.MsgRunTitle:\n   259Ôćĺ\t\t\tif run.Title == \"\" {\n   260Ôćĺ\t\t\t\trun.Title = msg.Message\n   261Ôćĺ\t\t\t}\n   262Ôćĺ\t\tcase protocol.MsgRunCompleted:\n   263Ôćĺ\t\t\treportedResult = msg.Result\n   264Ôćĺ\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   265Ôćĺ\t\t}\n   266Ôćĺ\n   267Ôćĺ\t\t_ = s.store.UpdateRun(ctx, run)\n   268Ôćĺ\t}\n   269Ôćĺ\treader.Close()\n   270Ôćĺ\n   271Ôćĺ\t// Signal live-stream subscribers that this run is done.\n   272Ôćĺ\tif s.logBroadcast != nil {\n   273Ôćĺ\t\ts.logBroadcast.Finish(runID)\n   274Ôćĺ\t}\n   275Ôćĺ\n   276Ôćĺ\t// Wait for process exit\n   277Ôćĺ\texitCode, err := s.container.Wait(ctx, containerID)\n   278Ôćĺ\tif err != nil {\n   279Ôćĺ\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   280Ôćĺ\t}\n   281Ôćĺ\n   282Ôćĺ\t// Extract step output files from container before it's removed\n   283Ôćĺ\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   284Ôćĺ\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   285Ôćĺ\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   286Ôćĺ\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   287Ôćĺ\t\t}\n   288Ôćĺ\t}\n   289Ôćĺ\n   290Ôćĺ\t// Capture full container stdout/stderr before the container is removed\n   291Ôćĺ\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   292Ôćĺ\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   293Ôćĺ\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   294Ôćĺ\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   295Ôćĺ\t\t}\n   296Ôćĺ\t}\n   297Ôćĺ\n   298Ôćĺ\t// Index extracted log files in the log store\n   299Ôćĺ\tif s.logStore != nil {\n   300Ôćĺ\t\ts.indexLogFiles(ctx, runID, outputDst)\n   301Ôćĺ\t}\n   302Ôćĺ\n   303Ôćĺ\t// Extract results to git branch BEFORE finalizing state, so that\n   304Ôćĺ\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   305Ôćĺ\t// before the run is marked complete.\n   306Ôćĺ\tresultLabel := reportedResult\n   307Ôćĺ\tif resultLabel == \"\" {\n   308Ôćĺ\t\tif exitCode == 0 {\n   309Ôćĺ\t\t\tresultLabel = \"succeeded\"\n   310Ôćĺ\t\t} else {\n   311Ôćĺ\t\t\tresultLabel = \"failed\"\n   312Ôćĺ\t\t}\n   313Ôćĺ\t}\n   314Ôćĺ\t{\n   315Ôćĺ\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   316Ôćĺ\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   317Ôćĺ\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   318Ôćĺ\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   319Ôćĺ\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   320Ôćĺ\t\t\t} else {\n   321Ôćĺ\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   322Ôćĺ\t\t\t}\n   323Ôćĺ\t\t} else {\n   324Ôćĺ\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   325Ôćĺ\t\t}\n   326Ôćĺ\t}\n   327Ôćĺ\n   328Ôćĺ\t// Now finalize run state\n   329Ôćĺ\trun, err := s.store.GetRun(ctx, runID)\n   330Ôćĺ\tif err != nil {\n   331Ôćĺ\t\treturn\n   332Ôćĺ\t}\n   333Ôćĺ\tif run.State == domain.RunStateRunning {\n   334Ôćĺ\t\tif reportedResult == \"succeeded\" {\n   335Ôćĺ\t\t\trun.Complete(domain.RunStateSucceeded)\n   336Ôćĺ\t\t} else if reportedResult != \"\" {\n   337Ôćĺ\t\t\trun.Complete(domain.RunStateFailed)\n   338Ôćĺ\t\t} else if exitCode == 0 {\n   339Ôćĺ\t\t\trun.Complete(domain.RunStateSucceeded)\n   340Ôćĺ\t\t} else {\n   341Ôćĺ\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   342Ôćĺ\t\t}\n   343Ôćĺ\t\t_ = s.store.UpdateRun(ctx, run)\n   344Ôćĺ\t}\n   345Ôćĺ\n   346Ôćĺ\t// Fire evolution trigger if configured\n   347Ôćĺ\tif s.evolution != nil {\n   348Ôćĺ\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   349Ôćĺ\t}\n   350Ôćĺ\n   351Ôćĺ\t// Merge is handled as a workflow step in host.cloche, not here.\n   352Ôćĺ\n   353Ôćĺ\t// Container retention policy:\n   354Ôćĺ\t// - Failed runs: always keep the container for debugging\n   355Ôćĺ\t// - Successful runs + --keep-container: keep the container\n   356Ôćĺ\t// - Successful runs without --keep-container: remove the container\n   357Ôćĺ\trunFinal, _ := s.store.GetRun(ctx, runID)\n   358Ôćĺ\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   359Ôćĺ\n   360Ôćĺ\tif keepContainer || runFailed {\n   361Ôćĺ\t\treason := \"--keep-container\"\n   362Ôćĺ\t\tif runFailed {\n   363Ôćĺ\t\t\treason = \"run failed\"\n   364Ôćĺ\t\t}\n   365Ôćĺ\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   366Ôćĺ\t\tif runFinal != nil {\n   367Ôćĺ\t\t\trunFinal.ContainerKept = true\n   368Ôćĺ\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   369Ôćĺ\t\t}\n   370Ôćĺ\t} else {\n   371Ôćĺ\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   372Ôćĺ\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   373Ôćĺ\t\t} else {\n   374Ôćĺ\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   375Ôćĺ\t\t}\n   376Ôćĺ\t}\n   377Ôćĺ\n   378Ôćĺ\t// Cleanup mapping\n   379Ôćĺ\ts.mu.Lock()\n   380Ôćĺ\tdelete(s.runIDs, runID)\n   381Ôćĺ\ts.mu.Unlock()\n   382Ôćĺ}\n   383Ôćĺ\n   384Ôćĺfunc (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   385Ôćĺ\tvar since time.Time\n   386Ôćĺ\tif !req.All {\n   387Ôćĺ\t\tsince = time.Now().Add(-1 * time.Hour)\n   388Ôćĺ\t}\n   389Ôćĺ\truns, err := s.store.ListRuns(ctx, since)\n   390Ôćĺ\tif err != nil {\n   391Ôćĺ\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   392Ôćĺ\t}\n   393Ôćĺ\n   394Ôćĺ\tresp := &pb.ListRunsResponse{}\n   395Ôćĺ\tfor _, run := range runs {\n   396Ôćĺ\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   397Ôćĺ\t\t\tRunId:        run.ID,\n   398Ôćĺ\t\t\tWorkflowName: run.WorkflowName,\n   399Ôćĺ\t\t\tState:        string(run.State),\n   400Ôćĺ\t\t\tStartedAt:    run.StartedAt.String(),\n   401Ôćĺ\t\t\tErrorMessage: run.ErrorMessage,\n   402Ôćĺ\t\t\tContainerId:  run.ContainerID,\n   403Ôćĺ\t\t\tTitle:        run.Title,\n   404Ôćĺ\t\t\tIsHost:       run.IsHost,\n   405Ôćĺ\t\t})\n   406Ôćĺ\t}\n   407Ôćĺ\treturn resp, nil\n   408Ôćĺ}\n   409Ôćĺ\n   410Ôćĺfunc (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   411Ôćĺ\trun, err := s.store.GetRun(ctx, req.RunId)\n   412Ôćĺ\tif err != nil {\n   413Ôćĺ\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   414Ôćĺ\t}\n   415Ôćĺ\n   416Ôćĺ\tresp := &pb.GetStatusResponse{\n   417Ôćĺ\t\tRunId:        run.ID,\n   418Ôćĺ\t\tWorkflowName: run.WorkflowName,\n   419Ôćĺ\t\tState:        string(run.State),\n   420Ôćĺ\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   421Ôćĺ\t\tErrorMessage: run.ErrorMessage,\n   422Ôćĺ\t\tContainerId:  run.ContainerID,\n   423Ôćĺ\t\tTitle:        run.Title,\n   424Ôćĺ\t\tIsHost:       run.IsHost,\n   425Ôćĺ\t}\n   426Ôćĺ\n   427Ôćĺ\t// Check container liveness\n   428Ôćĺ\tif run.ContainerID != \"\" && s.container != nil {\n   429Ôćĺ\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   430Ôćĺ\t\t\tresp.ContainerAlive = cs.Running\n   431Ôćĺ\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   432Ôćĺ\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   433Ôćĺ\t\t\t}\n   434Ôćĺ\t\t}\n   435Ôćĺ\t}\n   436Ôćĺ\n   437Ôćĺ\t// Load step executions from captures store if available\n   438Ôćĺ\tif s.captures != nil {\n   439Ôćĺ\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   440Ôćĺ\t\tif err == nil {\n   441Ôćĺ\t\t\tfor _, exec := range captures {\n   442Ôćĺ\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   443Ôćĺ\t\t\t\t\tStepName:    exec.StepName,\n   444Ôćĺ\t\t\t\t\tResult:      exec.Result,\n   445Ôćĺ\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   446Ôćĺ\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   447Ôćĺ\t\t\t\t})\n   448Ôćĺ\t\t\t}\n   449Ôćĺ\t\t}\n   450Ôćĺ\t} else {\n   451Ôćĺ\t\tfor _, exec := range run.StepExecutions {\n   452Ôćĺ\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   453Ôćĺ\t\t\t\tStepName:    exec.StepName,\n   454Ôćĺ\t\t\t\tResult:      exec.Result,\n   455Ôćĺ\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   456Ôćĺ\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   457Ôćĺ\t\t\t})\n   458Ôćĺ\t\t}\n   459Ôćĺ\t}\n   460Ôćĺ\n   461Ôćĺ\treturn resp, nil\n   462Ôćĺ}\n   463Ôćĺ\n   464Ôćĺfunc (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   465Ôćĺ\tctx := stream.Context()\n   466Ôćĺ\n   467Ôćĺ\t// Verify run exists\n   468Ôćĺ\trun, err := s.store.GetRun(ctx, req.RunId)\n   469Ôćĺ\tif err != nil {\n   470Ôćĺ\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   471Ôćĺ\t}\n   472Ôćĺ\n   473Ôćĺ\t// If step_name or log_type filter is set, serve content directly from the log index\n   474Ôćĺ\tif req.StepName != \"\" || req.LogType != \"\" {\n   475Ôćĺ\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   476Ôćĺ\t}\n   477Ôćĺ\n   478Ôćĺ\t// For active runs, stream live from the broadcaster so callers can tail output.\n   479Ôćĺ\tif (run.State == domain.RunStateRunning || run.State == domain.RunStatePending) && s.logBroadcast != nil {\n   480Ôćĺ\t\treturn s.streamLiveLogs(req.RunId, stream)\n   481Ôćĺ\t}\n   482Ôćĺ\n   483Ôćĺ\tif s.captures == nil {\n   484Ôćĺ\t\treturn fmt.Errorf(\"captures store not configured\")\n   485Ôćĺ\t}\n   486Ôćĺ\n   487Ôćĺ\t// Check for full.log first ÔÇö if it exists, serve it as the unified log\n   488Ôćĺ\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   489Ôćĺ\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   490Ôćĺ\t\tif err := stream.Send(&pb.LogEntry{\n   491Ôćĺ\t\t\tType:    \"full_log\",\n   492Ôćĺ\t\t\tMessage: string(data),\n   493Ôćĺ\t\t}); err != nil {\n   494Ôćĺ\t\t\treturn err\n   495Ôćĺ\t\t}\n   496Ôćĺ\t\t// Still send run completion entry\n   497Ôćĺ\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   498Ôćĺ\t\t\tif err := stream.Send(&pb.LogEntry{\n   499Ôćĺ\t\t\t\tType:      \"run_completed\",\n   500Ôćĺ\t\t\t\tResult:    string(run.State),\n   501Ôćĺ\t\t\t\tTimestamp: run.CompletedAt.String(),\n   502Ôćĺ\t\t\t\tMessage:   run.ErrorMessage,\n   503Ôćĺ\t\t\t}); err != nil {\n   504Ôćĺ\t\t\t\treturn err\n   505Ôćĺ\t\t\t}\n   506Ôćĺ\t\t}\n   507Ôćĺ\t\treturn nil\n   508Ôćĺ\t}\n   509Ôćĺ\n   510Ôćĺ\t// Fall back to capture-based streaming\n   511Ôćĺ\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   512Ôćĺ\tif err != nil {\n   513Ôćĺ\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   514Ôćĺ\t}\n   515Ôćĺ\n   516Ôćĺ\tfor _, exec := range captures {\n   517Ôćĺ\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   518Ôćĺ\t\t// and one for step_completed (has Result).\n   519Ôćĺ\t\tif exec.Result == \"\" {\n   520Ôćĺ\t\t\tentry := &pb.LogEntry{\n   521Ôćĺ\t\t\t\tType:      \"step_started\",\n   522Ôćĺ\t\t\t\tStepName:  exec.StepName,\n   523Ôćĺ\t\t\t\tTimestamp: exec.StartedAt.String(),\n   524Ôćĺ\t\t\t}\n   525Ôćĺ\t\t\tif err := stream.Send(entry); err != nil {\n   526Ôćĺ\t\t\t\treturn err\n   527Ôćĺ\t\t\t}\n   528Ôćĺ\t\t} else {\n   529Ôćĺ\t\t\t// Read step output from per-step log file.\n   530Ôćĺ\t\t\t// Do NOT fall back to container.log ÔÇö it contains unfiltered output\n   531Ôćĺ\t\t\t// from ALL steps and would show wrong content for this step.\n   532Ôćĺ\t\t\tvar output string\n   533Ôćĺ\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   534Ôćĺ\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   535Ôćĺ\t\t\t\toutput = string(data)\n   536Ôćĺ\t\t\t}\n   537Ôćĺ\t\t\tentry := &pb.LogEntry{\n   538Ôćĺ\t\t\t\tType:      \"step_completed\",\n   539Ôćĺ\t\t\t\tStepName:  exec.StepName,\n   540Ôćĺ\t\t\t\tResult:    exec.Result,\n   541Ôćĺ\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   542Ôćĺ\t\t\t\tMessage:   output,\n   543Ôćĺ\t\t\t}\n   544Ôćĺ\t\t\tif err := stream.Send(entry); err != nil {\n   545Ôćĺ\t\t\t\treturn err\n   546Ôćĺ\t\t\t}\n   547Ôćĺ\t\t}\n   548Ôćĺ\t}\n   549Ôćĺ\n   550Ôćĺ\t// Send run completion entry\n   551Ôćĺ\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   552Ôćĺ\t\tif err := stream.Send(&pb.LogEntry{\n   553Ôćĺ\t\t\tType:      \"run_completed\",\n   554Ôćĺ\t\t\tResult:    string(run.State),\n   555Ôćĺ\t\t\tTimestamp: run.CompletedAt.String(),\n   556Ôćĺ\t\t\tMessage:   run.ErrorMessage,\n   557Ôćĺ\t\t}); err != nil {\n   558Ôćĺ\t\t\treturn err\n   559Ôćĺ\t\t}\n   560Ôćĺ\t}\n   561Ôćĺ\n   562Ôćĺ\treturn nil\n   563Ôćĺ}\n   564Ôćĺ\n   565Ôćĺ// streamFilteredLogs serves log content filtered by step name and/or log type.\n   566Ôćĺ// It uses the log index when available, falling back to file path conventions.\n   567Ôćĺfunc (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   568Ôćĺ\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   569Ôćĺ\n   570Ôćĺ\t// Try log index first\n   571Ôćĺ\tif s.logStore != nil {\n   572Ôćĺ\t\tvar logFiles []*ports.LogFileEntry\n   573Ôćĺ\t\tvar err error\n   574Ôćĺ\n   575Ôćĺ\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   576Ôćĺ\t\t\t// Filter by both step and type\n   577Ôćĺ\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   578Ôćĺ\t\t\tif err == nil {\n   579Ôćĺ\t\t\t\tfiltered := logFiles[:0]\n   580Ôćĺ\t\t\t\tfor _, lf := range logFiles {\n   581Ôćĺ\t\t\t\t\tif lf.FileType == req.LogType {\n   582Ôćĺ\t\t\t\t\t\tfiltered = append(filtered, lf)\n   583Ôćĺ\t\t\t\t\t}\n   584Ôćĺ\t\t\t\t}\n   585Ôćĺ\t\t\t\tlogFiles = filtered\n   586Ôćĺ\t\t\t}\n   587Ôćĺ\t\t} else if req.StepName != \"\" {\n   588Ôćĺ\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   589Ôćĺ\t\t} else {\n   590Ôćĺ\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   591Ôćĺ\t\t}\n   592Ôćĺ\n   593Ôćĺ\t\tif err == nil && len(logFiles) > 0 {\n   594Ôćĺ\t\t\tfor _, lf := range logFiles {\n   595Ôćĺ\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   596Ôćĺ\t\t\t\tif readErr != nil {\n   597Ôćĺ\t\t\t\t\tcontinue\n   598Ôćĺ\t\t\t\t}\n   599Ôćĺ\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   600Ôćĺ\t\t\t\t\tType:     lf.FileType + \"_log\",\n   601Ôćĺ\t\t\t\t\tStepName: lf.StepName,\n   602Ôćĺ\t\t\t\t\tMessage:  string(data),\n   603Ôćĺ\t\t\t\t}); err != nil {\n   604Ôćĺ\t\t\t\t\treturn err\n   605Ôćĺ\t\t\t\t}\n   606Ôćĺ\t\t\t}\n   607Ôćĺ\t\t\treturn nil\n   608Ôćĺ\t\t}\n   609Ôćĺ\t}\n   610Ôćĺ\n   611Ôćĺ\t// Fall back to file path conventions\n   612Ôćĺ\tif req.StepName != \"\" {\n   613Ôćĺ\t\tvar logPath string\n   614Ôćĺ\t\tswitch req.LogType {\n   615Ôćĺ\t\tcase \"llm\":\n   616Ôćĺ\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   617Ôćĺ\t\tdefault:\n   618Ôćĺ\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   619Ôćĺ\t\t}\n   620Ôćĺ\n   621Ôćĺ\t\tdata, err := os.ReadFile(logPath)\n   622Ôćĺ\t\tif err != nil {\n   623Ôćĺ\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   624Ôćĺ\t\t}\n   625Ôćĺ\t\treturn stream.Send(&pb.LogEntry{\n   626Ôćĺ\t\t\tType:     \"step_log\",\n   627Ôćĺ\t\t\tStepName: req.StepName,\n   628Ôćĺ\t\t\tMessage:  string(data),\n   629Ôćĺ\t\t})\n   630Ôćĺ\t}\n   631Ôćĺ\n   632Ôćĺ\treturn fmt.Errorf(\"no log files found matching filter\")\n   633Ôćĺ}\n   634Ôćĺ\n   635Ôćĺ// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n   636Ôćĺ// time for an active run. The stream closes when the run completes or the\n   637Ôćĺ// client disconnects.\n   638Ôćĺfunc (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   639Ôćĺ\tsub := s.logBroadcast.Subscribe(runID)\n   640Ôćĺ\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   641Ôćĺ\n   642Ôćĺ\tctx := stream.Context()\n   643Ôćĺ\tfor {\n   644Ôćĺ\t\tselect {\n   645Ôćĺ\t\tcase <-ctx.Done():\n   646Ôćĺ\t\t\treturn ctx.Err()\n   647Ôćĺ\t\tcase line, ok := <-sub.C:\n   648Ôćĺ\t\t\tif !ok {\n   649Ôćĺ\t\t\t\t// Run completed ÔÇö send terminal entry.\n   650Ôćĺ\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   651Ôćĺ\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   652Ôćĺ\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   653Ôćĺ\t\t\t\t\t\tType:      \"run_completed\",\n   654Ôćĺ\t\t\t\t\t\tResult:    string(run.State),\n   655Ôćĺ\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   656Ôćĺ\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   657Ôćĺ\t\t\t\t\t})\n   658Ôćĺ\t\t\t\t}\n   659Ôćĺ\t\t\t\treturn nil\n   660Ôćĺ\t\t\t}\n   661Ôćĺ\t\t\tif err := stream.Send(&pb.LogEntry{\n   662Ôćĺ\t\t\t\tType:      \"log\",\n   663Ôćĺ\t\t\t\tStepName:  line.StepName,\n   664Ôćĺ\t\t\t\tMessage:   line.Content,\n   665Ôćĺ\t\t\t\tTimestamp: line.Timestamp,\n   666Ôćĺ\t\t\t}); err != nil {\n   667Ôćĺ\t\t\t\treturn err\n   668Ôćĺ\t\t\t}\n   669Ôćĺ\t\t}\n   670Ôćĺ\t}\n   671Ôćĺ}\n   672Ôćĺ\n   673Ôćĺfunc (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   674Ôćĺ\ts.mu.Lock()\n   675Ôćĺ\tcontainerID, ok := s.runIDs[req.RunId]\n   676Ôćĺ\ts.mu.Unlock()\n   677Ôćĺ\n   678Ôćĺ\tif !ok {\n   679Ôćĺ\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   680Ôćĺ\t}\n   681Ôćĺ\n   682Ôćĺ\tif err := s.container.Stop(ctx, containerID); err != nil {\n   683Ôćĺ\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   684Ôćĺ\t}\n   685Ôćĺ\n   686Ôćĺ\t// Mark as cancelled in store\n   687Ôćĺ\trun, err := s.store.GetRun(ctx, req.RunId)\n   688Ôćĺ\tif err == nil {\n   689Ôćĺ\t\trun.Complete(domain.RunStateCancelled)\n   690Ôćĺ\t\t_ = s.store.UpdateRun(ctx, run)\n   691Ôćĺ\t}\n   692Ôćĺ\n   693Ôćĺ\treturn &pb.StopRunResponse{}, nil\n   694Ôćĺ}\n   695Ôćĺ\n   696Ôćĺfunc (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   697Ôćĺ\tif s.container == nil {\n   698Ôćĺ\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   699Ôćĺ\t}\n   700Ôćĺ\n   701Ôćĺ\tid := req.Id\n   702Ôćĺ\tif id == \"\" {\n   703Ôćĺ\t\treturn nil, fmt.Errorf(\"id is required\")\n   704Ôćĺ\t}\n   705Ôćĺ\n   706Ôćĺ\t// Try to resolve as a run ID first\n   707Ôćĺ\tcontainerID := id\n   708Ôćĺ\trun, err := s.store.GetRun(ctx, id)\n   709Ôćĺ\tif err == nil {\n   710Ôćĺ\t\t// It's a run ID ÔÇö use the container ID from the run record\n   711Ôćĺ\t\tif run.ContainerID == \"\" {\n   712Ôćĺ\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   713Ôćĺ\t\t}\n   714Ôćĺ\t\tcontainerID = run.ContainerID\n   715Ôćĺ\t}\n   716Ôćĺ\n   717Ôćĺ\t// Remove the container\n   718Ôćĺ\tif err := s.container.Remove(ctx, containerID); err != nil {\n   719Ôćĺ\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   720Ôćĺ\t}\n   721Ôćĺ\n   722Ôćĺ\t// If we resolved a run, clear the container_kept flag\n   723Ôćĺ\tif run != nil {\n   724Ôćĺ\t\trun.ContainerKept = false\n   725Ôćĺ\t\t_ = s.store.UpdateRun(ctx, run)\n   726Ôćĺ\t}\n   727Ôćĺ\n   728Ôćĺ\treturn &pb.DeleteContainerResponse{}, nil\n   729Ôćĺ}\n   730Ôćĺ\n   731Ôćĺfunc (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   732Ôćĺ\tprojectDir := req.ProjectDir\n   733Ôćĺ\tif projectDir == \"\" {\n   734Ôćĺ\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   735Ôćĺ\t}\n   736Ôćĺ\n   737Ôćĺ\t// Verify host.cloche exists\n   738Ôćĺ\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   739Ôćĺ\tif _, err := os.Stat(hostPath); err != nil {\n   740Ôćĺ\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n   741Ôćĺ\t}\n   742Ôćĺ\n   743Ôćĺ\t// Load project config for defaults.\n   744Ôćĺ\tprojCfg, _ := config.Load(projectDir)\n   745Ôćĺ\n   746Ôćĺ\tmaxConc := int(req.MaxConcurrent)\n   747Ôćĺ\tif maxConc <= 0 {\n   748Ôćĺ\t\tmaxConc = projCfg.Orchestration.Concurrency\n   749Ôćĺ\t}\n   750Ôćĺ\tif maxConc <= 0 {\n   751Ôćĺ\t\tmaxConc = 1\n   752Ôćĺ\t}\n   753Ôćĺ\n   754Ôćĺ\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   755Ôćĺ\n   756Ôćĺ\ts.mu.Lock()\n   757Ôćĺ\tdefer s.mu.Unlock()\n   758Ôćĺ\n   759Ôćĺ\t// Stop existing loop if running.\n   760Ôćĺ\tif existing, ok := s.loops[projectDir]; ok {\n   761Ôćĺ\t\texisting.Stop()\n   762Ôćĺ\t}\n   763Ôćĺ\n   764Ôćĺ\trunFn := func(ctx context.Context, projDir string) (*host.RunResult, error) {\n   765Ôćĺ\t\trunner := &host.Runner{\n   766Ôćĺ\t\t\tDispatcher: s,\n   767Ôćĺ\t\t\tStore:      s.store,\n   768Ôćĺ\t\t}\n   769Ôćĺ\t\treturn runner.Run(ctx, projDir)\n   770Ôćĺ\t}\n   771Ôćĺ\n   772Ôćĺ\tloop := host.NewLoop(host.LoopConfig{\n   773Ôćĺ\t\tProjectDir:    projectDir,\n   774Ôćĺ\t\tMaxConcurrent: maxConc,\n   775Ôćĺ\t\tStaggerDelay:  stagger,\n   776Ôćĺ\t}, s.store, runFn)\n   777Ôćĺ\ts.loops[projectDir] = loop\n   778Ôćĺ\tloop.Start()\n   779Ôćĺ\n   780Ôćĺ\treturn &pb.EnableLoopResponse{}, nil\n   781Ôćĺ}\n   782Ôćĺ\n   783Ôćĺfunc (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n   784Ôćĺ\tprojectDir := req.ProjectDir\n   785Ôćĺ\tif projectDir == \"\" {\n   786Ôćĺ\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   787Ôćĺ\t}\n   788Ôćĺ\n   789Ôćĺ\ts.mu.Lock()\n   790Ôćĺ\tdefer s.mu.Unlock()\n   791Ôćĺ\n   792Ôćĺ\tif loop, ok := s.loops[projectDir]; ok {\n   793Ôćĺ\t\tloop.Stop()\n   794Ôćĺ\t\tdelete(s.loops, projectDir)\n   795Ôćĺ\t}\n   796Ôćĺ\n   797Ôćĺ\treturn &pb.DisableLoopResponse{}, nil\n   798Ôćĺ}\n   799Ôćĺ\n   800Ôćĺfunc (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n   801Ôćĺ\t// Stop all orchestration loops.\n   802Ôćĺ\ts.mu.Lock()\n   803Ôćĺ\tfor _, loop := range s.loops {\n   804Ôćĺ\t\tloop.Stop()\n   805Ôćĺ\t}\n   806Ôćĺ\ts.loops = make(map[string]*host.Loop)\n   807Ôćĺ\ts.mu.Unlock()\n   808Ôćĺ\n   809Ôćĺ\tif s.shutdownFn == nil {\n   810Ôćĺ\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n   811Ôćĺ\t}\n   812Ôćĺ\tgo s.shutdownFn()\n   813Ôćĺ\treturn &pb.ShutdownResponse{}, nil\n   814Ôćĺ}\n   815Ôćĺ\n   816Ôćĺ// indexLogFiles scans the extracted output directory and creates log_files index entries.\n   817Ôćĺfunc (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n   818Ôćĺ\tentries, err := os.ReadDir(outputDir)\n   819Ôćĺ\tif err != nil {\n   820Ôćĺ\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n   821Ôćĺ\t\treturn\n   822Ôćĺ\t}\n   823Ôćĺ\n   824Ôćĺ\tnow := time.Now()\n   825Ôćĺ\tfor _, entry := range entries {\n   826Ôćĺ\t\tif entry.IsDir() {\n   827Ôćĺ\t\t\tcontinue\n   828Ôćĺ\t\t}\n   829Ôćĺ\t\tname := entry.Name()\n   830Ôćĺ\t\tif !strings.HasSuffix(name, \".log\") {\n   831Ôćĺ\t\t\tcontinue\n   832Ôćĺ\t\t}\n   833Ôćĺ\n   834Ôćĺ\t\tvar fileType, stepName string\n   835Ôćĺ\t\tbase := strings.TrimSuffix(name, \".log\")\n   836Ôćĺ\n   837Ôćĺ\t\tswitch {\n   838Ôćĺ\t\tcase name == \"full.log\":\n   839Ôćĺ\t\t\tfileType = \"full\"\n   840Ôćĺ\t\tcase name == \"container.log\":\n   841Ôćĺ\t\t\t// container.log is internal, not indexed as a user-facing log type\n   842Ôćĺ\t\t\tcontinue\n   843Ôćĺ\t\tcase strings.HasPrefix(name, \"llm-\"):\n   844Ôćĺ\t\t\tfileType = \"llm\"\n   845Ôćĺ\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n   846Ôćĺ\t\tdefault:\n   847Ôćĺ\t\t\tfileType = \"script\"\n   848Ôćĺ\t\t\tstepName = base\n   849Ôćĺ\t\t}\n   850Ôćĺ\n   851Ôćĺ\t\tinfo, _ := entry.Info()\n   852Ôćĺ\t\tvar fileSize int64\n   853Ôćĺ\t\tif info != nil {\n   854Ôćĺ\t\t\tfileSize = info.Size()\n   855Ôćĺ\t\t}\n   856Ôćĺ\n   857Ôćĺ\t\tlogEntry := &ports.LogFileEntry{\n   858Ôćĺ\t\t\tRunID:     runID,\n   859Ôćĺ\t\t\tStepName:  stepName,\n   860Ôćĺ\t\t\tFileType:  fileType,\n   861Ôćĺ\t\t\tFilePath:  filepath.Join(outputDir, name),\n   862Ôćĺ\t\t\tFileSize:  fileSize,\n   863Ôćĺ\t\t\tCreatedAt: now,\n   864Ôćĺ\t\t}\n   865Ôćĺ\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n   866Ôćĺ\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n   867Ôćĺ\t\t}\n   868Ôćĺ\t}\n   869Ôćĺ}\n   870Ôćĺ\n   871Ôćĺfunc gitHEAD(dir string) string {\n   872Ôćĺ\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n   873Ôćĺ\tcmd.Dir = dir\n   874Ôćĺ\tout, err := cmd.Output()\n   875Ôćĺ\tif err != nil {\n   876Ôćĺ\t\treturn \"\"\n   877Ôćĺ\t}\n   878Ôćĺ\treturn strings.TrimSpace(string(out))\n   879Ôćĺ}\n   880Ôćĺ"}]},"parent_tool_use_id":null,"session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"7d66b7d0-f17d-4e23-a11a-a8622fbc1935","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server.go","content":"package grpc\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\t\"github.com/cloche-dev/cloche/internal/host\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\trpcgrpc \"google.golang.org/grpc\"\n)\n\ntype ClocheServer struct {\n\tpb.UnimplementedClocheServiceServer\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogStore     ports.LogStore\n\tcontainer    ports.ContainerRuntime\n\tdefaultImage string\n\tevolution    *evolution.Trigger\n\tlogBroadcast *logstream.Broadcaster\n\tshutdownFn   func()\n\tmu           sync.Mutex\n\trunIDs       map[string]string      // run_id -> container_id\n\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n}\n\nfunc NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:     store,\n\t\tcontainer: container,\n\t\trunIDs:    make(map[string]string),\n\t\tloops:     make(map[string]*host.Loop),\n\t}\n}\n\nfunc NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:        store,\n\t\tcaptures:     captures,\n\t\tcontainer:    container,\n\t\tdefaultImage: defaultImage,\n\t\trunIDs:       make(map[string]string),\n\t\tloops:        make(map[string]*host.Loop),\n\t}\n}\n\n// SetLogStore attaches a log store to the server for indexing extracted log files.\nfunc (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n\ts.logStore = ls\n}\n\n\n// SetEvolution attaches an evolution trigger to the server.\nfunc (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n\ts.evolution = trigger\n}\n\n// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\nfunc (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n\ts.logBroadcast = b\n}\n\n// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\nfunc (s *ClocheServer) SetShutdownFunc(fn func()) {\n\ts.shutdownFn = fn\n}\n\nfunc (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\t// Generate a unique run ID, retrying on collision\n\tvar runID string\n\tfor attempts := 0; attempts < 10; attempts++ {\n\t\trunID = domain.GenerateRunID(req.WorkflowName)\n\t\texisting, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tbreak // ID is free\n\t\t}\n\t\t// Reuse if completed more than 1 hour ago\n\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n\t\t\t_ = s.store.DeleteRun(ctx, runID)\n\t\t\tbreak\n\t\t}\n\t}\n\n\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n\tif req.Prompt != \"\" {\n\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n\t\t}\n\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n\t\t}\n\t}\n\trun := domain.NewRun(runID, req.WorkflowName)\n\trun.ProjectDir = req.ProjectDir\n\trun.Title = req.Title\n\tif err := s.store.CreateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n\t}\n\n\t// Resolve image: request-level override, then server default\n\timage := req.Image\n\tif image == \"\" {\n\t\timage = s.defaultImage\n\t}\n\n\t// Launch container start + tracking in background so the RPC returns immediately.\n\t// The run stays in \"pending\" state until the container is up.\n\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n\n\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n}\n\n// launchAndTrack starts the container and then tracks it to completion.\n// It runs in a background goroutine with its own context, independent of the\n// RPC context which may be cancelled after RunWorkflow returns.\nfunc (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n\tctx := context.Background()\n\n\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n\t\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\t\tif run != nil {\n\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t\t}\n\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n\t\t\t\treturn\n\t\t}\n\t}\n\n\tbaseSHA := gitHEAD(req.ProjectDir)\n\n\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n\t\tImage:        image,\n\t\tWorkflowName: req.WorkflowName,\n\t\tProjectDir:   req.ProjectDir,\n\t\tRunID:        runID,\n\t\tNetworkAllow: []string{\"*\"},\n\t})\n\tif err != nil {\n\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\tif run != nil {\n\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t}\n\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n\t\treturn\n\t}\n\n\ts.mu.Lock()\n\ts.runIDs[runID] = containerID\n\ts.mu.Unlock()\n\n\trun, _ := s.store.GetRun(ctx, runID)\n\tif run != nil {\n\t\trun.Start()\n\t\trun.ContainerID = containerID\n\t\trun.BaseSHA = baseSHA\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n}\n\nfunc (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n\tctx := context.Background()\n\n\t// Attach to agent output\n\treader, err := s.container.AttachOutput(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n\t\t\treturn\n\t}\n\n\t// Parse JSON-lines status messages\n\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n\tscanner := bufio.NewScanner(reader)\n\tfor scanner.Scan() {\n\t\tvar msg protocol.StatusMessage\n\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Fast path: log messages don't need store interaction.\n\t\tif msg.Type == protocol.MsgLog {\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"llm\",\n\t\t\t\t\tContent:   msg.Message,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\trun, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch msg.Type {\n\t\tcase protocol.MsgStepStarted:\n\t\t\trun.RecordStepStart(msg.StepName)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t\tStartedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"status\",\n\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgStepCompleted:\n\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:    msg.StepName,\n\t\t\t\t\tResult:      msg.Result,\n\t\t\t\t\tCompletedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"status\",\n\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgRunTitle:\n\t\t\tif run.Title == \"\" {\n\t\t\t\trun.Title = msg.Message\n\t\t\t}\n\t\tcase protocol.MsgRunCompleted:\n\t\t\treportedResult = msg.Result\n\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n\t\t}\n\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\treader.Close()\n\n\t// Signal live-stream subscribers that this run is done.\n\tif s.logBroadcast != nil {\n\t\ts.logBroadcast.Finish(runID)\n\t}\n\n\t// Wait for process exit\n\texitCode, err := s.container.Wait(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n\t}\n\n\t// Extract step output files from container before it's removed\n\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n\t\t}\n\t}\n\n\t// Capture full container stdout/stderr before the container is removed\n\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n\t\t}\n\t}\n\n\t// Index extracted log files in the log store\n\tif s.logStore != nil {\n\t\ts.indexLogFiles(ctx, runID, outputDst)\n\t}\n\n\t// Extract results to git branch BEFORE finalizing state, so that\n\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n\t// before the run is marked complete.\n\tresultLabel := reportedResult\n\tif resultLabel == \"\" {\n\t\tif exitCode == 0 {\n\t\t\tresultLabel = \"succeeded\"\n\t\t} else {\n\t\t\tresultLabel = \"failed\"\n\t\t}\n\t}\n\t{\n\t\textractRun, _ := s.store.GetRun(ctx, runID)\n\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n\t\t\t} else {\n\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n\t\t\t}\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n\t\t}\n\t}\n\n\t// Now finalize run state\n\trun, err := s.store.GetRun(ctx, runID)\n\tif err != nil {\n\t\treturn\n\t}\n\tif run.State == domain.RunStateRunning {\n\t\tif reportedResult == \"succeeded\" {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else if reportedResult != \"\" {\n\t\t\trun.Complete(domain.RunStateFailed)\n\t\t} else if exitCode == 0 {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else {\n\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n\t\t}\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\t// Fire evolution trigger if configured\n\tif s.evolution != nil {\n\t\ts.evolution.Fire(projectDir, workflowName, runID)\n\t}\n\n\t// Merge is handled as a workflow step in host.cloche, not here.\n\n\t// Container retention policy:\n\t// - Failed runs: always keep the container for debugging\n\t// - Successful runs + --keep-container: keep the container\n\t// - Successful runs without --keep-container: remove the container\n\trunFinal, _ := s.store.GetRun(ctx, runID)\n\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n\n\tif keepContainer || runFailed {\n\t\treason := \"--keep-container\"\n\t\tif runFailed {\n\t\t\treason = \"run failed\"\n\t\t}\n\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n\t\tif runFinal != nil {\n\t\t\trunFinal.ContainerKept = true\n\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n\t\t}\n\t} else {\n\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n\t\t}\n\t}\n\n\t// Cleanup mapping\n\ts.mu.Lock()\n\tdelete(s.runIDs, runID)\n\ts.mu.Unlock()\n}\n\nfunc (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n\tvar since time.Time\n\tif !req.All {\n\t\tsince = time.Now().Add(-1 * time.Hour)\n\t}\n\truns, err := s.store.ListRuns(ctx, since)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n\t}\n\n\tresp := &pb.ListRunsResponse{}\n\tfor _, run := range runs {\n\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n\t\t\tRunId:        run.ID,\n\t\t\tWorkflowName: run.WorkflowName,\n\t\t\tState:        string(run.State),\n\t\t\tStartedAt:    run.StartedAt.String(),\n\t\t\tErrorMessage: run.ErrorMessage,\n\t\t\tContainerId:  run.ContainerID,\n\t\t\tTitle:        run.Title,\n\t\t\tIsHost:       run.IsHost,\n\t\t})\n\t}\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n\t}\n\n\tresp := &pb.GetStatusResponse{\n\t\tRunId:        run.ID,\n\t\tWorkflowName: run.WorkflowName,\n\t\tState:        string(run.State),\n\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n\t\tErrorMessage: run.ErrorMessage,\n\t\tContainerId:  run.ContainerID,\n\t\tTitle:        run.Title,\n\t\tIsHost:       run.IsHost,\n\t}\n\n\t// Check container liveness\n\tif run.ContainerID != \"\" && s.container != nil {\n\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n\t\t\tresp.ContainerAlive = cs.Running\n\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n\t\t\t}\n\t\t}\n\t}\n\n\t// Load step executions from captures store if available\n\tif s.captures != nil {\n\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\t\tif err == nil {\n\t\t\tfor _, exec := range captures {\n\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\t\tStepName:    exec.StepName,\n\t\t\t\t\tResult:      exec.Result,\n\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, exec := range run.StepExecutions {\n\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\tStepName:    exec.StepName,\n\t\t\t\tResult:      exec.Result,\n\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t})\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tctx := stream.Context()\n\n\t// Verify run exists\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n\t}\n\n\t// If step_name or log_type filter is set, serve content directly from the log index\n\tif req.StepName != \"\" || req.LogType != \"\" {\n\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n\t}\n\n\t// For active runs, stream live from the broadcaster so callers can tail output.\n\tif (run.State == domain.RunStateRunning || run.State == domain.RunStatePending) && s.logBroadcast != nil {\n\t\treturn s.streamLiveLogs(req.RunId, stream)\n\t}\n\n\tif s.captures == nil {\n\t\treturn fmt.Errorf(\"captures store not configured\")\n\t}\n\n\t// Check for full.log first ÔÇö if it exists, serve it as the unified log\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: string(data),\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t\t// Still send run completion entry\n\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"run_completed\",\n\t\t\t\tResult:    string(run.State),\n\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}\n\n\t// Fall back to capture-based streaming\n\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n\t}\n\n\tfor _, exec := range captures {\n\t\t// Captures are stored as separate rows: one for step_started (no Result)\n\t\t// and one for step_completed (has Result).\n\t\tif exec.Result == \"\" {\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_started\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tTimestamp: exec.StartedAt.String(),\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t} else {\n\t\t\t// Read step output from per-step log file.\n\t\t\t// Do NOT fall back to container.log ÔÇö it contains unfiltered output\n\t\t\t// from ALL steps and would show wrong content for this step.\n\t\t\tvar output string\n\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\t\t\toutput = string(data)\n\t\t\t}\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_completed\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tResult:    exec.Result,\n\t\t\t\tTimestamp: exec.CompletedAt.String(),\n\t\t\t\tMessage:   output,\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\t// Send run completion entry\n\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:      \"run_completed\",\n\t\t\tResult:    string(run.State),\n\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\tMessage:   run.ErrorMessage,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// streamFilteredLogs serves log content filtered by step name and/or log type.\n// It uses the log index when available, falling back to file path conventions.\nfunc (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n\n\t// Try log index first\n\tif s.logStore != nil {\n\t\tvar logFiles []*ports.LogFileEntry\n\t\tvar err error\n\n\t\tif req.StepName != \"\" && req.LogType != \"\" {\n\t\t\t// Filter by both step and type\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t\tif err == nil {\n\t\t\t\tfiltered := logFiles[:0]\n\t\t\t\tfor _, lf := range logFiles {\n\t\t\t\t\tif lf.FileType == req.LogType {\n\t\t\t\t\t\tfiltered = append(filtered, lf)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tlogFiles = filtered\n\t\t\t}\n\t\t} else if req.StepName != \"\" {\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t} else {\n\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n\t\t}\n\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr != nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\t\tType:     lf.FileType + \"_log\",\n\t\t\t\t\tStepName: lf.StepName,\n\t\t\t\t\tMessage:  string(data),\n\t\t\t\t}); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Fall back to file path conventions\n\tif req.StepName != \"\" {\n\t\tvar logPath string\n\t\tswitch req.LogType {\n\t\tcase \"llm\":\n\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n\t\tdefault:\n\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n\t\t}\n\n\t\tdata, err := os.ReadFile(logPath)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n\t\t}\n\t\treturn stream.Send(&pb.LogEntry{\n\t\t\tType:     \"step_log\",\n\t\t\tStepName: req.StepName,\n\t\t\tMessage:  string(data),\n\t\t})\n\t}\n\n\treturn fmt.Errorf(\"no log files found matching filter\")\n}\n\n// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n// time for an active run. The stream closes when the run completes or the\n// client disconnects.\nfunc (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tsub := s.logBroadcast.Subscribe(runID)\n\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n\n\tctx := stream.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Run completed ÔÇö send terminal entry.\n\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n\t\t\t\t\t\tType:      \"run_completed\",\n\t\t\t\t\t\tResult:    string(run.State),\n\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"log\",\n\t\t\t\tStepName:  line.StepName,\n\t\t\t\tMessage:   line.Content,\n\t\t\t\tTimestamp: line.Timestamp,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n\ts.mu.Lock()\n\tcontainerID, ok := s.runIDs[req.RunId]\n\ts.mu.Unlock()\n\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n\t}\n\n\tif err := s.container.Stop(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n\t}\n\n\t// Mark as cancelled in store\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err == nil {\n\t\trun.Complete(domain.RunStateCancelled)\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.StopRunResponse{}, nil\n}\n\nfunc (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\tid := req.Id\n\tif id == \"\" {\n\t\treturn nil, fmt.Errorf(\"id is required\")\n\t}\n\n\t// Try to resolve as a run ID first\n\tcontainerID := id\n\trun, err := s.store.GetRun(ctx, id)\n\tif err == nil {\n\t\t// It's a run ID ÔÇö use the container ID from the run record\n\t\tif run.ContainerID == \"\" {\n\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n\t\t}\n\t\tcontainerID = run.ContainerID\n\t}\n\n\t// Remove the container\n\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n\t}\n\n\t// If we resolved a run, clear the container_kept flag\n\tif run != nil {\n\t\trun.ContainerKept = false\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.DeleteContainerResponse{}, nil\n}\n\nfunc (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n\tprojectDir := req.ProjectDir\n\tif projectDir == \"\" {\n\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n\t}\n\n\t// Verify host.cloche exists\n\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n\tif _, err := os.Stat(hostPath); err != nil {\n\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n\t}\n\n\t// Load project config for defaults.\n\tprojCfg, _ := config.Load(projectDir)\n\n\tmaxConc := int(req.MaxConcurrent)\n\tif maxConc <= 0 {\n\t\tmaxConc = projCfg.Orchestration.Concurrency\n\t}\n\tif maxConc <= 0 {\n\t\tmaxConc = 1\n\t}\n\n\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\t// Stop existing loop if running.\n\tif existing, ok := s.loops[projectDir]; ok {\n\t\texisting.Stop()\n\t}\n\n\trunFn := func(ctx context.Context, projDir string) (*host.RunResult, error) {\n\t\trunner := &host.Runner{\n\t\t\tDispatcher: s,\n\t\t\tStore:      s.store,\n\t\t}\n\t\treturn runner.Run(ctx, projDir)\n\t}\n\n\tloop := host.NewLoop(host.LoopConfig{\n\t\tProjectDir:    projectDir,\n\t\tMaxConcurrent: maxConc,\n\t\tStaggerDelay:  stagger,\n\t}, s.store, runFn)\n\ts.loops[projectDir] = loop\n\tloop.Start()\n\n\treturn &pb.EnableLoopResponse{}, nil\n}\n\nfunc (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n\tprojectDir := req.ProjectDir\n\tif projectDir == \"\" {\n\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n\t}\n\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\tif loop, ok := s.loops[projectDir]; ok {\n\t\tloop.Stop()\n\t\tdelete(s.loops, projectDir)\n\t}\n\n\treturn &pb.DisableLoopResponse{}, nil\n}\n\nfunc (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n\t// Stop all orchestration loops.\n\ts.mu.Lock()\n\tfor _, loop := range s.loops {\n\t\tloop.Stop()\n\t}\n\ts.loops = make(map[string]*host.Loop)\n\ts.mu.Unlock()\n\n\tif s.shutdownFn == nil {\n\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n\t}\n\tgo s.shutdownFn()\n\treturn &pb.ShutdownResponse{}, nil\n}\n\n// indexLogFiles scans the extracted output directory and creates log_files index entries.\nfunc (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tname := entry.Name()\n\t\tif !strings.HasSuffix(name, \".log\") {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar fileType, stepName string\n\t\tbase := strings.TrimSuffix(name, \".log\")\n\n\t\tswitch {\n\t\tcase name == \"full.log\":\n\t\t\tfileType = \"full\"\n\t\tcase name == \"container.log\":\n\t\t\t// container.log is internal, not indexed as a user-facing log type\n\t\t\tcontinue\n\t\tcase strings.HasPrefix(name, \"llm-\"):\n\t\t\tfileType = \"llm\"\n\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n\t\tdefault:\n\t\t\tfileType = \"script\"\n\t\t\tstepName = base\n\t\t}\n\n\t\tinfo, _ := entry.Info()\n\t\tvar fileSize int64\n\t\tif info != nil {\n\t\t\tfileSize = info.Size()\n\t\t}\n\n\t\tlogEntry := &ports.LogFileEntry{\n\t\t\tRunID:     runID,\n\t\t\tStepName:  stepName,\n\t\t\tFileType:  fileType,\n\t\t\tFilePath:  filepath.Join(outputDir, name),\n\t\t\tFileSize:  fileSize,\n\t\t\tCreatedAt: now,\n\t\t}\n\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n\t\t}\n\t}\n}\n\nfunc gitHEAD(dir string) string {\n\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\treturn strings.TrimSpace(string(out))\n}\n","numLines":880,"startLine":1,"totalLines":880}}}
