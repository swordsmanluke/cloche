ueryContext(ctx,\n   245Ôćĺ\t\t`SELECT DISTINCT project_dir FROM runs WHERE project_dir != '' ORDER BY project_dir`)\n   246Ôćĺ\tif err != nil {\n   247Ôćĺ\t\treturn nil, err\n   248Ôćĺ\t}\n   249Ôćĺ\tdefer rows.Close()\n   250Ôćĺ\n   251Ôćĺ\tvar projects []string\n   252Ôćĺ\tfor rows.Next() {\n   253Ôćĺ\t\tvar dir string\n   254Ôćĺ\t\tif err := rows.Scan(&dir); err != nil {\n   255Ôćĺ\t\t\treturn nil, err\n   256Ôćĺ\t\t}\n   257Ôćĺ\t\tprojects = append(projects, dir)\n   258Ôćĺ\t}\n   259Ôćĺ\treturn projects, rows.Err()\n   260Ôćĺ}\n   261Ôćĺ\n   262Ôćĺfunc (s *Store) ListChildRuns(ctx context.Context, parentRunID string) ([]*domain.Run, error) {\n   263Ôćĺ\trows, err := s.db.QueryContext(ctx,\n   264Ôćĺ\t\t`SELECT `+runSelectCols+` FROM runs WHERE parent_run_id = ? ORDER BY started_at ASC`,\n   265Ôćĺ\t\tparentRunID)\n   266Ôćĺ\tif err != nil {\n   267Ôćĺ\t\treturn nil, err\n   268Ôćĺ\t}\n   269Ôćĺ\tdefer rows.Close()\n   270Ôćĺ\treturn scanRuns(rows)\n   271Ôćĺ}\n   272Ôćĺ\n   273Ôćĺfunc (s *Store) SaveCapture(ctx context.Context, runID string, exec *domain.StepExecution) error {\n   274Ôćĺ\t_, err := s.db.ExecContext(ctx,\n   275Ôćĺ\t\t`INSERT INTO step_executions (run_id, step_name, result, started_at, completed_at, logs, git_ref)\n   276Ôćĺ\t\t VALUES (?, ?, ?, ?, ?, ?, ?)`,\n   277Ôćĺ\t\trunID, exec.StepName, exec.Result,\n   278Ôćĺ\t\tformatTime(exec.StartedAt), formatTime(exec.CompletedAt),\n   279Ôćĺ\t\texec.Logs, exec.GitRef,\n   280Ôćĺ\t)\n   281Ôćĺ\treturn err\n   282Ôćĺ}\n   283Ôćĺ\n   284Ôćĺfunc (s *Store) GetCaptures(ctx context.Context, runID string) ([]*domain.StepExecution, error) {\n   285Ôćĺ\trows, err := s.db.QueryContext(ctx,\n   286Ôćĺ\t\t`SELECT step_name, result, started_at, completed_at, COALESCE(logs,''), COALESCE(git_ref,'')\n   287Ôćĺ\t\t FROM step_executions WHERE run_id = ? ORDER BY id`, runID)\n   288Ôćĺ\tif err != nil {\n   289Ôćĺ\t\treturn nil, err\n   290Ôćĺ\t}\n   291Ôćĺ\tdefer rows.Close()\n   292Ôćĺ\n   293Ôćĺ\tvar execs []*domain.StepExecution\n   294Ôćĺ\tfor rows.Next() {\n   295Ôćĺ\t\te := &domain.StepExecution{}\n   296Ôćĺ\t\tvar startedAt, completedAt string\n   297Ôćĺ\t\tif err := rows.Scan(&e.StepName, &e.Result, &startedAt, &completedAt, &e.Logs, &e.GitRef); err != nil {\n   298Ôćĺ\t\t\treturn nil, err\n   299Ôćĺ\t\t}\n   300Ôćĺ\t\te.StartedAt = parseTime(startedAt)\n   301Ôćĺ\t\te.CompletedAt = parseTime(completedAt)\n   302Ôćĺ\t\texecs = append(execs, e)\n   303Ôćĺ\t}\n   304Ôćĺ\treturn execs, rows.Err()\n   305Ôćĺ}\n   306Ôćĺ\n   307Ôćĺfunc (s *Store) SaveLogFile(ctx context.Context, entry *ports.LogFileEntry) error {\n   308Ôćĺ\t_, err := s.db.ExecContext(ctx,\n   309Ôćĺ\t\t`INSERT INTO log_files (run_id, step_name, file_type, file_path, file_size, created_at)\n   310Ôćĺ\t\t VALUES (?, ?, ?, ?, ?, ?)`,\n   311Ôćĺ\t\tentry.RunID, entry.StepName, entry.FileType, entry.FilePath, entry.FileSize,\n   312Ôćĺ\t\tformatTime(entry.CreatedAt),\n   313Ôćĺ\t)\n   314Ôćĺ\treturn err\n   315Ôćĺ}\n   316Ôćĺ\n   317Ôćĺfunc (s *Store) GetLogFiles(ctx context.Context, runID string) ([]*ports.LogFileEntry, error) {\n   318Ôćĺ\trows, err := s.db.QueryContext(ctx,\n   319Ôćĺ\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   320Ôćĺ\t\t FROM log_files WHERE run_id = ? ORDER BY id`, runID)\n   321Ôćĺ\tif err != nil {\n   322Ôćĺ\t\treturn nil, err\n   323Ôćĺ\t}\n   324Ôćĺ\tdefer rows.Close()\n   325Ôćĺ\treturn scanLogFiles(rows)\n   326Ôćĺ}\n   327Ôćĺ\n   328Ôćĺfunc (s *Store) GetLogFilesByStep(ctx context.Context, runID, stepName string) ([]*ports.LogFileEntry, error) {\n   329Ôćĺ\trows, err := s.db.QueryContext(ctx,\n   330Ôćĺ\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   331Ôćĺ\t\t FROM log_files WHERE run_id = ? AND step_name = ? ORDER BY id`, runID, stepName)\n   332Ôćĺ\tif err != nil {\n   333Ôćĺ\t\treturn nil, err\n   334Ôćĺ\t}\n   335Ôćĺ\tdefer rows.Close()\n   336Ôćĺ\treturn scanLogFiles(rows)\n   337Ôćĺ}\n   338Ôćĺ\n   339Ôćĺfunc (s *Store) GetLogFileByType(ctx context.Context, runID, fileType string) ([]*ports.LogFileEntry, error) {\n   340Ôćĺ\trows, err := s.db.QueryContext(ctx,\n   341Ôćĺ\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   342Ôćĺ\t\t FROM log_files WHERE run_id = ? AND file_type = ? ORDER BY id`, runID, fileType)\n   343Ôćĺ\tif err != nil {\n   344Ôćĺ\t\treturn nil, err\n   345Ôćĺ\t}\n   346Ôćĺ\tdefer rows.Close()\n   347Ôćĺ\treturn scanLogFiles(rows)\n   348Ôćĺ}\n   349Ôćĺ"}]},"parent_tool_use_id":"toolu_01Dpfoc28ynQqDwHgSbSci6o","session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"a06954dc-6a78-4835-b073-a94be14c3d18"}
