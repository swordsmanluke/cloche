[2026-03-11T00:29:45Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kynj4kCYJQrYWBjQEpSctF","type":"tool_result","content":"     1Ôćĺpackage host\n     2Ôćĺ\n     3Ôćĺimport (\n     4Ôćĺ\t\"context\"\n     5Ôćĺ\t\"os\"\n     6Ôćĺ\t\"os/exec\"\n     7Ôćĺ\t\"path/filepath\"\n     8Ôćĺ\t\"testing\"\n     9Ôćĺ\t\"time\"\n    10Ôćĺ\n    11Ôćĺ\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    12Ôćĺ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13Ôćĺ\t\"github.com/cloche-dev/cloche/internal/engine\"\n    14Ôćĺ\t\"github.com/stretchr/testify/assert\"\n    15Ôćĺ\t\"github.com/stretchr/testify/require\"\n    16Ôćĺ)\n    17Ôćĺ\n    18Ôćĺ// fakeDispatcher records dispatch calls and returns a predetermined run ID.\n    19Ôćĺtype fakeDispatcher struct {\n    20Ôćĺ\tcalls     []*pb.RunWorkflowRequest\n    21Ôćĺ\trunID     string\n    22Ôćĺ\treturnErr error\n    23Ôćĺ}\n    24Ôćĺ\n    25Ôćĺfunc (f *fakeDispatcher) RunWorkflow(_ context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    26Ôćĺ\tf.calls = append(f.calls, req)\n    27Ôćĺ\tif f.returnErr != nil {\n    28Ôćĺ\t\treturn nil, f.returnErr\n    29Ôćĺ\t}\n    30Ôćĺ\treturn &pb.RunWorkflowResponse{RunId: f.runID}, nil\n    31Ôćĺ}\n    32Ôćĺ\n    33Ôćĺ// fakeStore returns a predetermined run on GetRun.\n    34Ôćĺtype fakeStore struct {\n    35Ôćĺ\truns map[string]*domain.Run\n    36Ôćĺ}\n    37Ôćĺ\n    38Ôćĺfunc (f *fakeStore) CreateRun(_ context.Context, run *domain.Run) error {\n    39Ôćĺ\tf.runs[run.ID] = run\n    40Ôćĺ\treturn nil\n    41Ôćĺ}\n    42Ôćĺfunc (f *fakeStore) GetRun(_ context.Context, id string) (*domain.Run, error) {\n    43Ôćĺ\tif r, ok := f.runs[id]; ok {\n    44Ôćĺ\t\treturn r, nil\n    45Ôćĺ\t}\n    46Ôćĺ\treturn nil, os.ErrNotExist\n    47Ôćĺ}\n    48Ôćĺfunc (f *fakeStore) UpdateRun(_ context.Context, run *domain.Run) error {\n    49Ôćĺ\tf.runs[run.ID] = run\n    50Ôćĺ\treturn nil\n    51Ôćĺ}\n    52Ôćĺfunc (f *fakeStore) DeleteRun(_ context.Context, id string) error {\n    53Ôćĺ\tdelete(f.runs, id)\n    54Ôćĺ\treturn nil\n    55Ôćĺ}\n    56Ôćĺfunc (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n    57Ôćĺ\treturn nil, nil\n    58Ôćĺ}\n    59Ôćĺfunc (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n    60Ôćĺ\treturn nil, nil\n    61Ôćĺ}\n    62Ôćĺfunc (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n    63Ôćĺ\treturn nil, nil\n    64Ôćĺ}\n    65Ôćĺfunc (f *fakeStore) ListChildRuns(_ context.Context, parentRunID string) ([]*domain.Run, error) {\n    66Ôćĺ\tvar children []*domain.Run\n    67Ôćĺ\tfor _, r := range f.runs {\n    68Ôćĺ\t\tif r.ParentRunID == parentRunID {\n    69Ôćĺ\t\t\tchildren = append(children, r)\n    70Ôćĺ\t\t}\n    71Ôćĺ\t}\n    72Ôćĺ\treturn children, nil\n    73Ôćĺ}\n    74Ôćĺ\n    75Ôćĺfunc TestExecutor_ScriptStep_Success(t *testing.T) {\n    76Ôćĺ\ttmpDir := t.TempDir()\n    77Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n    78Ôćĺ\n    79Ôćĺ\texecutor := &Executor{\n    80Ôćĺ\t\tProjectDir: tmpDir,\n    81Ôćĺ\t\tOutputDir:  outputDir,\n    82Ôćĺ\t}\n    83Ôćĺ\n    84Ôćĺ\tstep := &domain.Step{\n    85Ôćĺ\t\tName:    \"greet\",\n    86Ôćĺ\t\tType:    domain.StepTypeScript,\n    87Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n    88Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n    89Ôćĺ\t}\n    90Ôćĺ\n    91Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n    92Ôćĺ\trequire.NoError(t, err)\n    93Ôćĺ\tassert.Equal(t, \"success\", result)\n    94Ôćĺ\n    95Ôćĺ\t// Check output was written\n    96Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n    97Ôćĺ\trequire.NoError(t, err)\n    98Ôćĺ\tassert.Contains(t, string(data), \"hello\")\n    99Ôćĺ}\n   100Ôćĺ\n   101Ôćĺfunc TestExecutor_ScriptStep_Failure(t *testing.T) {\n   102Ôćĺ\ttmpDir := t.TempDir()\n   103Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   104Ôćĺ\n   105Ôćĺ\texecutor := &Executor{\n   106Ôćĺ\t\tProjectDir: tmpDir,\n   107Ôćĺ\t\tOutputDir:  outputDir,\n   108Ôćĺ\t}\n   109Ôćĺ\n   110Ôćĺ\tstep := &domain.Step{\n   111Ôćĺ\t\tName:    \"bad\",\n   112Ôćĺ\t\tType:    domain.StepTypeScript,\n   113Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   114Ôćĺ\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   115Ôćĺ\t}\n   116Ôćĺ\n   117Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   118Ôćĺ\trequire.NoError(t, err)\n   119Ôćĺ\tassert.Equal(t, \"fail\", result)\n   120Ôćĺ}\n   121Ôćĺ\n   122Ôćĺfunc TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n   123Ôćĺ\ttmpDir := t.TempDir()\n   124Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   125Ôćĺ\n   126Ôćĺ\texecutor := &Executor{\n   127Ôćĺ\t\tProjectDir: tmpDir,\n   128Ôćĺ\t\tOutputDir:  outputDir,\n   129Ôćĺ\t}\n   130Ôćĺ\n   131Ôćĺ\tstep := &domain.Step{\n   132Ôćĺ\t\tName:    \"marker\",\n   133Ôćĺ\t\tType:    domain.StepTypeScript,\n   134Ôćĺ\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n   135Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n   136Ôćĺ\t}\n   137Ôćĺ\n   138Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   139Ôćĺ\trequire.NoError(t, err)\n   140Ôćĺ\tassert.Equal(t, \"custom\", result)\n   141Ôćĺ\n   142Ôćĺ\t// Marker line should be stripped from output\n   143Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n   144Ôćĺ\trequire.NoError(t, err)\n   145Ôćĺ\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n   146Ôćĺ\tassert.Contains(t, string(data), \"some output\")\n   147Ôćĺ}\n   148Ôćĺ\n   149Ôćĺfunc TestExecutor_WorkflowStep_Success(t *testing.T) {\n   150Ôćĺ\ttmpDir := t.TempDir()\n   151Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   152Ôćĺ\t_ = os.MkdirAll(outputDir, 0755)\n   153Ôćĺ\n   154Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{\n   155Ôćĺ\t\t\"develop-test-run\": {\n   156Ôćĺ\t\t\tID:    \"develop-test-run\",\n   157Ôćĺ\t\t\tState: domain.RunStateSucceeded,\n   158Ôćĺ\t\t},\n   159Ôćĺ\t}}\n   160Ôćĺ\n   161Ôćĺ\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   162Ôćĺ\n   163Ôćĺ\texecutor := &Executor{\n   164Ôćĺ\t\tProjectDir: tmpDir,\n   165Ôćĺ\t\tDispatcher: dispatcher,\n   166Ôćĺ\t\tStore:      store,\n   167Ôćĺ\t\tOutputDir:  outputDir,\n   168Ôćĺ\t}\n   169Ôćĺ\n   170Ôćĺ\tstep := &domain.Step{\n   171Ôćĺ\t\tName:    \"develop\",\n   172Ôćĺ\t\tType:    domain.StepTypeWorkflow,\n   173Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   174Ôćĺ\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   175Ôćĺ\t}\n   176Ôćĺ\n   177Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   178Ôćĺ\trequire.NoError(t, err)\n   179Ôćĺ\tassert.Equal(t, \"success\", result)\n   180Ôćĺ\tassert.Len(t, dispatcher.calls, 1)\n   181Ôćĺ\tassert.Equal(t, \"develop\", dispatcher.calls[0].WorkflowName)\n   182Ôćĺ\tassert.Equal(t, tmpDir, dispatcher.calls[0].ProjectDir)\n   183Ôćĺ}\n   184Ôćĺ\n   185Ôćĺfunc TestExecutor_WorkflowStep_Failure(t *testing.T) {\n   186Ôćĺ\ttmpDir := t.TempDir()\n   187Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   188Ôćĺ\t_ = os.MkdirAll(outputDir, 0755)\n   189Ôćĺ\n   190Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{\n   191Ôćĺ\t\t\"develop-test-run\": {\n   192Ôćĺ\t\t\tID:    \"develop-test-run\",\n   193Ôćĺ\t\t\tState: domain.RunStateFailed,\n   194Ôćĺ\t\t},\n   195Ôćĺ\t}}\n   196Ôćĺ\n   197Ôćĺ\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   198Ôćĺ\n   199Ôćĺ\texecutor := &Executor{\n   200Ôćĺ\t\tProjectDir: tmpDir,\n   201Ôćĺ\t\tDispatcher: dispatcher,\n   202Ôćĺ\t\tStore:      store,\n   203Ôćĺ\t\tOutputDir:  outputDir,\n   204Ôćĺ\t}\n   205Ôćĺ\n   206Ôćĺ\tstep := &domain.Step{\n   207Ôćĺ\t\tName:    \"develop\",\n   208Ôćĺ\t\tType:    domain.StepTypeWorkflow,\n   209Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   210Ôćĺ\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   211Ôćĺ\t}\n   212Ôćĺ\n   213Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   214Ôćĺ\trequire.NoError(t, err)\n   215Ôćĺ\tassert.Equal(t, \"fail\", result)\n   216Ôćĺ}\n   217Ôćĺ\n   218Ôćĺfunc TestExecutor_WorkflowStep_PassesPrompt(t *testing.T) {\n   219Ôćĺ\ttmpDir := t.TempDir()\n   220Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   221Ôćĺ\t_ = os.MkdirAll(outputDir, 0755)\n   222Ôćĺ\n   223Ôćĺ\t// Write a previous step's output\n   224Ôćĺ\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n   225Ôćĺ\n   226Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{\n   227Ôćĺ\t\t\"develop-test-run\": {\n   228Ôćĺ\t\t\tID:    \"develop-test-run\",\n   229Ôćĺ\t\t\tState: domain.RunStateSucceeded,\n   230Ôćĺ\t\t},\n   231Ôćĺ\t}}\n   232Ôćĺ\n   233Ôćĺ\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   234Ôćĺ\n   235Ôćĺ\texecutor := &Executor{\n   236Ôćĺ\t\tProjectDir: tmpDir,\n   237Ôćĺ\t\tDispatcher: dispatcher,\n   238Ôćĺ\t\tStore:      store,\n   239Ôćĺ\t\tOutputDir:  outputDir,\n   240Ôćĺ\t}\n   241Ôćĺ\n   242Ôćĺ\tstep := &domain.Step{\n   243Ôćĺ\t\tName:    \"develop\",\n   244Ôćĺ\t\tType:    domain.StepTypeWorkflow,\n   245Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   246Ôćĺ\t\tConfig: map[string]string{\n   247Ôćĺ\t\t\t\"workflow_name\": \"develop\",\n   248Ôćĺ\t\t\t\"prompt_step\":   \"prepare-prompt\",\n   249Ôćĺ\t\t},\n   250Ôćĺ\t}\n   251Ôćĺ\n   252Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   253Ôćĺ\trequire.NoError(t, err)\n   254Ôćĺ\tassert.Equal(t, \"success\", result)\n   255Ôćĺ\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n   256Ôćĺ}\n   257Ôćĺ\n   258Ôćĺfunc TestEngine_HostWorkflow_Linear(t *testing.T) {\n   259Ôćĺ\ttmpDir := t.TempDir()\n   260Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   261Ôćĺ\n   262Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{\n   263Ôćĺ\t\t\"develop-test-run\": {\n   264Ôćĺ\t\t\tID:    \"develop-test-run\",\n   265Ôćĺ\t\t\tState: domain.RunStateSucceeded,\n   266Ôćĺ\t\t},\n   267Ôćĺ\t}}\n   268Ôćĺ\n   269Ôćĺ\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   270Ôćĺ\n   271Ôćĺ\texecutor := &Executor{\n   272Ôćĺ\t\tProjectDir: tmpDir,\n   273Ôćĺ\t\tDispatcher: dispatcher,\n   274Ôćĺ\t\tStore:      store,\n   275Ôćĺ\t\tOutputDir:  outputDir,\n   276Ôćĺ\t}\n   277Ôćĺ\n   278Ôćĺ\twf := &domain.Workflow{\n   279Ôćĺ\t\tName: \"main\",\n   280Ôćĺ\t\tSteps: map[string]*domain.Step{\n   281Ôćĺ\t\t\t\"prepare\": {\n   282Ôćĺ\t\t\t\tName:    \"prepare\",\n   283Ôćĺ\t\t\t\tType:    domain.StepTypeScript,\n   284Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n   285Ôćĺ\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n   286Ôćĺ\t\t\t},\n   287Ôćĺ\t\t\t\"develop\": {\n   288Ôćĺ\t\t\t\tName:    \"develop\",\n   289Ôćĺ\t\t\t\tType:    domain.StepTypeWorkflow,\n   290Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n   291Ôćĺ\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   292Ôćĺ\t\t\t},\n   293Ôćĺ\t\t\t\"merge\": {\n   294Ôćĺ\t\t\t\tName:    \"merge\",\n   295Ôćĺ\t\t\t\tType:    domain.StepTypeScript,\n   296Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n   297Ôćĺ\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n   298Ôćĺ\t\t\t},\n   299Ôćĺ\t\t},\n   300Ôćĺ\t\tWiring: []domain.Wire{\n   301Ôćĺ\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   302Ôćĺ\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   303Ôćĺ\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n   304Ôćĺ\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   305Ôćĺ\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n   306Ôćĺ\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n   307Ôćĺ\t\t},\n   308Ôćĺ\t\tEntryStep: \"prepare\",\n   309Ôćĺ\t}\n   310Ôćĺ\n   311Ôćĺ\teng := engine.New(executor)\n   312Ôćĺ\trun, err := eng.Run(context.Background(), wf)\n   313Ôćĺ\trequire.NoError(t, err)\n   314Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   315Ôćĺ\tassert.Len(t, dispatcher.calls, 1)\n   316Ôćĺ}\n   317Ôćĺ\n   318Ôćĺfunc TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n   319Ôćĺ\ttmpDir := t.TempDir()\n   320Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   321Ôćĺ\n   322Ôćĺ\texecutor := &Executor{\n   323Ôćĺ\t\tProjectDir: tmpDir,\n   324Ôćĺ\t\tOutputDir:  outputDir,\n   325Ôćĺ\t}\n   326Ôćĺ\n   327Ôćĺ\twf := &domain.Workflow{\n   328Ôćĺ\t\tName: \"main\",\n   329Ôćĺ\t\tSteps: map[string]*domain.Step{\n   330Ôćĺ\t\t\t\"prepare\": {\n   331Ôćĺ\t\t\t\tName:    \"prepare\",\n   332Ôćĺ\t\t\t\tType:    domain.StepTypeScript,\n   333Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n   334Ôćĺ\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   335Ôćĺ\t\t\t},\n   336Ôćĺ\t\t\t\"develop\": {\n   337Ôćĺ\t\t\t\tName:    \"develop\",\n   338Ôćĺ\t\t\t\tType:    domain.StepTypeWorkflow,\n   339Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n   340Ôćĺ\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   341Ôćĺ\t\t\t},\n   342Ôćĺ\t\t},\n   343Ôćĺ\t\tWiring: []domain.Wire{\n   344Ôćĺ\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   345Ôćĺ\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   346Ôćĺ\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n   347Ôćĺ\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   348Ôćĺ\t\t},\n   349Ôćĺ\t\tEntryStep: \"prepare\",\n   350Ôćĺ\t}\n   351Ôćĺ\n   352Ôćĺ\teng := engine.New(executor)\n   353Ôćĺ\trun, err := eng.Run(context.Background(), wf)\n   354Ôćĺ\trequire.NoError(t, err)\n   355Ôćĺ\tassert.Equal(t, domain.RunStateFailed, run.State)\n   356Ôćĺ}\n   357Ôćĺ\n   358Ôćĺfunc TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n   359Ôćĺ\ttmpDir := t.TempDir()\n   360Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   361Ôćĺ\n   362Ôćĺ\texecutor := &Executor{\n   363Ôćĺ\t\tProjectDir: tmpDir,\n   364Ôćĺ\t\tOutputDir:  outputDir,\n   365Ôćĺ\t}\n   366Ôćĺ\n   367Ôćĺ\tstep := &domain.Step{\n   368Ôćĺ\t\tName:    \"env-check\",\n   369Ôćĺ\t\tType:    domain.StepTypeScript,\n   370Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   371Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n   372Ôćĺ\t}\n   373Ôćĺ\n   374Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   375Ôćĺ\trequire.NoError(t, err)\n   376Ôćĺ\tassert.Equal(t, \"success\", result)\n   377Ôćĺ\n   378Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n   379Ôćĺ\trequire.NoError(t, err)\n   380Ôćĺ\tassert.Contains(t, string(data), tmpDir)\n   381Ôćĺ}\n   382Ôćĺ\n   383Ôćĺfunc TestExecutor_ScriptStep_TaskIDEnvVar(t *testing.T) {\n   384Ôćĺ\ttmpDir := t.TempDir()\n   385Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   386Ôćĺ\n   387Ôćĺ\texecutor := &Executor{\n   388Ôćĺ\t\tProjectDir: tmpDir,\n   389Ôćĺ\t\tOutputDir:  outputDir,\n   390Ôćĺ\t\tTaskID:     \"my-task-42\",\n   391Ôćĺ\t}\n   392Ôćĺ\n   393Ôćĺ\tstep := &domain.Step{\n   394Ôćĺ\t\tName:    \"task-check\",\n   395Ôćĺ\t\tType:    domain.StepTypeScript,\n   396Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   397Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_TASK_ID\"},\n   398Ôćĺ\t}\n   399Ôćĺ\n   400Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   401Ôćĺ\trequire.NoError(t, err)\n   402Ôćĺ\tassert.Equal(t, \"success\", result)\n   403Ôćĺ\n   404Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"task-check.out\"))\n   405Ôćĺ\trequire.NoError(t, err)\n   406Ôćĺ\tassert.Contains(t, string(data), \"my-task-42\")\n   407Ôćĺ}\n   408Ôćĺ\n   409Ôćĺfunc TestExecutor_ScriptStep_NoTaskID(t *testing.T) {\n   410Ôćĺ\ttmpDir := t.TempDir()\n   411Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   412Ôćĺ\n   413Ôćĺ\texecutor := &Executor{\n   414Ôćĺ\t\tProjectDir: tmpDir,\n   415Ôćĺ\t\tOutputDir:  outputDir,\n   416Ôćĺ\t\t// No TaskID set\n   417Ôćĺ\t}\n   418Ôćĺ\n   419Ôćĺ\tstep := &domain.Step{\n   420Ôćĺ\t\tName:    \"task-check\",\n   421Ôćĺ\t\tType:    domain.StepTypeScript,\n   422Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   423Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo \\\"TASK_ID=$CLOCHE_TASK_ID\\\"\"},\n   424Ôćĺ\t}\n   425Ôćĺ\n   426Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   427Ôćĺ\trequire.NoError(t, err)\n   428Ôćĺ\tassert.Equal(t, \"success\", result)\n   429Ôćĺ\n   430Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"task-check.out\"))\n   431Ôćĺ\trequire.NoError(t, err)\n   432Ôćĺ\t// When no TaskID is set, CLOCHE_TASK_ID should not appear in the env\n   433Ôćĺ\tassert.Contains(t, string(data), \"TASK_ID=\\n\")\n   434Ôćĺ}\n   435Ôćĺ\n   436Ôćĺfunc TestExecutor_ScriptStep_NoOutputMappings(t *testing.T) {\n   437Ôćĺ\ttmpDir := t.TempDir()\n   438Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   439Ôćĺ\n   440Ôćĺ\texecutor := &Executor{\n   441Ôćĺ\t\tProjectDir: tmpDir,\n   442Ôćĺ\t\tOutputDir:  outputDir,\n   443Ôćĺ\t\tWires: []domain.Wire{\n   444Ôćĺ\t\t\t{From: \"step-a\", Result: \"success\", To: \"step-b\"},\n   445Ôćĺ\t\t},\n   446Ôćĺ\t}\n   447Ôćĺ\n   448Ôćĺ\tstep := &domain.Step{\n   449Ôćĺ\t\tName:    \"step-b\",\n   450Ôćĺ\t\tType:    domain.StepTypeScript,\n   451Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   452Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   453Ôćĺ\t}\n   454Ôćĺ\n   455Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   456Ôćĺ\trequire.NoError(t, err)\n   457Ôćĺ\tassert.Equal(t, \"success\", result)\n   458Ôćĺ}\n   459Ôćĺ\n   460Ôćĺfunc TestExecutor_ScriptStep_OutputMappings_JSONFields(t *testing.T) {\n   461Ôćĺ\ttmpDir := t.TempDir()\n   462Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   463Ôćĺ\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   464Ôćĺ\n   465Ôćĺ\t// Write source step output as JSON\n   466Ôćĺ\tsourceJSON := `{\"title\": \"Fix bug\", \"priority\": \"high\"}`\n   467Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"get-tasks.out\"), []byte(sourceJSON), 0644))\n   468Ôćĺ\n   469Ôćĺ\texecutor := &Executor{\n   470Ôćĺ\t\tProjectDir: tmpDir,\n   471Ôćĺ\t\tOutputDir:  outputDir,\n   472Ôćĺ\t\tWires: []domain.Wire{\n   473Ôćĺ\t\t\t{\n   474Ôćĺ\t\t\t\tFrom:   \"get-tasks\",\n   475Ôćĺ\t\t\t\tResult: \"success\",\n   476Ôćĺ\t\t\t\tTo:     \"use-tasks\",\n   477Ôćĺ\t\t\t\tOutputMap: []domain.OutputMapping{\n   478Ôćĺ\t\t\t\t\t{\n   479Ôćĺ\t\t\t\t\t\tEnvVar: \"TASK_TITLE\",\n   480Ôćĺ\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"title\"}}},\n   481Ôćĺ\t\t\t\t\t},\n   482Ôćĺ\t\t\t\t\t{\n   483Ôćĺ\t\t\t\t\t\tEnvVar: \"TASK_PRIORITY\",\n   484Ôćĺ\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"priority\"}}},\n   485Ôćĺ\t\t\t\t\t},\n   486Ôćĺ\t\t\t\t},\n   487Ôćĺ\t\t\t},\n   488Ôćĺ\t\t},\n   489Ôćĺ\t}\n   490Ôćĺ\n   491Ôćĺ\tstep := &domain.Step{\n   492Ôćĺ\t\tName:    \"use-tasks\",\n   493Ôćĺ\t\tType:    domain.StepTypeScript,\n   494Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   495Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo $TASK_TITLE $TASK_PRIORITY\"},\n   496Ôćĺ\t}\n   497Ôćĺ\n   498Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   499Ôćĺ\trequire.NoError(t, err)\n   500Ôćĺ\tassert.Equal(t, \"success\", result)\n   501Ôćĺ\n   502Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"use-tasks.out\"))\n   503Ôćĺ\trequire.NoError(t, err)\n   504Ôćĺ\tassert.Contains(t, string(data), \"Fix bug\")\n   505Ôćĺ\tassert.Contains(t, string(data), \"high\")\n   506Ôćĺ}\n   507Ôćĺ\n   508Ôćĺfunc TestExecutor_ScriptStep_OutputMappings_ArrayIndex(t *testing.T) {\n   509Ôćĺ\ttmpDir := t.TempDir()\n   510Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   511Ôćĺ\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   512Ôćĺ\n   513Ôćĺ\t// Write source step output as JSON array\n   514Ôćĺ\tsourceJSON := `[{\"id\": \"task-1\", \"title\": \"First\"}, {\"id\": \"task-2\", \"title\": \"Second\"}]`\n   515Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"list-tasks.out\"), []byte(sourceJSON), 0644))\n   516Ôćĺ\n   517Ôćĺ\texecutor := &Executor{\n   518Ôćĺ\t\tProjectDir: tmpDir,\n   519Ôćĺ\t\tOutputDir:  outputDir,\n   520Ôćĺ\t\tWires: []domain.Wire{\n   521Ôćĺ\t\t\t{\n   522Ôćĺ\t\t\t\tFrom:   \"list-tasks\",\n   523Ôćĺ\t\t\t\tResult: \"success\",\n   524Ôćĺ\t\t\t\tTo:     \"process\",\n   525Ôćĺ\t\t\t\tOutputMap: []domain.OutputMapping{\n   526Ôćĺ\t\t\t\t\t{\n   527Ôćĺ\t\t\t\t\t\tEnvVar: \"FIRST_ID\",\n   528Ôćĺ\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n   529Ôćĺ\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 0},\n   530Ôćĺ\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"id\"},\n   531Ôćĺ\t\t\t\t\t\t}},\n   532Ôćĺ\t\t\t\t\t},\n   533Ôćĺ\t\t\t\t\t{\n   534Ôćĺ\t\t\t\t\t\tEnvVar: \"SECOND_TITLE\",\n   535Ôćĺ\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n   536Ôćĺ\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 1},\n   537Ôćĺ\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"title\"},\n   538Ôćĺ\t\t\t\t\t\t}},\n   539Ôćĺ\t\t\t\t\t},\n   540Ôćĺ\t\t\t\t},\n   541Ôćĺ\t\t\t},\n   542Ôćĺ\t\t},\n   543Ôćĺ\t}\n   544Ôćĺ\n   545Ôćĺ\tstep := &domain.Step{\n   546Ôćĺ\t\tName:    \"process\",\n   547Ôćĺ\t\tType:    domain.StepTypeScript,\n   548Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   549Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo $FIRST_ID $SECOND_TITLE\"},\n   550Ôćĺ\t}\n   551Ôćĺ\n   552Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   553Ôćĺ\trequire.NoError(t, err)\n   554Ôćĺ\tassert.Equal(t, \"success\", result)\n   555Ôćĺ\n   556Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"process.out\"))\n   557Ôćĺ\trequire.NoError(t, err)\n   558Ôćĺ\tassert.Contains(t, string(data), \"task-1\")\n   559Ôćĺ\tassert.Contains(t, string(data), \"Second\")\n   560Ôćĺ}\n   561Ôćĺ\n   562Ôćĺfunc TestExecutor_ScriptStep_OutputMappings_MissingSourceOutput(t *testing.T) {\n   563Ôćĺ\ttmpDir := t.TempDir()\n   564Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   565Ôćĺ\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   566Ôćĺ\n   567Ôćĺ\t// No source output file written\n   568Ôćĺ\n   569Ôćĺ\texecutor := &Executor{\n   570Ôćĺ\t\tProjectDir: tmpDir,\n   571Ôćĺ\t\tOutputDir:  outputDir,\n   572Ôćĺ\t\tWires: []domain.Wire{\n   573Ôćĺ\t\t\t{\n   574Ôćĺ\t\t\t\tFrom:   \"missing-step\",\n   575Ôćĺ\t\t\t\tResult: \"success\",\n   576Ôćĺ\t\t\t\tTo:     \"consumer\",\n   577Ôćĺ\t\t\t\tOutputMap: []domain.OutputMapping{\n   578Ôćĺ\t\t\t\t\t{\n   579Ôćĺ\t\t\t\t\t\tEnvVar: \"VAL\",\n   580Ôćĺ\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n   581Ôćĺ\t\t\t\t\t},\n   582Ôćĺ\t\t\t\t},\n   583Ôćĺ\t\t\t},\n   584Ôćĺ\t\t},\n   585Ôćĺ\t}\n   586Ôćĺ\n   587Ôćĺ\tstep := &domain.Step{\n   588Ôćĺ\t\tName:    \"consumer\",\n   589Ôćĺ\t\tType:    domain.StepTypeScript,\n   590Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   591Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   592Ôćĺ\t}\n   593Ôćĺ\n   594Ôćĺ\t_, err := executor.Execute(context.Background(), step)\n   595Ôćĺ\trequire.Error(t, err)\n   596Ôćĺ\tassert.Contains(t, err.Error(), \"reading output of missing-step\")\n   597Ôćĺ}\n   598Ôćĺ\n   599Ôćĺfunc TestExecutor_ScriptStep_OutputMappings_NotJSON(t *testing.T) {\n   600Ôćĺ\ttmpDir := t.TempDir()\n   601Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   602Ôćĺ\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   603Ôćĺ\n   604Ôćĺ\t// Write non-JSON output\n   605Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"plain.out\"), []byte(\"not json\"), 0644))\n   606Ôćĺ\n   607Ôćĺ\texecutor := &Executor{\n   608Ôćĺ\t\tProjectDir: tmpDir,\n   609Ôćĺ\t\tOutputDir:  outputDir,\n   610Ôćĺ\t\tWires: []domain.Wire{\n   611Ôćĺ\t\t\t{\n   612Ôćĺ\t\t\t\tFrom:   \"plain\",\n   613Ôćĺ\t\t\t\tResult: \"success\",\n   614Ôćĺ\t\t\t\tTo:     \"consumer\",\n   615Ôćĺ\t\t\t\tOutputMap: []domain.OutputMapping{\n   616Ôćĺ\t\t\t\t\t{\n   617Ôćĺ\t\t\t\t\t\tEnvVar: \"VAL\",\n   618Ôćĺ\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n   619Ôćĺ\t\t\t\t\t},\n   620Ôćĺ\t\t\t\t},\n   621Ôćĺ\t\t\t},\n   622Ôćĺ\t\t},\n   623Ôćĺ\t}\n   624Ôćĺ\n   625Ôćĺ\tstep := &domain.Step{\n   626Ôćĺ\t\tName:    \"consumer\",\n   627Ôćĺ\t\tType:    domain.StepTypeScript,\n   628Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   629Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   630Ôćĺ\t}\n   631Ôćĺ\n   632Ôćĺ\t_, err := executor.Execute(context.Background(), step)\n   633Ôćĺ\trequire.Error(t, err)\n   634Ôćĺ\tassert.Contains(t, err.Error(), \"not valid JSON\")\n   635Ôćĺ}\n   636Ôćĺ\n   637Ôćĺfunc TestRunner_RunWithID(t *testing.T) {\n   638Ôćĺ\ttmpDir := t.TempDir()\n   639Ôćĺ\n   640Ôćĺ\t// Write a simple host.cloche\n   641Ôćĺ\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   642Ôćĺ\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   643Ôćĺ\thostCloche := `workflow \"main\" {\n   644Ôćĺ  step greet {\n   645Ôćĺ    run     = \"echo hi\"\n   646Ôćĺ    results = [success, fail]\n   647Ôćĺ  }\n   648Ôćĺ\n   649Ôćĺ  greet:success -> done\n   650Ôćĺ  greet:fail    -> abort\n   651Ôćĺ}`\n   652Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   653Ôćĺ\n   654Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   655Ôćĺ\n   656Ôćĺ\trunner := &Runner{\n   657Ôćĺ\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   658Ôćĺ\t\tStore:      store,\n   659Ôćĺ\t}\n   660Ôćĺ\n   661Ôćĺ\tcustomID := \"my-custom-run-id\"\n   662Ôćĺ\tresult, err := runner.RunWithID(context.Background(), tmpDir, customID)\n   663Ôćĺ\trequire.NoError(t, err)\n   664Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n   665Ôćĺ\tassert.Equal(t, customID, result.RunID, \"RunWithID should use the provided ID\")\n   666Ôćĺ\n   667Ôćĺ\t// Verify the run was persisted with the custom ID\n   668Ôćĺ\thostRun, err := store.GetRun(context.Background(), customID)\n   669Ôćĺ\trequire.NoError(t, err)\n   670Ôćĺ\tassert.True(t, hostRun.IsHost)\n   671Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n   672Ôćĺ}\n   673Ôćĺ\n   674Ôćĺfunc TestRunner_WithTaskID(t *testing.T) {\n   675Ôćĺ\ttmpDir := t.TempDir()\n   676Ôćĺ\n   677Ôćĺ\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   678Ôćĺ\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   679Ôćĺ\t// The script echoes the daemon-assigned CLOCHE_TASK_ID env var\n   680Ôćĺ\thostCloche := `workflow \"main\" {\n   681Ôćĺ  step check-task {\n   682Ôćĺ    run     = \"echo $CLOCHE_TASK_ID\"\n   683Ôćĺ    results = [success, fail]\n   684Ôćĺ  }\n   685Ôćĺ\n   686Ôćĺ  check-task:success -> done\n   687Ôćĺ  check-task:fail    -> abort\n   688Ôćĺ}`\n   689Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   690Ôćĺ\n   691Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   692Ôćĺ\n   693Ôćĺ\trunner := &Runner{\n   694Ôćĺ\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   695Ôćĺ\t\tStore:      store,\n   696Ôćĺ\t\tTaskID:     \"daemon-assigned-task-99\",\n   697Ôćĺ\t}\n   698Ôćĺ\n   699Ôćĺ\tresult, err := runner.Run(context.Background(), tmpDir)\n   700Ôćĺ\trequire.NoError(t, err)\n   701Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n   702Ôćĺ\n   703Ôćĺ\t// Verify the script saw the task ID\n   704Ôćĺ\toutputDir := filepath.Join(tmpDir, \".cloche\", result.RunID, \"output\")\n   705Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"check-task.out\"))\n   706Ôćĺ\trequire.NoError(t, err)\n   707Ôćĺ\tassert.Contains(t, string(data), \"daemon-assigned-task-99\")\n   708Ôćĺ}\n   709Ôćĺ\n   710Ôćĺfunc TestRunner_PersistsHostRun(t *testing.T) {\n   711Ôćĺ\ttmpDir := t.TempDir()\n   712Ôćĺ\n   713Ôćĺ\t// Write a simple host.cloche\n   714Ôćĺ\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   715Ôćĺ\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   716Ôćĺ\thostCloche := `workflow \"main\" {\n   717Ôćĺ  step prepare {\n   718Ôćĺ    run     = \"echo prepared\"\n   719Ôćĺ    results = [success, fail]\n   720Ôćĺ  }\n   721Ôćĺ\n   722Ôćĺ  prepare:success -> done\n   723Ôćĺ  prepare:fail    -> abort\n   724Ôćĺ}`\n   725Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   726Ôćĺ\n   727Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   728Ôćĺ\n   729Ôćĺ\trunner := &Runner{\n   730Ôćĺ\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   731Ôćĺ\t\tStore:      store,\n   732Ôćĺ\t}\n   733Ôćĺ\n   734Ôćĺ\tresult, err := runner.Run(context.Background(), tmpDir)\n   735Ôćĺ\trequire.NoError(t, err)\n   736Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n   737Ôćĺ\tassert.NotEmpty(t, result.RunID)\n   738Ôćĺ\n   739Ôćĺ\t// Verify the host run was persisted in the store\n   740Ôćĺ\thostRun, err := store.GetRun(context.Background(), result.RunID)\n   741Ôćĺ\trequire.NoError(t, err)\n   742Ôćĺ\tassert.True(t, hostRun.IsHost, \"host run should have IsHost=true\")\n   743Ôćĺ\tassert.Equal(t, tmpDir, hostRun.ProjectDir)\n   744Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n   745Ôćĺ\tassert.False(t, hostRun.StartedAt.IsZero())\n   746Ôćĺ\tassert.False(t, hostRun.CompletedAt.IsZero())\n   747Ôćĺ}\n   748Ôćĺ\n   749Ôćĺfunc TestExecutor_ScriptStep_UsesMainDir(t *testing.T) {\n   750Ôćĺ\t// ProjectDir has no script; MainDir has the script.\n   751Ôćĺ\tprojectDir := t.TempDir()\n   752Ôćĺ\tmainDir := t.TempDir()\n   753Ôćĺ\toutputDir := filepath.Join(projectDir, \"output\")\n   754Ôćĺ\n   755Ôćĺ\t// Create a script only in mainDir\n   756Ôćĺ\tscriptDir := filepath.Join(mainDir, \".cloche\", \"scripts\")\n   757Ôćĺ\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n   758Ôćĺ\trequire.NoError(t, os.WriteFile(\n   759Ôćĺ\t\tfilepath.Join(scriptDir, \"greet.sh\"),\n   760Ôćĺ\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n   761Ôćĺ\t\t0755,\n   762Ôćĺ\t))\n   763Ôćĺ\n   764Ôćĺ\texecutor := &Executor{\n   765Ôćĺ\t\tProjectDir: projectDir,\n   766Ôćĺ\t\tMainDir:    mainDir,\n   767Ôćĺ\t\tOutputDir:  outputDir,\n   768Ôćĺ\t}\n   769Ôćĺ\n   770Ôćĺ\tstep := &domain.Step{\n   771Ôćĺ\t\tName:    \"greet\",\n   772Ôćĺ\t\tType:    domain.StepTypeScript,\n   773Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   774Ôćĺ\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/greet.sh\"},\n   775Ôćĺ\t}\n   776Ôćĺ\n   777Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   778Ôćĺ\trequire.NoError(t, err)\n   779Ôćĺ\tassert.Equal(t, \"success\", result)\n   780Ôćĺ\n   781Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n   782Ôćĺ\trequire.NoError(t, err)\n   783Ôćĺ\tassert.Contains(t, string(data), \"from-main\")\n   784Ôćĺ}\n   785Ôćĺ\n   786Ôćĺfunc TestExecutor_ScriptStep_MainDirOverridesProjectDir(t *testing.T) {\n   787Ôćĺ\t// Both dirs have a script with different content; MainDir's version wins.\n   788Ôćĺ\tprojectDir := t.TempDir()\n   789Ôćĺ\tmainDir := t.TempDir()\n   790Ôćĺ\toutputDir := filepath.Join(projectDir, \"output\")\n   791Ôćĺ\n   792Ôćĺ\t// Create script in both dirs with different content\n   793Ôćĺ\tfor _, dir := range []string{projectDir, mainDir} {\n   794Ôćĺ\t\tscriptDir := filepath.Join(dir, \".cloche\", \"scripts\")\n   795Ôćĺ\t\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n   796Ôćĺ\t}\n   797Ôćĺ\trequire.NoError(t, os.WriteFile(\n   798Ôćĺ\t\tfilepath.Join(projectDir, \".cloche\", \"scripts\", \"hello.sh\"),\n   799Ôćĺ\t\t[]byte(\"#!/bin/sh\\necho from-branch\"),\n   800Ôćĺ\t\t0755,\n   801Ôćĺ\t))\n   802Ôćĺ\trequire.NoError(t, os.WriteFile(\n   803Ôćĺ\t\tfilepath.Join(mainDir, \".cloche\", \"scripts\", \"hello.sh\"),\n   804Ôćĺ\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n   805Ôćĺ\t\t0755,\n   806Ôćĺ\t))\n   807Ôćĺ\n   808Ôćĺ\texecutor := &Executor{\n   809Ôćĺ\t\tProjectDir: projectDir,\n   810Ôćĺ\t\tMainDir:    mainDir,\n   811Ôćĺ\t\tOutputDir:  outputDir,\n   812Ôćĺ\t}\n   813Ôćĺ\n   814Ôćĺ\tstep := &domain.Step{\n   815Ôćĺ\t\tName:    \"hello\",\n   816Ôćĺ\t\tType:    domain.StepTypeScript,\n   817Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   818Ôćĺ\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/hello.sh\"},\n   819Ôćĺ\t}\n   820Ôćĺ\n   821Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   822Ôćĺ\trequire.NoError(t, err)\n   823Ôćĺ\tassert.Equal(t, \"success\", result)\n   824Ôćĺ\n   825Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"hello.out\"))\n   826Ôćĺ\trequire.NoError(t, err)\n   827Ôćĺ\tassert.Contains(t, string(data), \"from-main\")\n   828Ôćĺ\tassert.NotContains(t, string(data), \"from-branch\")\n   829Ôćĺ}\n   830Ôćĺ\n   831Ôćĺfunc TestExecutor_ScriptStep_FallsBackToProjectDir(t *testing.T) {\n   832Ôćĺ\t// When MainDir is empty, scripts resolve from ProjectDir.\n   833Ôćĺ\tprojectDir := t.TempDir()\n   834Ôćĺ\toutputDir := filepath.Join(projectDir, \"output\")\n   835Ôćĺ\n   836Ôćĺ\texecutor := &Executor{\n   837Ôćĺ\t\tProjectDir: projectDir,\n   838Ôćĺ\t\tOutputDir:  outputDir,\n   839Ôćĺ\t}\n   840Ôćĺ\n   841Ôćĺ\tstep := &domain.Step{\n   842Ôćĺ\t\tName:    \"pwd-check\",\n   843Ôćĺ\t\tType:    domain.StepTypeScript,\n   844Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   845Ôćĺ\t\tConfig:  map[string]string{\"run\": \"pwd\"},\n   846Ôćĺ\t}\n   847Ôćĺ\n   848Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   849Ôćĺ\trequire.NoError(t, err)\n   850Ôćĺ\tassert.Equal(t, \"success\", result)\n   851Ôćĺ\n   852Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"pwd-check.out\"))\n   853Ôćĺ\trequire.NoError(t, err)\n   854Ôćĺ\tassert.Contains(t, string(data), projectDir)\n   855Ôćĺ}\n   856Ôćĺ\n   857Ôćĺfunc TestExecutor_ScriptStep_ProjectDirEnvVar(t *testing.T) {\n   858Ôćĺ\t// CLOCHE_PROJECT_DIR should always point to ProjectDir, not MainDir.\n   859Ôćĺ\tprojectDir := t.TempDir()\n   860Ôćĺ\tmainDir := t.TempDir()\n   861Ôćĺ\toutputDir := filepath.Join(projectDir, \"output\")\n   862Ôćĺ\n   863Ôćĺ\texecutor := &Executor{\n   864Ôćĺ\t\tProjectDir: projectDir,\n   865Ôćĺ\t\tMainDir:    mainDir,\n   866Ôćĺ\t\tOutputDir:  outputDir,\n   867Ôćĺ\t}\n   868Ôćĺ\n   869Ôćĺ\tstep := &domain.Step{\n   870Ôćĺ\t\tName:    \"env-check\",\n   871Ôćĺ\t\tType:    domain.StepTypeScript,\n   872Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   873Ôćĺ\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n   874Ôćĺ\t}\n   875Ôćĺ\n   876Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   877Ôćĺ\trequire.NoError(t, err)\n   878Ôćĺ\tassert.Equal(t, \"success\", result)\n   879Ôćĺ\n   880Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n   881Ôćĺ\trequire.NoError(t, err)\n   882Ôćĺ\tassert.Contains(t, string(data), projectDir)\n   883Ôćĺ\tassert.NotContains(t, string(data), mainDir)\n   884Ôćĺ}\n   885Ôćĺ\n   886Ôćĺfunc TestMainWorktreeDir_NonGitDir(t *testing.T) {\n   887Ôćĺ\ttmpDir := t.TempDir()\n   888Ôćĺ\t// Non-git directory should fall back to projectDir.\n   889Ôćĺ\tresult := MainWorktreeDir(tmpDir)\n   890Ôćĺ\tassert.Equal(t, tmpDir, result)\n   891Ôćĺ}\n   892Ôćĺ\n   893Ôćĺfunc TestMainWorktreeDir_WithWorktree(t *testing.T) {\n   894Ôćĺ\t// Set up a real git repo with a linked worktree.\n   895Ôćĺ\tmainDir := t.TempDir()\n   896Ôćĺ\n   897Ôćĺ\t// Initialize git repo\n   898Ôćĺ\trun := func(dir string, args ...string) {\n   899Ôćĺ\t\tt.Helper()\n   900Ôćĺ\t\tcmd := exec.Command(args[0], args[1:]...)\n   901Ôćĺ\t\tcmd.Dir = dir\n   902Ôćĺ\t\tout, err := cmd.CombinedOutput()\n   903Ôćĺ\t\trequire.NoError(t, err, \"command %v failed: %s\", args, out)\n   904Ôćĺ\t}\n   905Ôćĺ\n   906Ôćĺ\trun(mainDir, \"git\", \"init\")\n   907Ôćĺ\trun(mainDir, \"git\", \"config\", \"user.email\", \"test@test.com\")\n   908Ôćĺ\trun(mainDir, \"git\", \"config\", \"user.name\", \"Test\")\n   909Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(mainDir, \"file.txt\"), []byte(\"hello\"), 0644))\n   910Ôćĺ\trun(mainDir, \"git\", \"add\", \".\")\n   911Ôćĺ\trun(mainDir, \"git\", \"commit\", \"-m\", \"initial\")\n   912Ôćĺ\n   913Ôćĺ\t// Create a branch and worktree\n   914Ôćĺ\tworktreeDir := filepath.Join(t.TempDir(), \"wt\")\n   915Ôćĺ\trun(mainDir, \"git\", \"worktree\", \"add\", worktreeDir, \"-b\", \"feature\")\n   916Ôćĺ\n   917Ôćĺ\t// MainWorktreeDir from the linked worktree should return mainDir.\n   918Ôćĺ\tresult := MainWorktreeDir(worktreeDir)\n   919Ôćĺ\tassert.Equal(t, mainDir, result)\n   920Ôćĺ\n   921Ôćĺ\t// MainWorktreeDir from main should return mainDir.\n   922Ôćĺ\tresult = MainWorktreeDir(mainDir)\n   923Ôćĺ\tassert.Equal(t, mainDir, result)\n   924Ôćĺ}\n   925Ôćĺ\n   926Ôćĺfunc TestExecutor_AgentStep_Success(t *testing.T) {\n   927Ôćĺ\ttmpDir := t.TempDir()\n   928Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   929Ôćĺ\n   930Ôćĺ\t// Create a mock agent script that reads stdin and produces output\n   931Ôćĺ\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n   932Ôćĺ\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent did the work'\\n\"), 0755))\n   933Ôćĺ\n   934Ôćĺ\texecutor := &Executor{\n   935Ôćĺ\t\tProjectDir: tmpDir,\n   936Ôćĺ\t\tOutputDir:  outputDir,\n   937Ôćĺ\t\tHostRunID:  \"test-host-run\",\n   938Ôćĺ\t}\n   939Ôćĺ\n   940Ôćĺ\tstep := &domain.Step{\n   941Ôćĺ\t\tName:    \"implement\",\n   942Ôćĺ\t\tType:    domain.StepTypeAgent,\n   943Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   944Ôćĺ\t\tConfig: map[string]string{\n   945Ôćĺ\t\t\t\"prompt\":        \"You are a coding assistant.\",\n   946Ôćĺ\t\t\t\"agent_command\": mockAgent,\n   947Ôćĺ\t\t},\n   948Ôćĺ\t}\n   949Ôćĺ\n   950Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   951Ôćĺ\trequire.NoError(t, err)\n   952Ôćĺ\tassert.Equal(t, \"success\", result)\n   953Ôćĺ\n   954Ôćĺ\t// Check output was copied to executor's output path\n   955Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n   956Ôćĺ\trequire.NoError(t, err)\n   957Ôćĺ\tassert.Contains(t, string(data), \"agent did the work\")\n   958Ôćĺ}\n   959Ôćĺ\n   960Ôćĺfunc TestExecutor_AgentStep_Failure(t *testing.T) {\n   961Ôćĺ\ttmpDir := t.TempDir()\n   962Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   963Ôćĺ\n   964Ôćĺ\t// Create a mock agent that reports failure via result marker\n   965Ôćĺ\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n   966Ôćĺ\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'something went wrong'\\necho 'CLOCHE_RESULT:fail'\\n\"), 0755))\n   967Ôćĺ\n   968Ôćĺ\texecutor := &Executor{\n   969Ôćĺ\t\tProjectDir: tmpDir,\n   970Ôćĺ\t\tOutputDir:  outputDir,\n   971Ôćĺ\t\tHostRunID:  \"test-host-run\",\n   972Ôćĺ\t}\n   973Ôćĺ\n   974Ôćĺ\tstep := &domain.Step{\n   975Ôćĺ\t\tName:    \"implement\",\n   976Ôćĺ\t\tType:    domain.StepTypeAgent,\n   977Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n   978Ôćĺ\t\tConfig: map[string]string{\n   979Ôćĺ\t\t\t\"prompt\":        \"You are a coding assistant.\",\n   980Ôćĺ\t\t\t\"agent_command\": mockAgent,\n   981Ôćĺ\t\t},\n   982Ôćĺ\t}\n   983Ôćĺ\n   984Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n   985Ôćĺ\trequire.NoError(t, err)\n   986Ôćĺ\tassert.Equal(t, \"fail\", result)\n   987Ôćĺ}\n   988Ôćĺ\n   989Ôćĺfunc TestExecutor_AgentStep_WorkflowLevelCommand(t *testing.T) {\n   990Ôćĺ\ttmpDir := t.TempDir()\n   991Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n   992Ôćĺ\n   993Ôćĺ\t// Create a mock agent\n   994Ôćĺ\tmockAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n   995Ôćĺ\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow agent ran'\\n\"), 0755))\n   996Ôćĺ\n   997Ôćĺ\texecutor := &Executor{\n   998Ôćĺ\t\tProjectDir:    tmpDir,\n   999Ôćĺ\t\tOutputDir:     outputDir,\n  1000Ôćĺ\t\tHostRunID:     \"test-host-run\",\n  1001Ôćĺ\t\tAgentCommands: []string{mockAgent},\n  1002Ôćĺ\t}\n  1003Ôćĺ\n  1004Ôćĺ\tstep := &domain.Step{\n  1005Ôćĺ\t\tName:    \"implement\",\n  1006Ôćĺ\t\tType:    domain.StepTypeAgent,\n  1007Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n  1008Ôćĺ\t\tConfig: map[string]string{\n  1009Ôćĺ\t\t\t\"prompt\": \"Write some code.\",\n  1010Ôćĺ\t\t},\n  1011Ôćĺ\t}\n  1012Ôćĺ\n  1013Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n  1014Ôćĺ\trequire.NoError(t, err)\n  1015Ôćĺ\tassert.Equal(t, \"success\", result)\n  1016Ôćĺ\n  1017Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n  1018Ôćĺ\trequire.NoError(t, err)\n  1019Ôćĺ\tassert.Contains(t, string(data), \"workflow agent ran\")\n  1020Ôćĺ}\n  1021Ôćĺ\n  1022Ôćĺfunc TestExecutor_AgentStep_StepLevelOverridesWorkflow(t *testing.T) {\n  1023Ôćĺ\ttmpDir := t.TempDir()\n  1024Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n  1025Ôćĺ\n  1026Ôćĺ\t// Create two mock agents\n  1027Ôćĺ\tworkflowAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n  1028Ôćĺ\trequire.NoError(t, os.WriteFile(workflowAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow agent'\\n\"), 0755))\n  1029Ôćĺ\n  1030Ôćĺ\tstepAgent := filepath.Join(tmpDir, \"step-agent.sh\")\n  1031Ôćĺ\trequire.NoError(t, os.WriteFile(stepAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'step agent'\\n\"), 0755))\n  1032Ôćĺ\n  1033Ôćĺ\texecutor := &Executor{\n  1034Ôćĺ\t\tProjectDir:    tmpDir,\n  1035Ôćĺ\t\tOutputDir:     outputDir,\n  1036Ôćĺ\t\tHostRunID:     \"test-host-run\",\n  1037Ôćĺ\t\tAgentCommands: []string{workflowAgent},\n  1038Ôćĺ\t}\n  1039Ôćĺ\n  1040Ôćĺ\tstep := &domain.Step{\n  1041Ôćĺ\t\tName:    \"implement\",\n  1042Ôćĺ\t\tType:    domain.StepTypeAgent,\n  1043Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n  1044Ôćĺ\t\tConfig: map[string]string{\n  1045Ôćĺ\t\t\t\"prompt\":        \"Write some code.\",\n  1046Ôćĺ\t\t\t\"agent_command\": stepAgent,\n  1047Ôćĺ\t\t},\n  1048Ôćĺ\t}\n  1049Ôćĺ\n  1050Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n  1051Ôćĺ\trequire.NoError(t, err)\n  1052Ôćĺ\tassert.Equal(t, \"success\", result)\n  1053Ôćĺ\n  1054Ôćĺ\t// Step-level agent should have run, not workflow-level\n  1055Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n  1056Ôćĺ\trequire.NoError(t, err)\n  1057Ôćĺ\tassert.Contains(t, string(data), \"step agent\")\n  1058Ôćĺ\tassert.NotContains(t, string(data), \"workflow agent\")\n  1059Ôćĺ}\n  1060Ôćĺ\n  1061Ôćĺfunc TestExecutor_AgentStep_FallbackChain(t *testing.T) {\n  1062Ôćĺ\ttmpDir := t.TempDir()\n  1063Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n  1064Ôćĺ\n  1065Ôćĺ\t// Create a good agent\n  1066Ôćĺ\tgoodAgent := filepath.Join(tmpDir, \"good-agent.sh\")\n  1067Ôćĺ\trequire.NoError(t, os.WriteFile(goodAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'fallback agent ran'\\n\"), 0755))\n  1068Ôćĺ\n  1069Ôćĺ\texecutor := &Executor{\n  1070Ôćĺ\t\tProjectDir: tmpDir,\n  1071Ôćĺ\t\tOutputDir:  outputDir,\n  1072Ôćĺ\t\tHostRunID:  \"test-host-run\",\n  1073Ôćĺ\t}\n  1074Ôćĺ\n  1075Ôćĺ\t// Use nonexistent command as primary, good agent as fallback\n  1076Ôćĺ\tstep := &domain.Step{\n  1077Ôćĺ\t\tName:    \"implement\",\n  1078Ôćĺ\t\tType:    domain.StepTypeAgent,\n  1079Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n  1080Ôćĺ\t\tConfig: map[string]string{\n  1081Ôćĺ\t\t\t\"prompt\":        \"Write some code.\",\n  1082Ôćĺ\t\t\t\"agent_command\": \"nonexistent-agent-xyz,\" + goodAgent,\n  1083Ôćĺ\t\t},\n  1084Ôćĺ\t}\n  1085Ôćĺ\n  1086Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n  1087Ôćĺ\trequire.NoError(t, err)\n  1088Ôćĺ\tassert.Equal(t, \"success\", result)\n  1089Ôćĺ\n  1090Ôćĺ\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n  1091Ôćĺ\trequire.NoError(t, err)\n  1092Ôćĺ\tassert.Contains(t, string(data), \"fallback agent ran\")\n  1093Ôćĺ}\n  1094Ôćĺ\n  1095Ôćĺfunc TestExecutor_AgentStep_PrevOutput(t *testing.T) {\n  1096Ôćĺ\ttmpDir := t.TempDir()\n  1097Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n  1098Ôćĺ\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n  1099Ôćĺ\n  1100Ôćĺ\t// Write previous step output\n  1101Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"prepare.out\"), []byte(\"the task description\"), 0644))\n  1102Ôćĺ\n  1103Ôćĺ\t// Create a mock agent that echoes stdin (the prompt) to verify it received it\n  1104Ôćĺ\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1105Ôćĺ\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'processed prompt'\\n\"), 0755))\n  1106Ôćĺ\n  1107Ôćĺ\texecutor := &Executor{\n  1108Ôćĺ\t\tProjectDir: tmpDir,\n  1109Ôćĺ\t\tOutputDir:  outputDir,\n  1110Ôćĺ\t\tHostRunID:  \"test-host-run\",\n  1111Ôćĺ\t\tWires: []domain.Wire{\n  1112Ôćĺ\t\t\t{From: \"prepare\", Result: \"success\", To: \"implement\"},\n  1113Ôćĺ\t\t},\n  1114Ôćĺ\t}\n  1115Ôćĺ\n  1116Ôćĺ\tstep := &domain.Step{\n  1117Ôćĺ\t\tName:    \"implement\",\n  1118Ôćĺ\t\tType:    domain.StepTypeAgent,\n  1119Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n  1120Ôćĺ\t\tConfig: map[string]string{\n  1121Ôćĺ\t\t\t\"prompt\":        \"You are a coding assistant.\",\n  1122Ôćĺ\t\t\t\"agent_command\": mockAgent,\n  1123Ôćĺ\t\t},\n  1124Ôćĺ\t}\n  1125Ôćĺ\n  1126Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n  1127Ôćĺ\trequire.NoError(t, err)\n  1128Ôćĺ\tassert.Equal(t, \"success\", result)\n  1129Ôćĺ\n  1130Ôćĺ\t// Verify prompt.txt was written with previous step's output\n  1131Ôćĺ\tpromptPath := filepath.Join(tmpDir, \".cloche\", \"test-host-run\", \"prompt.txt\")\n  1132Ôćĺ\tdata, err := os.ReadFile(promptPath)\n  1133Ôćĺ\trequire.NoError(t, err)\n  1134Ôćĺ\tassert.Equal(t, \"the task description\", string(data))\n  1135Ôćĺ}\n  1136Ôćĺ\n  1137Ôćĺfunc TestExecutor_AgentStep_PromptStep(t *testing.T) {\n  1138Ôćĺ\ttmpDir := t.TempDir()\n  1139Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n  1140Ôćĺ\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n  1141Ôćĺ\n  1142Ôćĺ\t// Write a specific step's output\n  1143Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"custom-source.out\"), []byte(\"custom prompt content\"), 0644))\n  1144Ôćĺ\n  1145Ôćĺ\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1146Ôćĺ\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'done'\\n\"), 0755))\n  1147Ôćĺ\n  1148Ôćĺ\texecutor := &Executor{\n  1149Ôćĺ\t\tProjectDir: tmpDir,\n  1150Ôćĺ\t\tOutputDir:  outputDir,\n  1151Ôćĺ\t\tHostRunID:  \"test-host-run\",\n  1152Ôćĺ\t}\n  1153Ôćĺ\n  1154Ôćĺ\tstep := &domain.Step{\n  1155Ôćĺ\t\tName:    \"implement\",\n  1156Ôćĺ\t\tType:    domain.StepTypeAgent,\n  1157Ôćĺ\t\tResults: []string{\"success\", \"fail\"},\n  1158Ôćĺ\t\tConfig: map[string]string{\n  1159Ôćĺ\t\t\t\"prompt\":        \"You are a coding assistant.\",\n  1160Ôćĺ\t\t\t\"agent_command\": mockAgent,\n  1161Ôćĺ\t\t\t\"prompt_step\":   \"custom-source\",\n  1162Ôćĺ\t\t},\n  1163Ôćĺ\t}\n  1164Ôćĺ\n  1165Ôćĺ\tresult, err := executor.Execute(context.Background(), step)\n  1166Ôćĺ\trequire.NoError(t, err)\n  1167Ôćĺ\tassert.Equal(t, \"success\", result)\n  1168Ôćĺ\n  1169Ôćĺ\t// Verify prompt.txt was written with the prompt_step output\n  1170Ôćĺ\tpromptPath := filepath.Join(tmpDir, \".cloche\", \"test-host-run\", \"prompt.txt\")\n  1171Ôćĺ\tdata, err := os.ReadFile(promptPath)\n  1172Ôćĺ\trequire.NoError(t, err)\n  1173Ôćĺ\tassert.Equal(t, \"custom prompt content\", string(data))\n  1174Ôćĺ}\n  1175Ôćĺ\n  1176Ôćĺfunc TestEngine_HostWorkflow_WithAgentStep(t *testing.T) {\n  1177Ôćĺ\ttmpDir := t.TempDir()\n  1178Ôćĺ\toutputDir := filepath.Join(tmpDir, \"output\")\n  1179Ôćĺ\n  1180Ôćĺ\t// Create a mock agent\n  1181Ôćĺ\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1182Ôćĺ\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent output'\\n\"), 0755))\n  1183Ôćĺ\n  1184Ôćĺ\texecutor := &Executor{\n  1185Ôćĺ\t\tProjectDir: tmpDir,\n  1186Ôćĺ\t\tOutputDir:  outputDir,\n  1187Ôćĺ\t\tHostRunID:  \"test-host-run\",\n  1188Ôćĺ\t}\n  1189Ôćĺ\n  1190Ôćĺ\twf := &domain.Workflow{\n  1191Ôćĺ\t\tName: \"main\",\n  1192Ôćĺ\t\tSteps: map[string]*domain.Step{\n  1193Ôćĺ\t\t\t\"prepare\": {\n  1194Ôćĺ\t\t\t\tName:    \"prepare\",\n  1195Ôćĺ\t\t\t\tType:    domain.StepTypeScript,\n  1196Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n  1197Ôćĺ\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'task prompt'\"},\n  1198Ôćĺ\t\t\t},\n  1199Ôćĺ\t\t\t\"implement\": {\n  1200Ôćĺ\t\t\t\tName:    \"implement\",\n  1201Ôćĺ\t\t\t\tType:    domain.StepTypeAgent,\n  1202Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n  1203Ôćĺ\t\t\t\tConfig: map[string]string{\n  1204Ôćĺ\t\t\t\t\t\"prompt\":        \"You are a coding assistant.\",\n  1205Ôćĺ\t\t\t\t\t\"agent_command\": mockAgent,\n  1206Ôćĺ\t\t\t\t},\n  1207Ôćĺ\t\t\t},\n  1208Ôćĺ\t\t\t\"verify\": {\n  1209Ôćĺ\t\t\t\tName:    \"verify\",\n  1210Ôćĺ\t\t\t\tType:    domain.StepTypeScript,\n  1211Ôćĺ\t\t\t\tResults: []string{\"success\", \"fail\"},\n  1212Ôćĺ\t\t\t\tConfig:  map[string]string{\"run\": \"echo verified\"},\n  1213Ôćĺ\t\t\t},\n  1214Ôćĺ\t\t},\n  1215Ôćĺ\t\tWiring: []domain.Wire{\n  1216Ôćĺ\t\t\t{From: \"prepare\", Result: \"success\", To: \"implement\"},\n  1217Ôćĺ\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n  1218Ôćĺ\t\t\t{From: \"implement\", Result: \"success\", To: \"verify\"},\n  1219Ôćĺ\t\t\t{From: \"implement\", Result: \"fail\", To: domain.StepAbort},\n  1220Ôćĺ\t\t\t{From: \"verify\", Result: \"success\", To: domain.StepDone},\n  1221Ôćĺ\t\t\t{From: \"verify\", Result: \"fail\", To: domain.StepAbort},\n  1222Ôćĺ\t\t},\n  1223Ôćĺ\t\tEntryStep: \"prepare\",\n  1224Ôćĺ\t}\n  1225Ôćĺ\n  1226Ôćĺ\teng := engine.New(executor)\n  1227Ôćĺ\trun, err := eng.Run(context.Background(), wf)\n  1228Ôćĺ\trequire.NoError(t, err)\n  1229Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n  1230Ôćĺ}\n  1231Ôćĺ\n  1232Ôćĺfunc TestRunner_HostWorkflow_AgentStep(t *testing.T) {\n  1233Ôćĺ\ttmpDir := t.TempDir()\n  1234Ôćĺ\n  1235Ôćĺ\t// Create a mock agent\n  1236Ôćĺ\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1237Ôćĺ\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent implemented'\\n\"), 0755))\n  1238Ôćĺ\n  1239Ôćĺ\t// Write a host.cloche with an agent step\n  1240Ôćĺ\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n  1241Ôćĺ\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n  1242Ôćĺ\thostCloche := `workflow \"main\" {\n  1243Ôćĺ  host {\n  1244Ôćĺ    agent_command = \"` + mockAgent + `\"\n  1245Ôćĺ  }\n  1246Ôćĺ\n  1247Ôćĺ  step implement {\n  1248Ôćĺ    prompt = \"Implement the feature.\"\n  1249Ôćĺ    results = [success, fail]\n  1250Ôćĺ  }\n  1251Ôćĺ\n  1252Ôćĺ  implement:success -> done\n  1253Ôćĺ  implement:fail    -> abort\n  1254Ôćĺ}`\n  1255Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n  1256Ôćĺ\n  1257Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n  1258Ôćĺ\n  1259Ôćĺ\trunner := &Runner{\n  1260Ôćĺ\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n  1261Ôćĺ\t\tStore:      store,\n  1262Ôćĺ\t}\n  1263Ôćĺ\n  1264Ôćĺ\tresult, err := runner.Run(context.Background(), tmpDir)\n  1265Ôćĺ\trequire.NoError(t, err)\n  1266Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n  1267Ôćĺ\n  1268Ôćĺ\t// Verify the run completed\n  1269Ôćĺ\thostRun, err := store.GetRun(context.Background(), result.RunID)\n  1270Ôćĺ\trequire.NoError(t, err)\n  1271Ôćĺ\tassert.True(t, hostRun.IsHost)\n  1272Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n  1273Ôćĺ}\n  1274Ôćĺ\n  1275Ôćĺfunc TestRunner_HostWorkflow_AgentStepOverridesWorkflowCommand(t *testing.T) {\n  1276Ôćĺ\ttmpDir := t.TempDir()\n  1277Ôćĺ\n  1278Ôćĺ\t// Create two mock agents\n  1279Ôćĺ\tworkflowAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n  1280Ôćĺ\trequire.NoError(t, os.WriteFile(workflowAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow level'\\n\"), 0755))\n  1281Ôćĺ\n  1282Ôćĺ\tstepAgent := filepath.Join(tmpDir, \"step-agent.sh\")\n  1283Ôćĺ\trequire.NoError(t, os.WriteFile(stepAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'step level'\\n\"), 0755))\n  1284Ôćĺ\n  1285Ôćĺ\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n  1286Ôćĺ\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n  1287Ôćĺ\thostCloche := `workflow \"main\" {\n  1288Ôćĺ  host {\n  1289Ôćĺ    agent_command = \"` + workflowAgent + `\"\n  1290Ôćĺ  }\n  1291Ôćĺ\n  1292Ôćĺ  step implement {\n  1293Ôćĺ    agent_command = \"` + stepAgent + `\"\n  1294Ôćĺ    prompt = \"Implement the feature.\"\n  1295Ôćĺ    results = [success, fail]\n  1296Ôćĺ  }\n  1297Ôćĺ\n  1298Ôćĺ  implement:success -> done\n  1299Ôćĺ  implement:fail    -> abort\n  1300Ôćĺ}`\n  1301Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n  1302Ôćĺ\n  1303Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n  1304Ôćĺ\trunner := &Runner{\n  1305Ôćĺ\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n  1306Ôćĺ\t\tStore:      store,\n  1307Ôćĺ\t}\n  1308Ôćĺ\n  1309Ôćĺ\tresult, err := runner.Run(context.Background(), tmpDir)\n  1310Ôćĺ\trequire.NoError(t, err)\n  1311Ôćĺ\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n  1312Ôćĺ}\n  1313Ôćĺ\n  1314Ôćĺfunc TestRunner_PersistsHostRunOnFailure(t *testing.T) {\n  1315Ôćĺ\ttmpDir := t.TempDir()\n  1316Ôćĺ\n  1317Ôćĺ\t// Write a host.cloche that will fail\n  1318Ôćĺ\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n  1319Ôćĺ\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n  1320Ôćĺ\thostCloche := `workflow \"main\" {\n  1321Ôćĺ  step bad {\n  1322Ôćĺ    run     = \"exit 1\"\n  1323Ôćĺ    results = [success, fail]\n  1324Ôćĺ  }\n  1325Ôćĺ\n  1326Ôćĺ  bad:success -> done\n  1327Ôćĺ  bad:fail    -> abort\n  1328Ôćĺ}`\n  1329Ôćĺ\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n  1330Ôćĺ\n  1331Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n  1332Ôćĺ\n  1333Ôćĺ\trunner := &Runner{\n  1334Ôćĺ\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n  1335Ôćĺ\t\tStore:      store,\n  1336Ôćĺ\t}\n  1337Ôćĺ\n  1338Ôćĺ\tresult, err := runner.Run(context.Background(), tmpDir)\n  1339Ôćĺ\trequire.NoError(t, err)\n  1340Ôćĺ\tassert.Equal(t, domain.RunStateFailed, result.State)\n  1341Ôćĺ\n  1342Ôćĺ\t// Verify the host run was persisted with failed state\n  1343Ôćĺ\thostRun, err := store.GetRun(context.Background(), result.RunID)\n  1344Ôćĺ\trequire.NoError(t, err)\n  1345Ôćĺ\tassert.True(t, hostRun.IsHost)\n  1346Ôćĺ\tassert.Equal(t, domain.RunStateFailed, hostRun.State)\n  1347Ôćĺ\tassert.False(t, hostRun.CompletedAt.IsZero())\n  1348Ôćĺ}\n  1349Ôćĺ"}]},"parent_tool_use_id":"toolu_012epjQe4jiFDSKQ49cH1EjH","session_id":"b83aa53c-b539-403e-957d-d27f065bd09c","uuid":"a7e37143-22a5-40ce-8545-44c624d784ec"}
[2026-03-11T00:29:45Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016fuwRv8MXx7UobtoHPdVra","type":"tool_result","content":"     1Ôćĺpackage host\n     2Ôćĺ\n     3Ôćĺimport (\n     4Ôćĺ\t\"context\"\n     5Ôćĺ\t\"sync\"\n     6Ôćĺ\t\"sync/atomic\"\n     7Ôćĺ\t\"testing\"\n     8Ôćĺ\t\"time\"\n     9Ôćĺ\n    10Ôćĺ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11Ôćĺ\t\"github.com/stretchr/testify/assert\"\n    12Ôćĺ)\n    13Ôćĺ\n    14Ôćĺfunc TestLoop_StartStop(t *testing.T) {\n    15Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    16Ôćĺ\tvar called atomic.Int32\n    17Ôćĺ\n    18Ôćĺ\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    19Ôćĺ\t\tcalled.Add(1)\n    20Ôćĺ\t\t// Simulate a run that finds no work (failed = aborted).\n    21Ôćĺ\t\ttime.Sleep(50 * time.Millisecond)\n    22Ôćĺ\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    23Ôćĺ\t}\n    24Ôćĺ\n    25Ôćĺ\tloop := NewLoop(LoopConfig{\n    26Ôćĺ\t\tProjectDir:    \"/tmp/test-project\",\n    27Ôćĺ\t\tMaxConcurrent: 1,\n    28Ôćĺ\t}, store, runFn)\n    29Ôćĺ\n    30Ôćĺ\tif loop.Running() {\n    31Ôćĺ\t\tt.Fatal(\"loop should not be running before Start\")\n    32Ôćĺ\t}\n    33Ôćĺ\n    34Ôćĺ\tloop.Start()\n    35Ôćĺ\tif !loop.Running() {\n    36Ôćĺ\t\tt.Fatal(\"loop should be running after Start\")\n    37Ôćĺ\t}\n    38Ôćĺ\n    39Ôćĺ\t// Wait enough time for at least one run to happen.\n    40Ôćĺ\ttime.Sleep(200 * time.Millisecond)\n    41Ôćĺ\tloop.Stop()\n    42Ôćĺ\n    43Ôćĺ\tif loop.Running() {\n    44Ôćĺ\t\tt.Fatal(\"loop should not be running after Stop\")\n    45Ôćĺ\t}\n    46Ôćĺ\n    47Ôćĺ\tif called.Load() < 1 {\n    48Ôćĺ\t\tt.Fatal(\"expected at least one run to be launched\")\n    49Ôćĺ\t}\n    50Ôćĺ}\n    51Ôćĺ\n    52Ôćĺfunc TestLoop_RampsUpOnSuccess(t *testing.T) {\n    53Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    54Ôćĺ\tvar called atomic.Int32\n    55Ôćĺ\n    56Ôćĺ\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    57Ôćĺ\t\tn := called.Add(1)\n    58Ôćĺ\t\ttime.Sleep(20 * time.Millisecond)\n    59Ôćĺ\t\t// First 3 succeed, then fail (no more work).\n    60Ôćĺ\t\tif n <= 3 {\n    61Ôćĺ\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n    62Ôćĺ\t\t}\n    63Ôćĺ\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    64Ôćĺ\t}\n    65Ôćĺ\n    66Ôćĺ\tloop := NewLoop(LoopConfig{\n    67Ôćĺ\t\tProjectDir:    \"/tmp/test-project\",\n    68Ôćĺ\t\tMaxConcurrent: 1,\n    69Ôćĺ\t}, store, runFn)\n    70Ôćĺ\n    71Ôćĺ\tloop.Start()\n    72Ôćĺ\t// With no backoff between successes, 3 successful + 1 failed should happen fast.\n    73Ôćĺ\ttime.Sleep(300 * time.Millisecond)\n    74Ôćĺ\tloop.Stop()\n    75Ôćĺ\n    76Ôćĺ\tif called.Load() < 4 {\n    77Ôćĺ\t\tt.Fatalf(\"expected at least 4 runs, got %d\", called.Load())\n    78Ôćĺ\t}\n    79Ôćĺ}\n    80Ôćĺ\n    81Ôćĺfunc TestLoop_DoubleStartIsNoop(t *testing.T) {\n    82Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    83Ôćĺ\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    84Ôćĺ\t\ttime.Sleep(100 * time.Millisecond)\n    85Ôćĺ\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    86Ôćĺ\t}\n    87Ôćĺ\n    88Ôćĺ\tloop := NewLoop(LoopConfig{\n    89Ôćĺ\t\tProjectDir:    \"/tmp/test-project\",\n    90Ôćĺ\t\tMaxConcurrent: 1,\n    91Ôćĺ\t}, store, runFn)\n    92Ôćĺ\n    93Ôćĺ\tloop.Start()\n    94Ôćĺ\tloop.Start() // Should be a no-op.\n    95Ôćĺ\tloop.Stop()\n    96Ôćĺ}\n    97Ôćĺ\n    98Ôćĺ// fakeTaskAssigner implements TaskAssigner for testing.\n    99Ôćĺtype fakeTaskAssigner struct {\n   100Ôćĺ\tmu    sync.Mutex\n   101Ôćĺ\ttasks []Task\n   102Ôćĺ\tcalls int\n   103Ôćĺ}\n   104Ôćĺ\n   105Ôćĺfunc (f *fakeTaskAssigner) ListTasks(_ context.Context, _ string) ([]Task, error) {\n   106Ôćĺ\tf.mu.Lock()\n   107Ôćĺ\tdefer f.mu.Unlock()\n   108Ôćĺ\tf.calls++\n   109Ôćĺ\tresult := make([]Task, len(f.tasks))\n   110Ôćĺ\tcopy(result, f.tasks)\n   111Ôćĺ\treturn result, nil\n   112Ôćĺ}\n   113Ôćĺ\n   114Ôćĺfunc TestLoop_TaskAssigner_PassesTaskID(t *testing.T) {\n   115Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   116Ôćĺ\n   117Ôćĺ\tassigner := &fakeTaskAssigner{\n   118Ôćĺ\t\ttasks: []Task{\n   119Ôćĺ\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n   120Ôćĺ\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n   121Ôćĺ\t\t},\n   122Ôćĺ\t}\n   123Ôćĺ\n   124Ôćĺ\tvar receivedTaskIDs []string\n   125Ôćĺ\tvar mu sync.Mutex\n   126Ôćĺ\n   127Ôćĺ\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   128Ôćĺ\t\tmu.Lock()\n   129Ôćĺ\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   130Ôćĺ\t\tmu.Unlock()\n   131Ôćĺ\t\ttime.Sleep(20 * time.Millisecond)\n   132Ôćĺ\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   133Ôćĺ\t}\n   134Ôćĺ\n   135Ôćĺ\tloop := NewLoop(LoopConfig{\n   136Ôćĺ\t\tProjectDir:    \"/tmp/test-project\",\n   137Ôćĺ\t\tMaxConcurrent: 1,\n   138Ôćĺ\t\tDedupTimeout:  1 * time.Second,\n   139Ôćĺ\t}, store, runFn)\n   140Ôćĺ\tloop.SetTaskAssigner(assigner)\n   141Ôćĺ\n   142Ôćĺ\tloop.Start()\n   143Ôćĺ\ttime.Sleep(200 * time.Millisecond)\n   144Ôćĺ\tloop.Stop()\n   145Ôćĺ\n   146Ôćĺ\tmu.Lock()\n   147Ôćĺ\tdefer mu.Unlock()\n   148Ôćĺ\t// Should have received task-1 first, then task-2 (task-1 is deduped).\n   149Ôćĺ\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2)\n   150Ôćĺ\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   151Ôćĺ\tassert.Equal(t, \"task-2\", receivedTaskIDs[1])\n   152Ôćĺ}\n   153Ôćĺ\n   154Ôćĺfunc TestLoop_TaskAssigner_DedupPreventsReassignment(t *testing.T) {\n   155Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   156Ôćĺ\n   157Ôćĺ\tassigner := &fakeTaskAssigner{\n   158Ôćĺ\t\ttasks: []Task{{ID: \"task-1\"}},\n   159Ôćĺ\t}\n   160Ôćĺ\n   161Ôćĺ\tvar receivedTaskIDs []string\n   162Ôćĺ\tvar mu sync.Mutex\n   163Ôćĺ\n   164Ôćĺ\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   165Ôćĺ\t\tmu.Lock()\n   166Ôćĺ\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   167Ôćĺ\t\tmu.Unlock()\n   168Ôćĺ\t\ttime.Sleep(20 * time.Millisecond)\n   169Ôćĺ\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   170Ôćĺ\t}\n   171Ôćĺ\n   172Ôćĺ\tloop := NewLoop(LoopConfig{\n   173Ôćĺ\t\tProjectDir:    \"/tmp/test-project\",\n   174Ôćĺ\t\tMaxConcurrent: 1,\n   175Ôćĺ\t\tDedupTimeout:  2 * time.Second, // long enough that task-1 won't be reassigned during test\n   176Ôćĺ\t}, store, runFn)\n   177Ôćĺ\tloop.SetTaskAssigner(assigner)\n   178Ôćĺ\n   179Ôćĺ\tloop.Start()\n   180Ôćĺ\ttime.Sleep(200 * time.Millisecond)\n   181Ôćĺ\tloop.Stop()\n   182Ôćĺ\n   183Ôćĺ\tmu.Lock()\n   184Ôćĺ\tdefer mu.Unlock()\n   185Ôćĺ\t// Only one run should have been launched since task-1 is deduped after first assignment.\n   186Ôćĺ\tassert.Equal(t, 1, len(receivedTaskIDs))\n   187Ôćĺ\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   188Ôćĺ}\n   189Ôćĺ\n   190Ôćĺfunc TestLoop_TaskAssigner_DedupExpires(t *testing.T) {\n   191Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   192Ôćĺ\n   193Ôćĺ\tassigner := &fakeTaskAssigner{\n   194Ôćĺ\t\ttasks: []Task{{ID: \"task-1\"}},\n   195Ôćĺ\t}\n   196Ôćĺ\n   197Ôćĺ\tvar receivedTaskIDs []string\n   198Ôćĺ\tvar mu sync.Mutex\n   199Ôćĺ\n   200Ôćĺ\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   201Ôćĺ\t\tmu.Lock()\n   202Ôćĺ\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   203Ôćĺ\t\tmu.Unlock()\n   204Ôćĺ\t\t// Run takes longer than dedup timeout, so by the time the run\n   205Ôćĺ\t\t// completes the dedup window has already expired and pickTask\n   206Ôćĺ\t\t// can re-assign immediately without hitting capacityPollInterval.\n   207Ôćĺ\t\ttime.Sleep(100 * time.Millisecond)\n   208Ôćĺ\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   209Ôćĺ\t}\n   210Ôćĺ\n   211Ôćĺ\tloop := NewLoop(LoopConfig{\n   212Ôćĺ\t\tProjectDir:    \"/tmp/test-project\",\n   213Ôćĺ\t\tMaxConcurrent: 1,\n   214Ôćĺ\t\tDedupTimeout:  50 * time.Millisecond,\n   215Ôćĺ\t}, store, runFn)\n   216Ôćĺ\tloop.SetTaskAssigner(assigner)\n   217Ôćĺ\n   218Ôćĺ\tloop.Start()\n   219Ôćĺ\ttime.Sleep(500 * time.Millisecond)\n   220Ôćĺ\tloop.Stop()\n   221Ôćĺ\n   222Ôćĺ\tmu.Lock()\n   223Ôćĺ\tdefer mu.Unlock()\n   224Ôćĺ\t// With 50ms dedup and 100ms run time, dedup expires before run completes,\n   225Ôćĺ\t// so task-1 should be assigned multiple times.\n   226Ôćĺ\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2, \"dedup should have expired, allowing reassignment\")\n   227Ôćĺ\tfor _, id := range receivedTaskIDs {\n   228Ôćĺ\t\tassert.Equal(t, \"task-1\", id)\n   229Ôćĺ\t}\n   230Ôćĺ}\n   231Ôćĺ\n   232Ôćĺfunc TestLoop_TaskAssigner_NoTasks_BacksOff(t *testing.T) {\n   233Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   234Ôćĺ\n   235Ôćĺ\tassigner := &fakeTaskAssigner{\n   236Ôćĺ\t\ttasks: nil, // no tasks available\n   237Ôćĺ\t}\n   238Ôćĺ\n   239Ôćĺ\tvar called atomic.Int32\n   240Ôćĺ\n   241Ôćĺ\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   242Ôćĺ\t\tcalled.Add(1)\n   243Ôćĺ\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   244Ôćĺ\t}\n   245Ôćĺ\n   246Ôćĺ\tloop := NewLoop(LoopConfig{\n   247Ôćĺ\t\tProjectDir:    \"/tmp/test-project\",\n   248Ôćĺ\t\tMaxConcurrent: 1,\n   249Ôćĺ\t}, store, runFn)\n   250Ôćĺ\tloop.SetTaskAssigner(assigner)\n   251Ôćĺ\n   252Ôćĺ\tloop.Start()\n   253Ôćĺ\ttime.Sleep(200 * time.Millisecond)\n   254Ôćĺ\tloop.Stop()\n   255Ôćĺ\n   256Ôćĺ\t// With no tasks, no runs should have been launched.\n   257Ôćĺ\tassert.Equal(t, int32(0), called.Load())\n   258Ôćĺ}\n   259Ôćĺ\n   260Ôćĺfunc TestLoop_NoTaskAssigner_EmptyTaskID(t *testing.T) {\n   261Ôćĺ\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   262Ôćĺ\n   263Ôćĺ\tvar receivedTaskID string\n   264Ôćĺ\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   265Ôćĺ\t\treceivedTaskID = taskID\n   266Ôćĺ\t\ttime.Sleep(20 * time.Millisecond)\n   267Ôćĺ\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   268Ôćĺ\t}\n   269Ôćĺ\n   270Ôćĺ\tloop := NewLoop(LoopConfig{\n   271Ôćĺ\t\tProjectDir:    \"/tmp/test-project\",\n   272Ôćĺ\t\tMaxConcurrent: 1,\n   273Ôćĺ\t}, store, runFn)\n   274Ôćĺ\t// No SetTaskAssigner call ÔÇö backward compatible mode.\n   275Ôćĺ\n   276Ôćĺ\tloop.Start()\n   277Ôćĺ\ttime.Sleep(200 * time.Millisecond)\n   278Ôćĺ\tloop.Stop()\n   279Ôćĺ\n   280Ôćĺ\t// Without a task assigner, taskID should be empty.\n   281Ôćĺ\tassert.Empty(t, receivedTaskID)\n   282Ôćĺ}\n   283Ôćĺ"}]},"parent_tool_use_id":"toolu_012epjQe4jiFDSKQ49cH1EjH","session_id":"b83aa53c-b539-403e-957d-d27f065bd09c","uuid":"98249bec-083b-458f-83cc-337a603ff394"}
