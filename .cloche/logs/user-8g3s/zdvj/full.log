[2026-03-11T00:27:32Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gr4QGZ68nmPZftbw62Xa9M","type":"tool_result","content":"     1Ôćĺpackage host\n     2Ôćĺ\n     3Ôćĺimport (\n     4Ôćĺ\t\"context\"\n     5Ôćĺ\t\"fmt\"\n     6Ôćĺ\t\"log\"\n     7Ôćĺ\t\"os\"\n     8Ôćĺ\t\"os/exec\"\n     9Ôćĺ\t\"path/filepath\"\n    10Ôćĺ\t\"strings\"\n    11Ôćĺ\t\"time\"\n    12Ôćĺ\n    13Ôćĺ\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14Ôćĺ\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    15Ôćĺ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16Ôćĺ\t\"github.com/cloche-dev/cloche/internal/engine\"\n    17Ôćĺ\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18Ôćĺ\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    19Ôćĺ)\n    20Ôćĺ\n    21Ôćĺ// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    22Ôćĺ// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    23Ôćĺ// strings suitable for adding to a command's environment.\n    24Ôćĺfunc (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    25Ôćĺ\tvar env []string\n    26Ôćĺ\tfor _, w := range wires {\n    27Ôćĺ\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    28Ôćĺ\t\t\tcontinue\n    29Ôćĺ\t\t}\n    30Ôćĺ\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    31Ôćĺ\t\tif err != nil {\n    32Ôćĺ\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    33Ôćĺ\t\t}\n    34Ôćĺ\t\tfor _, m := range w.OutputMap {\n    35Ôćĺ\t\t\tval, err := m.Path.Evaluate(data)\n    36Ôćĺ\t\t\tif err != nil {\n    37Ôćĺ\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    38Ôćĺ\t\t\t}\n    39Ôćĺ\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    40Ôćĺ\t\t}\n    41Ôćĺ\t}\n    42Ôćĺ\treturn env, nil\n    43Ôćĺ}\n    44Ôćĺ\n    45Ôćĺ// RunDispatcher dispatches a container workflow run and returns the run ID.\n    46Ôćĺtype RunDispatcher interface {\n    47Ôćĺ\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    48Ôćĺ}\n    49Ôćĺ\n    50Ôćĺ// Executor implements engine.StepExecutor for host workflow steps.\n    51Ôćĺtype Executor struct {\n    52Ôćĺ\tProjectDir    string\n    53Ôćĺ\tMainDir       string         // main branch worktree dir; scripts execute from here\n    54Ôćĺ\tDispatcher    RunDispatcher\n    55Ôćĺ\tStore         ports.RunStore\n    56Ôćĺ\tOutputDir     string         // directory for step output files\n    57Ôćĺ\tWires         []domain.Wire  // workflow wiring (for output mappings)\n    58Ôćĺ\tHostRunID     string         // ID of the parent host run (set on child runs)\n    59Ôćĺ\tAgentCommands []string       // workflow-level agent command fallback chain\n    60Ôćĺ\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n    61Ôćĺ}\n    62Ôćĺ\n    63Ôćĺ// scriptDir returns the directory from which scripts should execute.\n    64Ôćĺ// Uses MainDir if set, otherwise falls back to ProjectDir.\n    65Ôćĺfunc (e *Executor) scriptDir() string {\n    66Ôćĺ\tif e.MainDir != \"\" {\n    67Ôćĺ\t\treturn e.MainDir\n    68Ôćĺ\t}\n    69Ôćĺ\treturn e.ProjectDir\n    70Ôćĺ}\n    71Ôćĺ\n    72Ôćĺvar _ engine.StepExecutor = (*Executor)(nil)\n    73Ôćĺ\n    74Ôćĺ// Execute runs a single host workflow step.\n    75Ôćĺfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    76Ôćĺ\tswitch step.Type {\n    77Ôćĺ\tcase domain.StepTypeScript:\n    78Ôćĺ\t\treturn e.executeScript(ctx, step)\n    79Ôćĺ\tcase domain.StepTypeWorkflow:\n    80Ôćĺ\t\treturn e.executeWorkflow(ctx, step)\n    81Ôćĺ\tcase domain.StepTypeAgent:\n    82Ôćĺ\t\treturn e.executeAgent(ctx, step)\n    83Ôćĺ\tdefault:\n    84Ôćĺ\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    85Ôćĺ\t}\n    86Ôćĺ}\n    87Ôćĺ\n    88Ôćĺ// executeScript runs a shell command on the host.\n    89Ôćĺfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    90Ôćĺ\tcmdStr := step.Config[\"run\"]\n    91Ôćĺ\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    92Ôćĺ\tcmd.Dir = e.scriptDir()\n    93Ôćĺ\tcmd.Env = append(os.Environ(),\n    94Ôćĺ\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    95Ôćĺ\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    96Ôćĺ\t)\n    97Ôćĺ\n    98Ôćĺ\t// Pass previous step output if available\n    99Ôćĺ\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n   100Ôćĺ\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n   101Ôćĺ\t}\n   102Ôćĺ\n   103Ôćĺ\t// Resolve output mappings from wires and add as env vars\n   104Ôćĺ\tif len(e.Wires) > 0 {\n   105Ôćĺ\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n   106Ôćĺ\t\tif err != nil {\n   107Ôćĺ\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n   108Ôćĺ\t\t}\n   109Ôćĺ\t\tcmd.Env = append(cmd.Env, mapped...)\n   110Ôćĺ\t}\n   111Ôćĺ\n   112Ôćĺ\toutput, err := cmd.CombinedOutput()\n   113Ôćĺ\n   114Ôćĺ\t// Extract result marker\n   115Ôćĺ\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n   116Ôćĺ\n   117Ôćĺ\t// Write output to file\n   118Ôćĺ\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   119Ôćĺ\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   120Ôćĺ\t}\n   121Ôćĺ\n   122Ôćĺ\tif err != nil {\n   123Ôćĺ\t\tif _, ok := err.(*exec.ExitError); ok {\n   124Ôćĺ\t\t\tresult := \"fail\"\n   125Ôćĺ\t\t\tif found {\n   126Ôćĺ\t\t\t\tresult = markerResult\n   127Ôćĺ\t\t\t}\n   128Ôćĺ\t\t\treturn result, nil\n   129Ôćĺ\t\t}\n   130Ôćĺ\t\treturn \"\", err\n   131Ôćĺ\t}\n   132Ôćĺ\n   133Ôćĺ\tresult := \"success\"\n   134Ôćĺ\tif found {\n   135Ôćĺ\t\tresult = markerResult\n   136Ôćĺ\t}\n   137Ôćĺ\treturn result, nil\n   138Ôćĺ}\n   139Ôćĺ\n   140Ôćĺ// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   141Ôćĺfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   142Ôćĺ\tworkflowName := step.Config[\"workflow_name\"]\n   143Ôćĺ\tif workflowName == \"\" {\n   144Ôćĺ\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   145Ôćĺ\t}\n   146Ôćĺ\n   147Ôćĺ\t// Read prompt from previous step output or prompt_step override\n   148Ôćĺ\tvar promptContent string\n   149Ôćĺ\tpromptSource := step.Config[\"prompt_step\"]\n   150Ôćĺ\tif promptSource != \"\" {\n   151Ôćĺ\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   152Ôćĺ\t\tif err == nil {\n   153Ôćĺ\t\t\tpromptContent = string(data)\n   154Ôćĺ\t\t}\n   155Ôćĺ\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   156Ôćĺ\t\tdata, err := os.ReadFile(prev)\n   157Ôćĺ\t\tif err == nil {\n   158Ôćĺ\t\t\tpromptContent = string(data)\n   159Ôćĺ\t\t}\n   160Ôćĺ\t}\n   161Ôćĺ\n   162Ôćĺ\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   163Ôćĺ\t\tWorkflowName: workflowName,\n   164Ôćĺ\t\tProjectDir:   e.ProjectDir,\n   165Ôćĺ\t\tPrompt:       promptContent,\n   166Ôćĺ\t})\n   167Ôćĺ\tif err != nil {\n   168Ôćĺ\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   169Ôćĺ\t}\n   170Ôćĺ\n   171Ôćĺ\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   172Ôćĺ\n   173Ôćĺ\t// Link child run to parent host run\n   174Ôćĺ\tif e.HostRunID != \"\" {\n   175Ôćĺ\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n   176Ôćĺ\t\t\tchildRun.ParentRunID = e.HostRunID\n   177Ôćĺ\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n   178Ôćĺ\t\t}\n   179Ôćĺ\t}\n   180Ôćĺ\n   181Ôćĺ\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n   182Ôćĺ\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   183Ôćĺ\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n   184Ôćĺ\t}\n   185Ôćĺ\n   186Ôćĺ\t// Poll until the run reaches a terminal state\n   187Ôćĺ\tstate, err := e.waitForRun(ctx, resp.RunId)\n   188Ôćĺ\tif err != nil {\n   189Ôćĺ\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   190Ôćĺ\t}\n   191Ôćĺ\n   192Ôćĺ\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   193Ôćĺ\n   194Ôćĺ\t// Map run state to step result\n   195Ôćĺ\tif state == domain.RunStateSucceeded {\n   196Ôćĺ\t\treturn \"success\", nil\n   197Ôćĺ\t}\n   198Ôćĺ\treturn \"fail\", nil\n   199Ôćĺ}\n   200Ôćĺ\n   201Ôćĺ// executeAgent runs an agent command on the host using the prompt adapter.\n   202Ôćĺfunc (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n   203Ôćĺ\tadapter := prompt.New()\n   204Ôćĺ\n   205Ôćĺ\t// Apply workflow-level agent config\n   206Ôćĺ\tif len(e.AgentCommands) > 0 {\n   207Ôćĺ\t\tadapter.Commands = e.AgentCommands\n   208Ôćĺ\t}\n   209Ôćĺ\tif len(e.AgentArgs) > 0 {\n   210Ôćĺ\t\tadapter.ExplicitArgs = e.AgentArgs\n   211Ôćĺ\t}\n   212Ôćĺ\n   213Ôćĺ\t// Step-level overrides\n   214Ôćĺ\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   215Ôćĺ\t\tadapter.Commands = prompt.ParseCommands(cmd)\n   216Ôćĺ\t}\n   217Ôćĺ\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   218Ôćĺ\t\tadapter.ExplicitArgs = strings.Fields(args)\n   219Ôćĺ\t}\n   220Ôćĺ\n   221Ôćĺ\tadapter.RunID = e.HostRunID\n   222Ôćĺ\n   223Ôćĺ\t// Write previous step output as user prompt so the adapter can pick it up.\n   224Ôćĺ\tvar promptContent string\n   225Ôćĺ\tpromptSource := step.Config[\"prompt_step\"]\n   226Ôćĺ\tif promptSource != \"\" {\n   227Ôćĺ\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n   228Ôćĺ\t\t\tpromptContent = string(data)\n   229Ôćĺ\t\t}\n   230Ôćĺ\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   231Ôćĺ\t\tif data, err := os.ReadFile(prev); err == nil {\n   232Ôćĺ\t\t\tpromptContent = string(data)\n   233Ôćĺ\t\t}\n   234Ôćĺ\t}\n   235Ôćĺ\n   236Ôćĺ\tif promptContent != \"\" {\n   237Ôćĺ\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n   238Ôćĺ\t\t_ = os.MkdirAll(promptDir, 0755)\n   239Ôćĺ\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n   240Ôćĺ\t}\n   241Ôćĺ\n   242Ôćĺ\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n   243Ôćĺ\tif err != nil {\n   244Ôćĺ\t\treturn \"\", err\n   245Ôćĺ\t}\n   246Ôćĺ\n   247Ôćĺ\t// Copy output from adapter's output location to executor's output path\n   248Ôćĺ\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n   249Ôćĺ\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n   250Ôćĺ\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   251Ôćĺ\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n   252Ôćĺ\t\t}\n   253Ôćĺ\t}\n   254Ôćĺ\n   255Ôćĺ\treturn result, nil\n   256Ôćĺ}\n   257Ôćĺ\n   258Ôćĺ// waitForRun polls the store until the run reaches a terminal state.\n   259Ôćĺfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   260Ôćĺ\tticker := time.NewTicker(2 * time.Second)\n   261Ôćĺ\tdefer ticker.Stop()\n   262Ôćĺ\n   263Ôćĺ\tfor {\n   264Ôćĺ\t\tselect {\n   265Ôćĺ\t\tcase <-ctx.Done():\n   266Ôćĺ\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   267Ôćĺ\t\tcase <-ticker.C:\n   268Ôćĺ\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   269Ôćĺ\t\t\tif err != nil {\n   270Ôćĺ\t\t\t\tcontinue // transient error, retry\n   271Ôćĺ\t\t\t}\n   272Ôćĺ\t\t\tswitch run.State {\n   273Ôćĺ\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   274Ôćĺ\t\t\t\treturn run.State, nil\n   275Ôćĺ\t\t\t}\n   276Ôćĺ\t\t\t// Still pending or running, continue polling\n   277Ôćĺ\t\t}\n   278Ôćĺ\t}\n   279Ôćĺ}\n   280Ôćĺ\n   281Ôćĺ// stepOutputPath returns the path for a step's output file.\n   282Ôćĺfunc (e *Executor) stepOutputPath(stepName string) string {\n   283Ôćĺ\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   284Ôćĺ}\n   285Ôćĺ\n   286Ôćĺ// findPrevOutput finds the output file from the step that wires into this one.\n   287Ôćĺ// It checks prompt_step config first, then walks the wiring graph to find the\n   288Ôćĺ// source step.\n   289Ôćĺfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n   290Ôćĺ\t// Explicit prompt_step config takes priority\n   291Ôćĺ\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   292Ôćĺ\t\tpath := e.stepOutputPath(ps)\n   293Ôćĺ\t\tif _, err := os.Stat(path); err == nil {\n   294Ôćĺ\t\t\treturn path\n   295Ôćĺ\t\t}\n   296Ôćĺ\t}\n   297Ôćĺ\n   298Ôćĺ\t// Walk wiring to find the step that feeds into this one\n   299Ôćĺ\tfor _, w := range e.Wires {\n   300Ôćĺ\t\tif w.To == step.Name {\n   301Ôćĺ\t\t\tpath := e.stepOutputPath(w.From)\n   302Ôćĺ\t\t\tif _, err := os.Stat(path); err == nil {\n   303Ôćĺ\t\t\t\treturn path\n   304Ôćĺ\t\t\t}\n   305Ôćĺ\t\t}\n   306Ôćĺ\t}\n   307Ôćĺ\treturn \"\"\n   308Ôćĺ}\n   309Ôćĺ\n   310Ôćĺ// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n   311Ôćĺ// the repository containing projectDir. If projectDir is already the main\n   312Ôćĺ// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n   313Ôćĺ// error (e.g. not a git repo).\n   314Ôćĺfunc MainWorktreeDir(projectDir string) string {\n   315Ôćĺ\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n   316Ôćĺ\tout, err := cmd.Output()\n   317Ôćĺ\tif err != nil {\n   318Ôćĺ\t\treturn projectDir\n   319Ôćĺ\t}\n   320Ôćĺ\t// The first \"worktree <path>\" line is always the main worktree.\n   321Ôćĺ\tfor _, line := range strings.Split(string(out), \"\\n\") {\n   322Ôćĺ\t\tif strings.HasPrefix(line, \"worktree \") {\n   323Ôćĺ\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n   324Ôćĺ\t\t}\n   325Ôćĺ\t}\n   326Ôćĺ\treturn projectDir\n   327Ôćĺ}\n   328Ôćĺ"}]},"parent_tool_use_id":null,"session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"41f7c2df-f0aa-4521-ade7-f06865c3c70c","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\n// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n// reads the source step's output, evaluates each mapping path, and returns KEY=value\n// strings suitable for adding to a command's environment.\nfunc (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n\tvar env []string\n\tfor _, w := range wires {\n\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n\t\t}\n\t\tfor _, m := range w.OutputMap {\n\t\t\tval, err := m.Path.Evaluate(data)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n\t\t\t}\n\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n\t\t}\n\t}\n\treturn env, nil\n}\n\n// RunDispatcher dispatches a container workflow run and returns the run ID.\ntype RunDispatcher interface {\n\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n}\n\n// Executor implements engine.StepExecutor for host workflow steps.\ntype Executor struct {\n\tProjectDir    string\n\tMainDir       string         // main branch worktree dir; scripts execute from here\n\tDispatcher    RunDispatcher\n\tStore         ports.RunStore\n\tOutputDir     string         // directory for step output files\n\tWires         []domain.Wire  // workflow wiring (for output mappings)\n\tHostRunID     string         // ID of the parent host run (set on child runs)\n\tAgentCommands []string       // workflow-level agent command fallback chain\n\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n}\n\n// scriptDir returns the directory from which scripts should execute.\n// Uses MainDir if set, otherwise falls back to ProjectDir.\nfunc (e *Executor) scriptDir() string {\n\tif e.MainDir != \"\" {\n\t\treturn e.MainDir\n\t}\n\treturn e.ProjectDir\n}\n\nvar _ engine.StepExecutor = (*Executor)(nil)\n\n// Execute runs a single host workflow step.\nfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\treturn e.executeScript(ctx, step)\n\tcase domain.StepTypeWorkflow:\n\t\treturn e.executeWorkflow(ctx, step)\n\tcase domain.StepTypeAgent:\n\t\treturn e.executeAgent(ctx, step)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n\t}\n}\n\n// executeScript runs a shell command on the host.\nfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n\tcmdStr := step.Config[\"run\"]\n\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n\tcmd.Dir = e.scriptDir()\n\tcmd.Env = append(os.Environ(),\n\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n\t)\n\n\t// Pass previous step output if available\n\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n\t}\n\n\t// Resolve output mappings from wires and add as env vars\n\tif len(e.Wires) > 0 {\n\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n\t\t}\n\t\tcmd.Env = append(cmd.Env, mapped...)\n\t}\n\n\toutput, err := cmd.CombinedOutput()\n\n\t// Extract result marker\n\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n\n\t// Write output to file\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n\t}\n\n\tif err != nil {\n\t\tif _, ok := err.(*exec.ExitError); ok {\n\t\t\tresult := \"fail\"\n\t\t\tif found {\n\t\t\t\tresult = markerResult\n\t\t\t}\n\t\t\treturn result, nil\n\t\t}\n\t\treturn \"\", err\n\t}\n\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, nil\n}\n\n// executeWorkflow dispatches a container workflow run and blocks until it completes.\nfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n\tworkflowName := step.Config[\"workflow_name\"]\n\tif workflowName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n\t}\n\n\t// Read prompt from previous step output or prompt_step override\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tdata, err := os.ReadFile(prev)\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName: workflowName,\n\t\tProjectDir:   e.ProjectDir,\n\t\tPrompt:       promptContent,\n\t})\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n\t}\n\n\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n\n\t// Link child run to parent host run\n\tif e.HostRunID != \"\" {\n\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n\t\t\tchildRun.ParentRunID = e.HostRunID\n\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n\t\t}\n\t}\n\n\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n\t}\n\n\t// Poll until the run reaches a terminal state\n\tstate, err := e.waitForRun(ctx, resp.RunId)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n\t}\n\n\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n\n\t// Map run state to step result\n\tif state == domain.RunStateSucceeded {\n\t\treturn \"success\", nil\n\t}\n\treturn \"fail\", nil\n}\n\n// executeAgent runs an agent command on the host using the prompt adapter.\nfunc (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n\tadapter := prompt.New()\n\n\t// Apply workflow-level agent config\n\tif len(e.AgentCommands) > 0 {\n\t\tadapter.Commands = e.AgentCommands\n\t}\n\tif len(e.AgentArgs) > 0 {\n\t\tadapter.ExplicitArgs = e.AgentArgs\n\t}\n\n\t// Step-level overrides\n\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n\t\tadapter.Commands = prompt.ParseCommands(cmd)\n\t}\n\tif args := step.Config[\"agent_args\"]; args != \"\" {\n\t\tadapter.ExplicitArgs = strings.Fields(args)\n\t}\n\n\tadapter.RunID = e.HostRunID\n\n\t// Write previous step output as user prompt so the adapter can pick it up.\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tif data, err := os.ReadFile(prev); err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tif promptContent != \"\" {\n\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n\t\t_ = os.MkdirAll(promptDir, 0755)\n\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n\t}\n\n\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\t// Copy output from adapter's output location to executor's output path\n\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\n// waitForRun polls the store until the run reaches a terminal state.\nfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n\tticker := time.NewTicker(2 * time.Second)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n\t\tcase <-ticker.C:\n\t\t\trun, err := e.Store.GetRun(ctx, runID)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // transient error, retry\n\t\t\t}\n\t\t\tswitch run.State {\n\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n\t\t\t\treturn run.State, nil\n\t\t\t}\n\t\t\t// Still pending or running, continue polling\n\t\t}\n\t}\n}\n\n// stepOutputPath returns the path for a step's output file.\nfunc (e *Executor) stepOutputPath(stepName string) string {\n\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n}\n\n// findPrevOutput finds the output file from the step that wires into this one.\n// It checks prompt_step config first, then walks the wiring graph to find the\n// source step.\nfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n\t// Explicit prompt_step config takes priority\n\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n\t\tpath := e.stepOutputPath(ps)\n\t\tif _, err := os.Stat(path); err == nil {\n\t\t\treturn path\n\t\t}\n\t}\n\n\t// Walk wiring to find the step that feeds into this one\n\tfor _, w := range e.Wires {\n\t\tif w.To == step.Name {\n\t\t\tpath := e.stepOutputPath(w.From)\n\t\t\tif _, err := os.Stat(path); err == nil {\n\t\t\t\treturn path\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n// the repository containing projectDir. If projectDir is already the main\n// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n// error (e.g. not a git repo).\nfunc MainWorktreeDir(projectDir string) string {\n\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn projectDir\n\t}\n\t// The first \"worktree <path>\" line is always the main worktree.\n\tfor _, line := range strings.Split(string(out), \"\\n\") {\n\t\tif strings.HasPrefix(line, \"worktree \") {\n\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n\t\t}\n\t}\n\treturn projectDir\n}\n","numLines":328,"startLine":1,"totalLines":328}}}
