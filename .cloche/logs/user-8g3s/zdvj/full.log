[2026-03-11T00:29:45Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017YPrvhpMhsxeYfGEyYKtaA","type":"tool_result","content":"     1Ôćĺpackage host\n     2Ôćĺ\n     3Ôćĺimport (\n     4Ôćĺ\t\"context\"\n     5Ôćĺ\t\"fmt\"\n     6Ôćĺ\t\"log\"\n     7Ôćĺ\t\"os\"\n     8Ôćĺ\t\"os/exec\"\n     9Ôćĺ\t\"path/filepath\"\n    10Ôćĺ\t\"strings\"\n    11Ôćĺ\t\"time\"\n    12Ôćĺ\n    13Ôćĺ\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14Ôćĺ\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    15Ôćĺ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16Ôćĺ\t\"github.com/cloche-dev/cloche/internal/engine\"\n    17Ôćĺ\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18Ôćĺ\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    19Ôćĺ)\n    20Ôćĺ\n    21Ôćĺ// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    22Ôćĺ// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    23Ôćĺ// strings suitable for adding to a command's environment.\n    24Ôćĺfunc (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    25Ôćĺ\tvar env []string\n    26Ôćĺ\tfor _, w := range wires {\n    27Ôćĺ\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    28Ôćĺ\t\t\tcontinue\n    29Ôćĺ\t\t}\n    30Ôćĺ\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    31Ôćĺ\t\tif err != nil {\n    32Ôćĺ\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    33Ôćĺ\t\t}\n    34Ôćĺ\t\tfor _, m := range w.OutputMap {\n    35Ôćĺ\t\t\tval, err := m.Path.Evaluate(data)\n    36Ôćĺ\t\t\tif err != nil {\n    37Ôćĺ\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    38Ôćĺ\t\t\t}\n    39Ôćĺ\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    40Ôćĺ\t\t}\n    41Ôćĺ\t}\n    42Ôćĺ\treturn env, nil\n    43Ôćĺ}\n    44Ôćĺ\n    45Ôćĺ// RunDispatcher dispatches a container workflow run and returns the run ID.\n    46Ôćĺtype RunDispatcher interface {\n    47Ôćĺ\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    48Ôćĺ}\n    49Ôćĺ\n    50Ôćĺ// Executor implements engine.StepExecutor for host workflow steps.\n    51Ôćĺtype Executor struct {\n    52Ôćĺ\tProjectDir    string\n    53Ôćĺ\tMainDir       string         // main branch worktree dir; scripts execute from here\n    54Ôćĺ\tDispatcher    RunDispatcher\n    55Ôćĺ\tStore         ports.RunStore\n    56Ôćĺ\tOutputDir     string         // directory for step output files\n    57Ôćĺ\tWires         []domain.Wire  // workflow wiring (for output mappings)\n    58Ôćĺ\tHostRunID     string         // ID of the parent host run (set on child runs)\n    59Ôćĺ\tAgentCommands []string       // workflow-level agent command fallback chain\n    60Ôćĺ\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n    61Ôćĺ\tTaskID        string         // optional task ID assigned by the daemon loop\n    62Ôćĺ}\n    63Ôćĺ\n    64Ôćĺ// scriptDir returns the directory from which scripts should execute.\n    65Ôćĺ// Uses MainDir if set, otherwise falls back to ProjectDir.\n    66Ôćĺfunc (e *Executor) scriptDir() string {\n    67Ôćĺ\tif e.MainDir != \"\" {\n    68Ôćĺ\t\treturn e.MainDir\n    69Ôćĺ\t}\n    70Ôćĺ\treturn e.ProjectDir\n    71Ôćĺ}\n    72Ôćĺ\n    73Ôćĺvar _ engine.StepExecutor = (*Executor)(nil)\n    74Ôćĺ\n    75Ôćĺ// Execute runs a single host workflow step.\n    76Ôćĺfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    77Ôćĺ\tswitch step.Type {\n    78Ôćĺ\tcase domain.StepTypeScript:\n    79Ôćĺ\t\treturn e.executeScript(ctx, step)\n    80Ôćĺ\tcase domain.StepTypeWorkflow:\n    81Ôćĺ\t\treturn e.executeWorkflow(ctx, step)\n    82Ôćĺ\tcase domain.StepTypeAgent:\n    83Ôćĺ\t\treturn e.executeAgent(ctx, step)\n    84Ôćĺ\tdefault:\n    85Ôćĺ\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    86Ôćĺ\t}\n    87Ôćĺ}\n    88Ôćĺ\n    89Ôćĺ// executeScript runs a shell command on the host.\n    90Ôćĺfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    91Ôćĺ\tcmdStr := step.Config[\"run\"]\n    92Ôćĺ\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    93Ôćĺ\tcmd.Dir = e.scriptDir()\n    94Ôćĺ\tcmd.Env = append(os.Environ(),\n    95Ôćĺ\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    96Ôćĺ\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    97Ôćĺ\t)\n    98Ôćĺ\n    99Ôćĺ\t// Pass daemon-assigned task ID if available\n   100Ôćĺ\tif e.TaskID != \"\" {\n   101Ôćĺ\t\tcmd.Env = append(cmd.Env, \"CLOCHE_TASK_ID=\"+e.TaskID)\n   102Ôćĺ\t}\n   103Ôćĺ\n   104Ôćĺ\t// Pass previous step output if available\n   105Ôćĺ\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n   106Ôćĺ\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n   107Ôćĺ\t}\n   108Ôćĺ\n   109Ôćĺ\t// Resolve output mappings from wires and add as env vars\n   110Ôćĺ\tif len(e.Wires) > 0 {\n   111Ôćĺ\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n   112Ôćĺ\t\tif err != nil {\n   113Ôćĺ\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n   114Ôćĺ\t\t}\n   115Ôćĺ\t\tcmd.Env = append(cmd.Env, mapped...)\n   116Ôćĺ\t}\n   117Ôćĺ\n   118Ôćĺ\toutput, err := cmd.CombinedOutput()\n   119Ôćĺ\n   120Ôćĺ\t// Extract result marker\n   121Ôćĺ\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n   122Ôćĺ\n   123Ôćĺ\t// Write output to file\n   124Ôćĺ\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   125Ôćĺ\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   126Ôćĺ\t}\n   127Ôćĺ\n   128Ôćĺ\tif err != nil {\n   129Ôćĺ\t\tif _, ok := err.(*exec.ExitError); ok {\n   130Ôćĺ\t\t\tresult := \"fail\"\n   131Ôćĺ\t\t\tif found {\n   132Ôćĺ\t\t\t\tresult = markerResult\n   133Ôćĺ\t\t\t}\n   134Ôćĺ\t\t\treturn result, nil\n   135Ôćĺ\t\t}\n   136Ôćĺ\t\treturn \"\", err\n   137Ôćĺ\t}\n   138Ôćĺ\n   139Ôćĺ\tresult := \"success\"\n   140Ôćĺ\tif found {\n   141Ôćĺ\t\tresult = markerResult\n   142Ôćĺ\t}\n   143Ôćĺ\treturn result, nil\n   144Ôćĺ}\n   145Ôćĺ\n   146Ôćĺ// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   147Ôćĺfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   148Ôćĺ\tworkflowName := step.Config[\"workflow_name\"]\n   149Ôćĺ\tif workflowName == \"\" {\n   150Ôćĺ\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   151Ôćĺ\t}\n   152Ôćĺ\n   153Ôćĺ\t// Read prompt from previous step output or prompt_step override\n   154Ôćĺ\tvar promptContent string\n   155Ôćĺ\tpromptSource := step.Config[\"prompt_step\"]\n   156Ôćĺ\tif promptSource != \"\" {\n   157Ôćĺ\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   158Ôćĺ\t\tif err == nil {\n   159Ôćĺ\t\t\tpromptContent = string(data)\n   160Ôćĺ\t\t}\n   161Ôćĺ\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   162Ôćĺ\t\tdata, err := os.ReadFile(prev)\n   163Ôćĺ\t\tif err == nil {\n   164Ôćĺ\t\t\tpromptContent = string(data)\n   165Ôćĺ\t\t}\n   166Ôćĺ\t}\n   167Ôćĺ\n   168Ôćĺ\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   169Ôćĺ\t\tWorkflowName: workflowName,\n   170Ôćĺ\t\tProjectDir:   e.ProjectDir,\n   171Ôćĺ\t\tPrompt:       promptContent,\n   172Ôćĺ\t})\n   173Ôćĺ\tif err != nil {\n   174Ôćĺ\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   175Ôćĺ\t}\n   176Ôćĺ\n   177Ôćĺ\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   178Ôćĺ\n   179Ôćĺ\t// Link child run to parent host run\n   180Ôćĺ\tif e.HostRunID != \"\" {\n   181Ôćĺ\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n   182Ôćĺ\t\t\tchildRun.ParentRunID = e.HostRunID\n   183Ôćĺ\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n   184Ôćĺ\t\t}\n   185Ôćĺ\t}\n   186Ôćĺ\n   187Ôćĺ\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n   188Ôćĺ\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   189Ôćĺ\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n   190Ôćĺ\t}\n   191Ôćĺ\n   192Ôćĺ\t// Poll until the run reaches a terminal state\n   193Ôćĺ\tstate, err := e.waitForRun(ctx, resp.RunId)\n   194Ôćĺ\tif err != nil {\n   195Ôćĺ\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   196Ôćĺ\t}\n   197Ôćĺ\n   198Ôćĺ\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   199Ôćĺ\n   200Ôćĺ\t// Map run state to step result\n   201Ôćĺ\tif state == domain.RunStateSucceeded {\n   202Ôćĺ\t\treturn \"success\", nil\n   203Ôćĺ\t}\n   204Ôćĺ\treturn \"fail\", nil\n   205Ôćĺ}\n   206Ôćĺ\n   207Ôćĺ// executeAgent runs an agent command on the host using the prompt adapter.\n   208Ôćĺfunc (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n   209Ôćĺ\tadapter := prompt.New()\n   210Ôćĺ\n   211Ôćĺ\t// Apply workflow-level agent config\n   212Ôćĺ\tif len(e.AgentCommands) > 0 {\n   213Ôćĺ\t\tadapter.Commands = e.AgentCommands\n   214Ôćĺ\t}\n   215Ôćĺ\tif len(e.AgentArgs) > 0 {\n   216Ôćĺ\t\tadapter.ExplicitArgs = e.AgentArgs\n   217Ôćĺ\t}\n   218Ôćĺ\n   219Ôćĺ\t// Step-level overrides\n   220Ôćĺ\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   221Ôćĺ\t\tadapter.Commands = prompt.ParseCommands(cmd)\n   222Ôćĺ\t}\n   223Ôćĺ\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   224Ôćĺ\t\tadapter.ExplicitArgs = strings.Fields(args)\n   225Ôćĺ\t}\n   226Ôćĺ\n   227Ôćĺ\tadapter.RunID = e.HostRunID\n   228Ôćĺ\n   229Ôćĺ\t// Write previous step output as user prompt so the adapter can pick it up.\n   230Ôćĺ\tvar promptContent string\n   231Ôćĺ\tpromptSource := step.Config[\"prompt_step\"]\n   232Ôćĺ\tif promptSource != \"\" {\n   233Ôćĺ\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n   234Ôćĺ\t\t\tpromptContent = string(data)\n   235Ôćĺ\t\t}\n   236Ôćĺ\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   237Ôćĺ\t\tif data, err := os.ReadFile(prev); err == nil {\n   238Ôćĺ\t\t\tpromptContent = string(data)\n   239Ôćĺ\t\t}\n   240Ôćĺ\t}\n   241Ôćĺ\n   242Ôćĺ\tif promptContent != \"\" {\n   243Ôćĺ\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n   244Ôćĺ\t\t_ = os.MkdirAll(promptDir, 0755)\n   245Ôćĺ\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n   246Ôćĺ\t}\n   247Ôćĺ\n   248Ôćĺ\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n   249Ôćĺ\tif err != nil {\n   250Ôćĺ\t\treturn \"\", err\n   251Ôćĺ\t}\n   252Ôćĺ\n   253Ôćĺ\t// Copy output from adapter's output location to executor's output path\n   254Ôćĺ\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n   255Ôćĺ\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n   256Ôćĺ\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   257Ôćĺ\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n   258Ôćĺ\t\t}\n   259Ôćĺ\t}\n   260Ôćĺ\n   261Ôćĺ\treturn result, nil\n   262Ôćĺ}\n   263Ôćĺ\n   264Ôćĺ// waitForRun polls the store until the run reaches a terminal state.\n   265Ôćĺfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   266Ôćĺ\tticker := time.NewTicker(2 * time.Second)\n   267Ôćĺ\tdefer ticker.Stop()\n   268Ôćĺ\n   269Ôćĺ\tfor {\n   270Ôćĺ\t\tselect {\n   271Ôćĺ\t\tcase <-ctx.Done():\n   272Ôćĺ\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   273Ôćĺ\t\tcase <-ticker.C:\n   274Ôćĺ\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   275Ôćĺ\t\t\tif err != nil {\n   276Ôćĺ\t\t\t\tcontinue // transient error, retry\n   277Ôćĺ\t\t\t}\n   278Ôćĺ\t\t\tswitch run.State {\n   279Ôćĺ\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   280Ôćĺ\t\t\t\treturn run.State, nil\n   281Ôćĺ\t\t\t}\n   282Ôćĺ\t\t\t// Still pending or running, continue polling\n   283Ôćĺ\t\t}\n   284Ôćĺ\t}\n   285Ôćĺ}\n   286Ôćĺ\n   287Ôćĺ// stepOutputPath returns the path for a step's output file.\n   288Ôćĺfunc (e *Executor) stepOutputPath(stepName string) string {\n   289Ôćĺ\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   290Ôćĺ}\n   291Ôćĺ\n   292Ôćĺ// findPrevOutput finds the output file from the step that wires into this one.\n   293Ôćĺ// It checks prompt_step config first, then walks the wiring graph to find the\n   294Ôćĺ// source step.\n   295Ôćĺfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n   296Ôćĺ\t// Explicit prompt_step config takes priority\n   297Ôćĺ\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   298Ôćĺ\t\tpath := e.stepOutputPath(ps)\n   299Ôćĺ\t\tif _, err := os.Stat(path); err == nil {\n   300Ôćĺ\t\t\treturn path\n   301Ôćĺ\t\t}\n   302Ôćĺ\t}\n   303Ôćĺ\n   304Ôćĺ\t// Walk wiring to find the step that feeds into this one\n   305Ôćĺ\tfor _, w := range e.Wires {\n   306Ôćĺ\t\tif w.To == step.Name {\n   307Ôćĺ\t\t\tpath := e.stepOutputPath(w.From)\n   308Ôćĺ\t\t\tif _, err := os.Stat(path); err == nil {\n   309Ôćĺ\t\t\t\treturn path\n   310Ôćĺ\t\t\t}\n   311Ôćĺ\t\t}\n   312Ôćĺ\t}\n   313Ôćĺ\treturn \"\"\n   314Ôćĺ}\n   315Ôćĺ\n   316Ôćĺ// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n   317Ôćĺ// the repository containing projectDir. If projectDir is already the main\n   318Ôćĺ// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n   319Ôćĺ// error (e.g. not a git repo).\n   320Ôćĺfunc MainWorktreeDir(projectDir string) string {\n   321Ôćĺ\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n   322Ôćĺ\tout, err := cmd.Output()\n   323Ôćĺ\tif err != nil {\n   324Ôćĺ\t\treturn projectDir\n   325Ôćĺ\t}\n   326Ôćĺ\t// The first \"worktree <path>\" line is always the main worktree.\n   327Ôćĺ\tfor _, line := range strings.Split(string(out), \"\\n\") {\n   328Ôćĺ\t\tif strings.HasPrefix(line, \"worktree \") {\n   329Ôćĺ\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n   330Ôćĺ\t\t}\n   331Ôćĺ\t}\n   332Ôćĺ\treturn projectDir\n   333Ôćĺ}\n   334Ôćĺ"}]},"parent_tool_use_id":"toolu_012epjQe4jiFDSKQ49cH1EjH","session_id":"b83aa53c-b539-403e-957d-d27f065bd09c","uuid":"a1ec0af4-f722-4a2f-8886-c266aa1ac4a6"}
