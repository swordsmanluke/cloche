[2026-03-11T00:27:32Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LL25s3PXWSjwJdbq17krLL","type":"tool_result","content":"     1Ôćĺpackage domain\n     2Ôćĺ\n     3Ôćĺimport (\n     4Ôćĺ\t\"encoding/json\"\n     5Ôćĺ\t\"fmt\"\n     6Ôćĺ\t\"strings\"\n     7Ôćĺ)\n     8Ôćĺ\n     9Ôćĺconst (\n    10Ôćĺ\tStepDone  = \"done\"\n    11Ôćĺ\tStepAbort = \"abort\"\n    12Ôćĺ)\n    13Ôćĺ\n    14Ôćĺtype StepType string\n    15Ôćĺ\n    16Ôćĺconst (\n    17Ôćĺ\tStepTypeAgent    StepType = \"agent\"\n    18Ôćĺ\tStepTypeScript   StepType = \"script\"\n    19Ôćĺ\tStepTypeWorkflow StepType = \"workflow\"\n    20Ôćĺ)\n    21Ôćĺ\n    22Ôćĺ// WorkflowLocation indicates where a workflow is intended to run.\n    23Ôćĺtype WorkflowLocation string\n    24Ôćĺ\n    25Ôćĺconst (\n    26Ôćĺ\t// LocationContainer is for workflows that run inside a Docker container.\n    27Ôćĺ\t// These are all .cloche/*.cloche files except host.cloche.\n    28Ôćĺ\tLocationContainer WorkflowLocation = \"container\"\n    29Ôćĺ\n    30Ôćĺ\t// LocationHost is for workflows that run on the host machine.\n    31Ôćĺ\t// Only .cloche/host.cloche uses this location.\n    32Ôćĺ\tLocationHost WorkflowLocation = \"host\"\n    33Ôćĺ)\n    34Ôćĺ\n    35Ôćĺtype Step struct {\n    36Ôćĺ\tName    string\n    37Ôćĺ\tType    StepType\n    38Ôćĺ\tResults []string\n    39Ôćĺ\tConfig  map[string]string\n    40Ôćĺ}\n    41Ôćĺ\n    42Ôćĺtype Wire struct {\n    43Ôćĺ\tFrom      string\n    44Ôćĺ\tResult    string\n    45Ôćĺ\tTo        string\n    46Ôćĺ\tOutputMap []OutputMapping\n    47Ôćĺ}\n    48Ôćĺ\n    49Ôćĺtype SegmentKind int\n    50Ôćĺ\n    51Ôćĺconst (\n    52Ôćĺ\tSegmentField SegmentKind = iota\n    53Ôćĺ\tSegmentIndex\n    54Ôćĺ)\n    55Ôćĺ\n    56Ôćĺtype PathSegment struct {\n    57Ôćĺ\tKind  SegmentKind\n    58Ôćĺ\tField string // for SegmentField\n    59Ôćĺ\tIndex int    // for SegmentIndex\n    60Ôćĺ}\n    61Ôćĺ\n    62Ôćĺtype OutputPath struct {\n    63Ôćĺ\tSegments []PathSegment\n    64Ôćĺ}\n    65Ôćĺ\n    66Ôćĺtype OutputMapping struct {\n    67Ôćĺ\tEnvVar string\n    68Ôćĺ\tPath   OutputPath\n    69Ôćĺ}\n    70Ôćĺ\n    71Ôćĺ// Evaluate navigates the raw output bytes using the path segments.\n    72Ôćĺ// With no segments, it returns the raw output as a string.\n    73Ôćĺ// With segments, it parses the raw bytes as JSON and navigates using\n    74Ôćĺ// field access (SegmentField) and array indexing (SegmentIndex).\n    75Ôćĺfunc (p OutputPath) Evaluate(raw []byte) (string, error) {\n    76Ôćĺ\tif len(p.Segments) == 0 {\n    77Ôćĺ\t\treturn string(raw), nil\n    78Ôćĺ\t}\n    79Ôćĺ\n    80Ôćĺ\tvar val any\n    81Ôćĺ\tif err := json.Unmarshal(raw, &val); err != nil {\n    82Ôćĺ\t\treturn \"\", fmt.Errorf(\"output is not valid JSON\")\n    83Ôćĺ\t}\n    84Ôćĺ\n    85Ôćĺ\tfor _, seg := range p.Segments {\n    86Ôćĺ\t\tswitch seg.Kind {\n    87Ôćĺ\t\tcase SegmentField:\n    88Ôćĺ\t\t\tm, ok := val.(map[string]any)\n    89Ôćĺ\t\t\tif !ok {\n    90Ôćĺ\t\t\t\treturn \"\", fmt.Errorf(\"expected object for .%s\", seg.Field)\n    91Ôćĺ\t\t\t}\n    92Ôćĺ\t\t\tval, ok = m[seg.Field]\n    93Ôćĺ\t\t\tif !ok {\n    94Ôćĺ\t\t\t\treturn \"\", fmt.Errorf(\"field %q not found\", seg.Field)\n    95Ôćĺ\t\t\t}\n    96Ôćĺ\t\tcase SegmentIndex:\n    97Ôćĺ\t\t\tarr, ok := val.([]any)\n    98Ôćĺ\t\t\tif !ok {\n    99Ôćĺ\t\t\t\treturn \"\", fmt.Errorf(\"expected array for [%d]\", seg.Index)\n   100Ôćĺ\t\t\t}\n   101Ôćĺ\t\t\tif seg.Index < 0 || seg.Index >= len(arr) {\n   102Ôćĺ\t\t\t\treturn \"\", fmt.Errorf(\"index %d out of range (len %d)\", seg.Index, len(arr))\n   103Ôćĺ\t\t\t}\n   104Ôćĺ\t\t\tval = arr[seg.Index]\n   105Ôćĺ\t\t}\n   106Ôćĺ\t}\n   107Ôćĺ\n   108Ôćĺ\tswitch v := val.(type) {\n   109Ôćĺ\tcase string:\n   110Ôćĺ\t\treturn v, nil\n   111Ôćĺ\tdefault:\n   112Ôćĺ\t\tb, _ := json.Marshal(v)\n   113Ôćĺ\t\treturn string(b), nil\n   114Ôćĺ\t}\n   115Ôćĺ}\n   116Ôćĺ\n   117Ôćĺtype CollectMode string\n   118Ôćĺ\n   119Ôćĺconst (\n   120Ôćĺ\tCollectAll CollectMode = \"all\"\n   121Ôćĺ\tCollectAny CollectMode = \"any\"\n   122Ôćĺ)\n   123Ôćĺ\n   124Ôćĺtype WireCondition struct {\n   125Ôćĺ\tStep   string\n   126Ôćĺ\tResult string\n   127Ôćĺ}\n   128Ôćĺ\n   129Ôćĺtype Collect struct {\n   130Ôćĺ\tMode       CollectMode\n   131Ôćĺ\tConditions []WireCondition\n   132Ôćĺ\tTo         string\n   133Ôćĺ}\n   134Ôćĺ\n   135Ôćĺtype Workflow struct {\n   136Ôćĺ\tName      string\n   137Ôćĺ\tLocation  WorkflowLocation  // host or container\n   138Ôćĺ\tSteps     map[string]*Step\n   139Ôćĺ\tWiring    []Wire\n   140Ôćĺ\tCollects  []Collect\n   141Ôćĺ\tEntryStep string\n   142Ôćĺ\tConfig    map[string]string // workflow-level config (e.g. \"container.image\")\n   143Ôćĺ}\n   144Ôćĺ\n   145Ôćĺfunc (w *Workflow) Validate() error {\n   146Ôćĺ\tif w.EntryStep == \"\" {\n   147Ôćĺ\t\treturn fmt.Errorf(\"workflow %q: no entry step defined\", w.Name)\n   148Ôćĺ\t}\n   149Ôćĺ\tif _, ok := w.Steps[w.EntryStep]; !ok {\n   150Ôćĺ\t\treturn fmt.Errorf(\"workflow %q: entry step %q not found\", w.Name, w.EntryStep)\n   151Ôćĺ\t}\n   152Ôćĺ\n   153Ôćĺ\twired := make(map[string]map[string]bool)\n   154Ôćĺ\treachable := map[string]bool{w.EntryStep: true}\n   155Ôćĺ\tfor _, wire := range w.Wiring {\n   156Ôćĺ\t\tif wired[wire.From] == nil {\n   157Ôćĺ\t\t\twired[wire.From] = make(map[string]bool)\n   158Ôćĺ\t\t}\n   159Ôćĺ\t\twired[wire.From][wire.Result] = true\n   160Ôćĺ\t\tif wire.To != StepDone && wire.To != StepAbort {\n   161Ôćĺ\t\t\treachable[wire.To] = true\n   162Ôćĺ\t\t}\n   163Ôćĺ\t}\n   164Ôćĺ\n   165Ôćĺ\t// Validate collects and count their results as wired\n   166Ôćĺ\tfor _, c := range w.Collects {\n   167Ôćĺ\t\t// Validate target step exists\n   168Ôćĺ\t\tif c.To != StepDone && c.To != StepAbort {\n   169Ôćĺ\t\t\tif _, ok := w.Steps[c.To]; !ok {\n   170Ôćĺ\t\t\t\treturn fmt.Errorf(\"workflow %q: collect target step %q not found\", w.Name, c.To)\n   171Ôćĺ\t\t\t}\n   172Ôćĺ\t\t\treachable[c.To] = true\n   173Ôćĺ\t\t}\n   174Ôćĺ\n   175Ôćĺ\t\tfor _, cond := range c.Conditions {\n   176Ôćĺ\t\t\t// Validate condition step exists\n   177Ôćĺ\t\t\tstep, ok := w.Steps[cond.Step]\n   178Ôćĺ\t\t\tif !ok {\n   179Ôćĺ\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references unknown step %q\", w.Name, cond.Step)\n   180Ôćĺ\t\t\t}\n   181Ôćĺ\t\t\t// Validate condition result is declared\n   182Ôćĺ\t\t\tfound := false\n   183Ôćĺ\t\t\tfor _, r := range step.Results {\n   184Ôćĺ\t\t\t\tif r == cond.Result {\n   185Ôćĺ\t\t\t\t\tfound = true\n   186Ôćĺ\t\t\t\t\tbreak\n   187Ôćĺ\t\t\t\t}\n   188Ôćĺ\t\t\t}\n   189Ôćĺ\t\t\tif !found {\n   190Ôćĺ\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references undeclared result %q on step %q\", w.Name, cond.Result, cond.Step)\n   191Ôćĺ\t\t\t}\n   192Ôćĺ\t\t\t// Mark as wired so the \"every result must be wired\" check passes\n   193Ôćĺ\t\t\tif wired[cond.Step] == nil {\n   194Ôćĺ\t\t\t\twired[cond.Step] = make(map[string]bool)\n   195Ôćĺ\t\t\t}\n   196Ôćĺ\t\t\twired[cond.Step][cond.Result] = true\n   197Ôćĺ\t\t}\n   198Ôćĺ\t}\n   199Ôćĺ\n   200Ôćĺ\tfor name, step := range w.Steps {\n   201Ôćĺ\t\tfor _, result := range step.Results {\n   202Ôćĺ\t\t\tif !wired[name][result] {\n   203Ôćĺ\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q result %q is not wired\", w.Name, name, result)\n   204Ôćĺ\t\t\t}\n   205Ôćĺ\t\t}\n   206Ôćĺ\t}\n   207Ôćĺ\n   208Ôćĺ\tfor name := range w.Steps {\n   209Ôćĺ\t\tif !reachable[name] {\n   210Ôćĺ\t\t\treturn fmt.Errorf(\"workflow %q: step %q is orphaned (unreachable)\", w.Name, name)\n   211Ôćĺ\t\t}\n   212Ôćĺ\t}\n   213Ôćĺ\n   214Ôćĺ\t// Check for duplicate output mapping env vars targeting the same step\n   215Ôćĺ\ttargetEnvVars := make(map[string]map[string]bool) // step -> env var -> seen\n   216Ôćĺ\tfor _, wire := range w.Wiring {\n   217Ôćĺ\t\tfor _, om := range wire.OutputMap {\n   218Ôćĺ\t\t\tif targetEnvVars[wire.To] == nil {\n   219Ôćĺ\t\t\t\ttargetEnvVars[wire.To] = make(map[string]bool)\n   220Ôćĺ\t\t\t}\n   221Ôćĺ\t\t\tif targetEnvVars[wire.To][om.EnvVar] {\n   222Ôćĺ\t\t\t\treturn fmt.Errorf(\"duplicate output mapping for env var %q targeting step %q\", om.EnvVar, wire.To)\n   223Ôćĺ\t\t\t}\n   224Ôćĺ\t\t\ttargetEnvVars[wire.To][om.EnvVar] = true\n   225Ôćĺ\t\t}\n   226Ôćĺ\t}\n   227Ôćĺ\n   228Ôćĺ\treturn nil\n   229Ôćĺ}\n   230Ôćĺ\n   231Ôćĺ// ValidateLocation checks that step types are compatible with the workflow location.\n   232Ôćĺ// workflow_name steps are only allowed in host workflows.\n   233Ôćĺfunc (w *Workflow) ValidateLocation() error {\n   234Ôćĺ\tif w.Location == LocationContainer {\n   235Ôćĺ\t\tfor name, step := range w.Steps {\n   236Ôćĺ\t\t\tif step.Type == StepTypeWorkflow {\n   237Ôćĺ\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q uses workflow_name, which is only allowed in host workflows (host.cloche)\", w.Name, name)\n   238Ôćĺ\t\t\t}\n   239Ôćĺ\t\t}\n   240Ôćĺ\t}\n   241Ôćĺ\treturn nil\n   242Ôćĺ}\n   243Ôćĺ\n   244Ôćĺ// knownStepConfigKeys lists recognized step-level config keys.\n   245Ôćĺ// Keys with a \"container.\" prefix are also allowed.\n   246Ôćĺvar knownStepConfigKeys = map[string]bool{\n   247Ôćĺ\t\"prompt\":        true,\n   248Ôćĺ\t\"run\":           true,\n   249Ôćĺ\t\"max_attempts\":  true,\n   250Ôćĺ\t\"timeout\":       true,\n   251Ôćĺ\t\"agent_command\": true,\n   252Ôćĺ\t\"agent_args\":    true,\n   253Ôćĺ\t\"results\":       true,\n   254Ôćĺ\t\"feedback\":      true,\n   255Ôćĺ\t\"workflow_name\": true,\n   256Ôćĺ\t\"prompt_step\":   true,\n   257Ôćĺ}\n   258Ôćĺ\n   259Ôćĺ// ValidateConfig checks step config keys against known keys and returns\n   260Ôćĺ// warnings for any unrecognized keys (likely typos).\n   261Ôćĺfunc (w *Workflow) ValidateConfig() []string {\n   262Ôćĺ\tvar warnings []string\n   263Ôćĺ\tfor name, step := range w.Steps {\n   264Ôćĺ\t\tfor key := range step.Config {\n   265Ôćĺ\t\t\tif knownStepConfigKeys[key] {\n   266Ôćĺ\t\t\t\tcontinue\n   267Ôćĺ\t\t\t}\n   268Ôćĺ\t\t\tif strings.HasPrefix(key, \"container.\") || strings.HasPrefix(key, \"host.\") {\n   269Ôćĺ\t\t\t\tcontinue\n   270Ôćĺ\t\t\t}\n   271Ôćĺ\t\t\twarnings = append(warnings, fmt.Sprintf(\n   272Ôćĺ\t\t\t\t\"workflow %q: step %q has unrecognized config key %q\", w.Name, name, key))\n   273Ôćĺ\t\t}\n   274Ôćĺ\t}\n   275Ôćĺ\treturn warnings\n   276Ôćĺ}\n   277Ôćĺ\n   278Ôćĺ// NextSteps returns all target step names wired from the given (stepName, result) pair.\n   279Ôćĺ// Multiple targets indicate fanout ÔÇö parallel branches launched by the engine.\n   280Ôćĺfunc (w *Workflow) NextSteps(stepName, result string) ([]string, error) {\n   281Ôćĺ\tvar targets []string\n   282Ôćĺ\tfor _, wire := range w.Wiring {\n   283Ôćĺ\t\tif wire.From == stepName && wire.Result == result {\n   284Ôćĺ\t\t\ttargets = append(targets, wire.To)\n   285Ôćĺ\t\t}\n   286Ôćĺ\t}\n   287Ôćĺ\tif len(targets) == 0 {\n   288Ôćĺ\t\treturn nil, fmt.Errorf(\"workflow %q: no wiring for step %q result %q\", w.Name, stepName, result)\n   289Ôćĺ\t}\n   290Ôćĺ\treturn targets, nil\n   291Ôćĺ}\n   292Ôćĺ\n   293Ôćĺ// Deprecated: NextStep returns the first target only. Use NextSteps for fanout support.\n   294Ôćĺfunc (w *Workflow) NextStep(stepName, result string) (string, error) {\n   295Ôćĺ\ttargets, err := w.NextSteps(stepName, result)\n   296Ôćĺ\tif err != nil {\n   297Ôćĺ\t\treturn \"\", err\n   298Ôćĺ\t}\n   299Ôćĺ\treturn targets[0], nil\n   300Ôćĺ}\n   301Ôćĺ"}]},"parent_tool_use_id":"toolu_01PBzqGrRSxSxC8pWZNjvguQ","session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"a425df90-30ef-47aa-a9f7-c1db0f85230e"}
