, COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,''), COALESCE(is_host,0), COALESCE(parent_run_id,'')`\n   145Ôćĺ\n   146Ôćĺ// scanRun scans a single row into a *domain.Run.\n   147Ôćĺfunc scanRun(scanner interface{ Scan(...any) error }) (*domain.Run, error) {\n   148Ôćĺ\trun := &domain.Run{}\n   149Ôćĺ\tvar activeSteps, startedAt, completedAt string\n   150Ôćĺ\tvar containerKept, isHost int\n   151Ôćĺ\terr := scanner.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title, &isHost, &run.ParentRunID)\n   152Ôćĺ\tif err != nil {\n   153Ôćĺ\t\treturn nil, err\n   154Ôćĺ\t}\n   155Ôćĺ\trun.SetActiveStepsFromString(activeSteps)\n   156Ôćĺ\trun.StartedAt = parseTime(startedAt)\n   157Ôćĺ\trun.CompletedAt = parseTime(completedAt)\n   158Ôćĺ\trun.ContainerKept = containerKept != 0\n   159Ôćĺ\trun.IsHost = isHost != 0\n   160Ôćĺ\treturn run, nil\n   161Ôćĺ}\n   162Ôćĺ\n   163Ôćĺfunc (s *Store) GetRun(ctx context.Context, id string) (*domain.Run, error) {\n   164Ôćĺ\trow := s.db.QueryRowContext(ctx,\n   165Ôćĺ\t\t`SELECT `+runSelectCols+` FROM runs WHERE id = ?`, id)\n   166Ôćĺ\n   167Ôćĺ\trun, err := scanRun(row)\n   168Ôćĺ\tif err == sql.ErrNoRows {\n   169Ôćĺ\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n   170Ôćĺ\t}\n   171Ôćĺ\treturn run, err\n   172Ôćĺ}\n   173Ôćĺ\n   174Ôćĺfunc (s *Store) UpdateRun(ctx context.Context, run *domain.Run) error {\n   175Ôćĺ\t_, err := s.db.ExecContext(ctx,\n   176Ôćĺ\t\t`UPDATE runs SET state = ?, active_steps = ?, started_at = ?, completed_at = ?, error_message = ?, container_id = ?, base_sha = ?, container_kept = ?, title = ?, is_host = ?, parent_run_id = ? WHERE id = ?`,\n   177Ôćĺ\t\tstring(run.State), run.ActiveStepsString(),\n   178Ôćĺ\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt),\n   179Ôćĺ\t\trun.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), 