0Ôćĺ\t\tstatus:         noopStatus{},\n    51Ôćĺ\t\tmaxSteps:       1000,\n    52Ôćĺ\t\tdefaultTimeout: DefaultStepTimeout,\n    53Ôćĺ\t}\n    54Ôćĺ}\n    55Ôćĺ\n    56Ôćĺfunc (e *Engine) SetStatusHandler(h StatusHandler) {\n    57Ôćĺ\te.status = h\n    58Ôćĺ}\n    59Ôćĺ\n    60Ôćĺfunc (e *Engine) SetMaxSteps(n int) {\n    61Ôćĺ\te.maxSteps = n\n    62Ôćĺ}\n    63Ôćĺ\n    64Ôćĺ// SetDefaultTimeout sets the default timeout for steps that don't specify one.\n    65Ôćĺfunc (e *Engine) SetDefaultTimeout(d time.Duration) {\n    66Ôćĺ\te.defaultTimeout = d\n    67Ôćĺ}\n    68Ôćĺ\n    69Ôćĺ// stepResult is sent from worker goroutines back to the main event loop.\n    70Ôćĺtype stepResult struct {\n    71Ôćĺ\tstepName string\n    72Ôćĺ\tresult   string\n    73Ôćĺ\terr      error\n    74Ôćĺ}\n    75Ôćĺ\n    76Ôćĺ// collectState tracks the satisfaction state of a single Collect clause.\n    77Ôćĺtype collectState struct {\n    78Ôćĺ\tcollect   *domain.Collect\n    79Ôćĺ\tsatisfied map[int]bool\n    80Ôćĺ\tfired     bool\n    81Ôćĺ}\n    82Ôćĺ\n    83Ôćĺfunc (e *Engine) Run(ctx context.Context, wf *domain.Workflow) (*domain.Run, error) {\n    84Ôćĺ\tif err := wf.Validate(); err != nil {\n    85Ôćĺ\t\treturn nil, fmt.Errorf(\"invalid workflow: %w\", err)\n    86Ôćĺ\t}\n    87Ôćĺ\tfor _, w := range wf.ValidateConfig() {\n    88Ôćĺ\t\tlog.Printf(\"WARNING: %s\", w)\n    89Ôćĺ\t}\n    90Ôćĺ\n    91Ôćĺ\trun := domain.NewRun(generateRunID(), wf.Name)\n    92Ôćĺ\trun.Start()\n    93Ôćĺ\n    94Ôćĺ\t// Check context cancellation before starting.\n    95Ôćĺ\tif err := ctx.Err(); err != nil {\n    96Ôćĺ\t\trun.Complete(domain.RunStateCancelled)\n    97Ôćĺ\t\treturn run, fmt.Errorf(\"workflow cancelled: %w\", err)\n    98Ôćĺ\t}\n    99Ôćĺ\n   100Ôćĺ\t// Build a set of (step, result) pairs that are handled by collects,\n   101Ôćĺ\t// so we know when a missing wire is acceptable.\n   102Ôćĺ\tcollectHandled := make(map[string]map[string]bool)\n   103Ôćĺ\tfor _, c := range wf.Collects {\n   104Ôćĺ\t\tfor _, cond := range c.Conditions {\n   105Ôćĺ\t\t\tif collectHandled[cond.Step] == nil {\n   106Ôćĺ\t\t\t\tcollectHandled[cond.Step] = make(map[string]bool)\n   107Ôćĺ\t\t\t}\n   108Ôćĺ\t\t\tcollectHandled[cond.Step][cond.Result] = true\n   109Ôćĺ\t\t}\n   110Ôćĺ\t}\n   111Ôćĺ\n   112Ôćĺ\t// Initialize collect states.\n   113Ôćĺ\tcStates := make([]*collectState, len(wf.Collects))\n   114Ôćĺ\tfor i := range wf.Collects {\n   115Ôćĺ\t\tcStates[i] = &collectState{\n   116Ôćĺ\t\t\tcollect:   &wf.Collects[i],\n   117Ôćĺ\t\t\tsatisfied: make(map[int]bool),\n   118Ôćĺ\t\t}\n   119Ôćĺ\t}\n   120Ôćĺ\n   121Ôćĺ\tresults := make(chan stepResult, e.maxSteps)\n   122Ôćĺ\tactiveCount := 0\n   123Ôćĺ\tstepCount := 0\n   124Ôćĺ\tdoneCount := 0\n   125Ôćĺ\taborted := false\n   126Ôćĺ\tvar runErr error\n   127Ôćĺ\n   128Ôćĺ\t// Use a mutex to protect run state from concurrent goroutine access.\n   129Ôćĺ\t// Only the main loop should touch the Run, but we record step start before\n   130Ôćĺ\t// launching the goroutine, so this is safe without a mutex for now.\n   131Ôćĺ\t// The goroutines only read the step and send on the channel.\n   132Ôćĺ\n   133Ôćĺ\tlaunchStep := func(stepName string) error {\n   134Ôćĺ\t\tstepCount++\n   135Ôćĺ\t\tif stepCount > e.maxSteps {\n   136Ôćĺ\t\t\treturn fmt.Errorf(\"workflow exceeded maximum step count (%d)\", e.maxSteps)\n   137Ôćĺ\t\t}\n   138Ôćĺ\n   139Ôćĺ\t\tstep, ok := wf.Steps[stepName]\n   140Ôćĺ\t\tif !ok {\n   141Ôćĺ\t\t\treturn fmt.Errorf(\"step %q not found in workflow\", stepName)\n   142Ôćĺ\t\t}\n   143Ôćĺ\n   144Ôćĺ\t\tactiveCount++\n   145Ôćĺ\t\trun.RecordStepStart(step.Name)\n   146Ôćĺ\t\te.status.OnStepStart(run, step)\n   147Ôćĺ\n   148Ôćĺ\t\tgo func(s *domain.Step) {\n   149Ôćĺ\t\t\tstepCtx := ctx\n   150Ôćĺ\t\t\tif d := stepTimeout(s, e.defaultTimeout); d > 0 {\n   151Ôćĺ\t\t\t\tvar cancel context.CancelFunc\n   152Ôćĺ\t\t\t\tstepCtx, cancel = context.WithTimeout(ctx, d)\n   153Ôćĺ\t\t\t\tdefer cancel()\n   154Ôćĺ\t\t\t}\n   155Ôćĺ\t\t\tresult, err := e.executor.Execute(stepCtx, s)\n   156Ôćĺ\t\t\tresults <- stepResult{stepName: s.Name, result: result, err: err}\n   157Ôćĺ\t\t}(step)\n   158Ôćĺ\n   159Ôćĺ\t\treturn nil\n   160Ôćĺ\t}\n   161Ôćĺ\n   162Ôćĺ\t// Launch entry step.\n   163Ôćĺ\tif err := launchStep(wf.EntryStep); err != nil {\n   164Ôćĺ\t\trun.Complete(domain.RunStateFailed)\n   165Ôćĺ\t\treturn run, err\n   166Ôćĺ\t}\n   167Ôćĺ\n   168Ôćĺ\t// Main event loop.\n   169Ôćĺ\tfor activeCount > 0 {\n   170Ôćĺ\t\tselect {\n   171Ôćĺ\t\tcase <-ctx.Done():\n   172Ôćĺ\t\t\trun.Complete(domain.RunStateCancelled)\n   173Ôćĺ\t\t\treturn run, fmt.Errorf(\"workflow cancelled: %w\", ctx.Err())\n   174Ôćĺ\n   175Ôćĺ\t\tcase sr := <-results:\n   176Ôćĺ\t\t\tactiveCount--\n   177Ôćĺ\n   178Ôćĺ\t\t\t// Step execution error.\n   179Ôćĺ\t\t\tif sr.err != nil {\n   180Ôćĺ\t\t\t\trun.RecordStepComplete(sr.stepName, \"error\")\n   181Ôćĺ\t\t\t\trun.Complete(domain.RunStateFailed)\n   182Ôćĺ\t\t\t\te.status.OnRunComplete(run)\n   183Ôćĺ\t\t\t\treturn run, fmt.Errorf(\"step %q execution failed: %w\", sr.stepName, sr.err)\n   184Ôćĺ\t\t\t}\n   185Ôćĺ\n   186Ôćĺ\t\t\t// Validate result is declared in the step's Results list.\n   187Ôćĺ\t\t\tstep := wf.Steps[sr.stepName]\n   188Ôćĺ\t\t\tif !isResultDeclared(step, sr.result) {\n   189Ôćĺ\t\t\t\trun.RecordStepComplete(sr.stepName, sr.result)\n   190Ôćĺ\t\t\t\trun.Complete(domain.RunStateFailed)\n   191Ôćĺ\t\t\t\te.status.OnRunComplete(run)\n   192Ôćĺ\t\t\t\treturn run, fmt.Errorf(\"step %q returned undeclared result %q\", sr.stepName, sr.result)\n   193Ôćĺ\t\t\t}\n   194Ôćĺ\n   195Ôćĺ\t\t\trun.RecordStepComplete(sr.stepName, sr.result)\n   196Ôćĺ\t\t\te.status.OnStepComplete(run, step, sr.result)\n   197Ôćĺ\n   198Ôćĺ\t\t\t// Process wiring: get next steps for this (step, result) pair.\n   199Ôćĺ\t\t\tnextSteps, wireErr := wf.NextSteps(sr.stepName, sr.result)\n   200Ôćĺ\t\t\tif wireErr != nil {\n   201Ôćĺ\t\t\t\t// No wire found. Check if any collect handles this (step, result).\n   202Ôćĺ\t\t\t\tif !collectHandled[sr.stepName][sr.result] {\n   203Ôćĺ\t\t\t\t\t// Neither wires nor collects handle this result.\n   204Ôćĺ\t\t\t\t\trun.Complete(domain.RunStateFailed)\n   205Ôćĺ\t\t\t\t\te.status.OnRunComplete(run)\n   206Ôćĺ\t\t\t\t\treturn run, wireErr\n   207Ôćĺ\t\t\t\t}\n   208Ôćĺ\t\t\t\t// Collect handles it; no wire targets to launch.\n   209Ôćĺ\t\t\t} else {\n   210Ôćĺ\t\t\t\t// Process wire targets.\n   211Ôćĺ\t\t\t\tfor _, target := range nextSteps {\n   212Ôćĺ\t\t\t\t\tswitch target {\n   213Ôćĺ\t\t\t\t\tcase domain.StepDone:\n   214Ôćĺ\t\t\t\t\t\tdoneCount++\n   215Ôćĺ\t\t\t\t\tcase domain.StepAbort:\n   216Ôćĺ\t\t\t\t\t\taborted = true\n   217Ôćĺ\t\t\t\t\tdefault:\n   218Ôćĺ\t\t\t\t\t\tif err := launchStep(target); err != nil {\n   219Ôćĺ\t\t\t\t\t\t\trun.Complete(domain.RunStateFailed)\n   220Ôćĺ\t\t\t\t\t\t\te.status.OnRunComplete(run)\n   221Ôćĺ\t\t\t\t\t\t\treturn run, err\n   222Ôćĺ\t\t\t\t\t\t}\n   223Ôćĺ\t\t\t\t\t}\n   224Ôćĺ\t\t\t\t}\n   225Ôćĺ\t\t\t}\n   226Ôćĺ\n   227Ôćĺ\t\t\t// Check and fire collect conditions.\n   228Ôćĺ\t\t\tfor _, cs := range cStates {\n   229Ôćĺ\t\t\t\tif cs.fired {\n   230Ôćĺ\t\t\t\t\tcontinue\n   231Ôćĺ\t\t\t\t}\n   232Ôćĺ\t\t\t\tfor i, cond := range cs.collect.Conditions {\n   233Ôćĺ\t\t\t\t\tif cond.Step == sr.stepName && cond.Result == sr.result {\n   234Ôćĺ\t\t\t\t\t\tcs.satisfied[i] = true\n   235Ôćĺ\t\t\t\t\t}\n   236Ôćĺ\t\t\t\t}\n   237Ôćĺ\n   238Ôćĺ\t\t\t\tshouldFire := false\n   239Ôćĺ\t\t\t\tswitch cs.collect.Mode {\n   240Ôćĺ\t\t\t\tcase domain.CollectAll:\n   241Ôćĺ\t\t\t\t\tshouldFire = len(cs.satisfied) == len(cs.collect.Conditions)\n   242Ôćĺ\t\t\t\tcase domain.CollectAny:\n   243Ôćĺ\t\t\t\t\tshouldFire = len(cs.satisfied) > 0\n   244Ôćĺ\t\t\t\t}\n   245Ôćĺ\n   246Ôćĺ\t\t\t\tif shouldFire {\n   247Ôćĺ\t\t\t\t\tcs.fired = true\n   248Ôćĺ\t\t\t\t\ttarget := cs.collect.To\n   249Ôćĺ\t\t\t\t\tswitch target {\n   250Ôćĺ\t\t\t\t\tcase domain.StepDone:\n   251Ôćĺ\t\t\t\t\t\tdoneCount++\n   252Ôćĺ\t\t\t\t\tcase domain.StepAbort:\n   253Ôćĺ\t\t\t\t\t\taborted = true\n   254Ôćĺ\t\t\t\t\tdefault:\n   255Ôćĺ\t\t\t\t\t\tif err := launchStep(target); err != nil {\n   256Ôćĺ\t\t\t\t\t\t\trun.Complete(domain.RunStateFailed)\n   257Ôćĺ\t\t\t\t\t\t\te.status.OnRunComplete(run)\n   258Ôćĺ\t\t\t\t\t\t\treturn run, err\n   259Ôćĺ\t\t\t\t\t\t}\n   260Ôćĺ\t\t\t\t\t}\n   261Ôćĺ\t\t\t\t}\n   262Ôćĺ\t\t\t}\n   263Ôćĺ\t\t}\n   264Ôćĺ\t}\n   265Ôćĺ\n   266Ôćĺ\t// Determine final state.\n   267Ôćĺ\tif aborted || runErr != nil {\n   268Ôćĺ\t\trun.Complete(domain.RunStateFailed)\n   269Ôćĺ\t} else if doneCount > 0 {\n   270Ôćĺ\t\trun.Complete(domain.RunStateSucceeded)\n   271Ôćĺ\t} else {\n   272Ôćĺ\t\trun.Complete(domain.RunStateFailed)\n   273Ôćĺ\t\trunErr = fmt.Errorf(\"workflow %q: no branches reached done\", wf.Name)\n   274Ôćĺ\t}\n   275Ôćĺ\n   276Ôćĺ\te.status.OnRunComplete(run)\n   277Ôćĺ\treturn run, runErr\n   278Ôćĺ}\n   279Ôćĺ\n   280Ôćĺ// isResultDeclared checks whether the given result is in the step's declared Results list.\n   281Ôćĺfunc isResultDeclared(step *domain.Step, result string) bool {\n   282Ôćĺ\tfor _, r := range step.Results {\n   283Ôćĺ\t\tif r == result {\n   284Ôćĺ\t\t\treturn true\n   285Ôćĺ\t\t}\n   286Ôćĺ\t}\n   287Ôćĺ\treturn false\n   288Ôćĺ}\n   289Ôćĺ\n   290Ôćĺvar (\n   291Ôćĺ\trunCounter int\n   292Ôćĺ\trunMu      sync.Mutex\n   293Ôćĺ)\n   294Ôćĺ\n   295Ôćĺfunc generateRunID() string {\n   296Ôćĺ\trunMu.Lock()\n   297Ôćĺ\tdefer runMu.Unlock()\n   298Ôćĺ\trunCounter++\n   299Ôćĺ\treturn fmt.Sprintf(\"run-%d\", runCounter)\n   300Ôćĺ}\n   301Ôćĺ\n   302Ôćĺ// stepTimeout returns the timeout for a step. It checks step.Config[\"timeout\"]\n   303Ôćĺ// first, falling back to the provided default.\n   304Ôćĺfunc stepTimeout(step *domain.Step, defaultTimeout time.Duration) time.Duration {\n   305Ôćĺ\tif raw, ok := step.Config[\"timeout\"]; ok {\n   306Ôćĺ\t\tif d, err := time.ParseDuration(raw); err == nil {\n   3