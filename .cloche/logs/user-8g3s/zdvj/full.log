yte(output), &tasks); err != nil {\n    47Ôćĺ\t\treturn nil, fmt.Errorf(\"parsing list-tasks output: %w\", err)\n    48Ôćĺ\t}\n    49Ôćĺ\treturn tasks, nil\n    50Ôćĺ}\n    51Ôćĺ"}]},"parent_tool_use_id":"toolu_012epjQe4jiFDSKQ49cH1EjH","session_id":"b83aa53c-b539-403e-957d-d27f065bd09c","uuid":"4d628229-349e-4811-95b7-5070aa90c056"}
