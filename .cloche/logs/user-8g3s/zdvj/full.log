[2026-03-11T00:27:32Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017FAmvuxbuzrAJj6MeXz3Uw","type":"tool_result","content":"     1Ôćĺpackage main\n     2Ôćĺ\n     3Ôćĺimport (\n     4Ôćĺ\t\"context\"\n     5Ôćĺ\t\"fmt\"\n     6Ôćĺ\t\"net\"\n     7Ôćĺ\t\"net/http\"\n     8Ôćĺ\t\"os\"\n     9Ôćĺ\t\"os/signal\"\n    10Ôćĺ\t\"path/filepath\"\n    11Ôćĺ\t\"syscall\"\n    12Ôćĺ\n    13Ôćĺ\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14Ôćĺ\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    15Ôćĺ\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    16Ôćĺ\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    17Ôćĺ\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    18Ôćĺ\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    19Ôćĺ\t\"github.com/cloche-dev/cloche/internal/config\"\n    20Ôćĺ\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    21Ôćĺ\thostpkg \"github.com/cloche-dev/cloche/internal/host\"\n    22Ôćĺ\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    23Ôćĺ\t\"github.com/cloche-dev/cloche/internal/ports\"\n    24Ôćĺ\t\"google.golang.org/grpc\"\n    25Ôćĺ)\n    26Ôćĺ\n    27Ôćĺfunc main() {\n    28Ôćĺ\t// Load global config file (~/.config/cloche/config)\n    29Ôćĺ\tglobalCfg, err := config.LoadGlobal()\n    30Ôćĺ\tif err != nil {\n    31Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n    32Ôćĺ\t\tdefaults := config.Config{}\n    33Ôćĺ\t\tglobalCfg = &defaults\n    34Ôćĺ\t}\n    35Ôćĺ\n    36Ôćĺ\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, \"cloche.db\")\n    37Ôćĺ\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, \"unix:///tmp/cloche.sock\")\n    38Ôćĺ\n    39Ôćĺ\tstore, err := sqlite.NewStore(dbPath)\n    40Ôćĺ\tif err != nil {\n    41Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    42Ôćĺ\t\tos.Exit(1)\n    43Ôćĺ\t}\n    44Ôćĺ\tdefer store.Close()\n    45Ôćĺ\n    46Ôćĺ\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    47Ôćĺ\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    48Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    49Ôćĺ\t} else if n > 0 {\n    50Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    51Ôćĺ\t}\n    52Ôćĺ\n    53Ôćĺ\truntime, err := initRuntime(globalCfg)\n    54Ôćĺ\tif err != nil {\n    55Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    56Ôćĺ\t\tos.Exit(1)\n    57Ôćĺ\t}\n    58Ôćĺ\n    59Ôćĺ\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    60Ôćĺ\n    61Ôćĺ\tbroadcaster := logstream.NewBroadcaster()\n    62Ôćĺ\n    63Ôćĺ\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    64Ôćĺ\tsrv.SetLogStore(store)\n    65Ôćĺ\tsrv.SetLogBroadcaster(broadcaster)\n    66Ôćĺ\n    67Ôćĺ\t// Set up evolution trigger\n    68Ôćĺ\tevoTrigger := initEvolution(globalCfg, store, store)\n    69Ôćĺ\tif evoTrigger != nil {\n    70Ôćĺ\t\tsrv.SetEvolution(evoTrigger)\n    71Ôćĺ\t}\n    72Ôćĺ\n    73Ôćĺ\tgrpcServer := grpc.NewServer()\n    74Ôćĺ\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    75Ôćĺ\n    76Ôćĺ\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    77Ôćĺ\n    78Ôćĺ\tlis, err := listen(listenAddr)\n    79Ôćĺ\tif err != nil {\n    80Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    81Ôćĺ\t\tos.Exit(1)\n    82Ôćĺ\t}\n    83Ôćĺ\n    84Ôćĺ\tvar httpServer *http.Server\n    85Ôćĺ\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n    86Ôćĺ\t\twebOpts := []web.HandlerOption{\n    87Ôćĺ\t\t\tweb.WithContainerLogger(runtime),\n    88Ôćĺ\t\t\tweb.WithLogStore(store),\n    89Ôćĺ\t\t\tweb.WithLogBroadcaster(broadcaster),\n    90Ôćĺ\t\t}\n    91Ôćĺ\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n    92Ôćĺ\t\tif err != nil {\n    93Ôćĺ\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n    94Ôćĺ\t\t\tos.Exit(1)\n    95Ôćĺ\t\t}\n    96Ôćĺ\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n    97Ôćĺ\t\tgo func() {\n    98Ôćĺ\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n    99Ôćĺ\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   100Ôćĺ\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   101Ôćĺ\t\t\t}\n   102Ôćĺ\t\t}()\n   103Ôćĺ\t}\n   104Ôćĺ\n   105Ôćĺ\t// Auto-execute main workflow for active projects\n   106Ôćĺ\tautoRunActiveProjects(store, srv)\n   107Ôćĺ\n   108Ôćĺ\tsigCh := make(chan os.Signal, 1)\n   109Ôćĺ\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   110Ôćĺ\tgo func() {\n   111Ôćĺ\t\t<-sigCh\n   112Ôćĺ\t\tif httpServer != nil {\n   113Ôćĺ\t\t\thttpServer.Close()\n   114Ôćĺ\t\t}\n   115Ôćĺ\t\tgrpcServer.GracefulStop()\n   116Ôćĺ\t}()\n   117Ôćĺ\n   118Ôćĺ\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   119Ôćĺ\tif err := grpcServer.Serve(lis); err != nil {\n   120Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   121Ôćĺ\t\tos.Exit(1)\n   122Ôćĺ\t}\n   123Ôćĺ}\n   124Ôćĺ\n   125Ôćĺfunc initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   126Ôćĺ\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   127Ôćĺ\n   128Ôćĺ\tswitch runtimeType {\n   129Ôćĺ\tcase \"local\":\n   130Ôćĺ\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   131Ôćĺ\t\tif agentPath == \"\" {\n   132Ôćĺ\t\t\t// Look for cloche-agent next to this binary\n   133Ôćĺ\t\t\texe, err := os.Executable()\n   134Ôćĺ\t\t\tif err == nil {\n   135Ôćĺ\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   136Ôćĺ\t\t\t} else {\n   137Ôćĺ\t\t\t\tagentPath = \"cloche-agent\"\n   138Ôćĺ\t\t\t}\n   139Ôćĺ\t\t}\n   140Ôćĺ\t\treturn local.NewRuntime(agentPath), nil\n   141Ôćĺ\tcase \"docker\":\n   142Ôćĺ\t\treturn docker.NewRuntime()\n   143Ôćĺ\tdefault:\n   144Ôćĺ\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   145Ôćĺ\t}\n   146Ôćĺ}\n   147Ôćĺ\n   148Ôćĺfunc initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   149Ôćĺ\t// Load config from working directory (daemon-level defaults)\n   150Ôćĺ\tcfg, err := config.Load(\".\")\n   151Ôćĺ\tif err != nil || !cfg.Evolution.Enabled {\n   152Ôćĺ\t\treturn nil\n   153Ôćĺ\t}\n   154Ôćĺ\n   155Ôćĺ\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   156Ôćĺ\tif llmCmd == \"\" {\n   157Ôćĺ\t\treturn nil\n   158Ôćĺ\t}\n   159Ôćĺ\n   160Ôćĺ\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   161Ôćĺ\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   162Ôćĺ\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   163Ôćĺ\t\t\t// Load per-project config for confidence threshold\n   164Ôćĺ\t\t\tprojCfg, err := config.Load(projectDir)\n   165Ôćĺ\t\t\tif err != nil {\n   166Ôćĺ\t\t\t\tprojCfg = cfg // fall back to daemon config\n   167Ôćĺ\t\t\t}\n   168Ôćĺ\n   169Ôćĺ\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   170Ôćĺ\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   171Ôćĺ\t\t\t\tProjectDir:    projectDir,\n   172Ôćĺ\t\t\t\tWorkflowName:  workflowName,\n   173Ôćĺ\t\t\t\tLLM:           llm,\n   174Ôćĺ\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   175Ôćĺ\t\t\t})\n   176Ôćĺ\n   177Ôćĺ\t\t\tctx := context.Background()\n   178Ôćĺ\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   179Ôćĺ\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   180Ôćĺ\t\t\t}\n   181Ôćĺ\t\t},\n   182Ôćĺ\t})\n   183Ôćĺ\n   184Ôćĺ\treturn trigger\n   185Ôćĺ}\n   186Ôćĺ\n   187Ôćĺfunc listen(addr string) (net.Listener, error) {\n   188Ôćĺ\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   189Ôćĺ\t\tsockPath := addr[7:]\n   190Ôćĺ\t\tos.Remove(sockPath)\n   191Ôćĺ\t\treturn net.Listen(\"unix\", sockPath)\n   192Ôćĺ\t}\n   193Ôćĺ\treturn net.Listen(\"tcp\", addr)\n   194Ôćĺ}\n   195Ôćĺ\n   196Ôćĺ// autoRunActiveProjects scans known projects for active = true in their config,\n   197Ôćĺ// parses .cloche/host.cloche and executes the full host workflow step by step.\n   198Ôćĺfunc autoRunActiveProjects(store ports.RunStore, srv *adaptgrpc.ClocheServer) {\n   199Ôćĺ\tctx := context.Background()\n   200Ôćĺ\tprojects, err := store.ListProjects(ctx)\n   201Ôćĺ\tif err != nil {\n   202Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"startup: failed to list projects: %v\\n\", err)\n   203Ôćĺ\t\treturn\n   204Ôćĺ\t}\n   205Ôćĺ\n   206Ôćĺ\tfor _, projectDir := range projects {\n   207Ôćĺ\t\tcfg, err := config.Load(projectDir)\n   208Ôćĺ\t\tif err != nil || !cfg.Active {\n   209Ôćĺ\t\t\tcontinue\n   210Ôćĺ\t\t}\n   211Ôćĺ\n   212Ôćĺ\t\t// Verify host.cloche exists before launching\n   213Ôćĺ\t\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   214Ôćĺ\t\tif _, err := os.Stat(hostPath); err != nil {\n   215Ôćĺ\t\t\tfmt.Fprintf(os.Stderr, \"startup: skipping active project %s: %v\\n\", projectDir, err)\n   216Ôćĺ\t\t\tcontinue\n   217Ôćĺ\t\t}\n   218Ôćĺ\n   219Ôćĺ\t\tfmt.Fprintf(os.Stderr, \"startup: auto-running host workflow for active project %s\\n\", projectDir)\n   220Ôćĺ\t\tgo func(projDir string) {\n   221Ôćĺ\t\t\trunner := &hostpkg.Runner{\n   222Ôćĺ\t\t\t\tDispatcher: srv,\n   223Ôćĺ\t\t\t\tStore:      store,\n   224Ôćĺ\t\t\t}\n   225Ôćĺ\t\t\tresult, err := runner.Run(context.Background(), projDir)\n   226Ôćĺ\t\t\tif err != nil {\n   227Ôćĺ\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow failed for %s: %v\\n\", projDir, err)\n   228Ôćĺ\t\t\t} else {\n   229Ôćĺ\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow completed for %s: %s (run %s)\\n\", projDir, result.State, result.RunID)\n   230Ôćĺ\t\t\t}\n   231Ôćĺ\t\t}(projectDir)\n   232Ôćĺ\t}\n   233Ôćĺ}\n   234Ôćĺ\n   235Ôćĺ// envOrConfig returns the env var value if set, otherwise the config file\n   236Ôćĺ// value if non-empty, otherwise the fallback default.\n   237Ôćĺfunc envOrConfig(envKey, configVal, fallback string) string {\n   238Ôćĺ\tif v := os.Getenv(envKey); v != \"\" {\n   239Ôćĺ\t\treturn v\n   240Ôćĺ\t}\n   241Ôćĺ\tif configVal != \"\" {\n   242Ôćĺ\t\treturn configVal\n   243Ôćĺ\t}\n   244Ôćĺ\treturn fallback\n   245Ôćĺ}\n   246Ôćĺ"}]},"parent_tool_use_id":"toolu_01Dpfoc28ynQqDwHgSbSci6o","session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"8b0a61f1-3ade-48b3-ac18-a3f981ec2c7a"}
