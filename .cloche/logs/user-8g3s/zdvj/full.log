[2026-03-11T00:27:32Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xc99FuCrgUBfFYASwspj4j","type":"tool_result","content":"     1Ôćĺ#!/usr/bin/env bash\n     2Ôćĺ# cleanup-run.sh ÔÇö Remove the worktree and branch left over from a cloche run.\n     3Ôćĺ# Expects CLOCHE_PREV_OUTPUT to point to a file containing the run ID.\n     4Ôćĺset -euo pipefail\n     5Ôćĺ\n     6Ôćĺif [ -z \"${CLOCHE_PREV_OUTPUT:-}\" ] || [ ! -f \"$CLOCHE_PREV_OUTPUT\" ]; then\n     7Ôćĺ  echo \"error: CLOCHE_PREV_OUTPUT not set or file missing\" >&2\n     8Ôćĺ  exit 1\n     9Ôćĺfi\n    10Ôćĺ\n    11ÔćĺRUN_ID=$(cat \"$CLOCHE_PREV_OUTPUT\" | tr -d '[:space:]')\n    12ÔćĺPROJECT_DIR=\"${CLOCHE_PROJECT_DIR:-.}\"\n    13Ôćĺ\n    14Ôćĺ# Try to find the task ID from the ready-tasks output in our run's output directory\n    15Ôćĺif [ -z \"${CLOCHE_TASK_ID:-}\" ]; then\n    16Ôćĺ  OUTPUT_DIR=\"$(dirname \"$CLOCHE_PREV_OUTPUT\")\"\n    17Ôćĺ  READY_OUT=\"$OUTPUT_DIR/ready-tasks.out\"\n    18Ôćĺ  if [ -f \"$READY_OUT\" ]; then\n    19Ôćĺ    CLOCHE_TASK_ID=$(jq -r '.[0].id // empty' \"$READY_OUT\" 2>/dev/null) || true\n    20Ôćĺ  fi\n    21Ôćĺfi\n    22ÔćĺBRANCH=\"cloche/${RUN_ID}\"\n    23ÔćĺWORKTREE_DIR=\"$PROJECT_DIR/.gitworktrees/cloche/$RUN_ID\"\n    24Ôćĺ\n    25Ôćĺ# Remove the extraction worktree if it still exists\n    26Ôćĺif [ -d \"$WORKTREE_DIR\" ]; then\n    27Ôćĺ  git -C \"$PROJECT_DIR\" worktree remove --force \"$WORKTREE_DIR\" 2>/dev/null || true\n    28Ôćĺfi\n    29Ôćĺ\n    30Ôćĺ# Prune any stale worktree bookkeeping\n    31Ôćĺgit -C \"$PROJECT_DIR\" worktree prune 2>/dev/null || true\n    32Ôćĺ\n    33Ôćĺ# Delete the branch if it still exists (merge may have already removed it)\n    34Ôćĺif git -C \"$PROJECT_DIR\" rev-parse --verify \"$BRANCH\" >/dev/null 2>&1; then\n    35Ôćĺ  git -C \"$PROJECT_DIR\" branch -D \"$BRANCH\" 2>/dev/null || true\n    36Ôćĺfi\n    37Ôćĺ\n    38Ôćĺ# Close the task if CLOCHE_TASK_ID is set\n    39Ôćĺif [ -n \"${CLOCHE_TASK_ID:-}\" ]; then\n    40Ôćĺ  bd close \"$CLOCHE_TASK_ID\" 2>/dev/null && echo \"Closed task $CLOCHE_TASK_ID\" || echo \"warning: could not close task $CLOCHE_TASK_ID\" >&2\n    41Ôćĺfi\n    42Ôćĺ\n    43Ôćĺecho \"Cleaned up run $RUN_ID\"\n    44Ôćĺ"}]},"parent_tool_use_id":"toolu_01PBzqGrRSxSxC8pWZNjvguQ","session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"5b009648-2a75-4b8b-b48d-ef687840aa1e"}
