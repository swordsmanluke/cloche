[2026-03-11T00:27:32Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LBmdj9FK7ZMfmtQDpedgz6","type":"tool_result","content":"     1Ôćĺpackage agent\n     2Ôćĺ\n     3Ôćĺimport (\n     4Ôćĺ\t\"context\"\n     5Ôćĺ\t\"fmt\"\n     6Ôćĺ\t\"io\"\n     7Ôćĺ\t\"os\"\n     8Ôćĺ\t\"path/filepath\"\n     9Ôćĺ\t\"strings\"\n    10Ôćĺ\n    11Ôćĺ\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n    12Ôćĺ\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    13Ôćĺ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14Ôćĺ\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    15Ôćĺ\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16Ôćĺ\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    17Ôćĺ\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    18Ôćĺ)\n    19Ôćĺ\n    20Ôćĺtype RunnerConfig struct {\n    21Ôćĺ\tWorkflowPath string\n    22Ôćĺ\tWorkDir      string\n    23Ôćĺ\tStatusOutput io.Writer\n    24Ôćĺ\tRunID        string\n    25Ôćĺ}\n    26Ôćĺ\n    27Ôćĺtype Runner struct {\n    28Ôćĺ\tcfg RunnerConfig\n    29Ôćĺ}\n    30Ôćĺ\n    31Ôćĺfunc NewRunner(cfg RunnerConfig) *Runner {\n    32Ôćĺ\treturn &Runner{\n    33Ôćĺ\t\tcfg: cfg,\n    34Ôćĺ\t}\n    35Ôćĺ}\n    36Ôćĺ\n    37Ôćĺfunc (r *Runner) Run(ctx context.Context) error {\n    38Ôćĺ\tdata, err := os.ReadFile(r.cfg.WorkflowPath)\n    39Ôćĺ\tif err != nil {\n    40Ôćĺ\t\treturn fmt.Errorf(\"reading workflow file: %w\", err)\n    41Ôćĺ\t}\n    42Ôćĺ\n    43Ôćĺ\twf, err := dsl.ParseForContainer(string(data))\n    44Ôćĺ\tif err != nil {\n    45Ôćĺ\t\treturn fmt.Errorf(\"parsing workflow: %w\", err)\n    46Ôćĺ\t}\n    47Ôćĺ\n    48Ôćĺ\tstatusWriter := protocol.NewStatusWriter(r.cfg.StatusOutput)\n    49Ôćĺ\tgenericAdapter := generic.New()\n    50Ôćĺ\tpromptAdapter := prompt.New()\n    51Ôćĺ\tpromptAdapter.RunID = r.cfg.RunID\n    52Ôćĺ\tpromptAdapter.StatusWriter = statusWriter\n    53Ôćĺ\tif cmd, ok := os.LookupEnv(\"CLOCHE_AGENT_COMMAND\"); ok {\n    54Ôćĺ\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    55Ôćĺ\t}\n    56Ôćĺ\tif cmd := wf.Config[\"container.agent_command\"]; cmd != \"\" {\n    57Ôćĺ\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    58Ôćĺ\t}\n    59Ôćĺ\tif args := wf.Config[\"container.agent_args\"]; args != \"\" {\n    60Ôćĺ\t\tpromptAdapter.ExplicitArgs = strings.Fields(args)\n    61Ôćĺ\t}\n    62Ôćĺ\n    63Ôćĺ\t// Reset per-run state from any previous run\n    64Ôćĺ\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"attempt_count\"))\n    65Ôćĺ\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"output\"))\n    66Ôćĺ\n    67Ôćĺ\t// Create unified log writer\n    68Ôćĺ\tulog, err := logstream.New(r.cfg.WorkDir)\n    69Ôćĺ\tif err != nil {\n    70Ôćĺ\t\treturn fmt.Errorf(\"creating unified log: %w\", err)\n    71Ôćĺ\t}\n    72Ôćĺ\tdefer ulog.Close()\n    73Ôćĺ\n    74Ôćĺ\tgenericAdapter.StatusWriter = statusWriter\n    75Ôćĺ\n    76Ôćĺ\texecutor := &stepExecutor{\n    77Ôćĺ\t\tworkDir:      r.cfg.WorkDir,\n    78Ôćĺ\t\tgeneric:      genericAdapter,\n    79Ôćĺ\t\tprompt:       promptAdapter,\n    80Ôćĺ\t\tlogStream:    ulog,\n    81Ôćĺ\t\tstatusWriter: statusWriter,\n    82Ôćĺ\t}\n    83Ôćĺ\n    84Ôćĺ\teng := engine.New(executor)\n    85Ôćĺ\teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n    86Ôćĺ\n    87Ôćĺ\t// Generate a run title from the prompt if one was not provided by the caller.\n    88Ôćĺ\t// The daemon sets title from --title; if empty, the agent extracts from prompt.\n    89Ôćĺ\tif title := extractTitle(r.cfg.WorkDir, r.cfg.RunID); title != \"\" {\n    90Ôćĺ\t\tstatusWriter.RunTitle(title)\n    91Ôćĺ\t}\n    92Ôćĺ\n    93Ôćĺ\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n    94Ôćĺ\n    95Ôćĺ\trun, runErr := eng.Run(ctx, wf)\n    96Ôćĺ\tif runErr != nil {\n    97Ôćĺ\t\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:failed\")\n    98Ôćĺ\t\tulog.Log(logstream.TypeStatus, \"error: \"+runErr.Error())\n    99Ôćĺ\t\tulog.Log(logstream.TypeStatus, \"run_completed: failed\")\n   100Ôćĺ\t\tstatusWriter.Error(\"\", runErr.Error())\n   101Ôćĺ\t\tstatusWriter.RunCompleted(\"failed\")\n   102Ôćĺ\t\treturn runErr\n   103Ôćĺ\t}\n   104Ôćĺ\n   105Ôćĺ\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:\"+string(run.State))\n   106Ôćĺ\n   107Ôćĺ\tulog.Log(logstream.TypeStatus, \"run_completed: \"+string(run.State))\n   108Ôćĺ\tstatusWriter.RunCompleted(string(run.State))\n   109Ôćĺ\treturn nil\n   110Ôćĺ}\n   111Ôćĺ\n   112Ôćĺtype stepExecutor struct {\n   113Ôćĺ\tworkDir      string\n   114Ôćĺ\tgeneric      *generic.Adapter\n   115Ôćĺ\tprompt       *prompt.Adapter\n   116Ôćĺ\tlogStream    *logstream.Writer\n   117Ôćĺ\tstatusWriter *protocol.StatusWriter\n   118Ôćĺ}\n   119Ôćĺ\n   120Ôćĺfunc (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n   121Ôćĺ\tswitch step.Type {\n   122Ôćĺ\tcase domain.StepTypeScript:\n   123Ôćĺ\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   124Ôćĺ\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   125Ôćĺ\t\treturn result, err\n   126Ôćĺ\tcase domain.StepTypeAgent:\n   127Ôćĺ\t\tif _, ok := step.Config[\"run\"]; ok {\n   128Ôćĺ\t\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   129Ôćĺ\t\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   130Ôćĺ\t\t\treturn result, err\n   131Ôćĺ\t\t}\n   132Ôćĺ\t\tif _, ok := step.Config[\"prompt\"]; ok {\n   133Ôćĺ\t\t\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   134Ôćĺ\t\t\t\te.prompt.Commands = prompt.ParseCommands(cmd)\n   135Ôćĺ\t\t\t}\n   136Ôćĺ\t\t\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   137Ôćĺ\t\t\t\te.prompt.ExplicitArgs = strings.Fields(args)\n   138Ôćĺ\t\t\t}\n   139Ôćĺ\t\t\tresult, err := e.prompt.Execute(ctx, step, e.workDir)\n   140Ôćĺ\t\t\te.copyToLLMLog(step.Name)\n   141Ôćĺ\t\t\te.logStepOutput(step.Name, logstream.TypeLLM)\n   142Ôćĺ\t\t\treturn result, err\n   143Ôćĺ\t\t}\n   144Ôćĺ\t\treturn \"\", fmt.Errorf(\"agent step %q requires either 'run' or 'prompt' config\", step.Name)\n   145Ôćĺ\tdefault:\n   146Ôćĺ\t\treturn \"\", fmt.Errorf(\"unknown step type: %s\", step.Type)\n   147Ôćĺ\t}\n   148Ôćĺ}\n   149Ôćĺ\n   150Ôćĺ// logStepOutput reads the per-step log file and writes its contents to the unified log.\n   151Ôćĺfunc (e *stepExecutor) logStepOutput(stepName string, typ logstream.EntryType) {\n   152Ôćĺ\tpath := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   153Ôćĺ\tdata, err := os.ReadFile(path)\n   154Ôćĺ\tif err != nil || len(data) == 0 {\n   155Ôćĺ\t\treturn\n   156Ôćĺ\t}\n   157Ôćĺ\te.logStream.Log(typ, string(data))\n   158Ôćĺ}\n   159Ôćĺ\n   160Ôćĺ// copyToLLMLog copies <step>.log to llm-<step>.log for agent prompt steps.\n   161Ôćĺfunc (e *stepExecutor) copyToLLMLog(stepName string) {\n   162Ôćĺ\tsrc := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   163Ôćĺ\tdst := filepath.Join(e.workDir, \".cloche\", \"output\", \"llm-\"+stepName+\".log\")\n   164Ôćĺ\tdata, err := os.ReadFile(src)\n   165Ôćĺ\tif err != nil {\n   166Ôćĺ\t\treturn\n   167Ôćĺ\t}\n   168Ôćĺ\t_ = os.WriteFile(dst, data, 0644)\n   169Ôćĺ}\n   170Ôćĺ\n   171Ôćĺtype statusReporter struct {\n   172Ôćĺ\twriter    *protocol.StatusWriter\n   173Ôćĺ\tlogStream *logstream.Writer\n   174Ôćĺ}\n   175Ôćĺ\n   176Ôćĺfunc (s *statusReporter) OnStepStart(_ *domain.Run, step *domain.Step) {\n   177Ôćĺ\ts.writer.StepStarted(step.Name)\n   178Ôćĺ\ts.logStream.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n   179Ôćĺ}\n   180Ôćĺ\n   181Ôćĺfunc (s *statusReporter) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   182Ôćĺ\ts.writer.StepCompleted(step.Name, result)\n   183Ôćĺ\ts.logStream.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n   184Ôćĺ}\n   185Ôćĺ\n   186Ôćĺfunc (s *statusReporter) OnRunComplete(_ *domain.Run) {}\n   187Ôćĺ\n   188Ôćĺ// extractTitle tries to derive a one-line summary from the run's prompt content.\n   189Ôćĺ// It reads the per-run prompt.txt file (written by the daemon before container start),\n   190Ôćĺ// then returns the first non-empty line, truncated to 100 characters.\n   191Ôćĺfunc extractTitle(workDir string, runID string) string {\n   192Ôćĺ\t// Try the per-run prompt file\n   193Ôćĺ\tpromptPath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   194Ôćĺ\tif _, err := os.Stat(promptPath); err != nil {\n   195Ôćĺ\t\t// Fall back to legacy path\n   196Ôćĺ\t\tpromptPath = filepath.Join(workDir, \".cloche\", \"prompt.txt\")\n   197Ôćĺ\t}\n   198Ôćĺ\tdata, err := os.ReadFile(promptPath)\n   199Ôćĺ\tif err != nil || len(data) == 0 {\n   200Ôćĺ\t\treturn \"\""}]},"parent_tool_use_id":"toolu_01Dpfoc28ynQqDwHgSbSci6o","session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"e23d1015-5947-4712-bc21-44808f0bbbaf"}
