!ok {\n   649Ôćĺ\t\t\t\t// Run completed ÔÇö send terminal entry.\n   650Ôćĺ\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   651Ôćĺ\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   652Ôćĺ\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   653Ôćĺ\t\t\t\t\t\tType:      \"run_completed\",\n   654Ôćĺ\t\t\t\t\t\tResult:    string(run.State),\n   655Ôćĺ\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   656Ôćĺ\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   657Ôćĺ\t\t\t\t\t})\n   658Ôćĺ\t\t\t\t}\n   659Ôćĺ\t\t\t\treturn nil\n   660Ôćĺ\t\t\t}\n   661Ôćĺ\t\t\tif err := stream.Send(&pb.LogEntry{\n   662Ôćĺ\t\t\t\tType:      \"log\",\n   663Ôćĺ\t\t\t\tStepName:  line.StepName,\n   664Ôćĺ\t\t\t\tMessage:   line.Content,\n   665Ôćĺ\t\t\t\tTimestamp: line.Timestamp,\n   666Ôćĺ\t\t\t}); err != nil {\n   667Ôćĺ\t\t\t\treturn err\n   668Ôćĺ\t\t\t}\n   669Ôćĺ\t\t}\n   670Ôćĺ\t}\n   671Ôćĺ}\n   672Ôćĺ\n   673Ôćĺfunc (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   674Ôćĺ\ts.mu.Lock()\n   675Ôćĺ\tcontainerID, ok := s.runIDs[req.RunId]\n   676Ôćĺ\ts.mu.Unlock()\n   677Ôćĺ\n   678Ôćĺ\tif !ok {\n   679Ôćĺ\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   680Ôćĺ\t}\n   681Ôćĺ\n   682Ôćĺ\tif err := s.container.Stop(ctx, containerID); err != nil {\n   683Ôćĺ\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   684Ôćĺ\t}\n   685Ôćĺ\n   686Ôćĺ\t// Mark as cancelled in store\n   687Ôćĺ\trun, err := s.store.GetRun(ctx, req.RunId)\n   688Ôćĺ\tif err == nil {\n   689Ôćĺ\t\trun.Complete(domain.RunStateCancelled)\n   690Ôćĺ\t\t_ = s.store.UpdateRun(ctx, run)\n   691Ôćĺ\t}\n   692Ôćĺ\n   693Ôćĺ\treturn &pb.StopRunResponse{}, nil\n   694Ôćĺ}\n   695Ôćĺ\n   696Ôćĺfunc (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   697Ôćĺ\tif s.container == nil {\n   698Ôćĺ\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   699Ôćĺ\t}\n   700Ôćĺ\n   701Ôćĺ\tid := req.Id\n   702Ôćĺ\tif id == \"\" {\n   703Ôćĺ\t\treturn nil, fmt.Errorf(\"id is required\")\n   704Ôćĺ\t}\n   705Ôćĺ\n   706Ôćĺ\t// Try to resolve as a run ID first\n   707Ôćĺ\tcontainerID := id\n   708Ôćĺ\trun, err := s.store.GetRun(ctx, id)\n   709Ôćĺ\tif err == nil {\n   710Ôćĺ\t\t// It's a run ID ÔÇö use the container ID from the run record\n   711Ôćĺ\t\tif run.ContainerID == \"\" {\n   712Ôćĺ\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   713Ôćĺ\t\t}\n   714Ôćĺ\t\tcontainerID = run.ContainerID\n   715Ôćĺ\t}\n   716Ôćĺ\n   717Ôćĺ\t// Remove the container\n   718Ôćĺ\tif err := s.container.Remove(ctx, containerID); err != nil {\n   719Ôćĺ\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   720Ôćĺ\t}\n   721Ôćĺ\n   722Ôćĺ\t// If we resolved a run, clear the container_kept flag\n   723Ôćĺ\tif run != nil {\n   724Ôćĺ\t\trun.ContainerKept = false\n   725Ôćĺ\t\t_ = s.store.UpdateRun(ctx, run)\n   726Ôćĺ\t}\n   727Ôćĺ\n   728Ôćĺ\treturn &pb.DeleteContainerResponse{}, nil\n   729Ôćĺ}\n   730Ôćĺ\n   731Ôćĺfunc (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   732Ôćĺ\tprojectDir := req.ProjectDir\n   733Ôćĺ\tif projectDir == \"\" {\n   734Ôćĺ\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   735Ôćĺ\t}\n   736Ôćĺ\n   737Ôćĺ\t// Verify host.cloche exists\n   738Ôćĺ\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   739Ôćĺ\tif _, err := os.Stat(hostPath); err != nil {\n   740Ôćĺ\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n   741Ôćĺ\t}\n   742Ôćĺ\n   743Ôćĺ\t// Load project config for defaults.\n   744Ôćĺ\tprojCfg, _ := config.Load(projectDir)\n   745Ôćĺ\n   746Ôćĺ\tmaxConc := int(req.MaxConcurrent)\n   747Ôćĺ\tif maxConc <= 0 {\n   748Ôćĺ\t\tmaxConc = projCfg.Orchestration.Concurrency\n   749Ôćĺ\t}\n   750Ôćĺ\tif maxConc <= 0 {\n   751Ôćĺ\t\tmaxConc = 1\n   752Ôćĺ\t}\n   753Ôćĺ\n   754Ôćĺ\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   755Ôćĺ\n   756Ôćĺ\ts.mu.Lock()\n   757Ôćĺ\tdefer s.mu.Unlock()\n   758Ôćĺ\n   759Ôćĺ\t// Stop existing loop if running.\n   760Ôćĺ\tif existing, ok := s.loops[projectDir]; ok {\n   761Ôćĺ\t\texisting.Stop()\n   762Ôćĺ\t}\n   763Ôćĺ\n   764Ôćĺ\trunFn := func(ctx context.Context, projDir string) (*host.RunResult, error) {\n   765Ôćĺ\t\trunner := &host.Runner{\n   766Ôćĺ\t\t\tDispatcher: s,\n   767Ôćĺ\t\t\tStore:      s.store,\n   768Ôćĺ\t\t}\n   769Ôćĺ\t\treturn runner.Run(ctx, projDir)\n   770Ôćĺ\t}\n   771Ôćĺ\n   772Ôćĺ\tloop := host.NewLoop(host.LoopConfig{\n   773Ôćĺ\t\tProjectDir:    projectDir,\n   774Ôćĺ\t\tMaxConcurrent: maxConc,\n   775Ôćĺ\t\tStaggerDelay:  stagger,\n   776Ôćĺ\t}, s.store, runFn)\n   777Ôćĺ\ts.loops[projectDir] = loop\n   778Ôćĺ\tloop.Start()\n   779Ôćĺ\n   780Ôćĺ\treturn &pb.EnableLoopResponse{}, nil\n   781Ôćĺ}\n   782Ôćĺ\n   783Ôćĺfunc (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n   784Ôćĺ\tprojectDir := req.ProjectDir\n   785Ôćĺ\tif projectDir == \"\" {\n   786Ôćĺ\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   787Ôćĺ\t}\n   788Ôćĺ\n   789Ôćĺ\ts.mu.Lock()\n   790Ôćĺ\tdefer s.mu.Unlock()\n   791Ôćĺ\n   792Ôćĺ\tif loop, ok := s.loops[projectDir]; ok {\n   793Ôćĺ\t\tloop.Stop()\n   794Ôćĺ\t\tdelete(s.loops, projectDir)\n   795Ôćĺ\t}\n   796Ôćĺ\n   797Ôćĺ\treturn &pb.DisableLoopResponse{}, nil\n   798Ôćĺ}\n   799Ôćĺ"}]},"parent_tool_use_id":"toolu_01Dpfoc28ynQqDwHgSbSci6o","session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"1c60de16-041b-4b75-ba8a-39a14de48b28"}
