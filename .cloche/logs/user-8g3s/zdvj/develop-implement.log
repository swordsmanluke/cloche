{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R95U2s7Mx6r4xyQDFKkwWj","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# claim-task.sh — Claim a bead task by setting it to in_progress.\n     3→# Expects CLOCHE_TASK_ID env var from the previous step's output mapping.\n     4→set -euo pipefail\n     5→\n     6→if [ -z \"${CLOCHE_TASK_ID:-}\" ]; then\n     7→  echo \"error: CLOCHE_TASK_ID not set\" >&2\n     8→  exit 1\n     9→fi\n    10→\n    11→# Capture bd output separately so it doesn't corrupt our JSON stdout.\n    12→claim_output=$(bd update \"$CLOCHE_TASK_ID\" --claim 2>&1) || true\n    13→\n    14→# bd exits 0 even on failure, so check for error in output.\n    15→if echo \"$claim_output\" | grep -qi \"error\\|already claimed\"; then\n    16→  echo \"claim failed: $claim_output\" >&2\n    17→  exit 1\n    18→fi\n    19→\n    20→# Forward task info as properly escaped JSON so downstream steps can parse it.\n    21→jq -n --arg id \"${CLOCHE_TASK_ID}\" \\\n    22→      --arg title \"${CLOCHE_TASK_TITLE:-}\" \\\n    23→      --arg desc \"${CLOCHE_TASK_BODY:-}\" \\\n    24→      '[{id: $id, title: $title, description: $desc}]'\n    25→"}]},"parent_tool_use_id":"toolu_01PBzqGrRSxSxC8pWZNjvguQ","session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"5f02c478-81d3-4478-8457-01234cb277d4"}
