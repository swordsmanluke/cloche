{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011zkTTFBqkbkzZaJeyZyRhP","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"os\"\n     6→\t\"os/exec\"\n     7→\t\"path/filepath\"\n     8→\t\"testing\"\n     9→\t\"time\"\n    10→\n    11→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    14→\t\"github.com/stretchr/testify/assert\"\n    15→\t\"github.com/stretchr/testify/require\"\n    16→)\n    17→\n    18→// fakeDispatcher records dispatch calls and returns a predetermined run ID.\n    19→type fakeDispatcher struct {\n    20→\tcalls     []*pb.RunWorkflowRequest\n    21→\trunID     string\n    22→\treturnErr error\n    23→}\n    24→\n    25→func (f *fakeDispatcher) RunWorkflow(_ context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    26→\tf.calls = append(f.calls, req)\n    27→\tif f.returnErr != nil {\n    28→\t\treturn nil, f.returnErr\n    29→\t}\n    30→\treturn &pb.RunWorkflowResponse{RunId: f.runID}, nil\n    31→}\n    32→\n    33→// fakeStore returns a predetermined run on GetRun.\n    34→type fakeStore struct {\n    35→\truns map[string]*domain.Run\n    36→}\n    37→\n    38→func (f *fakeStore) CreateRun(_ context.Context, run *domain.Run) error {\n    39→\tf.runs[run.ID] = run\n    40→\treturn nil\n    41→}\n    42→func (f *fakeStore) GetRun(_ context.Context, id string) (*domain.Run, error) {\n    43→\tif r, ok := f.runs[id]; ok {\n    44→\t\treturn r, nil\n    45→\t}\n    46→\treturn nil, os.ErrNotExist\n    47→}\n    48→func (f *fakeStore) UpdateRun(_ context.Context, run *domain.Run) error {\n    49→\tf.runs[run.ID] = run\n    50→\treturn nil\n    51→}\n    52→func (f *fakeStore) DeleteRun(_ context.Context, id string) error {\n    53→\tdelete(f.runs, id)\n    54→\treturn nil\n    55→}\n    56→func (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n    57→\treturn nil, nil\n    58→}\n    59→func (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n    60→\treturn nil, nil\n    61→}\n    62→func (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n    63→\treturn nil, nil\n    64→}\n    65→func (f *fakeStore) ListChildRuns(_ context.Context, parentRunID string) ([]*domain.Run, error) {\n    66→\tvar children []*domain.Run\n    67→\tfor _, r := range f.runs {\n    68→\t\tif r.ParentRunID == parentRunID {\n    69→\t\t\tchildren = append(children, r)\n    70→\t\t}\n    71→\t}\n    72→\treturn children, nil\n    73→}\n    74→\n    75→func TestExecutor_ScriptStep_Success(t *testing.T) {\n    76→\ttmpDir := t.TempDir()\n    77→\toutputDir := filepath.Join(tmpDir, \"output\")\n    78→\n    79→\texecutor := &Executor{\n    80→\t\tProjectDir: tmpDir,\n    81→\t\tOutputDir:  outputDir,\n    82→\t}\n    83→\n    84→\tstep := &domain.Step{\n    85→\t\tName:    \"greet\",\n    86→\t\tType:    domain.StepTypeScript,\n    87→\t\tResults: []string{\"success\", \"fail\"},\n    88→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n    89→\t}\n    90→\n    91→\tresult, err := executor.Execute(context.Background(), step)\n    92→\trequire.NoError(t, err)\n    93→\tassert.Equal(t, \"success\", result)\n    94→\n    95→\t// Check output was written\n    96→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n    97→\trequire.NoError(t, err)\n    98→\tassert.Contains(t, string(data), \"hello\")\n    99→}\n   100→\n   101→func TestExecutor_ScriptStep_Failure(t *testing.T) {\n   102→\ttmpDir := t.TempDir()\n   103→\toutputDir := filepath.Join(tmpDir, \"output\")\n   104→\n   105→\texecutor := &Executor{\n   106→\t\tProjectDir: tmpDir,\n   107→\t\tOutputDir:  outputDir,\n   108→\t}\n   109→\n   110→\tstep := &domain.Step{\n   111→\t\tName:    \"bad\",\n   112→\t\tType:    domain.StepTypeScript,\n   113→\t\tResults: []string{\"success\", \"fail\"},\n   114→\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   115→\t}\n   116→\n   117→\tresult, err := executor.Execute(context.Background(), step)\n   118→\trequire.NoError(t, err)\n   119→\tassert.Equal(t, \"fail\", result)\n   120→}\n   121→\n   122→func TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n   123→\ttmpDir := t.TempDir()\n   124→\toutputDir := filepath.Join(tmpDir, \"output\")\n   125→\n   126→\texecutor := &Executor{\n   127→\t\tProjectDir: tmpDir,\n   128→\t\tOutputDir:  outputDir,\n   129→\t}\n   130→\n   131→\tstep := &domain.Step{\n   132→\t\tName:    \"marker\",\n   133→\t\tType:    domain.StepTypeScript,\n   134→\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n   135→\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n   136→\t}\n   137→\n   138→\tresult, err := executor.Execute(context.Background(), step)\n   139→\trequire.NoError(t, err)\n   140→\tassert.Equal(t, \"custom\", result)\n   141→\n   142→\t// Marker line should be stripped from output\n   143→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n   144→\trequire.NoError(t, err)\n   145→\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n   146→\tassert.Contains(t, string(data), \"some output\")\n   147→}\n   148→\n   149→func TestExecutor_WorkflowStep_Success(t *testing.T) {\n   150→\ttmpDir := t.TempDir()\n   151→\toutputDir := filepath.Join(tmpDir, \"output\")\n   152→\t_ = os.MkdirAll(outputDir, 0755)\n   153→\n   154→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   155→\t\t\"develop-test-run\": {\n   156→\t\t\tID:    \"develop-test-run\",\n   157→\t\t\tState: domain.RunStateSucceeded,\n   158→\t\t},\n   159→\t}}\n   160→\n   161→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   162→\n   163→\texecutor := &Executor{\n   164→\t\tProjectDir: tmpDir,\n   165→\t\tDispatcher: dispatcher,\n   166→\t\tStore:      store,\n   167→\t\tOutputDir:  outputDir,\n   168→\t}\n   169→\n   170→\tstep := &domain.Step{\n   171→\t\tName:    \"develop\",\n   172→\t\tType:    domain.StepTypeWorkflow,\n   173→\t\tResults: []string{\"success\", \"fail\"},\n   174→\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   175→\t}\n   176→\n   177→\tresult, err := executor.Execute(context.Background(), step)\n   178→\trequire.NoError(t, err)\n   179→\tassert.Equal(t, \"success\", result)\n   180→\tassert.Len(t, dispatcher.calls, 1)\n   181→\tassert.Equal(t, \"develop\", dispatcher.calls[0].WorkflowName)\n   182→\tassert.Equal(t, tmpDir, dispatcher.calls[0].ProjectDir)\n   183→}\n   184→\n   185→func TestExecutor_WorkflowStep_Failure(t *testing.T) {\n   186→\ttmpDir := t.TempDir()\n   187→\toutputDir := filepath.Join(tmpDir, \"output\")\n   188→\t_ = os.MkdirAll(outputDir, 0755)\n   189→\n   190→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   191→\t\t\"develop-test-run\": {\n   192→\t\t\tID:    \"develop-test-run\",\n   193→\t\t\tState: domain.RunStateFailed,\n   194→\t\t},\n   195→\t}}\n   196→\n   197→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   198→\n   199→\texecutor := &Executor{\n   200→\t\tProjectDir: tmpDir,\n   201→\t\tDispatcher: dispatcher,\n   202→\t\tStore:      store,\n   203→\t\tOutputDir:  outputDir,\n   204→\t}\n   205→\n   206→\tstep := &domain.Step{\n   207→\t\tName:    \"develop\",\n   208→\t\tType:    domain.StepTypeWorkflow,\n   209→\t\tResults: []string{\"success\", \"fail\"},\n   210→\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   211→\t}\n   212→\n   213→\tresult, err := executor.Execute(context.Background(), step)\n   214→\trequire.NoError(t, err)\n   215→\tassert.Equal(t, \"fail\", result)\n   216→}\n   217→\n   218→func TestExecutor_WorkflowStep_PassesPrompt(t *testing.T) {\n   219→\ttmpDir := t.TempDir()\n   220→\toutputDir := filepath.Join(tmpDir, \"output\")\n   221→\t_ = os.MkdirAll(outputDir, 0755)\n   222→\n   223→\t// Write a previous step's output\n   224→\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n   225→\n   226→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   227→\t\t\"develop-test-run\": {\n   228→\t\t\tID:    \"develop-test-run\",\n   229→\t\t\tState: domain.RunStateSucceeded,\n   230→\t\t},\n   231→\t}}\n   232→\n   233→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   234→\n   235→\texecutor := &Executor{\n   236→\t\tProjectDir: tmpDir,\n   237→\t\tDispatcher: dispatcher,\n   238→\t\tStore:      store,\n   239→\t\tOutputDir:  outputDir,\n   240→\t}\n   241→\n   242→\tstep := &domain.Step{\n   243→\t\tName:    \"develop\",\n   244→\t\tType:    domain.StepTypeWorkflow,\n   245→\t\tResults: []string{\"success\", \"fail\"},\n   246→\t\tConfig: map[string]string{\n   247→\t\t\t\"workflow_name\": \"develop\",\n   248→\t\t\t\"prompt_step\":   \"prepare-prompt\",\n   249→\t\t},\n   250→\t}\n   251→\n   252→\tresult, err := executor.Execute(context.Background(), step)\n   253→\trequire.NoError(t, err)\n   254→\tassert.Equal(t, \"success\", result)\n   255→\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n   256→}\n   257→\n   258→func TestEngine_HostWorkflow_Linear(t *testing.T) {\n   259→\ttmpDir := t.TempDir()\n   260→\toutputDir := filepath.Join(tmpDir, \"output\")\n   261→\n   262→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   263→\t\t\"develop-test-run\": {\n   264→\t\t\tID:    \"develop-test-run\",\n   265→\t\t\tState: domain.RunStateSucceeded,\n   266→\t\t},\n   267→\t}}\n   268→\n   269→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   270→\n   271→\texecutor := &Executor{\n   272→\t\tProjectDir: tmpDir,\n   273→\t\tDispatcher: dispatcher,\n   274→\t\tStore:      store,\n   275→\t\tOutputDir:  outputDir,\n   276→\t}\n   277→\n   278→\twf := &domain.Workflow{\n   279→\t\tName: \"main\",\n   280→\t\tSteps: map[string]*domain.Step{\n   281→\t\t\t\"prepare\": {\n   282→\t\t\t\tName:    \"prepare\",\n   283→\t\t\t\tType:    domain.StepTypeScript,\n   284→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   285→\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n   286→\t\t\t},\n   287→\t\t\t\"develop\": {\n   288→\t\t\t\tName:    \"develop\",\n   289→\t\t\t\tType:    domain.StepTypeWorkflow,\n   290→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   291→\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   292→\t\t\t},\n   293→\t\t\t\"merge\": {\n   294→\t\t\t\tName:    \"merge\",\n   295→\t\t\t\tType:    domain.StepTypeScript,\n   296→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   297→\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n   298→\t\t\t},\n   299→\t\t},\n   300→\t\tWiring: []domain.Wire{\n   301→\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   302→\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   303→\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n   304→\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   305→\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n   306→\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n   307→\t\t},\n   308→\t\tEntryStep: \"prepare\",\n   309→\t}\n   310→\n   311→\teng := engine.New(executor)\n   312→\trun, err := eng.Run(context.Background(), wf)\n   313→\trequire.NoError(t, err)\n   314→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   315→\tassert.Len(t, dispatcher.calls, 1)\n   316→}\n   317→\n   318→func TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n   319→\ttmpDir := t.TempDir()\n   320→\toutputDir := filepath.Join(tmpDir, \"output\")\n   321→\n   322→\texecutor := &Executor{\n   323→\t\tProjectDir: tmpDir,\n   324→\t\tOutputDir:  outputDir,\n   325→\t}\n   326→\n   327→\twf := &domain.Workflow{\n   328→\t\tName: \"main\",\n   329→\t\tSteps: map[string]*domain.Step{\n   330→\t\t\t\"prepare\": {\n   331→\t\t\t\tName:    \"prepare\",\n   332→\t\t\t\tType:    domain.StepTypeScript,\n   333→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   334→\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   335→\t\t\t},\n   336→\t\t\t\"develop\": {\n   337→\t\t\t\tName:    \"develop\",\n   338→\t\t\t\tType:    domain.StepTypeWorkflow,\n   339→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   340→\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   341→\t\t\t},\n   342→\t\t},\n   343→\t\tWiring: []domain.Wire{\n   344→\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   345→\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   346→\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n   347→\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   348→\t\t},\n   349→\t\tEntryStep: \"prepare\",\n   350→\t}\n   351→\n   352→\teng := engine.New(executor)\n   353→\trun, err := eng.Run(context.Background(), wf)\n   354→\trequire.NoError(t, err)\n   355→\tassert.Equal(t, domain.RunStateFailed, run.State)\n   356→}\n   357→\n   358→func TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n   359→\ttmpDir := t.TempDir()\n   360→\toutputDir := filepath.Join(tmpDir, \"output\")\n   361→\n   362→\texecutor := &Executor{\n   363→\t\tProjectDir: tmpDir,\n   364→\t\tOutputDir:  outputDir,\n   365→\t}\n   366→\n   367→\tstep := &domain.Step{\n   368→\t\tName:    \"env-check\",\n   369→\t\tType:    domain.StepTypeScript,\n   370→\t\tResults: []string{\"success\", \"fail\"},\n   371→\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n   372→\t}\n   373→\n   374→\tresult, err := executor.Execute(context.Background(), step)\n   375→\trequire.NoError(t, err)\n   376→\tassert.Equal(t, \"success\", result)\n   377→\n   378→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n   379→\trequire.NoError(t, err)\n   380→\tassert.Contains(t, string(data), tmpDir)\n   381→}\n   382→\n   383→func TestExecutor_ScriptStep_NoOutputMappings(t *testing.T) {\n   384→\ttmpDir := t.TempDir()\n   385→\toutputDir := filepath.Join(tmpDir, \"output\")\n   386→\n   387→\texecutor := &Executor{\n   388→\t\tProjectDir: tmpDir,\n   389→\t\tOutputDir:  outputDir,\n   390→\t\tWires: []domain.Wire{\n   391→\t\t\t{From: \"step-a\", Result: \"success\", To: \"step-b\"},\n   392→\t\t},\n   393→\t}\n   394→\n   395→\tstep := &domain.Step{\n   396→\t\tName:    \"step-b\",\n   397→\t\tType:    domain.StepTypeScript,\n   398→\t\tResults: []string{\"success\", \"fail\"},\n   399→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   400→\t}\n   401→\n   402→\tresult, err := executor.Execute(context.Background(), step)\n   403→\trequire.NoError(t, err)\n   404→\tassert.Equal(t, \"success\", result)\n   405→}\n   406→\n   407→func TestExecutor_ScriptStep_OutputMappings_JSONFields(t *testing.T) {\n   408→\ttmpDir := t.TempDir()\n   409→\toutputDir := filepath.Join(tmpDir, \"output\")\n   410→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   411→\n   412→\t// Write source step output as JSON\n   413→\tsourceJSON := `{\"title\": \"Fix bug\", \"priority\": \"high\"}`\n   414→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"get-tasks.out\"), []byte(sourceJSON), 0644))\n   415→\n   416→\texecutor := &Executor{\n   417→\t\tProjectDir: tmpDir,\n   418→\t\tOutputDir:  outputDir,\n   419→\t\tWires: []domain.Wire{\n   420→\t\t\t{\n   421→\t\t\t\tFrom:   \"get-tasks\",\n   422→\t\t\t\tResult: \"success\",\n   423→\t\t\t\tTo:     \"use-tasks\",\n   424→\t\t\t\tOutputMap: []domain.OutputMapping{\n   425→\t\t\t\t\t{\n   426→\t\t\t\t\t\tEnvVar: \"TASK_TITLE\",\n   427→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"title\"}}},\n   428→\t\t\t\t\t},\n   429→\t\t\t\t\t{\n   430→\t\t\t\t\t\tEnvVar: \"TASK_PRIORITY\",\n   431→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"priority\"}}},\n   432→\t\t\t\t\t},\n   433→\t\t\t\t},\n   434→\t\t\t},\n   435→\t\t},\n   436→\t}\n   437→\n   438→\tstep := &domain.Step{\n   439→\t\tName:    \"use-tasks\",\n   440→\t\tType:    domain.StepTypeScript,\n   441→\t\tResults: []string{\"success\", \"fail\"},\n   442→\t\tConfig:  map[string]string{\"run\": \"echo $TASK_TITLE $TASK_PRIORITY\"},\n   443→\t}\n   444→\n   445→\tresult, err := executor.Execute(context.Background(), step)\n   446→\trequire.NoError(t, err)\n   447→\tassert.Equal(t, \"success\", result)\n   448→\n   449→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"use-tasks.out\"))\n   450→\trequire.NoError(t, err)\n   451→\tassert.Contains(t, string(data), \"Fix bug\")\n   452→\tassert.Contains(t, string(data), \"high\")\n   453→}\n   454→\n   455→func TestExecutor_ScriptStep_OutputMappings_ArrayIndex(t *testing.T) {\n   456→\ttmpDir := t.TempDir()\n   457→\toutputDir := filepath.Join(tmpDir, \"output\")\n   458→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   459→\n   460→\t// Write source step output as JSON array\n   461→\tsourceJSON := `[{\"id\": \"task-1\", \"title\": \"First\"}, {\"id\": \"task-2\", \"title\": \"Second\"}]`\n   462→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"list-tasks.out\"), []byte(sourceJSON), 0644))\n   463→\n   464→\texecutor := &Executor{\n   465→\t\tProjectDir: tmpDir,\n   466→\t\tOutputDir:  outputDir,\n   467→\t\tWires: []domain.Wire{\n   468→\t\t\t{\n   469→\t\t\t\tFrom:   \"list-tasks\",\n   470→\t\t\t\tResult: \"success\",\n   471→\t\t\t\tTo:     \"process\",\n   472→\t\t\t\tOutputMap: []domain.OutputMapping{\n   473→\t\t\t\t\t{\n   474→\t\t\t\t\t\tEnvVar: \"FIRST_ID\",\n   475→\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n   476→\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 0},\n   477→\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"id\"},\n   478→\t\t\t\t\t\t}},\n   479→\t\t\t\t\t},\n   480→\t\t\t\t\t{\n   481→\t\t\t\t\t\tEnvVar: \"SECOND_TITLE\",\n   482→\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n   483→\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 1},\n   484→\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"title\"},\n   485→\t\t\t\t\t\t}},\n   486→\t\t\t\t\t},\n   487→\t\t\t\t},\n   488→\t\t\t},\n   489→\t\t},\n   490→\t}\n   491→\n   492→\tstep := &domain.Step{\n   493→\t\tName:    \"process\",\n   494→\t\tType:    domain.StepTypeScript,\n   495→\t\tResults: []string{\"success\", \"fail\"},\n   496→\t\tConfig:  map[string]string{\"run\": \"echo $FIRST_ID $SECOND_TITLE\"},\n   497→\t}\n   498→\n   499→\tresult, err := executor.Execute(context.Background(), step)\n   500→\trequire.NoError(t, err)\n   501→\tassert.Equal(t, \"success\", result)\n   502→\n   503→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"process.out\"))\n   504→\trequire.NoError(t, err)\n   505→\tassert.Contains(t, string(data), \"task-1\")\n   506→\tassert.Contains(t, string(data), \"Second\")\n   507→}\n   508→\n   509→func TestExecutor_ScriptStep_OutputMappings_MissingSourceOutput(t *testing.T) {\n   510→\ttmpDir := t.TempDir()\n   511→\toutputDir := filepath.Join(tmpDir, \"output\")\n   512→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   513→\n   514→\t// No source output file written\n   515→\n   516→\texecutor := &Executor{\n   517→\t\tProjectDir: tmpDir,\n   518→\t\tOutputDir:  outputDir,\n   519→\t\tWires: []domain.Wire{\n   520→\t\t\t{\n   521→\t\t\t\tFrom:   \"missing-step\",\n   522→\t\t\t\tResult: \"success\",\n   523→\t\t\t\tTo:     \"consumer\",\n   524→\t\t\t\tOutputMap: []domain.OutputMapping{\n   525→\t\t\t\t\t{\n   526→\t\t\t\t\t\tEnvVar: \"VAL\",\n   527→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n   528→\t\t\t\t\t},\n   529→\t\t\t\t},\n   530→\t\t\t},\n   531→\t\t},\n   532→\t}\n   533→\n   534→\tstep := &domain.Step{\n   535→\t\tName:    \"consumer\",\n   536→\t\tType:    domain.StepTypeScript,\n   537→\t\tResults: []string{\"success\", \"fail\"},\n   538→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   539→\t}\n   540→\n   541→\t_, err := executor.Execute(context.Background(), step)\n   542→\trequire.Error(t, err)\n   543→\tassert.Contains(t, err.Error(), \"reading output of missing-step\")\n   544→}\n   545→\n   546→func TestExecutor_ScriptStep_OutputMappings_NotJSON(t *testing.T) {\n   547→\ttmpDir := t.TempDir()\n   548→\toutputDir := filepath.Join(tmpDir, \"output\")\n   549→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   550→\n   551→\t// Write non-JSON output\n   552→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"plain.out\"), []byte(\"not json\"), 0644))\n   553→\n   554→\texecutor := &Executor{\n   555→\t\tProjectDir: tmpDir,\n   556→\t\tOutputDir:  outputDir,\n   557→\t\tWires: []domain.Wire{\n   558→\t\t\t{\n   559→\t\t\t\tFrom:   \"plain\",\n   560→\t\t\t\tResult: \"success\",\n   561→\t\t\t\tTo:     \"consumer\",\n   562→\t\t\t\tOutputMap: []domain.OutputMapping{\n   563→\t\t\t\t\t{\n   564→\t\t\t\t\t\tEnvVar: \"VAL\",\n   565→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n   566→\t\t\t\t\t},\n   567→\t\t\t\t},\n   568→\t\t\t},\n   569→\t\t},\n   570→\t}\n   571→\n   572→\tstep := &domain.Step{\n   573→\t\tName:    \"consumer\",\n   574→\t\tType:    domain.StepTypeScript,\n   575→\t\tResults: []string{\"success\", \"fail\"},\n   576→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   577→\t}\n   578→\n   579→\t_, err := executor.Execute(context.Background(), step)\n   580→\trequire.Error(t, err)\n   581→\tassert.Contains(t, err.Error(), \"not valid JSON\")\n   582→}\n   583→\n   584→func TestRunner_RunWithID(t *testing.T) {\n   585→\ttmpDir := t.TempDir()\n   586→\n   587→\t// Write a simple host.cloche\n   588→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   589→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   590→\thostCloche := `workflow \"main\" {\n   591→  step greet {\n   592→    run     = \"echo hi\"\n   593→    results = [success, fail]\n   594→  }\n   595→\n   596→  greet:success -> done\n   597→  greet:fail    -> abort\n   598→}`\n   599→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   600→\n   601→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   602→\n   603→\trunner := &Runner{\n   604→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   605→\t\tStore:      store,\n   606→\t}\n   607→\n   608→\tcustomID := \"my-custom-run-id\"\n   609→\tresult, err := runner.RunWithID(context.Background(), tmpDir, customID)\n   610→\trequire.NoError(t, err)\n   611→\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n   612→\tassert.Equal(t, customID, result.RunID, \"RunWithID should use the provided ID\")\n   613→\n   614→\t// Verify the run was persisted with the custom ID\n   615→\thostRun, err := store.GetRun(context.Background(), customID)\n   616→\trequire.NoError(t, err)\n   617→\tassert.True(t, hostRun.IsHost)\n   618→\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n   619→}\n   620→\n   621→func TestRunner_PersistsHostRun(t *testing.T) {\n   622→\ttmpDir := t.TempDir()\n   623→\n   624→\t// Write a simple host.cloche\n   625→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   626→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   627→\thostCloche := `workflow \"main\" {\n   628→  step prepare {\n   629→    run     = \"echo prepared\"\n   630→    results = [success, fail]\n   631→  }\n   632→\n   633→  prepare:success -> done\n   634→  prepare:fail    -> abort\n   635→}`\n   636→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   637→\n   638→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   639→\n   640→\trunner := &Runner{\n   641→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   642→\t\tStore:      store,\n   643→\t}\n   644→\n   645→\tresult, err := runner.Run(context.Background(), tmpDir)\n   646→\trequire.NoError(t, err)\n   647→\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n   648→\tassert.NotEmpty(t, result.RunID)\n   649→\n   650→\t// Verify the host run was persisted in the store\n   651→\thostRun, err := store.GetRun(context.Background(), result.RunID)\n   652→\trequire.NoError(t, err)\n   653→\tassert.True(t, hostRun.IsHost, \"host run should have IsHost=true\")\n   654→\tassert.Equal(t, tmpDir, hostRun.ProjectDir)\n   655→\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n   656→\tassert.False(t, hostRun.StartedAt.IsZero())\n   657→\tassert.False(t, hostRun.CompletedAt.IsZero())\n   658→}\n   659→\n   660→func TestExecutor_ScriptStep_UsesMainDir(t *testing.T) {\n   661→\t// ProjectDir has no script; MainDir has the script.\n   662→\tprojectDir := t.TempDir()\n   663→\tmainDir := t.TempDir()\n   664→\toutputDir := filepath.Join(projectDir, \"output\")\n   665→\n   666→\t// Create a script only in mainDir\n   667→\tscriptDir := filepath.Join(mainDir, \".cloche\", \"scripts\")\n   668→\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n   669→\trequire.NoError(t, os.WriteFile(\n   670→\t\tfilepath.Join(scriptDir, \"greet.sh\"),\n   671→\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n   672→\t\t0755,\n   673→\t))\n   674→\n   675→\texecutor := &Executor{\n   676→\t\tProjectDir: projectDir,\n   677→\t\tMainDir:    mainDir,\n   678→\t\tOutputDir:  outputDir,\n   679→\t}\n   680→\n   681→\tstep := &domain.Step{\n   682→\t\tName:    \"greet\",\n   683→\t\tType:    domain.StepTypeScript,\n   684→\t\tResults: []string{\"success\", \"fail\"},\n   685→\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/greet.sh\"},\n   686→\t}\n   687→\n   688→\tresult, err := executor.Execute(context.Background(), step)\n   689→\trequire.NoError(t, err)\n   690→\tassert.Equal(t, \"success\", result)\n   691→\n   692→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n   693→\trequire.NoError(t, err)\n   694→\tassert.Contains(t, string(data), \"from-main\")\n   695→}\n   696→\n   697→func TestExecutor_ScriptStep_MainDirOverridesProjectDir(t *testing.T) {\n   698→\t// Both dirs have a script with different content; MainDir's version wins.\n   699→\tprojectDir := t.TempDir()\n   700→\tmainDir := t.TempDir()\n   701→\toutputDir := filepath.Join(projectDir, \"output\")\n   702→\n   703→\t// Create script in both dirs with different content\n   704→\tfor _, dir := range []string{projectDir, mainDir} {\n   705→\t\tscriptDir := filepath.Join(dir, \".cloche\", \"scripts\")\n   706→\t\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n   707→\t}\n   708→\trequire.NoError(t, os.WriteFile(\n   709→\t\tfilepath.Join(projectDir, \".cloche\", \"scripts\", \"hello.sh\"),\n   710→\t\t[]byte(\"#!/bin/sh\\necho from-branch\"),\n   711→\t\t0755,\n   712→\t))\n   713→\trequire.NoError(t, os.WriteFile(\n   714→\t\tfilepath.Join(mainDir, \".cloche\", \"scripts\", \"hello.sh\"),\n   715→\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n   716→\t\t0755,\n   717→\t))\n   718→\n   719→\texecutor := &Executor{\n   720→\t\tProjectDir: projectDir,\n   721→\t\tMainDir:    mainDir,\n   722→\t\tOutputDir:  outputDir,\n   723→\t}\n   724→\n   725→\tstep := &domain.Step{\n   726→\t\tName:    \"hello\",\n   727→\t\tType:    domain.StepTypeScript,\n   728→\t\tResults: []string{\"success\", \"fail\"},\n   729→\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/hello.sh\"},\n   730→\t}\n   731→\n   732→\tresult, err := executor.Execute(context.Background(), step)\n   733→\trequire.NoError(t, err)\n   734→\tassert.Equal(t, \"success\", result)\n   735→\n   736→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"hello.out\"))\n   737→\trequire.NoError(t, err)\n   738→\tassert.Contains(t, string(data), \"from-main\")\n   739→\tassert.NotContains(t, string(data), \"from-branch\")\n   740→}\n   741→\n   742→func TestExecutor_ScriptStep_FallsBackToProjectDir(t *testing.T) {\n   743→\t// When MainDir is empty, scripts resolve from ProjectDir.\n   744→\tprojectDir := t.TempDir()\n   745→\toutputDir := filepath.Join(projectDir, \"output\")\n   746→\n   747→\texecutor := &Executor{\n   748→\t\tProjectDir: projectDir,\n   749→\t\tOutputDir:  outputDir,\n   750→\t}\n   751→\n   752→\tstep := &domain.Step{\n   753→\t\tName:    \"pwd-check\",\n   754→\t\tType:    domain.StepTypeScript,\n   755→\t\tResults: []string{\"success\", \"fail\"},\n   756→\t\tConfig:  map[string]string{\"run\": \"pwd\"},\n   757→\t}\n   758→\n   759→\tresult, err := executor.Execute(context.Background(), step)\n   760→\trequire.NoError(t, err)\n   761→\tassert.Equal(t, \"success\", result)\n   762→\n   763→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"pwd-check.out\"))\n   764→\trequire.NoError(t, err)\n   765→\tassert.Contains(t, string(data), projectDir)\n   766→}\n   767→\n   768→func TestExecutor_ScriptStep_ProjectDirEnvVar(t *testing.T) {\n   769→\t// CLOCHE_PROJECT_DIR should always point to ProjectDir, not MainDir.\n   770→\tprojectDir := t.TempDir()\n   771→\tmainDir := t.TempDir()\n   772→\toutputDir := filepath.Join(projectDir, \"output\")\n   773→\n   774→\texecutor := &Executor{\n   775→\t\tProjectDir: projectDir,\n   776→\t\tMainDir:    mainDir,\n   777→\t\tOutputDir:  outputDir,\n   778→\t}\n   779→\n   780→\tstep := &domain.Step{\n   781→\t\tName:    \"env-check\",\n   782→\t\tType:    domain.StepTypeScript,\n   783→\t\tResults: []string{\"success\", \"fail\"},\n   784→\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n   785→\t}\n   786→\n   787→\tresult, err := executor.Execute(context.Background(), step)\n   788→\trequire.NoError(t, err)\n   789→\tassert.Equal(t, \"success\", result)\n   790→\n   791→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n   792→\trequire.NoError(t, err)\n   793→\tassert.Contains(t, string(data), projectDir)\n   794→\tassert.NotContains(t, string(data), mainDir)\n   795→}\n   796→\n   797→func TestMainWorktreeDir_NonGitDir(t *testing.T) {\n   798→\ttmpDir := t.TempDir()\n   799→\t// Non-git directory should fall back to projectDir.\n   800→\tresult := MainWorktreeDir(tmpDir)\n   801→\tassert.Equal(t, tmpDir, result)\n   802→}\n   803→\n   804→func TestMainWorktreeDir_WithWorktree(t *testing.T) {\n   805→\t// Set up a real git repo with a linked worktree.\n   806→\tmainDir := t.TempDir()\n   807→\n   808→\t// Initialize git repo\n   809→\trun := func(dir string, args ...string) {\n   810→\t\tt.Helper()\n   811→\t\tcmd := exec.Command(args[0], args[1:]...)\n   812→\t\tcmd.Dir = dir\n   813→\t\tout, err := cmd.CombinedOutput()\n   814→\t\trequire.NoError(t, err, \"command %v failed: %s\", args, out)\n   815→\t}\n   816→\n   817→\trun(mainDir, \"git\", \"init\")\n   818→\trun(mainDir, \"git\", \"config\", \"user.email\", \"test@test.com\")\n   819→\trun(mainDir, \"git\", \"config\", \"user.name\", \"Test\")\n   820→\trequire.NoError(t, os.WriteFile(filepath.Join(mainDir, \"file.txt\"), []byte(\"hello\"), 0644))\n   821→\trun(mainDir, \"git\", \"add\", \".\")\n   822→\trun(mainDir, \"git\", \"commit\", \"-m\", \"initial\")\n   823→\n   824→\t// Create a branch and worktree\n   825→\tworktreeDir := filepath.Join(t.TempDir(), \"wt\")\n   826→\trun(mainDir, \"git\", \"worktree\", \"add\", worktreeDir, \"-b\", \"feature\")\n   827→\n   828→\t// MainWorktreeDir from the linked worktree should return mainDir.\n   829→\tresult := MainWorktreeDir(worktreeDir)\n   830→\tassert.Equal(t, mainDir, result)\n   831→\n   832→\t// MainWorktreeDir from main should return mainDir.\n   833→\tresult = MainWorktreeDir(mainDir)\n   834→\tassert.Equal(t, mainDir, result)\n   835→}\n   836→\n   837→func TestExecutor_AgentStep_Success(t *testing.T) {\n   838→\ttmpDir := t.TempDir()\n   839→\toutputDir := filepath.Join(tmpDir, \"output\")\n   840→\n   841→\t// Create a mock agent script that reads stdin and produces output\n   842→\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n   843→\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent did the work'\\n\"), 0755))\n   844→\n   845→\texecutor := &Executor{\n   846→\t\tProjectDir: tmpDir,\n   847→\t\tOutputDir:  outputDir,\n   848→\t\tHostRunID:  \"test-host-run\",\n   849→\t}\n   850→\n   851→\tstep := &domain.Step{\n   852→\t\tName:    \"implement\",\n   853→\t\tType:    domain.StepTypeAgent,\n   854→\t\tResults: []string{\"success\", \"fail\"},\n   855→\t\tConfig: map[string]string{\n   856→\t\t\t\"prompt\":        \"You are a coding assistant.\",\n   857→\t\t\t\"agent_command\": mockAgent,\n   858→\t\t},\n   859→\t}\n   860→\n   861→\tresult, err := executor.Execute(context.Background(), step)\n   862→\trequire.NoError(t, err)\n   863→\tassert.Equal(t, \"success\", result)\n   864→\n   865→\t// Check output was copied to executor's output path\n   866→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n   867→\trequire.NoError(t, err)\n   868→\tassert.Contains(t, string(data), \"agent did the work\")\n   869→}\n   870→\n   871→func TestExecutor_AgentStep_Failure(t *testing.T) {\n   872→\ttmpDir := t.TempDir()\n   873→\toutputDir := filepath.Join(tmpDir, \"output\")\n   874→\n   875→\t// Create a mock agent that reports failure via result marker\n   876→\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n   877→\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'something went wrong'\\necho 'CLOCHE_RESULT:fail'\\n\"), 0755))\n   878→\n   879→\texecutor := &Executor{\n   880→\t\tProjectDir: tmpDir,\n   881→\t\tOutputDir:  outputDir,\n   882→\t\tHostRunID:  \"test-host-run\",\n   883→\t}\n   884→\n   885→\tstep := &domain.Step{\n   886→\t\tName:    \"implement\",\n   887→\t\tType:    domain.StepTypeAgent,\n   888→\t\tResults: []string{\"success\", \"fail\"},\n   889→\t\tConfig: map[string]string{\n   890→\t\t\t\"prompt\":        \"You are a coding assistant.\",\n   891→\t\t\t\"agent_command\": mockAgent,\n   892→\t\t},\n   893→\t}\n   894→\n   895→\tresult, err := executor.Execute(context.Background(), step)\n   896→\trequire.NoError(t, err)\n   897→\tassert.Equal(t, \"fail\", result)\n   898→}\n   899→\n   900→func TestExecutor_AgentStep_WorkflowLevelCommand(t *testing.T) {\n   901→\ttmpDir := t.TempDir()\n   902→\toutputDir := filepath.Join(tmpDir, \"output\")\n   903→\n   904→\t// Create a mock agent\n   905→\tmockAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n   906→\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow agent ran'\\n\"), 0755))\n   907→\n   908→\texecutor := &Executor{\n   909→\t\tProjectDir:    tmpDir,\n   910→\t\tOutputDir:     outputDir,\n   911→\t\tHostRunID:     \"test-host-run\",\n   912→\t\tAgentCommands: []string{mockAgent},\n   913→\t}\n   914→\n   915→\tstep := &domain.Step{\n   916→\t\tName:    \"implement\",\n   917→\t\tType:    domain.StepTypeAgent,\n   918→\t\tResults: []string{\"success\", \"fail\"},\n   919→\t\tConfig: map[string]string{\n   920→\t\t\t\"prompt\": \"Write some code.\",\n   921→\t\t},\n   922→\t}\n   923→\n   924→\tresult, err := executor.Execute(context.Background(), step)\n   925→\trequire.NoError(t, err)\n   926→\tassert.Equal(t, \"success\", result)\n   927→\n   928→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n   929→\trequire.NoError(t, err)\n   930→\tassert.Contains(t, string(data), \"workflow agent ran\")\n   931→}\n   932→\n   933→func TestExecutor_AgentStep_StepLevelOverridesWorkflow(t *testing.T) {\n   934→\ttmpDir := t.TempDir()\n   935→\toutputDir := filepath.Join(tmpDir, \"output\")\n   936→\n   937→\t// Create two mock agents\n   938→\tworkflowAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n   939→\trequire.NoError(t, os.WriteFile(workflowAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow agent'\\n\"), 0755))\n   940→\n   941→\tstepAgent := filepath.Join(tmpDir, \"step-agent.sh\")\n   942→\trequire.NoError(t, os.WriteFile(stepAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'step agent'\\n\"), 0755))\n   943→\n   944→\texecutor := &Executor{\n   945→\t\tProjectDir:    tmpDir,\n   946→\t\tOutputDir:     outputDir,\n   947→\t\tHostRunID:     \"test-host-run\",\n   948→\t\tAgentCommands: []string{workflowAgent},\n   949→\t}\n   950→\n   951→\tstep := &domain.Step{\n   952→\t\tName:    \"implement\",\n   953→\t\tType:    domain.StepTypeAgent,\n   954→\t\tResults: []string{\"success\", \"fail\"},\n   955→\t\tConfig: map[string]string{\n   956→\t\t\t\"prompt\":        \"Write some code.\",\n   957→\t\t\t\"agent_command\": stepAgent,\n   958→\t\t},\n   959→\t}\n   960→\n   961→\tresult, err := executor.Execute(context.Background(), step)\n   962→\trequire.NoError(t, err)\n   963→\tassert.Equal(t, \"success\", result)\n   964→\n   965→\t// Step-level agent should have run, not workflow-level\n   966→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n   967→\trequire.NoError(t, err)\n   968→\tassert.Contains(t, string(data), \"step agent\")\n   969→\tassert.NotContains(t, string(data), \"workflow agent\")\n   970→}\n   971→\n   972→func TestExecutor_AgentStep_FallbackChain(t *testing.T) {\n   973→\ttmpDir := t.TempDir()\n   974→\toutputDir := filepath.Join(tmpDir, \"output\")\n   975→\n   976→\t// Create a good agent\n   977→\tgoodAgent := filepath.Join(tmpDir, \"good-agent.sh\")\n   978→\trequire.NoError(t, os.WriteFile(goodAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'fallback agent ran'\\n\"), 0755))\n   979→\n   980→\texecutor := &Executor{\n   981→\t\tProjectDir: tmpDir,\n   982→\t\tOutputDir:  outputDir,\n   983→\t\tHostRunID:  \"test-host-run\",\n   984→\t}\n   985→\n   986→\t// Use nonexistent command as primary, good agent as fallback\n   987→\tstep := &domain.Step{\n   988→\t\tName:    \"implement\",\n   989→\t\tType:    domain.StepTypeAgent,\n   990→\t\tResults: []string{\"success\", \"fail\"},\n   991→\t\tConfig: map[string]string{\n   992→\t\t\t\"prompt\":        \"Write some code.\",\n   993→\t\t\t\"agent_command\": \"nonexistent-agent-xyz,\" + goodAgent,\n   994→\t\t},\n   995→\t}\n   996→\n   997→\tresult, err := executor.Execute(context.Background(), step)\n   998→\trequire.NoError(t, err)\n   999→\tassert.Equal(t, \"success\", result)\n  1000→\n  1001→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n  1002→\trequire.NoError(t, err)\n  1003→\tassert.Contains(t, string(data), \"fallback agent ran\")\n  1004→}\n  1005→\n  1006→func TestExecutor_AgentStep_PrevOutput(t *testing.T) {\n  1007→\ttmpDir := t.TempDir()\n  1008→\toutputDir := filepath.Join(tmpDir, \"output\")\n  1009→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n  1010→\n  1011→\t// Write previous step output\n  1012→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"prepare.out\"), []byte(\"the task description\"), 0644))\n  1013→\n  1014→\t// Create a mock agent that echoes stdin (the prompt) to verify it received it\n  1015→\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1016→\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'processed prompt'\\n\"), 0755))\n  1017→\n  1018→\texecutor := &Executor{\n  1019→\t\tProjectDir: tmpDir,\n  1020→\t\tOutputDir:  outputDir,\n  1021→\t\tHostRunID:  \"test-host-run\",\n  1022→\t\tWires: []domain.Wire{\n  1023→\t\t\t{From: \"prepare\", Result: \"success\", To: \"implement\"},\n  1024→\t\t},\n  1025→\t}\n  1026→\n  1027→\tstep := &domain.Step{\n  1028→\t\tName:    \"implement\",\n  1029→\t\tType:    domain.StepTypeAgent,\n  1030→\t\tResults: []string{\"success\", \"fail\"},\n  1031→\t\tConfig: map[string]string{\n  1032→\t\t\t\"prompt\":        \"You are a coding assistant.\",\n  1033→\t\t\t\"agent_command\": mockAgent,\n  1034→\t\t},\n  1035→\t}\n  1036→\n  1037→\tresult, err := executor.Execute(context.Background(), step)\n  1038→\trequire.NoError(t, err)\n  1039→\tassert.Equal(t, \"success\", result)\n  1040→\n  1041→\t// Verify prompt.txt was written with previous step's output\n  1042→\tpromptPath := filepath.Join(tmpDir, \".cloche\", \"test-host-run\", \"prompt.txt\")\n  1043→\tdata, err := os.ReadFile(promptPath)\n  1044→\trequire.NoError(t, err)\n  1045→\tassert.Equal(t, \"the task description\", string(data))\n  1046→}\n  1047→\n  1048→func TestExecutor_AgentStep_PromptStep(t *testing.T) {\n  1049→\ttmpDir := t.TempDir()\n  1050→\toutputDir := filepath.Join(tmpDir, \"output\")\n  1051→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n  1052→\n  1053→\t// Write a specific step's output\n  1054→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"custom-source.out\"), []byte(\"custom prompt content\"), 0644))\n  1055→\n  1056→\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1057→\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'done'\\n\"), 0755))\n  1058→\n  1059→\texecutor := &Executor{\n  1060→\t\tProjectDir: tmpDir,\n  1061→\t\tOutputDir:  outputDir,\n  1062→\t\tHostRunID:  \"test-host-run\",\n  1063→\t}\n  1064→\n  1065→\tstep := &domain.Step{\n  1066→\t\tName:    \"implement\",\n  1067→\t\tType:    domain.StepTypeAgent,\n  1068→\t\tResults: []string{\"success\", \"fail\"},\n  1069→\t\tConfig: map[string]string{\n  1070→\t\t\t\"prompt\":        \"You are a coding assistant.\",\n  1071→\t\t\t\"agent_command\": mockAgent,\n  1072→\t\t\t\"prompt_step\":   \"custom-source\",\n  1073→\t\t},\n  1074→\t}\n  1075→\n  1076→\tresult, err := executor.Execute(context.Background(), step)\n  1077→\trequire.NoError(t, err)\n  1078→\tassert.Equal(t, \"success\", result)\n  1079→\n  1080→\t// Verify prompt.txt was written with the prompt_step output\n  1081→\tpromptPath := filepath.Join(tmpDir, \".cloche\", \"test-host-run\", \"prompt.txt\")\n  1082→\tdata, err := os.ReadFile(promptPath)\n  1083→\trequire.NoError(t, err)\n  1084→\tassert.Equal(t, \"custom prompt content\", string(data))\n  1085→}\n  1086→\n  1087→func TestEngine_HostWorkflow_WithAgentStep(t *testing.T) {\n  1088→\ttmpDir := t.TempDir()\n  1089→\toutputDir := filepath.Join(tmpDir, \"output\")\n  1090→\n  1091→\t// Create a mock agent\n  1092→\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1093→\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent output'\\n\"), 0755))\n  1094→\n  1095→\texecutor := &Executor{\n  1096→\t\tProjectDir: tmpDir,\n  1097→\t\tOutputDir:  outputDir,\n  1098→\t\tHostRunID:  \"test-host-run\",\n  1099→\t}\n  1100→\n  1101→\twf := &domain.Workflow{\n  1102→\t\tName: \"main\",\n  1103→\t\tSteps: map[string]*domain.Step{\n  1104→\t\t\t\"prepare\": {\n  1105→\t\t\t\tName:    \"prepare\",\n  1106→\t\t\t\tType:    domain.StepTypeScript,\n  1107→\t\t\t\tResults: []string{\"success\", \"fail\"},\n  1108→\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'task prompt'\"},\n  1109→\t\t\t},\n  1110→\t\t\t\"implement\": {\n  1111→\t\t\t\tName:    \"implement\",\n  1112→\t\t\t\tType:    domain.StepTypeAgent,\n  1113→\t\t\t\tResults: []string{\"success\", \"fail\"},\n  1114→\t\t\t\tConfig: map[string]string{\n  1115→\t\t\t\t\t\"prompt\":        \"You are a coding assistant.\",\n  1116→\t\t\t\t\t\"agent_command\": mockAgent,\n  1117→\t\t\t\t},\n  1118→\t\t\t},\n  1119→\t\t\t\"verify\": {\n  1120→\t\t\t\tName:    \"verify\",\n  1121→\t\t\t\tType:    domain.StepTypeScript,\n  1122→\t\t\t\tResults: []string{\"success\", \"fail\"},\n  1123→\t\t\t\tConfig:  map[string]string{\"run\": \"echo verified\"},\n  1124→\t\t\t},\n  1125→\t\t},\n  1126→\t\tWiring: []domain.Wire{\n  1127→\t\t\t{From: \"prepare\", Result: \"success\", To: \"implement\"},\n  1128→\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n  1129→\t\t\t{From: \"implement\", Result: \"success\", To: \"verify\"},\n  1130→\t\t\t{From: \"implement\", Result: \"fail\", To: domain.StepAbort},\n  1131→\t\t\t{From: \"verify\", Result: \"success\", To: domain.StepDone},\n  1132→\t\t\t{From: \"verify\", Result: \"fail\", To: domain.StepAbort},\n  1133→\t\t},\n  1134→\t\tEntryStep: \"prepare\",\n  1135→\t}\n  1136→\n  1137→\teng := engine.New(executor)\n  1138→\trun, err := eng.Run(context.Background(), wf)\n  1139→\trequire.NoError(t, err)\n  1140→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n  1141→}\n  1142→\n  1143→func TestRunner_HostWorkflow_AgentStep(t *testing.T) {\n  1144→\ttmpDir := t.TempDir()\n  1145→\n  1146→\t// Create a mock agent\n  1147→\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1148→\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent implemented'\\n\"), 0755))\n  1149→\n  1150→\t// Write a host.cloche with an agent step\n  1151→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n  1152→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n  1153→\thostCloche := `workflow \"main\" {\n  1154→  host {\n  1155→    agent_command = \"` + mockAgent + `\"\n  1156→  }\n  1157→\n  1158→  step implement {\n  1159→    prompt = \"Implement the feature.\"\n  1160→    results = [success, fail]\n  1161→  }\n  1162→\n  1163→  implement:success -> done\n  1164→  implement:fail    -> abort\n  1165→}`\n  1166→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n  1167→\n  1168→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n  1169→\n  1170→\trunner := &Runner{\n  1171→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n  1172→\t\tStore:      store,\n  1173→\t}\n  1174→\n  1175→\tresult, err := runner.Run(context.Background(), tmpDir)\n  1176→\trequire.NoError(t, err)\n  1177→\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n  1178→\n  1179→\t// Verify the run completed\n  1180→\thostRun, err := store.GetRun(context.Background(), result.RunID)\n  1181→\trequire.NoError(t, err)\n  1182→\tassert.True(t, hostRun.IsHost)\n  1183→\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n  1184→}\n  1185→\n  1186→func TestRunner_HostWorkflow_AgentStepOverridesWorkflowCommand(t *testing.T) {\n  1187→\ttmpDir := t.TempDir()\n  1188→\n  1189→\t// Create two mock agents\n  1190→\tworkflowAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n  1191→\trequire.NoError(t, os.WriteFile(workflowAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow level'\\n\"), 0755))\n  1192→\n  1193→\tstepAgent := filepath.Join(tmpDir, \"step-agent.sh\")\n  1194→\trequire.NoError(t, os.WriteFile(stepAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'step level'\\n\"), 0755))\n  1195→\n  1196→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n  1197→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n  1198→\thostCloche := `workflow \"main\" {\n  1199→  host {\n  1200→    agent_command = \"` + workflowAgent + `\"\n  1201→  }\n  1202→\n  1203→  step implement {\n  1204→    agent_command = \"` + stepAgent + `\"\n  1205→    prompt = \"Implement the feature.\"\n  1206→    results = [success, fail]\n  1207→  }\n  1208→\n  1209→  implement:success -> done\n  1210→  implement:fail    -> abort\n  1211→}`\n  1212→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n  1213→\n  1214→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n  1215→\trunner := &Runner{\n  1216→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n  1217→\t\tStore:      store,\n  1218→\t}\n  1219→\n  1220→\tresult, err := runner.Run(context.Background(), tmpDir)\n  1221→\trequire.NoError(t, err)\n  1222→\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n  1223→}\n  1224→\n  1225→func TestRunner_PersistsHostRunOnFailure(t *testing.T) {\n  1226→\ttmpDir := t.TempDir()\n  1227→\n  1228→\t// Write a host.cloche that will fail\n  1229→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n  1230→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n  1231→\thostCloche := `workflow \"main\" {\n  1232→  step bad {\n  1233→    run     = \"exit 1\"\n  1234→    results = [success, fail]\n  1235→  }\n  1236→\n  1237→  bad:success -> done\n  1238→  bad:fail    -> abort\n  1239→}`\n  1240→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n  1241→\n  1242→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n  1243→\n  1244→\trunner := &Runner{\n  1245→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n  1246→\t\tStore:      store,\n  1247→\t}\n  1248→\n  1249→\tresult, err := runner.Run(context.Background(), tmpDir)\n  1250→\trequire.NoError(t, err)\n  1251→\tassert.Equal(t, domain.RunStateFailed, result.State)\n  1252→\n  1253→\t// Verify the host run was persisted with failed state\n  1254→\thostRun, err := store.GetRun(context.Background(), result.RunID)\n  1255→\trequire.NoError(t, err)\n  1256→\tassert.True(t, hostRun.IsHost)\n  1257→\tassert.Equal(t, domain.RunStateFailed, hostRun.State)\n  1258→\tassert.False(t, hostRun.CompletedAt.IsZero())\n  1259→}\n  1260→"}]},"parent_tool_use_id":null,"session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"fe251748-6d3c-4b26-b995-e3315a1d46bf","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor_test.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// fakeDispatcher records dispatch calls and returns a predetermined run ID.\ntype fakeDispatcher struct {\n\tcalls     []*pb.RunWorkflowRequest\n\trunID     string\n\treturnErr error\n}\n\nfunc (f *fakeDispatcher) RunWorkflow(_ context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tf.calls = append(f.calls, req)\n\tif f.returnErr != nil {\n\t\treturn nil, f.returnErr\n\t}\n\treturn &pb.RunWorkflowResponse{RunId: f.runID}, nil\n}\n\n// fakeStore returns a predetermined run on GetRun.\ntype fakeStore struct {\n\truns map[string]*domain.Run\n}\n\nfunc (f *fakeStore) CreateRun(_ context.Context, run *domain.Run) error {\n\tf.runs[run.ID] = run\n\treturn nil\n}\nfunc (f *fakeStore) GetRun(_ context.Context, id string) (*domain.Run, error) {\n\tif r, ok := f.runs[id]; ok {\n\t\treturn r, nil\n\t}\n\treturn nil, os.ErrNotExist\n}\nfunc (f *fakeStore) UpdateRun(_ context.Context, run *domain.Run) error {\n\tf.runs[run.ID] = run\n\treturn nil\n}\nfunc (f *fakeStore) DeleteRun(_ context.Context, id string) error {\n\tdelete(f.runs, id)\n\treturn nil\n}\nfunc (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListChildRuns(_ context.Context, parentRunID string) ([]*domain.Run, error) {\n\tvar children []*domain.Run\n\tfor _, r := range f.runs {\n\t\tif r.ParentRunID == parentRunID {\n\t\t\tchildren = append(children, r)\n\t\t}\n\t}\n\treturn children, nil\n}\n\nfunc TestExecutor_ScriptStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"greet\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Check output was written\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"hello\")\n}\n\nfunc TestExecutor_ScriptStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"bad\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"marker\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"custom\", result)\n\n\t// Marker line should be stripped from output\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n\trequire.NoError(t, err)\n\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n\tassert.Contains(t, string(data), \"some output\")\n}\n\nfunc TestExecutor_WorkflowStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\tassert.Len(t, dispatcher.calls, 1)\n\tassert.Equal(t, \"develop\", dispatcher.calls[0].WorkflowName)\n\tassert.Equal(t, tmpDir, dispatcher.calls[0].ProjectDir)\n}\n\nfunc TestExecutor_WorkflowStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateFailed,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_WorkflowStep_PassesPrompt(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\t// Write a previous step's output\n\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"workflow_name\": \"develop\",\n\t\t\t\"prompt_step\":   \"prepare-prompt\",\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n}\n\nfunc TestEngine_HostWorkflow_Linear(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n\t\t\t},\n\t\t\t\"develop\": {\n\t\t\t\tName:    \"develop\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t\t\"merge\": {\n\t\t\t\tName:    \"merge\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\tassert.Len(t, dispatcher.calls, 1)\n}\n\nfunc TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n\t\t\t},\n\t\t\t\"develop\": {\n\t\t\t\tName:    \"develop\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n}\n\nfunc TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"env-check\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), tmpDir)\n}\n\nfunc TestExecutor_ScriptStep_NoOutputMappings(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{From: \"step-a\", Result: \"success\", To: \"step-b\"},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"step-b\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_JSONFields(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write source step output as JSON\n\tsourceJSON := `{\"title\": \"Fix bug\", \"priority\": \"high\"}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"get-tasks.out\"), []byte(sourceJSON), 0644))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"get-tasks\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"use-tasks\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"TASK_TITLE\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"title\"}}},\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"TASK_PRIORITY\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"priority\"}}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"use-tasks\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $TASK_TITLE $TASK_PRIORITY\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"use-tasks.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"Fix bug\")\n\tassert.Contains(t, string(data), \"high\")\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_ArrayIndex(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write source step output as JSON array\n\tsourceJSON := `[{\"id\": \"task-1\", \"title\": \"First\"}, {\"id\": \"task-2\", \"title\": \"Second\"}]`\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"list-tasks.out\"), []byte(sourceJSON), 0644))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"list-tasks\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"process\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"FIRST_ID\",\n\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 0},\n\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"id\"},\n\t\t\t\t\t\t}},\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"SECOND_TITLE\",\n\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 1},\n\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"title\"},\n\t\t\t\t\t\t}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"process\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $FIRST_ID $SECOND_TITLE\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"process.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"task-1\")\n\tassert.Contains(t, string(data), \"Second\")\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_MissingSourceOutput(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// No source output file written\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"missing-step\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"consumer\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"VAL\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"consumer\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\t_, err := executor.Execute(context.Background(), step)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"reading output of missing-step\")\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_NotJSON(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write non-JSON output\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"plain.out\"), []byte(\"not json\"), 0644))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"plain\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"consumer\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"VAL\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"consumer\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\t_, err := executor.Execute(context.Background(), step)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"not valid JSON\")\n}\n\nfunc TestRunner_RunWithID(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Write a simple host.cloche\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  step greet {\n    run     = \"echo hi\"\n    results = [success, fail]\n  }\n\n  greet:success -> done\n  greet:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tcustomID := \"my-custom-run-id\"\n\tresult, err := runner.RunWithID(context.Background(), tmpDir, customID)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n\tassert.Equal(t, customID, result.RunID, \"RunWithID should use the provided ID\")\n\n\t// Verify the run was persisted with the custom ID\n\thostRun, err := store.GetRun(context.Background(), customID)\n\trequire.NoError(t, err)\n\tassert.True(t, hostRun.IsHost)\n\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n}\n\nfunc TestRunner_PersistsHostRun(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Write a simple host.cloche\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  step prepare {\n    run     = \"echo prepared\"\n    results = [success, fail]\n  }\n\n  prepare:success -> done\n  prepare:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tresult, err := runner.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n\tassert.NotEmpty(t, result.RunID)\n\n\t// Verify the host run was persisted in the store\n\thostRun, err := store.GetRun(context.Background(), result.RunID)\n\trequire.NoError(t, err)\n\tassert.True(t, hostRun.IsHost, \"host run should have IsHost=true\")\n\tassert.Equal(t, tmpDir, hostRun.ProjectDir)\n\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n\tassert.False(t, hostRun.StartedAt.IsZero())\n\tassert.False(t, hostRun.CompletedAt.IsZero())\n}\n\nfunc TestExecutor_ScriptStep_UsesMainDir(t *testing.T) {\n\t// ProjectDir has no script; MainDir has the script.\n\tprojectDir := t.TempDir()\n\tmainDir := t.TempDir()\n\toutputDir := filepath.Join(projectDir, \"output\")\n\n\t// Create a script only in mainDir\n\tscriptDir := filepath.Join(mainDir, \".cloche\", \"scripts\")\n\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n\trequire.NoError(t, os.WriteFile(\n\t\tfilepath.Join(scriptDir, \"greet.sh\"),\n\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n\t\t0755,\n\t))\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tMainDir:    mainDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"greet\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/greet.sh\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"from-main\")\n}\n\nfunc TestExecutor_ScriptStep_MainDirOverridesProjectDir(t *testing.T) {\n\t// Both dirs have a script with different content; MainDir's version wins.\n\tprojectDir := t.TempDir()\n\tmainDir := t.TempDir()\n\toutputDir := filepath.Join(projectDir, \"output\")\n\n\t// Create script in both dirs with different content\n\tfor _, dir := range []string{projectDir, mainDir} {\n\t\tscriptDir := filepath.Join(dir, \".cloche\", \"scripts\")\n\t\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n\t}\n\trequire.NoError(t, os.WriteFile(\n\t\tfilepath.Join(projectDir, \".cloche\", \"scripts\", \"hello.sh\"),\n\t\t[]byte(\"#!/bin/sh\\necho from-branch\"),\n\t\t0755,\n\t))\n\trequire.NoError(t, os.WriteFile(\n\t\tfilepath.Join(mainDir, \".cloche\", \"scripts\", \"hello.sh\"),\n\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n\t\t0755,\n\t))\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tMainDir:    mainDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"hello\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/hello.sh\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"hello.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"from-main\")\n\tassert.NotContains(t, string(data), \"from-branch\")\n}\n\nfunc TestExecutor_ScriptStep_FallsBackToProjectDir(t *testing.T) {\n\t// When MainDir is empty, scripts resolve from ProjectDir.\n\tprojectDir := t.TempDir()\n\toutputDir := filepath.Join(projectDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"pwd-check\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"pwd\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"pwd-check.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), projectDir)\n}\n\nfunc TestExecutor_ScriptStep_ProjectDirEnvVar(t *testing.T) {\n\t// CLOCHE_PROJECT_DIR should always point to ProjectDir, not MainDir.\n\tprojectDir := t.TempDir()\n\tmainDir := t.TempDir()\n\toutputDir := filepath.Join(projectDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tMainDir:    mainDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"env-check\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), projectDir)\n\tassert.NotContains(t, string(data), mainDir)\n}\n\nfunc TestMainWorktreeDir_NonGitDir(t *testing.T) {\n\ttmpDir := t.TempDir()\n\t// Non-git directory should fall back to projectDir.\n\tresult := MainWorktreeDir(tmpDir)\n\tassert.Equal(t, tmpDir, result)\n}\n\nfunc TestMainWorktreeDir_WithWorktree(t *testing.T) {\n\t// Set up a real git repo with a linked worktree.\n\tmainDir := t.TempDir()\n\n\t// Initialize git repo\n\trun := func(dir string, args ...string) {\n\t\tt.Helper()\n\t\tcmd := exec.Command(args[0], args[1:]...)\n\t\tcmd.Dir = dir\n\t\tout, err := cmd.CombinedOutput()\n\t\trequire.NoError(t, err, \"command %v failed: %s\", args, out)\n\t}\n\n\trun(mainDir, \"git\", \"init\")\n\trun(mainDir, \"git\", \"config\", \"user.email\", \"test@test.com\")\n\trun(mainDir, \"git\", \"config\", \"user.name\", \"Test\")\n\trequire.NoError(t, os.WriteFile(filepath.Join(mainDir, \"file.txt\"), []byte(\"hello\"), 0644))\n\trun(mainDir, \"git\", \"add\", \".\")\n\trun(mainDir, \"git\", \"commit\", \"-m\", \"initial\")\n\n\t// Create a branch and worktree\n\tworktreeDir := filepath.Join(t.TempDir(), \"wt\")\n\trun(mainDir, \"git\", \"worktree\", \"add\", worktreeDir, \"-b\", \"feature\")\n\n\t// MainWorktreeDir from the linked worktree should return mainDir.\n\tresult := MainWorktreeDir(worktreeDir)\n\tassert.Equal(t, mainDir, result)\n\n\t// MainWorktreeDir from main should return mainDir.\n\tresult = MainWorktreeDir(mainDir)\n\tassert.Equal(t, mainDir, result)\n}\n\nfunc TestExecutor_AgentStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\t// Create a mock agent script that reads stdin and produces output\n\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent did the work'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tHostRunID:  \"test-host-run\",\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\":        \"You are a coding assistant.\",\n\t\t\t\"agent_command\": mockAgent,\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Check output was copied to executor's output path\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"agent did the work\")\n}\n\nfunc TestExecutor_AgentStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\t// Create a mock agent that reports failure via result marker\n\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'something went wrong'\\necho 'CLOCHE_RESULT:fail'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tHostRunID:  \"test-host-run\",\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\":        \"You are a coding assistant.\",\n\t\t\t\"agent_command\": mockAgent,\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_AgentStep_WorkflowLevelCommand(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\t// Create a mock agent\n\tmockAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow agent ran'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir:    tmpDir,\n\t\tOutputDir:     outputDir,\n\t\tHostRunID:     \"test-host-run\",\n\t\tAgentCommands: []string{mockAgent},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\": \"Write some code.\",\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"workflow agent ran\")\n}\n\nfunc TestExecutor_AgentStep_StepLevelOverridesWorkflow(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\t// Create two mock agents\n\tworkflowAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n\trequire.NoError(t, os.WriteFile(workflowAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow agent'\\n\"), 0755))\n\n\tstepAgent := filepath.Join(tmpDir, \"step-agent.sh\")\n\trequire.NoError(t, os.WriteFile(stepAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'step agent'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir:    tmpDir,\n\t\tOutputDir:     outputDir,\n\t\tHostRunID:     \"test-host-run\",\n\t\tAgentCommands: []string{workflowAgent},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\":        \"Write some code.\",\n\t\t\t\"agent_command\": stepAgent,\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Step-level agent should have run, not workflow-level\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"step agent\")\n\tassert.NotContains(t, string(data), \"workflow agent\")\n}\n\nfunc TestExecutor_AgentStep_FallbackChain(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\t// Create a good agent\n\tgoodAgent := filepath.Join(tmpDir, \"good-agent.sh\")\n\trequire.NoError(t, os.WriteFile(goodAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'fallback agent ran'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tHostRunID:  \"test-host-run\",\n\t}\n\n\t// Use nonexistent command as primary, good agent as fallback\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\":        \"Write some code.\",\n\t\t\t\"agent_command\": \"nonexistent-agent-xyz,\" + goodAgent,\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"fallback agent ran\")\n}\n\nfunc TestExecutor_AgentStep_PrevOutput(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write previous step output\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"prepare.out\"), []byte(\"the task description\"), 0644))\n\n\t// Create a mock agent that echoes stdin (the prompt) to verify it received it\n\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'processed prompt'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tHostRunID:  \"test-host-run\",\n\t\tWires: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"implement\"},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\":        \"You are a coding assistant.\",\n\t\t\t\"agent_command\": mockAgent,\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Verify prompt.txt was written with previous step's output\n\tpromptPath := filepath.Join(tmpDir, \".cloche\", \"test-host-run\", \"prompt.txt\")\n\tdata, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"the task description\", string(data))\n}\n\nfunc TestExecutor_AgentStep_PromptStep(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write a specific step's output\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"custom-source.out\"), []byte(\"custom prompt content\"), 0644))\n\n\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'done'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tHostRunID:  \"test-host-run\",\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"prompt\":        \"You are a coding assistant.\",\n\t\t\t\"agent_command\": mockAgent,\n\t\t\t\"prompt_step\":   \"custom-source\",\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Verify prompt.txt was written with the prompt_step output\n\tpromptPath := filepath.Join(tmpDir, \".cloche\", \"test-host-run\", \"prompt.txt\")\n\tdata, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"custom prompt content\", string(data))\n}\n\nfunc TestEngine_HostWorkflow_WithAgentStep(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\t// Create a mock agent\n\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent output'\\n\"), 0755))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tHostRunID:  \"test-host-run\",\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'task prompt'\"},\n\t\t\t},\n\t\t\t\"implement\": {\n\t\t\t\tName:    \"implement\",\n\t\t\t\tType:    domain.StepTypeAgent,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig: map[string]string{\n\t\t\t\t\t\"prompt\":        \"You are a coding assistant.\",\n\t\t\t\t\t\"agent_command\": mockAgent,\n\t\t\t\t},\n\t\t\t},\n\t\t\t\"verify\": {\n\t\t\t\tName:    \"verify\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo verified\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"implement\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"implement\", Result: \"success\", To: \"verify\"},\n\t\t\t{From: \"implement\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"verify\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"verify\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n}\n\nfunc TestRunner_HostWorkflow_AgentStep(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Create a mock agent\n\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent implemented'\\n\"), 0755))\n\n\t// Write a host.cloche with an agent step\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  host {\n    agent_command = \"` + mockAgent + `\"\n  }\n\n  step implement {\n    prompt = \"Implement the feature.\"\n    results = [success, fail]\n  }\n\n  implement:success -> done\n  implement:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tresult, err := runner.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n\n\t// Verify the run completed\n\thostRun, err := store.GetRun(context.Background(), result.RunID)\n\trequire.NoError(t, err)\n\tassert.True(t, hostRun.IsHost)\n\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n}\n\nfunc TestRunner_HostWorkflow_AgentStepOverridesWorkflowCommand(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Create two mock agents\n\tworkflowAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n\trequire.NoError(t, os.WriteFile(workflowAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow level'\\n\"), 0755))\n\n\tstepAgent := filepath.Join(tmpDir, \"step-agent.sh\")\n\trequire.NoError(t, os.WriteFile(stepAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'step level'\\n\"), 0755))\n\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  host {\n    agent_command = \"` + workflowAgent + `\"\n  }\n\n  step implement {\n    agent_command = \"` + stepAgent + `\"\n    prompt = \"Implement the feature.\"\n    results = [success, fail]\n  }\n\n  implement:success -> done\n  implement:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tresult, err := runner.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n}\n\nfunc TestRunner_PersistsHostRunOnFailure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Write a host.cloche that will fail\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  step bad {\n    run     = \"exit 1\"\n    results = [success, fail]\n  }\n\n  bad:success -> done\n  bad:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tresult, err := runner.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, result.State)\n\n\t// Verify the host run was persisted with failed state\n\thostRun, err := store.GetRun(context.Background(), result.RunID)\n\trequire.NoError(t, err)\n\tassert.True(t, hostRun.IsHost)\n\tassert.Equal(t, domain.RunStateFailed, hostRun.State)\n\tassert.False(t, hostRun.CompletedAt.IsZero())\n}\n","numLines":1260,"startLine":1,"totalLines":1260}}}
