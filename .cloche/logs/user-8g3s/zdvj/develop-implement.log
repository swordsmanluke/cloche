{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JjD2Qo3wTF2DU1Wx3cE5jg","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# Returns ready, unclaimed tasks from bd as a JSON array.\n     3→# Usage: ready-tasks.sh [max]\n     4→#   max  — maximum number of IDs to return (default: all)\n     5→set -euo pipefail\n     6→\n     7→max=\"${1:-0}\"\n     8→\n     9→limit_args=()\n    10→if [ \"$max\" -gt 0 ] 2>/dev/null; then\n    11→  limit_args=(--limit \"$max\")\n    12→fi\n    13→\n    14→# Filter to open status only — excludes in_progress (already claimed) tasks.\n    15→json=$(bd list -s open --json \"${limit_args[@]}\" 2>/dev/null) || json=\"[]\"\n    16→\n    17→echo \"$json\"\n    18→"}]},"parent_tool_use_id":"toolu_01PBzqGrRSxSxC8pWZNjvguQ","session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"a8b72ec8-100f-4a67-b86f-cc146257073a"}
