{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WD89LP1JTKHenNApyPFtss","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"sync/atomic\"\n     6→\t\"testing\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→)\n    11→\n    12→func TestLoop_StartStop(t *testing.T) {\n    13→\tstore := &fakeStore{}\n    14→\tvar called atomic.Int32\n    15→\n    16→\trunFn := func(ctx context.Context, projectDir string) (*RunResult, error) {\n    17→\t\tcalled.Add(1)\n    18→\t\t// Simulate a run that finds no work (failed = aborted).\n    19→\t\ttime.Sleep(50 * time.Millisecond)\n    20→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    21→\t}\n    22→\n    23→\tloop := NewLoop(LoopConfig{\n    24→\t\tProjectDir:    \"/tmp/test-project\",\n    25→\t\tMaxConcurrent: 1,\n    26→\t}, store, runFn)\n    27→\n    28→\tif loop.Running() {\n    29→\t\tt.Fatal(\"loop should not be running before Start\")\n    30→\t}\n    31→\n    32→\tloop.Start()\n    33→\tif !loop.Running() {\n    34→\t\tt.Fatal(\"loop should be running after Start\")\n    35→\t}\n    36→\n    37→\t// Wait enough time for at least one run to happen.\n    38→\ttime.Sleep(200 * time.Millisecond)\n    39→\tloop.Stop()\n    40→\n    41→\tif loop.Running() {\n    42→\t\tt.Fatal(\"loop should not be running after Stop\")\n    43→\t}\n    44→\n    45→\tif called.Load() < 1 {\n    46→\t\tt.Fatal(\"expected at least one run to be launched\")\n    47→\t}\n    48→}\n    49→\n    50→func TestLoop_RampsUpOnSuccess(t *testing.T) {\n    51→\tstore := &fakeStore{}\n    52→\tvar called atomic.Int32\n    53→\n    54→\trunFn := func(ctx context.Context, projectDir string) (*RunResult, error) {\n    55→\t\tn := called.Add(1)\n    56→\t\ttime.Sleep(20 * time.Millisecond)\n    57→\t\t// First 3 succeed, then fail (no more work).\n    58→\t\tif n <= 3 {\n    59→\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n    60→\t\t}\n    61→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    62→\t}\n    63→\n    64→\tloop := NewLoop(LoopConfig{\n    65→\t\tProjectDir:    \"/tmp/test-project\",\n    66→\t\tMaxConcurrent: 1,\n    67→\t}, store, runFn)\n    68→\n    69→\tloop.Start()\n    70→\t// With no backoff between successes, 3 successful + 1 failed should happen fast.\n    71→\ttime.Sleep(300 * time.Millisecond)\n    72→\tloop.Stop()\n    73→\n    74→\tif called.Load() < 4 {\n    75→\t\tt.Fatalf(\"expected at least 4 runs, got %d\", called.Load())\n    76→\t}\n    77→}\n    78→\n    79→func TestLoop_DoubleStartIsNoop(t *testing.T) {\n    80→\tstore := &fakeStore{}\n    81→\trunFn := func(ctx context.Context, projectDir string) (*RunResult, error) {\n    82→\t\ttime.Sleep(100 * time.Millisecond)\n    83→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    84→\t}\n    85→\n    86→\tloop := NewLoop(LoopConfig{\n    87→\t\tProjectDir:    \"/tmp/test-project\",\n    88→\t\tMaxConcurrent: 1,\n    89→\t}, store, runFn)\n    90→\n    91→\tloop.Start()\n    92→\tloop.Start() // Should be a no-op.\n    93→\tloop.Stop()\n    94→}\n    95→"}]},"parent_tool_use_id":null,"session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"445c85df-c475-4308-9b2c-655494603401","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/loop_test.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"sync/atomic\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n)\n\nfunc TestLoop_StartStop(t *testing.T) {\n\tstore := &fakeStore{}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string) (*RunResult, error) {\n\t\tcalled.Add(1)\n\t\t// Simulate a run that finds no work (failed = aborted).\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\tif loop.Running() {\n\t\tt.Fatal(\"loop should not be running before Start\")\n\t}\n\n\tloop.Start()\n\tif !loop.Running() {\n\t\tt.Fatal(\"loop should be running after Start\")\n\t}\n\n\t// Wait enough time for at least one run to happen.\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tif loop.Running() {\n\t\tt.Fatal(\"loop should not be running after Stop\")\n\t}\n\n\tif called.Load() < 1 {\n\t\tt.Fatal(\"expected at least one run to be launched\")\n\t}\n}\n\nfunc TestLoop_RampsUpOnSuccess(t *testing.T) {\n\tstore := &fakeStore{}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string) (*RunResult, error) {\n\t\tn := called.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\t// First 3 succeed, then fail (no more work).\n\t\tif n <= 3 {\n\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t\t}\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\t// With no backoff between successes, 3 successful + 1 failed should happen fast.\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\tif called.Load() < 4 {\n\t\tt.Fatalf(\"expected at least 4 runs, got %d\", called.Load())\n\t}\n}\n\nfunc TestLoop_DoubleStartIsNoop(t *testing.T) {\n\tstore := &fakeStore{}\n\trunFn := func(ctx context.Context, projectDir string) (*RunResult, error) {\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\tloop.Start() // Should be a no-op.\n\tloop.Stop()\n}\n","numLines":95,"startLine":1,"totalLines":95}}}
