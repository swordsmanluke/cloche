{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EiAHNKeYujmjx8g1toAE2k","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# Default prompt generator.\n     3→# Writes the task prompt to stdout and to $CLOCHE_STEP_OUTPUT.\n     4→# Expects CLOCHE_TASK_TITLE and CLOCHE_TASK_BODY from wire output mappings.\n     5→set -euo pipefail\n     6→\n     7→task_title=\"${CLOCHE_TASK_TITLE:-}\"\n     8→task_body=\"${CLOCHE_TASK_BODY:-}\"\n     9→\n    10→if [ -z \"$task_title\" ]; then\n    11→  echo \"error: CLOCHE_TASK_TITLE is not set\" >&2\n    12→  exit 1\n    13→fi\n    14→\n    15→prompt=\"## Task: ${task_title}\n    16→\n    17→${task_body}\"\n    18→\n    19→echo \"$prompt\"\n    20→[ -n \"${CLOCHE_STEP_OUTPUT:-}\" ] && echo \"$prompt\" > \"$CLOCHE_STEP_OUTPUT\"\n    21→"}]},"parent_tool_use_id":"toolu_01PBzqGrRSxSxC8pWZNjvguQ","session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"7972f7e9-a3fb-49c9-bcf6-68bd1210688b"}
