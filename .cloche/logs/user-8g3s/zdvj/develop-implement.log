{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HU8os5jyVcbYAppk92kJ8D","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"strings\"\n    11→\t\"time\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    17→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    19→)\n    20→\n    21→// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    22→// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    23→// strings suitable for adding to a command's environment.\n    24→func (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    25→\tvar env []string\n    26→\tfor _, w := range wires {\n    27→\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    28→\t\t\tcontinue\n    29→\t\t}\n    30→\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    31→\t\tif err != nil {\n    32→\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    33→\t\t}\n    34→\t\tfor _, m := range w.OutputMap {\n    35→\t\t\tval, err := m.Path.Evaluate(data)\n    36→\t\t\tif err != nil {\n    37→\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    38→\t\t\t}\n    39→\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    40→\t\t}\n    41→\t}\n    42→\treturn env, nil\n    43→}\n    44→\n    45→// RunDispatcher dispatches a container workflow run and returns the run ID.\n    46→type RunDispatcher interface {\n    47→\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    48→}\n    49→\n    50→// Executor implements engine.StepExecutor for host workflow steps.\n    51→type Executor struct {\n    52→\tProjectDir    string\n    53→\tMainDir       string         // main branch worktree dir; scripts execute from here\n    54→\tDispatcher    RunDispatcher\n    55→\tStore         ports.RunStore\n    56→\tOutputDir     string         // directory for step output files\n    57→\tWires         []domain.Wire  // workflow wiring (for output mappings)\n    58→\tHostRunID     string         // ID of the parent host run (set on child runs)\n    59→\tAgentCommands []string       // workflow-level agent command fallback chain\n    60→\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n    61→}\n    62→\n    63→// scriptDir returns the directory from which scripts should execute.\n    64→// Uses MainDir if set, otherwise falls back to ProjectDir.\n    65→func (e *Executor) scriptDir() string {\n    66→\tif e.MainDir != \"\" {\n    67→\t\treturn e.MainDir\n    68→\t}\n    69→\treturn e.ProjectDir\n    70→}\n    71→\n    72→var _ engine.StepExecutor = (*Executor)(nil)\n    73→\n    74→// Execute runs a single host workflow step.\n    75→func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    76→\tswitch step.Type {\n    77→\tcase domain.StepTypeScript:\n    78→\t\treturn e.executeScript(ctx, step)\n    79→\tcase domain.StepTypeWorkflow:\n    80→\t\treturn e.executeWorkflow(ctx, step)\n    81→\tcase domain.StepTypeAgent:\n    82→\t\treturn e.executeAgent(ctx, step)\n    83→\tdefault:\n    84→\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    85→\t}\n    86→}\n    87→\n    88→// executeScript runs a shell command on the host.\n    89→func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    90→\tcmdStr := step.Config[\"run\"]\n    91→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    92→\tcmd.Dir = e.scriptDir()\n    93→\tcmd.Env = append(os.Environ(),\n    94→\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    95→\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    96→\t)\n    97→\n    98→\t// Pass previous step output if available\n    99→\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n   100→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n   101→\t}\n   102→\n   103→\t// Resolve output mappings from wires and add as env vars\n   104→\tif len(e.Wires) > 0 {\n   105→\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n   106→\t\tif err != nil {\n   107→\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n   108→\t\t}\n   109→\t\tcmd.Env = append(cmd.Env, mapped...)\n   110→\t}\n   111→\n   112→\toutput, err := cmd.CombinedOutput()\n   113→\n   114→\t// Extract result marker\n   115→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n   116→\n   117→\t// Write output to file\n   118→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   119→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   120→\t}\n   121→\n   122→\tif err != nil {\n   123→\t\tif _, ok := err.(*exec.ExitError); ok {\n   124→\t\t\tresult := \"fail\"\n   125→\t\t\tif found {\n   126→\t\t\t\tresult = markerResult\n   127→\t\t\t}\n   128→\t\t\treturn result, nil\n   129→\t\t}\n   130→\t\treturn \"\", err\n   131→\t}\n   132→\n   133→\tresult := \"success\"\n   134→\tif found {\n   135→\t\tresult = markerResult\n   136→\t}\n   137→\treturn result, nil\n   138→}\n   139→\n   140→// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   141→func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   142→\tworkflowName := step.Config[\"workflow_name\"]\n   143→\tif workflowName == \"\" {\n   144→\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   145→\t}\n   146→\n   147→\t// Read prompt from previous step output or prompt_step override\n   148→\tvar promptContent string\n   149→\tpromptSource := step.Config[\"prompt_step\"]\n   150→\tif promptSource != \"\" {\n   151→\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   152→\t\tif err == nil {\n   153→\t\t\tpromptContent = string(data)\n   154→\t\t}\n   155→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   156→\t\tdata, err := os.ReadFile(prev)\n   157→\t\tif err == nil {\n   158→\t\t\tpromptContent = string(data)\n   159→\t\t}\n   160→\t}\n   161→\n   162→\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   163→\t\tWorkflowName: workflowName,\n   164→\t\tProjectDir:   e.ProjectDir,\n   165→\t\tPrompt:       promptContent,\n   166→\t})\n   167→\tif err != nil {\n   168→\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   169→\t}\n   170→\n   171→\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   172→\n   173→\t// Link child run to parent host run\n   174→\tif e.HostRunID != \"\" {\n   175→\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n   176→\t\t\tchildRun.ParentRunID = e.HostRunID\n   177→\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n   178→\t\t}\n   179→\t}\n   180→\n   181→\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n   182→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   183→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n   184→\t}\n   185→\n   186→\t// Poll until the run reaches a terminal state\n   187→\tstate, err := e.waitForRun(ctx, resp.RunId)\n   188→\tif err != nil {\n   189→\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   190→\t}\n   191→\n   192→\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   193→\n   194→\t// Map run state to step result\n   195→\tif state == domain.RunStateSucceeded {\n   196→\t\treturn \"success\", nil\n   197→\t}\n   198→\treturn \"fail\", nil\n   199→}\n   200→\n   201→// executeAgent runs an agent command on the host using the prompt adapter.\n   202→func (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n   203→\tadapter := prompt.New()\n   204→\n   205→\t// Apply workflow-level agent config\n   206→\tif len(e.AgentCommands) > 0 {\n   207→\t\tadapter.Commands = e.AgentCommands\n   208→\t}\n   209→\tif len(e.AgentArgs) > 0 {\n   210→\t\tadapter.ExplicitArgs = e.AgentArgs\n   211→\t}\n   212→\n   213→\t// Step-level overrides\n   214→\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   215→\t\tadapter.Commands = prompt.ParseCommands(cmd)\n   216→\t}\n   217→\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   218→\t\tadapter.ExplicitArgs = strings.Fields(args)\n   219→\t}\n   220→\n   221→\tadapter.RunID = e.HostRunID\n   222→\n   223→\t// Write previous step output as user prompt so the adapter can pick it up.\n   224→\tvar promptContent string\n   225→\tpromptSource := step.Config[\"prompt_step\"]\n   226→\tif promptSource != \"\" {\n   227→\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n   228→\t\t\tpromptContent = string(data)\n   229→\t\t}\n   230→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   231→\t\tif data, err := os.ReadFile(prev); err == nil {\n   232→\t\t\tpromptContent = string(data)\n   233→\t\t}\n   234→\t}\n   235→\n   236→\tif promptContent != \"\" {\n   237→\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n   238→\t\t_ = os.MkdirAll(promptDir, 0755)\n   239→\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n   240→\t}\n   241→\n   242→\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n   243→\tif err != nil {\n   244→\t\treturn \"\", err\n   245→\t}\n   246→\n   247→\t// Copy output from adapter's output location to executor's output path\n   248→\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n   249→\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n   250→\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   251→\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n   252→\t\t}\n   253→\t}\n   254→\n   255→\treturn result, nil\n   256→}\n   257→\n   258→// waitForRun polls the store until the run reaches a terminal state.\n   259→func (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   260→\tticker := time.NewTicker(2 * time.Second)\n   261→\tdefer ticker.Stop()\n   262→\n   263→\tfor {\n   264→\t\tselect {\n   265→\t\tcase <-ctx.Done():\n   266→\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   267→\t\tcase <-ticker.C:\n   268→\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   269→\t\t\tif err != nil {\n   270→\t\t\t\tcontinue // transient error, retry\n   271→\t\t\t}\n   272→\t\t\tswitch run.State {\n   273→\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   274→\t\t\t\treturn run.State, nil\n   275→\t\t\t}\n   276→\t\t\t// Still pending or running, continue polling\n   277→\t\t}\n   278→\t}\n   279→}\n   280→\n   281→// stepOutputPath returns the path for a step's output file.\n   282→func (e *Executor) stepOutputPath(stepName string) string {\n   283→\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   284→}\n   285→\n   286→// findPrevOutput finds the output file from the step that wires into this one.\n   287→// It checks prompt_step config first, then walks the wiring graph to find the\n   288→// source step.\n   289→func (e *Executor) findPrevOutput(step *domain.Step) string {\n   290→\t// Explicit prompt_step config takes priority\n   291→\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   292→\t\tpath := e.stepOutputPath(ps)\n   293→\t\tif _, err := os.Stat(path); err == nil {\n   294→\t\t\treturn path\n   295→\t\t}\n   296→\t}\n   297→\n   298→\t// Walk wiring to find the step that feeds into this one\n   299→\tfor _, w := range e.Wires {\n   300→\t\tif w.To == step.Name {\n   301→\t\t\tpath := e.stepOutputPath(w.From)\n   302→\t\t\tif _, err := os.Stat(path); err == nil {\n   303→\t\t\t\treturn path\n   304→\t\t\t}\n   305→\t\t}\n   306→\t}\n   307→\treturn \"\"\n   308→}\n   309→\n   310→// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n   311→// the repository containing projectDir. If projectDir is already the main\n   312→// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n   313→// error (e.g. not a git repo).\n   314→func MainWorktreeDir(projectDir string) string {\n   315→\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n   316→\tout, err := cmd.Output()\n   317→\tif err != nil {\n   318→\t\treturn projectDir\n   319→\t}\n   320→\t// The first \"worktree <path>\" line is always the main worktree.\n   321→\tfor _, line := range strings.Split(string(out), \"\\n\") {\n   322→\t\tif strings.HasPrefix(line, \"worktree \") {\n   323→\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n   324→\t\t}\n   325→\t}\n   326→\treturn projectDir\n   327→}\n   328→"}]},"parent_tool_use_id":"toolu_01Dpfoc28ynQqDwHgSbSci6o","session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"72f15f0d-46d5-4177-8f98-5e034acf5c36"}
