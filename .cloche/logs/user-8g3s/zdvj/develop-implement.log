{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xc99FuCrgUBfFYASwspj4j","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# cleanup-run.sh — Remove the worktree and branch left over from a cloche run.\n     3→# Expects CLOCHE_PREV_OUTPUT to point to a file containing the run ID.\n     4→set -euo pipefail\n     5→\n     6→if [ -z \"${CLOCHE_PREV_OUTPUT:-}\" ] || [ ! -f \"$CLOCHE_PREV_OUTPUT\" ]; then\n     7→  echo \"error: CLOCHE_PREV_OUTPUT not set or file missing\" >&2\n     8→  exit 1\n     9→fi\n    10→\n    11→RUN_ID=$(cat \"$CLOCHE_PREV_OUTPUT\" | tr -d '[:space:]')\n    12→PROJECT_DIR=\"${CLOCHE_PROJECT_DIR:-.}\"\n    13→\n    14→# Try to find the task ID from the ready-tasks output in our run's output directory\n    15→if [ -z \"${CLOCHE_TASK_ID:-}\" ]; then\n    16→  OUTPUT_DIR=\"$(dirname \"$CLOCHE_PREV_OUTPUT\")\"\n    17→  READY_OUT=\"$OUTPUT_DIR/ready-tasks.out\"\n    18→  if [ -f \"$READY_OUT\" ]; then\n    19→    CLOCHE_TASK_ID=$(jq -r '.[0].id // empty' \"$READY_OUT\" 2>/dev/null) || true\n    20→  fi\n    21→fi\n    22→BRANCH=\"cloche/${RUN_ID}\"\n    23→WORKTREE_DIR=\"$PROJECT_DIR/.gitworktrees/cloche/$RUN_ID\"\n    24→\n    25→# Remove the extraction worktree if it still exists\n    26→if [ -d \"$WORKTREE_DIR\" ]; then\n    27→  git -C \"$PROJECT_DIR\" worktree remove --force \"$WORKTREE_DIR\" 2>/dev/null || true\n    28→fi\n    29→\n    30→# Prune any stale worktree bookkeeping\n    31→git -C \"$PROJECT_DIR\" worktree prune 2>/dev/null || true\n    32→\n    33→# Delete the branch if it still exists (merge may have already removed it)\n    34→if git -C \"$PROJECT_DIR\" rev-parse --verify \"$BRANCH\" >/dev/null 2>&1; then\n    35→  git -C \"$PROJECT_DIR\" branch -D \"$BRANCH\" 2>/dev/null || true\n    36→fi\n    37→\n    38→# Close the task if CLOCHE_TASK_ID is set\n    39→if [ -n \"${CLOCHE_TASK_ID:-}\" ]; then\n    40→  bd close \"$CLOCHE_TASK_ID\" 2>/dev/null && echo \"Closed task $CLOCHE_TASK_ID\" || echo \"warning: could not close task $CLOCHE_TASK_ID\" >&2\n    41→fi\n    42→\n    43→echo \"Cleaned up run $RUN_ID\"\n    44→"}]},"parent_tool_use_id":"toolu_01PBzqGrRSxSxC8pWZNjvguQ","session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"5b009648-2a75-4b8b-b48d-ef687840aa1e"}
