 != \"\" {\n\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n\t}\n\n\ts.loops[projectDir] = loop\n\tloop.Start()\n\n\treturn &pb.EnableLoopResponse{}, nil\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1013,"cache_read_input_tokens":86220,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1013},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"74c1c4ef-a1d6-45cd-87db-e0ad06bd6f1c"}
