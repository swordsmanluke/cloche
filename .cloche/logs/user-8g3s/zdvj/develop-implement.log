{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017QNb6t5GhDsFxRXVkMytgJ","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"strings\"\n    11→\t\"time\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    17→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    19→)\n    20→\n    21→// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    22→// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    23→// strings suitable for adding to a command's environment.\n    24→func (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    25→\tvar env []string\n    26→\tfor _, w := range wires {\n    27→\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    28→\t\t\tcontinue\n    29→\t\t}\n    30→\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    31→\t\tif err != nil {\n    32→\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    33→\t\t}\n    34→\t\tfor _, m := range w.OutputMap {\n    35→\t\t\tval, err := m.Path.Evaluate(data)\n    36→\t\t\tif err != nil {\n    37→\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    38→\t\t\t}\n    39→\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    40→\t\t}\n    41→\t}\n    42→\treturn env, nil\n    43→}\n    44→\n    45→// RunDispatcher dispatches a container workflow run and returns the run ID.\n    46→type RunDispatcher interface {\n    47→\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    48→}\n    49→\n    50→// Executor implements engine.StepExecutor for host workflow steps.\n    51→type Executor struct {\n    52→\tProjectDir    string\n    53→\tMainDir       string         // main branch worktree dir; scripts execute from here\n    54→\tDispatcher    RunDispatcher\n    55→\tStore         ports.RunStore\n    56→\tOutputDir     string         // directory for step output files\n    57→\tWires         []domain.Wire  // workflow wiring (for output mappings)\n    58→\tHostRunID     string         // ID of the parent host run (set on child runs)\n    59→\tAgentCommands []string       // workflow-level agent command fallback chain\n    60→\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n    61→}\n    62→\n    63→// scriptDir returns the directory from which scripts should execute.\n    64→// Uses MainDir if set, otherwise falls back to ProjectDir.\n    65→func (e *Executor) scriptDir() string {\n    66→\tif e.MainDir != \"\" {\n    67→\t\treturn e.MainDir\n    68→\t}\n    69→\treturn e.ProjectDir\n    70→}\n    71→\n    72→var _ engine.StepExecutor = (*Executor)(nil)\n    73→\n    74→// Execute runs a single host workflow step.\n    75→func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    76→\tswitch step.Type {\n    77→\tcase domain.StepTypeScript:\n    78→\t\treturn e.executeScript(ctx, step)\n    79→\tcase domain.StepTypeWorkflow:\n    80→\t\treturn e.executeWorkflow(ctx, step)\n    81→\tcase domain.StepTypeAgent:\n    82→\t\treturn e.executeAgent(ctx, step)\n    83→\tdefault:\n    84→\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    85→\t}\n    86→}\n    87→\n    88→// executeScript runs a shell command on the host.\n    89→func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    90→\tcmdStr := step.Config[\"run\"]\n    91→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    92→\tcmd.Dir = e.scriptDir()\n    93→\tcmd.Env = append(os.Environ(),\n    94→\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    95→\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    96→\t)\n    97→\n    98→\t// Pass previous step output if available\n    99→\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n   100→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n   101→\t}\n   102→\n   103→\t// Resolve output mappings from wires and add as env vars\n   104→\tif len(e.Wires) > 0 {\n   105→\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n   106→\t\tif err != nil {\n   107→\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n   108→\t\t}\n   109→\t\tcmd.Env = append(cmd.Env, mapped...)\n   110→\t}\n   111→\n   112→\toutput, err := cmd.CombinedOutput()\n   113→\n   114→\t// Extract result marker\n   115→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n   116→\n   117→\t// Write output to file\n   118→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   119→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   120→\t}\n   121→\n   122→\tif err != nil {\n   123→\t\tif _, ok := err.(*exec.ExitError); ok {\n   124→\t\t\tresult := \"fail\"\n   125→\t\t\tif found {\n   126→\t\t\t\tresult = markerResult\n   127→\t\t\t}\n   128→\t\t\treturn result, nil\n   129→\t\t}\n   130→\t\treturn \"\", err\n   131→\t}\n   132→\n   133→\tresult := \"success\"\n   134→\tif found {\n   135→\t\tresult = markerResult\n   136→\t}\n   137→\treturn result, nil\n   138→}\n   139→\n   140→// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   141→func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   142→\tworkflowName := step.Config[\"workflow_name\"]\n   143→\tif workflowName == \"\" {\n   144→\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   145→\t}\n   146→\n   147→\t// Read prompt from previous step output or prompt_step override\n   148→\tvar promptContent string\n   149→\tpromptSource := step.Config[\"prompt_step\"]\n   150→\tif promptSource != \"\" {"}]},"parent_tool_use_id":"toolu_01PBzqGrRSxSxC8pWZNjvguQ","session_id":"2f8bcbbf-b8aa-4f20-9779-dee3a5fa668b","uuid":"485de9ae-8800-4bef-a350-378185b3ac73"}
