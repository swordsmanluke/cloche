{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GvjdDZMZcJA3m3Mjo1aUgm","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"os/exec\"\n     8→\t\"strings\"\n     9→)\n    10→\n    11→// Task represents a work item from an external task tracker.\n    12→type Task struct {\n    13→\tID          string `json:\"id\"`\n    14→\tTitle       string `json:\"title\"`\n    15→\tDescription string `json:\"description\"`\n    16→}\n    17→\n    18→// TaskAssigner lists available tasks for the daemon to assign to workflow runs.\n    19→type TaskAssigner interface {\n    20→\tListTasks(ctx context.Context, projectDir string) ([]Task, error)\n    21→}\n    22→\n    23→// ScriptTaskAssigner runs a shell command to list tasks and parses the JSON output.\n    24→// The command should output a JSON array of objects with at least an \"id\" field.\n    25→type ScriptTaskAssigner struct {\n    26→\tCommand string // shell command to run (e.g., \"bash .cloche/scripts/ready-tasks.sh\")\n    27→}\n    28→\n    29→// ListTasks executes the configured command from the project directory and\n    30→// parses its stdout as a JSON array of Task objects.\n    31→func (s *ScriptTaskAssigner) ListTasks(ctx context.Context, projectDir string) ([]Task, error) {\n    32→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", s.Command)\n    33→\tcmd.Dir = MainWorktreeDir(projectDir)\n    34→\n    35→\tout, err := cmd.Output()\n    36→\tif err != nil {\n    37→\t\treturn nil, fmt.Errorf(\"running list-tasks command: %w\", err)\n    38→\t}\n    39→\n    40→\toutput := strings.TrimSpace(string(out))\n    41→\tif output == \"\" || output == \"[]\" {\n    42→\t\treturn nil, nil\n    43→\t}\n    44→\n    45→\tvar tasks []Task\n    46→\tif err := json.Unmarshal([]byte(output), &tasks); err != nil {\n    47→\t\treturn nil, fmt.Errorf(\"parsing list-tasks output: %w\", err)\n    48→\t}\n    49→\treturn tasks, nil\n    50→}\n    51→"}]},"parent_tool_use_id":"toolu_012epjQe4jiFDSKQ49cH1EjH","session_id":"b83aa53c-b539-403e-957d-d27f065bd09c","uuid":"4d628229-349e-4811-95b7-5070aa90c056"}
