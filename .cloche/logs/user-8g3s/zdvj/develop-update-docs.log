{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015RHq6hAq5CCC28H6oDx53r","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/config\"\n    19→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    20→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    21→\t\"github.com/cloche-dev/cloche/internal/host\"\n    22→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    23→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    24→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    25→\trpcgrpc \"google.golang.org/grpc\"\n    26→)\n    27→\n    28→type ClocheServer struct {\n    29→\tpb.UnimplementedClocheServiceServer\n    30→\tstore        ports.RunStore\n    31→\tcaptures     ports.CaptureStore\n    32→\tlogStore     ports.LogStore\n    33→\tcontainer    ports.ContainerRuntime\n    34→\tdefaultImage string\n    35→\tevolution    *evolution.Trigger\n    36→\tlogBroadcast *logstream.Broadcaster\n    37→\tshutdownFn   func()\n    38→\tmu           sync.Mutex\n    39→\trunIDs       map[string]string      // run_id -> container_id\n    40→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    41→}\n    42→\n    43→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    44→\treturn &ClocheServer{\n    45→\t\tstore:     store,\n    46→\t\tcontainer: container,\n    47→\t\trunIDs:    make(map[string]string),\n    48→\t\tloops:     make(map[string]*host.Loop),\n    49→\t}\n    50→}\n    51→\n    52→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    53→\treturn &ClocheServer{\n    54→\t\tstore:        store,\n    55→\t\tcaptures:     captures,\n    56→\t\tcontainer:    container,\n    57→\t\tdefaultImage: defaultImage,\n    58→\t\trunIDs:       make(map[string]string),\n    59→\t\tloops:        make(map[string]*host.Loop),\n    60→\t}\n    61→}\n    62→\n    63→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    64→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    65→\ts.logStore = ls\n    66→}\n    67→\n    68→\n    69→// SetEvolution attaches an evolution trigger to the server.\n    70→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    71→\ts.evolution = trigger\n    72→}\n    73→\n    74→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    75→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    76→\ts.logBroadcast = b\n    77→}\n    78→\n    79→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    80→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    81→\ts.shutdownFn = fn\n    82→}\n    83→\n    84→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    85→\tif s.container == nil {\n    86→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    87→\t}\n    88→\n    89→\t// Generate a unique run ID, retrying on collision\n    90→\tvar runID string\n    91→\tfor attempts := 0; attempts < 10; attempts++ {\n    92→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    93→\t\texisting, err := s.store.GetRun(ctx, runID)\n    94→\t\tif err != nil {\n    95→\t\t\tbreak // ID is free\n    96→\t\t}\n    97→\t\t// Reuse if completed more than 1 hour ago\n    98→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n    99→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   100→\t\t\tbreak\n   101→\t\t}\n   102→\t}\n   103→\n   104→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   105→\tif req.Prompt != \"\" {\n   106→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   107→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   108→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   109→\t\t}\n   110→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   111→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   112→\t\t}\n   113→\t}\n   114→\trun := domain.NewRun(runID, req.WorkflowName)\n   115→\trun.ProjectDir = req.ProjectDir\n   116→\trun.Title = req.Title\n   117→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   118→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   119→\t}\n   120→\n   121→\t// Resolve image: request-level override, then server default\n   122→\timage := req.Image\n   123→\tif image == \"\" {\n   124→\t\timage = s.defaultImage\n   125→\t}\n   126→\n   127→\t// Launch container start + tracking in background so the RPC returns immediately.\n   128→\t// The run stays in \"pending\" state until the container is up.\n   129→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   130→\n   131→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   132→}\n   133→\n   134→// launchAndTrack starts the container and then tracks it to completion.\n   135→// It runs in a background goroutine with its own context, independent of the\n   136→// RPC context which may be cancelled after RunWorkflow returns.\n   137→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   138→\tctx := context.Background()\n   139→\n   140→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   141→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   142→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   143→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   144→\t\t\tif run != nil {\n   145→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   146→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   147→\t\t\t}\n   148→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   149→\t\t\t\treturn\n   150→\t\t}\n   151→\t}\n   152→\n   153→\tbaseSHA := gitHEAD(req.ProjectDir)\n   154→\n   155→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   156→\t\tImage:        image,\n   157→\t\tWorkflowName: req.WorkflowName,\n   158→\t\tProjectDir:   req.ProjectDir,\n   159→\t\tRunID:        runID,\n   160→\t\tNetworkAllow: []string{\"*\"},\n   161→\t})\n   162→\tif err != nil {\n   163→\t\trun, _ := s.store.GetRun(ctx, runID)\n   164→\t\tif run != nil {\n   165→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   166→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   167→\t\t}\n   168→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   169→\t\treturn\n   170→\t}\n   171→\n   172→\ts.mu.Lock()\n   173→\ts.runIDs[runID] = containerID\n   174→\ts.mu.Unlock()\n   175→\n   176→\trun, _ := s.store.GetRun(ctx, runID)\n   177→\tif run != nil {\n   178→\t\trun.Start()\n   179→\t\trun.ContainerID = containerID\n   180→\t\trun.BaseSHA = baseSHA\n   181→\t\t_ = s.store.UpdateRun(ctx, run)\n   182→\t}\n   183→\n   184→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   185→}\n   186→\n   187→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   188→\tctx := context.Background()\n   189→\n   190→\t// Attach to agent output\n   191→\treader, err := s.container.AttachOutput(ctx, containerID)\n   192→\tif err != nil {\n   193→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   194→\t\t\treturn\n   195→\t}\n   196→\n   197→\t// Parse JSON-lines status messages\n   198→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   199→\tscanner := bufio.NewScanner(reader)\n   200→\tfor scanner.Scan() {\n   201→\t\tvar msg protocol.StatusMessage\n   202→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   203→\t\t\tcontinue\n   204→\t\t}\n   205→\n   206→\t\t// Fast path: log messages don't need store interaction.\n   207→\t\tif msg.Type == protocol.MsgLog {\n   208→\t\t\tif s.logBroadcast != nil {\n   209→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   210→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   211→\t\t\t\t\tType:      \"llm\",\n   212→\t\t\t\t\tContent:   msg.Message,\n   213→\t\t\t\t\tStepName:  msg.StepName,\n   214→\t\t\t\t})\n   215→\t\t\t}\n   216→\t\t\tcontinue\n   217→\t\t}\n   218→\n   219→\t\trun, err := s.store.GetRun(ctx, runID)\n   220→\t\tif err != nil {\n   221→\t\t\tcontinue\n   222→\t\t}\n   223→\n   224→\t\tswitch msg.Type {\n   225→\t\tcase protocol.MsgStepStarted:\n   226→\t\t\trun.RecordStepStart(msg.StepName)\n   227→\t\t\tif s.captures != nil {\n   228→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   229→\t\t\t\t\tStepName:  msg.StepName,\n   230→\t\t\t\t\tStartedAt: msg.Timestamp,\n   231→\t\t\t\t})\n   232→\t\t\t}\n   233→\t\t\tif s.logBroadcast != nil {\n   234→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   235→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   236→\t\t\t\t\tType:      \"status\",\n   237→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   238→\t\t\t\t\tStepName:  msg.StepName,\n   239→\t\t\t\t})\n   240→\t\t\t}\n   241→\t\tcase protocol.MsgStepCompleted:\n   242→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   243→\t\t\tif s.captures != nil {\n   244→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   245→\t\t\t\t\tStepName:    msg.StepName,\n   246→\t\t\t\t\tResult:      msg.Result,\n   247→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   248→\t\t\t\t})\n   249→\t\t\t}\n   250→\t\t\tif s.logBroadcast != nil {\n   251→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   252→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   253→\t\t\t\t\tType:      \"status\",\n   254→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   255→\t\t\t\t\tStepName:  msg.StepName,\n   256→\t\t\t\t})\n   257→\t\t\t}\n   258→\t\tcase protocol.MsgRunTitle:\n   259→\t\t\tif run.Title == \"\" {\n   260→\t\t\t\trun.Title = msg.Message\n   261→\t\t\t}\n   262→\t\tcase protocol.MsgRunCompleted:\n   263→\t\t\treportedResult = msg.Result\n   264→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   265→\t\t}\n   266→\n   267→\t\t_ = s.store.UpdateRun(ctx, run)\n   268→\t}\n   269→\treader.Close()\n   270→\n   271→\t// Signal live-stream subscribers that this run is done.\n   272→\tif s.logBroadcast != nil {\n   273→\t\ts.logBroadcast.Finish(runID)\n   274→\t}\n   275→\n   276→\t// Wait for process exit\n   277→\texitCode, err := s.container.Wait(ctx, containerID)\n   278→\tif err != nil {\n   279→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   280→\t}\n   281→\n   282→\t// Extract step output files from container before it's removed\n   283→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   284→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   285→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   286→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   287→\t\t}\n   288→\t}\n   289→\n   290→\t// Capture full container stdout/stderr before the container is removed\n   291→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   292→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   293→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   294→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   295→\t\t}\n   296→\t}\n   297→\n   298→\t// Index extracted log files in the log store\n   299→\tif s.logStore != nil {\n   300→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   301→\t}\n   302→\n   303→\t// Extract results to git branch BEFORE finalizing state, so that\n   304→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   305→\t// before the run is marked complete.\n   306→\tresultLabel := reportedResult\n   307→\tif resultLabel == \"\" {\n   308→\t\tif exitCode == 0 {\n   309→\t\t\tresultLabel = \"succeeded\"\n   310→\t\t} else {\n   311→\t\t\tresultLabel = \"failed\"\n   312→\t\t}\n   313→\t}\n   314→\t{\n   315→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   316→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   317→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   318→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   319→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   320→\t\t\t} else {\n   321→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   322→\t\t\t}\n   323→\t\t} else {\n   324→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   325→\t\t}\n   326→\t}\n   327→\n   328→\t// Now finalize run state\n   329→\trun, err := s.store.GetRun(ctx, runID)\n   330→\tif err != nil {\n   331→\t\treturn\n   332→\t}\n   333→\tif run.State == domain.RunStateRunning {\n   334→\t\tif reportedResult == \"succeeded\" {\n   335→\t\t\trun.Complete(domain.RunStateSucceeded)\n   336→\t\t} else if reportedResult != \"\" {\n   337→\t\t\trun.Complete(domain.RunStateFailed)\n   338→\t\t} else if exitCode == 0 {\n   339→\t\t\trun.Complete(domain.RunStateSucceeded)\n   340→\t\t} else {\n   341→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   342→\t\t}\n   343→\t\t_ = s.store.UpdateRun(ctx, run)\n   344→\t}\n   345→\n   346→\t// Fire evolution trigger if configured\n   347→\tif s.evolution != nil {\n   348→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   349→\t}\n   350→\n   351→\t// Merge is handled as a workflow step in host.cloche, not here.\n   352→\n   353→\t// Container retention policy:\n   354→\t// - Failed runs: always keep the container for debugging\n   355→\t// - Successful runs + --keep-container: keep the container\n   356→\t// - Successful runs without --keep-container: remove the container\n   357→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   358→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   359→\n   360→\tif keepContainer || runFailed {\n   361→\t\treason := \"--keep-container\"\n   362→\t\tif runFailed {\n   363→\t\t\treason = \"run failed\"\n   364→\t\t}\n   365→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   366→\t\tif runFinal != nil {\n   367→\t\t\trunFinal.ContainerKept = true\n   368→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   369→\t\t}\n   370→\t} else {\n   371→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   372→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   373→\t\t} else {\n   374→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   375→\t\t}\n   376→\t}\n   377→\n   378→\t// Cleanup mapping\n   379→\ts.mu.Lock()\n   380→\tdelete(s.runIDs, runID)\n   381→\ts.mu.Unlock()\n   382→}\n   383→\n   384→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   385→\tvar since time.Time\n   386→\tif !req.All {\n   387→\t\tsince = time.Now().Add(-1 * time.Hour)\n   388→\t}\n   389→\truns, err := s.store.ListRuns(ctx, since)\n   390→\tif err != nil {\n   391→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   392→\t}\n   393→\n   394→\tresp := &pb.ListRunsResponse{}\n   395→\tfor _, run := range runs {\n   396→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   397→\t\t\tRunId:        run.ID,\n   398→\t\t\tWorkflowName: run.WorkflowName,\n   399→\t\t\tState:        string(run.State),\n   400→\t\t\tStartedAt:    run.StartedAt.String(),\n   401→\t\t\tErrorMessage: run.ErrorMessage,\n   402→\t\t\tContainerId:  run.ContainerID,\n   403→\t\t\tTitle:        run.Title,\n   404→\t\t\tIsHost:       run.IsHost,\n   405→\t\t})\n   406→\t}\n   407→\treturn resp, nil\n   408→}\n   409→\n   410→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   411→\trun, err := s.store.GetRun(ctx, req.RunId)\n   412→\tif err != nil {\n   413→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   414→\t}\n   415→\n   416→\tresp := &pb.GetStatusResponse{\n   417→\t\tRunId:        run.ID,\n   418→\t\tWorkflowName: run.WorkflowName,\n   419→\t\tState:        string(run.State),\n   420→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   421→\t\tErrorMessage: run.ErrorMessage,\n   422→\t\tContainerId:  run.ContainerID,\n   423→\t\tTitle:        run.Title,\n   424→\t\tIsHost:       run.IsHost,\n   425→\t}\n   426→\n   427→\t// Check container liveness\n   428→\tif run.ContainerID != \"\" && s.container != nil {\n   429→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   430→\t\t\tresp.ContainerAlive = cs.Running\n   431→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   432→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   433→\t\t\t}\n   434→\t\t}\n   435→\t}\n   436→\n   437→\t// Load step executions from captures store if available\n   438→\tif s.captures != nil {\n   439→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   440→\t\tif err == nil {\n   441→\t\t\tfor _, exec := range captures {\n   442→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   443→\t\t\t\t\tStepName:    exec.StepName,\n   444→\t\t\t\t\tResult:      exec.Result,\n   445→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   446→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   447→\t\t\t\t})\n   448→\t\t\t}\n   449→\t\t}\n   450→\t} else {\n   451→\t\tfor _, exec := range run.StepExecutions {\n   452→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   453→\t\t\t\tStepName:    exec.StepName,\n   454→\t\t\t\tResult:      exec.Result,\n   455→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   456→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   457→\t\t\t})\n   458→\t\t}\n   459→\t}\n   460→\n   461→\treturn resp, nil\n   462→}\n   463→\n   464→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   465→\tctx := stream.Context()\n   466→\n   467→\t// Verify run exists\n   468→\trun, err := s.store.GetRun(ctx, req.RunId)\n   469→\tif err != nil {\n   470→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   471→\t}\n   472→\n   473→\t// If step_name or log_type filter is set, serve content directly from the log index\n   474→\tif req.StepName != \"\" || req.LogType != \"\" {\n   475→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   476→\t}\n   477→\n   478→\t// For active runs, stream live from the broadcaster so callers can tail output.\n   479→\tif (run.State == domain.RunStateRunning || run.State == domain.RunStatePending) && s.logBroadcast != nil {\n   480→\t\treturn s.streamLiveLogs(req.RunId, stream)\n   481→\t}\n   482→\n   483→\tif s.captures == nil {\n   484→\t\treturn fmt.Errorf(\"captures store not configured\")\n   485→\t}\n   486→\n   487→\t// Check for full.log first — if it exists, serve it as the unified log\n   488→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   489→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   490→\t\tif err := stream.Send(&pb.LogEntry{\n   491→\t\t\tType:    \"full_log\",\n   492→\t\t\tMessage: string(data),\n   493→\t\t}); err != nil {\n   494→\t\t\treturn err\n   495→\t\t}\n   496→\t\t// Still send run completion entry\n   497→\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   498→\t\t\tif err := stream.Send(&pb.LogEntry{\n   499→\t\t\t\tType:      \"run_completed\",\n   500→\t\t\t\tResult:    string(run.State),\n   501→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   502→\t\t\t\tMessage:   run.ErrorMessage,\n   503→\t\t\t}); err != nil {\n   504→\t\t\t\treturn err\n   505→\t\t\t}\n   506→\t\t}\n   507→\t\treturn nil\n   508→\t}\n   509→\n   510→\t// Fall back to capture-based streaming\n   511→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   512→\tif err != nil {\n   513→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   514→\t}\n   515→\n   516→\tfor _, exec := range captures {\n   517→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   518→\t\t// and one for step_completed (has Result).\n   519→\t\tif exec.Result == \"\" {\n   520→\t\t\tentry := &pb.LogEntry{\n   521→\t\t\t\tType:      \"step_started\",\n   522→\t\t\t\tStepName:  exec.StepName,\n   523→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   524→\t\t\t}\n   525→\t\t\tif err := stream.Send(entry); err != nil {\n   526→\t\t\t\treturn err\n   527→\t\t\t}\n   528→\t\t} else {\n   529→\t\t\t// Read step output from per-step log file.\n   530→\t\t\t// Do NOT fall back to container.log — it contains unfiltered output\n   531→\t\t\t// from ALL steps and would show wrong content for this step.\n   532→\t\t\tvar output string\n   533→\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   534→\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   535→\t\t\t\toutput = string(data)\n   536→\t\t\t}\n   537→\t\t\tentry := &pb.LogEntry{\n   538→\t\t\t\tType:      \"step_completed\",\n   539→\t\t\t\tStepName:  exec.StepName,\n   540→\t\t\t\tResult:    exec.Result,\n   541→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   542→\t\t\t\tMessage:   output,\n   543→\t\t\t}\n   544→\t\t\tif err := stream.Send(entry); err != nil {\n   545→\t\t\t\treturn err\n   546→\t\t\t}\n   547→\t\t}\n   548→\t}\n   549→\n   550→\t// Send run completion entry\n   551→\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   552→\t\tif err := stream.Send(&pb.LogEntry{\n   553→\t\t\tType:      \"run_completed\",\n   554→\t\t\tResult:    string(run.State),\n   555→\t\t\tTimestamp: run.CompletedAt.String(),\n   556→\t\t\tMessage:   run.ErrorMessage,\n   557→\t\t}); err != nil {\n   558→\t\t\treturn err\n   559→\t\t}\n   560→\t}\n   561→\n   562→\treturn nil\n   563→}\n   564→\n   565→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   566→// It uses the log index when available, falling back to file path conventions.\n   567→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   568→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   569→\n   570→\t// Try log index first\n   571→\tif s.logStore != nil {\n   572→\t\tvar logFiles []*ports.LogFileEntry\n   573→\t\tvar err error\n   574→\n   575→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   576→\t\t\t// Filter by both step and type\n   577→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   578→\t\t\tif err == nil {\n   579→\t\t\t\tfiltered := logFiles[:0]\n   580→\t\t\t\tfor _, lf := range logFiles {\n   581→\t\t\t\t\tif lf.FileType == req.LogType {\n   582→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   583→\t\t\t\t\t}\n   584→\t\t\t\t}\n   585→\t\t\t\tlogFiles = filtered\n   586→\t\t\t}\n   587→\t\t} else if req.StepName != \"\" {\n   588→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   589→\t\t} else {\n   590→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   591→\t\t}\n   592→\n   593→\t\tif err == nil && len(logFiles) > 0 {\n   594→\t\t\tfor _, lf := range logFiles {\n   595→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   596→\t\t\t\tif readErr != nil {\n   597→\t\t\t\t\tcontinue\n   598→\t\t\t\t}\n   599→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   600→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   601→\t\t\t\t\tStepName: lf.StepName,\n   602→\t\t\t\t\tMessage:  string(data),\n   603→\t\t\t\t}); err != nil {\n   604→\t\t\t\t\treturn err\n   605→\t\t\t\t}\n   606→\t\t\t}\n   607→\t\t\treturn nil\n   608→\t\t}\n   609→\t}\n   610→\n   611→\t// Fall back to file path conventions\n   612→\tif req.StepName != \"\" {\n   613→\t\tvar logPath string\n   614→\t\tswitch req.LogType {\n   615→\t\tcase \"llm\":\n   616→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   617→\t\tdefault:\n   618→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   619→\t\t}\n   620→\n   621→\t\tdata, err := os.ReadFile(logPath)\n   622→\t\tif err != nil {\n   623→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   624→\t\t}\n   625→\t\treturn stream.Send(&pb.LogEntry{\n   626→\t\t\tType:     \"step_log\",\n   627→\t\t\tStepName: req.StepName,\n   628→\t\t\tMessage:  string(data),\n   629→\t\t})\n   630→\t}\n   631→\n   632→\treturn fmt.Errorf(\"no log files found matching filter\")\n   633→}\n   634→\n   635→// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n   636→// time for an active run. The stream closes when the run completes or the\n   637→// client disconnects.\n   638→func (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   639→\tsub := s.logBroadcast.Subscribe(runID)\n   640→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   641→\n   642→\tctx := stream.Context()\n   643→\tfor {\n   644→\t\tselect {\n   645→\t\tcase <-ctx.Done():\n   646→\t\t\treturn ctx.Err()\n   647→\t\tcase line, ok := <-sub.C:\n   648→\t\t\tif !ok {\n   649→\t\t\t\t// Run completed — send terminal entry.\n   650→\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   651→\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   652→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   653→\t\t\t\t\t\tType:      \"run_completed\",\n   654→\t\t\t\t\t\tResult:    string(run.State),\n   655→\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   656→\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   657→\t\t\t\t\t})\n   658→\t\t\t\t}\n   659→\t\t\t\treturn nil\n   660→\t\t\t}\n   661→\t\t\tif err := stream.Send(&pb.LogEntry{\n   662→\t\t\t\tType:      \"log\",\n   663→\t\t\t\tStepName:  line.StepName,\n   664→\t\t\t\tMessage:   line.Content,\n   665→\t\t\t\tTimestamp: line.Timestamp,\n   666→\t\t\t}); err != nil {\n   667→\t\t\t\treturn err\n   668→\t\t\t}\n   669→\t\t}\n   670→\t}\n   671→}\n   672→\n   673→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   674→\ts.mu.Lock()\n   675→\tcontainerID, ok := s.runIDs[req.RunId]\n   676→\ts.mu.Unlock()\n   677→\n   678→\tif !ok {\n   679→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   680→\t}\n   681→\n   682→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   683→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   684→\t}\n   685→\n   686→\t// Mark as cancelled in store\n   687→\trun, err := s.store.GetRun(ctx, req.RunId)\n   688→\tif err == nil {\n   689→\t\trun.Complete(domain.RunStateCancelled)\n   690→\t\t_ = s.store.UpdateRun(ctx, run)\n   691→\t}\n   692→\n   693→\treturn &pb.StopRunResponse{}, nil\n   694→}\n   695→\n   696→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   697→\tif s.container == nil {\n   698→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   699→\t}\n   700→\n   701→\tid := req.Id\n   702→\tif id == \"\" {\n   703→\t\treturn nil, fmt.Errorf(\"id is required\")\n   704→\t}\n   705→\n   706→\t// Try to resolve as a run ID first\n   707→\tcontainerID := id\n   708→\trun, err := s.store.GetRun(ctx, id)\n   709→\tif err == nil {\n   710→\t\t// It's a run ID — use the container ID from the run record\n   711→\t\tif run.ContainerID == \"\" {\n   712→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   713→\t\t}\n   714→\t\tcontainerID = run.ContainerID\n   715→\t}\n   716→\n   717→\t// Remove the container\n   718→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   719→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   720→\t}\n   721→\n   722→\t// If we resolved a run, clear the container_kept flag\n   723→\tif run != nil {\n   724→\t\trun.ContainerKept = false\n   725→\t\t_ = s.store.UpdateRun(ctx, run)\n   726→\t}\n   727→\n   728→\treturn &pb.DeleteContainerResponse{}, nil\n   729→}\n   730→\n   731→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   732→\tprojectDir := req.ProjectDir\n   733→\tif projectDir == \"\" {\n   734→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   735→\t}\n   736→\n   737→\t// Verify host.cloche exists\n   738→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   739→\tif _, err := os.Stat(hostPath); err != nil {\n   740→\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n   741→\t}\n   742→\n   743→\t// Load project config for defaults.\n   744→\tprojCfg, _ := config.Load(projectDir)\n   745→\n   746→\tmaxConc := int(req.MaxConcurrent)\n   747→\tif maxConc <= 0 {\n   748→\t\tmaxConc = projCfg.Orchestration.Concurrency\n   749→\t}\n   750→\tif maxConc <= 0 {\n   751→\t\tmaxConc = 1\n   752→\t}\n   753→\n   754→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   755→\n   756→\t// Compute dedup timeout from config (default 5 minutes).\n   757→\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n   758→\n   759→\ts.mu.Lock()\n   760→\tdefer s.mu.Unlock()\n   761→\n   762→\t// Stop existing loop if running.\n   763→\tif existing, ok := s.loops[projectDir]; ok {\n   764→\t\texisting.Stop()\n   765→\t}\n   766→\n   767→\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   768→\t\trunner := &host.Runner{\n   769→\t\t\tDispatcher: s,\n   770→\t\t\tStore:      s.store,\n   771→\t\t\tTaskID:     taskID,\n   772→\t\t}\n   773→\t\treturn runner.Run(ctx, projDir)\n   774→\t}\n   775→\n   776→\tloop := host.NewLoop(host.LoopConfig{\n   777→\t\tProjectDir:    projectDir,\n   778→\t\tMaxConcurrent: maxConc,\n   779→\t\tStaggerDelay:  stagger,\n   780→\t\tDedupTimeout:  dedupTimeout,\n   781→\t}, s.store, runFn)\n   782→\n   783→\t// Configure daemon-managed task assignment if a list-tasks command is set.\n   784→\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n   785→\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n   786→\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n   787→\t}\n   788→\n   789→\ts.loops[projectDir] = loop\n   790→\tloop.Start()\n   791→\n   792→\treturn &pb.EnableLoopResponse{}, nil\n   793→}\n   794→\n   795→func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n   796→\tprojectDir := req.ProjectDir\n   797→\tif projectDir == \"\" {\n   798→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   799→\t}\n   800→\n   801→\ts.mu.Lock()\n   802→\tdefer s.mu.Unlock()\n   803→\n   804→\tif loop, ok := s.loops[projectDir]; ok {\n   805→\t\tloop.Stop()\n   806→\t\tdelete(s.loops, projectDir)\n   807→\t}\n   808→\n   809→\treturn &pb.DisableLoopResponse{}, nil\n   810→}\n   811→\n   812→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n   813→\t// Stop all orchestration loops.\n   814→\ts.mu.Lock()\n   815→\tfor _, loop := range s.loops {\n   816→\t\tloop.Stop()\n   817→\t}\n   818→\ts.loops = make(map[string]*host.Loop)\n   819→\ts.mu.Unlock()\n   820→\n   821→\tif s.shutdownFn == nil {\n   822→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n   823→\t}\n   824→\tgo s.shutdownFn()\n   825→\treturn &pb.ShutdownResponse{}, nil\n   826→}\n   827→\n   828→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n   829→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n   830→\tentries, err := os.ReadDir(outputDir)\n   831→\tif err != nil {\n   832→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n   833→\t\treturn\n   834→\t}\n   835→\n   836→\tnow := time.Now()\n   837→\tfor _, entry := range entries {\n   838→\t\tif entry.IsDir() {\n   839→\t\t\tcontinue\n   840→\t\t}\n   841→\t\tname := entry.Name()\n   842→\t\tif !strings.HasSuffix(name, \".log\") {\n   843→\t\t\tcontinue\n   844→\t\t}\n   845→\n   846→\t\tvar fileType, stepName string\n   847→\t\tbase := strings.TrimSuffix(name, \".log\")\n   848→\n   849→\t\tswitch {\n   850→\t\tcase name == \"full.log\":\n   851→\t\t\tfileType = \"full\"\n   852→\t\tcase name == \"container.log\":\n   853→\t\t\t// container.log is internal, not indexed as a user-facing log type\n   854→\t\t\tcontinue\n   855→\t\tcase strings.HasPrefix(name, \"llm-\"):\n   856→\t\t\tfileType = \"llm\"\n   857→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n   858→\t\tdefault:\n   859→\t\t\tfileType = \"script\"\n   860→\t\t\tstepName = base\n   861→\t\t}\n   862→\n   863→\t\tinfo, _ := entry.Info()\n   864→\t\tvar fileSize int64\n   865→\t\tif info != nil {\n   866→\t\t\tfileSize = info.Size()\n   867→\t\t}\n   868→\n   869→\t\tlogEntry := &ports.LogFileEntry{\n   870→\t\t\tRunID:     runID,\n   871→\t\t\tStepName:  stepName,\n   872→\t\t\tFileType:  fileType,\n   873→\t\t\tFilePath:  filepath.Join(outputDir, name),\n   874→\t\t\tFileSize:  fileSize,\n   875→\t\t\tCreatedAt: now,\n   876→\t\t}\n   877→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n   878→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n   879→\t\t}\n   880→\t}\n   881→}\n   882→\n   883→func gitHEAD(dir string) string {\n   884→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n   885→\tcmd.Dir = dir\n   886→\tout, err := cmd.Output()\n   887→\tif err != nil {\n   888→\t\treturn \"\"\n   889→\t}\n   890→\treturn strings.TrimSpace(string(out))\n   891→}\n   892→"}]},"parent_tool_use_id":"toolu_012epjQe4jiFDSKQ49cH1EjH","session_id":"b83aa53c-b539-403e-957d-d27f065bd09c","uuid":"6196834a-ff7e-42f6-a332-9670fb909ed4"}
