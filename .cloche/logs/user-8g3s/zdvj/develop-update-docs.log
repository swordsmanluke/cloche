e. I'll focus on updating the reference docs instead and leave the design doc as-is.","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":5401,"cache_read_input_tokens":38248,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":5401},"output_tokens":10,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b83aa53c-b539-403e-957d-d27f065bd09c","uuid":"22c6891e-1f16-4668-8c61-b67e544140c8"}
