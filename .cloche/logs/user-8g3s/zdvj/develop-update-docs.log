{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kynj4kCYJQrYWBjQEpSctF","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"os\"\n     6→\t\"os/exec\"\n     7→\t\"path/filepath\"\n     8→\t\"testing\"\n     9→\t\"time\"\n    10→\n    11→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    14→\t\"github.com/stretchr/testify/assert\"\n    15→\t\"github.com/stretchr/testify/require\"\n    16→)\n    17→\n    18→// fakeDispatcher records dispatch calls and returns a predetermined run ID.\n    19→type fakeDispatcher struct {\n    20→\tcalls     []*pb.RunWorkflowRequest\n    21→\trunID     string\n    22→\treturnErr error\n    23→}\n    24→\n    25→func (f *fakeDispatcher) RunWorkflow(_ context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    26→\tf.calls = append(f.calls, req)\n    27→\tif f.returnErr != nil {\n    28→\t\treturn nil, f.returnErr\n    29→\t}\n    30→\treturn &pb.RunWorkflowResponse{RunId: f.runID}, nil\n    31→}\n    32→\n    33→// fakeStore returns a predetermined run on GetRun.\n    34→type fakeStore struct {\n    35→\truns map[string]*domain.Run\n    36→}\n    37→\n    38→func (f *fakeStore) CreateRun(_ context.Context, run *domain.Run) error {\n    39→\tf.runs[run.ID] = run\n    40→\treturn nil\n    41→}\n    42→func (f *fakeStore) GetRun(_ context.Context, id string) (*domain.Run, error) {\n    43→\tif r, ok := f.runs[id]; ok {\n    44→\t\treturn r, nil\n    45→\t}\n    46→\treturn nil, os.ErrNotExist\n    47→}\n    48→func (f *fakeStore) UpdateRun(_ context.Context, run *domain.Run) error {\n    49→\tf.runs[run.ID] = run\n    50→\treturn nil\n    51→}\n    52→func (f *fakeStore) DeleteRun(_ context.Context, id string) error {\n    53→\tdelete(f.runs, id)\n    54→\treturn nil\n    55→}\n    56→func (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n    57→\treturn nil, nil\n    58→}\n    59→func (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n    60→\treturn nil, nil\n    61→}\n    62→func (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n    63→\treturn nil, nil\n    64→}\n    65→func (f *fakeStore) ListChildRuns(_ context.Context, parentRunID string) ([]*domain.Run, error) {\n    66→\tvar children []*domain.Run\n    67→\tfor _, r := range f.runs {\n    68→\t\tif r.ParentRunID == parentRunID {\n    69→\t\t\tchildren = append(children, r)\n    70→\t\t}\n    71→\t}\n    72→\treturn children, nil\n    73→}\n    74→\n    75→func TestExecutor_ScriptStep_Success(t *testing.T) {\n    76→\ttmpDir := t.TempDir()\n    77→\toutputDir := filepath.Join(tmpDir, \"output\")\n    78→\n    79→\texecutor := &Executor{\n    80→\t\tProjectDir: tmpDir,\n    81→\t\tOutputDir:  outputDir,\n    82→\t}\n    83→\n    84→\tstep := &domain.Step{\n    85→\t\tName:    \"greet\",\n    86→\t\tType:    domain.StepTypeScript,\n    87→\t\tResults: []string{\"success\", \"fail\"},\n    88→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n    89→\t}\n    90→\n    91→\tresult, err := executor.Execute(context.Background(), step)\n    92→\trequire.NoError(t, err)\n    93→\tassert.Equal(t, \"success\", result)\n    94→\n    95→\t// Check output was written\n    96→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n    97→\trequire.NoError(t, err)\n    98→\tassert.Contains(t, string(data), \"hello\")\n    99→}\n   100→\n   101→func TestExecutor_ScriptStep_Failure(t *testing.T) {\n   102→\ttmpDir := t.TempDir()\n   103→\toutputDir := filepath.Join(tmpDir, \"output\")\n   104→\n   105→\texecutor := &Executor{\n   106→\t\tProjectDir: tmpDir,\n   107→\t\tOutputDir:  outputDir,\n   108→\t}\n   109→\n   110→\tstep := &domain.Step{\n   111→\t\tName:    \"bad\",\n   112→\t\tType:    domain.StepTypeScript,\n   113→\t\tResults: []string{\"success\", \"fail\"},\n   114→\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   115→\t}\n   116→\n   117→\tresult, err := executor.Execute(context.Background(), step)\n   118→\trequire.NoError(t, err)\n   119→\tassert.Equal(t, \"fail\", result)\n   120→}\n   121→\n   122→func TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n   123→\ttmpDir := t.TempDir()\n   124→\toutputDir := filepath.Join(tmpDir, \"output\")\n   125→\n   126→\texecutor := &Executor{\n   127→\t\tProjectDir: tmpDir,\n   128→\t\tOutputDir:  outputDir,\n   129→\t}\n   130→\n   131→\tstep := &domain.Step{\n   132→\t\tName:    \"marker\",\n   133→\t\tType:    domain.StepTypeScript,\n   134→\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n   135→\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n   136→\t}\n   137→\n   138→\tresult, err := executor.Execute(context.Background(), step)\n   139→\trequire.NoError(t, err)\n   140→\tassert.Equal(t, \"custom\", result)\n   141→\n   142→\t// Marker line should be stripped from output\n   143→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n   144→\trequire.NoError(t, err)\n   145→\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n   146→\tassert.Contains(t, string(data), \"some output\")\n   147→}\n   148→\n   149→func TestExecutor_WorkflowStep_Success(t *testing.T) {\n   150→\ttmpDir := t.TempDir()\n   151→\toutputDir := filepath.Join(tmpDir, \"output\")\n   152→\t_ = os.MkdirAll(outputDir, 0755)\n   153→\n   154→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   155→\t\t\"develop-test-run\": {\n   156→\t\t\tID:    \"develop-test-run\",\n   157→\t\t\tState: domain.RunStateSucceeded,\n   158→\t\t},\n   159→\t}}\n   160→\n   161→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   162→\n   163→\texecutor := &Executor{\n   164→\t\tProjectDir: tmpDir,\n   165→\t\tDispatcher: dispatcher,\n   166→\t\tStore:      store,\n   167→\t\tOutputDir:  outputDir,\n   168→\t}\n   169→\n   170→\tstep := &domain.Step{\n   171→\t\tName:    \"develop\",\n   172→\t\tType:    domain.StepTypeWorkflow,\n   173→\t\tResults: []string{\"success\", \"fail\"},\n   174→\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   175→\t}\n   176→\n   177→\tresult, err := executor.Execute(context.Background(), step)\n   178→\trequire.NoError(t, err)\n   179→\tassert.Equal(t, \"success\", result)\n   180→\tassert.Len(t, dispatcher.calls, 1)\n   181→\tassert.Equal(t, \"develop\", dispatcher.calls[0].WorkflowName)\n   182→\tassert.Equal(t, tmpDir, dispatcher.calls[0].ProjectDir)\n   183→}\n   184→\n   185→func TestExecutor_WorkflowStep_Failure(t *testing.T) {\n   186→\ttmpDir := t.TempDir()\n   187→\toutputDir := filepath.Join(tmpDir, \"output\")\n   188→\t_ = os.MkdirAll(outputDir, 0755)\n   189→\n   190→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   191→\t\t\"develop-test-run\": {\n   192→\t\t\tID:    \"develop-test-run\",\n   193→\t\t\tState: domain.RunStateFailed,\n   194→\t\t},\n   195→\t}}\n   196→\n   197→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   198→\n   199→\texecutor := &Executor{\n   200→\t\tProjectDir: tmpDir,\n   201→\t\tDispatcher: dispatcher,\n   202→\t\tStore:      store,\n   203→\t\tOutputDir:  outputDir,\n   204→\t}\n   205→\n   206→\tstep := &domain.Step{\n   207→\t\tName:    \"develop\",\n   208→\t\tType:    domain.StepTypeWorkflow,\n   209→\t\tResults: []string{\"success\", \"fail\"},\n   210→\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   211→\t}\n   212→\n   213→\tresult, err := executor.Execute(context.Background(), step)\n   214→\trequire.NoError(t, err)\n   215→\tassert.Equal(t, \"fail\", result)\n   216→}\n   217→\n   218→func TestExecutor_WorkflowStep_PassesPrompt(t *testing.T) {\n   219→\ttmpDir := t.TempDir()\n   220→\toutputDir := filepath.Join(tmpDir, \"output\")\n   221→\t_ = os.MkdirAll(outputDir, 0755)\n   222→\n   223→\t// Write a previous step's output\n   224→\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n   225→\n   226→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   227→\t\t\"develop-test-run\": {\n   228→\t\t\tID:    \"develop-test-run\",\n   229→\t\t\tState: domain.RunStateSucceeded,\n   230→\t\t},\n   231→\t}}\n   232→\n   233→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   234→\n   235→\texecutor := &Executor{\n   236→\t\tProjectDir: tmpDir,\n   237→\t\tDispatcher: dispatcher,\n   238→\t\tStore:      store,\n   239→\t\tOutputDir:  outputDir,\n   240→\t}\n   241→\n   242→\tstep := &domain.Step{\n   243→\t\tName:    \"develop\",\n   244→\t\tType:    domain.StepTypeWorkflow,\n   245→\t\tResults: []string{\"success\", \"fail\"},\n   246→\t\tConfig: map[string]string{\n   247→\t\t\t\"workflow_name\": \"develop\",\n   248→\t\t\t\"prompt_step\":   \"prepare-prompt\",\n   249→\t\t},\n   250→\t}\n   251→\n   252→\tresult, err := executor.Execute(context.Background(), step)\n   253→\trequire.NoError(t, err)\n   254→\tassert.Equal(t, \"success\", result)\n   255→\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n   256→}\n   257→\n   258→func TestEngine_HostWorkflow_Linear(t *testing.T) {\n   259→\ttmpDir := t.TempDir()\n   260→\toutputDir := filepath.Join(tmpDir, \"output\")\n   261→\n   262→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   263→\t\t\"develop-test-run\": {\n   264→\t\t\tID:    \"develop-test-run\",\n   265→\t\t\tState: domain.RunStateSucceeded,\n   266→\t\t},\n   267→\t}}\n   268→\n   269→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   270→\n   271→\texecutor := &Executor{\n   272→\t\tProjectDir: tmpDir,\n   273→\t\tDispatcher: dispatcher,\n   274→\t\tStore:      store,\n   275→\t\tOutputDir:  outputDir,\n   276→\t}\n   277→\n   278→\twf := &domain.Workflow{\n   279→\t\tName: \"main\",\n   280→\t\tSteps: map[string]*domain.Step{\n   281→\t\t\t\"prepare\": {\n   282→\t\t\t\tName:    \"prepare\",\n   283→\t\t\t\tType:    domain.StepTypeScript,\n   284→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   285→\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n   286→\t\t\t},\n   287→\t\t\t\"develop\": {\n   288→\t\t\t\tName:    \"develop\",\n   289→\t\t\t\tType:    domain.StepTypeWorkflow,\n   290→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   291→\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   292→\t\t\t},\n   293→\t\t\t\"merge\": {\n   294→\t\t\t\tName:    \"merge\",\n   295→\t\t\t\tType:    domain.StepTypeScript,\n   296→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   297→\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n   298→\t\t\t},\n   299→\t\t},\n   300→\t\tWiring: []domain.Wire{\n   301→\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   302→\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   303→\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n   304→\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   305→\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n   306→\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n   307→\t\t},\n   308→\t\tEntryStep: \"prepare\",\n   309→\t}\n   310→\n   311→\teng := engine.New(executor)\n   312→\trun, err := eng.Run(context.Background(), wf)\n   313→\trequire.NoError(t, err)\n   314→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   315→\tassert.Len(t, dispatcher.calls, 1)\n   316→}\n   317→\n   318→func TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n   319→\ttmpDir := t.TempDir()\n   320→\toutputDir := filepath.Join(tmpDir, \"output\")\n   321→\n   322→\texecutor := &Executor{\n   323→\t\tProjectDir: tmpDir,\n   324→\t\tOutputDir:  outputDir,\n   325→\t}\n   326→\n   327→\twf := &domain.Workflow{\n   328→\t\tName: \"main\",\n   329→\t\tSteps: map[string]*domain.Step{\n   330→\t\t\t\"prepare\": {\n   331→\t\t\t\tName:    \"prepare\",\n   332→\t\t\t\tType:    domain.StepTypeScript,\n   333→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   334→\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   335→\t\t\t},\n   336→\t\t\t\"develop\": {\n   337→\t\t\t\tName:    \"develop\",\n   338→\t\t\t\tType:    domain.StepTypeWorkflow,\n   339→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   340→\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   341→\t\t\t},\n   342→\t\t},\n   343→\t\tWiring: []domain.Wire{\n   344→\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   345→\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   346→\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n   347→\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   348→\t\t},\n   349→\t\tEntryStep: \"prepare\",\n   350→\t}\n   351→\n   352→\teng := engine.New(executor)\n   353→\trun, err := eng.Run(context.Background(), wf)\n   354→\trequire.NoError(t, err)\n   355→\tassert.Equal(t, domain.RunStateFailed, run.State)\n   356→}\n   357→\n   358→func TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n   359→\ttmpDir := t.TempDir()\n   360→\toutputDir := filepath.Join(tmpDir, \"output\")\n   361→\n   362→\texecutor := &Executor{\n   363→\t\tProjectDir: tmpDir,\n   364→\t\tOutputDir:  outputDir,\n   365→\t}\n   366→\n   367→\tstep := &domain.Step{\n   368→\t\tName:    \"env-check\",\n   369→\t\tType:    domain.StepTypeScript,\n   370→\t\tResults: []string{\"success\", \"fail\"},\n   371→\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n   372→\t}\n   373→\n   374→\tresult, err := executor.Execute(context.Background(), step)\n   375→\trequire.NoError(t, err)\n   376→\tassert.Equal(t, \"success\", result)\n   377→\n   378→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n   379→\trequire.NoError(t, err)\n   380→\tassert.Contains(t, string(data), tmpDir)\n   381→}\n   382→\n   383→func TestExecutor_ScriptStep_TaskIDEnvVar(t *testing.T) {\n   384→\ttmpDir := t.TempDir()\n   385→\toutputDir := filepath.Join(tmpDir, \"output\")\n   386→\n   387→\texecutor := &Executor{\n   388→\t\tProjectDir: tmpDir,\n   389→\t\tOutputDir:  outputDir,\n   390→\t\tTaskID:     \"my-task-42\",\n   391→\t}\n   392→\n   393→\tstep := &domain.Step{\n   394→\t\tName:    \"task-check\",\n   395→\t\tType:    domain.StepTypeScript,\n   396→\t\tResults: []string{\"success\", \"fail\"},\n   397→\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_TASK_ID\"},\n   398→\t}\n   399→\n   400→\tresult, err := executor.Execute(context.Background(), step)\n   401→\trequire.NoError(t, err)\n   402→\tassert.Equal(t, \"success\", result)\n   403→\n   404→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"task-check.out\"))\n   405→\trequire.NoError(t, err)\n   406→\tassert.Contains(t, string(data), \"my-task-42\")\n   407→}\n   408→\n   409→func TestExecutor_ScriptStep_NoTaskID(t *testing.T) {\n   410→\ttmpDir := t.TempDir()\n   411→\toutputDir := filepath.Join(tmpDir, \"output\")\n   412→\n   413→\texecutor := &Executor{\n   414→\t\tProjectDir: tmpDir,\n   415→\t\tOutputDir:  outputDir,\n   416→\t\t// No TaskID set\n   417→\t}\n   418→\n   419→\tstep := &domain.Step{\n   420→\t\tName:    \"task-check\",\n   421→\t\tType:    domain.StepTypeScript,\n   422→\t\tResults: []string{\"success\", \"fail\"},\n   423→\t\tConfig:  map[string]string{\"run\": \"echo \\\"TASK_ID=$CLOCHE_TASK_ID\\\"\"},\n   424→\t}\n   425→\n   426→\tresult, err := executor.Execute(context.Background(), step)\n   427→\trequire.NoError(t, err)\n   428→\tassert.Equal(t, \"success\", result)\n   429→\n   430→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"task-check.out\"))\n   431→\trequire.NoError(t, err)\n   432→\t// When no TaskID is set, CLOCHE_TASK_ID should not appear in the env\n   433→\tassert.Contains(t, string(data), \"TASK_ID=\\n\")\n   434→}\n   435→\n   436→func TestExecutor_ScriptStep_NoOutputMappings(t *testing.T) {\n   437→\ttmpDir := t.TempDir()\n   438→\toutputDir := filepath.Join(tmpDir, \"output\")\n   439→\n   440→\texecutor := &Executor{\n   441→\t\tProjectDir: tmpDir,\n   442→\t\tOutputDir:  outputDir,\n   443→\t\tWires: []domain.Wire{\n   444→\t\t\t{From: \"step-a\", Result: \"success\", To: \"step-b\"},\n   445→\t\t},\n   446→\t}\n   447→\n   448→\tstep := &domain.Step{\n   449→\t\tName:    \"step-b\",\n   450→\t\tType:    domain.StepTypeScript,\n   451→\t\tResults: []string{\"success\", \"fail\"},\n   452→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   453→\t}\n   454→\n   455→\tresult, err := executor.Execute(context.Background(), step)\n   456→\trequire.NoError(t, err)\n   457→\tassert.Equal(t, \"success\", result)\n   458→}\n   459→\n   460→func TestExecutor_ScriptStep_OutputMappings_JSONFields(t *testing.T) {\n   461→\ttmpDir := t.TempDir()\n   462→\toutputDir := filepath.Join(tmpDir, \"output\")\n   463→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   464→\n   465→\t// Write source step output as JSON\n   466→\tsourceJSON := `{\"title\": \"Fix bug\", \"priority\": \"high\"}`\n   467→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"get-tasks.out\"), []byte(sourceJSON), 0644))\n   468→\n   469→\texecutor := &Executor{\n   470→\t\tProjectDir: tmpDir,\n   471→\t\tOutputDir:  outputDir,\n   472→\t\tWires: []domain.Wire{\n   473→\t\t\t{\n   474→\t\t\t\tFrom:   \"get-tasks\",\n   475→\t\t\t\tResult: \"success\",\n   476→\t\t\t\tTo:     \"use-tasks\",\n   477→\t\t\t\tOutputMap: []domain.OutputMapping{\n   478→\t\t\t\t\t{\n   479→\t\t\t\t\t\tEnvVar: \"TASK_TITLE\",\n   480→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"title\"}}},\n   481→\t\t\t\t\t},\n   482→\t\t\t\t\t{\n   483→\t\t\t\t\t\tEnvVar: \"TASK_PRIORITY\",\n   484→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"priority\"}}},\n   485→\t\t\t\t\t},\n   486→\t\t\t\t},\n   487→\t\t\t},\n   488→\t\t},\n   489→\t}\n   490→\n   491→\tstep := &domain.Step{\n   492→\t\tName:    \"use-tasks\",\n   493→\t\tType:    domain.StepTypeScript,\n   494→\t\tResults: []string{\"success\", \"fail\"},\n   495→\t\tConfig:  map[string]string{\"run\": \"echo $TASK_TITLE $TASK_PRIORITY\"},\n   496→\t}\n   497→\n   498→\tresult, err := executor.Execute(context.Background(), step)\n   499→\trequire.NoError(t, err)\n   500→\tassert.Equal(t, \"success\", result)\n   501→\n   502→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"use-tasks.out\"))\n   503→\trequire.NoError(t, err)\n   504→\tassert.Contains(t, string(data), \"Fix bug\")\n   505→\tassert.Contains(t, string(data), \"high\")\n   506→}\n   507→\n   508→func TestExecutor_ScriptStep_OutputMappings_ArrayIndex(t *testing.T) {\n   509→\ttmpDir := t.TempDir()\n   510→\toutputDir := filepath.Join(tmpDir, \"output\")\n   511→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   512→\n   513→\t// Write source step output as JSON array\n   514→\tsourceJSON := `[{\"id\": \"task-1\", \"title\": \"First\"}, {\"id\": \"task-2\", \"title\": \"Second\"}]`\n   515→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"list-tasks.out\"), []byte(sourceJSON), 0644))\n   516→\n   517→\texecutor := &Executor{\n   518→\t\tProjectDir: tmpDir,\n   519→\t\tOutputDir:  outputDir,\n   520→\t\tWires: []domain.Wire{\n   521→\t\t\t{\n   522→\t\t\t\tFrom:   \"list-tasks\",\n   523→\t\t\t\tResult: \"success\",\n   524→\t\t\t\tTo:     \"process\",\n   525→\t\t\t\tOutputMap: []domain.OutputMapping{\n   526→\t\t\t\t\t{\n   527→\t\t\t\t\t\tEnvVar: \"FIRST_ID\",\n   528→\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n   529→\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 0},\n   530→\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"id\"},\n   531→\t\t\t\t\t\t}},\n   532→\t\t\t\t\t},\n   533→\t\t\t\t\t{\n   534→\t\t\t\t\t\tEnvVar: \"SECOND_TITLE\",\n   535→\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n   536→\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 1},\n   537→\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"title\"},\n   538→\t\t\t\t\t\t}},\n   539→\t\t\t\t\t},\n   540→\t\t\t\t},\n   541→\t\t\t},\n   542→\t\t},\n   543→\t}\n   544→\n   545→\tstep := &domain.Step{\n   546→\t\tName:    \"process\",\n   547→\t\tType:    domain.StepTypeScript,\n   548→\t\tResults: []string{\"success\", \"fail\"},\n   549→\t\tConfig:  map[string]string{\"run\": \"echo $FIRST_ID $SECOND_TITLE\"},\n   550→\t}\n   551→\n   552→\tresult, err := executor.Execute(context.Background(), step)\n   553→\trequire.NoError(t, err)\n   554→\tassert.Equal(t, \"success\", result)\n   555→\n   556→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"process.out\"))\n   557→\trequire.NoError(t, err)\n   558→\tassert.Contains(t, string(data), \"task-1\")\n   559→\tassert.Contains(t, string(data), \"Second\")\n   560→}\n   561→\n   562→func TestExecutor_ScriptStep_OutputMappings_MissingSourceOutput(t *testing.T) {\n   563→\ttmpDir := t.TempDir()\n   564→\toutputDir := filepath.Join(tmpDir, \"output\")\n   565→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   566→\n   567→\t// No source output file written\n   568→\n   569→\texecutor := &Executor{\n   570→\t\tProjectDir: tmpDir,\n   571→\t\tOutputDir:  outputDir,\n   572→\t\tWires: []domain.Wire{\n   573→\t\t\t{\n   574→\t\t\t\tFrom:   \"missing-step\",\n   575→\t\t\t\tResult: \"success\",\n   576→\t\t\t\tTo:     \"consumer\",\n   577→\t\t\t\tOutputMap: []domain.OutputMapping{\n   578→\t\t\t\t\t{\n   579→\t\t\t\t\t\tEnvVar: \"VAL\",\n   580→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n   581→\t\t\t\t\t},\n   582→\t\t\t\t},\n   583→\t\t\t},\n   584→\t\t},\n   585→\t}\n   586→\n   587→\tstep := &domain.Step{\n   588→\t\tName:    \"consumer\",\n   589→\t\tType:    domain.StepTypeScript,\n   590→\t\tResults: []string{\"success\", \"fail\"},\n   591→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   592→\t}\n   593→\n   594→\t_, err := executor.Execute(context.Background(), step)\n   595→\trequire.Error(t, err)\n   596→\tassert.Contains(t, err.Error(), \"reading output of missing-step\")\n   597→}\n   598→\n   599→func TestExecutor_ScriptStep_OutputMappings_NotJSON(t *testing.T) {\n   600→\ttmpDir := t.TempDir()\n   601→\toutputDir := filepath.Join(tmpDir, \"output\")\n   602→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   603→\n   604→\t// Write non-JSON output\n   605→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"plain.out\"), []byte(\"not json\"), 0644))\n   606→\n   607→\texecutor := &Executor{\n   608→\t\tProjectDir: tmpDir,\n   609→\t\tOutputDir:  outputDir,\n   610→\t\tWires: []domain.Wire{\n   611→\t\t\t{\n   612→\t\t\t\tFrom:   \"plain\",\n   613→\t\t\t\tResult: \"success\",\n   614→\t\t\t\tTo:     \"consumer\",\n   615→\t\t\t\tOutputMap: []domain.OutputMapping{\n   616→\t\t\t\t\t{\n   617→\t\t\t\t\t\tEnvVar: \"VAL\",\n   618→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n   619→\t\t\t\t\t},\n   620→\t\t\t\t},\n   621→\t\t\t},\n   622→\t\t},\n   623→\t}\n   624→\n   625→\tstep := &domain.Step{\n   626→\t\tName:    \"consumer\",\n   627→\t\tType:    domain.StepTypeScript,\n   628→\t\tResults: []string{\"success\", \"fail\"},\n   629→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   630→\t}\n   631→\n   632→\t_, err := executor.Execute(context.Background(), step)\n   633→\trequire.Error(t, err)\n   634→\tassert.Contains(t, err.Error(), \"not valid JSON\")\n   635→}\n   636→\n   637→func TestRunner_RunWithID(t *testing.T) {\n   638→\ttmpDir := t.TempDir()\n   639→\n   640→\t// Write a simple host.cloche\n   641→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   642→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   643→\thostCloche := `workflow \"main\" {\n   644→  step greet {\n   645→    run     = \"echo hi\"\n   646→    results = [success, fail]\n   647→  }\n   648→\n   649→  greet:success -> done\n   650→  greet:fail    -> abort\n   651→}`\n   652→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   653→\n   654→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   655→\n   656→\trunner := &Runner{\n   657→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   658→\t\tStore:      store,\n   659→\t}\n   660→\n   661→\tcustomID := \"my-custom-run-id\"\n   662→\tresult, err := runner.RunWithID(context.Background(), tmpDir, customID)\n   663→\trequire.NoError(t, err)\n   664→\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n   665→\tassert.Equal(t, customID, result.RunID, \"RunWithID should use the provided ID\")\n   666→\n   667→\t// Verify the run was persisted with the custom ID\n   668→\thostRun, err := store.GetRun(context.Background(), customID)\n   669→\trequire.NoError(t, err)\n   670→\tassert.True(t, hostRun.IsHost)\n   671→\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n   672→}\n   673→\n   674→func TestRunner_WithTaskID(t *testing.T) {\n   675→\ttmpDir := t.TempDir()\n   676→\n   677→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   678→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   679→\t// The script echoes the daemon-assigned CLOCHE_TASK_ID env var\n   680→\thostCloche := `workflow \"main\" {\n   681→  step check-task {\n   682→    run     = \"echo $CLOCHE_TASK_ID\"\n   683→    results = [success, fail]\n   684→  }\n   685→\n   686→  check-task:success -> done\n   687→  check-task:fail    -> abort\n   688→}`\n   689→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   690→\n   691→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   692→\n   693→\trunner := &Runner{\n   694→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   695→\t\tStore:      store,\n   696→\t\tTaskID:     \"daemon-assigned-task-99\",\n   697→\t}\n   698→\n   699→\tresult, err := runner.Run(context.Background(), tmpDir)\n   700→\trequire.NoError(t, err)\n   701→\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n   702→\n   703→\t// Verify the script saw the task ID\n   704→\toutputDir := filepath.Join(tmpDir, \".cloche\", result.RunID, \"output\")\n   705→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"check-task.out\"))\n   706→\trequire.NoError(t, err)\n   707→\tassert.Contains(t, string(data), \"daemon-assigned-task-99\")\n   708→}\n   709→\n   710→func TestRunner_PersistsHostRun(t *testing.T) {\n   711→\ttmpDir := t.TempDir()\n   712→\n   713→\t// Write a simple host.cloche\n   714→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   715→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   716→\thostCloche := `workflow \"main\" {\n   717→  step prepare {\n   718→    run     = \"echo prepared\"\n   719→    results = [success, fail]\n   720→  }\n   721→\n   722→  prepare:success -> done\n   723→  prepare:fail    -> abort\n   724→}`\n   725→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   726→\n   727→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   728→\n   729→\trunner := &Runner{\n   730→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   731→\t\tStore:      store,\n   732→\t}\n   733→\n   734→\tresult, err := runner.Run(context.Background(), tmpDir)\n   735→\trequire.NoError(t, err)\n   736→\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n   737→\tassert.NotEmpty(t, result.RunID)\n   738→\n   739→\t// Verify the host run was persisted in the store\n   740→\thostRun, err := store.GetRun(context.Background(), result.RunID)\n   741→\trequire.NoError(t, err)\n   742→\tassert.True(t, hostRun.IsHost, \"host run should have IsHost=true\")\n   743→\tassert.Equal(t, tmpDir, hostRun.ProjectDir)\n   744→\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n   745→\tassert.False(t, hostRun.StartedAt.IsZero())\n   746→\tassert.False(t, hostRun.CompletedAt.IsZero())\n   747→}\n   748→\n   749→func TestExecutor_ScriptStep_UsesMainDir(t *testing.T) {\n   750→\t// ProjectDir has no script; MainDir has the script.\n   751→\tprojectDir := t.TempDir()\n   752→\tmainDir := t.TempDir()\n   753→\toutputDir := filepath.Join(projectDir, \"output\")\n   754→\n   755→\t// Create a script only in mainDir\n   756→\tscriptDir := filepath.Join(mainDir, \".cloche\", \"scripts\")\n   757→\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n   758→\trequire.NoError(t, os.WriteFile(\n   759→\t\tfilepath.Join(scriptDir, \"greet.sh\"),\n   760→\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n   761→\t\t0755,\n   762→\t))\n   763→\n   764→\texecutor := &Executor{\n   765→\t\tProjectDir: projectDir,\n   766→\t\tMainDir:    mainDir,\n   767→\t\tOutputDir:  outputDir,\n   768→\t}\n   769→\n   770→\tstep := &domain.Step{\n   771→\t\tName:    \"greet\",\n   772→\t\tType:    domain.StepTypeScript,\n   773→\t\tResults: []string{\"success\", \"fail\"},\n   774→\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/greet.sh\"},\n   775→\t}\n   776→\n   777→\tresult, err := executor.Execute(context.Background(), step)\n   778→\trequire.NoError(t, err)\n   779→\tassert.Equal(t, \"success\", result)\n   780→\n   781→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n   782→\trequire.NoError(t, err)\n   783→\tassert.Contains(t, string(data), \"from-main\")\n   784→}\n   785→\n   786→func TestExecutor_ScriptStep_MainDirOverridesProjectDir(t *testing.T) {\n   787→\t// Both dirs have a script with different content; MainDir's version wins.\n   788→\tprojectDir := t.TempDir()\n   789→\tmainDir := t.TempDir()\n   790→\toutputDir := filepath.Join(projectDir, \"output\")\n   791→\n   792→\t// Create script in both dirs with different content\n   793→\tfor _, dir := range []string{projectDir, mainDir} {\n   794→\t\tscriptDir := filepath.Join(dir, \".cloche\", \"scripts\")\n   795→\t\trequire.NoError(t, os.MkdirAll(scriptDir, 0755))\n   796→\t}\n   797→\trequire.NoError(t, os.WriteFile(\n   798→\t\tfilepath.Join(projectDir, \".cloche\", \"scripts\", \"hello.sh\"),\n   799→\t\t[]byte(\"#!/bin/sh\\necho from-branch\"),\n   800→\t\t0755,\n   801→\t))\n   802→\trequire.NoError(t, os.WriteFile(\n   803→\t\tfilepath.Join(mainDir, \".cloche\", \"scripts\", \"hello.sh\"),\n   804→\t\t[]byte(\"#!/bin/sh\\necho from-main\"),\n   805→\t\t0755,\n   806→\t))\n   807→\n   808→\texecutor := &Executor{\n   809→\t\tProjectDir: projectDir,\n   810→\t\tMainDir:    mainDir,\n   811→\t\tOutputDir:  outputDir,\n   812→\t}\n   813→\n   814→\tstep := &domain.Step{\n   815→\t\tName:    \"hello\",\n   816→\t\tType:    domain.StepTypeScript,\n   817→\t\tResults: []string{\"success\", \"fail\"},\n   818→\t\tConfig:  map[string]string{\"run\": \"bash .cloche/scripts/hello.sh\"},\n   819→\t}\n   820→\n   821→\tresult, err := executor.Execute(context.Background(), step)\n   822→\trequire.NoError(t, err)\n   823→\tassert.Equal(t, \"success\", result)\n   824→\n   825→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"hello.out\"))\n   826→\trequire.NoError(t, err)\n   827→\tassert.Contains(t, string(data), \"from-main\")\n   828→\tassert.NotContains(t, string(data), \"from-branch\")\n   829→}\n   830→\n   831→func TestExecutor_ScriptStep_FallsBackToProjectDir(t *testing.T) {\n   832→\t// When MainDir is empty, scripts resolve from ProjectDir.\n   833→\tprojectDir := t.TempDir()\n   834→\toutputDir := filepath.Join(projectDir, \"output\")\n   835→\n   836→\texecutor := &Executor{\n   837→\t\tProjectDir: projectDir,\n   838→\t\tOutputDir:  outputDir,\n   839→\t}\n   840→\n   841→\tstep := &domain.Step{\n   842→\t\tName:    \"pwd-check\",\n   843→\t\tType:    domain.StepTypeScript,\n   844→\t\tResults: []string{\"success\", \"fail\"},\n   845→\t\tConfig:  map[string]string{\"run\": \"pwd\"},\n   846→\t}\n   847→\n   848→\tresult, err := executor.Execute(context.Background(), step)\n   849→\trequire.NoError(t, err)\n   850→\tassert.Equal(t, \"success\", result)\n   851→\n   852→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"pwd-check.out\"))\n   853→\trequire.NoError(t, err)\n   854→\tassert.Contains(t, string(data), projectDir)\n   855→}\n   856→\n   857→func TestExecutor_ScriptStep_ProjectDirEnvVar(t *testing.T) {\n   858→\t// CLOCHE_PROJECT_DIR should always point to ProjectDir, not MainDir.\n   859→\tprojectDir := t.TempDir()\n   860→\tmainDir := t.TempDir()\n   861→\toutputDir := filepath.Join(projectDir, \"output\")\n   862→\n   863→\texecutor := &Executor{\n   864→\t\tProjectDir: projectDir,\n   865→\t\tMainDir:    mainDir,\n   866→\t\tOutputDir:  outputDir,\n   867→\t}\n   868→\n   869→\tstep := &domain.Step{\n   870→\t\tName:    \"env-check\",\n   871→\t\tType:    domain.StepTypeScript,\n   872→\t\tResults: []string{\"success\", \"fail\"},\n   873→\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n   874→\t}\n   875→\n   876→\tresult, err := executor.Execute(context.Background(), step)\n   877→\trequire.NoError(t, err)\n   878→\tassert.Equal(t, \"success\", result)\n   879→\n   880→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n   881→\trequire.NoError(t, err)\n   882→\tassert.Contains(t, string(data), projectDir)\n   883→\tassert.NotContains(t, string(data), mainDir)\n   884→}\n   885→\n   886→func TestMainWorktreeDir_NonGitDir(t *testing.T) {\n   887→\ttmpDir := t.TempDir()\n   888→\t// Non-git directory should fall back to projectDir.\n   889→\tresult := MainWorktreeDir(tmpDir)\n   890→\tassert.Equal(t, tmpDir, result)\n   891→}\n   892→\n   893→func TestMainWorktreeDir_WithWorktree(t *testing.T) {\n   894→\t// Set up a real git repo with a linked worktree.\n   895→\tmainDir := t.TempDir()\n   896→\n   897→\t// Initialize git repo\n   898→\trun := func(dir string, args ...string) {\n   899→\t\tt.Helper()\n   900→\t\tcmd := exec.Command(args[0], args[1:]...)\n   901→\t\tcmd.Dir = dir\n   902→\t\tout, err := cmd.CombinedOutput()\n   903→\t\trequire.NoError(t, err, \"command %v failed: %s\", args, out)\n   904→\t}\n   905→\n   906→\trun(mainDir, \"git\", \"init\")\n   907→\trun(mainDir, \"git\", \"config\", \"user.email\", \"test@test.com\")\n   908→\trun(mainDir, \"git\", \"config\", \"user.name\", \"Test\")\n   909→\trequire.NoError(t, os.WriteFile(filepath.Join(mainDir, \"file.txt\"), []byte(\"hello\"), 0644))\n   910→\trun(mainDir, \"git\", \"add\", \".\")\n   911→\trun(mainDir, \"git\", \"commit\", \"-m\", \"initial\")\n   912→\n   913→\t// Create a branch and worktree\n   914→\tworktreeDir := filepath.Join(t.TempDir(), \"wt\")\n   915→\trun(mainDir, \"git\", \"worktree\", \"add\", worktreeDir, \"-b\", \"feature\")\n   916→\n   917→\t// MainWorktreeDir from the linked worktree should return mainDir.\n   918→\tresult := MainWorktreeDir(worktreeDir)\n   919→\tassert.Equal(t, mainDir, result)\n   920→\n   921→\t// MainWorktreeDir from main should return mainDir.\n   922→\tresult = MainWorktreeDir(mainDir)\n   923→\tassert.Equal(t, mainDir, result)\n   924→}\n   925→\n   926→func TestExecutor_AgentStep_Success(t *testing.T) {\n   927→\ttmpDir := t.TempDir()\n   928→\toutputDir := filepath.Join(tmpDir, \"output\")\n   929→\n   930→\t// Create a mock agent script that reads stdin and produces output\n   931→\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n   932→\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent did the work'\\n\"), 0755))\n   933→\n   934→\texecutor := &Executor{\n   935→\t\tProjectDir: tmpDir,\n   936→\t\tOutputDir:  outputDir,\n   937→\t\tHostRunID:  \"test-host-run\",\n   938→\t}\n   939→\n   940→\tstep := &domain.Step{\n   941→\t\tName:    \"implement\",\n   942→\t\tType:    domain.StepTypeAgent,\n   943→\t\tResults: []string{\"success\", \"fail\"},\n   944→\t\tConfig: map[string]string{\n   945→\t\t\t\"prompt\":        \"You are a coding assistant.\",\n   946→\t\t\t\"agent_command\": mockAgent,\n   947→\t\t},\n   948→\t}\n   949→\n   950→\tresult, err := executor.Execute(context.Background(), step)\n   951→\trequire.NoError(t, err)\n   952→\tassert.Equal(t, \"success\", result)\n   953→\n   954→\t// Check output was copied to executor's output path\n   955→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n   956→\trequire.NoError(t, err)\n   957→\tassert.Contains(t, string(data), \"agent did the work\")\n   958→}\n   959→\n   960→func TestExecutor_AgentStep_Failure(t *testing.T) {\n   961→\ttmpDir := t.TempDir()\n   962→\toutputDir := filepath.Join(tmpDir, \"output\")\n   963→\n   964→\t// Create a mock agent that reports failure via result marker\n   965→\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n   966→\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'something went wrong'\\necho 'CLOCHE_RESULT:fail'\\n\"), 0755))\n   967→\n   968→\texecutor := &Executor{\n   969→\t\tProjectDir: tmpDir,\n   970→\t\tOutputDir:  outputDir,\n   971→\t\tHostRunID:  \"test-host-run\",\n   972→\t}\n   973→\n   974→\tstep := &domain.Step{\n   975→\t\tName:    \"implement\",\n   976→\t\tType:    domain.StepTypeAgent,\n   977→\t\tResults: []string{\"success\", \"fail\"},\n   978→\t\tConfig: map[string]string{\n   979→\t\t\t\"prompt\":        \"You are a coding assistant.\",\n   980→\t\t\t\"agent_command\": mockAgent,\n   981→\t\t},\n   982→\t}\n   983→\n   984→\tresult, err := executor.Execute(context.Background(), step)\n   985→\trequire.NoError(t, err)\n   986→\tassert.Equal(t, \"fail\", result)\n   987→}\n   988→\n   989→func TestExecutor_AgentStep_WorkflowLevelCommand(t *testing.T) {\n   990→\ttmpDir := t.TempDir()\n   991→\toutputDir := filepath.Join(tmpDir, \"output\")\n   992→\n   993→\t// Create a mock agent\n   994→\tmockAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n   995→\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow agent ran'\\n\"), 0755))\n   996→\n   997→\texecutor := &Executor{\n   998→\t\tProjectDir:    tmpDir,\n   999→\t\tOutputDir:     outputDir,\n  1000→\t\tHostRunID:     \"test-host-run\",\n  1001→\t\tAgentCommands: []string{mockAgent},\n  1002→\t}\n  1003→\n  1004→\tstep := &domain.Step{\n  1005→\t\tName:    \"implement\",\n  1006→\t\tType:    domain.StepTypeAgent,\n  1007→\t\tResults: []string{\"success\", \"fail\"},\n  1008→\t\tConfig: map[string]string{\n  1009→\t\t\t\"prompt\": \"Write some code.\",\n  1010→\t\t},\n  1011→\t}\n  1012→\n  1013→\tresult, err := executor.Execute(context.Background(), step)\n  1014→\trequire.NoError(t, err)\n  1015→\tassert.Equal(t, \"success\", result)\n  1016→\n  1017→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n  1018→\trequire.NoError(t, err)\n  1019→\tassert.Contains(t, string(data), \"workflow agent ran\")\n  1020→}\n  1021→\n  1022→func TestExecutor_AgentStep_StepLevelOverridesWorkflow(t *testing.T) {\n  1023→\ttmpDir := t.TempDir()\n  1024→\toutputDir := filepath.Join(tmpDir, \"output\")\n  1025→\n  1026→\t// Create two mock agents\n  1027→\tworkflowAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n  1028→\trequire.NoError(t, os.WriteFile(workflowAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow agent'\\n\"), 0755))\n  1029→\n  1030→\tstepAgent := filepath.Join(tmpDir, \"step-agent.sh\")\n  1031→\trequire.NoError(t, os.WriteFile(stepAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'step agent'\\n\"), 0755))\n  1032→\n  1033→\texecutor := &Executor{\n  1034→\t\tProjectDir:    tmpDir,\n  1035→\t\tOutputDir:     outputDir,\n  1036→\t\tHostRunID:     \"test-host-run\",\n  1037→\t\tAgentCommands: []string{workflowAgent},\n  1038→\t}\n  1039→\n  1040→\tstep := &domain.Step{\n  1041→\t\tName:    \"implement\",\n  1042→\t\tType:    domain.StepTypeAgent,\n  1043→\t\tResults: []string{\"success\", \"fail\"},\n  1044→\t\tConfig: map[string]string{\n  1045→\t\t\t\"prompt\":        \"Write some code.\",\n  1046→\t\t\t\"agent_command\": stepAgent,\n  1047→\t\t},\n  1048→\t}\n  1049→\n  1050→\tresult, err := executor.Execute(context.Background(), step)\n  1051→\trequire.NoError(t, err)\n  1052→\tassert.Equal(t, \"success\", result)\n  1053→\n  1054→\t// Step-level agent should have run, not workflow-level\n  1055→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n  1056→\trequire.NoError(t, err)\n  1057→\tassert.Contains(t, string(data), \"step agent\")\n  1058→\tassert.NotContains(t, string(data), \"workflow agent\")\n  1059→}\n  1060→\n  1061→func TestExecutor_AgentStep_FallbackChain(t *testing.T) {\n  1062→\ttmpDir := t.TempDir()\n  1063→\toutputDir := filepath.Join(tmpDir, \"output\")\n  1064→\n  1065→\t// Create a good agent\n  1066→\tgoodAgent := filepath.Join(tmpDir, \"good-agent.sh\")\n  1067→\trequire.NoError(t, os.WriteFile(goodAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'fallback agent ran'\\n\"), 0755))\n  1068→\n  1069→\texecutor := &Executor{\n  1070→\t\tProjectDir: tmpDir,\n  1071→\t\tOutputDir:  outputDir,\n  1072→\t\tHostRunID:  \"test-host-run\",\n  1073→\t}\n  1074→\n  1075→\t// Use nonexistent command as primary, good agent as fallback\n  1076→\tstep := &domain.Step{\n  1077→\t\tName:    \"implement\",\n  1078→\t\tType:    domain.StepTypeAgent,\n  1079→\t\tResults: []string{\"success\", \"fail\"},\n  1080→\t\tConfig: map[string]string{\n  1081→\t\t\t\"prompt\":        \"Write some code.\",\n  1082→\t\t\t\"agent_command\": \"nonexistent-agent-xyz,\" + goodAgent,\n  1083→\t\t},\n  1084→\t}\n  1085→\n  1086→\tresult, err := executor.Execute(context.Background(), step)\n  1087→\trequire.NoError(t, err)\n  1088→\tassert.Equal(t, \"success\", result)\n  1089→\n  1090→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"implement.out\"))\n  1091→\trequire.NoError(t, err)\n  1092→\tassert.Contains(t, string(data), \"fallback agent ran\")\n  1093→}\n  1094→\n  1095→func TestExecutor_AgentStep_PrevOutput(t *testing.T) {\n  1096→\ttmpDir := t.TempDir()\n  1097→\toutputDir := filepath.Join(tmpDir, \"output\")\n  1098→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n  1099→\n  1100→\t// Write previous step output\n  1101→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"prepare.out\"), []byte(\"the task description\"), 0644))\n  1102→\n  1103→\t// Create a mock agent that echoes stdin (the prompt) to verify it received it\n  1104→\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1105→\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'processed prompt'\\n\"), 0755))\n  1106→\n  1107→\texecutor := &Executor{\n  1108→\t\tProjectDir: tmpDir,\n  1109→\t\tOutputDir:  outputDir,\n  1110→\t\tHostRunID:  \"test-host-run\",\n  1111→\t\tWires: []domain.Wire{\n  1112→\t\t\t{From: \"prepare\", Result: \"success\", To: \"implement\"},\n  1113→\t\t},\n  1114→\t}\n  1115→\n  1116→\tstep := &domain.Step{\n  1117→\t\tName:    \"implement\",\n  1118→\t\tType:    domain.StepTypeAgent,\n  1119→\t\tResults: []string{\"success\", \"fail\"},\n  1120→\t\tConfig: map[string]string{\n  1121→\t\t\t\"prompt\":        \"You are a coding assistant.\",\n  1122→\t\t\t\"agent_command\": mockAgent,\n  1123→\t\t},\n  1124→\t}\n  1125→\n  1126→\tresult, err := executor.Execute(context.Background(), step)\n  1127→\trequire.NoError(t, err)\n  1128→\tassert.Equal(t, \"success\", result)\n  1129→\n  1130→\t// Verify prompt.txt was written with previous step's output\n  1131→\tpromptPath := filepath.Join(tmpDir, \".cloche\", \"test-host-run\", \"prompt.txt\")\n  1132→\tdata, err := os.ReadFile(promptPath)\n  1133→\trequire.NoError(t, err)\n  1134→\tassert.Equal(t, \"the task description\", string(data))\n  1135→}\n  1136→\n  1137→func TestExecutor_AgentStep_PromptStep(t *testing.T) {\n  1138→\ttmpDir := t.TempDir()\n  1139→\toutputDir := filepath.Join(tmpDir, \"output\")\n  1140→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n  1141→\n  1142→\t// Write a specific step's output\n  1143→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"custom-source.out\"), []byte(\"custom prompt content\"), 0644))\n  1144→\n  1145→\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1146→\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'done'\\n\"), 0755))\n  1147→\n  1148→\texecutor := &Executor{\n  1149→\t\tProjectDir: tmpDir,\n  1150→\t\tOutputDir:  outputDir,\n  1151→\t\tHostRunID:  \"test-host-run\",\n  1152→\t}\n  1153→\n  1154→\tstep := &domain.Step{\n  1155→\t\tName:    \"implement\",\n  1156→\t\tType:    domain.StepTypeAgent,\n  1157→\t\tResults: []string{\"success\", \"fail\"},\n  1158→\t\tConfig: map[string]string{\n  1159→\t\t\t\"prompt\":        \"You are a coding assistant.\",\n  1160→\t\t\t\"agent_command\": mockAgent,\n  1161→\t\t\t\"prompt_step\":   \"custom-source\",\n  1162→\t\t},\n  1163→\t}\n  1164→\n  1165→\tresult, err := executor.Execute(context.Background(), step)\n  1166→\trequire.NoError(t, err)\n  1167→\tassert.Equal(t, \"success\", result)\n  1168→\n  1169→\t// Verify prompt.txt was written with the prompt_step output\n  1170→\tpromptPath := filepath.Join(tmpDir, \".cloche\", \"test-host-run\", \"prompt.txt\")\n  1171→\tdata, err := os.ReadFile(promptPath)\n  1172→\trequire.NoError(t, err)\n  1173→\tassert.Equal(t, \"custom prompt content\", string(data))\n  1174→}\n  1175→\n  1176→func TestEngine_HostWorkflow_WithAgentStep(t *testing.T) {\n  1177→\ttmpDir := t.TempDir()\n  1178→\toutputDir := filepath.Join(tmpDir, \"output\")\n  1179→\n  1180→\t// Create a mock agent\n  1181→\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1182→\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent output'\\n\"), 0755))\n  1183→\n  1184→\texecutor := &Executor{\n  1185→\t\tProjectDir: tmpDir,\n  1186→\t\tOutputDir:  outputDir,\n  1187→\t\tHostRunID:  \"test-host-run\",\n  1188→\t}\n  1189→\n  1190→\twf := &domain.Workflow{\n  1191→\t\tName: \"main\",\n  1192→\t\tSteps: map[string]*domain.Step{\n  1193→\t\t\t\"prepare\": {\n  1194→\t\t\t\tName:    \"prepare\",\n  1195→\t\t\t\tType:    domain.StepTypeScript,\n  1196→\t\t\t\tResults: []string{\"success\", \"fail\"},\n  1197→\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'task prompt'\"},\n  1198→\t\t\t},\n  1199→\t\t\t\"implement\": {\n  1200→\t\t\t\tName:    \"implement\",\n  1201→\t\t\t\tType:    domain.StepTypeAgent,\n  1202→\t\t\t\tResults: []string{\"success\", \"fail\"},\n  1203→\t\t\t\tConfig: map[string]string{\n  1204→\t\t\t\t\t\"prompt\":        \"You are a coding assistant.\",\n  1205→\t\t\t\t\t\"agent_command\": mockAgent,\n  1206→\t\t\t\t},\n  1207→\t\t\t},\n  1208→\t\t\t\"verify\": {\n  1209→\t\t\t\tName:    \"verify\",\n  1210→\t\t\t\tType:    domain.StepTypeScript,\n  1211→\t\t\t\tResults: []string{\"success\", \"fail\"},\n  1212→\t\t\t\tConfig:  map[string]string{\"run\": \"echo verified\"},\n  1213→\t\t\t},\n  1214→\t\t},\n  1215→\t\tWiring: []domain.Wire{\n  1216→\t\t\t{From: \"prepare\", Result: \"success\", To: \"implement\"},\n  1217→\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n  1218→\t\t\t{From: \"implement\", Result: \"success\", To: \"verify\"},\n  1219→\t\t\t{From: \"implement\", Result: \"fail\", To: domain.StepAbort},\n  1220→\t\t\t{From: \"verify\", Result: \"success\", To: domain.StepDone},\n  1221→\t\t\t{From: \"verify\", Result: \"fail\", To: domain.StepAbort},\n  1222→\t\t},\n  1223→\t\tEntryStep: \"prepare\",\n  1224→\t}\n  1225→\n  1226→\teng := engine.New(executor)\n  1227→\trun, err := eng.Run(context.Background(), wf)\n  1228→\trequire.NoError(t, err)\n  1229→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n  1230→}\n  1231→\n  1232→func TestRunner_HostWorkflow_AgentStep(t *testing.T) {\n  1233→\ttmpDir := t.TempDir()\n  1234→\n  1235→\t// Create a mock agent\n  1236→\tmockAgent := filepath.Join(tmpDir, \"mock-agent.sh\")\n  1237→\trequire.NoError(t, os.WriteFile(mockAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent implemented'\\n\"), 0755))\n  1238→\n  1239→\t// Write a host.cloche with an agent step\n  1240→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n  1241→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n  1242→\thostCloche := `workflow \"main\" {\n  1243→  host {\n  1244→    agent_command = \"` + mockAgent + `\"\n  1245→  }\n  1246→\n  1247→  step implement {\n  1248→    prompt = \"Implement the feature.\"\n  1249→    results = [success, fail]\n  1250→  }\n  1251→\n  1252→  implement:success -> done\n  1253→  implement:fail    -> abort\n  1254→}`\n  1255→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n  1256→\n  1257→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n  1258→\n  1259→\trunner := &Runner{\n  1260→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n  1261→\t\tStore:      store,\n  1262→\t}\n  1263→\n  1264→\tresult, err := runner.Run(context.Background(), tmpDir)\n  1265→\trequire.NoError(t, err)\n  1266→\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n  1267→\n  1268→\t// Verify the run completed\n  1269→\thostRun, err := store.GetRun(context.Background(), result.RunID)\n  1270→\trequire.NoError(t, err)\n  1271→\tassert.True(t, hostRun.IsHost)\n  1272→\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n  1273→}\n  1274→\n  1275→func TestRunner_HostWorkflow_AgentStepOverridesWorkflowCommand(t *testing.T) {\n  1276→\ttmpDir := t.TempDir()\n  1277→\n  1278→\t// Create two mock agents\n  1279→\tworkflowAgent := filepath.Join(tmpDir, \"workflow-agent.sh\")\n  1280→\trequire.NoError(t, os.WriteFile(workflowAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'workflow level'\\n\"), 0755))\n  1281→\n  1282→\tstepAgent := filepath.Join(tmpDir, \"step-agent.sh\")\n  1283→\trequire.NoError(t, os.WriteFile(stepAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'step level'\\n\"), 0755))\n  1284→\n  1285→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n  1286→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n  1287→\thostCloche := `workflow \"main\" {\n  1288→  host {\n  1289→    agent_command = \"` + workflowAgent + `\"\n  1290→  }\n  1291→\n  1292→  step implement {\n  1293→    agent_command = \"` + stepAgent + `\"\n  1294→    prompt = \"Implement the feature.\"\n  1295→    results = [success, fail]\n  1296→  }\n  1297→\n  1298→  implement:success -> done\n  1299→  implement:fail    -> abort\n  1300→}`\n  1301→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n  1302→\n  1303→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n  1304→\trunner := &Runner{\n  1305→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n  1306→\t\tStore:      store,\n  1307→\t}\n  1308→\n  1309→\tresult, err := runner.Run(context.Background(), tmpDir)\n  1310→\trequire.NoError(t, err)\n  1311→\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n  1312→}\n  1313→\n  1314→func TestRunner_PersistsHostRunOnFailure(t *testing.T) {\n  1315→\ttmpDir := t.TempDir()\n  1316→\n  1317→\t// Write a host.cloche that will fail\n  1318→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n  1319→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n  1320→\thostCloche := `workflow \"main\" {\n  1321→  step bad {\n  1322→    run     = \"exit 1\"\n  1323→    results = [success, fail]\n  1324→  }\n  1325→\n  1326→  bad:success -> done\n  1327→  bad:fail    -> abort\n  1328→}`\n  1329→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n  1330→\n  1331→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n  1332→\n  1333→\trunner := &Runner{\n  1334→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n  1335→\t\tStore:      store,\n  1336→\t}\n  1337→\n  1338→\tresult, err := runner.Run(context.Background(), tmpDir)\n  1339→\trequire.NoError(t, err)\n  1340→\tassert.Equal(t, domain.RunStateFailed, result.State)\n  1341→\n  1342→\t// Verify the host run was persisted with failed state\n  1343→\thostRun, err := store.GetRun(context.Background(), result.RunID)\n  1344→\trequire.NoError(t, err)\n  1345→\tassert.True(t, hostRun.IsHost)\n  1346→\tassert.Equal(t, domain.RunStateFailed, hostRun.State)\n  1347→\tassert.False(t, hostRun.CompletedAt.IsZero())\n  1348→}\n  1349→"}]},"parent_tool_use_id":"toolu_012epjQe4jiFDSKQ49cH1EjH","session_id":"b83aa53c-b539-403e-957d-d27f065bd09c","uuid":"a7e37143-22a5-40ce-8545-44c624d784ec"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016fuwRv8MXx7UobtoHPdVra","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"sync\"\n     6→\t\"sync/atomic\"\n     7→\t\"testing\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11→\t\"github.com/stretchr/testify/assert\"\n    12→)\n    13→\n    14→func TestLoop_StartStop(t *testing.T) {\n    15→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    16→\tvar called atomic.Int32\n    17→\n    18→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    19→\t\tcalled.Add(1)\n    20→\t\t// Simulate a run that finds no work (failed = aborted).\n    21→\t\ttime.Sleep(50 * time.Millisecond)\n    22→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    23→\t}\n    24→\n    25→\tloop := NewLoop(LoopConfig{\n    26→\t\tProjectDir:    \"/tmp/test-project\",\n    27→\t\tMaxConcurrent: 1,\n    28→\t}, store, runFn)\n    29→\n    30→\tif loop.Running() {\n    31→\t\tt.Fatal(\"loop should not be running before Start\")\n    32→\t}\n    33→\n    34→\tloop.Start()\n    35→\tif !loop.Running() {\n    36→\t\tt.Fatal(\"loop should be running after Start\")\n    37→\t}\n    38→\n    39→\t// Wait enough time for at least one run to happen.\n    40→\ttime.Sleep(200 * time.Millisecond)\n    41→\tloop.Stop()\n    42→\n    43→\tif loop.Running() {\n    44→\t\tt.Fatal(\"loop should not be running after Stop\")\n    45→\t}\n    46→\n    47→\tif called.Load() < 1 {\n    48→\t\tt.Fatal(\"expected at least one run to be launched\")\n    49→\t}\n    50→}\n    51→\n    52→func TestLoop_RampsUpOnSuccess(t *testing.T) {\n    53→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    54→\tvar called atomic.Int32\n    55→\n    56→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    57→\t\tn := called.Add(1)\n    58→\t\ttime.Sleep(20 * time.Millisecond)\n    59→\t\t// First 3 succeed, then fail (no more work).\n    60→\t\tif n <= 3 {\n    61→\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n    62→\t\t}\n    63→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    64→\t}\n    65→\n    66→\tloop := NewLoop(LoopConfig{\n    67→\t\tProjectDir:    \"/tmp/test-project\",\n    68→\t\tMaxConcurrent: 1,\n    69→\t}, store, runFn)\n    70→\n    71→\tloop.Start()\n    72→\t// With no backoff between successes, 3 successful + 1 failed should happen fast.\n    73→\ttime.Sleep(300 * time.Millisecond)\n    74→\tloop.Stop()\n    75→\n    76→\tif called.Load() < 4 {\n    77→\t\tt.Fatalf(\"expected at least 4 runs, got %d\", called.Load())\n    78→\t}\n    79→}\n    80→\n    81→func TestLoop_DoubleStartIsNoop(t *testing.T) {\n    82→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    83→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    84→\t\ttime.Sleep(100 * time.Millisecond)\n    85→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    86→\t}\n    87→\n    88→\tloop := NewLoop(LoopConfig{\n    89→\t\tProjectDir:    \"/tmp/test-project\",\n    90→\t\tMaxConcurrent: 1,\n    91→\t}, store, runFn)\n    92→\n    93→\tloop.Start()\n    94→\tloop.Start() // Should be a no-op.\n    95→\tloop.Stop()\n    96→}\n    97→\n    98→// fakeTaskAssigner implements TaskAssigner for testing.\n    99→type fakeTaskAssigner struct {\n   100→\tmu    sync.Mutex\n   101→\ttasks []Task\n   102→\tcalls int\n   103→}\n   104→\n   105→func (f *fakeTaskAssigner) ListTasks(_ context.Context, _ string) ([]Task, error) {\n   106→\tf.mu.Lock()\n   107→\tdefer f.mu.Unlock()\n   108→\tf.calls++\n   109→\tresult := make([]Task, len(f.tasks))\n   110→\tcopy(result, f.tasks)\n   111→\treturn result, nil\n   112→}\n   113→\n   114→func TestLoop_TaskAssigner_PassesTaskID(t *testing.T) {\n   115→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   116→\n   117→\tassigner := &fakeTaskAssigner{\n   118→\t\ttasks: []Task{\n   119→\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n   120→\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n   121→\t\t},\n   122→\t}\n   123→\n   124→\tvar receivedTaskIDs []string\n   125→\tvar mu sync.Mutex\n   126→\n   127→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   128→\t\tmu.Lock()\n   129→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   130→\t\tmu.Unlock()\n   131→\t\ttime.Sleep(20 * time.Millisecond)\n   132→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   133→\t}\n   134→\n   135→\tloop := NewLoop(LoopConfig{\n   136→\t\tProjectDir:    \"/tmp/test-project\",\n   137→\t\tMaxConcurrent: 1,\n   138→\t\tDedupTimeout:  1 * time.Second,\n   139→\t}, store, runFn)\n   140→\tloop.SetTaskAssigner(assigner)\n   141→\n   142→\tloop.Start()\n   143→\ttime.Sleep(200 * time.Millisecond)\n   144→\tloop.Stop()\n   145→\n   146→\tmu.Lock()\n   147→\tdefer mu.Unlock()\n   148→\t// Should have received task-1 first, then task-2 (task-1 is deduped).\n   149→\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2)\n   150→\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   151→\tassert.Equal(t, \"task-2\", receivedTaskIDs[1])\n   152→}\n   153→\n   154→func TestLoop_TaskAssigner_DedupPreventsReassignment(t *testing.T) {\n   155→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   156→\n   157→\tassigner := &fakeTaskAssigner{\n   158→\t\ttasks: []Task{{ID: \"task-1\"}},\n   159→\t}\n   160→\n   161→\tvar receivedTaskIDs []string\n   162→\tvar mu sync.Mutex\n   163→\n   164→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   165→\t\tmu.Lock()\n   166→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   167→\t\tmu.Unlock()\n   168→\t\ttime.Sleep(20 * time.Millisecond)\n   169→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   170→\t}\n   171→\n   172→\tloop := NewLoop(LoopConfig{\n   173→\t\tProjectDir:    \"/tmp/test-project\",\n   174→\t\tMaxConcurrent: 1,\n   175→\t\tDedupTimeout:  2 * time.Second, // long enough that task-1 won't be reassigned during test\n   176→\t}, store, runFn)\n   177→\tloop.SetTaskAssigner(assigner)\n   178→\n   179→\tloop.Start()\n   180→\ttime.Sleep(200 * time.Millisecond)\n   181→\tloop.Stop()\n   182→\n   183→\tmu.Lock()\n   184→\tdefer mu.Unlock()\n   185→\t// Only one run should have been launched since task-1 is deduped after first assignment.\n   186→\tassert.Equal(t, 1, len(receivedTaskIDs))\n   187→\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   188→}\n   189→\n   190→func TestLoop_TaskAssigner_DedupExpires(t *testing.T) {\n   191→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   192→\n   193→\tassigner := &fakeTaskAssigner{\n   194→\t\ttasks: []Task{{ID: \"task-1\"}},\n   195→\t}\n   196→\n   197→\tvar receivedTaskIDs []string\n   198→\tvar mu sync.Mutex\n   199→\n   200→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   201→\t\tmu.Lock()\n   202→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   203→\t\tmu.Unlock()\n   204→\t\t// Run takes longer than dedup timeout, so by the time the run\n   205→\t\t// completes the dedup window has already expired and pickTask\n   206→\t\t// can re-assign immediately without hitting capacityPollInterval.\n   207→\t\ttime.Sleep(100 * time.Millisecond)\n   208→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   209→\t}\n   210→\n   211→\tloop := NewLoop(LoopConfig{\n   212→\t\tProjectDir:    \"/tmp/test-project\",\n   213→\t\tMaxConcurrent: 1,\n   214→\t\tDedupTimeout:  50 * time.Millisecond,\n   215→\t}, store, runFn)\n   216→\tloop.SetTaskAssigner(assigner)\n   217→\n   218→\tloop.Start()\n   219→\ttime.Sleep(500 * time.Millisecond)\n   220→\tloop.Stop()\n   221→\n   222→\tmu.Lock()\n   223→\tdefer mu.Unlock()\n   224→\t// With 50ms dedup and 100ms run time, dedup expires before run completes,\n   225→\t// so task-1 should be assigned multiple times.\n   226→\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2, \"dedup should have expired, allowing reassignment\")\n   227→\tfor _, id := range receivedTaskIDs {\n   228→\t\tassert.Equal(t, \"task-1\", id)\n   229→\t}\n   230→}\n   231→\n   232→func TestLoop_TaskAssigner_NoTasks_BacksOff(t *testing.T) {\n   233→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   234→\n   235→\tassigner := &fakeTaskAssigner{\n   236→\t\ttasks: nil, // no tasks available\n   237→\t}\n   238→\n   239→\tvar called atomic.Int32\n   240→\n   241→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   242→\t\tcalled.Add(1)\n   243→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   244→\t}\n   245→\n   246→\tloop := NewLoop(LoopConfig{\n   247→\t\tProjectDir:    \"/tmp/test-project\",\n   248→\t\tMaxConcurrent: 1,\n   249→\t}, store, runFn)\n   250→\tloop.SetTaskAssigner(assigner)\n   251→\n   252→\tloop.Start()\n   253→\ttime.Sleep(200 * time.Millisecond)\n   254→\tloop.Stop()\n   255→\n   256→\t// With no tasks, no runs should have been launched.\n   257→\tassert.Equal(t, int32(0), called.Load())\n   258→}\n   259→\n   260→func TestLoop_NoTaskAssigner_EmptyTaskID(t *testing.T) {\n   261→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   262→\n   263→\tvar receivedTaskID string\n   264→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   265→\t\treceivedTaskID = taskID\n   266→\t\ttime.Sleep(20 * time.Millisecond)\n   267→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   268→\t}\n   269→\n   270→\tloop := NewLoop(LoopConfig{\n   271→\t\tProjectDir:    \"/tmp/test-project\",\n   272→\t\tMaxConcurrent: 1,\n   273→\t}, store, runFn)\n   274→\t// No SetTaskAssigner call — backward compatible mode.\n   275→\n   276→\tloop.Start()\n   277→\ttime.Sleep(200 * time.Millisecond)\n   278→\tloop.Stop()\n   279→\n   280→\t// Without a task assigner, taskID should be empty.\n   281→\tassert.Empty(t, receivedTaskID)\n   282→}\n   283→"}]},"parent_tool_use_id":"toolu_012epjQe4jiFDSKQ49cH1EjH","session_id":"b83aa53c-b539-403e-957d-d27f065bd09c","uuid":"98249bec-083b-458f-83cc-337a603ff394"}
