ntains(t, mgr.stopped, \"cid-pdr1\")\n\tassert.Contains(t, mgr.removed, \"cid-pdr1\")\n\tassert.Contains(t, mgr.removed, \"cid-pdr2\")\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":617,"cache_read_input_tokens":95454,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":617},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8afa4431-c2af-45d7-8651-174f88b0e5d9","uuid":"23003bcb-5450-4a73-b138-63b06996ebdc"}
