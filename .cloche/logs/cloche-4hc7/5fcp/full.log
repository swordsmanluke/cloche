tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   330→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   331→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   332→\t}\n   333→}\n   334→\n   335→// handleProjectRuns renders the runs list filtered by the project in the URL path.\n   336→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   337→\tdir, _, ok := h.resolveProjectDir(w, r)\n   338→\tif !ok {\n   339→\t\treturn"}]},"parent_tool_use_id":"toolu_016qqohA26N1zyrzkc6V7p2n","session_id":"8afa4431-c2af-45d7-8651-174f88b0e5d9","uuid":"44562a33-7912-4628-9f18-e04aed4a616a"}
