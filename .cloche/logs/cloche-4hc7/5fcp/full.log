"DELETE\", \"/api/containers\", nil)\n  2003→\tw := httptest.NewRecorder()\n  2004→\th.ServeHTTP(w, req)\n  2005→\n  2006→\tassert.Equal(t, http.StatusOK, w.Code)\n  2007→\n  2008→\tvar resp map[string]any\n  2009→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n  2010→\tassert.Equal(t, float64(1), resp[\"deleted\"])\n  2011→\n  2012→\t// Running container not removed\n  2013→\tassert.NotContains(t, mgr.removed, \"cid-acr1\")\n  2014→\tassert.Contains(t, mgr.removed, \"cid-acr2\")\n  2015→}\n  2016→\n  2017→func TestAPIDeleteAllContainers_SkipsNonKept(t *testing.T) {\n  2018→\th, store, mgr := setupHandlerWithContainerManager(t)\n  2019→\tseedRunWithContainer(t, store, mgr, \"run-ack1\", \"develop\", \"/home/user/alpha\", \"cid-ack1\", false) // not kept\n  2020→\n  2021→\treq := httptest.NewRequest(\"DELETE\", \"/api/containers\", nil)\n  2022→\tw := httptest.NewRecorder()\n  2023→\th.ServeHTTP(w, req)\n  2024→\n  2025→\tassert.Equal(t, http.StatusOK, w.Code)\n  2026→\n  2027→\tvar resp map[string]any\n  2028→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n  2029→\tassert.Equal(t, float64(0), resp[\"deleted\"])\n  2030→}\n  2031→\n  2032→func TestAPIDeleteAllContainers_NoManager(t *testing.T) {\n  2033→\th, store := setupHandler(t)\n  2034→\tseedRunWithProject(t, store, \"run-acnm\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n  2035→\n  2036→\treq := httptest.NewRequest(\"DELETE\", \"/api/containers\", nil)\n  2037→\tw := httptest.NewRecorder()\n  2038→\th.ServeHTTP(w, req)\n  2039→\n  2040→\tassert.Equal(t, http.StatusBadRequest, w.Code)\n  2041→}\n  2042→\n  2043→func TestRunsList_CleanupButton(t *testing.T) {\n  2044→\th, store, mgr := setupHandlerWithContainerManager(t)\n  2045→\tseedRunWithContainer(t, store, mgr, \"run-cb1\", \"develop\", \"/home/user/alpha\", \"cid-cb1\", true)"}]},"parent_tool_use_id":"toolu_016qqohA26N1zyrzkc6V7p2n","session_id":"8afa4431-c2af-45d7-8651-174f88b0e5d9","uuid":"a5ec86db-0903-4fa8-b6