{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KjtpRigdNEgKGuLUhFyecr","type":"tool_result","content":"     1â†’package evolution\n     2â†’\n     3â†’import (\n     4â†’\t\"context\"\n     5â†’\t\"encoding/json\"\n     6â†’\t\"os\"\n     7â†’\t\"path/filepath\"\n     8â†’\t\"strings\"\n     9â†’\t\"testing\"\n    10â†’\n    11â†’\t\"github.com/stretchr/testify/assert\"\n    12â†’\t\"github.com/stretchr/testify/require\"\n    13â†’)\n    14â†’\n    15â†’// fakeLLM returns a fixed response for testing.\n    16â†’type fakeLLM struct {\n    17â†’\tresponse string\n    18â†’}\n    19â†’\n    20â†’func (f *fakeLLM) Complete(ctx context.Context, system, user string) (string, error) {\n    21â†’\treturn f.response, nil\n    22â†’}\n    23â†’\n    24â†’// --- Collector tests ---\n    25â†’\n    26â†’func TestCollectorGathersData(t *testing.T) {\n    27â†’\tdir := t.TempDir()\n    28â†’\n    29â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n    30â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n    31â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n    32â†’\t\t[]byte(\"# Knowledge Base\\n\"), 0644)\n    33â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n    34â†’\t\t[]byte(\"Write good code\"), 0644)\n    35â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n    36â†’\t\t[]byte(`workflow \"develop\" {\n    37â†’  step impl {\n    38â†’    prompt = file(\".cloche/prompts/implement.md\")\n    39â†’    results = [success]\n    40â†’  }\n    41â†’  impl:success -> done\n    42â†’}`), 0644)\n    43â†’\n    44â†’\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n    45â†’\tdata, err := c.Collect(context.Background(), nil, nil)\n    46â†’\trequire.NoError(t, err)\n    47â†’\n    48â†’\tassert.Equal(t, \"# Knowledge Base\\n\", data.KnowledgeBase)\n    49â†’\tassert.Contains(t, data.CurrentPrompts, \".cloche/prompts/implement.md\")\n    50â†’\tassert.Equal(t, \"Write good code\", data.CurrentPrompts[\".cloche/prompts/implement.md\"])\n    51â†’\tassert.NotEmpty(t, data.CurrentWorkflow)\n    52â†’\tassert.Equal(t, dir, data.ProjectDir)\n    53â†’\tassert.Equal(t, \"develop\", data.WorkflowName)\n    54â†’}\n    55â†’\n    56â†’func TestCollectorNoKnowledgeBase(t *testing.T) {\n    57â†’\tdir := t.TempDir()\n    58â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n    59â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n    60â†’\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n    61â†’\n    62â†’\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n    63â†’\tdata, err := c.Collect(context.Background(), nil, nil)\n    64â†’\trequire.NoError(t, err)\n    65â†’\tassert.Empty(t, data.KnowledgeBase)\n    66â†’}\n    67â†’\n    68â†’func TestExtractPromptFiles(t *testing.T) {\n    69â†’\tworkflow := `step impl { prompt = file(\".cloche/prompts/implement.md\") }\n    70â†’step fix { prompt = file(\".cloche/prompts/fix.md\") }\n    71â†’step test { run = \"make test\" }`\n    72â†’\n    73â†’\tfiles := extractPromptFiles(workflow)\n    74â†’\tassert.Len(t, files, 2)\n    75â†’\tassert.Contains(t, files, \".cloche/prompts/implement.md\")\n    76â†’\tassert.Contains(t, files, \".cloche/prompts/fix.md\")\n    77â†’}\n    78â†’\n    79â†’// --- Classifier tests ---\n    80â†’\n    81â†’func TestClassifierCategorizesRun(t *testing.T) {\n    82â†’\ttests := []struct {\n    83â†’\t\tname     string\n    84â†’\t\tresponse string\n    85â†’\t\texpected string\n    86â†’\t}{\n    87â†’\t\t{\"bug\", `{\"classification\": \"bug\"}`, \"bug\"},\n    88â†’\t\t{\"feature\", `{\"classification\": \"feature\"}`, \"feature\"},\n    89â†’\t\t{\"feedback\", `{\"classification\": \"feedback\"}`, \"feedback\"},\n    90â†’\t\t{\"enhancement\", `{\"classification\": \"enhancement\"}`, \"enhancement\"},\n    91â†’\t\t{\"chore\", `{\"classification\": \"chore\"}`, \"chore\"},\n    92â†’\t\t{\"invalid defaults to feature\", `{\"classification\": \"unknown\"}`, \"feature\"},\n    93â†’\t\t{\"malformed JSON defaults to feature\", `not json`, \"feature\"},\n    94â†’\t}\n    95â†’\n    96â†’\tfor _, tt := range tests {\n    97â†’\t\tt.Run(tt.name, func(t *testing.T) {\n    98â†’\t\t\tllm := &fakeLLM{response: tt.response}\n    99â†’\t\t\tc := &Classifier{LLM: llm}\n   100â†’\t\t\tresult, err := c.Classify(context.Background(), \"some prompt\")\n   101â†’\t\t\trequire.NoError(t, err)\n   102â†’\t\t\tassert.Equal(t, tt.expected, result)\n   103â†’\t\t})\n   104â†’\t}\n   105â†’}\n   106â†’\n   107â†’// --- Reflector tests ---\n   108â†’\n   109â†’func TestReflectorExtractsLessons(t *testing.T) {\n   110â†’\tlessonsJSON, _ := json.Marshal(map[string]any{\n   111â†’\t\t\"lessons\": []map[string]any{\n   112â†’\t\t\t{\n   113â†’\t\t\t\t\"id\":               \"lesson-001\",\n   114â†’\t\t\t\t\"category\":         \"prompt_improvement\",\n   115â†’\t\t\t\t\"target\":           \".cloche/prompts/implement.md\",\n   116â†’\t\t\t\t\"insight\":          \"Agent produces unsanitized HTML\",\n   117â†’\t\t\t\t\"suggested_action\": \"Add sanitization rule\",\n   118â†’\t\t\t\t\"evidence\":         []string{\"run-1\", \"run-2\"},\n   119â†’\t\t\t\t\"confidence\":       \"high\",\n   120â†’\t\t\t},\n   121â†’\t\t},\n   122â†’\t})\n   123â†’\n   124â†’\tllm := &fakeLLM{response: string(lessonsJSON)}\n   125â†’\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n   126â†’\n   127â†’\tdata := &CollectedData{WorkflowName: \"develop\", KnowledgeBase: \"# KB\\n\"}\n   128â†’\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n   129â†’\trequire.NoError(t, err)\n   130â†’\trequire.Len(t, lessons, 1)\n   131â†’\tassert.Equal(t, \"prompt_improvement\", lessons[0].Category)\n   132â†’\tassert.Equal(t, \"high\", lessons[0].Confidence)\n   133â†’}\n   134â†’\n   135â†’func TestReflectorFiltersLowConfidence(t *testing.T) {\n   136â†’\tlessonsJSON, _ := json.Marshal(map[string]any{\n   137â†’\t\t\"lessons\": []map[string]any{\n   138â†’\t\t\t{\"id\": \"L1\", \"category\": \"new_step\", \"confidence\": \"low\"},\n   139â†’\t\t\t{\"id\": \"L2\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n   140â†’\t\t},\n   141â†’\t})\n   142â†’\n   143â†’\tllm := &fakeLLM{response: string(lessonsJSON)}\n   144â†’\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n   145â†’\n   146â†’\tlessons, err := r.Reflect(context.Background(), &CollectedData{}, \"bug\")\n   147â†’\trequire.NoError(t, err)\n   148â†’\tassert.Len(t, lessons, 1)\n   149â†’\tassert.Equal(t, \"L2\", lessons[0].ID)\n   150â†’}\n   151â†’\n   152â†’func TestConfidenceLevel(t *testing.T) {\n   153â†’\tassert.Equal(t, 3, confidenceLevel(\"high\"))\n   154â†’\tassert.Equal(t, 2, confidenceLevel(\"medium\"))\n   155â†’\tassert.Equal(t, 1, confidenceLevel(\"low\"))\n   156â†’\tassert.Equal(t, 0, confidenceLevel(\"\"))\n   157â†’}\n   158â†’\n   159â†’// --- Audit Logger tests ---\n   160â†’\n   161â†’func TestAuditLoggerAppendsJSONL(t *testing.T) {\n   162â†’\tdir := t.TempDir()\n   163â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\"), 0755)\n   164â†’\n   165â†’\tlogger := &AuditLogger{ProjectDir: dir}\n   166â†’\n   167â†’\tresult1 := &EvolutionResult{\n   168â†’\t\tID:           \"evo-1\",\n   169â†’\t\tWorkflowName: \"develop\",\n   170â†’\t\tChanges:      []Change{{Type: \"prompt_update\", File: \".cloche/prompts/impl.md\"}},\n   171â†’\t}\n   172â†’\trequire.NoError(t, logger.Log(result1))\n   173â†’\n   174â†’\tresult2 := &EvolutionResult{\n   175â†’\t\tID:           \"evo-2\",\n   176â†’\t\tWorkflowName: \"develop\",\n   177â†’\t\tChanges:      []Change{{Type: \"add_step\", File: \".cloche/develop.cloche\"}},\n   178â†’\t}\n   179â†’\trequire.NoError(t, logger.Log(result2))\n   180â†’\n   181â†’\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n   182â†’\trequire.NoError(t, err)\n   183â†’\n   184â†’\tlines := strings.Split(strings.TrimSpace(string(content)), \"\\n\")\n   185â†’\tassert.Len(t, lines, 2)\n   186â†’\n   187â†’\tvar entry1 EvolutionResult\n   188â†’\trequire.NoError(t, json.Unmarshal([]byte(lines[0]), &entry1))\n   189â†’\tassert.Equal(t, \"evo-1\", entry1.ID)\n   190â†’}\n   191â†’\n   192â†’func TestAuditLoggerSnapshot(t *testing.T) {\n   193â†’\tdir := t.TempDir()\n   194â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   195â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   196â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"original content\"), 0644)\n   197â†’\n   198â†’\tlogger := &AuditLogger{ProjectDir: dir}\n   199â†’\tsnapName, err := logger.Snapshot(\".cloche/prompts/implement.md\")\n   200â†’\trequire.NoError(t, err)\n   201â†’\tassert.NotEmpty(t, snapName)\n   202â†’\n   203â†’\tsnapPath := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\", snapName)\n   204â†’\tcontent, err := os.ReadFile(snapPath)\n   205â†’\trequire.NoError(t, err)\n   206â†’\tassert.Equal(t, \"original content\", string(content))\n   207â†’}\n   208â†’\n   209â†’func TestAuditLoggerUpdatesKnowledge(t *testing.T) {\n   210â†’\tdir := t.TempDir()\n   211â†’\tkbDir := filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\")\n   212â†’\tos.MkdirAll(kbDir, 0755)\n   213â†’\tos.WriteFile(filepath.Join(kbDir, \"develop.md\"), []byte(\"# Knowledge Base: develop workflow\\n\"), 0644)\n   214â†’\n   215â†’\tlogger := &AuditLogger{ProjectDir: dir}\n   216â†’\tlessons := []Lesson{\n   217â†’\t\t{\n   218â†’\t\t\tID:              \"P001\",\n   219â†’\t\t\tCategory:        \"prompt_improvement\",\n   220â†’\t\t\tConfidence:      \"high\",\n   221â†’\t\t\tInsight:         \"Always sanitize HTML inputs\",\n   222â†’\t\t\tSuggestedAction: \"Add rule to implement prompt\",\n   223â†’\t\t\tEvidence:        []string{\"run-1\", \"run-2\"},\n   224â†’\t\t},\n   225â†’\t}\n   226â†’\n   227â†’\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", lessons))\n   228â†’\n   229â†’\tcontent, err := os.ReadFile(filepath.Join(kbDir, \"develop.md\"))\n   230â†’\trequire.NoError(t, err)\n   231â†’\tassert.Contains(t, string(content), \"[P001]\")\n   232â†’\tassert.Contains(t, string(content), \"sanitize HTML\")\n   233â†’\tassert.Contains(t, string(content), \"run-1, run-2\")\n   234â†’}\n   235â†’\n   236â†’// --- LLM Client tests ---\n   237â†’\n   238â†’// --- Curator tests ---\n   239â†’\n   240â†’func TestCuratorUpdatesPrompt(t *testing.T) {\n   241â†’\tdir := t.TempDir()\n   242â†’\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   243â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   244â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   245â†’\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   246â†’\n   247â†’\tupdatedContent := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"\n   248â†’\tllm := &fakeLLM{response: updatedContent}\n   249â†’\n   250â†’\taudit := &AuditLogger{ProjectDir: dir}\n   251â†’\tc := &Curator{LLM: llm, Audit: audit}\n   252â†’\tlesson := &Lesson{\n   253â†’\t\tID:              \"lesson-001\",\n   254â†’\t\tCategory:        \"prompt_improvement\",\n   255â†’\t\tTarget:          \".cloche/prompts/implement.md\",\n   256â†’\t\tInsight:         \"XSS vulnerabilities in form handlers\",\n   257â†’\t\tSuggestedAction: \"Add sanitization rule\",\n   258â†’\t}\n   259â†’\n   260â†’\tchange, err := c.Apply(context.Background(), dir, lesson)\n   261â†’\trequire.NoError(t, err)\n   262â†’\tassert.Equal(t, \"prompt_update\", change.Type)\n   263â†’\tassert.Equal(t, \".cloche/prompts/implement.md\", change.File)\n   264â†’\tassert.NotEmpty(t, change.Snapshot)\n   265â†’\n   266â†’\tcontent, err := os.ReadFile(promptPath)\n   267â†’\trequire.NoError(t, err)\n   268â†’\tassert.Contains(t, string(content), \"sanitize user inputs\")\n   269â†’}\n   270â†’\n   271â†’// --- Script Generator tests ---\n   272â†’\n   273â†’func TestScriptGeneratorCreatesScript(t *testing.T) {\n   274â†’\tdir := t.TempDir()\n   275â†’\n   276â†’\tllm := &fakeLLM{response: `{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`}\n   277â†’\tg := &ScriptGenerator{LLM: llm}\n   278â†’\n   279â†’\tlesson := &Lesson{\n   280â†’\t\tID:              \"lesson-001\",\n   281â†’\t\tCategory:        \"new_step\",\n   282â†’\t\tStepType:        \"script\",\n   283â†’\t\tInsight:         \"No security scanning\",\n   284â†’\t\tSuggestedAction: \"Add gosec security scan\",\n   285â†’\t}\n   286â†’\n   287â†’\tresult, err := g.Generate(context.Background(), dir, lesson)\n   288â†’\trequire.NoError(t, err)\n   289â†’\tassert.Equal(t, \"scripts/security-scan.sh\", result.Path)\n   290â†’\n   291â†’\tcontent, err := os.ReadFile(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n   292â†’\trequire.NoError(t, err)\n   293â†’\tassert.Contains(t, string(content), \"gosec\")\n   294â†’\n   295â†’\tinfo, err := os.Stat(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n   296â†’\trequire.NoError(t, err)\n   297â†’\tassert.NotZero(t, info.Mode()&0111) // executable\n   298â†’}\n   299â†’\n   300â†’// --- LLM Client tests ---\n   301â†’\n   302â†’func TestCommandLLMClient(t *testing.T) {\n   303â†’\tc := &CommandLLMClient{Command: \"cat\", Args: []string{}}\n   304â†’\tresult, err := c.Complete(context.Background(), \"system\", \"user prompt\")\n   305â†’\trequire.NoError(t, err)\n   306â†’\tassert.Contains(t, result, \"user prompt\")\n   307â†’\tassert.Contains(t, result, \"system\")\n   308â†’}\n   309â†’\n   310â†’// --- Orchestrator tests ---\n   311â†’\n   312â†’// scriptedLLM returns responses in order.\n   313â†’type scriptedLLM struct {\n   314â†’\tresponses []string\n   315â†’\tidx       int\n   316â†’}\n   317â†’\n   318â†’func (s *scriptedLLM) Complete(ctx context.Context, system, user string) (string, error) {\n   319â†’\tresp := s.responses[s.idx]\n   320â†’\ts.idx++\n   321â†’\treturn resp, nil\n   322â†’}\n   323â†’\n   324â†’func TestOrchestratorEndToEnd(t *testing.T) {\n   325â†’\tdir := t.TempDir()\n   326â†’\n   327â†’\t// Set up project structure\n   328â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   329â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   330â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   331â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n   332â†’\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n   333â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n   334â†’\t\t[]byte(\"Write good code.\\n\"), 0644)\n   335â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   336â†’\t\t[]byte(`workflow \"develop\" {\n   337â†’  step implement {\n   338â†’    prompt = file(\".cloche/prompts/implement.md\")\n   339â†’    results = [success, fail]\n   340â†’  }\n   341â†’  step test {\n   342â†’    run = \"make test\"\n   343â†’    results = [success, fail]\n   344â†’  }\n   345â†’  implement:success -> test\n   346â†’  test:success -> done\n   347â†’  test:fail -> abort\n   348â†’}`), 0644)\n   349â†’\n   350â†’\t// Fake LLM that returns appropriate responses per stage\n   351â†’\tllm := &scriptedLLM{\n   352â†’\t\tresponses: []string{\n   353â†’\t\t\t// Classifier\n   354â†’\t\t\t`{\"classification\": \"bug\"}`,\n   355â†’\t\t\t// Reflector\n   356â†’\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n   357â†’\t\t\t// Curator\n   358â†’\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n   359â†’\t\t},\n   360â†’\t}\n   361â†’\n   362â†’\torch := NewOrchestrator(OrchestratorConfig{\n   363â†’\t\tProjectDir:    dir,\n   364â†’\t\tWorkflowName:  \"develop\",\n   365â†’\t\tLLM:           llm,\n   366â†’\t\tMinConfidence: \"medium\",\n   367â†’\t})\n   368â†’\n   369â†’\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   370â†’\trequire.NoError(t, err)\n   371â†’\tassert.Equal(t, \"bug\", result.Classification)\n   372â†’\trequire.Len(t, result.Changes, 1)\n   373â†’\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n   374â†’\n   375â†’\t// Verify prompt was actually updated\n   376â†’\tcontent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n   377â†’\tassert.Contains(t, string(content), \"sanitize user inputs\")\n   378â†’\n   379â†’\t// Verify audit log was written\n   380â†’\tlogContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n   381â†’\tassert.Contains(t, string(logContent), \"prompt_update\")\n   382â†’\tassert.Contains(t, string(logContent), \"XSS pattern\")\n   383â†’\n   384â†’\t// Verify knowledge base was updated\n   385â†’\tkbContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"))\n   386â†’\tassert.Contains(t, string(kbContent), \"L001\")\n   387â†’}\n   388â†’\n   389â†’func TestOrchestratorNoLessons(t *testing.T) {\n   390â†’\tdir := t.TempDir()\n   391â†’\n   392â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   393â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   394â†’\t\t[]byte(`workflow \"develop\" {\n   395â†’  step s {\n   396â†’    run = \"echo hi\"\n   397â†’    results = [success]\n   398â†’  }\n   399â†’  s:success -> done\n   400â†’}`), 0644)\n   401â†’\n   402â†’\tllm := &scriptedLLM{\n   403â†’\t\tresponses: []string{\n   404â†’\t\t\t// Classifier\n   405â†’\t\t\t`{\"classification\": \"feature\"}`,\n   406â†’\t\t\t// Reflector â€” no lessons\n   407â†’\t\t\t`{\"lessons\": []}`,\n   408â†’\t\t},\n   409â†’\t}\n   410â†’\n   411â†’\torch := NewOrchestrator(OrchestratorConfig{\n   412â†’\t\tProjectDir:    dir,\n   413â†’\t\tWorkflowName:  \"develop\",\n   414â†’\t\tLLM:           llm,\n   415â†’\t\tMinConfidence: \"medium\",\n   416â†’\t})\n   417â†’\n   418â†’\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   419â†’\trequire.NoError(t, err)\n   420â†’\tassert.Equal(t, \"feature\", result.Classification)\n   421â†’\tassert.Empty(t, result.Changes)\n   422â†’}\n   423â†’"}]},"parent_tool_use_id":null,"session_id":"14372d0c-650b-41f9-87a5-8a37b0a7cc99","uuid":"d588aa68-dda1-4fc5-8983-3d35981b2c16","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/evolution_test.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// fakeLLM returns a fixed response for testing.\ntype fakeLLM struct {\n\tresponse string\n}\n\nfunc (f *fakeLLM) Complete(ctx context.Context, system, user string) (string, error) {\n\treturn f.response, nil\n}\n\n// --- Collector tests ---\n\nfunc TestCollectorGathersData(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n\t\t[]byte(\"# Knowledge Base\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"Write good code\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step impl {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success]\n  }\n  impl:success -> done\n}`), 0644)\n\n\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n\tdata, err := c.Collect(context.Background(), nil, nil)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, \"# Knowledge Base\\n\", data.KnowledgeBase)\n\tassert.Contains(t, data.CurrentPrompts, \".cloche/prompts/implement.md\")\n\tassert.Equal(t, \"Write good code\", data.CurrentPrompts[\".cloche/prompts/implement.md\"])\n\tassert.NotEmpty(t, data.CurrentWorkflow)\n\tassert.Equal(t, dir, data.ProjectDir)\n\tassert.Equal(t, \"develop\", data.WorkflowName)\n}\n\nfunc TestCollectorNoKnowledgeBase(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n\n\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n\tdata, err := c.Collect(context.Background(), nil, nil)\n\trequire.NoError(t, err)\n\tassert.Empty(t, data.KnowledgeBase)\n}\n\nfunc TestExtractPromptFiles(t *testing.T) {\n\tworkflow := `step impl { prompt = file(\".cloche/prompts/implement.md\") }\nstep fix { prompt = file(\".cloche/prompts/fix.md\") }\nstep test { run = \"make test\" }`\n\n\tfiles := extractPromptFiles(workflow)\n\tassert.Len(t, files, 2)\n\tassert.Contains(t, files, \".cloche/prompts/implement.md\")\n\tassert.Contains(t, files, \".cloche/prompts/fix.md\")\n}\n\n// --- Classifier tests ---\n\nfunc TestClassifierCategorizesRun(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tresponse string\n\t\texpected string\n\t}{\n\t\t{\"bug\", `{\"classification\": \"bug\"}`, \"bug\"},\n\t\t{\"feature\", `{\"classification\": \"feature\"}`, \"feature\"},\n\t\t{\"feedback\", `{\"classification\": \"feedback\"}`, \"feedback\"},\n\t\t{\"enhancement\", `{\"classification\": \"enhancement\"}`, \"enhancement\"},\n\t\t{\"chore\", `{\"classification\": \"chore\"}`, \"chore\"},\n\t\t{\"invalid defaults to feature\", `{\"classification\": \"unknown\"}`, \"feature\"},\n\t\t{\"malformed JSON defaults to feature\", `not json`, \"feature\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tllm := &fakeLLM{response: tt.response}\n\t\t\tc := &Classifier{LLM: llm}\n\t\t\tresult, err := c.Classify(context.Background(), \"some prompt\")\n\t\t\trequire.NoError(t, err)\n\t\t\tassert.Equal(t, tt.expected, result)\n\t\t})\n\t}\n}\n\n// --- Reflector tests ---\n\nfunc TestReflectorExtractsLessons(t *testing.T) {\n\tlessonsJSON, _ := json.Marshal(map[string]any{\n\t\t\"lessons\": []map[string]any{\n\t\t\t{\n\t\t\t\t\"id\":               \"lesson-001\",\n\t\t\t\t\"category\":         \"prompt_improvement\",\n\t\t\t\t\"target\":           \".cloche/prompts/implement.md\",\n\t\t\t\t\"insight\":          \"Agent produces unsanitized HTML\",\n\t\t\t\t\"suggested_action\": \"Add sanitization rule\",\n\t\t\t\t\"evidence\":         []string{\"run-1\", \"run-2\"},\n\t\t\t\t\"confidence\":       \"high\",\n\t\t\t},\n\t\t},\n\t})\n\n\tllm := &fakeLLM{response: string(lessonsJSON)}\n\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n\n\tdata := &CollectedData{WorkflowName: \"develop\", KnowledgeBase: \"# KB\\n\"}\n\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n\trequire.NoError(t, err)\n\trequire.Len(t, lessons, 1)\n\tassert.Equal(t, \"prompt_improvement\", lessons[0].Category)\n\tassert.Equal(t, \"high\", lessons[0].Confidence)\n}\n\nfunc TestReflectorFiltersLowConfidence(t *testing.T) {\n\tlessonsJSON, _ := json.Marshal(map[string]any{\n\t\t\"lessons\": []map[string]any{\n\t\t\t{\"id\": \"L1\", \"category\": \"new_step\", \"confidence\": \"low\"},\n\t\t\t{\"id\": \"L2\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n\t\t},\n\t})\n\n\tllm := &fakeLLM{response: string(lessonsJSON)}\n\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n\n\tlessons, err := r.Reflect(context.Background(), &CollectedData{}, \"bug\")\n\trequire.NoError(t, err)\n\tassert.Len(t, lessons, 1)\n\tassert.Equal(t, \"L2\", lessons[0].ID)\n}\n\nfunc TestConfidenceLevel(t *testing.T) {\n\tassert.Equal(t, 3, confidenceLevel(\"high\"))\n\tassert.Equal(t, 2, confidenceLevel(\"medium\"))\n\tassert.Equal(t, 1, confidenceLevel(\"low\"))\n\tassert.Equal(t, 0, confidenceLevel(\"\"))\n}\n\n// --- Audit Logger tests ---\n\nfunc TestAuditLoggerAppendsJSONL(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\"), 0755)\n\n\tlogger := &AuditLogger{ProjectDir: dir}\n\n\tresult1 := &EvolutionResult{\n\t\tID:           \"evo-1\",\n\t\tWorkflowName: \"develop\",\n\t\tChanges:      []Change{{Type: \"prompt_update\", File: \".cloche/prompts/impl.md\"}},\n\t}\n\trequire.NoError(t, logger.Log(result1))\n\n\tresult2 := &EvolutionResult{\n\t\tID:           \"evo-2\",\n\t\tWorkflowName: \"develop\",\n\t\tChanges:      []Change{{Type: \"add_step\", File: \".cloche/develop.cloche\"}},\n\t}\n\trequire.NoError(t, logger.Log(result2))\n\n\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n\trequire.NoError(t, err)\n\n\tlines := strings.Split(strings.TrimSpace(string(content)), \"\\n\")\n\tassert.Len(t, lines, 2)\n\n\tvar entry1 EvolutionResult\n\trequire.NoError(t, json.Unmarshal([]byte(lines[0]), &entry1))\n\tassert.Equal(t, \"evo-1\", entry1.ID)\n}\n\nfunc TestAuditLoggerSnapshot(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"original content\"), 0644)\n\n\tlogger := &AuditLogger{ProjectDir: dir}\n\tsnapName, err := logger.Snapshot(\".cloche/prompts/implement.md\")\n\trequire.NoError(t, err)\n\tassert.NotEmpty(t, snapName)\n\n\tsnapPath := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\", snapName)\n\tcontent, err := os.ReadFile(snapPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"original content\", string(content))\n}\n\nfunc TestAuditLoggerUpdatesKnowledge(t *testing.T) {\n\tdir := t.TempDir()\n\tkbDir := filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\")\n\tos.MkdirAll(kbDir, 0755)\n\tos.WriteFile(filepath.Join(kbDir, \"develop.md\"), []byte(\"# Knowledge Base: develop workflow\\n\"), 0644)\n\n\tlogger := &AuditLogger{ProjectDir: dir}\n\tlessons := []Lesson{\n\t\t{\n\t\t\tID:              \"P001\",\n\t\t\tCategory:        \"prompt_improvement\",\n\t\t\tConfidence:      \"high\",\n\t\t\tInsight:         \"Always sanitize HTML inputs\",\n\t\t\tSuggestedAction: \"Add rule to implement prompt\",\n\t\t\tEvidence:        []string{\"run-1\", \"run-2\"},\n\t\t},\n\t}\n\n\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", lessons))\n\n\tcontent, err := os.ReadFile(filepath.Join(kbDir, \"develop.md\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"[P001]\")\n\tassert.Contains(t, string(content), \"sanitize HTML\")\n\tassert.Contains(t, string(content), \"run-1, run-2\")\n}\n\n// --- LLM Client tests ---\n\n// --- Curator tests ---\n\nfunc TestCuratorUpdatesPrompt(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n\n\tupdatedContent := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"\n\tllm := &fakeLLM{response: updatedContent}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tID:              \"lesson-001\",\n\t\tCategory:        \"prompt_improvement\",\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"XSS vulnerabilities in form handlers\",\n\t\tSuggestedAction: \"Add sanitization rule\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"prompt_update\", change.Type)\n\tassert.Equal(t, \".cloche/prompts/implement.md\", change.File)\n\tassert.NotEmpty(t, change.Snapshot)\n\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"sanitize user inputs\")\n}\n\n// --- Script Generator tests ---\n\nfunc TestScriptGeneratorCreatesScript(t *testing.T) {\n\tdir := t.TempDir()\n\n\tllm := &fakeLLM{response: `{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`}\n\tg := &ScriptGenerator{LLM: llm}\n\n\tlesson := &Lesson{\n\t\tID:              \"lesson-001\",\n\t\tCategory:        \"new_step\",\n\t\tStepType:        \"script\",\n\t\tInsight:         \"No security scanning\",\n\t\tSuggestedAction: \"Add gosec security scan\",\n\t}\n\n\tresult, err := g.Generate(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"scripts/security-scan.sh\", result.Path)\n\n\tcontent, err := os.ReadFile(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"gosec\")\n\n\tinfo, err := os.Stat(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n\trequire.NoError(t, err)\n\tassert.NotZero(t, info.Mode()&0111) // executable\n}\n\n// --- LLM Client tests ---\n\nfunc TestCommandLLMClient(t *testing.T) {\n\tc := &CommandLLMClient{Command: \"cat\", Args: []string{}}\n\tresult, err := c.Complete(context.Background(), \"system\", \"user prompt\")\n\trequire.NoError(t, err)\n\tassert.Contains(t, result, \"user prompt\")\n\tassert.Contains(t, result, \"system\")\n}\n\n// --- Orchestrator tests ---\n\n// scriptedLLM returns responses in order.\ntype scriptedLLM struct {\n\tresponses []string\n\tidx       int\n}\n\nfunc (s *scriptedLLM) Complete(ctx context.Context, system, user string) (string, error) {\n\tresp := s.responses[s.idx]\n\ts.idx++\n\treturn resp, nil\n}\n\nfunc TestOrchestratorEndToEnd(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Set up project structure\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"Write good code.\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n  implement:success -> test\n  test:success -> done\n  test:fail -> abort\n}`), 0644)\n\n\t// Fake LLM that returns appropriate responses per stage\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t// Reflector\n\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t\t// Curator\n\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"bug\", result.Classification)\n\trequire.Len(t, result.Changes, 1)\n\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n\n\t// Verify prompt was actually updated\n\tcontent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n\tassert.Contains(t, string(content), \"sanitize user inputs\")\n\n\t// Verify audit log was written\n\tlogContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n\tassert.Contains(t, string(logContent), \"prompt_update\")\n\tassert.Contains(t, string(logContent), \"XSS pattern\")\n\n\t// Verify knowledge base was updated\n\tkbContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"))\n\tassert.Contains(t, string(kbContent), \"L001\")\n}\n\nfunc TestOrchestratorNoLessons(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step s {\n    run = \"echo hi\"\n    results = [success]\n  }\n  s:success -> done\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"feature\"}`,\n\t\t\t// Reflector â€” no lessons\n\t\t\t`{\"lessons\": []}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"feature\", result.Classification)\n\tassert.Empty(t, result.Changes)\n}\n","numLines":423,"startLine":1,"totalLines":423}}}
