n    56→\t}\n    57→}\n    58→\n    59→// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    60→func Load(projectDir string) (*Config, error) {\n    61→\tcfg := defaults()\n    62→\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    63→\n    64→\tdata, err := os.ReadFile(path)\n    65→\tif os.IsNotExist(err) {\n    66→\t\treturn &cfg, nil\n    67→\t}\n    68→\tif err != nil {\n    69→\t\treturn nil, err\n    70→\t}\n    71→\n    72→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    73→\t\treturn nil, err\n    74→\t}\n    75→\treturn &cfg, nil\n    76→}\n    77→\n    78→// LoadVersion reads the project version from .cloche/version.\n    79→// Returns 1 if the file does not exist.\n    80→func LoadVersion(projectDir string) (int, error) {\n    81→\tpath := filepath.Join(projectDir, \".cloche\", \"version\")\n    82→\tdata, err := os.ReadFile(path)\n    83→\tif os.IsNotExist(err) {\n    84→\t\treturn 1, nil\n    85→\t}\n    86→\tif err != nil {\n    87→\t\treturn 0, err\n    88→\t}\n    89→\tv, err := strconv.Atoi(strings.TrimSpace(string(data)))\n    90→\tif err != nil {\n    91→\t\treturn 0, fmt.Errorf(\"parsing version: %w\", err)\n    92→\t}\n    93→\treturn v, nil\n    94→}\n    95→\n    96→// IncrementProjectVersion atomically increments the integer in .cloche/version.\n    97→// If the file does not exist, it writes 2 (treating missing as implicit version 1).\n    98→func IncrementProjectVersion(projectDir string) error {\n    99→\tv, err := LoadVersion(projectDir)\n   100→\tif err != nil {\n   101→\t\treturn err\n   102→\t}\n   103→\tnext := strconv.Itoa(v+1) + \"\\n\"\n   104→\n   105→\tdir := filepath.Join(projectDir, \".cloche\")\n   106→\ttmp, err := os.CreateTemp(dir, \"version-*\")\n   107→\tif err != nil {\n   108→\t\treturn fmt.Errorf(\"creating temp file: %w\", err)\n   109→\t}\n   110→\ttmpName := tmp.Name()\n   111→\tif _, err := tmp.WriteString(next); err != nil {\n   112→\t\ttmp.Close()\n   113→\t\tos.Remove(tmpName)\n   114→\t\treturn err\n   115→\t}\n   116→\tif err := tmp.Close(); err != nil {\n   117→\t\tos.Remove(tmpName)\n   118→\t\treturn err\n   119→\t}\n   120→\ttarget := filepath.Join(dir, \"version\")\n   121→\tif err := os.Rename(tmpName, target); err != nil {\n   122→\t\tos.Remove(tmpName)\n   123→\t\treturn err\n   124→\t}\n   125→\treturn nil\n   126→}\n   127→\n   128→// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n   129→// Returns defaults if the file does not exist.\n   130→func LoadGlobal() (*Config, error) {\n   131→\tcfg := defaults()\n   132→\n   133→\thome, err := os.UserHomeDir()\n   134→\tif err != nil {\n   135→\t\treturn &cfg, nil\n   136→\t}\n   137→\n   138→\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n   139→\tdata, err := os.ReadFile(path)\n   140→\tif os.IsNotExist(err) {\n   141→\t\treturn &cfg, nil\n   142→\t}\n   143→\tif err != nil {\n   144→\t\treturn nil, err\n   145→\t}\n   146→\n   147→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   148→\t\treturn nil, err\n   149→\t}\n   150→\treturn &cfg, nil\n   151→}\n   152→\n   153→// LoadGlobalFrom reads the global config from a specific path.\n   154→// Useful for testing.\n   155→func LoadGlobalFrom(path string) (*Config, error) {\n   156→\tcfg := defaults()\n   157→\n   158→\tdata, err := os.ReadFile(path)\n   159→\tif os.IsNotExist(err) {\n   160→\t\treturn &cfg, nil\n   161→\t}\n   162→\tif err != nil {\n   163→\t\treturn nil, err\n   164→\t}\n   165→\n   166→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   167→\t\treturn nil, err\n   168→\t}\n   169→\treturn &cfg, nil\n   170→}\n   171→"}]},"parent_tool_use_id":null,"session_id":"012df8f2-7f15-4be4-918a-e3546bce6fc8","uuid":"78ccccfc-3eef-4a46-97d8-d1256ec10c94","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/config/config.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/BurntSushi/toml\"\n)\n\ntype DaemonConfig struct {\n\tListen     string `toml:\"listen\"`\n\tHTTP       string `toml:\"http\"`\n\tImage      string `toml:\"image\"`\n\tDB         string `toml:\"db\"`\n\tRuntime    string `toml:\"runtime\"`\n\tAgentPath  string `toml:\"agent_path\"`\n\tLLMCommand string `toml:\"llm_command\"`\n}\n\ntype EvolutionConfig struct {\n\tEnabled          bool   `toml:\"enabled\"`\n\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n\tMinConfidence    string `toml:\"min_confidence\"`\n\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n}\n\ntype OrchestrationConfig struct {\n\tEnabled     bool   `toml:\"enabled\"`\n\tTracker     string `toml:\"tracker\"`\n\tConcurrency int    `toml:\"concurrency\"`\n\tWorkflow    string `toml:\"workflow\"`\n}\n\ntype Config struct {\n\tDaemon        DaemonConfig        `toml:\"daemon\"`\n\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n}\n\nfunc defaults() Config {\n\treturn Config{\n\t\tEvolution: EvolutionConfig{\n\t\t\tEnabled:          true,\n\t\t\tDebounceSeconds:  30,\n\t\t\tMinConfidence:    \"medium\",\n\t\t\tMaxPromptBullets: 50,\n\t\t},\n\t\tOrchestration: OrchestrationConfig{\n\t\t\tTracker:     \"beads\",\n\t\t\tConcurrency: 1,\n\t\t\tWorkflow:     \"develop\",\n\t\t},\n\t}\n}\n\n// Load reads a per-project config from <projectDir>/.cloche/config.toml.\nfunc Load(projectDir string) (*Config, error) {\n\tcfg := defaults()\n\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadVersion reads the project version from .cloche/version.\n// Returns 1 if the file does not exist.\nfunc LoadVersion(projectDir string) (int, error) {\n\tpath := filepath.Join(projectDir, \".cloche\", \"version\")\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn 1, nil\n\t}\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\tv, err := strconv.Atoi(strings.TrimSpace(string(data)))\n\tif err != nil {\n\t\treturn 0, fmt.Errorf(\"parsing version: %w\", err)\n\t}\n\treturn v, nil\n}\n\n// IncrementProjectVersion atomically increments the integer in .cloche/version.\n// If the file does not exist, it writes 2 (treating missing as implicit version 1).\nfunc IncrementProjectVersion(projectDir string) error {\n\tv, err := LoadVersion(projectDir)\n\tif err != nil {\n\t\treturn err\n\t}\n\tnext := strconv.Itoa(v+1) + \"\\n\"\n\n\tdir := filepath.Join(projectDir, \".cloche\")\n\ttmp, err := os.CreateTemp(dir, \"version-*\")\n\tif err != nil {\n\t\treturn fmt.Errorf(\"creating temp file: %w\", err)\n\t}\n\ttmpName := tmp.Name()\n\tif _, err := tmp.WriteString(next); err != nil {\n\t\ttmp.Close()\n\t\tos.Remove(tmpName)\n\t\treturn err\n\t}\n\tif err := tmp.Close(); err != nil {\n\t\tos.Remove(tmpName)\n\t\treturn err\n\t}\n\ttarget := filepath.Join(dir, \"version\")\n\tif err := os.Rename(tmpName, target); err != nil {\n\t\tos.Remove(tmpName)\n\t\treturn err\n\t}\n\treturn nil\n}\n\n// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n// Returns defaults if the file does not exist.\nfunc LoadGlobal() (*Config, error) {\n\tcfg := defaults()\n\n\thome, err := os.UserHomeDir()\n\tif err != nil {\n\t\treturn &cfg, nil\n\t}\n\n\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadGlobalFrom reads the global config from a specific path.\n// Useful for testing.\nfunc LoadGlobalFrom(path string) (*Config, error) {\n\tcfg := defaults()\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n","numLines":171,"startLine":1,"totalLines":171}}}
