uccess, fail]\n   115→  }\n   116→\n   117→  step develop {\n   118→    workflow_name = \"develop\"\n   119→    results       = [success, fail]\n   120→  }\n   121→\n   122→  prepare-prompt:success -> develop\n   123→  prepare-prompt:fail    -> abort\n   124→  develop:success        -> done\n   125→  develop:fail           -> done\n   126→}\n   127→`\n   128→\n   129→var preparePromptScript = `#!/usr/bin/env bash\n   130→# Default prompt generator.\n   131→# Writes the task prompt to stdout and to $CLOCHE_STEP_OUTPUT.\n   132→set -euo pipefail\n   133→\n   134→prompt=\"## Task: ${CLOCHE_TASK_TITLE}\n   135→\n   136→${CLOCHE_TASK_BODY}\"\n   137→\n   138→echo \"$prompt\"\n   139→[ -n \"${CLOCHE_STEP_OUTPUT:-}\" ] && echo \"$prompt\" > \"$CLOCHE_STEP_OUTPUT\"\n   140→`\n   141→\n   142→func cmdInit(args []string) {\n   143→\tworkflow := \"develop\"\n   144→\tbaseImage := \"cloche-base:latest\"\n   145→\n   146→\tfor i := 0; i < len(args); i++ {\n   147→\t\tswitch args[i] {\n   148→\t\tcase \"--workflow\":\n   149→\t\t\tif i+1 < len(args) {\n   150→\t\t\t\ti++\n   151→\t\t\t\tworkflow = args[i]\n   152→\t\t\t}\n   153→\t\tcase \"--base-image\":\n   154→\t\t\tif i+1 < len(args) {\n   155→\t\t\t\ti++\n   156→\t\t\t\tbaseImage = args[i]\n   157→\t\t\t}\n   158→\t\t}\n   159→\t}\n   160→\n   161→\tclocheDir := \".cloche\"\n   162→\tworkflowFile := filepath.Join(clocheDir, workflow+\".cloche\")\n   163→\n   164→\t// Refuse to overwrite existing workflow\n   165→\tif _, err := os.Stat(workflowFile); err == nil {\n   166→\t\tfmt.Fprintf(os.Stderr, \"error: %s already exists\\n\", workflowFile)\n   167→\t\tos.Exit(1)\n   168→\t}\n   169→\n   170→\t// Create directories\n   171→\tfor _, dir := range []string{\n   172→\t\tclocheDir,\n   173→\t\tfilepath.Join(clocheDir, \"prompts\"),\n   174→\t\tfilepath.Join(clocheDir, \"overrides\"),\n   175→\t\tfilepath.Join(clocheDir, \"scripts\"),\n   176→\t} {\n   177→\t\tif err := os.MkdirAll(dir, 0755); err != nil {\n   178→\t\t\tfmt.Fpri