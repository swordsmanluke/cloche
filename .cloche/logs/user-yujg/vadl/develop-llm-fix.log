n   107→[orchestration]\n   108→enabled = true\n   109→tracker = \"beads\"\n   110→concurrency = 3\n   111→workflow = \"build\"\n   112→`), 0644)\n   113→\n   114→\tcfg, err := Load(dir)\n   115→\trequire.NoError(t, err)\n   116→\tassert.True(t, cfg.Orchestration.Enabled)\n   117→\tassert.Equal(t, \"beads\", cfg.Orchestration.Tracker)\n   118→\tassert.Equal(t, 3, cfg.Orchestration.Concurrency)\n   119→\tassert.Equal(t, \"build\", cfg.Orchestration.Workflow)\n   120→}\n   121→\n   122→func TestLoadOrchestrationConfigDefaults(t *testing.T) {\n   123→\tdir := t.TempDir()\n   124→\n   125→\tcfg, err := Load(dir)\n   126→\trequire.NoError(t, err)\n   127→\t// Defaults: not enabled, beads tracker, concurrency 1, develop workflow\n   128→\tassert.False(t, cfg.Orchestration.Enabled)\n   129→\tassert.Equal(t, \"beads\", cfg.Orchestration.Tracker)\n   130→\tassert.Equal(t, 1, cfg.Orchestration.Concurrency)\n   131→\tassert.Equal(t, \"develop\", cfg.Orchestration.Workflow)\n   132→}\n   133→\n   134→func TestLoadVersionDefault(t *testing.T) {\n   135→\tdir := t.TempDir()\n   136→\n   137→\tv, err := LoadVersion(dir)\n   138→\trequire.NoError(t, err)\n   139→\tassert.Equal(t, 1, v)\n   140→}\n   141→\n   142→func TestLoadVersionFromFile(t *testing.T) {\n   143→\tdir := t.TempDir()\n   144→\tclocheDir := filepath.Join(dir, \".cloche\")\n   145→\tos.MkdirAll(clocheDir, 0755)\n   146→\tos.WriteFile(filepath.Join(clocheDir, \"version\"), []byte(\"5\\n\"), 0644)\n   147→\n   148→\tv, err := LoadVersion(dir)\n   149→\trequire.NoError(t, err)\n   150→\tassert.Equal(t, 5, v)\n   151→}\n   152→\n   153→func TestLoadVersionInvalidContent(t *testing.T) {\n   154→\tdir := t.TempDir()\n   155→\tclocheDir := filepath.Join(dir, \".cloche\")\n   156→\tos.MkdirAll(clocheDir, 0755)\n   157→\tos.WriteFile(filepath.Join(clocheDir, \"version\"), []byte(\"abc\\n\"), 0644)\n   158→\n   159→\t_, err := LoadVersion(dir)\n   160→\tassert.Error(t, err)\n   161→}\n   162→\n   163→func TestIncrementProject