→\n    59→// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    60→func Load(projectDir string) (*Config, error) {\n    61→\tcfg := defaults()\n    62→\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    63→\n    64→\tdata, err := os.ReadFile(path)\n    65→\tif os.IsNotExist(err) {\n    66→\t\treturn &cfg, nil\n    67→\t}\n    68→\tif err != nil {\n    69→\t\treturn nil, err\n    70→\t}\n    71→\n    72→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    73→\t\treturn nil, err\n    74→\t}\n    75→\treturn &cfg, nil\n    76→}\n    77→\n    78→// LoadVersion reads the project version from .cloche/version.\n    79→// Returns 1 if the file does not exist.\n    80→func LoadVersion(projectDir string) (int, error) {\n    81→\tpath := filepath.Join(projectDir, \".cloche\", \"version\")\n    82→\tdata, err := os.ReadFile(path)\n    83→\tif os.IsNotExist(err) {\n    84→\t\treturn 1, nil\n    85→\t}\n    86→\tif err != nil {\n    87→\t\treturn 0, err\n    88→\t}\n    89→\tv, err := strconv.Atoi(strings.TrimSpace(string(data)))\n    90→\tif err != nil {\n    91→\t\treturn 0, fmt.Errorf(\"parsing version: %w\", err)\n    92→\t}\n    93→\treturn v, nil\n    94→}\n    95→\n    96→// IncrementProjectVersion atomically increments the integer in .cloche/version.\n    97→// If the file does not exist, it writes 2 (treating missing as implicit version 1).\n    98→func IncrementProjectVersion(projectDir string) error {\n    99→\tv, err := LoadVersion(projectDir)\n   100→\tif err != nil {\n   101→\t\treturn err\n   102→\t}\n   103→\tnext := strconv.Itoa(v+1) + \"\\n\"\n   104→\n   105→\tdir := filepath.Join(projectDir, \".cloche\")\n   106→\ttmp, err := os.CreateTemp(dir, \"version-*\")\n   107→\tif err != nil {\n   108→\t\treturn fmt.Errorf(\"creating temp file: %w\", err)\n   109→\t}\n   110→\ttmpName := tmp.Name()\n   111→\tif _, err := tmp.WriteString(next); err != nil {\n   112→\t\ttmp.Close()\n   113→\t\tos.Remove(tmpName)\n 