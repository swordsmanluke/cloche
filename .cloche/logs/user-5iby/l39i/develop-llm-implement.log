{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JvtW6eWS2MLq6z654MC84b","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"net\"\n     7→\t\"net/http\"\n     8→\t\"os\"\n     9→\t\"os/signal\"\n    10→\t\"path/filepath\"\n    11→\t\"syscall\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    15→\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    16→\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    19→\t\"github.com/cloche-dev/cloche/internal/config\"\n    20→\t_ \"github.com/cloche-dev/cloche/internal/domain\"\n    21→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    22→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    23→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    24→\t\"google.golang.org/grpc\"\n    25→)\n    26→\n    27→func main() {\n    28→\t// Load global config file (~/.config/cloche/config)\n    29→\tglobalCfg, err := config.LoadGlobal()\n    30→\tif err != nil {\n    31→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n    32→\t\tdefaults := config.Config{}\n    33→\t\tglobalCfg = &defaults\n    34→\t}\n    35→\n    36→\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, \"cloche.db\")\n    37→\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, \"unix:///tmp/cloche.sock\")\n    38→\n    39→\tstore, err := sqlite.NewStore(dbPath)\n    40→\tif err != nil {\n    41→\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    42→\t\tos.Exit(1)\n    43→\t}\n    44→\tdefer store.Close()\n    45→\n    46→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    47→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    48→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    49→\t} else if n > 0 {\n    50→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    51→\t}\n    52→\n    53→\truntime, err := initRuntime(globalCfg)\n    54→\tif err != nil {\n    55→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    56→\t\tos.Exit(1)\n    57→\t}\n    58→\n    59→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    60→\n    61→\tbroadcaster := logstream.NewBroadcaster()\n    62→\n    63→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    64→\tsrv.SetLogStore(store)\n    65→\tsrv.SetLogBroadcaster(broadcaster)\n    66→\n    67→\t// Set up evolution trigger\n    68→\tevoTrigger := initEvolution(globalCfg, store, store)\n    69→\tif evoTrigger != nil {\n    70→\t\tsrv.SetEvolution(evoTrigger)\n    71→\t}\n    72→\n    73→\tgrpcServer := grpc.NewServer()\n    74→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    75→\n    76→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    77→\n    78→\tlis, err := listen(listenAddr)\n    79→\tif err != nil {\n    80→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    81→\t\tos.Exit(1)\n    82→\t}\n    83→\n    84→\tvar httpServer *http.Server\n    85→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n    86→\t\twebOpts := []web.HandlerOption{\n    87→\t\t\tweb.WithContainerLogger(runtime),\n    88→\t\t\tweb.WithLogStore(store),\n    89→\t\t\tweb.WithLogBroadcaster(broadcaster),\n    90→\t\t}\n    91→\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n    92→\t\tif err != nil {\n    93→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n    94→\t\t\tos.Exit(1)\n    95→\t\t}\n    96→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n    97→\t\tgo func() {\n    98→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n    99→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   100→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   101→\t\t\t}\n   102→\t\t}()\n   103→\t}\n   104→\n   105→\tsigCh := make(chan os.Signal, 1)\n   106→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   107→\tgo func() {\n   108→\t\t<-sigCh\n   109→\t\tif httpServer != nil {\n   110→\t\t\thttpServer.Close()\n   111→\t\t}\n   112→\t\tgrpcServer.GracefulStop()\n   113→\t}()\n   114→\n   115→\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   116→\tif err := grpcServer.Serve(lis); err != nil {\n   117→\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   118→\t\tos.Exit(1)\n   119→\t}\n   120→}\n   121→\n   122→func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   123→\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   124→\n   125→\tswitch runtimeType {\n   126→\tcase \"local\":\n   127→\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   128→\t\tif agentPath == \"\" {\n   129→\t\t\t// Look for cloche-agent next to this binary\n   130→\t\t\texe, err := os.Executable()\n   131→\t\t\tif err == nil {\n   132→\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   133→\t\t\t} else {\n   134→\t\t\t\tagentPath = \"cloche-agent\"\n   135→\t\t\t}\n   136→\t\t}\n   137→\t\treturn local.NewRuntime(agentPath), nil\n   138→\tcase \"docker\":\n   139→\t\treturn docker.NewRuntime()\n   140→\tdefault:\n   141→\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   142→\t}\n   143→}\n   144→\n   145→func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   146→\t// Load config from working directory (daemon-level defaults)\n   147→\tcfg, err := config.Load(\".\")\n   148→\tif err != nil || !cfg.Evolution.Enabled {\n   149→\t\treturn nil\n   150→\t}\n   151→\n   152→\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   153→\tif llmCmd == \"\" {\n   154→\t\treturn nil\n   155→\t}\n   156→\n   157→\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   158→\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   159→\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   160→\t\t\t// Load per-project config for confidence threshold\n   161→\t\t\tprojCfg, err := config.Load(projectDir)\n   162→\t\t\tif err != nil {\n   163→\t\t\t\tprojCfg = cfg // fall back to daemon config\n   164→\t\t\t}\n   165→\n   166→\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   167→\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   168→\t\t\t\tProjectDir:    projectDir,\n   169→\t\t\t\tWorkflowName:  workflowName,\n   170→\t\t\t\tLLM:           llm,\n   171→\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   172→\t\t\t})\n   173→\n   174→\t\t\tctx := context.Background()\n   175→\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   176→\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   177→\t\t\t}\n   178→\t\t},\n   179→\t})\n   180→\n   181→\treturn trigger\n   182→}\n   183→\n   184→func listen(addr string) (net.Listener, error) {\n   185→\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   186→\t\tsockPath := addr[7:]\n   187→\t\tos.Remove(sockPath)\n   188→\t\treturn net.Listen(\"unix\", sockPath)\n   189→\t}\n   190→\treturn net.Listen(\"tcp\", addr)\n   191→}\n   192→\n   193→// envOrConfig returns the env var value if set, otherwise the config file\n   194→// value if non-empty, otherwise the fallback default.\n   195→func envOrConfig(envKey, configVal, fallback string) string {\n   196→\tif v := os.Getenv(envKey); v != \"\" {\n   197→\t\treturn v\n   198→\t}\n   199→\tif configVal != \"\" {\n   200→\t\treturn configVal\n   201→\t}\n   202→\treturn fallback\n   203→}\n   204→"}]},"parent_tool_use_id":"toolu_0178Fx9DkF5kR6HuyT1bAmTp","session_id":"bfbfa05f-1a70-4d4a-b95c-68347a51b3e3","uuid":"8749a17e-3dce-4cae-9f11-46ab590178b1"}
