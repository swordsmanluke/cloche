{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BEMSuHKqKPqGsF8Mtyz5cP","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    19→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    20→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    21→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    22→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    23→\trpcgrpc \"google.golang.org/grpc\"\n    24→)\n    25→\n    26→type ClocheServer struct {\n    27→\tpb.UnimplementedClocheServiceServer\n    28→\tstore        ports.RunStore\n    29→\tcaptures     ports.CaptureStore\n    30→\tlogStore     ports.LogStore\n    31→\tcontainer    ports.ContainerRuntime\n    32→\tdefaultImage string\n    33→\tevolution    *evolution.Trigger\n    34→\tlogBroadcast *logstream.Broadcaster\n    35→\tshutdownFn   func()\n    36→\tmu           sync.Mutex\n    37→\trunIDs       map[string]string // run_id -> container_id\n    38→}\n    39→\n    40→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    41→\treturn &ClocheServer{\n    42→\t\tstore:     store,\n    43→\t\tcontainer: container,\n    44→\t\trunIDs:    make(map[string]string),\n    45→\t}\n    46→}\n    47→\n    48→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    49→\treturn &ClocheServer{\n    50→\t\tstore:        store,\n    51→\t\tcaptures:     captures,\n    52→\t\tcontainer:    container,\n    53→\t\tdefaultImage: defaultImage,\n    54→\t\trunIDs:       make(map[string]string),\n    55→\t}\n    56→}\n    57→\n    58→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    59→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    60→\ts.logStore = ls\n    61→}\n    62→\n    63→\n    64→// SetEvolution attaches an evolution trigger to the server.\n    65→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    66→\ts.evolution = trigger\n    67→}\n    68→\n    69→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    70→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    71→\ts.logBroadcast = b\n    72→}\n    73→\n    74→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    75→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    76→\ts.shutdownFn = fn\n    77→}\n    78→\n    79→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    80→\tif s.container == nil {\n    81→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    82→\t}\n    83→\n    84→\t// Generate a unique run ID, retrying on collision\n    85→\tvar runID string\n    86→\tfor attempts := 0; attempts < 10; attempts++ {\n    87→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    88→\t\texisting, err := s.store.GetRun(ctx, runID)\n    89→\t\tif err != nil {\n    90→\t\t\tbreak // ID is free\n    91→\t\t}\n    92→\t\t// Reuse if completed more than 1 hour ago\n    93→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n    94→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n    95→\t\t\tbreak\n    96→\t\t}\n    97→\t}\n    98→\n    99→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   100→\tif req.Prompt != \"\" {\n   101→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   102→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   103→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   104→\t\t}\n   105→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   106→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   107→\t\t}\n   108→\t}\n   109→\trun := domain.NewRun(runID, req.WorkflowName)\n   110→\trun.ProjectDir = req.ProjectDir\n   111→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   112→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   113→\t}\n   114→\n   115→\t// Resolve image: request-level override, then server default\n   116→\timage := req.Image\n   117→\tif image == \"\" {\n   118→\t\timage = s.defaultImage\n   119→\t}\n   120→\n   121→\t// Launch container start + tracking in background so the RPC returns immediately.\n   122→\t// The run stays in \"pending\" state until the container is up.\n   123→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   124→\n   125→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   126→}\n   127→\n   128→// launchAndTrack starts the container and then tracks it to completion.\n   129→// It runs in a background goroutine with its own context, independent of the\n   130→// RPC context which may be cancelled after RunWorkflow returns.\n   131→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   132→\tctx := context.Background()\n   133→\n   134→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   135→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   136→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   137→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   138→\t\t\tif run != nil {\n   139→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   140→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   141→\t\t\t}\n   142→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   143→\t\t\treturn\n   144→\t\t}\n   145→\t}\n   146→\n   147→\tbaseSHA := gitHEAD(req.ProjectDir)\n   148→\n   149→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   150→\t\tImage:        image,\n   151→\t\tWorkflowName: req.WorkflowName,\n   152→\t\tProjectDir:   req.ProjectDir,\n   153→\t\tRunID:        runID,\n   154→\t\tNetworkAllow: []string{\"*\"},\n   155→\t})\n   156→\tif err != nil {\n   157→\t\trun, _ := s.store.GetRun(ctx, runID)\n   158→\t\tif run != nil {\n   159→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   160→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   161→\t\t}\n   162→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   163→\t\treturn\n   164→\t}\n   165→\n   166→\ts.mu.Lock()\n   167→\ts.runIDs[runID] = containerID\n   168→\ts.mu.Unlock()\n   169→\n   170→\trun, _ := s.store.GetRun(ctx, runID)\n   171→\tif run != nil {\n   172→\t\trun.Start()\n   173→\t\trun.ContainerID = containerID\n   174→\t\trun.BaseSHA = baseSHA\n   175→\t\t_ = s.store.UpdateRun(ctx, run)\n   176→\t}\n   177→\n   178→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   179→}\n   180→\n   181→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   182→\tctx := context.Background()\n   183→\n   184→\t// Attach to agent output\n   185→\treader, err := s.container.AttachOutput(ctx, containerID)\n   186→\tif err != nil {\n   187→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   188→\t\treturn\n   189→\t}\n   190→\n   191→\t// Parse JSON-lines status messages\n   192→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   193→\tscanner := bufio.NewScanner(reader)\n   194→\tfor scanner.Scan() {\n   195→\t\tvar msg protocol.StatusMessage\n   196→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   197→\t\t\tcontinue\n   198→\t\t}\n   199→\n   200→\t\t// Fast path: log messages don't need store interaction.\n   201→\t\tif msg.Type == protocol.MsgLog {\n   202→\t\t\tif s.logBroadcast != nil {\n   203→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   204→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   205→\t\t\t\t\tType:      \"llm\",\n   206→\t\t\t\t\tContent:   msg.Message,\n   207→\t\t\t\t})\n   208→\t\t\t}\n   209→\t\t\tcontinue\n   210→\t\t}\n   211→\n   212→\t\trun, err := s.store.GetRun(ctx, runID)\n   213→\t\tif err != nil {\n   214→\t\t\tcontinue\n   215→\t\t}\n   216→\n   217→\t\tswitch msg.Type {\n   218→\t\tcase protocol.MsgStepStarted:\n   219→\t\t\trun.RecordStepStart(msg.StepName)\n   220→\t\t\tif s.captures != nil {\n   221→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   222→\t\t\t\t\tStepName:  msg.StepName,\n   223→\t\t\t\t\tStartedAt: msg.Timestamp,\n   224→\t\t\t\t})\n   225→\t\t\t}\n   226→\t\tcase protocol.MsgStepCompleted:\n   227→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   228→\t\t\tif s.captures != nil {\n   229→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   230→\t\t\t\t\tStepName:    msg.StepName,\n   231→\t\t\t\t\tResult:      msg.Result,\n   232→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   233→\t\t\t\t})\n   234→\t\t\t}\n   235→\t\tcase protocol.MsgRunCompleted:\n   236→\t\t\treportedResult = msg.Result\n   237→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   238→\t\t}\n   239→\n   240→\t\t_ = s.store.UpdateRun(ctx, run)\n   241→\t}\n   242→\treader.Close()\n   243→\n   244→\t// Signal live-stream subscribers that this run is done.\n   245→\tif s.logBroadcast != nil {\n   246→\t\ts.logBroadcast.Finish(runID)\n   247→\t}\n   248→\n   249→\t// Wait for process exit\n   250→\texitCode, err := s.container.Wait(ctx, containerID)\n   251→\tif err != nil {\n   252→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   253→\t}\n   254→\n   255→\t// Extract step output files from container before it's removed\n   256→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   257→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   258→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   259→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   260→\t\t}\n   261→\t}\n   262→\n   263→\t// Capture full container stdout/stderr before the container is removed\n   264→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   265→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   266→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   267→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   268→\t\t}\n   269→\t}\n   270→\n   271→\t// Index extracted log files in the log store\n   272→\tif s.logStore != nil {\n   273→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   274→\t}\n   275→\n   276→\t// Extract results to git branch BEFORE finalizing state, so that\n   277→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   278→\t// before the run is marked complete.\n   279→\tresultLabel := reportedResult\n   280→\tif resultLabel == \"\" {\n   281→\t\tif exitCode == 0 {\n   282→\t\t\tresultLabel = \"succeeded\"\n   283→\t\t} else {\n   284→\t\t\tresultLabel = \"failed\"\n   285→\t\t}\n   286→\t}\n   287→\t{\n   288→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   289→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   290→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   291→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   292→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   293→\t\t\t} else {\n   294→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   295→\t\t\t}\n   296→\t\t} else {\n   297→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   298→\t\t}\n   299→\t}\n   300→\n   301→\t// Now finalize run state\n   302→\trun, err := s.store.GetRun(ctx, runID)\n   303→\tif err != nil {\n   304→\t\treturn\n   305→\t}\n   306→\tif run.State == domain.RunStateRunning {\n   307→\t\tif reportedResult == \"succeeded\" {\n   308→\t\t\trun.Complete(domain.RunStateSucceeded)\n   309→\t\t} else if reportedResult != \"\" {\n   310→\t\t\trun.Complete(domain.RunStateFailed)\n   311→\t\t} else if exitCode == 0 {\n   312→\t\t\trun.Complete(domain.RunStateSucceeded)\n   313→\t\t} else {\n   314→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   315→\t\t}\n   316→\t\t_ = s.store.UpdateRun(ctx, run)\n   317→\t}\n   318→\n   319→\t// Fire evolution trigger if configured\n   320→\tif s.evolution != nil {\n   321→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   322→\t}\n   323→\n   324→\t// Merge is handled as a workflow step in host.cloche, not here.\n   325→\n   326→\t// Container retention policy:\n   327→\t// - Failed runs: always keep the container for debugging\n   328→\t// - Successful runs + --keep-container: keep the container\n   329→\t// - Successful runs without --keep-container: remove the container\n   330→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   331→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   332→\n   333→\tif keepContainer || runFailed {\n   334→\t\treason := \"--keep-container\"\n   335→\t\tif runFailed {\n   336→\t\t\treason = \"run failed\"\n   337→\t\t}\n   338→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   339→\t\tif runFinal != nil {\n   340→\t\t\trunFinal.ContainerKept = true\n   341→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   342→\t\t}\n   343→\t} else {\n   344→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   345→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   346→\t\t} else {\n   347→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   348→\t\t}\n   349→\t}\n   350→\n   351→\t// Cleanup mapping\n   352→\ts.mu.Lock()\n   353→\tdelete(s.runIDs, runID)\n   354→\ts.mu.Unlock()\n   355→}\n   356→\n   357→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   358→\tvar since time.Time\n   359→\tif !req.All {\n   360→\t\tsince = time.Now().Add(-1 * time.Hour)\n   361→\t}\n   362→\truns, err := s.store.ListRuns(ctx, since)\n   363→\tif err != nil {\n   364→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   365→\t}\n   366→\n   367→\tresp := &pb.ListRunsResponse{}\n   368→\tfor _, run := range runs {\n   369→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   370→\t\t\tRunId:        run.ID,\n   371→\t\t\tWorkflowName: run.WorkflowName,\n   372→\t\t\tState:        string(run.State),\n   373→\t\t\tStartedAt:    run.StartedAt.String(),\n   374→\t\t\tErrorMessage: run.ErrorMessage,\n   375→\t\t\tContainerId:  run.ContainerID,\n   376→\t\t})\n   377→\t}\n   378→\treturn resp, nil\n   379→}\n   380→\n   381→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   382→\trun, err := s.store.GetRun(ctx, req.RunId)\n   383→\tif err != nil {\n   384→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   385→\t}\n   386→\n   387→\tresp := &pb.GetStatusResponse{\n   388→\t\tRunId:        run.ID,\n   389→\t\tWorkflowName: run.WorkflowName,\n   390→\t\tState:        string(run.State),\n   391→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   392→\t\tErrorMessage: run.ErrorMessage,\n   393→\t\tContainerId:  run.ContainerID,\n   394→\t}\n   395→\n   396→\t// Check container liveness\n   397→\tif run.ContainerID != \"\" && s.container != nil {\n   398→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   399→\t\t\tresp.ContainerAlive = cs.Running\n   400→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   401→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   402→\t\t\t}\n   403→\t\t}\n   404→\t}\n   405→\n   406→\t// Load step executions from captures store if available\n   407→\tif s.captures != nil {\n   408→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   409→\t\tif err == nil {\n   410→\t\t\tfor _, exec := range captures {\n   411→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   412→\t\t\t\t\tStepName:    exec.StepName,\n   413→\t\t\t\t\tResult:      exec.Result,\n   414→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   415→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   416→\t\t\t\t})\n   417→\t\t\t}\n   418→\t\t}\n   419→\t} else {\n   420→\t\tfor _, exec := range run.StepExecutions {\n   421→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   422→\t\t\t\tStepName:    exec.StepName,\n   423→\t\t\t\tResult:      exec.Result,\n   424→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   425→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   426→\t\t\t})\n   427→\t\t}\n   428→\t}\n   429→\n   430→\treturn resp, nil\n   431→}\n   432→\n   433→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   434→\tctx := stream.Context()\n   435→\n   436→\t// Verify run exists\n   437→\trun, err := s.store.GetRun(ctx, req.RunId)\n   438→\tif err != nil {\n   439→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   440→\t}\n   441→\n   442→\t// If step_name or log_type filter is set, serve content directly from the log index\n   443→\tif req.StepName != \"\" || req.LogType != \"\" {\n   444→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   445→\t}\n   446→\n   447→\tif s.captures == nil {\n   448→\t\treturn fmt.Errorf(\"captures store not configured\")\n   449→\t}\n   450→\n   451→\t// Check for full.log first — if it exists, serve it as the unified log\n   452→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   453→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   454→\t\tif err := stream.Send(&pb.LogEntry{\n   455→\t\t\tType:    \"full_log\",\n   456→\t\t\tMessage: string(data),\n   457→\t\t}); err != nil {\n   458→\t\t\treturn err\n   459→\t\t}\n   460→\t\t// Still send run completion entry\n   461→\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   462→\t\t\tif err := stream.Send(&pb.LogEntry{\n   463→\t\t\t\tType:      \"run_completed\",\n   464→\t\t\t\tResult:    string(run.State),\n   465→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   466→\t\t\t\tMessage:   run.ErrorMessage,\n   467→\t\t\t}); err != nil {\n   468→\t\t\t\treturn err\n   469→\t\t\t}\n   470→\t\t}\n   471→\t\treturn nil\n   472→\t}\n   473→\n   474→\t// Fall back to capture-based streaming\n   475→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   476→\tif err != nil {\n   477→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   478→\t}\n   479→\n   480→\tfor _, exec := range captures {\n   481→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   482→\t\t// and one for step_completed (has Result).\n   483→\t\tif exec.Result == \"\" {\n   484→\t\t\tentry := &pb.LogEntry{\n   485→\t\t\t\tType:      \"step_started\",\n   486→\t\t\t\tStepName:  exec.StepName,\n   487→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   488→\t\t\t}\n   489→\t\t\tif err := stream.Send(entry); err != nil {\n   490→\t\t\t\treturn err\n   491→\t\t\t}\n   492→\t\t} else {\n   493→\t\t\t// Read step output from file, falling back to container.log\n   494→\t\t\tvar output string\n   495→\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   496→\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   497→\t\t\t\toutput = string(data)\n   498→\t\t\t} else {\n   499→\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n   500→\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n   501→\t\t\t\t\toutput = string(data)\n   502→\t\t\t\t}\n   503→\t\t\t}\n   504→\t\t\tentry := &pb.LogEntry{\n   505→\t\t\t\tType:      \"step_completed\",\n   506→\t\t\t\tStepName:  exec.StepName,\n   507→\t\t\t\tResult:    exec.Result,\n   508→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   509→\t\t\t\tMessage:   output,\n   510→\t\t\t}\n   511→\t\t\tif err := stream.Send(entry); err != nil {\n   512→\t\t\t\treturn err\n   513→\t\t\t}\n   514→\t\t}\n   515→\t}\n   516→\n   517→\t// Send run completion entry\n   518→\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   519→\t\tif err := stream.Send(&pb.LogEntry{\n   520→\t\t\tType:      \"run_completed\",\n   521→\t\t\tResult:    string(run.State),\n   522→\t\t\tTimestamp: run.CompletedAt.String(),\n   523→\t\t\tMessage:   run.ErrorMessage,\n   524→\t\t}); err != nil {\n   525→\t\t\treturn err\n   526→\t\t}\n   527→\t}\n   528→\n   529→\treturn nil\n   530→}\n   531→\n   532→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   533→// It uses the log index when available, falling back to file path conventions.\n   534→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   535→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   536→\n   537→\t// Try log index first\n   538→\tif s.logStore != nil {\n   539→\t\tvar logFiles []*ports.LogFileEntry\n   540→\t\tvar err error\n   541→\n   542→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   543→\t\t\t// Filter by both step and type\n   544→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   545→\t\t\tif err == nil {\n   546→\t\t\t\tfiltered := logFiles[:0]\n   547→\t\t\t\tfor _, lf := range logFiles {\n   548→\t\t\t\t\tif lf.FileType == req.LogType {\n   549→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   550→\t\t\t\t\t}\n   551→\t\t\t\t}\n   552→\t\t\t\tlogFiles = filtered\n   553→\t\t\t}\n   554→\t\t} else if req.StepName != \"\" {\n   555→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   556→\t\t} else {\n   557→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   558→\t\t}\n   559→\n   560→\t\tif err == nil && len(logFiles) > 0 {\n   561→\t\t\tfor _, lf := range logFiles {\n   562→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   563→\t\t\t\tif readErr != nil {\n   564→\t\t\t\t\tcontinue\n   565→\t\t\t\t}\n   566→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   567→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   568→\t\t\t\t\tStepName: lf.StepName,\n   569→\t\t\t\t\tMessage:  string(data),\n   570→\t\t\t\t}); err != nil {\n   571→\t\t\t\t\treturn err\n   572→\t\t\t\t}\n   573→\t\t\t}\n   574→\t\t\treturn nil\n   575→\t\t}\n   576→\t}\n   577→\n   578→\t// Fall back to file path conventions\n   579→\tif req.StepName != \"\" {\n   580→\t\tvar logPath string\n   581→\t\tswitch req.LogType {\n   582→\t\tcase \"llm\":\n   583→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   584→\t\tdefault:\n   585→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   586→\t\t}\n   587→\n   588→\t\tdata, err := os.ReadFile(logPath)\n   589→\t\tif err != nil {\n   590→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   591→\t\t}\n   592→\t\treturn stream.Send(&pb.LogEntry{\n   593→\t\t\tType:     \"step_log\",\n   594→\t\t\tStepName: req.StepName,\n   595→\t\t\tMessage:  string(data),\n   596→\t\t})\n   597→\t}\n   598→\n   599→\treturn fmt.Errorf(\"no log files found matching filter\")\n   600→}\n   601→\n   602→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   603→\ts.mu.Lock()\n   604→\tcontainerID, ok := s.runIDs[req.RunId]\n   605→\ts.mu.Unlock()\n   606→\n   607→\tif !ok {\n   608→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   609→\t}\n   610→\n   611→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   612→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   613→\t}\n   614→\n   615→\t// Mark as cancelled in store\n   616→\trun, err := s.store.GetRun(ctx, req.RunId)\n   617→\tif err == nil {\n   618→\t\trun.Complete(domain.RunStateCancelled)\n   619→\t\t_ = s.store.UpdateRun(ctx, run)\n   620→\t}\n   621→\n   622→\treturn &pb.StopRunResponse{}, nil\n   623→}\n   624→\n   625→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   626→\tif s.container == nil {\n   627→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   628→\t}\n   629→\n   630→\tid := req.Id\n   631→\tif id == \"\" {\n   632→\t\treturn nil, fmt.Errorf(\"id is required\")\n   633→\t}\n   634→\n   635→\t// Try to resolve as a run ID first\n   636→\tcontainerID := id\n   637→\trun, err := s.store.GetRun(ctx, id)\n   638→\tif err == nil {\n   639→\t\t// It's a run ID — use the container ID from the run record\n   640→\t\tif run.ContainerID == \"\" {\n   641→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   642→\t\t}\n   643→\t\tcontainerID = run.ContainerID\n   644→\t}\n   645→\n   646→\t// Remove the container\n   647→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   648→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   649→\t}\n   650→\n   651→\t// If we resolved a run, clear the container_kept flag\n   652→\tif run != nil {\n   653→\t\trun.ContainerKept = false\n   654→\t\t_ = s.store.UpdateRun(ctx, run)\n   655→\t}\n   656→\n   657→\treturn &pb.DeleteContainerResponse{}, nil\n   658→}\n   659→\n   660→func (s *ClocheServer) Orchestrate(ctx context.Context, req *pb.OrchestrateRequest) (*pb.OrchestrateResponse, error) {\n   661→\treturn nil, fmt.Errorf(\"orchestrator has been removed; use host workflow instead\")\n   662→}\n   663→\n   664→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n   665→\tif s.shutdownFn == nil {\n   666→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n   667→\t}\n   668→\tgo s.shutdownFn()\n   669→\treturn &pb.ShutdownResponse{}, nil\n   670→}\n   671→\n   672→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n   673→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n   674→\tentries, err := os.ReadDir(outputDir)\n   675→\tif err != nil {\n   676→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n   677→\t\treturn\n   678→\t}\n   679→\n   680→\tnow := time.Now()\n   681→\tfor _, entry := range entries {\n   682→\t\tif entry.IsDir() {\n   683→\t\t\tcontinue\n   684→\t\t}\n   685→\t\tname := entry.Name()\n   686→\t\tif !strings.HasSuffix(name, \".log\") {\n   687→\t\t\tcontinue\n   688→\t\t}\n   689→\n   690→\t\tvar fileType, stepName string\n   691→\t\tbase := strings.TrimSuffix(name, \".log\")\n   692→\n   693→\t\tswitch {\n   694→\t\tcase name == \"full.log\":\n   695→\t\t\tfileType = \"full\"\n   696→\t\tcase name == \"container.log\":\n   697→\t\t\t// container.log is internal, not indexed as a user-facing log type\n   698→\t\t\tcontinue\n   699→\t\tcase strings.HasPrefix(name, \"llm-\"):\n   700→\t\t\tfileType = \"llm\"\n   701→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n   702→\t\tdefault:\n   703→\t\t\tfileType = \"script\"\n   704→\t\t\tstepName = base\n   705→\t\t}\n   706→\n   707→\t\tinfo, _ := entry.Info()\n   708→\t\tvar fileSize int64\n   709→\t\tif info != nil {\n   710→\t\t\tfileSize = info.Size()\n   711→\t\t}\n   712→\n   713→\t\tlogEntry := &ports.LogFileEntry{\n   714→\t\t\tRunID:     runID,\n   715→\t\t\tStepName:  stepName,\n   716→\t\t\tFileType:  fileType,\n   717→\t\t\tFilePath:  filepath.Join(outputDir, name),\n   718→\t\t\tFileSize:  fileSize,\n   719→\t\t\tCreatedAt: now,\n   720→\t\t}\n   721→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n   722→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n   723→\t\t}\n   724→\t}\n   725→}\n   726→\n   727→func gitHEAD(dir string) string {\n   728→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n   729→\tcmd.Dir = dir\n   730→\tout, err := cmd.Output()\n   731→\tif err != nil {\n   732→\t\treturn \"\"\n   733→\t}\n   734→\treturn strings.TrimSpace(string(out))\n   735→}\n   736→"}]},"parent_tool_use_id":null,"session_id":"bfbfa05f-1a70-4d4a-b95c-68347a51b3e3","uuid":"85bdbca2-8948-4dd0-8531-151b3e07c785","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server.go","content":"package grpc\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\trpcgrpc \"google.golang.org/grpc\"\n)\n\ntype ClocheServer struct {\n\tpb.UnimplementedClocheServiceServer\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogStore     ports.LogStore\n\tcontainer    ports.ContainerRuntime\n\tdefaultImage string\n\tevolution    *evolution.Trigger\n\tlogBroadcast *logstream.Broadcaster\n\tshutdownFn   func()\n\tmu           sync.Mutex\n\trunIDs       map[string]string // run_id -> container_id\n}\n\nfunc NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:     store,\n\t\tcontainer: container,\n\t\trunIDs:    make(map[string]string),\n\t}\n}\n\nfunc NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:        store,\n\t\tcaptures:     captures,\n\t\tcontainer:    container,\n\t\tdefaultImage: defaultImage,\n\t\trunIDs:       make(map[string]string),\n\t}\n}\n\n// SetLogStore attaches a log store to the server for indexing extracted log files.\nfunc (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n\ts.logStore = ls\n}\n\n\n// SetEvolution attaches an evolution trigger to the server.\nfunc (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n\ts.evolution = trigger\n}\n\n// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\nfunc (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n\ts.logBroadcast = b\n}\n\n// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\nfunc (s *ClocheServer) SetShutdownFunc(fn func()) {\n\ts.shutdownFn = fn\n}\n\nfunc (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\t// Generate a unique run ID, retrying on collision\n\tvar runID string\n\tfor attempts := 0; attempts < 10; attempts++ {\n\t\trunID = domain.GenerateRunID(req.WorkflowName)\n\t\texisting, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tbreak // ID is free\n\t\t}\n\t\t// Reuse if completed more than 1 hour ago\n\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n\t\t\t_ = s.store.DeleteRun(ctx, runID)\n\t\t\tbreak\n\t\t}\n\t}\n\n\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n\tif req.Prompt != \"\" {\n\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n\t\t}\n\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n\t\t}\n\t}\n\trun := domain.NewRun(runID, req.WorkflowName)\n\trun.ProjectDir = req.ProjectDir\n\tif err := s.store.CreateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n\t}\n\n\t// Resolve image: request-level override, then server default\n\timage := req.Image\n\tif image == \"\" {\n\t\timage = s.defaultImage\n\t}\n\n\t// Launch container start + tracking in background so the RPC returns immediately.\n\t// The run stays in \"pending\" state until the container is up.\n\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n\n\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n}\n\n// launchAndTrack starts the container and then tracks it to completion.\n// It runs in a background goroutine with its own context, independent of the\n// RPC context which may be cancelled after RunWorkflow returns.\nfunc (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n\tctx := context.Background()\n\n\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n\t\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\t\tif run != nil {\n\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t\t}\n\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n\t\t\treturn\n\t\t}\n\t}\n\n\tbaseSHA := gitHEAD(req.ProjectDir)\n\n\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n\t\tImage:        image,\n\t\tWorkflowName: req.WorkflowName,\n\t\tProjectDir:   req.ProjectDir,\n\t\tRunID:        runID,\n\t\tNetworkAllow: []string{\"*\"},\n\t})\n\tif err != nil {\n\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\tif run != nil {\n\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t}\n\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n\t\treturn\n\t}\n\n\ts.mu.Lock()\n\ts.runIDs[runID] = containerID\n\ts.mu.Unlock()\n\n\trun, _ := s.store.GetRun(ctx, runID)\n\tif run != nil {\n\t\trun.Start()\n\t\trun.ContainerID = containerID\n\t\trun.BaseSHA = baseSHA\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n}\n\nfunc (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n\tctx := context.Background()\n\n\t// Attach to agent output\n\treader, err := s.container.AttachOutput(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n\t\treturn\n\t}\n\n\t// Parse JSON-lines status messages\n\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n\tscanner := bufio.NewScanner(reader)\n\tfor scanner.Scan() {\n\t\tvar msg protocol.StatusMessage\n\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Fast path: log messages don't need store interaction.\n\t\tif msg.Type == protocol.MsgLog {\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"llm\",\n\t\t\t\t\tContent:   msg.Message,\n\t\t\t\t})\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\trun, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch msg.Type {\n\t\tcase protocol.MsgStepStarted:\n\t\t\trun.RecordStepStart(msg.StepName)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t\tStartedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgStepCompleted:\n\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:    msg.StepName,\n\t\t\t\t\tResult:      msg.Result,\n\t\t\t\t\tCompletedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgRunCompleted:\n\t\t\treportedResult = msg.Result\n\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n\t\t}\n\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\treader.Close()\n\n\t// Signal live-stream subscribers that this run is done.\n\tif s.logBroadcast != nil {\n\t\ts.logBroadcast.Finish(runID)\n\t}\n\n\t// Wait for process exit\n\texitCode, err := s.container.Wait(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n\t}\n\n\t// Extract step output files from container before it's removed\n\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n\t\t}\n\t}\n\n\t// Capture full container stdout/stderr before the container is removed\n\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n\t\t}\n\t}\n\n\t// Index extracted log files in the log store\n\tif s.logStore != nil {\n\t\ts.indexLogFiles(ctx, runID, outputDst)\n\t}\n\n\t// Extract results to git branch BEFORE finalizing state, so that\n\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n\t// before the run is marked complete.\n\tresultLabel := reportedResult\n\tif resultLabel == \"\" {\n\t\tif exitCode == 0 {\n\t\t\tresultLabel = \"succeeded\"\n\t\t} else {\n\t\t\tresultLabel = \"failed\"\n\t\t}\n\t}\n\t{\n\t\textractRun, _ := s.store.GetRun(ctx, runID)\n\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n\t\t\t} else {\n\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n\t\t\t}\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n\t\t}\n\t}\n\n\t// Now finalize run state\n\trun, err := s.store.GetRun(ctx, runID)\n\tif err != nil {\n\t\treturn\n\t}\n\tif run.State == domain.RunStateRunning {\n\t\tif reportedResult == \"succeeded\" {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else if reportedResult != \"\" {\n\t\t\trun.Complete(domain.RunStateFailed)\n\t\t} else if exitCode == 0 {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else {\n\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n\t\t}\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\t// Fire evolution trigger if configured\n\tif s.evolution != nil {\n\t\ts.evolution.Fire(projectDir, workflowName, runID)\n\t}\n\n\t// Merge is handled as a workflow step in host.cloche, not here.\n\n\t// Container retention policy:\n\t// - Failed runs: always keep the container for debugging\n\t// - Successful runs + --keep-container: keep the container\n\t// - Successful runs without --keep-container: remove the container\n\trunFinal, _ := s.store.GetRun(ctx, runID)\n\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n\n\tif keepContainer || runFailed {\n\t\treason := \"--keep-container\"\n\t\tif runFailed {\n\t\t\treason = \"run failed\"\n\t\t}\n\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n\t\tif runFinal != nil {\n\t\t\trunFinal.ContainerKept = true\n\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n\t\t}\n\t} else {\n\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n\t\t}\n\t}\n\n\t// Cleanup mapping\n\ts.mu.Lock()\n\tdelete(s.runIDs, runID)\n\ts.mu.Unlock()\n}\n\nfunc (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n\tvar since time.Time\n\tif !req.All {\n\t\tsince = time.Now().Add(-1 * time.Hour)\n\t}\n\truns, err := s.store.ListRuns(ctx, since)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n\t}\n\n\tresp := &pb.ListRunsResponse{}\n\tfor _, run := range runs {\n\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n\t\t\tRunId:        run.ID,\n\t\t\tWorkflowName: run.WorkflowName,\n\t\t\tState:        string(run.State),\n\t\t\tStartedAt:    run.StartedAt.String(),\n\t\t\tErrorMessage: run.ErrorMessage,\n\t\t\tContainerId:  run.ContainerID,\n\t\t})\n\t}\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n\t}\n\n\tresp := &pb.GetStatusResponse{\n\t\tRunId:        run.ID,\n\t\tWorkflowName: run.WorkflowName,\n\t\tState:        string(run.State),\n\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n\t\tErrorMessage: run.ErrorMessage,\n\t\tContainerId:  run.ContainerID,\n\t}\n\n\t// Check container liveness\n\tif run.ContainerID != \"\" && s.container != nil {\n\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n\t\t\tresp.ContainerAlive = cs.Running\n\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n\t\t\t}\n\t\t}\n\t}\n\n\t// Load step executions from captures store if available\n\tif s.captures != nil {\n\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\t\tif err == nil {\n\t\t\tfor _, exec := range captures {\n\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\t\tStepName:    exec.StepName,\n\t\t\t\t\tResult:      exec.Result,\n\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, exec := range run.StepExecutions {\n\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\tStepName:    exec.StepName,\n\t\t\t\tResult:      exec.Result,\n\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t})\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tctx := stream.Context()\n\n\t// Verify run exists\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n\t}\n\n\t// If step_name or log_type filter is set, serve content directly from the log index\n\tif req.StepName != \"\" || req.LogType != \"\" {\n\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n\t}\n\n\tif s.captures == nil {\n\t\treturn fmt.Errorf(\"captures store not configured\")\n\t}\n\n\t// Check for full.log first — if it exists, serve it as the unified log\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: string(data),\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t\t// Still send run completion entry\n\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"run_completed\",\n\t\t\t\tResult:    string(run.State),\n\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}\n\n\t// Fall back to capture-based streaming\n\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n\t}\n\n\tfor _, exec := range captures {\n\t\t// Captures are stored as separate rows: one for step_started (no Result)\n\t\t// and one for step_completed (has Result).\n\t\tif exec.Result == \"\" {\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_started\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tTimestamp: exec.StartedAt.String(),\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t} else {\n\t\t\t// Read step output from file, falling back to container.log\n\t\t\tvar output string\n\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\t\t\toutput = string(data)\n\t\t\t} else {\n\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n\t\t\t\t\toutput = string(data)\n\t\t\t\t}\n\t\t\t}\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_completed\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tResult:    exec.Result,\n\t\t\t\tTimestamp: exec.CompletedAt.String(),\n\t\t\t\tMessage:   output,\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\t// Send run completion entry\n\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:      \"run_completed\",\n\t\t\tResult:    string(run.State),\n\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\tMessage:   run.ErrorMessage,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// streamFilteredLogs serves log content filtered by step name and/or log type.\n// It uses the log index when available, falling back to file path conventions.\nfunc (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n\n\t// Try log index first\n\tif s.logStore != nil {\n\t\tvar logFiles []*ports.LogFileEntry\n\t\tvar err error\n\n\t\tif req.StepName != \"\" && req.LogType != \"\" {\n\t\t\t// Filter by both step and type\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t\tif err == nil {\n\t\t\t\tfiltered := logFiles[:0]\n\t\t\t\tfor _, lf := range logFiles {\n\t\t\t\t\tif lf.FileType == req.LogType {\n\t\t\t\t\t\tfiltered = append(filtered, lf)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tlogFiles = filtered\n\t\t\t}\n\t\t} else if req.StepName != \"\" {\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t} else {\n\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n\t\t}\n\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr != nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\t\tType:     lf.FileType + \"_log\",\n\t\t\t\t\tStepName: lf.StepName,\n\t\t\t\t\tMessage:  string(data),\n\t\t\t\t}); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Fall back to file path conventions\n\tif req.StepName != \"\" {\n\t\tvar logPath string\n\t\tswitch req.LogType {\n\t\tcase \"llm\":\n\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n\t\tdefault:\n\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n\t\t}\n\n\t\tdata, err := os.ReadFile(logPath)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n\t\t}\n\t\treturn stream.Send(&pb.LogEntry{\n\t\t\tType:     \"step_log\",\n\t\t\tStepName: req.StepName,\n\t\t\tMessage:  string(data),\n\t\t})\n\t}\n\n\treturn fmt.Errorf(\"no log files found matching filter\")\n}\n\nfunc (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n\ts.mu.Lock()\n\tcontainerID, ok := s.runIDs[req.RunId]\n\ts.mu.Unlock()\n\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n\t}\n\n\tif err := s.container.Stop(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n\t}\n\n\t// Mark as cancelled in store\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err == nil {\n\t\trun.Complete(domain.RunStateCancelled)\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.StopRunResponse{}, nil\n}\n\nfunc (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\tid := req.Id\n\tif id == \"\" {\n\t\treturn nil, fmt.Errorf(\"id is required\")\n\t}\n\n\t// Try to resolve as a run ID first\n\tcontainerID := id\n\trun, err := s.store.GetRun(ctx, id)\n\tif err == nil {\n\t\t// It's a run ID — use the container ID from the run record\n\t\tif run.ContainerID == \"\" {\n\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n\t\t}\n\t\tcontainerID = run.ContainerID\n\t}\n\n\t// Remove the container\n\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n\t}\n\n\t// If we resolved a run, clear the container_kept flag\n\tif run != nil {\n\t\trun.ContainerKept = false\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.DeleteContainerResponse{}, nil\n}\n\nfunc (s *ClocheServer) Orchestrate(ctx context.Context, req *pb.OrchestrateRequest) (*pb.OrchestrateResponse, error) {\n\treturn nil, fmt.Errorf(\"orchestrator has been removed; use host workflow instead\")\n}\n\nfunc (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n\tif s.shutdownFn == nil {\n\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n\t}\n\tgo s.shutdownFn()\n\treturn &pb.ShutdownResponse{}, nil\n}\n\n// indexLogFiles scans the extracted output directory and creates log_files index entries.\nfunc (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tname := entry.Name()\n\t\tif !strings.HasSuffix(name, \".log\") {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar fileType, stepName string\n\t\tbase := strings.TrimSuffix(name, \".log\")\n\n\t\tswitch {\n\t\tcase name == \"full.log\":\n\t\t\tfileType = \"full\"\n\t\tcase name == \"container.log\":\n\t\t\t// container.log is internal, not indexed as a user-facing log type\n\t\t\tcontinue\n\t\tcase strings.HasPrefix(name, \"llm-\"):\n\t\t\tfileType = \"llm\"\n\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n\t\tdefault:\n\t\t\tfileType = \"script\"\n\t\t\tstepName = base\n\t\t}\n\n\t\tinfo, _ := entry.Info()\n\t\tvar fileSize int64\n\t\tif info != nil {\n\t\t\tfileSize = info.Size()\n\t\t}\n\n\t\tlogEntry := &ports.LogFileEntry{\n\t\t\tRunID:     runID,\n\t\t\tStepName:  stepName,\n\t\t\tFileType:  fileType,\n\t\t\tFilePath:  filepath.Join(outputDir, name),\n\t\t\tFileSize:  fileSize,\n\t\t\tCreatedAt: now,\n\t\t}\n\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n\t\t}\n\t}\n}\n\nfunc gitHEAD(dir string) string {\n\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\treturn strings.TrimSpace(string(out))\n}\n","numLines":736,"startLine":1,"totalLines":736}}}
