{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JfdKK1nM41BAzni9XAwg6a","type":"tool_result","content":"   150→\t}\n   151→\tif err != nil {\n   152→\t\treturn nil, err\n   153→\t}\n   154→\n   155→\trun.SetActiveStepsFromString(activeSteps)\n   156→\trun.StartedAt = parseTime(startedAt)\n   157→\trun.CompletedAt = parseTime(completedAt)\n   158→\trun.ContainerKept = containerKept != 0\n   159→\treturn run, nil\n   160→}\n   161→\n   162→func (s *Store) UpdateRun(ctx context.Context, run *domain.Run) error {\n   163→\t_, err := s.db.ExecContext(ctx,\n   164→\t\t`UPDATE runs SET state = ?, active_steps = ?, started_at = ?, completed_at = ?, error_message = ?, container_id = ?, base_sha = ?, container_kept = ? WHERE id = ?`,\n   165→\t\tstring(run.State), run.ActiveStepsString(),\n   166→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt),\n   167→\t\trun.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.ID,\n   168→\t)\n   169→\treturn err\n   170→}\n   171→\n   172→func (s *Store) DeleteRun(ctx context.Context, id string) error {\n   173→\t_, err := s.db.ExecContext(ctx, `DELETE FROM step_executions WHERE run_id = ?`, id)\n   174→\tif err != nil {\n   175→\t\treturn err\n   176→\t}\n   177→\t_, err = s.db.ExecContext(ctx, `DELETE FROM runs WHERE id = ?`, id)\n   178→\treturn err\n   179→}\n   180→\n   181→func (s *Store) ListRuns(ctx context.Context, since time.Time) ([]*domain.Run, error) {\n   182→\tvar rows *sql.Rows\n   183→\tvar err error\n   184→\tif since.IsZero() {\n   185→\t\trows, err = s.db.QueryContext(ctx,\n   186→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0) FROM runs ORDER BY started_at DESC`)\n   187→\t} else {\n   188→\t\trows, err = s.db.QueryContext(ctx,\n   189→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0) FROM runs WHERE started_at >= ? ORDER BY started_at DESC`,\n   190→\t\t\tformatTime(since))\n   191→\t}\n   192→\tif err != nil {\n   193→\t\treturn nil, err\n   194→\t}\n   195→\tdefer rows.Close()\n   196→\n   197→\tvar runs []*domain.Run\n   198→\tfor rows.Next() {\n   199→\t\trun := &domain.Run{}\n   200→\t\tvar activeSteps, startedAt, completedAt string\n   201→\t\tvar containerKept int\n   202→\t\tif err := rows.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept); err != nil {\n   203→\t\t\treturn nil, err\n   204→\t\t}\n   205→\t\trun.SetActiveStepsFromString(activeSteps)\n   206→\t\trun.StartedAt = parseTime(startedAt)\n   207→\t\trun.CompletedAt = parseTime(completedAt)\n   208→\t\trun.ContainerKept = containerKept != 0\n   209→\t\truns = append(runs, run)\n   210→\t}\n   211→\treturn runs, rows.Err()\n   212→}\n   213→\n   214→func (s *Store) ListRunsByProject(ctx context.Context, projectDir string, since time.Time) ([]*domain.Run, error) {\n   215→\tvar rows *sql.Rows\n   216→\tvar err error\n   217→\tif since.IsZero() {\n   218→\t\trows, err = s.db.QueryContext(ctx,\n   219→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0) FROM runs WHERE project_dir = ? ORDER BY started_at DESC`,\n   220→\t\t\tprojectDir)\n   221→\t} else {\n   222→\t\trows, err = s.db.QueryContext(ctx,\n   223→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0) FROM runs WHERE project_dir = ? AND started_at >= ? ORDER BY started_at DESC`,\n   224→\t\t\tprojectDir, formatTime(since))\n   225→\t}\n   226→\tif err != nil {\n   227→\t\treturn nil, err\n   228→\t}\n   229→\tdefer rows.Close()\n   230→\n   231→\tvar runs []*domain.Run\n   232→\tfor rows.Next() {\n   233→\t\trun := &domain.Run{}\n   234→\t\tvar activeSteps, startedAt, completedAt string\n   235→\t\tvar containerKept int\n   236→\t\tif err := rows.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept); err != nil {\n   237→\t\t\treturn nil, err\n   238→\t\t}\n   239→\t\trun.SetActiveStepsFromString(activeSteps)\n   240→\t\trun.StartedAt = parseTime(startedAt)\n   241→\t\trun.CompletedAt = parseTime(completedAt)\n   242→\t\trun.ContainerKept = containerKept != 0\n   243→\t\truns = append(runs, run)\n   244→\t}\n   245→\treturn runs, rows.Err()\n   246→}\n   247→\n   248→func (s *Store) ListProjects(ctx context.Context) ([]string, error) {\n   249→\trows, err := s.db.QueryContext(ctx,\n   250→\t\t`SELECT DISTINCT project_dir FROM runs WHERE project_dir != '' ORDER BY project_dir`)\n   251→\tif err != nil {\n   252→\t\treturn nil, err\n   253→\t}\n   254→\tdefer rows.Close()\n   255→\n   256→\tvar projects []string\n   257→\tfor rows.Next() {\n   258→\t\tvar dir string\n   259→\t\tif err := rows.Scan(&dir); err != nil {\n   260→\t\t\treturn nil, err\n   261→\t\t}\n   262→\t\tprojects = append(projects, dir)\n   263→\t}\n   264→\treturn projects, rows.Err()\n   265→}\n   266→\n   267→func (s *Store) SaveCapture(ctx context.Context, runID string, exec *domain.StepExecution) error {\n   268→\t_, err := s.db.ExecContext(ctx,\n   269→\t\t`INSERT INTO step_executions (run_id, step_name, result, started_at, completed_at, logs, git_ref)\n   270→\t\t VALUES (?, ?, ?, ?, ?, ?, ?)`,\n   271→\t\trunID, exec.StepName, exec.Result,\n   272→\t\tformatTime(exec.StartedAt), formatTime(exec.CompletedAt),\n   273→\t\texec.Logs, exec.GitRef,\n   274→\t)\n   275→\treturn err\n   276→}\n   277→\n   278→func (s *Store) GetCaptures(ctx context.Context, runID string) ([]*domain.StepExecution, error) {\n   279→\trows, err := s.db.QueryContext(ctx,\n   280→\t\t`SELECT step_name, result, started_at, completed_at, COALESCE(logs,''), COALESCE(git_ref,'')\n   281→\t\t FROM step_executions WHERE run_id = ? ORDER BY id`, runID)\n   282→\tif err != nil {\n   283→\t\treturn nil, err\n   284→\t}\n   285→\tdefer rows.Close()\n   286→\n   287→\tvar execs []*domain.StepExecution\n   288→\tfor rows.Next() {\n   289→\t\te := &domain.StepExecution{}\n   290→\t\tvar startedAt, completedAt string\n   291→\t\tif err := rows.Scan(&e.StepName, &e.Result, &startedAt, &completedAt, &e.Logs, &e.GitRef); err != nil {\n   292→\t\t\treturn nil, err\n   293→\t\t}\n   294→\t\te.StartedAt = parseTime(startedAt)\n   295→\t\te.CompletedAt = parseTime(completedAt)\n   296→\t\texecs = append(execs, e)\n   297→\t}\n   298→\treturn execs, rows.Err()\n   299→}"}]},"parent_tool_use_id":"toolu_01SVuP9F14VNAmGg3bxKWQaH","session_id":"bfbfa05f-1a70-4d4a-b95c-68347a51b3e3","uuid":"02988c3c-c268-40e5-b277-78da515a7e7f"}
