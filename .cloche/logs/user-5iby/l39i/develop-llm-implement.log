{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011fgU7KDL61yECdSBoDyLGA","type":"tool_result","content":"     1→package domain\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"strings\"\n     6→)\n     7→\n     8→const (\n     9→\tStepDone  = \"done\"\n    10→\tStepAbort = \"abort\"\n    11→)\n    12→\n    13→type StepType string\n    14→\n    15→const (\n    16→\tStepTypeAgent    StepType = \"agent\"\n    17→\tStepTypeScript   StepType = \"script\"\n    18→\tStepTypeWorkflow StepType = \"workflow\"\n    19→)\n    20→\n    21→// WorkflowLocation indicates where a workflow is intended to run.\n    22→type WorkflowLocation string\n    23→\n    24→const (\n    25→\t// LocationContainer is for workflows that run inside a Docker container.\n    26→\t// These are all .cloche/*.cloche files except host.cloche.\n    27→\tLocationContainer WorkflowLocation = \"container\"\n    28→\n    29→\t// LocationHost is for workflows that run on the host machine.\n    30→\t// Only .cloche/host.cloche uses this location.\n    31→\tLocationHost WorkflowLocation = \"host\"\n    32→)\n    33→\n    34→type Step struct {\n    35→\tName    string\n    36→\tType    StepType\n    37→\tResults []string\n    38→\tConfig  map[string]string\n    39→}\n    40→\n    41→type Wire struct {\n    42→\tFrom   string\n    43→\tResult string\n    44→\tTo     string\n    45→}\n    46→\n    47→type CollectMode string\n    48→\n    49→const (\n    50→\tCollectAll CollectMode = \"all\"\n    51→\tCollectAny CollectMode = \"any\"\n    52→)\n    53→\n    54→type WireCondition struct {\n    55→\tStep   string\n    56→\tResult string\n    57→}\n    58→\n    59→type Collect struct {\n    60→\tMode       CollectMode\n    61→\tConditions []WireCondition\n    62→\tTo         string\n    63→}\n    64→\n    65→type Workflow struct {\n    66→\tName      string\n    67→\tLocation  WorkflowLocation  // host or container\n    68→\tSteps     map[string]*Step\n    69→\tWiring    []Wire\n    70→\tCollects  []Collect\n    71→\tEntryStep string\n    72→\tConfig    map[string]string // workflow-level config (e.g. \"container.image\")\n    73→}\n    74→\n    75→func (w *Workflow) Validate() error {\n    76→\tif w.EntryStep == \"\" {\n    77→\t\treturn fmt.Errorf(\"workflow %q: no entry step defined\", w.Name)\n    78→\t}\n    79→\tif _, ok := w.Steps[w.EntryStep]; !ok {\n    80→\t\treturn fmt.Errorf(\"workflow %q: entry step %q not found\", w.Name, w.EntryStep)\n    81→\t}\n    82→\n    83→\twired := make(map[string]map[string]bool)\n    84→\treachable := map[string]bool{w.EntryStep: true}\n    85→\tfor _, wire := range w.Wiring {\n    86→\t\tif wired[wire.From] == nil {\n    87→\t\t\twired[wire.From] = make(map[string]bool)\n    88→\t\t}\n    89→\t\twired[wire.From][wire.Result] = true\n    90→\t\tif wire.To != StepDone && wire.To != StepAbort {\n    91→\t\t\treachable[wire.To] = true\n    92→\t\t}\n    93→\t}\n    94→\n    95→\t// Validate collects and count their results as wired\n    96→\tfor _, c := range w.Collects {\n    97→\t\t// Validate target step exists\n    98→\t\tif c.To != StepDone && c.To != StepAbort {\n    99→\t\t\tif _, ok := w.Steps[c.To]; !ok {\n   100→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect target step %q not found\", w.Name, c.To)\n   101→\t\t\t}\n   102→\t\t\treachable[c.To] = true\n   103→\t\t}\n   104→\n   105→\t\tfor _, cond := range c.Conditions {\n   106→\t\t\t// Validate condition step exists\n   107→\t\t\tstep, ok := w.Steps[cond.Step]\n   108→\t\t\tif !ok {\n   109→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references unknown step %q\", w.Name, cond.Step)\n   110→\t\t\t}\n   111→\t\t\t// Validate condition result is declared\n   112→\t\t\tfound := false\n   113→\t\t\tfor _, r := range step.Results {\n   114→\t\t\t\tif r == cond.Result {\n   115→\t\t\t\t\tfound = true\n   116→\t\t\t\t\tbreak\n   117→\t\t\t\t}\n   118→\t\t\t}\n   119→\t\t\tif !found {\n   120→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references undeclared result %q on step %q\", w.Name, cond.Result, cond.Step)\n   121→\t\t\t}\n   122→\t\t\t// Mark as wired so the \"every result must be wired\" check passes\n   123→\t\t\tif wired[cond.Step] == nil {\n   124→\t\t\t\twired[cond.Step] = make(map[string]bool)\n   125→\t\t\t}\n   126→\t\t\twired[cond.Step][cond.Result] = true\n   127→\t\t}\n   128→\t}\n   129→\n   130→\tfor name, step := range w.Steps {\n   131→\t\tfor _, result := range step.Results {\n   132→\t\t\tif !wired[name][result] {\n   133→\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q result %q is not wired\", w.Name, name, result)\n   134→\t\t\t}\n   135→\t\t}\n   136→\t}\n   137→\n   138→\tfor name := range w.Steps {\n   139→\t\tif !reachable[name] {\n   140→\t\t\treturn fmt.Errorf(\"workflow %q: step %q is orphaned (unreachable)\", w.Name, name)\n   141→\t\t}\n   142→\t}\n   143→\n   144→\treturn nil\n   145→}\n   146→\n   147→// ValidateLocation checks that step types are compatible with the workflow location.\n   148→// workflow_name steps are only allowed in host workflows.\n   149→func (w *Workflow) ValidateLocation() error {\n   150→\tif w.Location == LocationContainer {\n   151→\t\tfor name, step := range w.Steps {\n   152→\t\t\tif step.Type == StepTypeWorkflow {\n   153→\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q uses workflow_name, which is only allowed in host workflows (host.cloche)\", w.Name, name)\n   154→\t\t\t}\n   155→\t\t}\n   156→\t}\n   157→\treturn nil\n   158→}\n   159→\n   160→// knownStepConfigKeys lists recognized step-level config keys.\n   161→// Keys with a \"container.\" prefix are also allowed.\n   162→var knownStepConfigKeys = map[string]bool{\n   163→\t\"prompt\":        true,\n   164→\t\"run\":           true,\n   165→\t\"max_attempts\":  true,\n   166→\t\"timeout\":       true,\n   167→\t\"agent_command\": true,\n   168→\t\"agent_args\":    true,\n   169→\t\"results\":       true,\n   170→\t\"feedback\":      true,\n   171→\t\"workflow_name\": true,\n   172→\t\"prompt_step\":   true,\n   173→}\n   174→\n   175→// ValidateConfig checks step config keys against known keys and returns\n   176→// warnings for any unrecognized keys (likely typos).\n   177→func (w *Workflow) ValidateConfig() []string {\n   178→\tvar warnings []string\n   179→\tfor name, step := range w.Steps {\n   180→\t\tfor key := range step.Config {\n   181→\t\t\tif knownStepConfigKeys[key] {\n   182→\t\t\t\tcontinue\n   183→\t\t\t}\n   184→\t\t\tif strings.HasPrefix(key, \"container.\") {\n   185→\t\t\t\tcontinue\n   186→\t\t\t}\n   187→\t\t\twarnings = append(warnings, fmt.Sprintf(\n   188→\t\t\t\t\"workflow %q: step %q has unrecognized config key %q\", w.Name, name, key))\n   189→\t\t}\n   190→\t}\n   191→\treturn warnings\n   192→}\n   193→\n   194→// NextSteps returns all target step names wired from the given (stepName, result) pair.\n   195→// Multiple targets indicate fanout — parallel branches launched by the engine.\n   196→func (w *Workflow) NextSteps(stepName, result string) ([]string, error) {\n   197→\tvar targets []string\n   198→\tfor _, wire := range w.Wiring {\n   199→\t\tif wire.From == stepName && wire.Result == result {\n   200→\t\t\ttargets = append(targets, wire.To)\n   201→\t\t}\n   202→\t}\n   203→\tif len(targets) == 0 {\n   204→\t\treturn nil, fmt.Errorf(\"workflow %q: no wiring for step %q result %q\", w.Name, stepName, result)\n   205→\t}\n   206→\treturn targets, nil\n   207→}\n   208→\n   209→// Deprecated: NextStep returns the first target only. Use NextSteps for fanout support.\n   210→func (w *Workflow) NextStep(stepName, result string) (string, error) {\n   211→\ttargets, err := w.NextSteps(stepName, result)\n   212→\tif err != nil {\n   213→\t\treturn \"\", err\n   214→\t}\n   215→\treturn targets[0], nil\n   216→}\n   217→"}]},"parent_tool_use_id":"toolu_0178Fx9DkF5kR6HuyT1bAmTp","session_id":"bfbfa05f-1a70-4d4a-b95c-68347a51b3e3","uuid":"2c275197-34db-49c3-8068-24c497073e5b"}
