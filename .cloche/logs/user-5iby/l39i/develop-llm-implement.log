tion string\n    49→\tChangesJSON    string\n    50→\tKnowledgeDelta string\n    51→}\n    52→\n    53→type EvolutionStore interface {\n    54→\tSaveEvolution(ctx context.Context, entry *EvolutionEntry) error\n    55→\tGetLastEvolution(ctx context.Context, projectDir, workflowName string) (*EvolutionEntry, error)\n    56→\tListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error)\n    57→}\n    58→"}]},"parent_tool_use_id":"toolu_01SVuP9F14VNAmGg3bxKWQaH","session_id":"bfbfa05f-1a70-4d4a-b95c-68347a51b3e3","uuid":"deb6630d-d745-493c-b091-3ab6d936b98c"}
