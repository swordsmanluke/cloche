{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JMQZn8Pmp1YXLHUsihTnmy","type":"tool_result","content":"     1→package dsl\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"strings\"\n     6→\n     7→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     8→)\n     9→\n    10→type Parser struct {\n    11→\tlexer    *Lexer\n    12→\tcurrent  Token\n    13→\tpeek     Token\n    14→\tlocation domain.WorkflowLocation\n    15→}\n    16→\n    17→// ParseOption configures the parser.\n    18→type ParseOption func(*Parser)\n    19→\n    20→// WithLocation sets the workflow location, enabling location-based validation.\n    21→func WithLocation(loc domain.WorkflowLocation) ParseOption {\n    22→\treturn func(p *Parser) {\n    23→\t\tp.location = loc\n    24→\t}\n    25→}\n    26→\n    27→func Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n    28→\tp := &Parser{lexer: NewLexer(input)}\n    29→\tfor _, opt := range opts {\n    30→\t\topt(p)\n    31→\t}\n    32→\tp.advance() // load current\n    33→\tp.advance() // load peek\n    34→\treturn p.parseWorkflow()\n    35→}\n    36→\n    37→// ParseForHost parses a host.cloche file.\n    38→func ParseForHost(input string) (*domain.Workflow, error) {\n    39→\treturn Parse(input, WithLocation(domain.LocationHost))\n    40→}\n    41→\n    42→// ParseForContainer parses a container workflow file.\n    43→func ParseForContainer(input string) (*domain.Workflow, error) {\n    44→\treturn Parse(input, WithLocation(domain.LocationContainer))\n    45→}\n    46→\n    47→func (p *Parser) advance() {\n    48→\tp.current = p.peek\n    49→\tp.peek = p.lexer.NextToken()\n    50→}\n    51→\n    52→func (p *Parser) expect(typ TokenType) (Token, error) {\n    53→\tif p.current.Type != typ {\n    54→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n    55→\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n    56→\t}\n    57→\ttok := p.current\n    58→\tp.advance()\n    59→\treturn tok, nil\n    60→}\n    61→\n    62→func (p *Parser) expectIdent(value string) (Token, error) {\n    63→\tif p.current.Type != TokenIdent || p.current.Literal != value {\n    64→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n    65→\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n    66→\t}\n    67→\ttok := p.current\n    68→\tp.advance()\n    69→\treturn tok, nil\n    70→}\n    71→\n    72→func (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n    73→\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n    74→\t\treturn nil, err\n    75→\t}\n    76→\n    77→\tnameTok, err := p.expect(TokenString)\n    78→\tif err != nil {\n    79→\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n    80→\t}\n    81→\n    82→\tif _, err := p.expect(TokenLBrace); err != nil {\n    83→\t\treturn nil, err\n    84→\t}\n    85→\n    86→\twf := &domain.Workflow{\n    87→\t\tName:     nameTok.Literal,\n    88→\t\tLocation: p.location,\n    89→\t\tSteps:    make(map[string]*domain.Step),\n    90→\t\tConfig:   make(map[string]string),\n    91→\t}\n    92→\n    93→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n    94→\t\tif p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n    95→\t\t\tstep, err := p.parseStep()\n    96→\t\t\tif err != nil {\n    97→\t\t\t\treturn nil, err\n    98→\t\t\t}\n    99→\t\t\twf.Steps[step.Name] = step\n   100→\t\t\tif wf.EntryStep == \"\" {\n   101→\t\t\t\twf.EntryStep = step.Name\n   102→\t\t\t}\n   103→\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n   104→\t\t\tcollect, err := p.parseCollect()\n   105→\t\t\tif err != nil {\n   106→\t\t\t\treturn nil, err\n   107→\t\t\t}\n   108→\t\t\twf.Collects = append(wf.Collects, collect)\n   109→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n   110→\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n   111→\t\t\t\treturn nil, err\n   112→\t\t\t}\n   113→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n   114→\t\t\twire, err := p.parseWire()\n   115→\t\t\tif err != nil {\n   116→\t\t\t\treturn nil, err\n   117→\t\t\t}\n   118→\t\t\twf.Wiring = append(wf.Wiring, wire)\n   119→\t\t} else {\n   120→\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n   121→\t\t}\n   122→\t}\n   123→\n   124→\tif _, err := p.expect(TokenRBrace); err != nil {\n   125→\t\treturn nil, err\n   126→\t}\n   127→\n   128→\tif wf.Location != \"\" {\n   129→\t\tif err := wf.ValidateLocation(); err != nil {\n   130→\t\t\treturn nil, err\n   131→\t\t}\n   132→\t}\n   133→\n   134→\treturn wf, nil\n   135→}\n   136→\n   137→func (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n   138→\tprefix := p.current.Literal // e.g. \"container\"\n   139→\tp.advance()                 // consume prefix ident\n   140→\n   141→\tif _, err := p.expect(TokenLBrace); err != nil {\n   142→\t\treturn err\n   143→\t}\n   144→\n   145→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   146→\t\tkeyTok, err := p.expect(TokenIdent)\n   147→\t\tif err != nil {\n   148→\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   149→\t\t}\n   150→\n   151→\t\tif _, err := p.expect(TokenEquals); err != nil {\n   152→\t\t\treturn err\n   153→\t\t}\n   154→\n   155→\t\tval, err := p.parseValue()\n   156→\t\tif err != nil {\n   157→\t\t\treturn err\n   158→\t\t}\n   159→\n   160→\t\twf.Config[prefix+\".\"+keyTok.Literal] = val\n   161→\t}\n   162→\n   163→\tif _, err := p.expect(TokenRBrace); err != nil {\n   164→\t\treturn err\n   165→\t}\n   166→\n   167→\treturn nil\n   168→}\n   169→\n   170→func (p *Parser) parseStep() (*domain.Step, error) {\n   171→\tp.advance() // consume \"step\"\n   172→\n   173→\tnameTok, err := p.expect(TokenIdent)\n   174→\tif err != nil {\n   175→\t\treturn nil, fmt.Errorf(\"expected step name: %w\", err)\n   176→\t}\n   177→\n   178→\tif _, err := p.expect(TokenLBrace); err != nil {\n   179→\t\treturn nil, err\n   180→\t}\n   181→\n   182→\tstep := &domain.Step{\n   183→\t\tName:   nameTok.Literal,\n   184→\t\tConfig: make(map[string]string),\n   185→\t}\n   186→\n   187→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   188→\t\tif err := p.parseStepField(step, \"\"); err != nil {\n   189→\t\t\treturn nil, err\n   190→\t\t}\n   191→\t}\n   192→\n   193→\tif _, err := p.expect(TokenRBrace); err != nil {\n   194→\t\treturn nil, err\n   195→\t}\n   196→\n   197→\t// Infer step type from content\n   198→\t_, hasPrompt := step.Config[\"prompt\"]\n   199→\t_, hasRun := step.Config[\"run\"]\n   200→\t_, hasWorkflowName := step.Config[\"workflow_name\"]\n   201→\n   202→\tcount := 0\n   203→\tif hasPrompt {\n   204→\t\tcount++\n   205→\t}\n   206→\tif hasRun {\n   207→\t\tcount++\n   208→\t}\n   209→\tif hasWorkflowName {\n   210→\t\tcount++\n   211→\t}\n   212→\n   213→\tif count > 1 {\n   214→\t\treturn nil, fmt.Errorf(\"step %q has multiple of 'prompt', 'run', 'workflow_name'; must have exactly one\", step.Name)\n   215→\t}\n   216→\n   217→\tswitch {\n   218→\tcase hasPrompt:\n   219→\t\tstep.Type = domain.StepTypeAgent\n   220→\tcase hasRun:\n   221→\t\tstep.Type = domain.StepTypeScript\n   222→\tcase hasWorkflowName:\n   223→\t\tstep.Type = domain.StepTypeWorkflow\n   224→\tdefault:\n   225→\t\treturn nil, fmt.Errorf(\"step %q has none of 'prompt', 'run', or 'workflow_name'; must have exactly one\", step.Name)\n   226→\t}\n   227→\n   228→\treturn step, nil\n   229→}\n   230→\n   231→func (p *Parser) parseStepField(step *domain.Step, prefix string) error {\n   232→\tkeyTok, err := p.expect(TokenIdent)\n   233→\tif err != nil {\n   234→\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   235→\t}\n   236→\n   237→\tkey := keyTok.Literal\n   238→\tif prefix != \"\" {\n   239→\t\tkey = prefix + \".\" + key\n   240→\t}\n   241→\n   242→\t// Sub-block (e.g., container { ... })\n   243→\tif p.current.Type == TokenLBrace {\n   244→\t\tp.advance() // consume {\n   245→\t\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   246→\t\t\tif err := p.parseStepField(step, key); err != nil {\n   247→\t\t\t\treturn err\n   248→\t\t\t}\n   249→\t\t}\n   250→\t\tp.advance() // consume }\n   251→\t\treturn nil\n   252→\t}\n   253→\n   254→\tif _, err := p.expect(TokenEquals); err != nil {\n   255→\t\treturn err\n   256→\t}\n   257→\n   258→\tif key == \"results\" {\n   259→\t\tresults, err := p.parseIdentList()\n   260→\t\tif err != nil {\n   261→\t\t\treturn err\n   262→\t\t}\n   263→\t\tstep.Results = results\n   264→\t} else if p.current.Type == TokenLBracket {\n   265→\t\tvalues, err := p.parseStringList()\n   266→\t\tif err != nil {\n   267→\t\t\treturn err\n   268→\t\t}\n   269→\t\tstep.Config[key] = strings.Join(values, \",\")\n   270→\t} else {\n   271→\t\tval, err := p.parseValue()\n   272→\t\tif err != nil {\n   273→\t\t\treturn err\n   274→\t\t}\n   275→\t\tstep.Config[key] = val\n   276→\t}\n   277→\n   278→\treturn nil\n   279→}\n   280→\n   281→func (p *Parser) parseIdentList() ([]string, error) {\n   282→\tif _, err := p.expect(TokenLBracket); err != nil {\n   283→\t\treturn nil, err\n   284→\t}\n   285→\n   286→\tvar items []string\n   287→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   288→\t\ttok, err := p.expect(TokenIdent)\n   289→\t\tif err != nil {\n   290→\t\t\treturn nil, err\n   291→\t\t}\n   292→\t\titems = append(items, tok.Literal)\n   293→\t\tif p.current.Type == TokenComma {\n   294→\t\t\tp.advance()\n   295→\t\t}\n   296→\t}\n   297→\n   298→\tif _, err := p.expect(TokenRBracket); err != nil {\n   299→\t\treturn nil, err\n   300→\t}\n   301→\n   302→\treturn items, nil\n   303→}\n   304→\n   305→func (p *Parser) parseStringList() ([]string, error) {\n   306→\tif _, err := p.expect(TokenLBracket); err != nil {\n   307→\t\treturn nil, err\n   308→\t}\n   309→\n   310→\tvar items []string\n   311→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   312→\t\ttok, err := p.expect(TokenString)\n   313→\t\tif err != nil {\n   314→\t\t\treturn nil, err\n   315→\t\t}\n   316→\t\titems = append(items, tok.Literal)\n   317→\t\tif p.current.Type == TokenComma {\n   318→\t\t\tp.advance()\n   319→\t\t}\n   320→\t}\n   321→\n   322→\tif _, err := p.expect(TokenRBracket); err != nil {\n   323→\t\treturn nil, err\n   324→\t}\n   325→\n   326→\treturn items, nil\n   327→}\n   328→\n   329→func (p *Parser) parseValue() (string, error) {\n   330→\tif p.current.Type == TokenString {\n   331→\t\ttok := p.current\n   332→\t\tp.advance()\n   333→\t\treturn tok.Literal, nil\n   334→\t}\n   335→\n   336→\tif p.current.Type == TokenIdent {\n   337→\t\tvar buf strings.Builder\n   338→\t\tbuf.WriteString(p.current.Literal)\n   339→\t\tp.advance()\n   340→\n   341→\t\t// Function call: file(\"...\")\n   342→\t\tif p.current.Type == TokenLParen {\n   343→\t\t\tbuf.WriteRune('(')\n   344→\t\t\tp.advance()\n   345→\t\t\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   346→\t\t\t\tif p.current.Type == TokenString {\n   347→\t\t\t\t\tbuf.WriteRune('\"')\n   348→\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   349→\t\t\t\t\tbuf.WriteRune('\"')\n   350→\t\t\t\t} else {\n   351→\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   352→\t\t\t\t}\n   353→\t\t\t\tp.advance()\n   354→\t\t\t}\n   355→\t\t\tbuf.WriteRune(')')\n   356→\t\t\tp.advance() // consume )\n   357→\t\t}\n   358→\n   359→\t\t// Dotted path: step.code.output\n   360→\t\tfor p.current.Type == TokenDot {\n   361→\t\t\tbuf.WriteRune('.')\n   362→\t\t\tp.advance()\n   363→\t\t\tif p.current.Type == TokenIdent {\n   364→\t\t\t\tbuf.WriteString(p.current.Literal)\n   365→\t\t\t\tp.advance()\n   366→\t\t\t}\n   367→\t\t}\n   368→\n   369→\t\treturn buf.String(), nil\n   370→\t}\n   371→\n   372→\treturn \"\", fmt.Errorf(\"line %d col %d: expected value, got %q\", p.current.Line, p.current.Col, p.current.Literal)\n   373→}\n   374→\n   375→func (p *Parser) parseWire() (domain.Wire, error) {\n   376→\tfromTok := p.current\n   377→\tp.advance()\n   378→\n   379→\tif _, err := p.expect(TokenColon); err != nil {\n   380→\t\treturn domain.Wire{}, err\n   381→\t}\n   382→\n   383→\tresultTok, err := p.expect(TokenIdent)\n   384→\tif err != nil {\n   385→\t\treturn domain.Wire{}, err\n   386→\t}\n   387→\n   388→\tif _, err := p.expect(TokenArrow); err != nil {\n   389→\t\treturn domain.Wire{}, err\n   390→\t}\n   391→\n   392→\ttoTok, err := p.expect(TokenIdent)\n   393→\tif err != nil {\n   394→\t\treturn domain.Wire{}, err\n   395→\t}\n   396→\n   397→\treturn domain.Wire{\n   398→\t\tFrom:   fromTok.Literal,\n   399→\t\tResult: resultTok.Literal,\n   400→\t\tTo:     toTok.Literal,\n   401→\t}, nil\n   402→}\n   403→\n   404→func (p *Parser) parseCollect() (domain.Collect, error) {\n   405→\tp.advance() // consume \"collect\"\n   406→\n   407→\tmodeTok, err := p.expect(TokenIdent)\n   408→\tif err != nil {\n   409→\t\treturn domain.Collect{}, fmt.Errorf(\"expected 'all' or 'any': %w\", err)\n   410→\t}\n   411→\n   412→\tvar mode domain.CollectMode\n   413→\tswitch modeTok.Literal {\n   414→\tcase \"all\":\n   415→\t\tmode = domain.CollectAll\n   416→\tcase \"any\":\n   417→\t\tmode = domain.CollectAny\n   418→\tdefault:\n   419→\t\treturn domain.Collect{}, fmt.Errorf(\"line %d col %d: expected 'all' or 'any', got %q\",\n   420→\t\t\tmodeTok.Line, modeTok.Col, modeTok.Literal)\n   421→\t}\n   422→\n   423→\tif _, err := p.expect(TokenLParen); err != nil {\n   424→\t\treturn domain.Collect{}, err\n   425→\t}\n   426→\n   427→\tvar conditions []domain.WireCondition\n   428→\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   429→\t\tstepTok, err := p.expect(TokenIdent)\n   430→\t\tif err != nil {\n   431→\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected step name in collect: %w\", err)\n   432→\t\t}\n   433→\t\tif _, err := p.expect(TokenColon); err != nil {\n   434→\t\t\treturn domain.Collect{}, err\n   435→\t\t}\n   436→\t\tresultTok, err := p.expect(TokenIdent)\n   437→\t\tif err != nil {\n   438→\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected result name in collect: %w\", err)\n   439→\t\t}\n   440→\t\tconditions = append(conditions, domain.WireCondition{Step: stepTok.Literal, Result: resultTok.Literal})\n   441→\t\tif p.current.Type == TokenComma {\n   442→\t\t\tp.advance()\n   443→\t\t}\n   444→\t}\n   445→\n   446→\tif _, err := p.expect(TokenRParen); err != nil {\n   447→\t\treturn domain.Collect{}, err\n   448→\t}\n   449→\tif _, err := p.expect(TokenArrow); err != nil {\n   450→\t\treturn domain.Collect{}, err\n   451→\t}\n   452→\n   453→\ttoTok, err := p.expect(TokenIdent)\n   454→\tif err != nil {\n   455→\t\treturn domain.Collect{}, fmt.Errorf(\"expected target step: %w\", err)\n   456→\t}\n   457→\n   458→\treturn domain.Collect{\n   459→\t\tMode:       mode,\n   460→\t\tConditions: conditions,\n   461→\t\tTo:         toTok.Literal,\n   462→\t}, nil\n   463→}\n   464→"}]},"parent_tool_use_id":"toolu_0178Fx9DkF5kR6HuyT1bAmTp","session_id":"bfbfa05f-1a70-4d4a-b95c-68347a51b3e3","uuid":"b527d4cc-11a3-4a18-be96-08f9c361b196"}
