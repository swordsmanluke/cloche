{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Uhw4VuM9dJ8HAcGFqfnPuc","type":"tool_result","content":"     1â†’package sqlite\n     2â†’\n     3â†’import (\n     4â†’\t\"context\"\n     5â†’\t\"database/sql\"\n     6â†’\t\"fmt\"\n     7â†’\t\"time\"\n     8â†’\n     9â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10â†’\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11â†’\t_ \"modernc.org/sqlite\"\n    12â†’)\n    13â†’\n    14â†’type Store struct {\n    15â†’\tdb *sql.DB\n    16â†’}\n    17â†’\n    18â†’func NewStore(dsn string) (*Store, error) {\n    19â†’\tdb, err := sql.Open(\"sqlite\", dsn)\n    20â†’\tif err != nil {\n    21â†’\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n    22â†’\t}\n    23â†’\n    24â†’\t// Enable WAL mode for concurrent read/write access\n    25â†’\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n    26â†’\n    27â†’\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n    28â†’\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n    29â†’\n    30â†’\t// Serialize all Go-side access through a single connection so SQLite\n    31â†’\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n    32â†’\tdb.SetMaxOpenConns(1)\n    33â†’\n    34â†’\tif err := migrate(db); err != nil {\n    35â†’\t\tdb.Close()\n    36â†’\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n    37â†’\t}\n    38â†’\n    39â†’\treturn &Store{db: db}, nil\n    40â†’}\n    41â†’\n    42â†’func (s *Store) Close() error {\n    43â†’\treturn s.db.Close()\n    44â†’}\n    45â†’\n    46â†’func migrate(db *sql.DB) error {\n    47â†’\t_, err := db.Exec(`\n    48â†’\t\tCREATE TABLE IF NOT EXISTS runs (\n    49â†’\t\t\tid TEXT PRIMARY KEY,\n    50â†’\t\t\tworkflow_name TEXT NOT NULL,\n    51â†’\t\t\tstate TEXT NOT NULL,\n    52â†’\t\t\tactive_steps TEXT,\n    53â†’\t\t\tstarted_at TEXT,\n    54â†’\t\t\tcompleted_at TEXT\n    55â†’\t\t);\n    56â†’\t\tCREATE TABLE IF NOT EXISTS step_executions (\n    57â†’\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    58â†’\t\t\trun_id TEXT NOT NULL,\n    59â†’\t\t\tstep_name TEXT NOT NULL,\n    60â†’\t\t\tresult TEXT,\n    61â†’\t\t\tstarted_at TEXT NOT NULL,\n    62â†’\t\t\tcompleted_at TEXT,\n    63â†’\t\t\tlogs TEXT,\n    64â†’\t\t\tgit_ref TEXT,\n    65â†’\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    66â†’\t\t);\n    67â†’\t`)\n    68â†’\tif err != nil {\n    69â†’\t\treturn err\n    70â†’\t}\n    71â†’\n    72â†’\t// Evolution schema additions (idempotent)\n    73â†’\talterStmts := []string{\n    74â†’\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n    75â†’\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n    76â†’\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n    77â†’\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n    78â†’\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n    79â†’\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n    80â†’\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n    81â†’\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n    82â†’\t\t`ALTER TABLE runs ADD COLUMN title TEXT NOT NULL DEFAULT ''`,\n    83â†’\t\t`ALTER TABLE runs ADD COLUMN is_host INTEGER NOT NULL DEFAULT 0`,\n    84â†’\t\t`ALTER TABLE runs ADD COLUMN parent_run_id TEXT NOT NULL DEFAULT ''`,\n    85â†’\t\t`ALTER TABLE runs ADD COLUMN task_id TEXT NOT NULL DEFAULT ''`,\n    86â†’\t}\n    87â†’\tfor _, stmt := range alterStmts {\n    88â†’\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n    89â†’\t}\n    90â†’\n    91â†’\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n    92â†’\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    93â†’\t\trun_id TEXT NOT NULL,\n    94â†’\t\tstep_name TEXT,\n    95â†’\t\tfile_type TEXT NOT NULL,\n    96â†’\t\tfile_path TEXT NOT NULL,\n    97â†’\t\tfile_size INTEGER,\n    98â†’\t\tcreated_at TEXT NOT NULL,\n    99â†’\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n   100â†’\t)`)\n   101â†’\tif errLog != nil {\n   102â†’\t\treturn errLog\n   103â†’\t}\n   104â†’\n   105â†’\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n   106â†’\t\trun_id TEXT PRIMARY KEY,\n   107â†’\t\tbranch TEXT NOT NULL,\n   108â†’\t\tproject TEXT NOT NULL,\n   109â†’\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n   110â†’\t\tenqueued_at TEXT NOT NULL,\n   111â†’\t\tcompleted_at TEXT\n   112â†’\t)`)\n   113â†’\tif errMQ != nil {\n   114â†’\t\treturn errMQ\n   115â†’\t}\n   116â†’\n   117â†’\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n   118â†’\t\tid TEXT PRIMARY KEY,\n   119â†’\t\tproject_dir TEXT NOT NULL,\n   120â†’\t\tworkflow_name TEXT NOT NULL,\n   121â†’\t\ttrigger_run_id TEXT NOT NULL,\n   122â†’\t\tcreated_at TEXT NOT NULL,\n   123â†’\t\tclassification TEXT,\n   124â†’\t\tchanges_json TEXT NOT NULL,\n   125â†’\t\tknowledge_delta TEXT\n   126â†’\t)`)\n   127â†’\tif err2 != nil {\n   128â†’\t\treturn err2\n   129â†’\t}\n   130â†’\n   131â†’\treturn nil\n   132â†’}\n   133â†’\n   134â†’func (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n   135â†’\t_, err := s.db.ExecContext(ctx,\n   136â†’\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept, title, is_host, parent_run_id, task_id)\n   137â†’\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   138â†’\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n   139â†’\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, truncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID,\n   140â†’\t)\n   141â†’\treturn err\n   142â†’}\n   143â†’\n   144â†’// runSelectCols is the standard column list for scanning a Run row.\n   145â†’const runSelectCols = `id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,''), COALESCE(is_host,0), COALESCE(parent_run_id,''), COALESCE(task_id,'')`\n   146â†’\n   147â†’// scanRun scans a single row into a *domain.Run.\n   148â†’func scanRun(scanner interface{ Scan(...any) error }) (*domain.Run, error) {\n   149â†’\trun := &domain.Run{}\n   150â†’\tvar activeSteps, startedAt, completedAt string\n   151â†’\tvar containerKept, isHost int\n   152â†’\terr := scanner.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title, &isHost, &run.ParentRunID, &run.TaskID)\n   153â†’\tif err != nil {\n   154â†’\t\treturn nil, err\n   155â†’\t}\n   156â†’\trun.SetActiveStepsFromString(activeSteps)\n   157â†’\trun.StartedAt = parseTime(startedAt)\n   158â†’\trun.CompletedAt = parseTime(completedAt)\n   159â†’\trun.ContainerKept = containerKept != 0\n   160â†’\trun.IsHost = isHost != 0\n   161â†’\treturn run, nil\n   162â†’}\n   163â†’\n   164â†’func (s *Store) GetRun(ctx context.Context, id string) (*domain.Run, error) {\n   165â†’\trow := s.db.QueryRowContext(ctx,\n   166â†’\t\t`SELECT `+runSelectCols+` FROM runs WHERE id = ?`, id)\n   167â†’\n   168â†’\trun, err := scanRun(row)\n   169â†’\tif err == sql.ErrNoRows {\n   170â†’\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n   171â†’\t}\n   172â†’\treturn run, err\n   173â†’}\n   174â†’\n   175â†’func (s *Store) UpdateRun(ctx context.Context, run *domain.Run) error {\n   176â†’\t_, err := s.db.ExecContext(ctx,\n   177â†’\t\t`UPDATE runs SET state = ?, active_steps = ?, started_at = ?, completed_at = ?, error_message = ?, container_id = ?, base_sha = ?, container_kept = ?, title = ?, is_host = ?, parent_run_id = ?, task_id = ? WHERE id = ?`,\n   178â†’\t\tstring(run.State), run.ActiveStepsString(),\n   179â†’\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt),\n   180â†’\t\ttruncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID, run.ID,\n   181â†’\t)\n   182â†’\treturn err\n   183â†’}\n   184â†’\n   185â†’func (s *Store) DeleteRun(ctx context.Context, id string) error {\n   186â†’\t_, err := s.db.ExecContext(ctx, `DELETE FROM step_executions WHERE run_id = ?`, id)\n   187â†’\tif err != nil {\n   188â†’\t\treturn err\n   189â†’\t}\n   190â†’\t_, err = s.db.ExecContext(ctx, `DELETE FROM runs WHERE id = ?`, id)\n   191â†’\treturn err\n   192â†’}\n   193â†’\n   194â†’func (s *Store) ListRuns(ctx context.Context, since time.Time) ([]*domain.Run, error) {\n   195â†’\tvar rows *sql.Rows\n   196â†’\tvar err error\n   197â†’\tif since.IsZero() {\n   198â†’\t\trows, err = s.db.QueryContext(ctx,\n   199â†’\t\t\t`SELECT `+runSelectCols+` FROM runs ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`)\n   200â†’\t} else {\n   201â†’\t\trows, err = s.db.QueryContext(ctx,\n   202â†’\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   203â†’\t\t\tformatTime(since))\n   204â†’\t}\n   205â†’\tif err != nil {\n   206â†’\t\treturn nil, err\n   207â†’\t}\n   208â†’\tdefer rows.Close()\n   209â†’\treturn scanRuns(rows)\n   210â†’}\n   211â†’\n   212â†’// scanRuns scans all rows into a []*domain.Run slice.\n   213â†’func scanRuns(rows *sql.Rows) ([]*domain.Run, error) {\n   214â†’\tvar runs []*domain.Run\n   215â†’\tfor rows.Next() {\n   216â†’\t\trun, err := scanRun(rows)\n   217â†’\t\tif err != nil {\n   218â†’\t\t\treturn nil, err\n   219â†’\t\t}\n   220â†’\t\truns = append(runs, run)\n   221â†’\t}\n   222â†’\treturn runs, rows.Err()\n   223â†’}\n   224â†’\n   225â†’func (s *Store) ListRunsByProject(ctx context.Context, projectDir string, since time.Time) ([]*domain.Run, error) {\n   226â†’\tvar rows *sql.Rows\n   227â†’\tvar err error\n   228â†’\tif since.IsZero() {\n   229â†’\t\trows, err = s.db.QueryContext(ctx,\n   230â†’\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   231â†’\t\t\tprojectDir)\n   232â†’\t} else {\n   233â†’\t\trows, err = s.db.QueryContext(ctx,\n   234â†’\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? AND started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   235â†’\t\t\tprojectDir, formatTime(since))\n   236â†’\t}\n   237â†’\tif err != nil {\n   238â†’\t\treturn nil, err\n   239â†’\t}\n   240â†’\tdefer rows.Close()\n   241â†’\treturn scanRuns(rows)\n   242â†’}\n   243â†’\n   244â†’func (s *Store) ListRunsFiltered(ctx context.Context, filter domain.RunListFilter) ([]*domain.Run, error) {\n   245â†’\tquery := `SELECT ` + runSelectCols + ` FROM runs WHERE 1=1`\n   246â†’\tvar args []interface{}\n   247â†’\n   248â†’\tif filter.ProjectDir != \"\" {\n   249â†’\t\tquery += ` AND project_dir = ?`\n   250â†’\t\targs = append(args, filter.ProjectDir)\n   251â†’\t}\n   252â†’\tif filter.State != \"\" {\n   253â†’\t\tquery += ` AND state = ?`\n   254â†’\t\targs = append(args, string(filter.State))\n   255â†’\t}\n   256â†’\tif filter.TaskID != \"\" {\n   257â†’\t\tquery += ` AND task_id = ?`\n   258â†’\t\targs = append(args, filter.TaskID)\n   259â†’\t}\n   260â†’\tif !filter.Since.IsZero() {\n   261â†’\t\tquery += ` AND started_at >= ?`\n   262â†’\t\targs = append(args, formatTime(filter.Since))\n   263â†’\t}\n   264â†’\n   265â†’\tquery += ` ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`\n   266â†’\n   267â†’\tif filter.Limit > 0 {\n   268â†’\t\tquery += fmt.Sprintf(` LIMIT %d`, filter.Limit)\n   269â†’\t}\n   270â†’\n   271â†’\trows, err := s.db.QueryContext(ctx, query, args...)\n   272â†’\tif err != nil {\n   273â†’\t\treturn nil, err\n   274â†’\t}\n   275â†’\tdefer rows.Close()\n   276â†’\treturn scanRuns(rows)\n   277â†’}\n   278â†’\n   279â†’func (s *Store) ListProjects(ctx context.Context) ([]string, error) {\n   280â†’\trows, err := s.db.QueryContext(ctx,\n   281â†’\t\t`SELECT DISTINCT project_dir FROM runs WHERE project_dir != '' ORDER BY project_dir`)\n   282â†’\tif err != nil {\n   283â†’\t\treturn nil, err\n   284â†’\t}\n   285â†’\tdefer rows.Close()\n   286â†’\n   287â†’\tvar projects []string\n   288â†’\tfor rows.Next() {\n   289â†’\t\tvar dir string\n   290â†’\t\tif err := rows.Scan(&dir); err != nil {\n   291â†’\t\t\treturn nil, err\n   292â†’\t\t}\n   293â†’\t\tprojects = append(projects, dir)\n   294â†’\t}\n   295â†’\treturn projects, rows.Err()\n   296â†’}\n   297â†’\n   298â†’func (s *Store) ListChildRuns(ctx context.Context, parentRunID string) ([]*domain.Run, error) {\n   299â†’\trows, err := s.db.QueryContext(ctx,\n   300â†’\t\t`SELECT `+runSelectCols+` FROM runs WHERE parent_run_id = ? ORDER BY started_at ASC`,\n   301â†’\t\tparentRunID)\n   302â†’\tif err != nil {\n   303â†’\t\treturn nil, err\n   304â†’\t}\n   305â†’\tdefer rows.Close()\n   306â†’\treturn scanRuns(rows)\n   307â†’}\n   308â†’\n   309â†’func (s *Store) SaveCapture(ctx context.Context, runID string, exec *domain.StepExecution) error {\n   310â†’\t_, err := s.db.ExecContext(ctx,\n   311â†’\t\t`INSERT INTO step_executions (run_id, step_name, result, started_at, completed_at, logs, git_ref)\n   312â†’\t\t VALUES (?, ?, ?, ?, ?, ?, ?)`,\n   313â†’\t\trunID, exec.StepName, exec.Result,\n   314â†’\t\tformatTime(exec.StartedAt), formatTime(exec.CompletedAt),\n   315â†’\t\texec.Logs, exec.GitRef,\n   316â†’\t)\n   317â†’\treturn err\n   318â†’}\n   319â†’\n   320â†’func (s *Store) GetCaptures(ctx context.Context, runID string) ([]*domain.StepExecution, error) {\n   321â†’\trows, err := s.db.QueryContext(ctx,\n   322â†’\t\t`SELECT step_name, result, started_at, completed_at, COALESCE(logs,''), COALESCE(git_ref,'')\n   323â†’\t\t FROM step_executions WHERE run_id = ? ORDER BY id`, runID)\n   324â†’\tif err != nil {\n   325â†’\t\treturn nil, err\n   326â†’\t}\n   327â†’\tdefer rows.Close()\n   328â†’\n   329â†’\tvar execs []*domain.StepExecution\n   330â†’\tfor rows.Next() {\n   331â†’\t\te := &domain.StepExecution{}\n   332â†’\t\tvar startedAt, completedAt string\n   333â†’\t\tif err := rows.Scan(&e.StepName, &e.Result, &startedAt, &completedAt, &e.Logs, &e.GitRef); err != nil {\n   334â†’\t\t\treturn nil, err\n   335â†’\t\t}\n   336â†’\t\te.StartedAt = parseTime(startedAt)\n   337â†’\t\te.CompletedAt = parseTime(completedAt)\n   338â†’\t\texecs = append(execs, e)\n   339â†’\t}\n   340â†’\treturn execs, rows.Err()\n   341â†’}\n   342â†’\n   343â†’func (s *Store) SaveLogFile(ctx context.Context, entry *ports.LogFileEntry) error {\n   344â†’\t_, err := s.db.ExecContext(ctx,\n   345â†’\t\t`INSERT INTO log_files (run_id, step_name, file_type, file_path, file_size, created_at)\n   346â†’\t\t VALUES (?, ?, ?, ?, ?, ?)`,\n   347â†’\t\tentry.RunID, entry.StepName, entry.FileType, entry.FilePath, entry.FileSize,\n   348â†’\t\tformatTime(entry.CreatedAt),\n   349â†’\t)\n   350â†’\treturn err\n   351â†’}\n   352â†’\n   353â†’func (s *Store) GetLogFiles(ctx context.Context, runID string) ([]*ports.LogFileEntry, error) {\n   354â†’\trows, err := s.db.QueryContext(ctx,\n   355â†’\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   356â†’\t\t FROM log_files WHERE run_id = ? ORDER BY id`, runID)\n   357â†’\tif err != nil {\n   358â†’\t\treturn nil, err\n   359â†’\t}\n   360â†’\tdefer rows.Close()\n   361â†’\treturn scanLogFiles(rows)\n   362â†’}\n   363â†’\n   364â†’func (s *Store) GetLogFilesByStep(ctx context.Context, runID, stepName string) ([]*ports.LogFileEntry, error) {\n   365â†’\trows, err := s.db.QueryContext(ctx,\n   366â†’\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   367â†’\t\t FROM log_files WHERE run_id = ? AND step_name = ? ORDER BY id`, runID, stepName)\n   368â†’\tif err != nil {\n   369â†’\t\treturn nil, err\n   370â†’\t}\n   371â†’\tdefer rows.Close()\n   372â†’\treturn scanLogFiles(rows)\n   373â†’}\n   374â†’\n   375â†’func (s *Store) GetLogFileByType(ctx context.Context, runID, fileType string) ([]*ports.LogFileEntry, error) {\n   376â†’\trows, err := s.db.QueryContext(ctx,\n   377â†’\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   378â†’\t\t FROM log_files WHERE run_id = ? AND file_type = ? ORDER BY id`, runID, fileType)\n   379â†’\tif err != nil {\n   380â†’\t\treturn nil, err\n   381â†’\t}\n   382â†’\tdefer rows.Close()\n   383â†’\treturn scanLogFiles(rows)\n   384â†’}\n   385â†’\n   386â†’func scanLogFiles(rows *sql.Rows) ([]*ports.LogFileEntry, error) {\n   387â†’\tvar entries []*ports.LogFileEntry\n   388â†’\tfor rows.Next() {\n   389â†’\t\te := &ports.LogFileEntry{}\n   390â†’\t\tvar createdAt string\n   391â†’\t\tif err := rows.Scan(&e.ID, &e.RunID, &e.StepName, &e.FileType, &e.FilePath, &e.FileSize, &createdAt); err != nil {\n   392â†’\t\t\treturn nil, err\n   393â†’\t\t}\n   394â†’\t\te.CreatedAt = parseTime(createdAt)\n   395â†’\t\tentries = append(entries, e)\n   396â†’\t}\n   397â†’\treturn entries, rows.Err()\n   398â†’}\n   399â†’\n   400â†’func (s *Store) SaveEvolution(ctx context.Context, entry *ports.EvolutionEntry) error {\n   401â†’\t_, err := s.db.ExecContext(ctx,\n   402â†’\t\t`INSERT INTO evolution_log (id, project_dir, workflow_name, trigger_run_id, created_at, classification, changes_json, knowledge_delta)\n   403â†’\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,\n   404â†’\t\tentry.ID, entry.ProjectDir, entry.WorkflowName, entry.TriggerRunID,\n   405â†’\t\tformatTime(entry.CreatedAt), entry.Classification, entry.ChangesJSON, entry.KnowledgeDelta,\n   406â†’\t)\n   407â†’\treturn err\n   408â†’}\n   409â†’\n   410â†’func (s *Store) GetLastEvolution(ctx context.Context, projectDir, workflowName string) (*ports.EvolutionEntry, error) {\n   411â†’\trow := s.db.QueryRowContext(ctx,\n   412â†’\t\t`SELECT id, project_dir, workflow_name, trigger_run_id, created_at, COALESCE(classification,''), changes_json, COALESCE(knowledge_delta,'')\n   413â†’\t\t FROM evolution_log WHERE project_dir = ? AND workflow_name = ? ORDER BY created_at DESC LIMIT 1`,\n   414â†’\t\tprojectDir, workflowName)\n   415â†’\n   416â†’\tentry := &ports.EvolutionEntry{}\n   417â†’\tvar createdAt string\n   418â†’\terr := row.Scan(&entry.ID, &entry.ProjectDir, &entry.WorkflowName, &entry.TriggerRunID,\n   419â†’\t\t&createdAt, &entry.Classification, &entry.ChangesJSON, &entry.KnowledgeDelta)\n   420â†’\tif err == sql.ErrNoRows {\n   421â†’\t\treturn nil, nil\n   422â†’\t}\n   423â†’\tif err != nil {\n   424â†’\t\treturn nil, err\n   425â†’\t}\n   426â†’\tentry.CreatedAt = parseTime(createdAt)\n   427â†’\treturn entry, nil\n   428â†’}\n   429â†’\n   430â†’func (s *Store) ListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error) {\n   431â†’\tvar rows *sql.Rows\n   432â†’\tvar err error\n   433â†’\n   434â†’\tif sinceRunID == \"\" {\n   435â†’\t\trows, err = s.db.QueryContext(ctx,\n   436â†’\t\t\t`SELECT `+runSelectCols+`\n   437â†’\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? ORDER BY started_at ASC`,\n   438â†’\t\t\tprojectDir, workflowName)\n   439â†’\t} else {\n   440â†’\t\trows, err = s.db.QueryContext(ctx,\n   441â†’\t\t\t`SELECT `+runSelectCols+`\n   442â†’\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? AND started_at > (SELECT started_at FROM runs WHERE id = ?)\n   443â†’\t\t\t ORDER BY started_at ASC`,\n   444â†’\t\t\tprojectDir, workflowName, sinceRunID)\n   445â†’\t}\n   446â†’\tif err != nil {\n   447â†’\t\treturn nil, err\n   448â†’\t}\n   449â†’\tdefer rows.Close()\n   450â†’\treturn scanRuns(rows)\n   451â†’}\n   452â†’\n   453â†’\n   454â†’func (s *Store) FailStaleRuns(ctx context.Context) (int64, error) {\n   455â†’\tnow := formatTime(time.Now())\n   456â†’\tres, err := s.db.ExecContext(ctx,\n   457â†’\t\t`UPDATE runs SET state = 'failed', completed_at = ?, error_message = 'daemon restarted while run was active'\n   458â†’\t\t WHERE state IN ('pending', 'running')`,\n   459â†’\t\tnow,\n   460â†’\t)\n   461â†’\tif err != nil {\n   462â†’\t\treturn 0, err\n   463â†’\t}\n   464â†’\treturn res.RowsAffected()\n   465â†’}\n   466â†’\n   467â†’func formatTime(t time.Time) string {\n   468â†’\tif t.IsZero() {\n   469â†’\t\treturn \"\"\n   470â†’\t}\n   471â†’\treturn t.Format(time.RFC3339Nano)\n   472â†’}\n   473â†’\n   474â†’func parseTime(s string) time.Time {\n   475â†’\tif s == \"\" {\n   476â†’\t\treturn time.Time{}\n   477â†’\t}\n   478â†’\tt, _ := time.Parse(time.RFC3339Nano, s)\n   479â†’\treturn t\n   480â†’}\n   481â†’\n   482â†’func boolToInt(b bool) int {\n   483â†’\tif b {\n   484â†’\t\treturn 1\n   485â†’\t}\n   486â†’\treturn 0\n   487â†’}\n   488â†’\n   489â†’const maxErrorMessageLen = 1000\n   490â†’\n   491â†’// truncateErrorMessage caps s to maxErrorMessageLen characters to prevent\n   492â†’// oversized agent output dumps from bloating the database. Full error\n   493â†’// details remain available in step logs.\n   494â†’func truncateErrorMessage(s string) string {\n   495â†’\tif len(s) <= maxErrorMessageLen {\n   496â†’\t\treturn s\n   497â†’\t}\n   498â†’\treturn s[:maxErrorMessageLen] + \"... (truncated)\"\n   499â†’}\n   500â†’"}]},"parent_tool_use_id":"toolu_01HqGxcttN3K6oLdYWbW3TM7","session_id":"4d7e8ba7-70ae-45e4-b438-c668f354765a","uuid":"164830ce-d8eb-459e-9232-d9df5b83427e"}
