61â†’\t\t}\n    62â†’\t\tcmdGet(os.Args[2:])\n    63â†’\t\treturn\n    64â†’\tcase \"set\":\n    65â†’\t\tif hasHelpFlag(os.Args[2:]) {\n    66â†’\t\t\tprintSubcommandHelp(\"set\")\n    67â†’\t\t\treturn\n    68â†’\t\t}\n    69â†’\t\tcmdSet(os.Args[2:])\n    70â†’\t\treturn\n    71â†’\tcase \"tasks\":\n    72â†’\t\tif hasHelpFlag(os.Args[2:]) {\n    73â†’\t\t\tprintSubcommandHelp(\"tasks\")\n    74â†’\t\t\treturn\n    75â†’\t\t}\n    76â†’\t\tcmdTasks(os.Args[2:])\n    77â†’\t\treturn\n    78â†’\tcase \"workflow\":\n    79â†’\t\tif hasHelpFlag(os.Args[2:]) {\n    80â†’\t\t\tprintSubcommandHelp(\"workflow\")\n    81â†’\t\t\treturn\n    82â†’\t\t}\n    83â†’\t\tcmdWorkflow(os.Args[2:])\n    84â†’\t\treturn\n    85â†’\t}\n    86â†’\n    87â†’\t// Handle --help for daemon commands before connecting\n    88â†’\tdaemonCmds := map[string]bool{\n    89â†’\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n    90â†’\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n    91â†’\t}\n    92â†’\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n    93â†’\t\tprintSubcommandHelp(os.Args[1])\n    94â†’\t\treturn\n    95â†’\t}\n    96â†’\n    97â†’\t// Commands that need a daemon connection\n    98â†’\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    99â†’\tif addr == \"\" {\n   100â†’\t\taddr = \"unix:///tmp/cloche.sock\"\n   101â†’\t}\n   102â†’\n   103â†’\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   104â†’\tif err != nil {\n   105â†’\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   106â†’\t\tos.Exit(1)\n   107â†’\t}\n   108â†’\tdefer conn.Close()\n   109â†’\n   110â†’\tclient := pb.NewClocheServiceClient(conn)\n   111â†’\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   112â†’\tdefer cancel()\n   113â†’\n   114â†’\tswitch os.Args[1] {\n   115â†’\tcase \"run\":\n   116â†’\t\tcmdRun(ctx, client, os.Args[2:])\n   117â†’\tcase \"status\":\n   118â†’\t\tcmdStatus(ctx, client, os.Args[2:])\n   119â†’\tcase \"logs\":\n   120â†’\t\tcmdLogs(client, os.Args[2:])\n   121â†’\tcase \"poll\":\n   122â†’\t\tcmdPoll(client, os.Args[2:])\n   123â†’\tcase \"list\":\n   124â†’\t\tcmdList(ctx, client, os.Args[2:])\n   125â†’\tcase \"stop\":\n   126â†’\t\tcmdStop(ctx, client, os.Args[2:])\n   127â†’\tcase \"delete\":\n   128â†’\t\tcmdDelete(ctx, client, os.Args[2:])\n   129â†’\tcase \"loop\":\n   130â†’\t\tcmdLoop(ctx, client, os.Args[2:])\n   131â†’\tcase \"shutdown\":\n   132â†’\t\tcmdShutdown(ctx, client)\n   133â†’\tdefault:\n   134â†’\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   135â†’\t\tprintTopLevelHelp()\n   136â†’\t\tos.Exit(1)\n   137â†’\t}\n   138â†’}\n   139â†’\n   140â†’\n   141â†’func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   142â†’\tvar workflow, prompt, title string\n   143â†’\tvar keepContainer bool\n   144â†’\n   145â†’\tfor i := 0; i < len(args); i++ {\n   146â†’\t\tswitch args[i] {\n   147â†’\t\tcase \"--workflow\":\n   148â†’\t\t\tif i+1 < len(args) {\n   149â†’\t\t\t\ti++\n   150â†’\t\t\t\tworkflow = args[i]\n   151â†’\t\t\t}\n   152â†’\t\tcase \"--prompt\", \"-p\":\n   153â†’\t\t\tif i+1 < len(args) {\n   154â†’\t\t\t\ti++\n   155â†’\t\t\t\tprompt = args[i]\n   156â†’\t\t\t}\n   157â†’\t\tcase \"--title\":\n   158â†’\t\t\tif i+1 < len(args) {\n   159â†’\t\t\t\ti++\n   160â†’\t\t\t\ttitle = args[i]\n   161â†’\t\t\t}\n   162â†’\t\tcase \"--keep-container\":\n   163â†’\t\t\tkeepContainer = true\n   164â†’\t\tdefault:\n   165â†’\t\t\t// Support bare positional arg as workflow name for backwards compat\n   166â†’\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   167â†’\t\t\t\tworkflow = args[i]\n   168â†’\t\t\t}\n   169â†’\t\t}\n   170â†’\t}\n   171â†’\n   172â†’\tif workflow == \"\" {\n   173â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   174â†’\t\tos.Exit(1)\n   175â†’\t}\n   176â†’\n   177â†’\tcwd, _ := os.Getwd()\n   178â†’\n   179â†’\t// Resolve image from workflow file (soft failure â€” fall back to daemon default)\n   180â†’\tvar image string\n   181â†’\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   182â†’\tif data, err := os.ReadFile(wfPath); err == nil {\n   183â†’\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   184â†’\t\t\timage = wf.Config[\"container.image\"]\n   185â†’\t\t}\n   186â†’\t}\n   187â†’\n   188â†’\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   189â†’\t\tWorkflowName:  workflow,\n   190â†’\t\tProjectDir:    cwd,\n   191â†’\t\tImage:         image,\n   192â†’\t\tPrompt:        prompt,\n   193â†’\t\tKeepContainer: keepContainer,\n   194â†’\t\tTitle:         title,\n   195â†’\t})\n   196â†’\tif err != nil {\n   197â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   198â†’\t\tos.Exit(1)\n   199â†’\t}\n   200â†’\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   201â†’}\n   202â†’\n   203â†’func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   204â†’\tif len(args) < 1 {\n   205â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   206â†’\t\tos.Exit(1)\n   207â†’\t}\n   208â†’\n   209â†’\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   210â†’\tif err != nil {\n   211â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   212â†’\t\tos.Exit(1)\n   213â†’\t}\n   214â†’\n   215â†’\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   216â†’\tif resp.Title != \"\" {\n   217â†’\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   218â†’\t}\n   219â†’\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   220â†’\tif resp.IsHost {\n   221â†’\t\tfmt.Printf(\"Type:      host\\n\")\n   222â†’\t} else {\n   223â†’\t\tfmt.Printf(\"Type:      container\\n\")\n   224â†’\t}\n   225â†’\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   226â†’\tif resp.ContainerId != \"\" {\n   227â†’\t\tcid := resp.ContainerId\n   228â†’\t\tif len(cid) > 12 {\n   229â†’\t\t\tcid = cid[:12]\n   230â†’\t\t}\n   231â†’\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   232â†’\t}\n   233â†’\tif resp.ErrorMessage != \"\" {\n   234â†’\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   235â†’\t}\n   236â†’\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   237â†’\tfor _, exec := range resp.StepExecutions {\n   238â†’\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   239â†’\t}\n   240â†’}\n   241â†’\n   242â†’func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   243â†’\tvar all bool\n   244â†’\tvar projectDir, stateFilter, issueFilter string\n   245â†’\tvar limit int32\n   246â†’\n   247â†’\tfor i := 0; i < len(args); i++ {\n   248â†’\t\tswitch args[i] {\n   249â†’\t\tcase \"--all\":\n   250â†’\t\t\tall = true\n   251â†’\t\tcase \"--project\", \"-p\":\n   252â†’\t\t\tif i+1 < len(args) {\n   253â†’\t\t\t\ti++\n   254â†’\t\t\t\tprojectDir = args[i]\n   255â†’\t\t\t}\n   256â†’\t\tcase \"--state\", \"-s\":\n   257â†’\t\t\tif i+1 < len(args) {\n   258â†’\t\t\t\ti++\n   259â†’\t\t\t\tstateFilter = args[i]\n   260â†’\t\t\t}\n   261â†’\t\tcase \"--limit\", \"-n\":\n   262â†’\t\t\tif i+1 < len(args) {\n   263â†’\t\t\t\ti++\n   264â†’\t\t\t\tn, err := strconv.Atoi(args[i])\n   265â†’\t\t\t\tif err != nil {\n   266â†’\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   267â†’\t\t\t\t\tos.Exit(1)\n   268â†’\t\t\t\t}\n   269â†’\t\t\t\tlimit = int32(n)\n   270â†’\t\t\t}\n   271â†’\t\tcase \"--issue\", \"-i\":\n   272â†’\t\t\tif i+1 < len(args) {\n   273â†’\t\t\t\ti++\n   274â†’\t\t\t\tissueFilter = args[i]\n   275â†’\t\t\t}\n   276â†’\t\t}\n   277â†’\t}\n   278â†’\n   279â†’\treq := &pb.ListRunsRequest{\n   280â†’\t\tState:  stateFilter,\n   281â†’\t\tLimit:  limit,\n   282â†’\t\tTaskId: issueFilter,\n   283â†’\t}\n   284â†’\tif projectDir != \"\" {\n   285â†’\t\treq.ProjectDir = projectDir\n   286â†’\t} else if all {\n   287â†’\t\treq.All = true\n   288â†’\t} else {\n   289â†’\t\t// Default: filter to current project\n   290â†’\t\tcwd, _ := os.Getwd()\n   291â†’\t\treq.ProjectDir = cwd\n   292â†’\t}\n   293â†’\n   294â†’\tresp, err := client.ListRuns(ctx, req)\n   295â†’\tif err != nil {\n   296â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   297â†’\t\tos.Exit(1)\n   298â†’\t}\n   299â†’\n   300â†’\tif len(resp.Runs) == 0 {\n   301â†’\t\tfmt.Println(\"No runs found.\")\n   302â†’\t\treturn\n   303â†’\t}\n   304â†’\n   305â†’\tfor _, run := range resp.Runs {\n   306â†’\t\trunType := \"container\"\n   307â†’\t\tif run.IsHost {\n   308â†’\t\t\trunType = \"host\"\n   309â†’\t\t}\n   310â†’\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   311â†’\t\tif run.Title != \"\" {\n   312â†’\t\t\tt := run.Title\n   313â†’\t\t\tif len(t) > 40 {\n   314â†’\t\t\t\tt = t[:37] + \"...\"\n   315â†’\t\t\t}\n   316â†’\t\t\tline += \"  \" + t\n   317â†’\t\t}\n   318â†’\t\tif run.ContainerId != \"\" {\n   319â†’\t\t\tline += \"  \" + run.ContainerId\n   320â†’\t\t}\n   321â†’\t\tif run.ErrorMessage != \"\" {\n   322â†’\t\t\terrMsg := run.ErrorMessage\n   323â†’\t\t\tif len(errMsg) > 60 {\n   324â†’\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   325â†’\t\t\t}\n   326â†’\t\t\tline += \"  \" + errMsg\n   327â†’\t\t}\n   328â†’\t\tfmt.Println(line)\n   329â†’\t}\n   330â†’}\n   331â†’\n   332â†’func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   333â†’\tif len(args) < 1 {\n   334â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n   335â†’\t\tos.Exit(1)\n   336â†’\t}\n   337â†’\n   338â†’\tvar stepFilter, typeFilter string\n   339â†’\tvar follow bool\n   340â†’\trunID := args[0]\n   341â†’\n   342â†’\tfor i := 1; i < len(args); i++ {\n   343â†’\t\tswitch args[i] {\n   344â†’\t\tcase \"--step\":\n   345â†’\t\t\tif i+1 < len(args) {\n   346â†’\t\t\t\ti++\n   347â†’\t\t\t\tstepFilter = args[i]\n   348â†’\t\t\t}\n   349â†’\t\tcase \"--type\":\n   350â†’\t\t\tif i+1 < len(args) {\n   351â†’\t\t\t\ti++\n   352â†’\t\t\t\ttypeFilter = args[i]\n   353â†’\t\t\t}\n   354â†’\t\tcase \"--follow\", \"-f\":\n   355â†’\t\t\tfollow = true\n   356â†’\t\t}\n   357â†’\t}\n   358â†’\n   359â†’\t// Use background context â€” log output can be large and follow mode blocks.\n   360â†’\tctx := context.Background()\n   361â†’\tif follow {\n   362â†’\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n   363â†’\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   364â†’\t}\n   365â†’\n   366â†’\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   367â†’\t\tRunId:    runID,\n   368â†’\t\tStepName: stepFilter,\n   369â†’\t\tLogType:  typeFilter,\n   370â†’\t})\n   371â†’\tif err != nil {\n   372â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   373â†’\t\tos.Exit(1)\n   374â†’\t}\n   375â†’\n   376â†’\tfor {\n   377â†’\t\tentry, err := stream.Recv()\n   378â†’\t\tif err != nil {\n   379â†’\t\t\tif errors.Is(err, io.EOF) {\n   380â†’\t\t\t\tbreak\n   381â†’\t\t\t}\n   382â†’\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   383â†’\t\t\tos.Exit(1)\n   384â†’\t\t}\n   385â†’\n   386â†’\t\tswitch entry.Type {\n   387â†’\t\tcase \"step_started\":\n   388â†’\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   389â†’\t\t\tif entry.Message != \"\" {\n   390â†’\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   391â†’\t\t\t}\n   392â†’\t\tcase \"step_completed\":\n   393â†’\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   394â†’\t\t\tif entry.Message != \"\" {\n   395â†’\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   396â†’\t\t\t}\n   397â†’\t\tcase \"run_completed\":\n   398â†’\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   399â†’\t\t\tif entry.Message != \"\" {\n   400â†’\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   401â†’\t\t\t}\n   402â†’\t\tcase \"full_log\":\n   403â†’\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   404â†’\t\tcase \"log\":\n   405â†’\t\t\t// Live-streamed log line from an active run.\n   406â†’\t\t\tfmt.Println(entry.Message)\n   407â†’\t\tdefault:\n   408â†’\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   409â†’\t\t\tif entry.StepName != \"\" {\n   410â†’\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   411â†’\t\t\t}\n   412â†’\t\t\tif entry.Message != \"\" {\n   413â†’\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   414â†’\t\t\t}\n   415â†’\t\t}\n   416â†’\t}\n   417â†’}\n   418â†’\n   419â†’func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   420â†’\tif len(args) < 1 {\n   421â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   422â†’\t\tos.Exit(1)\n   423â†’\t}\n   424â†’\n   425â†’\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   426â†’\tif err != nil {\n   427â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   428â†’\t\tos.Exit(1)\n   429â†’\t}\n   430â†’\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   431â†’}\n   432â†’\n   433â†’func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   434â†’\tif len(args) < 1 {\n   435â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   436â†’\t\tos.Exit(1)\n   437â†’\t}\n   438â†’\n   439â†’\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   440â†’\tif err != nil {\n   441â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   442â†’\t\tos.Exit(1)\n   443â†’\t}\n   444â†’\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   445â†’}\n   446â†’\n   447â†’func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   448â†’\tcwd, _ := os.Getwd()\n   449â†’\n   450â†’\t// Check for \"stop\" subcommand\n   451â†’\tif len(args) > 0 && args[0] == \"stop\" {\n   452â†’\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   453â†’\t\tif err != nil {\n   454â†’\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   455â†’\t\t\tos.Exit(1)\n   456â†’\t\t}\n   457â†’\t\tfmt.Println(\"Orchestration loop stopped.\")\n   458â†’\t\treturn\n   459â†’\t}\n   460â†’\n   461â†’\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   462â†’\tvar maxConcurrent int32\n   463â†’\tfor i := 0; i < len(args); i++ {\n   464â†’\t\tswitch args[i] {\n   465â†’\t\tcase \"--max\":\n   466â†’\t\t\tif i+1 < len(args) {\n   467â†’\t\t\t\ti++\n   468â†’\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   469â†’\t\t\t\tif n != 1 || err != nil {\n   470â†’\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   471â†’\t\t\t\t\tos.Exit(1)\n   472â†’\t\t\t\t}\n   473â†’\t\t\t}\n   474â†’\t\t}\n   475â†’\t}\n   476â†’\n   477â†’\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   478â†’\t\tProjectDir:    cwd,\n   479â†’\t\tMaxConcurrent: maxConcurrent,\n   480â†’\t})\n   481â†’\tif err != nil {\n   482â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   483â†’\t\tos.Exit(1)\n   484â†’\t}\n   485â†’\tif maxConcurrent > 0 {\n   486â†’\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   487â†’\t} else {\n   488â†’\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   489â†’\t}\n   490â†’}\n   491â†’\n   492â†’func cmdTasks(args []string) {\n   493â†’\t// Determine HTTP address from env\n   494â†’\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   495â†’\tif httpAddr == \"\" {\n   496â†’\t\thttpAddr = \"localhost:8080\"\n   497â†’\t}\n   498â†’\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   499â†’\n   500â†’\t// Determine project label from --project flag or current directory\n   501â†’\tprojectDir := \"\"\n   502â†’\tfor i := 0; i < len(args); i++ {\n   503â†’\t\tswitch args[i] {\n   504â†’\t\tcase \"--project\":\n   505â†’\t\t\tif i+1 < len(args) {\n   506â†’\t\t\t\ti++\n   507â†’\t\t\t\tprojectDir = args[i]\n   508â†’\t\t\t}\n   509â†’\t\t}\n   510â†’\t}\n   511â†’\n   512â†’\tif projectDir == \"\" {\n   513â†’\t\tcwd, _ := os.Getwd()\n   514â†’\t\tprojectDir = filepath.Base(cwd)\n   515â†’\t}\n   516â†’\n   517â†’\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   518â†’\tresp, err := http.Get(tasksURL)\n   519â†’\tif err != nil {\n   520â†’\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   521â†’\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   522â†’\t\tos.Exit(1)\n   523â†’\t}\n   524â†’\tdefer resp.Body.Close()\n   525â†’\n   526â†’\tif resp.StatusCode != 200 {\n   527â†’\t\tbody, _ := io.ReadAll(resp.Body)\n   528â†’\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   529â†’\t\tos.Exit(1)\n   530â†’\t}\n   531â†’\n   532â†’\ttype taskEntry struct {\n   533â†’\t\tID          string `json:\"id\"`\n   534â†’\t\tStatus      string `json:\"status\"`\n   535â†’\t\tTitle       string `json:\"title\"`\n   536â†’\t\tDescription string `json:\"description\"`\n   537â†’\t\tAssigned    bool   `json:\"assigned\"`\n   538â†’\t\tAssignedAt  string `json:\"assigned_at\"`\n   539â†’\t\tRunID       string `json:\"run_id\"`\n   540â†’\t}\n   541â†’\n   542â†’\tvar tasks []taskEntry\n   543â†’\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   544â†’\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   545â†’\t\tos.Exit(1)\n   546â†’\t}\n   547â†’\n   548â†’\tif len(tasks) == 0 {\n   549â†’\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   550â†’\t\treturn\n   551â†’\t}\n   552â†’\n   553â†’\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   554â†’\tfor _, t := range tasks {\n   555â†’\t\tstatus := t.Status\n   556â†’\t\tif status == \"\" {\n   557â†’\t\t\tstatus = \"open\"\n   558â†’\t\t}\n   559â†’\t\tassigned := \"-\"\n   560â†’\t\tif t.Assigned {\n   561â†’\t\t\tassigned = \"yes\"\n   562â†’\t\t}\n   563â†’\t\trunID := \"\"\n   564â†’\t\tif t.RunID != \"\" {\n   565â†’\t\t\trunID = t.RunID\n   566â†’\t\t\tif len(runID) > 30 {\n   567â†’\t\t\t\trunID = runID[:27] + \"...\"\n   568â†’\t\t\t}\n   569â†’\t\t}\n   570â†’\t\ttitle := t.Title\n   571â†’\t\tif len(title) > 40 {\n   572â†’\t\t\ttitle = title[:37] + \"...\"\n   573â†’\t\t}\n   574â†’\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   575â†’\t}\n   576â†’}\n   577â†’\n   578â†’func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   579â†’\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   580â†’\tif err != nil {\n   581â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   582â†’\t\tos.Exit(1)\n   583â†’\t}\n   584â†’\tfmt.Println(\"Daemon shutting down.\")\n   585â†’}\n   586â†’\n   587â†’// resolveRunContext returns the project directory and run ID for context\n   588â†’// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   589â†’// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   590â†’func resolveRunContext() (projectDir, runID string, err error) {\n   591â†’\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   592â†’\tif runID == \"\" {\n   593â†’\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   594â†’\t}\n   595â†’\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   596â†’\tif projectDir == \"\" {\n   597â†’\t\tprojectDir, err = os.Getwd()\n   598â†’\t\tif err != nil {\n   599â†’\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   600â†’\t\t}\n   601â†’\t}\n   602â†’\treturn projectDir, runID, nil\n   603â†’}\n   604â†’\n   605â†’func cmdGet(args []string) {\n   606â†’\tif len(args) < 1 {\n   607â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   608â†’\t\tos.Exit(1)\n   609â†’\t}\n   610â†’\n   611â†’\tprojectDir, runID, err := resolveRunContext()\n   612â†’\tif err != nil {\n   613â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   614â†’\t\tos.Exit(1)\n   615â†’\t}\n   616â†’\n   617â†’\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   618â†’\tif err != nil {\n   619â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   620â†’\t\tos.Exit(1)\n   621â†’\t}\n   622â†’\tif !ok {\n   623â†’\t\tos.Exit(1)\n   624â†’\t}\n   625â†’\tfmt.Println(val)\n   626â†’}\n   627â†’\n   628â†’func cmdSet(args []string) {\n   629â†’\tif len(args) < 2 {\n   630â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   631â†’\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   632â†’\t\tos.Exit(1)\n   633â†’\t}\n   634â†’\n   635â†’\tprojectDir, runID, err := resolveRunContext()\n   636â†’\tif err != nil {\n   637â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   638â†’\t\tos.Exit(1)\n   639â†’\t}\n   640â†’\n   641â†’\tvalue := args[1]\n   642â†’\tif value == \"-\" {\n   643â†’\t\tdata, err := io.ReadAll(os.Stdin)\n   644â†’\t\tif err != nil {\n   645â†’\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   646â†’\t\t\tos.Exit(1)\n   647â†’\t\t}\n   648â†’\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   649â†’\t}\n   650â†’\n   651â†’\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   652â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   653â†’\t\tos.Exit(1)\n   654â†’\t}\n   655â†’}\n   656â†’"}]},"parent_tool_use_id":"toolu_01HqGxcttN3K6oLdYWbW3TM7","session_id":"4d7e8ba7-70ae-45e4-b438-c668f354765a","uuid":"ed2cf32a-bdf6-40a4-a8f1-12a3c32e8882"}
