{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ECZmf1Rjnq69u7uBEzPRaY","type":"tool_result","content":"     1→syntax = \"proto3\";\n     2→\n     3→package cloche.v1;\n     4→\n     5→option go_package = \"github.com/cloche-dev/cloche/api/clochepb\";\n     6→\n     7→service ClocheService {\n     8→  rpc RunWorkflow(RunWorkflowRequest) returns (RunWorkflowResponse);\n     9→  rpc GetStatus(GetStatusRequest) returns (GetStatusResponse);\n    10→  rpc StreamLogs(StreamLogsRequest) returns (stream LogEntry);\n    11→  rpc StopRun(StopRunRequest) returns (StopRunResponse);\n    12→  rpc ListRuns(ListRunsRequest) returns (ListRunsResponse);\n    13→  rpc Shutdown(ShutdownRequest) returns (ShutdownResponse);\n    14→  rpc DeleteContainer(DeleteContainerRequest) returns (DeleteContainerResponse);\n    15→\n    16→  rpc EnableLoop(EnableLoopRequest) returns (EnableLoopResponse);\n    17→  rpc DisableLoop(DisableLoopRequest) returns (DisableLoopResponse);\n    18→}\n    19→\n    20→message RunWorkflowRequest {\n    21→  string workflow_name = 1;\n    22→  string project_dir = 2;\n    23→  string image = 3;\n    24→  string prompt = 4;\n    25→  bool keep_container = 5;\n    26→  string title = 6;\n    27→}\n    28→\n    29→message RunWorkflowResponse {\n    30→  string run_id = 1;\n    31→}\n    32→\n    33→message GetStatusRequest {\n    34→  string run_id = 1;\n    35→}\n    36→\n    37→message GetStatusResponse {\n    38→  string run_id = 1;\n    39→  string workflow_name = 2;\n    40→  string state = 3;\n    41→  string current_step = 4;\n    42→  repeated StepExecutionStatus step_executions = 5;\n    43→  string error_message = 6;\n    44→  string container_id = 7;\n    45→  bool container_alive = 8;\n    46→  string container_dead_since = 9;\n    47→  string title = 10;\n    48→  bool is_host = 11;\n    49→}\n    50→\n    51→message StepExecutionStatus {\n    52→  string step_name = 1;\n    53→  string result = 2;\n    54→  string started_at = 3;\n    55→  string completed_at = 4;\n    56→}\n    57→\n    58→message StreamLogsRequest {\n    59→  string run_id = 1;\n    60→  string step_name = 2;\n    61→  string log_type = 3;\n    62→  bool follow = 4;  // When true, stream existing logs then continue tailing new lines (like tail -f).\n    63→                     // Passed via gRPC metadata header \"x-cloche-follow\" until proto is regenerated.\n    64→}\n    65→\n    66→message LogEntry {\n    67→  string type = 1;\n    68→  string step_name = 2;\n    69→  string result = 3;\n    70→  string message = 4;\n    71→  string timestamp = 5;\n    72→}\n    73→\n    74→message StopRunRequest {\n    75→  string run_id = 1;\n    76→}\n    77→\n    78→message StopRunResponse {}\n    79→\n    80→message ShutdownRequest {}\n    81→\n    82→message ShutdownResponse {}\n    83→\n    84→message DeleteContainerRequest {\n    85→  string id = 1;\n    86→}\n    87→\n    88→message DeleteContainerResponse {}\n    89→\n    90→message ListRunsRequest {\n    91→  bool all = 1;\n    92→  string project_dir = 2;\n    93→}\n    94→\n    95→message ListRunsResponse {\n    96→  repeated RunSummary runs = 1;\n    97→}\n    98→\n    99→message RunSummary {\n   100→  string run_id = 1;\n   101→  string workflow_name = 2;\n   102→  string state = 3;\n   103→  string started_at = 4;\n   104→  string error_message = 5;\n   105→  string container_id = 6;\n   106→  string title = 7;\n   107→  bool is_host = 8;\n   108→  string project_dir = 9;\n   109→}\n   110→\n   111→message EnableLoopRequest {\n   112→  string project_dir = 1;\n   113→  int32 max_concurrent = 2;\n   114→}\n   115→\n   116→message EnableLoopResponse {}\n   117→\n   118→message DisableLoopRequest {\n   119→  string project_dir = 1;\n   120→}\n   121→\n   122→message DisableLoopResponse {}\n   123→"}]},"parent_tool_use_id":"toolu_01R6FyHX8ezBGpk4fQZXf4qj","session_id":"c0b250b2-f9c5-4d6e-a2b5-21933ebd9c8c","uuid":"f407afb1-ea26-44c0-bc48-bc3535644c54"}
