{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YCx9TrxDwCRM97vrWtrhiY","type":"tool_result","content":"     1→package grpc_test\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"sync/atomic\"\n    10→\t\"testing\"\n    11→\t\"time\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\tserver \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    15→\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    16→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    17→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    18→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    19→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    20→\t\"github.com/stretchr/testify/assert\"\n    21→\t\"github.com/stretchr/testify/require\"\n    22→\tgrpclib \"google.golang.org/grpc\"\n    23→\t\"google.golang.org/grpc/metadata\"\n    24→)\n    25→\n    26→func TestServer_ListRuns_Empty(t *testing.T) {\n    27→\tstore, err := sqlite.NewStore(\":memory:\")\n    28→\trequire.NoError(t, err)\n    29→\tdefer store.Close()\n    30→\n    31→\tsrv := server.NewClocheServer(store, nil)\n    32→\tresp, err := srv.ListRuns(context.Background(), &pb.ListRunsRequest{All: true})\n    33→\trequire.NoError(t, err)\n    34→\tassert.Empty(t, resp.Runs)\n    35→}\n    36→\n    37→func TestServer_ListRuns_FilterByProject(t *testing.T) {\n    38→\tstore, err := sqlite.NewStore(\":memory:\")\n    39→\trequire.NoError(t, err)\n    40→\tdefer store.Close()\n    41→\n    42→\tctx := context.Background()\n    43→\n    44→\t// Create runs for two different projects\n    45→\trunA := domain.NewRun(\"run-proj-a\", \"wf\")\n    46→\trunA.ProjectDir = \"/home/user/project-a\"\n    47→\trequire.NoError(t, store.CreateRun(ctx, runA))\n    48→\n    49→\trunB := domain.NewRun(\"run-proj-b\", \"wf\")\n    50→\trunB.ProjectDir = \"/home/user/project-b\"\n    51→\trequire.NoError(t, store.CreateRun(ctx, runB))\n    52→\n    53→\tsrv := server.NewClocheServer(store, nil)\n    54→\n    55→\t// Filter by project-a: should only return runA\n    56→\tresp, err := srv.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: \"/home/user/project-a\"})\n    57→\trequire.NoError(t, err)\n    58→\trequire.Len(t, resp.Runs, 1)\n    59→\tassert.Equal(t, \"run-proj-a\", resp.Runs[0].RunId)\n    60→\tassert.Equal(t, \"/home/user/project-a\", resp.Runs[0].ProjectDir)\n    61→\n    62→\t// Filter by project-b: should only return runB\n    63→\tresp, err = srv.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: \"/home/user/project-b\"})\n    64→\trequire.NoError(t, err)\n    65→\trequire.Len(t, resp.Runs, 1)\n    66→\tassert.Equal(t, \"run-proj-b\", resp.Runs[0].RunId)\n    67→\n    68→\t// No filter (--all): should return both\n    69→\tresp, err = srv.ListRuns(ctx, &pb.ListRunsRequest{All: true})\n    70→\trequire.NoError(t, err)\n    71→\tassert.Len(t, resp.Runs, 2)\n    72→}\n    73→\n    74→func TestServer_GetStatus_NotFound(t *testing.T) {\n    75→\tstore, err := sqlite.NewStore(\":memory:\")\n    76→\trequire.NoError(t, err)\n    77→\tdefer store.Close()\n    78→\n    79→\tsrv := server.NewClocheServer(store, nil)\n    80→\t_, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: \"nonexistent\"})\n    81→\tassert.Error(t, err)\n    82→}\n    83→\n    84→func TestServer_RunWorkflow(t *testing.T) {\n    85→\tstore, err := sqlite.NewStore(\":memory:\")\n    86→\trequire.NoError(t, err)\n    87→\tdefer store.Close()\n    88→\n    89→\tdir := t.TempDir()\n    90→\n    91→\t// Create a mock \"agent\" shell script at test.cloche that outputs JSON status lines.\n    92→\t// The local runtime runs: sh <projectDir>/test.cloche\n    93→\tmsgs := []protocol.StatusMessage{\n    94→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n    95→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n    96→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n    97→\t}\n    98→\tscript := \"#!/bin/sh\\n\"\n    99→\tfor _, msg := range msgs {\n   100→\t\tdata, _ := json.Marshal(msg)\n   101→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   102→\t}\n   103→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   104→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   105→\n   106→\t// Use \"sh\" as the agent binary so it runs: sh test.cloche\n   107→\trt := local.NewRuntime(\"sh\")\n   108→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   109→\n   110→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   111→\t\tWorkflowName: \"test\",\n   112→\t\tProjectDir:   dir,\n   113→\t\tPrompt:       \"hello world\",\n   114→\t})\n   115→\trequire.NoError(t, err)\n   116→\tassert.NotEmpty(t, resp.RunId)\n   117→\n   118→\t// Verify prompt was written to run-specific path\n   119→\tpromptData, err := os.ReadFile(filepath.Join(dir, \".cloche\", resp.RunId, \"prompt.txt\"))\n   120→\trequire.NoError(t, err)\n   121→\tassert.Equal(t, \"hello world\", string(promptData))\n   122→\n   123→\t// Poll until the background goroutine finishes processing (up to 5s)\n   124→\tvar status *pb.GetStatusResponse\n   125→\tdeadline := time.Now().Add(5 * time.Second)\n   126→\tfor time.Now().Before(deadline) {\n   127→\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   128→\t\trequire.NoError(t, err)\n   129→\t\tif status.State == \"succeeded\" && len(status.StepExecutions) >= 1 {\n   130→\t\t\tbreak\n   131→\t\t}\n   132→\t\ttime.Sleep(50 * time.Millisecond)\n   133→\t}\n   134→\n   135→\t// Check that the run was tracked and completed\n   136→\trequire.NotNil(t, status)\n   137→\tassert.Equal(t, resp.RunId, status.RunId)\n   138→\tassert.Equal(t, \"succeeded\", status.State)\n   139→\tassert.GreaterOrEqual(t, len(status.StepExecutions), 1)\n   140→}\n   141→\n   142→func TestServer_RunWorkflow_WithTitle(t *testing.T) {\n   143→\tstore, err := sqlite.NewStore(\":memory:\")\n   144→\trequire.NoError(t, err)\n   145→\tdefer store.Close()\n   146→\n   147→\tdir := t.TempDir()\n   148→\n   149→\tmsgs := []protocol.StatusMessage{\n   150→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   151→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   152→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   153→\t}\n   154→\tscript := \"#!/bin/sh\\n\"\n   155→\tfor _, msg := range msgs {\n   156→\t\tdata, _ := json.Marshal(msg)\n   157→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   158→\t}\n   159→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   160→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   161→\n   162→\trt := local.NewRuntime(\"sh\")\n   163→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   164→\n   165→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   166→\t\tWorkflowName: \"test\",\n   167→\t\tProjectDir:   dir,\n   168→\t\tPrompt:       \"do something\",\n   169→\t\tTitle:        \"Add dark mode toggle\",\n   170→\t})\n   171→\trequire.NoError(t, err)\n   172→\tassert.NotEmpty(t, resp.RunId)\n   173→\n   174→\t// Poll until the background goroutine finishes\n   175→\tdeadline := time.Now().Add(5 * time.Second)\n   176→\tvar status *pb.GetStatusResponse\n   177→\tfor time.Now().Before(deadline) {\n   178→\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   179→\t\trequire.NoError(t, err)\n   180→\t\tif status.State == \"succeeded\" {\n   181→\t\t\tbreak\n   182→\t\t}\n   183→\t\ttime.Sleep(50 * time.Millisecond)\n   184→\t}\n   185→\n   186→\trequire.NotNil(t, status)\n   187→\tassert.Equal(t, \"Add dark mode toggle\", status.Title)\n   188→}\n   189→\n   190→func TestServer_RunWorkflow_AgentGeneratesTitle(t *testing.T) {\n   191→\tstore, err := sqlite.NewStore(\":memory:\")\n   192→\trequire.NoError(t, err)\n   193→\tdefer store.Close()\n   194→\n   195→\tdir := t.TempDir()\n   196→\n   197→\t// Mock agent outputs a run_title message (simulating agent-generated title)\n   198→\tmsgs := []protocol.StatusMessage{\n   199→\t\t{Type: protocol.MsgRunTitle, Message: \"Agent generated title\"},\n   200→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},"}]},"parent_tool_use_id":"toolu_01R6FyHX8ezBGpk4fQZXf4qj","session_id":"c0b250b2-f9c5-4d6e-a2b5-21933ebd9c8c","uuid":"7f960d95-1e91-42c2-a655-14aafbd9ba99"}
