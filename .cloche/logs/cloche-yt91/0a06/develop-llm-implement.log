{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JeM4Ypk7zqp9hqPJqUJE2A","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    19→\t\"github.com/cloche-dev/cloche/internal/config\"\n    20→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    21→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    22→\t\"github.com/cloche-dev/cloche/internal/host\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    26→\trpcgrpc \"google.golang.org/grpc\"\n    27→\t\"google.golang.org/grpc/metadata\"\n    28→)\n    29→\n    30→type ClocheServer struct {\n    31→\tpb.UnimplementedClocheServiceServer\n    32→\tstore        ports.RunStore\n    33→\tcaptures     ports.CaptureStore\n    34→\tlogStore     ports.LogStore\n    35→\tcontainer    ports.ContainerRuntime\n    36→\tdefaultImage string\n    37→\tevolution    *evolution.Trigger\n    38→\tlogBroadcast *logstream.Broadcaster\n    39→\tshutdownFn   func()\n    40→\tmu           sync.Mutex\n    41→\trunIDs       map[string]string      // run_id -> container_id\n    42→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    43→}\n    44→\n    45→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    46→\treturn &ClocheServer{\n    47→\t\tstore:     store,\n    48→\t\tcontainer: container,\n    49→\t\trunIDs:    make(map[string]string),\n    50→\t\tloops:     make(map[string]*host.Loop),\n    51→\t}\n    52→}\n    53→\n    54→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    55→\treturn &ClocheServer{\n    56→\t\tstore:        store,\n    57→\t\tcaptures:     captures,\n    58→\t\tcontainer:    container,\n    59→\t\tdefaultImage: defaultImage,\n    60→\t\trunIDs:       make(map[string]string),\n    61→\t\tloops:        make(map[string]*host.Loop),\n    62→\t}\n    63→}\n    64→\n    65→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    66→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    67→\ts.logStore = ls\n    68→}\n    69→\n    70→\n    71→// SetEvolution attaches an evolution trigger to the server.\n    72→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    73→\ts.evolution = trigger\n    74→}\n    75→\n    76→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    77→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    78→\ts.logBroadcast = b\n    79→}\n    80→\n    81→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    82→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    83→\ts.shutdownFn = fn\n    84→}\n    85→\n    86→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    87→\tif s.container == nil {\n    88→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    89→\t}\n    90→\n    91→\t// Generate a unique run ID, retrying on collision\n    92→\tvar runID string\n    93→\tfor attempts := 0; attempts < 10; attempts++ {\n    94→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    95→\t\texisting, err := s.store.GetRun(ctx, runID)\n    96→\t\tif err != nil {\n    97→\t\t\tbreak // ID is free\n    98→\t\t}\n    99→\t\t// Reuse if completed more than 1 hour ago\n   100→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   101→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   102→\t\t\tbreak\n   103→\t\t}\n   104→\t}\n   105→\n   106→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   107→\tif req.Prompt != \"\" {\n   108→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   109→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   110→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   111→\t\t}\n   112→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   113→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   114→\t\t}\n   115→\t}\n   116→\trun := domain.NewRun(runID, req.WorkflowName)\n   117→\trun.ProjectDir = req.ProjectDir\n   118→\trun.Title = req.Title\n   119→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   120→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   121→\t}\n   122→\n   123→\t// Resolve image: request-level override, then server default\n   124→\timage := req.Image\n   125→\tif image == \"\" {\n   126→\t\timage = s.defaultImage\n   127→\t}\n   128→\n   129→\t// Launch container start + tracking in background so the RPC returns immediately.\n   130→\t// The run stays in \"pending\" state until the container is up.\n   131→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   132→\n   133→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   134→}\n   135→\n   136→// launchAndTrack starts the container and then tracks it to completion.\n   137→// It runs in a background goroutine with its own context, independent of the\n   138→// RPC context which may be cancelled after RunWorkflow returns.\n   139→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   140→\tctx := context.Background()\n   141→\n   142→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   143→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   144→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   145→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   146→\t\t\tif run != nil {\n   147→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   148→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   149→\t\t\t}\n   150→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   151→\t\t\t\treturn\n   152→\t\t}\n   153→\t}\n   154→\n   155→\tbaseSHA := gitHEAD(req.ProjectDir)\n   156→\n   157→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   158→\t\tImage:        image,\n   159→\t\tWorkflowName: req.WorkflowName,\n   160→\t\tProjectDir:   req.ProjectDir,\n   161→\t\tRunID:        runID,\n   162→\t\tNetworkAllow: []string{\"*\"},\n   163→\t})\n   164→\tif err != nil {\n   165→\t\trun, _ := s.store.GetRun(ctx, runID)\n   166→\t\tif run != nil {\n   167→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   168→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   169→\t\t}\n   170→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   171→\t\treturn\n   172→\t}\n   173→\n   174→\ts.mu.Lock()\n   175→\ts.runIDs[runID] = containerID\n   176→\ts.mu.Unlock()\n   177→\n   178→\trun, _ := s.store.GetRun(ctx, runID)\n   179→\tif run != nil {\n   180→\t\trun.Start()\n   181→\t\trun.ContainerID = containerID\n   182→\t\trun.BaseSHA = baseSHA\n   183→\t\t_ = s.store.UpdateRun(ctx, run)\n   184→\t}\n   185→\n   186→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   187→}\n   188→\n   189→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   190→\tctx := context.Background()\n   191→\n   192→\t// Attach to agent output\n   193→\treader, err := s.container.AttachOutput(ctx, containerID)\n   194→\tif err != nil {\n   195→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   196→\t\t\treturn\n   197→\t}\n   198→\n   199→\t// Parse JSON-lines status messages\n   200→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   201→\tscanner := bufio.NewScanner(reader)\n   202→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   203→\tfor scanner.Scan() {\n   204→\t\tvar msg protocol.StatusMessage\n   205→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   206→\t\t\tcontinue\n   207→\t\t}\n   208→\n   209→\t\t// Fast path: log messages don't need store interaction.\n   210→\t\tif msg.Type == protocol.MsgLog {\n   211→\t\t\tif s.logBroadcast != nil {\n   212→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   213→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   214→\t\t\t\t\tType:      \"llm\",\n   215→\t\t\t\t\tContent:   msg.Message,\n   216→\t\t\t\t\tStepName:  msg.StepName,\n   217→\t\t\t\t})\n   218→\t\t\t}\n   219→\t\t\tcontinue\n   220→\t\t}\n   221→\n   222→\t\trun, err := s.store.GetRun(ctx, runID)\n   223→\t\tif err != nil {\n   224→\t\t\tcontinue\n   225→\t\t}\n   226→\n   227→\t\tswitch msg.Type {\n   228→\t\tcase protocol.MsgStepStarted:\n   229→\t\t\trun.RecordStepStart(msg.StepName)\n   230→\t\t\tif s.captures != nil {\n   231→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   232→\t\t\t\t\tStepName:  msg.StepName,\n   233→\t\t\t\t\tStartedAt: msg.Timestamp,\n   234→\t\t\t\t})\n   235→\t\t\t}\n   236→\t\t\tif s.logBroadcast != nil {\n   237→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   238→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   239→\t\t\t\t\tType:      \"status\",\n   240→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   241→\t\t\t\t\tStepName:  msg.StepName,\n   242→\t\t\t\t})\n   243→\t\t\t}\n   244→\t\tcase protocol.MsgStepCompleted:\n   245→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   246→\t\t\tif s.captures != nil {\n   247→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   248→\t\t\t\t\tStepName:    msg.StepName,\n   249→\t\t\t\t\tResult:      msg.Result,\n   250→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   251→\t\t\t\t})\n   252→\t\t\t}\n   253→\t\t\tif s.logBroadcast != nil {\n   254→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   255→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   256→\t\t\t\t\tType:      \"status\",\n   257→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   258→\t\t\t\t\tStepName:  msg.StepName,\n   259→\t\t\t\t})\n   260→\t\t\t}\n   261→\t\tcase protocol.MsgRunTitle:\n   262→\t\t\tif run.Title == \"\" {\n   263→\t\t\t\trun.Title = msg.Message\n   264→\t\t\t}\n   265→\t\tcase protocol.MsgRunCompleted:\n   266→\t\t\treportedResult = msg.Result\n   267→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   268→\t\t}\n   269→\n   270→\t\t_ = s.store.UpdateRun(ctx, run)\n   271→\t}\n   272→\treader.Close()\n   273→\n   274→\t// Signal live-stream subscribers that this run is done.\n   275→\tif s.logBroadcast != nil {\n   276→\t\ts.logBroadcast.Finish(runID)\n   277→\t}\n   278→\n   279→\t// Wait for process exit\n   280→\texitCode, err := s.container.Wait(ctx, containerID)\n   281→\tif err != nil {\n   282→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   283→\t}\n   284→\n   285→\t// Extract step output files from container before it's removed\n   286→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   287→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   288→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   289→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   290→\t\t}\n   291→\t}\n   292→\n   293→\t// Capture full container stdout/stderr before the container is removed\n   294→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   295→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   296→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   297→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   298→\t\t}\n   299→\t}\n   300→\n   301→\t// Index extracted log files in the log store\n   302→\tif s.logStore != nil {\n   303→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   304→\t}\n   305→\n   306→\t// Extract results to git branch BEFORE finalizing state, so that\n   307→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   308→\t// before the run is marked complete.\n   309→\tresultLabel := reportedResult\n   310→\tif resultLabel == \"\" {\n   311→\t\tif exitCode == 0 {\n   312→\t\t\tresultLabel = \"succeeded\"\n   313→\t\t} else {\n   314→\t\t\tresultLabel = \"failed\"\n   315→\t\t}\n   316→\t}\n   317→\t{\n   318→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   319→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   320→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   321→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   322→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   323→\t\t\t} else {\n   324→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   325→\t\t\t}\n   326→\t\t} else {\n   327→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   328→\t\t}\n   329→\t}\n   330→\n   331→\t// Now finalize run state\n   332→\trun, err := s.store.GetRun(ctx, runID)\n   333→\tif err != nil {\n   334→\t\treturn\n   335→\t}\n   336→\tif run.State == domain.RunStateRunning {\n   337→\t\tif reportedResult == \"succeeded\" {\n   338→\t\t\trun.Complete(domain.RunStateSucceeded)\n   339→\t\t} else if reportedResult != \"\" {\n   340→\t\t\trun.Complete(domain.RunStateFailed)\n   341→\t\t} else if exitCode == 0 {\n   342→\t\t\trun.Complete(domain.RunStateSucceeded)\n   343→\t\t} else {\n   344→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   345→\t\t}\n   346→\t\t_ = s.store.UpdateRun(ctx, run)\n   347→\t}\n   348→\n   349→\t// Fire evolution trigger if configured\n   350→\tif s.evolution != nil {\n   351→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   352→\t}\n   353→\n   354→\t// Merge is handled as a workflow step in host.cloche, not here.\n   355→\n   356→\t// Container retention policy:\n   357→\t// - Failed runs: always keep the container for debugging\n   358→\t// - Successful runs + --keep-container: keep the container\n   359→\t// - Successful runs without --keep-container: remove the container\n   360→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   361→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   362→\n   363→\tif keepContainer || runFailed {\n   364→\t\treason := \"--keep-container\"\n   365→\t\tif runFailed {\n   366→\t\t\treason = \"run failed\"\n   367→\t\t}\n   368→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   369→\t\tif runFinal != nil {\n   370→\t\t\trunFinal.ContainerKept = true\n   371→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   372→\t\t}\n   373→\t} else {\n   374→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   375→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   376→\t\t} else {\n   377→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   378→\t\t}\n   379→\t}\n   380→\n   381→\t// Cleanup mapping\n   382→\ts.mu.Lock()\n   383→\tdelete(s.runIDs, runID)\n   384→\ts.mu.Unlock()\n   385→}\n   386→\n   387→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   388→\tvar runs []*domain.Run\n   389→\tvar err error\n   390→\tif req.ProjectDir != \"\" {\n   391→\t\t// Project-scoped: no time filter (project is sufficient scoping)\n   392→\t\truns, err = s.store.ListRunsByProject(ctx, req.ProjectDir, time.Time{})\n   393→\t} else if req.All {\n   394→\t\truns, err = s.store.ListRuns(ctx, time.Time{})\n   395→\t} else {\n   396→\t\truns, err = s.store.ListRuns(ctx, time.Now().Add(-1*time.Hour))\n   397→\t}\n   398→\tif err != nil {\n   399→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   400→\t}\n   401→\n   402→\tresp := &pb.ListRunsResponse{}\n   403→\tfor _, run := range runs {\n   404→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   405→\t\t\tRunId:        run.ID,\n   406→\t\t\tWorkflowName: run.WorkflowName,\n   407→\t\t\tState:        string(run.State),\n   408→\t\t\tStartedAt:    run.StartedAt.String(),\n   409→\t\t\tErrorMessage: run.ErrorMessage,\n   410→\t\t\tContainerId:  run.ContainerID,\n   411→\t\t\tTitle:        run.Title,\n   412→\t\t\tIsHost:       run.IsHost,\n   413→\t\t\tProjectDir:   run.ProjectDir,\n   414→\t\t})\n   415→\t}\n   416→\treturn resp, nil\n   417→}\n   418→\n   419→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   420→\trun, err := s.store.GetRun(ctx, req.RunId)\n   421→\tif err != nil {\n   422→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   423→\t}\n   424→\n   425→\tresp := &pb.GetStatusResponse{\n   426→\t\tRunId:        run.ID,\n   427→\t\tWorkflowName: run.WorkflowName,\n   428→\t\tState:        string(run.State),\n   429→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   430→\t\tErrorMessage: run.ErrorMessage,\n   431→\t\tContainerId:  run.ContainerID,\n   432→\t\tTitle:        run.Title,\n   433→\t\tIsHost:       run.IsHost,\n   434→\t}\n   435→\n   436→\t// Check container liveness\n   437→\tif run.ContainerID != \"\" && s.container != nil {\n   438→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   439→\t\t\tresp.ContainerAlive = cs.Running\n   440→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   441→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   442→\t\t\t}\n   443→\t\t}\n   444→\t}\n   445→\n   446→\t// Load step executions from captures store if available\n   447→\tif s.captures != nil {\n   448→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   449→\t\tif err == nil {\n   450→\t\t\tfor _, exec := range captures {\n   451→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   452→\t\t\t\t\tStepName:    exec.StepName,\n   453→\t\t\t\t\tResult:      exec.Result,\n   454→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   455→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   456→\t\t\t\t})\n   457→\t\t\t}\n   458→\t\t}\n   459→\t} else {\n   460→\t\tfor _, exec := range run.StepExecutions {\n   461→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   462→\t\t\t\tStepName:    exec.StepName,\n   463→\t\t\t\tResult:      exec.Result,\n   464→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   465→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   466→\t\t\t})\n   467→\t\t}\n   468→\t}\n   469→\n   470→\treturn resp, nil\n   471→}\n   472→\n   473→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   474→\tctx := stream.Context()\n   475→\n   476→\t// Check for follow mode via gRPC metadata.\n   477→\tfollow := followFromContext(ctx)\n   478→\n   479→\t// Verify run exists\n   480→\trun, err := s.store.GetRun(ctx, req.RunId)\n   481→\tif err != nil {\n   482→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   483→\t}\n   484→\n   485→\t// If step_name or log_type filter is set, serve content directly from the log index\n   486→\tif req.StepName != \"\" || req.LogType != \"\" {\n   487→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   488→\t}\n   489→\n   490→\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n   491→\n   492→\t// With -f on an active run: send existing logs then tail live output.\n   493→\tif follow && isActive && s.logBroadcast != nil {\n   494→\t\treturn s.streamFollowLogs(req.RunId, run, stream)\n   495→\t}\n   496→\n   497→\t// Without -f on an active run: snapshot existing logs and return.\n   498→\t// (Legacy callers that relied on implicit live streaming should use -f.)\n   499→\t// With -f on a completed run: same as without -f — no new lines will arrive.\n   500→\n   501→\t// Check for full.log first — if it exists, serve it as the unified log\n   502→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   503→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   504→\t\tif err := stream.Send(&pb.LogEntry{\n   505→\t\t\tType:    \"full_log\",\n   506→\t\t\tMessage: string(data),\n   507→\t\t}); err != nil {\n   508→\t\t\treturn err\n   509→\t\t}\n   510→\t\tif !isActive {\n   511→\t\t\tif err := stream.Send(&pb.LogEntry{\n   512→\t\t\t\tType:      \"run_completed\",\n   513→\t\t\t\tResult:    string(run.State),\n   514→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   515→\t\t\t\tMessage:   run.ErrorMessage,\n   516→\t\t\t}); err != nil {\n   517→\t\t\t\treturn err\n   518→\t\t\t}\n   519→\t\t}\n   520→\t\treturn nil\n   521→\t}\n   522→\n   523→\tif s.captures == nil {\n   524→\t\treturn fmt.Errorf(\"captures store not configured\")\n   525→\t}\n   526→\n   527→\t// Fall back to capture-based streaming\n   528→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   529→\tif err != nil {\n   530→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   531→\t}\n   532→\n   533→\tfor _, exec := range captures {\n   534→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   535→\t\t// and one for step_completed (has Result).\n   536→\t\tif exec.Result == \"\" {\n   537→\t\t\tentry := &pb.LogEntry{\n   538→\t\t\t\tType:      \"step_started\",\n   539→\t\t\t\tStepName:  exec.StepName,\n   540→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   541→\t\t\t}\n   542→\t\t\tif err := stream.Send(entry); err != nil {\n   543→\t\t\t\treturn err\n   544→\t\t\t}\n   545→\t\t} else {\n   546→\t\t\t// Read step output from per-step output file.\n   547→\t\t\t// Container runs write .log, host runs write .out — try both.\n   548→\t\t\tvar output string\n   549→\t\t\tfor _, ext := range []string{\".log\", \".out\"} {\n   550→\t\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+ext)\n   551→\t\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   552→\t\t\t\t\toutput = string(data)\n   553→\t\t\t\t\tbreak\n   554→\t\t\t\t}\n   555→\t\t\t}\n   556→\t\t\tentry := &pb.LogEntry{\n   557→\t\t\t\tType:      \"step_completed\",\n   558→\t\t\t\tStepName:  exec.StepName,\n   559→\t\t\t\tResult:    exec.Result,\n   560→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   561→\t\t\t\tMessage:   output,\n   562→\t\t\t}\n   563→\t\t\tif err := stream.Send(entry); err != nil {\n   564→\t\t\t\treturn err\n   565→\t\t\t}\n   566→\t\t}\n   567→\t}\n   568→\n   569→\t// Send run completion entry\n   570→\tif !isActive {\n   571→\t\tif err := stream.Send(&pb.LogEntry{\n   572→\t\t\tType:      \"run_completed\",\n   573→\t\t\tResult:    string(run.State),\n   574→\t\t\tTimestamp: run.CompletedAt.String(),\n   575→\t\t\tMessage:   run.ErrorMessage,\n   576→\t\t}); err != nil {\n   577→\t\t\treturn err\n   578→\t\t}\n   579→\t}\n   580→\n   581→\treturn nil\n   582→}\n   583→\n   584→// followFromContext checks for the follow flag in gRPC metadata.\n   585→func followFromContext(ctx context.Context) bool {\n   586→\tmd, ok := metadata.FromIncomingContext(ctx)\n   587→\tif !ok {\n   588→\t\treturn false\n   589→\t}\n   590→\tvals := md.Get(\"x-cloche-follow\")\n   591→\treturn len(vals) > 0 && vals[0] == \"true\"\n   592→}\n   593→\n   594→// streamFollowLogs sends existing log content then tails live output from the\n   595→// broadcaster. It combines snapshot + live streaming (like tail -f).\n   596→func (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   597→\t// Subscribe first so we don't miss lines written between read and subscribe.\n   598→\tsub := s.logBroadcast.Subscribe(runID)\n   599→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   600→\n   601→\t// Send existing full.log content if available.\n   602→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n   603→\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n   604→\t\tif err := stream.Send(&pb.LogEntry{\n   605→\t\t\tType:    \"full_log\",\n   606→\t\t\tMessage: string(data),\n   607→\t\t}); err != nil {\n   608→\t\t\treturn err\n   609→\t\t}\n   610→\t}\n   611→\n   612→\t// Now tail live output from the broadcaster.\n   613→\tctx := stream.Context()\n   614→\tfor {\n   615→\t\tselect {\n   616→\t\tcase <-ctx.Done():\n   617→\t\t\treturn ctx.Err()\n   618→\t\tcase line, ok := <-sub.C:\n   619→\t\t\tif !ok {\n   620→\t\t\t\t// Run completed — send terminal entry.\n   621→\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n   622→\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n   623→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   624→\t\t\t\t\t\tType:      \"run_completed\",\n   625→\t\t\t\t\t\tResult:    string(r.State),\n   626→\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n   627→\t\t\t\t\t\tMessage:   r.ErrorMessage,\n   628→\t\t\t\t\t})\n   629→\t\t\t\t}\n   630→\t\t\t\treturn nil\n   631→\t\t\t}\n   632→\t\t\tif err := stream.Send(&pb.LogEntry{\n   633→\t\t\t\tType:      \"log\",\n   634→\t\t\t\tStepName:  line.StepName,\n   635→\t\t\t\tMessage:   line.Content,\n   636→\t\t\t\tTimestamp: line.Timestamp,\n   637→\t\t\t}); err != nil {\n   638→\t\t\t\treturn err\n   639→\t\t\t}\n   640→\t\t}\n   641→\t}\n   642→}\n   643→\n   644→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   645→// It uses the log index when available, falling back to file path conventions.\n   646→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   647→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   648→\n   649→\t// Try log index first\n   650→\tif s.logStore != nil {\n   651→\t\tvar logFiles []*ports.LogFileEntry\n   652→\t\tvar err error\n   653→\n   654→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   655→\t\t\t// Filter by both step and type\n   656→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   657→\t\t\tif err == nil {\n   658→\t\t\t\tfiltered := logFiles[:0]\n   659→\t\t\t\tfor _, lf := range logFiles {\n   660→\t\t\t\t\tif lf.FileType == req.LogType {\n   661→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   662→\t\t\t\t\t}\n   663→\t\t\t\t}\n   664→\t\t\t\tlogFiles = filtered\n   665→\t\t\t}\n   666→\t\t} else if req.StepName != \"\" {\n   667→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   668→\t\t} else {\n   669→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   670→\t\t}\n   671→\n   672→\t\tif err == nil && len(logFiles) > 0 {\n   673→\t\t\tfor _, lf := range logFiles {\n   674→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   675→\t\t\t\tif readErr != nil {\n   676→\t\t\t\t\tcontinue\n   677→\t\t\t\t}\n   678→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   679→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   680→\t\t\t\t\tStepName: lf.StepName,\n   681→\t\t\t\t\tMessage:  string(data),\n   682→\t\t\t\t}); err != nil {\n   683→\t\t\t\t\treturn err\n   684→\t\t\t\t}\n   685→\t\t\t}\n   686→\t\t\treturn nil\n   687→\t\t}\n   688→\t}\n   689→\n   690→\t// Fall back to file path conventions\n   691→\tif req.StepName != \"\" {\n   692→\t\tvar logPath string\n   693→\t\tswitch req.LogType {\n   694→\t\tcase \"llm\":\n   695→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   696→\t\tdefault:\n   697→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   698→\t\t}\n   699→\n   700→\t\tdata, err := os.ReadFile(logPath)\n   701→\t\tif err != nil {\n   702→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   703→\t\t}\n   704→\t\treturn stream.Send(&pb.LogEntry{\n   705→\t\t\tType:     \"step_log\",\n   706→\t\t\tStepName: req.StepName,\n   707→\t\t\tMessage:  string(data),\n   708→\t\t})\n   709→\t}\n   710→\n   711→\treturn fmt.Errorf(\"no log files found matching filter\")\n   712→}\n   713→\n   714→// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n   715→// time for an active run. The stream closes when the run completes or the\n   716→// client disconnects.\n   717→func (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   718→\tsub := s.logBroadcast.Subscribe(runID)\n   719→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   720→\n   721→\tctx := stream.Context()\n   722→\tfor {\n   723→\t\tselect {\n   724→\t\tcase <-ctx.Done():\n   725→\t\t\treturn ctx.Err()\n   726→\t\tcase line, ok := <-sub.C:\n   727→\t\t\tif !ok {\n   728→\t\t\t\t// Run completed — send terminal entry.\n   729→\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   730→\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   731→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   732→\t\t\t\t\t\tType:      \"run_completed\",\n   733→\t\t\t\t\t\tResult:    string(run.State),\n   734→\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   735→\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   736→\t\t\t\t\t})\n   737→\t\t\t\t}\n   738→\t\t\t\treturn nil\n   739→\t\t\t}\n   740→\t\t\tif err := stream.Send(&pb.LogEntry{\n   741→\t\t\t\tType:      \"log\",\n   742→\t\t\t\tStepName:  line.StepName,\n   743→\t\t\t\tMessage:   line.Content,\n   744→\t\t\t\tTimestamp: line.Timestamp,\n   745→\t\t\t}); err != nil {\n   746→\t\t\t\treturn err\n   747→\t\t\t}\n   748→\t\t}\n   749→\t}\n   750→}\n   751→\n   752→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   753→\ts.mu.Lock()\n   754→\tcontainerID, ok := s.runIDs[req.RunId]\n   755→\ts.mu.Unlock()\n   756→\n   757→\tif !ok {\n   758→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   759→\t}\n   760→\n   761→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   762→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   763→\t}\n   764→\n   765→\t// Mark as cancelled in store\n   766→\trun, err := s.store.GetRun(ctx, req.RunId)\n   767→\tif err == nil {\n   768→\t\trun.Complete(domain.RunStateCancelled)\n   769→\t\t_ = s.store.UpdateRun(ctx, run)\n   770→\t}\n   771→\n   772→\treturn &pb.StopRunResponse{}, nil\n   773→}\n   774→\n   775→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   776→\tif s.container == nil {\n   777→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   778→\t}\n   779→\n   780→\tid := req.Id\n   781→\tif id == \"\" {\n   782→\t\treturn nil, fmt.Errorf(\"id is required\")\n   783→\t}\n   784→\n   785→\t// Try to resolve as a run ID first\n   786→\tcontainerID := id\n   787→\trun, err := s.store.GetRun(ctx, id)\n   788→\tif err == nil {\n   789→\t\t// It's a run ID — use the container ID from the run record\n   790→\t\tif run.ContainerID == \"\" {\n   791→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   792→\t\t}\n   793→\t\tcontainerID = run.ContainerID\n   794→\t}\n   795→\n   796→\t// Remove the container\n   797→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   798→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   799→\t}\n   800→\n   801→\t// If we resolved a run, clear the container_kept flag\n   802→\tif run != nil {\n   803→\t\trun.ContainerKept = false\n   804→\t\t_ = s.store.UpdateRun(ctx, run)\n   805→\t}\n   806→\n   807→\treturn &pb.DeleteContainerResponse{}, nil\n   808→}\n   809→\n   810→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   811→\tprojectDir := req.ProjectDir\n   812→\tif projectDir == \"\" {\n   813→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   814→\t}\n   815→\n   816→\t// Verify host.cloche exists\n   817→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   818→\tif _, err := os.Stat(hostPath); err != nil {\n   819→\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n   820→\t}\n   821→\n   822→\t// Load project config for defaults.\n   823→\tprojCfg, _ := config.Load(projectDir)\n   824→\n   825→\tmaxConc := int(req.MaxConcurrent)\n   826→\tif maxConc <= 0 {\n   827→\t\tmaxConc = projCfg.Orchestration.Concurrency\n   828→\t}\n   829→\tif maxConc <= 0 {\n   830→\t\tmaxConc = 1\n   831→\t}\n   832→\n   833→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   834→\n   835→\t// Compute dedup timeout from config (default 5 minutes).\n   836→\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n   837→\n   838→\tloopCfg := host.LoopConfig{\n   839→\t\tProjectDir:    projectDir,\n   840→\t\tMaxConcurrent: maxConc,\n   841→\t\tStaggerDelay:  stagger,\n   842→\t\tDedupTimeout:  dedupTimeout,\n   843→\t}\n   844→\n   845→\ts.mu.Lock()\n   846→\tdefer s.mu.Unlock()\n   847→\n   848→\t// Stop existing loop if running.\n   849→\tif existing, ok := s.loops[projectDir]; ok {\n   850→\t\texisting.Stop()\n   851→\t}\n   852→\n   853→\t// Check if host.cloche defines a list-tasks workflow for three-phase mode.\n   854→\tvar loop *host.Loop\n   855→\tif s.hasWorkflow(hostPath, \"list-tasks\") {\n   856→\t\tloop = s.createPhaseLoop(loopCfg, projectDir, hostPath, dedupTimeout)\n   857→\t} else {\n   858→\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n   859→\t}\n   860→\n   861→\ts.loops[projectDir] = loop\n   862→\tloop.Start()\n   863→\n   864→\treturn &pb.EnableLoopResponse{}, nil\n   865→}\n   866→\n   867→// hasWorkflow checks if host.cloche contains a workflow with the given name.\n   868→func (s *ClocheServer) hasWorkflow(hostPath, workflowName string) bool {\n   869→\tdata, err := os.ReadFile(hostPath)\n   870→\tif err != nil {\n   871→\t\treturn false\n   872→\t}\n   873→\treturn strings.Contains(string(data), fmt.Sprintf(\"workflow %q\", workflowName))\n   874→}\n   875→\n   876→// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n   877→// main, and finalize workflows from host.cloche.\n   878→func (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir, hostPath string, dedupTimeout time.Duration) *host.Loop {\n   879→\t// Phase 1: list-tasks function\n   880→\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n   881→\t\trunner := &host.Runner{\n   882→\t\t\tDispatcher: s,\n   883→\t\t\tStore:      s.store,\n   884→\t\t}\n   885→\t\ttasks, _, err := host.RunListTasksWorkflow(ctx, runner, projDir)\n   886→\t\treturn tasks, err\n   887→\t}\n   888→\n   889→\t// Phase 2: main function\n   890→\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   891→\t\trunner := &host.Runner{\n   892→\t\t\tDispatcher:   s,\n   893→\t\t\tStore:        s.store,\n   894→\t\t\tCaptures:     s.captures,\n   895→\t\t\tLogBroadcast: s.logBroadcast,\n   896→\t\t\tTaskID:       taskID,\n   897→\t\t}\n   898→\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n   899→\t}\n   900→\n   901→\t// Phase 3: finalize function (optional — only if host.cloche has it)\n   902→\tvar finalizeFn host.FinalizeFunc\n   903→\tif s.hasWorkflow(hostPath, \"finalize\") {\n   904→\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n   905→\t\t\tmainRunID := \"\"\n   906→\t\t\tmainOutcome := \"failed\"\n   907→\t\t\tif mainResult != nil {\n   908→\t\t\t\tmainRunID = mainResult.RunID\n   909→\t\t\t\tmainOutcome = string(mainResult.State)\n   910→\t\t\t}\n   911→\t\t\trunner := &host.Runner{\n   912→\t\t\t\tDispatcher:   s,\n   913→\t\t\t\tStore:        s.store,\n   914→\t\t\t\tCaptures:     s.captures,\n   915→\t\t\t\tLogBroadcast: s.logBroadcast,\n   916→\t\t\t\tTaskID:       taskID,\n   917→\t\t\t\tExtraEnv: []string{\n   918→\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n   919→\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n   920→\t\t\t\t},\n   921→\t\t\t}\n   922→\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n   923→\t\t}\n   924→\t}\n   925→\n   926→\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n   927→\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n   928→}\n   929→\n   930→// createLegacyLoop creates a legacy single-function orchestration loop.\n   931→func (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n   932→\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   933→\t\trunner := &host.Runner{\n   934→\t\t\tDispatcher:   s,\n   935→\t\t\tStore:        s.store,\n   936→\t\t\tCaptures:     s.captures,\n   937→\t\t\tLogBroadcast: s.logBroadcast,\n   938→\t\t\tTaskID:       taskID,\n   939→\t\t}\n   940→\t\treturn runner.Run(ctx, projDir)\n   941→\t}\n   942→\n   943→\tloop := host.NewLoop(loopCfg, s.store, runFn)\n   944→\n   945→\t// Configure daemon-managed task assignment if a list-tasks command is set.\n   946→\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n   947→\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n   948→\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n   949→\t}\n   950→\n   951→\treturn loop\n   952→}\n   953→\n   954→// GetLoopTasks returns the current task pipeline state for a project's\n   955→// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n   956→// loop is active for the project.\n   957→func (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n   958→\ts.mu.Lock()\n   959→\tloop, ok := s.loops[projectDir]\n   960→\ts.mu.Unlock()\n   961→\tif !ok {\n   962→\t\treturn nil\n   963→\t}\n   964→\tsnapshot := loop.GetTaskSnapshot()\n   965→\tentries := make([]web.TaskEntry, len(snapshot))\n   966→\tfor i, e := range snapshot {\n   967→\t\tentry := web.TaskEntry{\n   968→\t\t\tID:          e.Task.ID,\n   969→\t\t\tStatus:      e.Task.Status,\n   970→\t\t\tTitle:       e.Task.Title,\n   971→\t\t\tDescription: e.Task.Description,\n   972→\t\t\tMetadata:    e.Task.Metadata,\n   973→\t\t\tAssigned:    e.Assigned,\n   974→\t\t\tRunID:       e.RunID,\n   975→\t\t}\n   976→\t\tif !e.AssignedAt.IsZero() {\n   977→\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n   978→\t\t}\n   979→\t\tentries[i] = entry\n   980→\t}\n   981→\treturn entries\n   982→}\n   983→\n   984→func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n   985→\tprojectDir := req.ProjectDir\n   986→\tif projectDir == \"\" {\n   987→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   988→\t}\n   989→\n   990→\ts.mu.Lock()\n   991→\tdefer s.mu.Unlock()\n   992→\n   993→\tif loop, ok := s.loops[projectDir]; ok {\n   994→\t\tloop.Stop()\n   995→\t\tdelete(s.loops, projectDir)\n   996→\t}\n   997→\n   998→\treturn &pb.DisableLoopResponse{}, nil\n   999→}\n  1000→\n  1001→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n  1002→\t// Stop all orchestration loops.\n  1003→\ts.mu.Lock()\n  1004→\tfor _, loop := range s.loops {\n  1005→\t\tloop.Stop()\n  1006→\t}\n  1007→\ts.loops = make(map[string]*host.Loop)\n  1008→\ts.mu.Unlock()\n  1009→\n  1010→\tif s.shutdownFn == nil {\n  1011→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n  1012→\t}\n  1013→\tgo s.shutdownFn()\n  1014→\treturn &pb.ShutdownResponse{}, nil\n  1015→}\n  1016→\n  1017→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n  1018→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n  1019→\tentries, err := os.ReadDir(outputDir)\n  1020→\tif err != nil {\n  1021→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n  1022→\t\treturn\n  1023→\t}\n  1024→\n  1025→\tnow := time.Now()\n  1026→\tfor _, entry := range entries {\n  1027→\t\tif entry.IsDir() {\n  1028→\t\t\tcontinue\n  1029→\t\t}\n  1030→\t\tname := entry.Name()\n  1031→\t\tif !strings.HasSuffix(name, \".log\") {\n  1032→\t\t\tcontinue\n  1033→\t\t}\n  1034→\n  1035→\t\tvar fileType, stepName string\n  1036→\t\tbase := strings.TrimSuffix(name, \".log\")\n  1037→\n  1038→\t\tswitch {\n  1039→\t\tcase name == \"full.log\":\n  1040→\t\t\tfileType = \"full\"\n  1041→\t\tcase name == \"container.log\":\n  1042→\t\t\t// container.log is internal, not indexed as a user-facing log type\n  1043→\t\t\tcontinue\n  1044→\t\tcase strings.HasPrefix(name, \"llm-\"):\n  1045→\t\t\tfileType = \"llm\"\n  1046→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n  1047→\t\tdefault:\n  1048→\t\t\tfileType = \"script\"\n  1049→\t\t\tstepName = base\n  1050→\t\t}\n  1051→\n  1052→\t\tinfo, _ := entry.Info()\n  1053→\t\tvar fileSize int64\n  1054→\t\tif info != nil {\n  1055→\t\t\tfileSize = info.Size()\n  1056→\t\t}\n  1057→\n  1058→\t\tlogEntry := &ports.LogFileEntry{\n  1059→\t\t\tRunID:     runID,\n  1060→\t\t\tStepName:  stepName,\n  1061→\t\t\tFileType:  fileType,\n  1062→\t\t\tFilePath:  filepath.Join(outputDir, name),\n  1063→\t\t\tFileSize:  fileSize,\n  1064→\t\t\tCreatedAt: now,\n  1065→\t\t}\n  1066→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n  1067→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n  1068→\t\t}\n  1069→\t}\n  1070→}\n  1071→\n  1072→func gitHEAD(dir string) string {\n  1073→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n  1074→\tcmd.Dir = dir\n  1075→\tout, err := cmd.Output()\n  1076→\tif err != nil {\n  1077→\t\treturn \"\"\n  1078→\t}\n  1079→\treturn strings.TrimSpace(string(out))\n  1080→}\n  1081→"}]},"parent_tool_use_id":"toolu_01R6FyHX8ezBGpk4fQZXf4qj","session_id":"c0b250b2-f9c5-4d6e-a2b5-21933ebd9c8c","uuid":"b946a760-449f-4ff5-9fd7-85210304b125"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qqwfho4nqznb7vGHnVUVce","type":"tool_result","content":"     1→package sqlite\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"database/sql\"\n     6→\t\"fmt\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11→\t_ \"modernc.org/sqlite\"\n    12→)\n    13→\n    14→type Store struct {\n    15→\tdb *sql.DB\n    16→}\n    17→\n    18→func NewStore(dsn string) (*Store, error) {\n    19→\tdb, err := sql.Open(\"sqlite\", dsn)\n    20→\tif err != nil {\n    21→\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n    22→\t}\n    23→\n    24→\t// Enable WAL mode for concurrent read/write access\n    25→\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n    26→\n    27→\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n    28→\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n    29→\n    30→\t// Serialize all Go-side access through a single connection so SQLite\n    31→\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n    32→\tdb.SetMaxOpenConns(1)\n    33→\n    34→\tif err := migrate(db); err != nil {\n    35→\t\tdb.Close()\n    36→\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n    37→\t}\n    38→\n    39→\treturn &Store{db: db}, nil\n    40→}\n    41→\n    42→func (s *Store) Close() error {\n    43→\treturn s.db.Close()\n    44→}\n    45→\n    46→func migrate(db *sql.DB) error {\n    47→\t_, err := db.Exec(`\n    48→\t\tCREATE TABLE IF NOT EXISTS runs (\n    49→\t\t\tid TEXT PRIMARY KEY,\n    50→\t\t\tworkflow_name TEXT NOT NULL,\n    51→\t\t\tstate TEXT NOT NULL,\n    52→\t\t\tactive_steps TEXT,\n    53→\t\t\tstarted_at TEXT,\n    54→\t\t\tcompleted_at TEXT\n    55→\t\t);\n    56→\t\tCREATE TABLE IF NOT EXISTS step_executions (\n    57→\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    58→\t\t\trun_id TEXT NOT NULL,\n    59→\t\t\tstep_name TEXT NOT NULL,\n    60→\t\t\tresult TEXT,\n    61→\t\t\tstarted_at TEXT NOT NULL,\n    62→\t\t\tcompleted_at TEXT,\n    63→\t\t\tlogs TEXT,\n    64→\t\t\tgit_ref TEXT,\n    65→\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    66→\t\t);\n    67→\t`)\n    68→\tif err != nil {\n    69→\t\treturn err\n    70→\t}\n    71→\n    72→\t// Evolution schema additions (idempotent)\n    73→\talterStmts := []string{\n    74→\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n    75→\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n    76→\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n    77→\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n    78→\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n    79→\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n    80→\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n    81→\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n    82→\t\t`ALTER TABLE runs ADD COLUMN title TEXT NOT NULL DEFAULT ''`,\n    83→\t\t`ALTER TABLE runs ADD COLUMN is_host INTEGER NOT NULL DEFAULT 0`,\n    84→\t\t`ALTER TABLE runs ADD COLUMN parent_run_id TEXT NOT NULL DEFAULT ''`,\n    85→\t\t`ALTER TABLE runs ADD COLUMN task_id TEXT NOT NULL DEFAULT ''`,\n    86→\t}\n    87→\tfor _, stmt := range alterStmts {\n    88→\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n    89→\t}\n    90→\n    91→\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n    92→\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    93→\t\trun_id TEXT NOT NULL,\n    94→\t\tstep_name TEXT,\n    95→\t\tfile_type TEXT NOT NULL,\n    96→\t\tfile_path TEXT NOT NULL,\n    97→\t\tfile_size INTEGER,\n    98→\t\tcreated_at TEXT NOT NULL,\n    99→\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n   100→\t)`)\n   101→\tif errLog != nil {\n   102→\t\treturn errLog\n   103→\t}\n   104→\n   105→\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n   106→\t\trun_id TEXT PRIMARY KEY,\n   107→\t\tbranch TEXT NOT NULL,\n   108→\t\tproject TEXT NOT NULL,\n   109→\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n   110→\t\tenqueued_at TEXT NOT NULL,\n   111→\t\tcompleted_at TEXT\n   112→\t)`)\n   113→\tif errMQ != nil {\n   114→\t\treturn errMQ\n   115→\t}\n   116→\n   117→\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n   118→\t\tid TEXT PRIMARY KEY,\n   119→\t\tproject_dir TEXT NOT NULL,\n   120→\t\tworkflow_name TEXT NOT NULL,\n   121→\t\ttrigger_run_id TEXT NOT NULL,\n   122→\t\tcreated_at TEXT NOT NULL,\n   123→\t\tclassification TEXT,\n   124→\t\tchanges_json TEXT NOT NULL,\n   125→\t\tknowledge_delta TEXT\n   126→\t)`)\n   127→\tif err2 != nil {\n   128→\t\treturn err2\n   129→\t}\n   130→\n   131→\treturn nil\n   132→}\n   133→\n   134→func (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n   135→\t_, err := s.db.ExecContext(ctx,\n   136→\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept, title, is_host, parent_run_id, task_id)\n   137→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   138→\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n   139→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, truncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID,\n   140→\t)\n   141→\treturn err\n   142→}\n   143→\n   144→// runSelectCols is the standard column list for scanning a Run row.\n   145→const runSelectCols = `id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,''), COALESCE(is_host,0), COALESCE(parent_run_id,''), COALESCE(task_id,'')`\n   146→\n   147→// scanRun scans a single row into a *domain.Run.\n   148→func scanRun(scanner interface{ Scan(...any) error }) (*domain.Run, error) {\n   149→\trun := &domain.Run{}\n   150→\tvar activeSteps, startedAt, completedAt string"}]},"parent_tool_use_id":"toolu_01R6FyHX8ezBGpk4fQZXf4qj","session_id":"c0b250b2-f9c5-4d6e-a2b5-21933ebd9c8c","uuid":"dcb337cb-21da-4c5e-8a6b-d18815e8c9b1"}
