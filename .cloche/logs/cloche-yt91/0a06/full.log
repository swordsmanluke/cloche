[2026-03-13T18:28:28Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KVLYpmGtdQpdwmR3ZGkD57","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"errors\"\n     7→\t\"fmt\"\n     8→\t\"io\"\n     9→\t\"net/http\"\n    10→\t\"os\"\n    11→\t\"path/filepath\"\n    12→\t\"strconv\"\n    13→\t\"strings\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    18→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    19→\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    20→\t\"google.golang.org/grpc\"\n    21→\t\"google.golang.org/grpc/credentials/insecure\"\n    22→\t\"google.golang.org/grpc/metadata\"\n    23→)\n    24→\n    25→func main() {\n    26→\tif len(os.Args) < 2 {\n    27→\t\tprintTopLevelHelp()\n    28→\t\tos.Exit(1)\n    29→\t}\n    30→\n    31→\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n    32→\tswitch os.Args[1] {\n    33→\tcase \"help\":\n    34→\t\tprintHelp(os.Args[2:])\n    35→\t\treturn\n    36→\tcase \"--help\", \"-h\":\n    37→\t\tprintTopLevelHelp()\n    38→\t\treturn\n    39→\t}\n    40→\n    41→\t// Commands that don't need a daemon connection\n    42→\tswitch os.Args[1] {\n    43→\tcase \"init\":\n    44→\t\tif hasHelpFlag(os.Args[2:]) {\n    45→\t\t\tprintSubcommandHelp(\"init\")\n    46→\t\t\treturn\n    47→\t\t}\n    48→\t\tcmdInit(os.Args[2:])\n    49→\t\treturn\n    50→\tcase \"health\":\n    51→\t\tif hasHelpFlag(os.Args[2:]) {\n    52→\t\t\tprintSubcommandHelp(\"health\")\n    53→\t\t\treturn\n    54→\t\t}\n    55→\t\tcmdHealth(os.Args[2:])\n    56→\t\treturn\n    57→\tcase \"get\":\n    58→\t\tif hasHelpFlag(os.Args[2:]) {\n    59→\t\t\tprintSubcommandHelp(\"get\")\n    60→\t\t\treturn\n    61→\t\t}\n    62→\t\tcmdGet(os.Args[2:])\n    63→\t\treturn\n    64→\tcase \"set\":\n    65→\t\tif hasHelpFlag(os.Args[2:]) {\n    66→\t\t\tprintSubcommandHelp(\"set\")\n    67→\t\t\treturn\n    68→\t\t}\n    69→\t\tcmdSet(os.Args[2:])\n    70→\t\treturn\n    71→\tcase \"tasks\":\n    72→\t\tif hasHelpFlag(os.Args[2:]) {\n    73→\t\t\tprintSubcommandHelp(\"tasks\")\n    74→\t\t\treturn\n    75→\t\t}\n    76→\t\tcmdTasks(os.Args[2:])\n    77→\t\treturn\n    78→\tcase \"workflow\":\n    79→\t\tif hasHelpFlag(os.Args[2:]) {\n    80→\t\t\tprintSubcommandHelp(\"workflow\")\n    81→\t\t\treturn\n    82→\t\t}\n    83→\t\tcmdWorkflow(os.Args[2:])\n    84→\t\treturn\n    85→\t}\n    86→\n    87→\t// Handle --help for daemon commands before connecting\n    88→\tdaemonCmds := map[string]bool{\n    89→\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n    90→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n    91→\t}\n    92→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n    93→\t\tprintSubcommandHelp(os.Args[1])\n    94→\t\treturn\n    95→\t}\n    96→\n    97→\t// Commands that need a daemon connection\n    98→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    99→\tif addr == \"\" {\n   100→\t\taddr = \"unix:///tmp/cloche.sock\"\n   101→\t}\n   102→\n   103→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   104→\tif err != nil {\n   105→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   106→\t\tos.Exit(1)\n   107→\t}\n   108→\tdefer conn.Close()\n   109→\n   110→\tclient := pb.NewClocheServiceClient(conn)\n   111→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   112→\tdefer cancel()\n   113→\n   114→\tswitch os.Args[1] {\n   115→\tcase \"run\":\n   116→\t\tcmdRun(ctx, client, os.Args[2:])\n   117→\tcase \"status\":\n   118→\t\tcmdStatus(ctx, client, os.Args[2:])\n   119→\tcase \"logs\":\n   120→\t\tcmdLogs(client, os.Args[2:])\n   121→\tcase \"poll\":\n   122→\t\tcmdPoll(client, os.Args[2:])\n   123→\tcase \"list\":\n   124→\t\tcmdList(ctx, client, os.Args[2:])\n   125→\tcase \"stop\":\n   126→\t\tcmdStop(ctx, client, os.Args[2:])\n   127→\tcase \"delete\":\n   128→\t\tcmdDelete(ctx, client, os.Args[2:])\n   129→\tcase \"loop\":\n   130→\t\tcmdLoop(ctx, client, os.Args[2:])\n   131→\tcase \"shutdown\":\n   132→\t\tcmdShutdown(ctx, client)\n   133→\tdefault:\n   134→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   135→\t\tprintTopLevelHelp()\n   136→\t\tos.Exit(1)\n   137→\t}\n   138→}\n   139→\n   140→\n   141→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   142→\tvar workflow, prompt, title string\n   143→\tvar keepContainer bool\n   144→\n   145→\tfor i := 0; i < len(args); i++ {\n   146→\t\tswitch args[i] {\n   147→\t\tcase \"--workflow\":\n   148→\t\t\tif i+1 < len(args) {\n   149→\t\t\t\ti++\n   150→\t\t\t\tworkflow = args[i]\n   151→\t\t\t}\n   152→\t\tcase \"--prompt\", \"-p\":\n   153→\t\t\tif i+1 < len(args) {\n   154→\t\t\t\ti++\n   155→\t\t\t\tprompt = args[i]\n   156→\t\t\t}\n   157→\t\tcase \"--title\":\n   158→\t\t\tif i+1 < len(args) {\n   159→\t\t\t\ti++\n   160→\t\t\t\ttitle = args[i]\n   161→\t\t\t}\n   162→\t\tcase \"--keep-container\":\n   163→\t\t\tkeepContainer = true\n   164→\t\tdefault:\n   165→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   166→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   167→\t\t\t\tworkflow = args[i]\n   168→\t\t\t}\n   169→\t\t}\n   170→\t}\n   171→\n   172→\tif workflow == \"\" {\n   173→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   174→\t\tos.Exit(1)\n   175→\t}\n   176→\n   177→\tcwd, _ := os.Getwd()\n   178→\n   179→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   180→\tvar image string\n   181→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   182→\tif data, err := os.ReadFile(wfPath); err == nil {\n   183→\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   184→\t\t\timage = wf.Config[\"container.image\"]\n   185→\t\t}\n   186→\t}\n   187→\n   188→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   189→\t\tWorkflowName:  workflow,\n   190→\t\tProjectDir:    cwd,\n   191→\t\tImage:         image,\n   192→\t\tPrompt:        prompt,\n   193→\t\tKeepContainer: keepContainer,\n   194→\t\tTitle:         title,\n   195→\t})\n   196→\tif err != nil {\n   197→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   198→\t\tos.Exit(1)\n   199→\t}\n   200→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   201→}\n   202→\n   203→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   204→\tif len(args) < 1 {\n   205→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   206→\t\tos.Exit(1)\n   207→\t}\n   208→\n   209→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   210→\tif err != nil {\n   211→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   212→\t\tos.Exit(1)\n   213→\t}\n   214→\n   215→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   216→\tif resp.Title != \"\" {\n   217→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   218→\t}\n   219→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   220→\tif resp.IsHost {\n   221→\t\tfmt.Printf(\"Type:      host\\n\")\n   222→\t} else {\n   223→\t\tfmt.Printf(\"Type:      container\\n\")\n   224→\t}\n   225→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   226→\tif resp.ContainerId != \"\" {\n   227→\t\tcid := resp.ContainerId\n   228→\t\tif len(cid) > 12 {\n   229→\t\t\tcid = cid[:12]\n   230→\t\t}\n   231→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   232→\t}\n   233→\tif resp.ErrorMessage != \"\" {\n   234→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   235→\t}\n   236→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   237→\tfor _, exec := range resp.StepExecutions {\n   238→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   239→\t}\n   240→}\n   241→\n   242→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   243→\tvar all bool\n   244→\tvar projectDir, stateFilter, issueFilter string\n   245→\tvar limit int32\n   246→\n   247→\tfor i := 0; i < len(args); i++ {\n   248→\t\tswitch args[i] {\n   249→\t\tcase \"--all\":\n   250→\t\t\tall = true\n   251→\t\tcase \"--project\", \"-p\":\n   252→\t\t\tif i+1 < len(args) {\n   253→\t\t\t\ti++\n   254→\t\t\t\tprojectDir = args[i]\n   255→\t\t\t}\n   256→\t\tcase \"--state\", \"-s\":\n   257→\t\t\tif i+1 < len(args) {\n   258→\t\t\t\ti++\n   259→\t\t\t\tstateFilter = args[i]\n   260→\t\t\t}\n   261→\t\tcase \"--limit\", \"-n\":\n   262→\t\t\tif i+1 < len(args) {\n   263→\t\t\t\ti++\n   264→\t\t\t\tn, err := strconv.Atoi(args[i])\n   265→\t\t\t\tif err != nil {\n   266→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   267→\t\t\t\t\tos.Exit(1)\n   268→\t\t\t\t}\n   269→\t\t\t\tlimit = int32(n)\n   270→\t\t\t}\n   271→\t\tcase \"--issue\", \"-i\":\n   272→\t\t\tif i+1 < len(args) {\n   273→\t\t\t\ti++\n   274→\t\t\t\tissueFilter = args[i]\n   275→\t\t\t}\n   276→\t\t}\n   277→\t}\n   278→\n   279→\treq := &pb.ListRunsRequest{\n   280→\t\tState:  stateFilter,\n   281→\t\tLimit:  limit,\n   282→\t\tTaskId: issueFilter,\n   283→\t}\n   284→\tif projectDir != \"\" {\n   285→\t\treq.ProjectDir = projectDir\n   286→\t} else if all {\n   287→\t\treq.All = true\n   288→\t} else {\n   289→\t\t// Default: filter to current project\n   290→\t\tcwd, _ := os.Getwd()\n   291→\t\treq.ProjectDir = cwd\n   292→\t}\n   293→\n   294→\tresp, err := client.ListRuns(ctx, req)\n   295→\tif err != nil {\n   296→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   297→\t\tos.Exit(1)\n   298→\t}\n   299→\n   300→\tif len(resp.Runs) == 0 {\n   301→\t\tfmt.Println(\"No runs found.\")\n   302→\t\treturn\n   303→\t}\n   304→\n   305→\tfor _, run := range resp.Runs {\n   306→\t\trunType := \"container\"\n   307→\t\tif run.IsHost {\n   308→\t\t\trunType = \"host\"\n   309→\t\t}\n   310→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   311→\t\tif run.Title != \"\" {\n   312→\t\t\tt := run.Title\n   313→\t\t\tif len(t) > 40 {\n   314→\t\t\t\tt = t[:37] + \"...\"\n   315→\t\t\t}\n   316→\t\t\tline += \"  \" + t\n   317→\t\t}\n   318→\t\tif run.ContainerId != \"\" {\n   319→\t\t\tline += \"  \" + run.ContainerId\n   320→\t\t}\n   321→\t\tif run.ErrorMessage != \"\" {\n   322→\t\t\terrMsg := run.ErrorMessage\n   323→\t\t\tif len(errMsg) > 60 {\n   324→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   325→\t\t\t}\n   326→\t\t\tline += \"  \" + errMsg\n   327→\t\t}\n   328→\t\tfmt.Println(line)\n   329→\t}\n   330→}\n   331→\n   332→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   333→\tif len(args) < 1 {\n   334→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n   335→\t\tos.Exit(1)\n   336→\t}\n   337→\n   338→\tvar stepFilter, typeFilter string\n   339→\tvar follow bool\n   340→\trunID := args[0]\n   341→\n   342→\tfor i := 1; i < len(args); i++ {\n   343→\t\tswitch args[i] {\n   344→\t\tcase \"--step\":\n   345→\t\t\tif i+1 < len(args) {\n   346→\t\t\t\ti++\n   347→\t\t\t\tstepFilter = args[i]\n   348→\t\t\t}\n   349→\t\tcase \"--type\":\n   350→\t\t\tif i+1 < len(args) {\n   351→\t\t\t\ti++\n   352→\t\t\t\ttypeFilter = args[i]\n   353→\t\t\t}\n   354→\t\tcase \"--follow\", \"-f\":\n   355→\t\t\tfollow = true\n   356→\t\t}\n   357→\t}\n   358→\n   359→\t// Use background context — log output can be large and follow mode blocks.\n   360→\tctx := context.Background()\n   361→\tif follow {\n   362→\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n   363→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   364→\t}\n   365→\n   366→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   367→\t\tRunId:    runID,\n   368→\t\tStepName: stepFilter,\n   369→\t\tLogType:  typeFilter,\n   370→\t})\n   371→\tif err != nil {\n   372→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   373→\t\tos.Exit(1)\n   374→\t}\n   375→\n   376→\tfor {\n   377→\t\tentry, err := stream.Recv()\n   378→\t\tif err != nil {\n   379→\t\t\tif errors.Is(err, io.EOF) {\n   380→\t\t\t\tbreak\n   381→\t\t\t}\n   382→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   383→\t\t\tos.Exit(1)\n   384→\t\t}\n   385→\n   386→\t\tswitch entry.Type {\n   387→\t\tcase \"step_started\":\n   388→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   389→\t\t\tif entry.Message != \"\" {\n   390→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   391→\t\t\t}\n   392→\t\tcase \"step_completed\":\n   393→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   394→\t\t\tif entry.Message != \"\" {\n   395→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   396→\t\t\t}\n   397→\t\tcase \"run_completed\":\n   398→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   399→\t\t\tif entry.Message != \"\" {\n   400→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   401→\t\t\t}\n   402→\t\tcase \"full_log\":\n   403→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   404→\t\tcase \"log\":\n   405→\t\t\t// Live-streamed log line from an active run.\n   406→\t\t\tfmt.Println(entry.Message)\n   407→\t\tdefault:\n   408→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   409→\t\t\tif entry.StepName != \"\" {\n   410→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   411→\t\t\t}\n   412→\t\t\tif entry.Message != \"\" {\n   413→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   414→\t\t\t}\n   415→\t\t}\n   416→\t}\n   417→}\n   418→\n   419→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   420→\tif len(args) < 1 {\n   421→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   422→\t\tos.Exit(1)\n   423→\t}\n   424→\n   425→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   426→\tif err != nil {\n   427→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   428→\t\tos.Exit(1)\n   429→\t}\n   430→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   431→}\n   432→\n   433→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   434→\tif len(args) < 1 {\n   435→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   436→\t\tos.Exit(1)\n   437→\t}\n   438→\n   439→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   440→\tif err != nil {\n   441→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   442→\t\tos.Exit(1)\n   443→\t}\n   444→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   445→}\n   446→\n   447→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   448→\tcwd, _ := os.Getwd()\n   449→\n   450→\t// Check for \"stop\" subcommand\n   451→\tif len(args) > 0 && args[0] == \"stop\" {\n   452→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   453→\t\tif err != nil {\n   454→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   455→\t\t\tos.Exit(1)\n   456→\t\t}\n   457→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   458→\t\treturn\n   459→\t}\n   460→\n   461→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   462→\tvar maxConcurrent int32\n   463→\tfor i := 0; i < len(args); i++ {\n   464→\t\tswitch args[i] {\n   465→\t\tcase \"--max\":\n   466→\t\t\tif i+1 < len(args) {\n   467→\t\t\t\ti++\n   468→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   469→\t\t\t\tif n != 1 || err != nil {\n   470→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   471→\t\t\t\t\tos.Exit(1)\n   472→\t\t\t\t}\n   473→\t\t\t}\n   474→\t\t}\n   475→\t}\n   476→\n   477→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   478→\t\tProjectDir:    cwd,\n   479→\t\tMaxConcurrent: maxConcurrent,\n   480→\t})\n   481→\tif err != nil {\n   482→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   483→\t\tos.Exit(1)\n   484→\t}\n   485→\tif maxConcurrent > 0 {\n   486→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   487→\t} else {\n   488→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   489→\t}\n   490→}\n   491→\n   492→func cmdTasks(args []string) {\n   493→\t// Determine HTTP address from env\n   494→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   495→\tif httpAddr == \"\" {\n   496→\t\thttpAddr = \"localhost:8080\"\n   497→\t}\n   498→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   499→\n   500→\t// Determine project label from --project flag or current directory\n   501→\tprojectDir := \"\"\n   502→\tfor i := 0; i < len(args); i++ {\n   503→\t\tswitch args[i] {\n   504→\t\tcase \"--project\":\n   505→\t\t\tif i+1 < len(args) {\n   506→\t\t\t\ti++\n   507→\t\t\t\tprojectDir = args[i]\n   508→\t\t\t}\n   509→\t\t}\n   510→\t}\n   511→\n   512→\tif projectDir == \"\" {\n   513→\t\tcwd, _ := os.Getwd()\n   514→\t\tprojectDir = filepath.Base(cwd)\n   515→\t}\n   516→\n   517→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   518→\tresp, err := http.Get(tasksURL)\n   519→\tif err != nil {\n   520→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   521→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   522→\t\tos.Exit(1)\n   523→\t}\n   524→\tdefer resp.Body.Close()\n   525→\n   526→\tif resp.StatusCode != 200 {\n   527→\t\tbody, _ := io.ReadAll(resp.Body)\n   528→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   529→\t\tos.Exit(1)\n   530→\t}\n   531→\n   532→\ttype taskEntry struct {\n   533→\t\tID          string `json:\"id\"`\n   534→\t\tStatus      string `json:\"status\"`\n   535→\t\tTitle       string `json:\"title\"`\n   536→\t\tDescription string `json:\"description\"`\n   537→\t\tAssigned    bool   `json:\"assigned\"`\n   538→\t\tAssignedAt  string `json:\"assigned_at\"`\n   539→\t\tRunID       string `json:\"run_id\"`\n   540→\t}\n   541→\n   542→\tvar tasks []taskEntry\n   543→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   544→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   545→\t\tos.Exit(1)\n   546→\t}\n   547→\n   548→\tif len(tasks) == 0 {\n   549→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   550→\t\treturn\n   551→\t}\n   552→\n   553→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   554→\tfor _, t := range tasks {\n   555→\t\tstatus := t.Status\n   556→\t\tif status == \"\" {\n   557→\t\t\tstatus = \"open\"\n   558→\t\t}\n   559→\t\tassigned := \"-\"\n   560→\t\tif t.Assigned {\n   561→\t\t\tassigned = \"yes\"\n   562→\t\t}\n   563→\t\trunID := \"\"\n   564→\t\tif t.RunID != \"\" {\n   565→\t\t\trunID = t.RunID\n   566→\t\t\tif len(runID) > 30 {\n   567→\t\t\t\trunID = runID[:27] + \"...\"\n   568→\t\t\t}\n   569→\t\t}\n   570→\t\ttitle := t.Title\n   571→\t\tif len(title) > 40 {\n   572→\t\t\ttitle = title[:37] + \"...\"\n   573→\t\t}\n   574→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   575→\t}\n   576→}\n   577→\n   578→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   579→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   580→\tif err != nil {\n   581→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   582→\t\tos.Exit(1)\n   583→\t}\n   584→\tfmt.Println(\"Daemon shutting down.\")\n   585→}\n   586→\n   587→// resolveRunContext returns the project directory and run ID for context\n   588→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   589→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   590→func resolveRunContext() (projectDir, runID string, err error) {\n   591→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   592→\tif runID == \"\" {\n   593→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   594→\t}\n   595→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   596→\tif projectDir == \"\" {\n   597→\t\tprojectDir, err = os.Getwd()\n   598→\t\tif err != nil {\n   599→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   600→\t\t}\n   601→\t}\n   602→\treturn projectDir, runID, nil\n   603→}\n   604→\n   605→func cmdGet(args []string) {\n   606→\tif len(args) < 1 {\n   607→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   608→\t\tos.Exit(1)\n   609→\t}\n   610→\n   611→\tprojectDir, runID, err := resolveRunContext()\n   612→\tif err != nil {\n   613→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   614→\t\tos.Exit(1)\n   615→\t}\n   616→\n   617→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   618→\tif err != nil {\n   619→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   620→\t\tos.Exit(1)\n   621→\t}\n   622→\tif !ok {\n   623→\t\tos.Exit(1)\n   624→\t}\n   625→\tfmt.Println(val)\n   626→}\n   627→\n   628→func cmdSet(args []string) {\n   629→\tif len(args) < 2 {\n   630→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   631→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   632→\t\tos.Exit(1)\n   633→\t}\n   634→\n   635→\tprojectDir, runID, err := resolveRunContext()\n   636→\tif err != nil {\n   637→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   638→\t\tos.Exit(1)\n   639→\t}\n   640→\n   641→\tvalue := args[1]\n   642→\tif value == \"-\" {\n   643→\t\tdata, err := io.ReadAll(os.Stdin)\n   644→\t\tif err != nil {\n   645→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   646→\t\t\tos.Exit(1)\n   647→\t\t}\n   648→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   649→\t}\n   650→\n   651→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   652→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   653→\t\tos.Exit(1)\n   654→\t}\n   655→}\n   656→"}]},"parent_tool_use_id":"toolu_01HqGxcttN3K6oLdYWbW3TM7","session_id":"4d7e8ba7-70ae-45e4-b438-c668f354765a","uuid":"ed2cf32a-bdf6-40a4-a8f1-12a3c32e8882"}
