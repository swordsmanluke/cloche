4→\t\treturn nil, err\n   425→\t}\n   426→\tentry.CreatedAt = parseTime(createdAt)\n   427→\treturn entry, nil\n   428→}\n   429→\n   430→func (s *Store) ListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error) {\n   431→\tvar rows *sql.Rows\n   432→\tvar err error\n   433→\n   434→\tif sinceRunID == \"\" {\n   435→\t\trows, err = s.db.QueryContext(ctx,\n   436→\t\t\t`SELECT `+runSelectCols+`\n   437→\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? ORDER BY started_at ASC`,\n   438→\t\t\tprojectDir, workflowName)\n   439→\t} else {\n   440→\t\trows, err = s.db.QueryContext(ctx,\n   441→\t\t\t`SELECT `+runSelectCols+`\n   442→\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? AND started_at > (SELECT started_at FROM runs WHERE id = ?)\n   443→\t\t\t ORDER BY started_at ASC`,\n   444→\t\t\tprojectDir, workflowName, sinceRunID)\n   445→\t}\n   446→\tif err != nil {\n   447→\t\treturn nil, err\n   448→\t}\n   449→\tdefer rows.Close()\n   450→\treturn scanRuns(rows)\n   451→}\n   452→\n   453→\n   454→func (s *Store) FailStaleRuns(ctx context.Context) (int64, error) {\n   455→\tnow := formatTime(time.Now())\n   456→\tres, err := s.db.ExecContext(ctx,\n   457→\t\t`UPDATE runs SET state = 'failed', completed_at = ?, error_message = 'daemon restarted while run was active'\n   458→\t\t WHERE state IN ('pending', 'running')`,\n   459→\t\tnow,\n   460→\t)\n   461→\tif err != nil {\n   462→\t\treturn 0, err\n   463→\t}\n   464→\treturn res.RowsAffected()\n   465→}\n   466→\n   467→func formatTime(t time.Time) string {\n   468→\tif t.IsZero() {\n   469→\t\treturn \"\"\n   470→\t}\n   471→\treturn t.Format(time.RFC3339Nano)\n   472→}\n   473→\n   474→func parseTime(s string) time.Time {\n   475→\tif s == \"\" {\n   476→\t\treturn time.Time{}\n   477→\t}\n   478→\tt, _ := time.Parse(time.RFC3339Nano, s)\n   479→\treturn t\n   480→}\n   481→\n   482→func boolToInt(b bool) int {\n   483→\tif b {\n   484→\t\treturn 1\n   485→\t}\n   486→\treturn 0\n   487→}\n   488→\n   489→const maxErrorMessageLen = 1000\n   490→\n   491→// truncateErrorMessage caps s to maxErrorMessageLen characters to prevent\n   492→// oversized agent output dumps from bloating the database. Full error\n   493→// details remain available in step logs.\n   494→func truncateErrorMessage(s string) string {\n   495→\tif len(s) <= maxErrorMessageLen {\n   496→\t\treturn s\n   497→\t}\n   498→\treturn s[:maxErrorMessageLen] + \"... (truncated)\"\n   499→}\n   500→"}]},"parent_tool_use_id":"toolu_01HqGxcttN3K6oLdYWbW3TM7","session_id":"4d7e8ba7-70ae-45e4-b438-c668f354765a","uuid":"164830ce-d8eb-459e-9232-d9df5b83427e"}
