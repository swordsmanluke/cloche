[2026-03-13T18:27:02Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VLhmCt6dLDby3hXwKc9JdF","type":"tool_result","content":"     1→package sqlite_test\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"path/filepath\"\n     7→\t\"sync\"\n     8→\t\"testing\"\n     9→\t\"time\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14→\t\"github.com/stretchr/testify/assert\"\n    15→\t\"github.com/stretchr/testify/require\"\n    16→)\n    17→\n    18→func TestRunStore_CreateAndGet(t *testing.T) {\n    19→\tstore, err := sqlite.NewStore(\":memory:\")\n    20→\trequire.NoError(t, err)\n    21→\tdefer store.Close()\n    22→\n    23→\tctx := context.Background()\n    24→\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n    25→\trun.Start()\n    26→\n    27→\terr = store.CreateRun(ctx, run)\n    28→\trequire.NoError(t, err)\n    29→\n    30→\tgot, err := store.GetRun(ctx, \"run-1\")\n    31→\trequire.NoError(t, err)\n    32→\tassert.Equal(t, \"run-1\", got.ID)\n    33→\tassert.Equal(t, \"test-workflow\", got.WorkflowName)\n    34→\tassert.Equal(t, domain.RunStateRunning, got.State)\n    35→}\n    36→\n    37→func TestRunStore_Update(t *testing.T) {\n    38→\tstore, err := sqlite.NewStore(\":memory:\")\n    39→\trequire.NoError(t, err)\n    40→\tdefer store.Close()\n    41→\n    42→\tctx := context.Background()\n    43→\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n    44→\trun.Start()\n    45→\trequire.NoError(t, store.CreateRun(ctx, run))\n    46→\n    47→\trun.Complete(domain.RunStateSucceeded)\n    48→\trequire.NoError(t, store.UpdateRun(ctx, run))\n    49→\n    50→\tgot, err := store.GetRun(ctx, \"run-1\")\n    51→\trequire.NoError(t, err)\n    52→\tassert.Equal(t, domain.RunStateSucceeded, got.State)\n    53→}\n    54→\n    55→func TestRunStore_List(t *testing.T) {\n    56→\tstore, err := sqlite.NewStore(\":memory:\")\n    57→\trequire.NoError(t, err)\n    58→\tdefer store.Close()\n    59→\n    60→\tctx := context.Background()\n    61→\trun1 := domain.NewRun(\"run-1\", \"wf-a\")\n    62→\trun2 := domain.NewRun(\"run-2\", \"wf-b\")\n    63→\trequire.NoError(t, store.CreateRun(ctx, run1))\n    64→\trequire.NoError(t, store.CreateRun(ctx, run2))\n    65→\n    66→\truns, err := store.ListRuns(ctx, time.Time{})\n    67→\trequire.NoError(t, err)\n    68→\tassert.Len(t, runs, 2)\n    69→}\n    70→\n    71→func TestRunStore_GetNotFound(t *testing.T) {\n    72→\tstore, err := sqlite.NewStore(\":memory:\")\n    73→\trequire.NoError(t, err)\n    74→\tdefer store.Close()\n    75→\n    76→\t_, err = store.GetRun(context.Background(), \"nonexistent\")\n    77→\tassert.Error(t, err)\n    78→}\n    79→\n    80→func TestStore_DeleteRun(t *testing.T) {\n    81→\tstore, err := sqlite.NewStore(\":memory:\")\n    82→\trequire.NoError(t, err)\n    83→\tdefer store.Close()\n    84→\n    85→\tctx := context.Background()\n    86→\n    87→\t// Create a run and save a capture for it\n    88→\trun := domain.NewRun(\"del-1\", \"test-workflow\")\n    89→\trun.Start()\n    90→\trequire.NoError(t, store.CreateRun(ctx, run))\n    91→\trequire.NoError(t, store.SaveCapture(ctx, \"del-1\", &domain.StepExecution{\n    92→\t\tStepName:  \"step1\",\n    93→\t\tStartedAt: time.Now(),\n    94→\t}))\n    95→\n    96→\t// Delete the run\n    97→\terr = store.DeleteRun(ctx, \"del-1\")\n    98→\trequire.NoError(t, err)\n    99→\n   100→\t// Verify run is gone\n   101→\t_, err = store.GetRun(ctx, \"del-1\")\n   102→\tassert.Error(t, err)\n   103→\n   104→\t// Verify captures are gone\n   105→\tcaps, err := store.GetCaptures(ctx, \"del-1\")\n   106→\trequire.NoError(t, err)\n   107→\tassert.Empty(t, caps)\n   108→}\n   109→\n   110→func TestRunProjectDir(t *testing.T) {\n   111→\tstore, err := sqlite.NewStore(\":memory:\")\n   112→\trequire.NoError(t, err)\n   113→\tdefer store.Close()\n   114→\n   115→\tctx := context.Background()\n   116→\trun := domain.NewRun(\"test-1\", \"develop\")\n   117→\trun.ProjectDir = \"/home/user/project\"\n   118→\trun.Start()\n   119→\n   120→\terr = store.CreateRun(ctx, run)\n   121→\trequire.NoError(t, err)\n   122→\n   123→\tgot, err := store.GetRun(ctx, \"test-1\")\n   124→\trequire.NoError(t, err)\n   125→\tassert.Equal(t, \"/home/user/project\", got.ProjectDir)\n   126→}\n   127→\n   128→func TestCaptureStepMetadata(t *testing.T) {\n   129→\tstore, err := sqlite.NewStore(\":memory:\")\n   130→\trequire.NoError(t, err)\n   131→\tdefer store.Close()\n   132→\n   133→\tctx := context.Background()\n   134→\trun := domain.NewRun(\"test-1\", \"develop\")\n   135→\trun.Start()\n   136→\tstore.CreateRun(ctx, run)\n   137→\n   138→\texec := &domain.StepExecution{\n   139→\t\tStepName:  \"implement\",\n   140→\t\tResult:    \"success\",\n   141→\t\tStartedAt: time.Now(),\n   142→\t}\n   143→\terr = store.SaveCapture(ctx, \"test-1\", exec)\n   144→\trequire.NoError(t, err)\n   145→\n   146→\tcaps, err := store.GetCaptures(ctx, \"test-1\")\n   147→\trequire.NoError(t, err)\n   148→\trequire.Len(t, caps, 1)\n   149→\tassert.Equal(t, \"implement\", caps[0].StepName)\n   150→\tassert.Equal(t, \"success\", caps[0].Result)\n   151→}\n   152→\n   153→func TestListRunsSince(t *testing.T) {\n   154→\tstore, err := sqlite.NewStore(\":memory:\")\n   155→\trequire.NoError(t, err)\n   156→\tdefer store.Close()\n   157→\n   158→\tctx := context.Background()\n   159→\tfor i, id := range []string{\"run-1\", \"run-2\", \"run-3\"} {\n   160→\t\tr := domain.NewRun(id, \"develop\")\n   161→\t\tr.ProjectDir = \"/project\"\n   162→\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n   163→\t\tr.State = domain.RunStateRunning\n   164→\t\trequire.NoError(t, store.CreateRun(ctx, r))\n   165→\t}\n   166→\n   167→\truns, err := store.ListRunsSince(ctx, \"/project\", \"develop\", \"run-1\")\n   168→\trequire.NoError(t, err)\n   169→\tassert.Len(t, runs, 2)\n   170→\tassert.Equal(t, \"run-2\", runs[0].ID)\n   171→\tassert.Equal(t, \"run-3\", runs[1].ID)\n   172→}\n   173→\n   174→func TestListRunsSinceEmpty(t *testing.T) {\n   175→\tstore, err := sqlite.NewStore(\":memory:\")\n   176→\trequire.NoError(t, err)\n   177→\tdefer store.Close()\n   178→\n   179→\tctx := context.Background()\n   180→\tfor i, id := range []string{\"run-1\", \"run-2\"} {\n   181→\t\tr := domain.NewRun(id, \"develop\")\n   182→\t\tr.ProjectDir = \"/project\"\n   183→\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n   184→\t\tr.State = domain.RunStateRunning\n   185→\t\trequire.NoError(t, store.CreateRun(ctx, r))\n   186→\t}\n   187→\n   188→\t// Empty sinceRunID returns all\n   189→\truns, err := store.ListRunsSince(ctx, \"/project\", \"develop\", \"\")\n   190→\trequire.NoError(t, err)\n   191→\tassert.Len(t, runs, 2)\n   192→}\n   193→\n   194→func TestGetLastEvolution(t *testing.T) {\n   195→\tstore, err := sqlite.NewStore(\":memory:\")\n   196→\trequire.NoError(t, err)\n   197→\tdefer store.Close()\n   198→\n   199→\tctx := context.Background()\n   200→\n   201→\t// No evolution yet\n   202→\tentry, err := store.GetLastEvolution(ctx, \"/project\", \"develop\")\n   203→\trequire.NoError(t, err)\n   204→\tassert.Nil(t, entry)\n   205→\n   206→\t// Save one\n   207→\trequire.NoError(t, store.SaveEvolution(ctx, &ports.EvolutionEntry{\n   208→\t\tID:           \"evo-1\",\n   209→\t\tProjectDir:   \"/project\",\n   210→\t\tWorkflowName: \"develop\",\n   211→\t\tTriggerRunID: \"run-1\",\n   212→\t\tCreatedAt:    time.Now(),\n   213→\t\tChangesJSON:  \"[]\",\n   214→\t}))\n   215→\n   216→\tentry, err = store.GetLastEvolution(ctx, \"/project\", \"develop\")\n   217→\trequire.NoError(t, err)\n   218→\trequire.NotNil(t, entry)\n   219→\tassert.Equal(t, \"evo-1\", entry.ID)\n   220→}\n   221→\n   222→func TestRunTitle(t *testing.T) {\n   223→\tstore, err := sqlite.NewStore(\":memory:\")\n   224→\trequire.NoError(t, err)\n   225→\tdefer store.Close()\n   226→\n   227→\tctx := context.Background()\n   228→\n   229→\t// Create a run with a title\n   230→\trun := domain.NewRun(\"title-1\", \"develop\")\n   231→\trun.Title = \"Add dark mode toggle\"\n   232→\trun.Start()\n   233→\trequire.NoError(t, store.CreateRun(ctx, run))\n   234→\n   235→\tgot, err := store.GetRun(ctx, \"title-1\")\n   236→\trequire.NoError(t, err)\n   237→\tassert.Equal(t, \"Add dark mode toggle\", got.Title)\n   238→\n   239→\t// Update title\n   240→\tgot.Title = \"Updated title\"\n   241→\trequire.NoError(t, store.UpdateRun(ctx, got))\n   242→\n   243→\tgot2, err := store.GetRun(ctx, \"title-1\")\n   244→\trequire.NoError(t, err)\n   245→\tassert.Equal(t, \"Updated title\", got2.Title)\n   246→\n   247→\t// Verify title shows up in ListRuns\n   248→\truns, err := store.ListRuns(ctx, time.Time{})\n   249→\trequire.NoError(t, err)\n   250→\trequire.Len(t, runs, 1)\n   251→\tassert.Equal(t, \"Updated title\", runs[0].Title)\n   252→}\n   253→\n   254→func TestRunTitle_BackwardCompat(t *testing.T) {\n   255→\tstore, err := sqlite.NewStore(\":memory:\")\n   256→\trequire.NoError(t, err)\n   257→\tdefer store.Close()\n   258→\n   259→\tctx := context.Background()\n   260→\n   261→\t// Create a run without setting Title — simulates pre-migration rows\n   262→\trun := domain.NewRun(\"notitle-1\", \"develop\")\n   263→\trun.Start()\n   264→\trequire.NoError(t, store.CreateRun(ctx, run))\n   265→\n   266→\tgot, err := store.GetRun(ctx, \"notitle-1\")\n   267→\trequire.NoError(t, err)\n   268→\tassert.Equal(t, \"\", got.Title)\n   269→}\n   270→\n   271→func TestRunContainerID(t *testing.T) {\n   272→\tstore, err := sqlite.NewStore(\":memory:\")\n   273→\trequire.NoError(t, err)\n   274→\tdefer store.Close()\n   275→\n   276→\tctx := context.Background()\n   277→\trun := domain.NewRun(\"cid-1\", \"develop\")\n   278→\trun.Start()\n   279→\trun.ContainerID = \"4647e7e70e3fabc123def456\"\n   280→\n   281→\terr = store.CreateRun(ctx, run)\n   282→\trequire.NoError(t, err)\n   283→\n   284→\tgot, err := store.GetRun(ctx, \"cid-1\")\n   285→\trequire.NoError(t, err)\n   286→\tassert.Equal(t, \"4647e7e70e3fabc123def456\", got.ContainerID)\n   287→\n   288→\t// Test update preserves container ID\n   289→\tgot.ContainerID = \"new-container-id\"\n   290→\trequire.NoError(t, store.UpdateRun(ctx, got))\n   291→\n   292→\tgot2, err := store.GetRun(ctx, \"cid-1\")\n   293→\trequire.NoError(t, err)\n   294→\tassert.Equal(t, \"new-container-id\", got2.ContainerID)\n   295→\n   296→\t// Test ListRuns includes container ID\n   297→\truns, err := store.ListRuns(ctx, time.Time{})\n   298→\trequire.NoError(t, err)\n   299→\trequire.Len(t, runs, 1)\n   300→\tassert.Equal(t, \"new-container-id\", runs[0].ContainerID)\n   301→}\n   302→\n   303→func TestRunContainerID_BackwardCompat(t *testing.T) {\n   304→\tstore, err := sqlite.NewStore(\":memory:\")\n   305→\trequire.NoError(t, err)\n   306→\tdefer store.Close()\n   307→\n   308→\tctx := context.Background()\n   309→\t// Create a run without setting ContainerID — simulates pre-migration rows\n   310→\trun := domain.NewRun(\"old-1\", \"develop\")\n   311→\trun.Start()\n   312→\trequire.NoError(t, store.CreateRun(ctx, run))\n   313→\n   314→\tgot, err := store.GetRun(ctx, \"old-1\")\n   315→\trequire.NoError(t, err)\n   316→\tassert.Equal(t, \"\", got.ContainerID)\n   317→}\n   318→\n   319→func TestRunErrorMessage(t *testing.T) {\n   320→\tstore, err := sqlite.NewStore(\":memory:\")\n   321→\trequire.NoError(t, err)\n   322→\tdefer store.Close()\n   323→\n   324→\tctx := context.Background()\n   325→\trun := domain.NewRun(\"err-1\", \"develop\")\n   326→\trun.Start()\n   327→\trun.Fail(\"failed to start container: image not found\")\n   328→\n   329→\terr = store.CreateRun(ctx, run)\n   330→\trequire.NoError(t, err)\n   331→\n   332→\tgot, err := store.GetRun(ctx, \"err-1\")\n   333→\trequire.NoError(t, err)\n   334→\tassert.Equal(t, domain.RunStateFailed, got.State)\n   335→\tassert.Equal(t, \"failed to start container: image not found\", got.ErrorMessage)\n   336→\n   337→\t// Test update preserves error message\n   338→\tgot.ErrorMessage = \"updated error\"\n   339→\trequire.NoError(t, store.UpdateRun(ctx, got))\n   340→\n   341→\tgot2, err := store.GetRun(ctx, \"err-1\")\n   342→\trequire.NoError(t, err)\n   343→\tassert.Equal(t, \"updated error\", got2.ErrorMessage)\n   344→}\n   345→\n   346→func TestRunErrorMessage_Truncation(t *testing.T) {\n   347→\tstore, err := sqlite.NewStore(\":memory:\")\n   348→\trequire.NoError(t, err)\n   349→\tdefer store.Close()\n   350→\n   351→\tctx := context.Background()\n   352→\n   353→\t// Build a message well over 1000 characters\n   354→\tlongMsg := \"\"\n   355→\tfor len(longMsg) < 5000 {\n   356→\t\tlongMsg += \"error output line that keeps going and going. \"\n   357→\t}\n   358→\n   359→\t// Test truncation on CreateRun\n   360→\trun := domain.NewRun(\"trunc-create\", \"develop\")\n   361→\trun.Start()\n   362→\trun.Fail(longMsg)\n   363→\trequire.NoError(t, store.CreateRun(ctx, run))\n   364→\n   365→\tgot, err := store.GetRun(ctx, \"trunc-create\")\n   366→\trequire.NoError(t, err)\n   367→\tassert.LessOrEqual(t, len(got.ErrorMessage), 1020) // 1000 + \"... (truncated)\"\n   368→\tassert.Contains(t, got.ErrorMessage, \"... (truncated)\")\n   369→\n   370→\t// Test truncation on UpdateRun\n   371→\trun2 := domain.NewRun(\"trunc-update\", \"develop\")\n   372→\trun2.Start()\n   373→\trequire.NoError(t, store.CreateRun(ctx, run2))\n   374→\n   375→\trun2.Fail(longMsg)\n   376→\trequire.NoError(t, store.UpdateRun(ctx, run2))\n   377→\n   378→\tgot2, err := store.GetRun(ctx, \"trunc-update\")\n   379→\trequire.NoError(t, err)\n   380→\tassert.LessOrEqual(t, len(got2.ErrorMessage), 1020)\n   381→\tassert.Contains(t, got2.ErrorMessage, \"... (truncated)\")\n   382→\n   383→\t// Short messages should NOT be truncated\n   384→\trun3 := domain.NewRun(\"trunc-short\", \"develop\")\n   385→\trun3.Start()\n   386→\trun3.Fail(\"short error\")\n   387→\trequire.NoError(t, store.CreateRun(ctx, run3))\n   388→\n   389→\tgot3, err := store.GetRun(ctx, \"trunc-short\")\n   390→\trequire.NoError(t, err)\n   391→\tassert.Equal(t, \"short error\", got3.ErrorMessage)\n   392→}\n   393→\n   394→func TestRunErrorMessageInList(t *testing.T) {\n   395→\tstore, err := sqlite.NewStore(\":memory:\")\n   396→\trequire.NoError(t, err)\n   397→\tdefer store.Close()\n   398→\n   399→\tctx := context.Background()\n   400→\trun := domain.NewRun(\"err-list-1\", \"develop\")\n   401→\trun.Start()\n   402→\trun.Fail(\"container crashed\")\n   403→\trequire.NoError(t, store.CreateRun(ctx, run))\n   404→\n   405→\truns, err := store.ListRuns(ctx, time.Time{})\n   406→\trequire.NoError(t, err)\n   407→\trequire.Len(t, runs, 1)\n   408→\tassert.Equal(t, \"container crashed\", runs[0].ErrorMessage)\n   409→}\n   410→\n   411→func TestStore_ConcurrentWrites(t *testing.T) {\n   412→\tdbPath := filepath.Join(t.TempDir(), \"concurrent.db\")\n   413→\tstore, err := sqlite.NewStore(dbPath)\n   414→\trequire.NoError(t, err)\n   415→\tdefer store.Close()\n   416→\n   417→\tconst n = 10\n   418→\tctx := context.Background()\n   419→\terrs := make([]error, n)\n   420→\n   421→\tvar wg sync.WaitGroup\n   422→\twg.Add(n)\n   423→\tfor i := 0; i < n; i++ {\n   424→\t\tgo func(i int) {\n   425→\t\t\tdefer wg.Done()\n   426→\t\t\tid := fmt.Sprintf(\"run-%d\", i)\n   427→\t\t\trun := domain.NewRun(id, \"test-workflow\")\n   428→\t\t\trun.Start()\n   429→\t\t\tif err := store.CreateRun(ctx, run); err != nil {\n   430→\t\t\t\terrs[i] = err\n   431→\t\t\t\treturn\n   432→\t\t\t}\n   433→\t\t\terrs[i] = store.SaveCapture(ctx, id, &domain.StepExecution{\n   434→\t\t\t\tStepName:  fmt.Sprintf(\"step-%d\", i),\n   435→\t\t\t\tStartedAt: time.Now(),\n   436→\t\t\t})\n   437→\t\t}(i)\n   438→\t}\n   439→\twg.Wait()\n   440→\n   441→\tfor i, err := range errs {\n   442→\t\tassert.NoError(t, err, \"goroutine %d failed\", i)\n   443→\t}\n   444→\n   445→\truns, err := store.ListRuns(ctx, time.Time{})\n   446→\trequire.NoError(t, err)\n   447→\tassert.Len(t, runs, n)\n   448→}\n   449→\n   450→func TestListRunsByProject(t *testing.T) {\n   451→\tstore, err := sqlite.NewStore(\":memory:\")\n   452→\trequire.NoError(t, err)\n   453→\tdefer store.Close()\n   454→\n   455→\tctx := context.Background()\n   456→\n   457→\t// Create runs for two different projects\n   458→\tfor i, id := range []string{\"proj-a-1\", \"proj-a-2\"} {\n   459→\t\tr := domain.NewRun(id, \"develop\")\n   460→\t\tr.ProjectDir = \"/home/user/project-a\"\n   461→\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n   462→\t\tr.State = domain.RunStateRunning\n   463→\t\trequire.NoError(t, store.CreateRun(ctx, r))\n   464→\t}\n   465→\trB := domain.NewRun(\"proj-b-1\", \"develop\")\n   466→\trB.ProjectDir = \"/home/user/project-b\"\n   467→\trB.StartedAt = time.Now()\n   468→\trB.State = domain.RunStateRunning\n   469→\trequire.NoError(t, store.CreateRun(ctx, rB))\n   470→\n   471→\t// Filter by project-a\n   472→\truns, err := store.ListRunsByProject(ctx, \"/home/user/project-a\", time.Time{})\n   473→\trequire.NoError(t, err)\n   474→\tassert.Len(t, runs, 2)\n   475→\tfor _, r := range runs {\n   476→\t\tassert.Equal(t, \"/home/user/project-a\", r.ProjectDir)\n   477→\t}\n   478→\n   479→\t// Filter by project-b\n   480→\truns, err = store.ListRunsByProject(ctx, \"/home/user/project-b\", time.Time{})\n   481→\trequire.NoError(t, err)\n   482→\tassert.Len(t, runs, 1)\n   483→\tassert.Equal(t, \"proj-b-1\", runs[0].ID)\n   484→\n   485→\t// Filter by nonexistent project\n   486→\truns, err = store.ListRunsByProject(ctx, \"/nonexistent\", time.Time{})\n   487→\trequire.NoError(t, err)\n   488→\tassert.Empty(t, runs)\n   489→}\n   490→\n   491→func TestListProjects(t *testing.T) {\n   492→\tstore, err := sqlite.NewStore(\":memory:\")\n   493→\trequire.NoError(t, err)\n   494→\tdefer store.Close()\n   495→\n   496→\tctx := context.Background()\n   497→\n   498→\t// Empty store returns no projects\n   499→\tprojects, err := store.ListProjects(ctx)\n   500→\trequire.NoError(t, err)\n   501→\tassert.Empty(t, projects)\n   502→\n   503→\t// Create runs for different projects\n   504→\tfor _, tc := range []struct {\n   505→\t\tid, project string\n   506→\t}{\n   507→\t\t{\"r1\", \"/home/user/alpha\"},\n   508→\t\t{\"r2\", \"/home/user/alpha\"},\n   509→\t\t{\"r3\", \"/home/user/beta\"},\n   510→\t\t{\"r4\", \"\"},\n   511→\t} {\n   512→\t\tr := domain.NewRun(tc.id, \"develop\")\n   513→\t\tr.ProjectDir = tc.project\n   514→\t\tr.State = domain.RunStatePending\n   515→\t\trequire.NoError(t, store.CreateRun(ctx, r))\n   516→\t}\n   517→\n   518→\tprojects, err = store.ListProjects(ctx)\n   519→\trequire.NoError(t, err)\n   520→\tassert.Equal(t, []string{\"/home/user/alpha\", \"/home/user/beta\"}, projects)\n   521→}\n   522→\n   523→func TestRunContainerKept(t *testing.T) {\n   524→\tstore, err := sqlite.NewStore(\":memory:\")\n   525→\trequire.NoError(t, err)\n   526→\tdefer store.Close()\n   527→\n   528→\tctx := context.Background()\n   529→\n   530→\t// Create a run with ContainerKept = false (default)\n   531→\trun := domain.NewRun(\"kept-1\", \"develop\")\n   532→\trun.Start()\n   533→\trun.ContainerID = \"abc123\"\n   534→\trequire.NoError(t, store.CreateRun(ctx, run))\n   535→\n   536→\tgot, err := store.GetRun(ctx, \"kept-1\")\n   537→\trequire.NoError(t, err)\n   538→\tassert.False(t, got.ContainerKept)\n   539→\n   540→\t// Update to mark container as kept\n   541→\tgot.ContainerKept = true\n   542→\trequire.NoError(t, store.UpdateRun(ctx, got))\n   543→\n   544→\tgot2, err := store.GetRun(ctx, \"kept-1\")\n   545→\trequire.NoError(t, err)\n   546→\tassert.True(t, got2.ContainerKept)\n   547→\n   548→\t// Verify ListRuns includes ContainerKept\n   549→\truns, err := store.ListRuns(ctx, time.Time{})\n   550→\trequire.NoError(t, err)\n   551→\trequire.Len(t, runs, 1)\n   552→\tassert.True(t, runs[0].ContainerKept)\n   553→}\n   554→\n   555→func TestRunIsHost(t *testing.T) {\n   556→\tstore, err := sqlite.NewStore(\":memory:\")\n   557→\trequire.NoError(t, err)\n   558→\tdefer store.Close()\n   559→\n   560→\tctx := context.Background()\n   561→\n   562→\t// Create a host run\n   563→\trun := domain.NewRun(\"host-1\", \"main\")\n   564→\trun.IsHost = true\n   565→\trun.ProjectDir = \"/project\"\n   566→\trun.Start()\n   567→\trequire.NoError(t, store.CreateRun(ctx, run))\n   568→\n   569→\tgot, err := store.GetRun(ctx, \"host-1\")\n   570→\trequire.NoError(t, err)\n   571→\tassert.True(t, got.IsHost)\n   572→\n   573→\t// Create a container run\n   574→\tcrun := domain.NewRun(\"container-1\", \"develop\")\n   575→\tcrun.ProjectDir = \"/project\"\n   576→\tcrun.Start()\n   577→\trequire.NoError(t, store.CreateRun(ctx, crun))\n   578→\n   579→\tgot2, err := store.GetRun(ctx, \"container-1\")\n   580→\trequire.NoError(t, err)\n   581→\tassert.False(t, got2.IsHost)\n   582→\n   583→\t// Verify IsHost shows up in ListRuns\n   584→\truns, err := store.ListRuns(ctx, time.Time{})\n   585→\trequire.NoError(t, err)\n   586→\trequire.Len(t, runs, 2)\n   587→\n   588→\thostFound := false\n   589→\tcontainerFound := false\n   590→\tfor _, r := range runs {\n   591→\t\tif r.ID == \"host-1\" {\n   592→\t\t\tassert.True(t, r.IsHost)\n   593→\t\t\thostFound = true\n   594→\t\t}\n   595→\t\tif r.ID == \"container-1\" {\n   596→\t\t\tassert.False(t, r.IsHost)\n   597→\t\t\tcontainerFound = true\n   598→\t\t}\n   599→\t}\n   600→\tassert.True(t, hostFound)\n   601→\tassert.True(t, containerFound)\n   602→\n   603→\t// Verify IsHost shows up in ListRunsByProject\n   604→\tprojRuns, err := store.ListRunsByProject(ctx, \"/project\", time.Time{})\n   605→\trequire.NoError(t, err)\n   606→\trequire.Len(t, projRuns, 2)\n   607→\tfor _, r := range projRuns {\n   608→\t\tif r.ID == \"host-1\" {\n   609→\t\t\tassert.True(t, r.IsHost)\n   610→\t\t}\n   611→\t}\n   612→\n   613→\t// Test update preserves IsHost\n   614→\tgot.IsHost = false\n   615→\trequire.NoError(t, store.UpdateRun(ctx, got))\n   616→\tgot3, err := store.GetRun(ctx, \"host-1\")\n   617→\trequire.NoError(t, err)\n   618→\tassert.False(t, got3.IsHost)\n   619→}\n   620→\n   621→func TestRunIsHost_BackwardCompat(t *testing.T) {\n   622→\tstore, err := sqlite.NewStore(\":memory:\")\n   623→\trequire.NoError(t, err)\n   624→\tdefer store.Close()\n   625→\n   626→\tctx := context.Background()\n   627→\n   628→\t// Create a run without setting IsHost — simulates pre-migration rows\n   629→\trun := domain.NewRun(\"old-1\", \"develop\")\n   630→\trun.Start()\n   631→\trequire.NoError(t, store.CreateRun(ctx, run))\n   632→\n   633→\tgot, err := store.GetRun(ctx, \"old-1\")\n   634→\trequire.NoError(t, err)\n   635→\tassert.False(t, got.IsHost)\n   636→}\n   637→\n   638→func TestStore_FailStaleRuns(t *testing.T) {\n   639→\tstore, err := sqlite.NewStore(\":memory:\")\n   640→\trequire.NoError(t, err)\n   641→\tdefer store.Close()\n   642→\n   643→\tctx := context.Background()\n   644→\n   645→\t// Create runs in different states.\n   646→\tpending := domain.NewRun(\"pending-1\", \"wf\")\n   647→\trequire.NoError(t, store.CreateRun(ctx, pending))\n   648→\n   649→\trunning := domain.NewRun(\"running-1\", \"wf\")\n   650→\trunning.Start()\n   651→\trequire.NoError(t, store.CreateRun(ctx, running))\n   652→\n   653→\tsucceeded := domain.NewRun(\"succeeded-1\", \"wf\")\n   654→\tsucceeded.Start()\n   655→\tsucceeded.Complete(domain.RunStateSucceeded)\n   656→\trequire.NoError(t, store.CreateRun(ctx, succeeded))\n   657→\n   658→\tn, err := store.FailStaleRuns(ctx)\n   659→\trequire.NoError(t, err)\n   660→\tassert.Equal(t, int64(2), n) // both pending and running\n   661→\n   662→\tgot, err := store.GetRun(ctx, \"pending-1\")\n   663→\trequire.NoError(t, err)\n   664→\tassert.Equal(t, domain.RunStateFailed, got.State)\n   665→\tassert.False(t, got.CompletedAt.IsZero(), \"completed_at should be set\")\n   666→\tassert.Equal(t, \"daemon restarted while run was active\", got.ErrorMessage)\n   667→\n   668→\tgotRunning, err := store.GetRun(ctx, \"running-1\")\n   669→\trequire.NoError(t, err)\n   670→\tassert.Equal(t, domain.RunStateFailed, gotRunning.State)\n   671→\tassert.False(t, gotRunning.CompletedAt.IsZero(), \"completed_at should be set\")\n   672→\tassert.Equal(t, \"daemon restarted while run was active\", gotRunning.ErrorMessage)\n   673→\n   674→\t// Succeeded runs should be untouched.\n   675→\tgotSucceeded, err := store.GetRun(ctx, \"succeeded-1\")\n   676→\trequire.NoError(t, err)\n   677→\tassert.Equal(t, domain.RunStateSucceeded, gotSucceeded.State)\n   678→}\n   679→\n   680→func TestLogFiles_SaveAndGet(t *testing.T) {\n   681→\tstore, err := sqlite.NewStore(\":memory:\")\n   682→\trequire.NoError(t, err)\n   683→\tdefer store.Close()\n   684→\n   685→\tctx := context.Background()\n   686→\n   687→\t// Create a run first (foreign key)\n   688→\trun := domain.NewRun(\"log-run-1\", \"develop\")\n   689→\trun.Start()\n   690→\trequire.NoError(t, store.CreateRun(ctx, run))\n   691→\n   692→\tnow := time.Now().Truncate(time.Second)\n   693→\n   694→\t// Save log file entries\n   695→\tentries := []*ports.LogFileEntry{\n   696→\t\t{RunID: \"log-run-1\", FileType: \"full\", FilePath: \"/tmp/output/full.log\", FileSize: 1024, CreatedAt: now},\n   697→\t\t{RunID: \"log-run-1\", StepName: \"build\", FileType: \"script\", FilePath: \"/tmp/output/build.log\", FileSize: 512, CreatedAt: now},\n   698→\t\t{RunID: \"log-run-1\", StepName: \"build\", FileType: \"llm\", FilePath: \"/tmp/output/llm-build.log\", FileSize: 2048, CreatedAt: now},\n   699→\t\t{RunID: \"log-run-1\", StepName: \"test\", FileType: \"script\", FilePath: \"/tmp/output/test.log\", FileSize: 256, CreatedAt: now},\n   700→\t}\n   701→\tfor _, e := range entries {\n   702→\t\trequire.NoError(t, store.SaveLogFile(ctx, e))\n   703→\t}\n   704→\n   705→\t// GetLogFiles returns all entries for a run\n   706→\tall, err := store.GetLogFiles(ctx, \"log-run-1\")\n   707→\trequire.NoError(t, err)\n   708→\tassert.Len(t, all, 4)\n   709→\n   710→\t// GetLogFilesByStep returns entries for a specific step\n   711→\tbuildLogs, err := store.GetLogFilesByStep(ctx, \"log-run-1\", \"build\")\n   712→\trequire.NoError(t, err)\n   713→\tassert.Len(t, buildLogs, 2)\n   714→\tfor _, lf := range buildLogs {\n   715→\t\tassert.Equal(t, \"build\", lf.StepName)\n   716→\t}\n   717→\n   718→\t// GetLogFileByType returns entries of a specific type\n   719→\tllmLogs, err := store.GetLogFileByType(ctx, \"log-run-1\", \"llm\")\n   720→\trequire.NoError(t, err)\n   721→\tassert.Len(t, llmLogs, 1)\n   722→\tassert.Equal(t, \"llm\", llmLogs[0].FileType)\n   723→\tassert.Equal(t, \"build\", llmLogs[0].StepName)\n   724→\n   725→\t// GetLogFileByType for \"full\"\n   726→\tfullLogs, err := store.GetLogFileByType(ctx, \"log-run-1\", \"full\")\n   727→\trequire.NoError(t, err)\n   728→\tassert.Len(t, fullLogs, 1)\n   729→\tassert.Equal(t, \"full\", fullLogs[0].FileType)\n   730→\tassert.Equal(t, int64(1024), fullLogs[0].FileSize)\n   731→}\n   732→\n   733→func TestRunParentRunID(t *testing.T) {\n   734→\tstore, err := sqlite.NewStore(\":memory:\")\n   735→\trequire.NoError(t, err)\n   736→\tdefer store.Close()\n   737→\n   738→\tctx := context.Background()\n   739→\n   740→\t// Create a host (parent) run\n   741→\tparent := domain.NewRun(\"host-run-1\", \"main\")\n   742→\tparent.IsHost = true\n   743→\tparent.ProjectDir = \"/project\"\n   744→\tparent.Start()\n   745→\trequire.NoError(t, store.CreateRun(ctx, parent))\n   746→\n   747→\t// Create child runs with ParentRunID set\n   748→\tchild1 := domain.NewRun(\"child-1\", \"develop\")\n   749→\tchild1.ProjectDir = \"/project\"\n   750→\tchild1.ParentRunID = \"host-run-1\"\n   751→\tchild1.StartedAt = time.Now()\n   752→\tchild1.State = domain.RunStateRunning\n   753→\trequire.NoError(t, store.CreateRun(ctx, child1))\n   754→\n   755→\tchild2 := domain.NewRun(\"child-2\", \"develop\")\n   756→\tchild2.ProjectDir = \"/project\"\n   757→\tchild2.ParentRunID = \"host-run-1\"\n   758→\tchild2.StartedAt = time.Now().Add(time.Second)\n   759→\tchild2.State = domain.RunStateSucceeded\n   760→\trequire.NoError(t, store.CreateRun(ctx, child2))\n   761→\n   762→\t// Verify ParentRunID is persisted via GetRun\n   763→\tgot, err := store.GetRun(ctx, \"child-1\")\n   764→\trequire.NoError(t, err)\n   765→\tassert.Equal(t, \"host-run-1\", got.ParentRunID)\n   766→\n   767→\t// Verify parent has no ParentRunID\n   768→\tgotParent, err := store.GetRun(ctx, \"host-run-1\")\n   769→\trequire.NoError(t, err)\n   770→\tassert.Equal(t, \"\", gotParent.ParentRunID)\n   771→\n   772→\t// ListChildRuns returns only children of the given parent\n   773→\tchildren, err := store.ListChildRuns(ctx, \"host-run-1\")\n   774→\trequire.NoError(t, err)\n   775→\tassert.Len(t, children, 2)\n   776→\tassert.Equal(t, \"child-1\", children[0].ID)\n   777→\tassert.Equal(t, \"child-2\", children[1].ID)\n   778→\n   779→\t// ListChildRuns for a non-parent returns empty\n   780→\tnoChildren, err := store.ListChildRuns(ctx, \"child-1\")\n   781→\trequire.NoError(t, err)\n   782→\tassert.Empty(t, noChildren)\n   783→\n   784→\t// Verify ParentRunID shows up in ListRuns\n   785→\truns, err := store.ListRuns(ctx, time.Time{})\n   786→\trequire.NoError(t, err)\n   787→\tfor _, r := range runs {\n   788→\t\tif r.ID == \"child-1\" || r.ID == \"child-2\" {\n   789→\t\t\tassert.Equal(t, \"host-run-1\", r.ParentRunID)\n   790→\t\t}\n   791→\t\tif r.ID == \"host-run-1\" {\n   792→\t\t\tassert.Equal(t, \"\", r.ParentRunID)\n   793→\t\t}\n   794→\t}\n   795→\n   796→\t// Test update preserves ParentRunID\n   797→\tgot.ParentRunID = \"new-parent\"\n   798→\trequire.NoError(t, store.UpdateRun(ctx, got))\n   799→\tgot2, err := store.GetRun(ctx, \"child-1\")\n   800→\trequire.NoError(t, err)\n   801→\tassert.Equal(t, \"new-parent\", got2.ParentRunID)\n   802→}\n   803→\n   804→func TestRunParentRunID_BackwardCompat(t *testing.T) {\n   805→\tstore, err := sqlite.NewStore(\":memory:\")\n   806→\trequire.NoError(t, err)\n   807→\tdefer store.Close()\n   808→\n   809→\tctx := context.Background()\n   810→\n   811→\t// Create a run without setting ParentRunID — simulates pre-migration rows\n   812→\trun := domain.NewRun(\"old-1\", \"develop\")\n   813→\trun.Start()\n   814→\trequire.NoError(t, store.CreateRun(ctx, run))\n   815→\n   816→\tgot, err := store.GetRun(ctx, \"old-1\")\n   817→\trequire.NoError(t, err)\n   818→\tassert.Equal(t, \"\", got.ParentRunID)\n   819→}\n   820→\n   821→func TestLogFiles_EmptyResults(t *testing.T) {\n   822→\tstore, err := sqlite.NewStore(\":memory:\")\n   823→\trequire.NoError(t, err)\n   824→\tdefer store.Close()\n   825→\n   826→\tctx := context.Background()\n   827→\n   828→\t// No entries yet\n   829→\tfiles, err := store.GetLogFiles(ctx, \"nonexistent\")\n   830→\trequire.NoError(t, err)\n   831→\tassert.Empty(t, files)\n   832→\n   833→\tfiles, err = store.GetLogFilesByStep(ctx, \"nonexistent\", \"build\")\n   834→\trequire.NoError(t, err)\n   835→\tassert.Empty(t, files)\n   836→\n   837→\tfiles, err = store.GetLogFileByType(ctx, \"nonexistent\", \"llm\")\n   838→\trequire.NoError(t, err)\n   839→\tassert.Empty(t, files)\n   840→}\n   841→\n   842→func TestListRunsSortRunningFirst(t *testing.T) {\n   843→\tstore, err := sqlite.NewStore(\":memory:\")\n   844→\trequire.NoError(t, err)\n   845→\tdefer store.Close()\n   846→\n   847→\tctx := context.Background()\n   848→\tnow := time.Now()\n   849→\n   850→\t// Create runs: oldest running, middle succeeded, newest failed\n   851→\truns := []struct {\n   852→\t\tid    string\n   853→\t\tstate domain.RunState\n   854→\t\tstart time.Time\n   855→\t}{\n   856→\t\t{\"old-running\", domain.RunStateRunning, now.Add(-10 * time.Minute)},\n   857→\t\t{\"mid-succeeded\", domain.RunStateSucceeded, now.Add(-5 * time.Minute)},\n   858→\t\t{\"new-failed\", domain.RunStateFailed, now.Add(-1 * time.Minute)},\n   859→\t\t{\"new-running\", domain.RunStateRunning, now.Add(-2 * time.Minute)},\n   860→\t}\n   861→\n   862→\tfor _, tc := range runs {\n   863→\t\tr := domain.NewRun(tc.id, \"develop\")\n   864→\t\tr.State = tc.state\n   865→\t\tr.StartedAt = tc.start\n   866→\t\tr.ProjectDir = \"/test/project\"\n   867→\t\tif tc.state != domain.RunStateRunning {\n   868→\t\t\tr.CompletedAt = tc.start.Add(time.Minute)\n   869→\t\t}\n   870→\t\trequire.NoError(t, store.CreateRun(ctx, r))\n   871→\t}\n   872→\n   873→\t// ListRuns: running runs first (by recency), then non-running by recency\n   874→\tlisted, err := store.ListRuns(ctx, time.Time{})\n   875→\trequire.NoError(t, err)\n   876→\trequire.Len(t, listed, 4)\n   877→\tassert.Equal(t, \"new-running\", listed[0].ID)    // running, more recent\n   878→\tassert.Equal(t, \"old-running\", listed[1].ID)     // running, older\n   879→\tassert.Equal(t, \"new-failed\", listed[2].ID)      // non-running, most recent\n   880→\tassert.Equal(t, \"mid-succeeded\", listed[3].ID)   // non-running, older\n   881→\n   882→\t// ListRunsByProject: same ordering\n   883→\tlisted, err = store.ListRunsByProject(ctx, \"/test/project\", time.Time{})\n   884→\trequire.NoError(t, err)\n   885→\trequire.Len(t, listed, 4)\n   886→\tassert.Equal(t, \"new-running\", listed[0].ID)\n   887→\tassert.Equal(t, \"old-running\", listed[1].ID)\n   888→\tassert.Equal(t, \"new-failed\", listed[2].ID)\n   889→\tassert.Equal(t, \"mid-succeeded\", listed[3].ID)\n   890→\n   891→\t// ListRuns with since filter: same ordering\n   892→\tlisted, err = store.ListRuns(ctx, now.Add(-6*time.Minute))\n   893→\trequire.NoError(t, err)\n   894→\trequire.Len(t, listed, 3) // excludes old-running (started 10min ago)\n   895→\tassert.Equal(t, \"new-running\", listed[0].ID)\n   896→\tassert.Equal(t, \"new-failed\", listed[1].ID)\n   897→\tassert.Equal(t, \"mid-succeeded\", listed[2].ID)\n   898→}\n   899→"}]},"parent_tool_use_id":null,"session_id":"c0b250b2-f9c5-4d6e-a2b5-21933ebd9c8c","uuid":"7d80b4d6-b3ab-446f-b8e6-61b1deafdec1","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/sqlite/store_test.go","content":"package sqlite_test\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"path/filepath\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestRunStore_CreateAndGet(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n\trun.Start()\n\n\terr = store.CreateRun(ctx, run)\n\trequire.NoError(t, err)\n\n\tgot, err := store.GetRun(ctx, \"run-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"run-1\", got.ID)\n\tassert.Equal(t, \"test-workflow\", got.WorkflowName)\n\tassert.Equal(t, domain.RunStateRunning, got.State)\n}\n\nfunc TestRunStore_Update(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.UpdateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"run-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, got.State)\n}\n\nfunc TestRunStore_List(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun1 := domain.NewRun(\"run-1\", \"wf-a\")\n\trun2 := domain.NewRun(\"run-2\", \"wf-b\")\n\trequire.NoError(t, store.CreateRun(ctx, run1))\n\trequire.NoError(t, store.CreateRun(ctx, run2))\n\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, 2)\n}\n\nfunc TestRunStore_GetNotFound(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\t_, err = store.GetRun(context.Background(), \"nonexistent\")\n\tassert.Error(t, err)\n}\n\nfunc TestStore_DeleteRun(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run and save a capture for it\n\trun := domain.NewRun(\"del-1\", \"test-workflow\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\trequire.NoError(t, store.SaveCapture(ctx, \"del-1\", &domain.StepExecution{\n\t\tStepName:  \"step1\",\n\t\tStartedAt: time.Now(),\n\t}))\n\n\t// Delete the run\n\terr = store.DeleteRun(ctx, \"del-1\")\n\trequire.NoError(t, err)\n\n\t// Verify run is gone\n\t_, err = store.GetRun(ctx, \"del-1\")\n\tassert.Error(t, err)\n\n\t// Verify captures are gone\n\tcaps, err := store.GetCaptures(ctx, \"del-1\")\n\trequire.NoError(t, err)\n\tassert.Empty(t, caps)\n}\n\nfunc TestRunProjectDir(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"test-1\", \"develop\")\n\trun.ProjectDir = \"/home/user/project\"\n\trun.Start()\n\n\terr = store.CreateRun(ctx, run)\n\trequire.NoError(t, err)\n\n\tgot, err := store.GetRun(ctx, \"test-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"/home/user/project\", got.ProjectDir)\n}\n\nfunc TestCaptureStepMetadata(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"test-1\", \"develop\")\n\trun.Start()\n\tstore.CreateRun(ctx, run)\n\n\texec := &domain.StepExecution{\n\t\tStepName:  \"implement\",\n\t\tResult:    \"success\",\n\t\tStartedAt: time.Now(),\n\t}\n\terr = store.SaveCapture(ctx, \"test-1\", exec)\n\trequire.NoError(t, err)\n\n\tcaps, err := store.GetCaptures(ctx, \"test-1\")\n\trequire.NoError(t, err)\n\trequire.Len(t, caps, 1)\n\tassert.Equal(t, \"implement\", caps[0].StepName)\n\tassert.Equal(t, \"success\", caps[0].Result)\n}\n\nfunc TestListRunsSince(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\tfor i, id := range []string{\"run-1\", \"run-2\", \"run-3\"} {\n\t\tr := domain.NewRun(id, \"develop\")\n\t\tr.ProjectDir = \"/project\"\n\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n\t\tr.State = domain.RunStateRunning\n\t\trequire.NoError(t, store.CreateRun(ctx, r))\n\t}\n\n\truns, err := store.ListRunsSince(ctx, \"/project\", \"develop\", \"run-1\")\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, 2)\n\tassert.Equal(t, \"run-2\", runs[0].ID)\n\tassert.Equal(t, \"run-3\", runs[1].ID)\n}\n\nfunc TestListRunsSinceEmpty(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\tfor i, id := range []string{\"run-1\", \"run-2\"} {\n\t\tr := domain.NewRun(id, \"develop\")\n\t\tr.ProjectDir = \"/project\"\n\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n\t\tr.State = domain.RunStateRunning\n\t\trequire.NoError(t, store.CreateRun(ctx, r))\n\t}\n\n\t// Empty sinceRunID returns all\n\truns, err := store.ListRunsSince(ctx, \"/project\", \"develop\", \"\")\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, 2)\n}\n\nfunc TestGetLastEvolution(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// No evolution yet\n\tentry, err := store.GetLastEvolution(ctx, \"/project\", \"develop\")\n\trequire.NoError(t, err)\n\tassert.Nil(t, entry)\n\n\t// Save one\n\trequire.NoError(t, store.SaveEvolution(ctx, &ports.EvolutionEntry{\n\t\tID:           \"evo-1\",\n\t\tProjectDir:   \"/project\",\n\t\tWorkflowName: \"develop\",\n\t\tTriggerRunID: \"run-1\",\n\t\tCreatedAt:    time.Now(),\n\t\tChangesJSON:  \"[]\",\n\t}))\n\n\tentry, err = store.GetLastEvolution(ctx, \"/project\", \"develop\")\n\trequire.NoError(t, err)\n\trequire.NotNil(t, entry)\n\tassert.Equal(t, \"evo-1\", entry.ID)\n}\n\nfunc TestRunTitle(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run with a title\n\trun := domain.NewRun(\"title-1\", \"develop\")\n\trun.Title = \"Add dark mode toggle\"\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"title-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"Add dark mode toggle\", got.Title)\n\n\t// Update title\n\tgot.Title = \"Updated title\"\n\trequire.NoError(t, store.UpdateRun(ctx, got))\n\n\tgot2, err := store.GetRun(ctx, \"title-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"Updated title\", got2.Title)\n\n\t// Verify title shows up in ListRuns\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, runs, 1)\n\tassert.Equal(t, \"Updated title\", runs[0].Title)\n}\n\nfunc TestRunTitle_BackwardCompat(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run without setting Title — simulates pre-migration rows\n\trun := domain.NewRun(\"notitle-1\", \"develop\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"notitle-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"\", got.Title)\n}\n\nfunc TestRunContainerID(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"cid-1\", \"develop\")\n\trun.Start()\n\trun.ContainerID = \"4647e7e70e3fabc123def456\"\n\n\terr = store.CreateRun(ctx, run)\n\trequire.NoError(t, err)\n\n\tgot, err := store.GetRun(ctx, \"cid-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"4647e7e70e3fabc123def456\", got.ContainerID)\n\n\t// Test update preserves container ID\n\tgot.ContainerID = \"new-container-id\"\n\trequire.NoError(t, store.UpdateRun(ctx, got))\n\n\tgot2, err := store.GetRun(ctx, \"cid-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"new-container-id\", got2.ContainerID)\n\n\t// Test ListRuns includes container ID\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, runs, 1)\n\tassert.Equal(t, \"new-container-id\", runs[0].ContainerID)\n}\n\nfunc TestRunContainerID_BackwardCompat(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\t// Create a run without setting ContainerID — simulates pre-migration rows\n\trun := domain.NewRun(\"old-1\", \"develop\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"old-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"\", got.ContainerID)\n}\n\nfunc TestRunErrorMessage(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"err-1\", \"develop\")\n\trun.Start()\n\trun.Fail(\"failed to start container: image not found\")\n\n\terr = store.CreateRun(ctx, run)\n\trequire.NoError(t, err)\n\n\tgot, err := store.GetRun(ctx, \"err-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, got.State)\n\tassert.Equal(t, \"failed to start container: image not found\", got.ErrorMessage)\n\n\t// Test update preserves error message\n\tgot.ErrorMessage = \"updated error\"\n\trequire.NoError(t, store.UpdateRun(ctx, got))\n\n\tgot2, err := store.GetRun(ctx, \"err-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"updated error\", got2.ErrorMessage)\n}\n\nfunc TestRunErrorMessage_Truncation(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Build a message well over 1000 characters\n\tlongMsg := \"\"\n\tfor len(longMsg) < 5000 {\n\t\tlongMsg += \"error output line that keeps going and going. \"\n\t}\n\n\t// Test truncation on CreateRun\n\trun := domain.NewRun(\"trunc-create\", \"develop\")\n\trun.Start()\n\trun.Fail(longMsg)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"trunc-create\")\n\trequire.NoError(t, err)\n\tassert.LessOrEqual(t, len(got.ErrorMessage), 1020) // 1000 + \"... (truncated)\"\n\tassert.Contains(t, got.ErrorMessage, \"... (truncated)\")\n\n\t// Test truncation on UpdateRun\n\trun2 := domain.NewRun(\"trunc-update\", \"develop\")\n\trun2.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run2))\n\n\trun2.Fail(longMsg)\n\trequire.NoError(t, store.UpdateRun(ctx, run2))\n\n\tgot2, err := store.GetRun(ctx, \"trunc-update\")\n\trequire.NoError(t, err)\n\tassert.LessOrEqual(t, len(got2.ErrorMessage), 1020)\n\tassert.Contains(t, got2.ErrorMessage, \"... (truncated)\")\n\n\t// Short messages should NOT be truncated\n\trun3 := domain.NewRun(\"trunc-short\", \"develop\")\n\trun3.Start()\n\trun3.Fail(\"short error\")\n\trequire.NoError(t, store.CreateRun(ctx, run3))\n\n\tgot3, err := store.GetRun(ctx, \"trunc-short\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"short error\", got3.ErrorMessage)\n}\n\nfunc TestRunErrorMessageInList(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"err-list-1\", \"develop\")\n\trun.Start()\n\trun.Fail(\"container crashed\")\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, runs, 1)\n\tassert.Equal(t, \"container crashed\", runs[0].ErrorMessage)\n}\n\nfunc TestStore_ConcurrentWrites(t *testing.T) {\n\tdbPath := filepath.Join(t.TempDir(), \"concurrent.db\")\n\tstore, err := sqlite.NewStore(dbPath)\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tconst n = 10\n\tctx := context.Background()\n\terrs := make([]error, n)\n\n\tvar wg sync.WaitGroup\n\twg.Add(n)\n\tfor i := 0; i < n; i++ {\n\t\tgo func(i int) {\n\t\t\tdefer wg.Done()\n\t\t\tid := fmt.Sprintf(\"run-%d\", i)\n\t\t\trun := domain.NewRun(id, \"test-workflow\")\n\t\t\trun.Start()\n\t\t\tif err := store.CreateRun(ctx, run); err != nil {\n\t\t\t\terrs[i] = err\n\t\t\t\treturn\n\t\t\t}\n\t\t\terrs[i] = store.SaveCapture(ctx, id, &domain.StepExecution{\n\t\t\t\tStepName:  fmt.Sprintf(\"step-%d\", i),\n\t\t\t\tStartedAt: time.Now(),\n\t\t\t})\n\t\t}(i)\n\t}\n\twg.Wait()\n\n\tfor i, err := range errs {\n\t\tassert.NoError(t, err, \"goroutine %d failed\", i)\n\t}\n\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, n)\n}\n\nfunc TestListRunsByProject(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create runs for two different projects\n\tfor i, id := range []string{\"proj-a-1\", \"proj-a-2\"} {\n\t\tr := domain.NewRun(id, \"develop\")\n\t\tr.ProjectDir = \"/home/user/project-a\"\n\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n\t\tr.State = domain.RunStateRunning\n\t\trequire.NoError(t, store.CreateRun(ctx, r))\n\t}\n\trB := domain.NewRun(\"proj-b-1\", \"develop\")\n\trB.ProjectDir = \"/home/user/project-b\"\n\trB.StartedAt = time.Now()\n\trB.State = domain.RunStateRunning\n\trequire.NoError(t, store.CreateRun(ctx, rB))\n\n\t// Filter by project-a\n\truns, err := store.ListRunsByProject(ctx, \"/home/user/project-a\", time.Time{})\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, 2)\n\tfor _, r := range runs {\n\t\tassert.Equal(t, \"/home/user/project-a\", r.ProjectDir)\n\t}\n\n\t// Filter by project-b\n\truns, err = store.ListRunsByProject(ctx, \"/home/user/project-b\", time.Time{})\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, 1)\n\tassert.Equal(t, \"proj-b-1\", runs[0].ID)\n\n\t// Filter by nonexistent project\n\truns, err = store.ListRunsByProject(ctx, \"/nonexistent\", time.Time{})\n\trequire.NoError(t, err)\n\tassert.Empty(t, runs)\n}\n\nfunc TestListProjects(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Empty store returns no projects\n\tprojects, err := store.ListProjects(ctx)\n\trequire.NoError(t, err)\n\tassert.Empty(t, projects)\n\n\t// Create runs for different projects\n\tfor _, tc := range []struct {\n\t\tid, project string\n\t}{\n\t\t{\"r1\", \"/home/user/alpha\"},\n\t\t{\"r2\", \"/home/user/alpha\"},\n\t\t{\"r3\", \"/home/user/beta\"},\n\t\t{\"r4\", \"\"},\n\t} {\n\t\tr := domain.NewRun(tc.id, \"develop\")\n\t\tr.ProjectDir = tc.project\n\t\tr.State = domain.RunStatePending\n\t\trequire.NoError(t, store.CreateRun(ctx, r))\n\t}\n\n\tprojects, err = store.ListProjects(ctx)\n\trequire.NoError(t, err)\n\tassert.Equal(t, []string{\"/home/user/alpha\", \"/home/user/beta\"}, projects)\n}\n\nfunc TestRunContainerKept(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run with ContainerKept = false (default)\n\trun := domain.NewRun(\"kept-1\", \"develop\")\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"kept-1\")\n\trequire.NoError(t, err)\n\tassert.False(t, got.ContainerKept)\n\n\t// Update to mark container as kept\n\tgot.ContainerKept = true\n\trequire.NoError(t, store.UpdateRun(ctx, got))\n\n\tgot2, err := store.GetRun(ctx, \"kept-1\")\n\trequire.NoError(t, err)\n\tassert.True(t, got2.ContainerKept)\n\n\t// Verify ListRuns includes ContainerKept\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, runs, 1)\n\tassert.True(t, runs[0].ContainerKept)\n}\n\nfunc TestRunIsHost(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a host run\n\trun := domain.NewRun(\"host-1\", \"main\")\n\trun.IsHost = true\n\trun.ProjectDir = \"/project\"\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"host-1\")\n\trequire.NoError(t, err)\n\tassert.True(t, got.IsHost)\n\n\t// Create a container run\n\tcrun := domain.NewRun(\"container-1\", \"develop\")\n\tcrun.ProjectDir = \"/project\"\n\tcrun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, crun))\n\n\tgot2, err := store.GetRun(ctx, \"container-1\")\n\trequire.NoError(t, err)\n\tassert.False(t, got2.IsHost)\n\n\t// Verify IsHost shows up in ListRuns\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, runs, 2)\n\n\thostFound := false\n\tcontainerFound := false\n\tfor _, r := range runs {\n\t\tif r.ID == \"host-1\" {\n\t\t\tassert.True(t, r.IsHost)\n\t\t\thostFound = true\n\t\t}\n\t\tif r.ID == \"container-1\" {\n\t\t\tassert.False(t, r.IsHost)\n\t\t\tcontainerFound = true\n\t\t}\n\t}\n\tassert.True(t, hostFound)\n\tassert.True(t, containerFound)\n\n\t// Verify IsHost shows up in ListRunsByProject\n\tprojRuns, err := store.ListRunsByProject(ctx, \"/project\", time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, projRuns, 2)\n\tfor _, r := range projRuns {\n\t\tif r.ID == \"host-1\" {\n\t\t\tassert.True(t, r.IsHost)\n\t\t}\n\t}\n\n\t// Test update preserves IsHost\n\tgot.IsHost = false\n\trequire.NoError(t, store.UpdateRun(ctx, got))\n\tgot3, err := store.GetRun(ctx, \"host-1\")\n\trequire.NoError(t, err)\n\tassert.False(t, got3.IsHost)\n}\n\nfunc TestRunIsHost_BackwardCompat(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run without setting IsHost — simulates pre-migration rows\n\trun := domain.NewRun(\"old-1\", \"develop\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"old-1\")\n\trequire.NoError(t, err)\n\tassert.False(t, got.IsHost)\n}\n\nfunc TestStore_FailStaleRuns(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create runs in different states.\n\tpending := domain.NewRun(\"pending-1\", \"wf\")\n\trequire.NoError(t, store.CreateRun(ctx, pending))\n\n\trunning := domain.NewRun(\"running-1\", \"wf\")\n\trunning.Start()\n\trequire.NoError(t, store.CreateRun(ctx, running))\n\n\tsucceeded := domain.NewRun(\"succeeded-1\", \"wf\")\n\tsucceeded.Start()\n\tsucceeded.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, succeeded))\n\n\tn, err := store.FailStaleRuns(ctx)\n\trequire.NoError(t, err)\n\tassert.Equal(t, int64(2), n) // both pending and running\n\n\tgot, err := store.GetRun(ctx, \"pending-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, got.State)\n\tassert.False(t, got.CompletedAt.IsZero(), \"completed_at should be set\")\n\tassert.Equal(t, \"daemon restarted while run was active\", got.ErrorMessage)\n\n\tgotRunning, err := store.GetRun(ctx, \"running-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, gotRunning.State)\n\tassert.False(t, gotRunning.CompletedAt.IsZero(), \"completed_at should be set\")\n\tassert.Equal(t, \"daemon restarted while run was active\", gotRunning.ErrorMessage)\n\n\t// Succeeded runs should be untouched.\n\tgotSucceeded, err := store.GetRun(ctx, \"succeeded-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, gotSucceeded.State)\n}\n\nfunc TestLogFiles_SaveAndGet(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run first (foreign key)\n\trun := domain.NewRun(\"log-run-1\", \"develop\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tnow := time.Now().Truncate(time.Second)\n\n\t// Save log file entries\n\tentries := []*ports.LogFileEntry{\n\t\t{RunID: \"log-run-1\", FileType: \"full\", FilePath: \"/tmp/output/full.log\", FileSize: 1024, CreatedAt: now},\n\t\t{RunID: \"log-run-1\", StepName: \"build\", FileType: \"script\", FilePath: \"/tmp/output/build.log\", FileSize: 512, CreatedAt: now},\n\t\t{RunID: \"log-run-1\", StepName: \"build\", FileType: \"llm\", FilePath: \"/tmp/output/llm-build.log\", FileSize: 2048, CreatedAt: now},\n\t\t{RunID: \"log-run-1\", StepName: \"test\", FileType: \"script\", FilePath: \"/tmp/output/test.log\", FileSize: 256, CreatedAt: now},\n\t}\n\tfor _, e := range entries {\n\t\trequire.NoError(t, store.SaveLogFile(ctx, e))\n\t}\n\n\t// GetLogFiles returns all entries for a run\n\tall, err := store.GetLogFiles(ctx, \"log-run-1\")\n\trequire.NoError(t, err)\n\tassert.Len(t, all, 4)\n\n\t// GetLogFilesByStep returns entries for a specific step\n\tbuildLogs, err := store.GetLogFilesByStep(ctx, \"log-run-1\", \"build\")\n\trequire.NoError(t, err)\n\tassert.Len(t, buildLogs, 2)\n\tfor _, lf := range buildLogs {\n\t\tassert.Equal(t, \"build\", lf.StepName)\n\t}\n\n\t// GetLogFileByType returns entries of a specific type\n\tllmLogs, err := store.GetLogFileByType(ctx, \"log-run-1\", \"llm\")\n\trequire.NoError(t, err)\n\tassert.Len(t, llmLogs, 1)\n\tassert.Equal(t, \"llm\", llmLogs[0].FileType)\n\tassert.Equal(t, \"build\", llmLogs[0].StepName)\n\n\t// GetLogFileByType for \"full\"\n\tfullLogs, err := store.GetLogFileByType(ctx, \"log-run-1\", \"full\")\n\trequire.NoError(t, err)\n\tassert.Len(t, fullLogs, 1)\n\tassert.Equal(t, \"full\", fullLogs[0].FileType)\n\tassert.Equal(t, int64(1024), fullLogs[0].FileSize)\n}\n\nfunc TestRunParentRunID(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a host (parent) run\n\tparent := domain.NewRun(\"host-run-1\", \"main\")\n\tparent.IsHost = true\n\tparent.ProjectDir = \"/project\"\n\tparent.Start()\n\trequire.NoError(t, store.CreateRun(ctx, parent))\n\n\t// Create child runs with ParentRunID set\n\tchild1 := domain.NewRun(\"child-1\", \"develop\")\n\tchild1.ProjectDir = \"/project\"\n\tchild1.ParentRunID = \"host-run-1\"\n\tchild1.StartedAt = time.Now()\n\tchild1.State = domain.RunStateRunning\n\trequire.NoError(t, store.CreateRun(ctx, child1))\n\n\tchild2 := domain.NewRun(\"child-2\", \"develop\")\n\tchild2.ProjectDir = \"/project\"\n\tchild2.ParentRunID = \"host-run-1\"\n\tchild2.StartedAt = time.Now().Add(time.Second)\n\tchild2.State = domain.RunStateSucceeded\n\trequire.NoError(t, store.CreateRun(ctx, child2))\n\n\t// Verify ParentRunID is persisted via GetRun\n\tgot, err := store.GetRun(ctx, \"child-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"host-run-1\", got.ParentRunID)\n\n\t// Verify parent has no ParentRunID\n\tgotParent, err := store.GetRun(ctx, \"host-run-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"\", gotParent.ParentRunID)\n\n\t// ListChildRuns returns only children of the given parent\n\tchildren, err := store.ListChildRuns(ctx, \"host-run-1\")\n\trequire.NoError(t, err)\n\tassert.Len(t, children, 2)\n\tassert.Equal(t, \"child-1\", children[0].ID)\n\tassert.Equal(t, \"child-2\", children[1].ID)\n\n\t// ListChildRuns for a non-parent returns empty\n\tnoChildren, err := store.ListChildRuns(ctx, \"child-1\")\n\trequire.NoError(t, err)\n\tassert.Empty(t, noChildren)\n\n\t// Verify ParentRunID shows up in ListRuns\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\tfor _, r := range runs {\n\t\tif r.ID == \"child-1\" || r.ID == \"child-2\" {\n\t\t\tassert.Equal(t, \"host-run-1\", r.ParentRunID)\n\t\t}\n\t\tif r.ID == \"host-run-1\" {\n\t\t\tassert.Equal(t, \"\", r.ParentRunID)\n\t\t}\n\t}\n\n\t// Test update preserves ParentRunID\n\tgot.ParentRunID = \"new-parent\"\n\trequire.NoError(t, store.UpdateRun(ctx, got))\n\tgot2, err := store.GetRun(ctx, \"child-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"new-parent\", got2.ParentRunID)\n}\n\nfunc TestRunParentRunID_BackwardCompat(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run without setting ParentRunID — simulates pre-migration rows\n\trun := domain.NewRun(\"old-1\", \"develop\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"old-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"\", got.ParentRunID)\n}\n\nfunc TestLogFiles_EmptyResults(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// No entries yet\n\tfiles, err := store.GetLogFiles(ctx, \"nonexistent\")\n\trequire.NoError(t, err)\n\tassert.Empty(t, files)\n\n\tfiles, err = store.GetLogFilesByStep(ctx, \"nonexistent\", \"build\")\n\trequire.NoError(t, err)\n\tassert.Empty(t, files)\n\n\tfiles, err = store.GetLogFileByType(ctx, \"nonexistent\", \"llm\")\n\trequire.NoError(t, err)\n\tassert.Empty(t, files)\n}\n\nfunc TestListRunsSortRunningFirst(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Create runs: oldest running, middle succeeded, newest failed\n\truns := []struct {\n\t\tid    string\n\t\tstate domain.RunState\n\t\tstart time.Time\n\t}{\n\t\t{\"old-running\", domain.RunStateRunning, now.Add(-10 * time.Minute)},\n\t\t{\"mid-succeeded\", domain.RunStateSucceeded, now.Add(-5 * time.Minute)},\n\t\t{\"new-failed\", domain.RunStateFailed, now.Add(-1 * time.Minute)},\n\t\t{\"new-running\", domain.RunStateRunning, now.Add(-2 * time.Minute)},\n\t}\n\n\tfor _, tc := range runs {\n\t\tr := domain.NewRun(tc.id, \"develop\")\n\t\tr.State = tc.state\n\t\tr.StartedAt = tc.start\n\t\tr.ProjectDir = \"/test/project\"\n\t\tif tc.state != domain.RunStateRunning {\n\t\t\tr.CompletedAt = tc.start.Add(time.Minute)\n\t\t}\n\t\trequire.NoError(t, store.CreateRun(ctx, r))\n\t}\n\n\t// ListRuns: running runs first (by recency), then non-running by recency\n\tlisted, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, listed, 4)\n\tassert.Equal(t, \"new-running\", listed[0].ID)    // running, more recent\n\tassert.Equal(t, \"old-running\", listed[1].ID)     // running, older\n\tassert.Equal(t, \"new-failed\", listed[2].ID)      // non-running, most recent\n\tassert.Equal(t, \"mid-succeeded\", listed[3].ID)   // non-running, older\n\n\t// ListRunsByProject: same ordering\n\tlisted, err = store.ListRunsByProject(ctx, \"/test/project\", time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, listed, 4)\n\tassert.Equal(t, \"new-running\", listed[0].ID)\n\tassert.Equal(t, \"old-running\", listed[1].ID)\n\tassert.Equal(t, \"new-failed\", listed[2].ID)\n\tassert.Equal(t, \"mid-succeeded\", listed[3].ID)\n\n\t// ListRuns with since filter: same ordering\n\tlisted, err = store.ListRuns(ctx, now.Add(-6*time.Minute))\n\trequire.NoError(t, err)\n\trequire.Len(t, listed, 3) // excludes old-running (started 10min ago)\n\tassert.Equal(t, \"new-running\", listed[0].ID)\n\tassert.Equal(t, \"new-failed\", listed[1].ID)\n\tassert.Equal(t, \"mid-succeeded\", listed[2].ID)\n}\n","numLines":899,"startLine":1,"totalLines":899}}}
