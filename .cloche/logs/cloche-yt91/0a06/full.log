.Args[2:]) {\n    65→\t\t\tprintSubcommandHelp(\"set\")\n    66→\t\t\treturn\n    67→\t\t}\n    68→\t\tcmdSet(os.Args[2:])\n    69→\t\treturn\n    70→\tcase \"tasks\":\n    71→\t\tif hasHelpFlag(os.Args[2:]) {\n    72→\t\t\tprintSubcommandHelp(\"tasks\")\n    73→\t\t\treturn\n    74→\t\t}\n    75→\t\tcmdTasks(os.Args[2:])\n    76→\t\treturn\n    77→\tcase \"workflow\":\n    78→\t\tif hasHelpFlag(os.Args[2:]) {\n    79→\t\t\tprintSubcommandHelp(\"workflow\")\n    80→\t\t\treturn\n    81→\t\t}\n    82→\t\tcmdWorkflow(os.Args[2:])\n    83→\t\treturn\n    84→\t}\n    85→\n    86→\t// Handle --help for daemon commands before connecting\n    87→\tdaemonCmds := map[string]bool{\n    88→\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n    89→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n    90→\t}\n    91→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n    92→\t\tprintSubcommandHelp(os.Args[1])\n    93→\t\treturn\n    94→\t}\n    95→\n    96→\t// Commands that need a daemon connection\n    97→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    98→\tif addr == \"\" {\n    99→\t\taddr = \"unix:///tmp/cloche.sock\"\n   100→\t}\n   101→\n   102→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   103→\tif err != nil {\n   104→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   105→\t\tos.Exit(1)\n   106→\t}\n   107→\tdefer conn.Close()\n   108→\n   109→\tclient := pb.NewClocheServiceClient(conn)\n   110→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   111→\tdefer cancel()\n   112→\n   113→\tswitch os.Args[1] {\n   114→\tcase \"run\":\n   115→\t\tcmdRun(ctx, client, os.Args[2:])\n   116→\tcase \"status\":\n   117→\t\tcmdStatus(ctx, client, os.Args[2:])\n   118→\tcase \"logs\":\n   119→\t\tcmdLogs(client, os.Args[2:])\n   120→\tcase \"poll\":\n   121→\t\tcmdPoll(client, os.Args[2:])\n   122→\tcase \"list\":\n   123→\t\tcmdList(ctx, client, os.Args[2:])\n   124→\tcase \"stop\":\n   125→\t\tcmdStop(ctx, client, os.Args[2:])\n   126→\tcase \"delete\":\n   127→\t\tcmdDelete(ctx, client, os.Args[2:])\n   128→\tcase \"loop\":\n   129→\t\tcmdLoop(ctx, client, os.Args[2:])\n   130→\tcase \"shutdown\":\n   131→\t\tcmdShutdown(ctx, client)\n   132→\tdefault:\n   133→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   134→\t\tprintTopLevelHelp()\n   135→\t\tos.Exit(1)\n   136→\t}\n   137→}\n   138→\n   139→\n   140→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   141→\tvar workflow, prompt, title string\n   142→\tvar keepContainer bool\n   143→\n   144→\tfor i := 0; i < len(args); i++ {\n   145→\t\tswitch args[i] {\n   146→\t\tcase \"--workflow\":\n   147→\t\t\tif i+1 < len(args) {\n   148→\t\t\t\ti++\n   149→\t\t\t\tworkflow = args[i]\n   150→\t\t\t}\n   151→\t\tcase \"--prompt\", \"-p\":\n   152→\t\t\tif i+1 < len(args) {\n   153→\t\t\t\ti++\n   154→\t\t\t\tprompt = args[i]\n   155→\t\t\t}\n   156→\t\tcase \"--title\":\n   157→\t\t\tif i+1 < len(args) {\n   158→\t\t\t\ti++\n   159→\t\t\t\ttitle = args[i]\n   160→\t\t\t}\n   161→\t\tcase \"--keep-container\":\n   162→\t\t\tkeepContainer = true\n   163→\t\tdefault:\n   164→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   165→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   166→\t\t\t\tworkflow = args[i]\n   167→\t\t\t}\n   168→\t\t}\n   169→\t}\n   170→\n   171→\tif workflow == \"\" {\n   172→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   173→\t\tos.Exit(1)\n   174→\t}\n   175→\n   176→\tcwd, _ := os.Getwd()\n   177→\n   178→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   179→\tvar image string\n   180→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   181→\tif data, err := os.ReadFile(wfPath); err == nil {\n   182→\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   183→\t\t\timage = wf.Config[\"container.image\"]\n   184→\t\t}\n   185→\t}\n   186→\n   187→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   188→\t\tWorkflowName:  workflow,\n   189→\t\tProjectDir:    cwd,\n   190→\t\tImage:         image,\n   191→\t\tPrompt:        prompt,\n   192→\t\tKeepContainer: keepContainer,\n   193→\t\tTitle:         title,\n   194→\t})\n   195→\tif err != nil {\n   196→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   197→\t\tos.Exit(1)\n   198→\t}\n   199→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   200→}\n   201→\n   202→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   203→\tif len(args) < 1 {\n   204→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   205→\t\tos.Exit(1)\n   206→\t}\n   207→\n   208→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   209→\tif err != nil {\n   210→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   211→\t\tos.Exit(1)\n   212→\t}\n   213→\n   214→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   215→\tif resp.Title != \"\" {\n   216→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   217→\t}\n   218→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   219→\tif resp.IsHost {\n   220→\t\tfmt.Printf(\"Type:      host\\n\")\n   221→\t} else {\n   222→\t\tfmt.Printf(\"Type:      container\\n\")\n   223→\t}\n   224→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   225→\tif resp.ContainerId != \"\" {\n   226→\t\tcid := resp.ContainerId\n   227→\t\tif len(cid) > 12 {\n   228→\t\t\tcid = cid[:12]\n   229→\t\t}\n   230→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   231→\t}\n   232→\tif resp.ErrorMessage != \"\" {\n   233→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   234→\t}\n   235→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   236→\tfor _, exec := range resp.StepExecutions {\n   237→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   238→\t}\n   239→}\n   240→\n   241→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   242→\tvar all bool\n   243→\tfor _, arg := range args {\n   244→\t\tif arg == \"--all\" {\n   245→\t\t\tall = true\n   246→\t\t}\n   247→\t}\n   248→\n   249→\treq := &pb.ListRunsRequest{}\n   250→\tif all {\n   251→\t\t// --all: show all runs across all projects (no time limit)\n   252→\t\treq.All = true\n   253→\t} else {\n   254→\t\t// Default: filter to current project\n   255→\t\tcwd, _ := os.Getwd()\n   256→\t\treq.ProjectDir = cwd\n   257→\t}\n   258→\n   259→\tresp, err := client.ListRuns(ctx, req)\n   260→\tif err != nil {\n   261→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   262→\t\tos.Exit(1)\n   263→\t}\n   264→\n   265→\tif len(resp.Runs) == 0 {\n   266→\t\tfmt.Println(\"No runs found.\")\n   267→\t\treturn\n   268→\t}\n   269→\n   270→\tfor _, run := range resp.Runs {\n   271→\t\trunType := \"container\"\n   272→\t\tif run.IsHost {\n   273→\t\t\trunType = \"host\"\n   274→\t\t}\n   275→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   276→\t\tif run.Title != \"\" {\n   277→\t\t\tt := run.Title\n   278→\t\t\tif len(t) > 40 {\n   279→\t\t\t\tt = t[:37] + \"...\"\n   280→\t\t\t}\n   281→\t\t\tline += \"  \" + t\n   282→\t\t}\n   283→\t\tif run.ContainerId != \"\" {\n   284→\t\t\tline += \"  \" + run.ContainerId\n   285→\t\t}\n   286→\t\tif run.ErrorMessage != \"\" {\n   287→\t\t\terrMsg := run.ErrorMessage\n   288→\t\t\tif len(errMsg) > 60 {\n   289→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   290→\t\t\t}\n   291→\t\t\tline += \"  \" + errMsg\n   292→\t\t}\n   293→\t\tfmt.Println(line)\n   294→\t}\n   295→}\n   296→\n   297→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   298→\tif len(args) < 1 {\n   299→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n   300→\t\tos.Exit(1)\n   301→\t}\n   302→\n   303→\tvar stepFilter, typeFilter string\n   304→\tvar follow bool\n   305→\trunID := args[0]\n   306→\n   307→\tfor i := 1; i < len(args); i++ {\n   308→\t\tswitch args[i] {\n   309→\t\tcase \"--step\":\n   310→\t\t\tif i+1 < len(args) {\n   311→\t\t\t\ti++\n   312→\t\t\t\tstepFilter = args[i]\n   313→\t\t\t}\n   314→\t\tcase \"--type\":\n   315→\t\t\tif i+1 < len(args) {\n   316→\t\t\t\ti++\n   317→\t\t\t\ttypeFilter = args[i]\n   318→\t\t\t}\n   319→\t\tcase \"--follow\", \"-f\":\n   320→\t\t\tfollow = true\n   321→\t\t}\n   322→\t}\n   323→\n   324→\t// Use background context — log output can be large and follow mode blocks.\n   325→\tctx := context.Background()\n   326→\tif follow {\n   327→\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n   328→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   329→\t}\n   330→\n   331→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   332→\t\tRunId:    runID,\n   333→\t\tStepName: stepFilter,\n   334→\t\tLogType:  typeFilter,\n   335→\t})\n   336→\tif err != nil {\n   337→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   338→\t\tos.Exit(1)\n   339→\t}\n   340→\n   341→\tfor {\n   342→\t\tentry, err := stream.Recv()\n   343→\t\tif err != nil {\n   344→\t\t\tif errors.Is(err, io.EOF) {\n   345→\t\t\t\tbreak\n   346→\t\t\t}\n   347→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   348→\t\t\tos.Exit(1)\n   349→\t\t}\n   350→\n   351→\t\tswitch entry.Type {\n   352→\t\tcase \"step_started\":\n   353→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   354→\t\t\tif entry.Message != \"\" {\n   355→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   356→\t\t\t}\n   357→\t\tcase \"step_completed\":\n   358→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   359→\t\t\tif entry.Message != \"\" {\n   360→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   361→\t\t\t}\n   362→\t\tcase \"run_completed\":\n   363→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   364→\t\t\tif entry.Message != \"\" {\n   365→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   366→\t\t\t}\n   367→\t\tcase \"full_log\":\n   368→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   369→\t\tcase \"log\":\n   370→\t\t\t// Live-streamed log line from an active run.\n   371→\t\t\tfmt.Println(entry.Message)\n   372→\t\tdefault:\n   373→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   374→\t\t\tif entry.StepName != \"\" {\n   375→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   376→\t\t\t}\n   377→\t\t\tif entry.Message != \"\" {\n   378→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   379→\t\t\t}\n   380→\t\t}\n   381→\t}\n   382→}\n   383→\n   384→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   385→\tif len(args) < 1 {\n   386→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   387→\t\tos.Exit(1)\n   388→\t}\n   389→\n   390→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   391→\tif err != nil {\n   392→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   393→\t\tos.Exit(1)\n   394→\t}\n   395→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   396→}\n   397→\n   398→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   399→\tif len(args) < 1 {\n   400→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   401→\t\tos.Exit(1)\n   402→\t}\n   403→\n   404→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   405→\tif err != nil {\n   406→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   407→\t\tos.Exit(1)\n   408→\t}\n   409→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   410→}\n   411→\n   412→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   413→\tcwd, _ := os.Getwd()\n   414→\n   415→\t// Check for \"stop\" subcommand\n   416→\tif len(args) > 0 && args[0] == \"stop\" {\n   417→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   418→\t\tif err != nil {\n   419→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   420→\t\t\tos.Exit(1)\n   421→\t\t}\n   422→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   423→\t\treturn\n   424→\t}\n   425→\n   426→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   427→\tvar maxConcurrent int32\n   428→\tfor i := 0; i < len(args); i++ {\n   429→\t\tswitch args[i] {\n   430→\t\tcase \"--max\":\n   431→\t\t\tif i+1 < len(args) {\n   432→\t\t\t\ti++\n   433→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   434→\t\t\t\tif n != 1 || err != nil {\n   435→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   436→\t\t\t\t\tos.Exit(1)\n   437→\t\t\t\t}\n   438→\t\t\t}\n   439→\t\t}\n   440→\t}\n   441→\n   442→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   443→\t\tProjectDir:    cwd,\n   444→\t\tMaxConcurrent: maxConcurrent,\n   445→\t})\n   446→\tif err != nil {\n   447→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   448→\t\tos.Exit(1)\n   449→\t}\n   450→\tif maxConcurrent > 0 {\n   451→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   452→\t} else {\n   453→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   454→\t}\n   455→}\n   456→\n   457→func cmdTasks(args []string) {\n   458→\t// Determine HTTP address from env\n   459→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   460→\tif httpAddr == \"\" {\n   461→\t\thttpAddr = \"localhost:8080\"\n   462→\t}\n   463→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   464→\n   465→\t// Determine project label from --project flag or current directory\n   466→\tprojectDir := \"\"\n   467→\tfor i := 0; i < len(args); i++ {\n   468→\t\tswitch args[i] {\n   469→\t\tcase \"--project\":\n   470→\t\t\tif i+1 < len(args) {\n   471→\t\t\t\ti++\n   472→\t\t\t\tprojectDir = args[i]\n   473→\t\t\t}\n   474→\t\t}\n   475→\t}\n   476→\n   477→\tif projectDir == \"\" {\n   478→\t\tcwd, _ := os.Getwd()\n   479→\t\tprojectDir = filepath.Base(cwd)\n   480→\t}\n   481→\n   482→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   483→\tresp, err := http.Get(tasksURL)\n   484→\tif err != nil {\n   485→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   486→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   487→\t\tos.Exit(1)\n   488→\t}\n   489→\tdefer resp.Body.Close()\n   490→\n   491→\tif resp.StatusCode != 200 {\n   492→\t\tbody, _ := io.ReadAll(resp.Body)\n   493→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   494→\t\tos.Exit(1)\n   495→\t}\n   496→\n   497→\ttype taskEntry struct {\n   498→\t\tID          string `json:\"id\"`\n   499→\t\tStatus      string `json:\"status\"`\n   500→\t\tTitle       string `json:\"title\"`\n   501→\t\tDescription string `json:\"description\"`\n   502→\t\tAssigned    bool   `json:\"assigned\"`\n   503→\t\tAssignedAt  string `json:\"assigned_at\"`\n   504→\t\tRunID       string `json:\"run_id\"`\n   505→\t}\n   506→\n   507→\tvar tasks []taskEntry\n   508→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   509→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   510→\t\tos.Exit(1)\n   511→\t}\n   512→\n   513→\tif len(tasks) == 0 {\n   514→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   515→\t\treturn\n   516→\t}\n   517→\n   518→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   519→\tfor _, t := range tasks {\n   520→\t\tstatus := t.Status\n   521→\t\tif status == 