{\n   578→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   579→\t\tos.Exit(1)\n   580→\t}\n   581→\n   582→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   583→\tif err != nil {\n   584→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   585→\t\tos.Exit(1)\n   586→\t}\n   587→\tif !ok {\n   588→\t\tos.Exit(1)\n   589→\t}\n   590→\tfmt.Println(val)\n   591→}\n   592→\n   593→func cmdSet(args []string) {\n   594→\tif len(args) < 2 {\n   595→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   596→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   597→\t\tos.Exit(1)\n   598→\t}\n   599→\n   600→\tprojectDir, runID, err := resolveRunContext()\n   601→\tif err != nil {\n   602→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   603→\t\tos.Exit(1)\n   604→\t}\n   605→\n   606→\tvalue := args[1]\n   607→\tif value == \"-\" {\n   608→\t\tdata, err := io.ReadAll(os.Stdin)\n   609→\t\tif err != nil {\n   610→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   611→\t\t\tos.Exit(1)\n   612→\t\t}\n   613→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   614→\t}\n   615→\n   616→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   617→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   618→\t\tos.Exit(1)\n   619→\t}\n   620→}\n   621→"}]},"parent_tool_use_id":"toolu_01R6FyHX8ezBGpk4fQZXf4qj","session_id":"c0b250b2-f9c5-4d6e-a2b5-21933ebd9c8c","uuid":"6b705ac5-a33f-43d0-be49-739977422d3c"}
