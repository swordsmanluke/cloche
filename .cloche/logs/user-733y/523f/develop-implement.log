{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Lofv6hXwXdMEecsdu3jUVK","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"strings\"\n    11→\t\"time\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    17→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    19→\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    20→)\n    21→\n    22→// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    23→// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    24→// strings suitable for adding to a command's environment.\n    25→func (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    26→\tvar env []string\n    27→\tfor _, w := range wires {\n    28→\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    29→\t\t\tcontinue\n    30→\t\t}\n    31→\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    32→\t\tif err != nil {\n    33→\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    34→\t\t}\n    35→\t\tfor _, m := range w.OutputMap {\n    36→\t\t\tval, err := m.Path.Evaluate(data)\n    37→\t\t\tif err != nil {\n    38→\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    39→\t\t\t}\n    40→\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    41→\t\t}\n    42→\t}\n    43→\treturn env, nil\n    44→}\n    45→\n    46→// RunDispatcher dispatches a container workflow run and returns the run ID.\n    47→type RunDispatcher interface {\n    48→\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    49→}\n    50→\n    51→// Executor implements engine.StepExecutor for host workflow steps.\n    52→type Executor struct {\n    53→\tProjectDir    string\n    54→\tMainDir       string         // main branch worktree dir; scripts execute from here\n    55→\tDispatcher    RunDispatcher\n    56→\tStore         ports.RunStore\n    57→\tOutputDir     string         // directory for step output files\n    58→\tWires         []domain.Wire  // workflow wiring (for output mappings)\n    59→\tHostRunID     string         // ID of the parent host run (set on child runs)\n    60→\tAgentCommands []string       // workflow-level agent command fallback chain\n    61→\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n    62→\tTaskID        string         // optional task ID assigned by the daemon loop\n    63→\tExtraEnv      []string       // additional KEY=VALUE env vars for all steps\n    64→}\n    65→\n    66→// scriptDir returns the directory from which scripts should execute.\n    67→// Uses MainDir if set, otherwise falls back to ProjectDir.\n    68→func (e *Executor) scriptDir() string {\n    69→\tif e.MainDir != \"\" {\n    70→\t\treturn e.MainDir\n    71→\t}\n    72→\treturn e.ProjectDir\n    73→}\n    74→\n    75→var _ engine.StepExecutor = (*Executor)(nil)\n    76→\n    77→// Execute runs a single host workflow step.\n    78→func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    79→\tswitch step.Type {\n    80→\tcase domain.StepTypeScript:\n    81→\t\treturn e.executeScript(ctx, step)\n    82→\tcase domain.StepTypeWorkflow:\n    83→\t\treturn e.executeWorkflow(ctx, step)\n    84→\tcase domain.StepTypeAgent:\n    85→\t\treturn e.executeAgent(ctx, step)\n    86→\tdefault:\n    87→\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    88→\t}\n    89→}\n    90→\n    91→// executeScript runs a shell command on the host.\n    92→func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    93→\tcmdStr := step.Config[\"run\"]\n    94→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    95→\tcmd.Dir = e.scriptDir()\n    96→\tcmd.Env = append(os.Environ(),\n    97→\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    98→\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    99→\t)\n   100→\n   101→\t// Pass run ID so steps can access .cloche/<run-id>/ and context.json\n   102→\tif e.HostRunID != \"\" {\n   103→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_RUN_ID=\"+e.HostRunID)\n   104→\t}\n   105→\n   106→\t// Pass daemon-assigned task ID if available\n   107→\tif e.TaskID != \"\" {\n   108→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_TASK_ID=\"+e.TaskID)\n   109→\t}\n   110→\n   111→\t// Pass extra env vars (e.g. finalize phase outcome vars)\n   112→\tif len(e.ExtraEnv) > 0 {\n   113→\t\tcmd.Env = append(cmd.Env, e.ExtraEnv...)\n   114→\t}\n   115→\n   116→\t// Pass previous step output if available\n   117→\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n   118→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n   119→\t}\n   120→\n   121→\t// Resolve output mappings from wires and add as env vars\n   122→\tif len(e.Wires) > 0 {\n   123→\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n   124→\t\tif err != nil {\n   125→\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n   126→\t\t}\n   127→\t\tcmd.Env = append(cmd.Env, mapped...)\n   128→\t}\n   129→\n   130→\toutput, err := cmd.CombinedOutput()\n   131→\n   132→\t// Extract result marker\n   133→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n   134→\n   135→\t// Write output to file\n   136→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   137→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   138→\t}\n   139→\n   140→\tif err != nil {\n   141→\t\tif _, ok := err.(*exec.ExitError); ok {\n   142→\t\t\tresult := \"fail\"\n   143→\t\t\tif found {\n   144→\t\t\t\tresult = markerResult\n   145→\t\t\t}\n   146→\t\t\treturn result, nil\n   147→\t\t}\n   148→\t\treturn \"\", err\n   149→\t}\n   150→\n   151→\tresult := \"success\"\n   152→\tif found {\n   153→\t\tresult = markerResult\n   154→\t}\n   155→\treturn result, nil\n   156→}\n   157→\n   158→// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   159→func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   160→\tworkflowName := step.Config[\"workflow_name\"]\n   161→\tif workflowName == \"\" {\n   162→\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   163→\t}\n   164→\n   165→\t// Read prompt from previous step output or prompt_step override\n   166→\tvar promptContent string\n   167→\tpromptSource := step.Config[\"prompt_step\"]\n   168→\tif promptSource != \"\" {\n   169→\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   170→\t\tif err == nil {\n   171→\t\t\tpromptContent = string(data)\n   172→\t\t}\n   173→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   174→\t\tdata, err := os.ReadFile(prev)\n   175→\t\tif err == nil {\n   176→\t\t\tpromptContent = string(data)\n   177→\t\t}\n   178→\t}\n   179→\n   180→\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   181→\t\tWorkflowName: workflowName,\n   182→\t\tProjectDir:   e.ProjectDir,\n   183→\t\tPrompt:       promptContent,\n   184→\t})\n   185→\tif err != nil {\n   186→\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   187→\t}\n   188→\n   189→\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   190→\n   191→\t// Link child run to parent host run and store in run context\n   192→\tif e.HostRunID != \"\" {\n   193→\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n   194→\t\t\tchildRun.ParentRunID = e.HostRunID\n   195→\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n   196→\t\t}\n   197→\t\t// Store child run ID in context so downstream steps can retrieve it\n   198→\t\t// via \"cloche get child_run_id\"\n   199→\t\t_ = runcontext.Set(e.ProjectDir, e.HostRunID, \"child_run_id\", resp.RunId)\n   200→\t}\n   201→\n   202→\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n   203→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   204→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n   205→\t}\n   206→\n   207→\t// Poll until the run reaches a terminal state\n   208→\tstate, err := e.waitForRun(ctx, resp.RunId)\n   209→\tif err != nil {\n   210→\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   211→\t}\n   212→\n   213→\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   214→\n   215→\t// Map run state to step result\n   216→\tif state == domain.RunStateSucceeded {\n   217→\t\treturn \"success\", nil\n   218→\t}\n   219→\treturn \"fail\", nil\n   220→}\n   221→\n   222→// executeAgent runs an agent command on the host using the prompt adapter.\n   223→func (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n   224→\tadapter := prompt.New()\n   225→\n   226→\t// Apply workflow-level agent config\n   227→\tif len(e.AgentCommands) > 0 {\n   228→\t\tadapter.Commands = e.AgentCommands\n   229→\t}\n   230→\tif len(e.AgentArgs) > 0 {\n   231→\t\tadapter.ExplicitArgs = e.AgentArgs\n   232→\t}\n   233→\n   234→\t// Step-level overrides\n   235→\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   236→\t\tadapter.Commands = prompt.ParseCommands(cmd)\n   237→\t}\n   238→\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   239→\t\tadapter.ExplicitArgs = strings.Fields(args)\n   240→\t}\n   241→\n   242→\tadapter.RunID = e.HostRunID\n   243→\n   244→\t// Write previous step output as user prompt so the adapter can pick it up.\n   245→\tvar promptContent string\n   246→\tpromptSource := step.Config[\"prompt_step\"]\n   247→\tif promptSource != \"\" {\n   248→\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n   249→\t\t\tpromptContent = string(data)\n   250→\t\t}\n   251→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   252→\t\tif data, err := os.ReadFile(prev); err == nil {\n   253→\t\t\tpromptContent = string(data)\n   254→\t\t}\n   255→\t}\n   256→\n   257→\tif promptContent != \"\" {\n   258→\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n   259→\t\t_ = os.MkdirAll(promptDir, 0755)\n   260→\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n   261→\t}\n   262→\n   263→\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n   264→\tif err != nil {\n   265→\t\treturn \"\", err\n   266→\t}\n   267→\n   268→\t// Copy output from adapter's output location to executor's output path\n   269→\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n   270→\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n   271→\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   272→\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n   273→\t\t}\n   274→\t}\n   275→\n   276→\treturn result, nil\n   277→}\n   278→\n   279→// waitForRun polls the store until the run reaches a terminal state.\n   280→func (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   281→\tticker := time.NewTicker(2 * time.Second)\n   282→\tdefer ticker.Stop()\n   283→\n   284→\tfor {\n   285→\t\tselect {\n   286→\t\tcase <-ctx.Done():\n   287→\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   288→\t\tcase <-ticker.C:\n   289→\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   290→\t\t\tif err != nil {\n   291→\t\t\t\tcontinue // transient error, retry\n   292→\t\t\t}\n   293→\t\t\tswitch run.State {\n   294→\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   295→\t\t\t\treturn run.State, nil\n   296→\t\t\t}\n   297→\t\t\t// Still pending or running, continue polling\n   298→\t\t}\n   299→\t}\n   300→}\n   301→\n   302→// stepOutputPath returns the path for a step's output file.\n   303→func (e *Executor) stepOutputPath(stepName string) string {\n   304→\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   305→}\n   306→\n   307→// findPrevOutput finds the output file from the step that wires into this one.\n   308→// It checks prompt_step config first, then walks the wiring graph to find the\n   309→// source step.\n   310→func (e *Executor) findPrevOutput(step *domain.Step) string {\n   311→\t// Explicit prompt_step config takes priority\n   312→\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   313→\t\tpath := e.stepOutputPath(ps)\n   314→\t\tif _, err := os.Stat(path); err == nil {\n   315→\t\t\treturn path\n   316→\t\t}\n   317→\t}\n   318→\n   319→\t// Walk wiring to find the step that feeds into this one\n   320→\tfor _, w := range e.Wires {\n   321→\t\tif w.To == step.Name {\n   322→\t\t\tpath := e.stepOutputPath(w.From)\n   323→\t\t\tif _, err := os.Stat(path); err == nil {\n   324→\t\t\t\treturn path\n   325→\t\t\t}\n   326→\t\t}\n   327→\t}\n   328→\treturn \"\"\n   329→}\n   330→\n   331→// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n   332→// the repository containing projectDir. If projectDir is already the main\n   333→// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n   334→// error (e.g. not a git repo).\n   335→func MainWorktreeDir(projectDir string) string {\n   336→\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n   337→\tout, err := cmd.Output()\n   338→\tif err != nil {\n   339→\t\treturn projectDir\n   340→\t}\n   341→\t// The first \"worktree <path>\" line is always the main worktree.\n   342→\tfor _, line := range strings.Split(string(out), \"\\n\") {\n   343→\t\tif strings.HasPrefix(line, \"worktree \") {\n   344→\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n   345→\t\t}\n   346→\t}\n   347→\treturn projectDir\n   348→}\n   349→"}]},"parent_tool_use_id":"toolu_015cqseuXNh5gHzEE8aAWQ9G","session_id":"4b95ef25-6022-40da-aa37-3e792f54f08f","uuid":"f6fafa33-0944-48ad-9a72-55a706866c1b"}
