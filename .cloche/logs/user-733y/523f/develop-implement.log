{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0135rcqHshPFGnjLcdRDus5y","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"net\"\n     7→\t\"net/http\"\n     8→\t\"os\"\n     9→\t\"os/signal\"\n    10→\t\"path/filepath\"\n    11→\t\"syscall\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    15→\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    16→\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    19→\t\"github.com/cloche-dev/cloche/internal/config\"\n    20→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    21→\thostpkg \"github.com/cloche-dev/cloche/internal/host\"\n    22→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    23→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    24→\t\"google.golang.org/grpc\"\n    25→)\n    26→\n    27→func main() {\n    28→\t// Load global config file (~/.config/cloche/config)\n    29→\tglobalCfg, err := config.LoadGlobal()\n    30→\tif err != nil {\n    31→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n    32→\t\tdefaults := config.Config{}\n    33→\t\tglobalCfg = &defaults\n    34→\t}\n    35→\n    36→\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, \"cloche.db\")\n    37→\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, \"unix:///tmp/cloche.sock\")\n    38→\n    39→\tstore, err := sqlite.NewStore(dbPath)\n    40→\tif err != nil {\n    41→\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    42→\t\tos.Exit(1)\n    43→\t}\n    44→\tdefer store.Close()\n    45→\n    46→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    47→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    48→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    49→\t} else if n > 0 {\n    50→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    51→\t}\n    52→\n    53→\truntime, err := initRuntime(globalCfg)\n    54→\tif err != nil {\n    55→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    56→\t\tos.Exit(1)\n    57→\t}\n    58→\n    59→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    60→\n    61→\tbroadcaster := logstream.NewBroadcaster()\n    62→\n    63→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    64→\tsrv.SetLogStore(store)\n    65→\tsrv.SetLogBroadcaster(broadcaster)\n    66→\n    67→\t// Set up evolution trigger\n    68→\tevoTrigger := initEvolution(globalCfg, store, store)\n    69→\tif evoTrigger != nil {\n    70→\t\tsrv.SetEvolution(evoTrigger)\n    71→\t}\n    72→\n    73→\tgrpcServer := grpc.NewServer()\n    74→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    75→\n    76→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    77→\n    78→\tlis, err := listen(listenAddr)\n    79→\tif err != nil {\n    80→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    81→\t\tos.Exit(1)\n    82→\t}\n    83→\n    84→\tvar httpServer *http.Server\n    85→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n    86→\t\twebOpts := []web.HandlerOption{\n    87→\t\t\tweb.WithContainerLogger(runtime),\n    88→\t\t\tweb.WithLogStore(store),\n    89→\t\t\tweb.WithLogBroadcaster(broadcaster),\n    90→\t\t\tweb.WithTaskProvider(srv),\n    91→\t\t}\n    92→\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n    93→\t\tif err != nil {\n    94→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n    95→\t\t\tos.Exit(1)\n    96→\t\t}\n    97→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n    98→\t\tgo func() {\n    99→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   100→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   101→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   102→\t\t\t}\n   103→\t\t}()\n   104→\t}\n   105→\n   106→\t// Auto-execute main workflow for active projects\n   107→\tautoRunActiveProjects(store, srv)\n   108→\n   109→\tsigCh := make(chan os.Signal, 1)\n   110→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   111→\tgo func() {\n   112→\t\t<-sigCh\n   113→\t\tif httpServer != nil {\n   114→\t\t\thttpServer.Close()\n   115→\t\t}\n   116→\t\tgrpcServer.GracefulStop()\n   117→\t}()\n   118→\n   119→\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   120→\tif err := grpcServer.Serve(lis); err != nil {\n   121→\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   122→\t\tos.Exit(1)\n   123→\t}\n   124→}\n   125→\n   126→func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   127→\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   128→\n   129→\tswitch runtimeType {\n   130→\tcase \"local\":\n   131→\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   132→\t\tif agentPath == \"\" {\n   133→\t\t\t// Look for cloche-agent next to this binary\n   134→\t\t\texe, err := os.Executable()\n   135→\t\t\tif err == nil {\n   136→\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   137→\t\t\t} else {\n   138→\t\t\t\tagentPath = \"cloche-agent\"\n   139→\t\t\t}\n   140→\t\t}\n   141→\t\treturn local.NewRuntime(agentPath), nil\n   142→\tcase \"docker\":\n   143→\t\treturn docker.NewRuntime()\n   144→\tdefault:\n   145→\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   146→\t}\n   147→}\n   148→\n   149→func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   150→\t// Load config from working directory (daemon-level defaults)\n   151→\tcfg, err := config.Load(\".\")\n   152→\tif err != nil || !cfg.Evolution.Enabled {\n   153→\t\treturn nil\n   154→\t}\n   155→\n   156→\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   157→\tif llmCmd == \"\" {\n   158→\t\treturn nil\n   159→\t}\n   160→\n   161→\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   162→\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   163→\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   164→\t\t\t// Load per-project config for confidence threshold\n   165→\t\t\tprojCfg, err := config.Load(projectDir)\n   166→\t\t\tif err != nil {\n   167→\t\t\t\tprojCfg = cfg // fall back to daemon config\n   168→\t\t\t}\n   169→\n   170→\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   171→\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   172→\t\t\t\tProjectDir:    projectDir,\n   173→\t\t\t\tWorkflowName:  workflowName,\n   174→\t\t\t\tLLM:           llm,\n   175→\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   176→\t\t\t})\n   177→\n   178→\t\t\tctx := context.Background()\n   179→\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   180→\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   181→\t\t\t}\n   182→\t\t},\n   183→\t})\n   184→\n   185→\treturn trigger\n   186→}\n   187→\n   188→func listen(addr string) (net.Listener, error) {\n   189→\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   190→\t\tsockPath := addr[7:]\n   191→\t\tos.Remove(sockPath)\n   192→\t\treturn net.Listen(\"unix\", sockPath)\n   193→\t}\n   194→\treturn net.Listen(\"tcp\", addr)\n   195→}\n   196→\n   197→// autoRunActiveProjects scans known projects for active = true in their config,\n   198→// parses .cloche/host.cloche and executes the full host workflow step by step.\n   199→func autoRunActiveProjects(store ports.RunStore, srv *adaptgrpc.ClocheServer) {\n   200→\tctx := context.Background()\n   201→\tprojects, err := store.ListProjects(ctx)\n   202→\tif err != nil {\n   203→\t\tfmt.Fprintf(os.Stderr, \"startup: failed to list projects: %v\\n\", err)\n   204→\t\treturn\n   205→\t}\n   206→\n   207→\tfor _, projectDir := range projects {\n   208→\t\tcfg, err := config.Load(projectDir)\n   209→\t\tif err != nil || !cfg.Active {\n   210→\t\t\tcontinue\n   211→\t\t}\n   212→\n   213→\t\t// Verify host.cloche exists before launching\n   214→\t\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   215→\t\tif _, err := os.Stat(hostPath); err != nil {\n   216→\t\t\tfmt.Fprintf(os.Stderr, \"startup: skipping active project %s: %v\\n\", projectDir, err)\n   217→\t\t\tcontinue\n   218→\t\t}\n   219→\n   220→\t\tfmt.Fprintf(os.Stderr, \"startup: auto-running host workflow for active project %s\\n\", projectDir)\n   221→\t\tgo func(projDir string) {\n   222→\t\t\trunner := &hostpkg.Runner{\n   223→\t\t\t\tDispatcher: srv,\n   224→\t\t\t\tStore:      store,\n   225→\t\t\t}\n   226→\t\t\tresult, err := runner.Run(context.Background(), projDir)\n   227→\t\t\tif err != nil {\n   228→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow failed for %s: %v\\n\", projDir, err)\n   229→\t\t\t} else {\n   230→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow completed for %s: %s (run %s)\\n\", projDir, result.State, result.RunID)\n   231→\t\t\t}\n   232→\t\t}(projectDir)\n   233→\t}\n   234→}\n   235→\n   236→// envOrConfig returns the env var value if set, otherwise the config file\n   237→// value if non-empty, otherwise the fallback default.\n   238→func envOrConfig(envKey, configVal, fallback string) string {\n   239→\tif v := os.Getenv(envKey); v != \"\" {\n   240→\t\treturn v\n   241→\t}\n   242→\tif configVal != \"\" {\n   243→\t\treturn configVal\n   244→\t}\n   245→\treturn fallback\n   246→}\n   247→"}]},"parent_tool_use_id":"toolu_015cqseuXNh5gHzEE8aAWQ9G","session_id":"4b95ef25-6022-40da-aa37-3e792f54f08f","uuid":"29e256ae-c94e-4904-887d-8404080a2b4c"}
