{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ly6bPmS2ERHjBKitCJwwUS","type":"tool_result","content":"     1→package prompt\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"bytes\"\n     6→\t\"context\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strconv\"\n    13→\t\"strings\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17→)\n    18→\n    19→// defaultAgentArgs maps known agent commands to their default arguments.\n    20→// Commands not in this map receive no default arguments (prompt on stdin only).\n    21→var defaultAgentArgs = map[string][]string{\n    22→\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n    23→}\n    24→\n    25→type Adapter struct {\n    26→\tCommands     []string // ordered fallback chain of agent commands\n    27→\tExplicitArgs []string // if non-nil, overrides default args for all commands\n    28→\tRunID        string\n    29→\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n    30→}\n    31→\n    32→func New() *Adapter {\n    33→\treturn &Adapter{\n    34→\t\tCommands: []string{\"claude\"},\n    35→\t}\n    36→}\n    37→\n    38→func (a *Adapter) Name() string {\n    39→\treturn \"prompt\"\n    40→}\n    41→\n    42→// argsFor returns the arguments for the given command. If ExplicitArgs is set,\n    43→// it is used for all commands. Otherwise, known agents get their default args.\n    44→func (a *Adapter) argsFor(command string) []string {\n    45→\tif a.ExplicitArgs != nil {\n    46→\t\treturn a.ExplicitArgs\n    47→\t}\n    48→\tif args, ok := defaultAgentArgs[command]; ok {\n    49→\t\treturn args\n    50→\t}\n    51→\treturn nil\n    52→}\n    53→\n    54→// ParseCommands splits a comma-separated agent_command string into individual\n    55→// command names, trimming whitespace from each entry.\n    56→func ParseCommands(s string) []string {\n    57→\tparts := strings.Split(s, \",\")\n    58→\tvar cmds []string\n    59→\tfor _, p := range parts {\n    60→\t\tp = strings.TrimSpace(p)\n    61→\t\tif p != \"\" {\n    62→\t\t\tcmds = append(cmds, p)\n    63→\t\t}\n    64→\t}\n    65→\treturn cmds\n    66→}\n    67→\n    68→func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    69→\t// Check attempt count for retry limiting\n    70→\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n    71→\t\tmax, err := strconv.Atoi(maxStr)\n    72→\t\tif err == nil {\n    73→\t\t\tcount := readAttemptCount(workDir, step.Name)\n    74→\t\t\tif count >= max {\n    75→\t\t\t\treturn \"give-up\", nil\n    76→\t\t\t}\n    77→\t\t}\n    78→\t}\n    79→\tincrementAttemptCount(workDir, step.Name)\n    80→\n    81→\t// Build the full prompt\n    82→\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n    83→\tif err != nil {\n    84→\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n    85→\t}\n    86→\n    87→\t// Try each command in the fallback chain\n    88→\tvar lastResult string\n    89→\tvar lastStdout []byte\n    90→\tvar lastErr error\n    91→\tran := false\n    92→\n    93→\tfor _, command := range a.Commands {\n    94→\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n    95→\t\tlastResult = result\n    96→\t\tlastStdout = stdout\n    97→\t\tlastErr = fallbackErr\n    98→\n    99→\t\tif fallbackErr == nil {\n   100→\t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n   101→\t\t\tbreak\n   102→\t\t}\n   103→\t\tif stdout != nil {\n   104→\t\t\tran = true\n   105→\t\t}\n   106→\t\t// Fallback-eligible — try next command\n   107→\t}\n   108→\n   109→\tif lastErr != nil && !ran && lastStdout == nil {\n   110→\t\t// All commands failed to produce any output (e.g., all not found)\n   111→\t\treturn \"\", lastErr\n   112→\t}\n   113→\n   114→\tresult := lastResult\n   115→\tif lastErr != nil {\n   116→\t\t// Last command in chain crashed without a result marker\n   117→\t\tresult = \"fail\"\n   118→\t}\n   119→\n   120→\t// Write output file\n   121→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   122→\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n   123→\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n   124→\t}\n   125→\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n   126→\treturn result, nil\n   127→}\n   128→\n   129→// tryCommand executes a single agent command and returns:\n   130→//   - result: the step result name (e.g. \"success\", \"fail\")\n   131→//   - stdout: captured stdout bytes\n   132→//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n   133→//\n   134→// Fallback-eligible conditions:\n   135→//   - Command not found or failed to start (stdout will be nil)\n   136→//   - Command exited non-zero without a CLOCHE_RESULT marker\n   137→//\n   138→// Definitive (non-fallback) conditions:\n   139→//   - Command exited 0\n   140→//   - Command exited non-zero but produced a CLOCHE_RESULT marker\n   141→func (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n   142→\targs := a.argsFor(command)\n   143→\tcmd := exec.CommandContext(ctx, command, args...)\n   144→\tcmd.Dir = workDir\n   145→\tcmd.Stdin = strings.NewReader(prompt)\n   146→\n   147→\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n   148→\tif a.StatusWriter == nil {\n   149→\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n   150→\t\tcmd.Stdout = &stdoutBuf\n   151→\t\tcmd.Stderr = &stderrBuf\n   152→\n   153→\t\trunErr := cmd.Run()\n   154→\t\tstdoutBytes := stdoutBuf.Bytes()\n   155→\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n   156→\t}\n   157→\n   158→\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n   159→\tpipe, err := cmd.StdoutPipe()\n   160→\tif err != nil {\n   161→\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n   162→\t}\n   163→\tcmd.Stderr = nil // discard stderr\n   164→\n   165→\tif err := cmd.Start(); err != nil {\n   166→\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n   167→\t}\n   168→\n   169→\t// textBuf accumulates extracted text content for result extraction.\n   170→\t// rawBuf accumulates raw stdout for the output log file.\n   171→\tvar textBuf, rawBuf bytes.Buffer\n   172→\t// lineBuf accumulates text deltas into lines for streaming.\n   173→\tvar lineBuf strings.Builder\n   174→\n   175→\tscanner := bufio.NewScanner(pipe)\n   176→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n   177→\tfor scanner.Scan() {\n   178→\t\traw := scanner.Bytes()\n   179→\t\trawBuf.Write(raw)\n   180→\t\trawBuf.WriteByte('\\n')\n   181→\n   182→\t\ttext := extractStreamText(raw)\n   183→\t\tif text == \"\" {\n   184→\t\t\tcontinue\n   185→\t\t}\n   186→\t\ttextBuf.WriteString(text)\n   187→\n   188→\t\t// Stream complete lines to StatusWriter as they form.\n   189→\t\tlineBuf.WriteString(text)\n   190→\t\tfor {\n   191→\t\t\ts := lineBuf.String()\n   192→\t\t\tidx := strings.IndexByte(s, '\\n')\n   193→\t\t\tif idx < 0 {\n   194→\t\t\t\tbreak\n   195→\t\t\t}\n   196→\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n   197→\t\t\tlineBuf.Reset()\n   198→\t\t\tlineBuf.WriteString(s[idx+1:])\n   199→\t\t}\n   200→\t}\n   201→\t// Flush any remaining partial line.\n   202→\tif lineBuf.Len() > 0 {\n   203→\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n   204→\t}\n   205→\tif scanErr := scanner.Err(); scanErr != nil {\n   206→\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n   207→\t}\n   208→\n   209→\twaitErr := cmd.Wait()\n   210→\t// Prefer extracted text (stream-json) for result classification; fall back\n   211→\t// to raw output for non-JSON commands (scripts, non-claude agents).\n   212→\tclassifyBuf := textBuf.Bytes()\n   213→\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n   214→\t\tclassifyBuf = rawBuf.Bytes()\n   215→\t}\n   216→\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n   217→\treturn result, rawBuf.Bytes(), fallbackErr\n   218→}\n   219→\n   220→// classifyResult interprets the command's exit status and stdout to determine\n   221→// the step result.\n   222→func (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n   223→\tif runErr != nil {\n   224→\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n   225→\t\t\t// Command failed to start (not found, permission denied, etc.)\n   226→\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n   227→\t\t}\n   228→\t\t// Command ran but exited non-zero\n   229→\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   230→\t\tif found {\n   231→\t\t\treturn markerResult, stdoutBytes, nil\n   232→\t\t}\n   233→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n   234→\t}\n   235→\n   236→\t// Command succeeded (exit 0)\n   237→\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n   238→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n   239→\t}\n   240→\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   241→\tresult := \"success\"\n   242→\tif found {\n   243→\t\tresult = markerResult\n   244→\t}\n   245→\treturn result, stdoutBytes, nil\n   246→}\n   247→\n   248→// extractStreamText parses a stream-json line and returns text content.\n   249→// It handles both content_block_delta (text_delta) events for streaming and\n   250→// result events for final output (which contains the CLOCHE_RESULT marker).\n   251→func extractStreamText(line []byte) string {\n   252→\t// Fast path: only parse lines that could contain text we care about.\n   253→\tif bytes.Contains(line, []byte(`\"text_delta\"`)) {\n   254→\t\tvar event struct {\n   255→\t\t\tType  string `json:\"type\"`\n   256→\t\t\tDelta struct {\n   257→\t\t\t\tType string `json:\"type\"`\n   258→\t\t\t\tText string `json:\"text\"`\n   259→\t\t\t} `json:\"delta\"`\n   260→\t\t}\n   261→\t\tif json.Unmarshal(line, &event) == nil &&\n   262→\t\t\tevent.Type == \"content_block_delta\" && event.Delta.Type == \"text_delta\" {\n   263→\t\t\treturn event.Delta.Text\n   264→\t\t}\n   265→\t}\n   266→\n   267→\t// Also extract the final result text (contains CLOCHE_RESULT marker).\n   268→\tif bytes.Contains(line, []byte(`\"result\"`)) && bytes.Contains(line, []byte(`\"subtype\"`)) {\n   269→\t\tvar event struct {\n   270→\t\t\tType   string `json:\"type\"`\n   271→\t\t\tResult string `json:\"result\"`\n   272→\t\t}\n   273→\t\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n   274→\t\t\treturn event.Result\n   275→\t\t}\n   276→\t}\n   277→\n   278→\treturn \"\"\n   279→}\n   280→\n   281→func assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n   282→\tvar parts []string\n   283→\n   284→\t// 1. Read system template from step config\n   285→\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n   286→\t\tcontent, err := resolveContent(tmpl, workDir)\n   287→\t\tif err != nil {\n   288→\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n   289→\t\t}\n   290→\t\tparts = append(parts, content)\n   291→\t}\n   292→\n   293→\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n   294→\tuserPrompt := readUserPrompt(workDir, runID)\n   295→\tif userPrompt != \"\" {\n   296→\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n   297→\t}\n   298→\n   299→\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n   300→\tif step.Config[\"feedback\"] == \"true\" {\n   301→\t\tfeedback := readFeedback(workDir)\n   302→\t\tif feedback != \"\" {\n   303→\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n   304→\t\t}\n   305→\t}\n   306→\n   307→\t// 4. Result selection instructions\n   308→\tif len(step.Results) > 0 {\n   309→\t\tvar resultLines []string\n   310→\t\tresultLines = append(resultLines, \"## Result Selection\")\n   311→\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n   312→\t\tfor _, r := range step.Results {\n   313→\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n   314→\t\t}\n   315→\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n   316→\t}\n   317→\n   318→\treturn strings.Join(parts, \"\\n\\n\"), nil\n   319→}\n   320→\n   321→// resolveContent handles file(\"path\") syntax or returns the string directly.\n   322→func resolveContent(value string, workDir string) (string, error) {\n   323→\t// Check for file(\"path\") syntax from DSL parser\n   324→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n   325→\t\tpath := value[6 : len(value)-2]\n   326→\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n   327→\t\tif err != nil {\n   328→\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n   329→\t\t}\n   330→\t\treturn string(data), nil\n   331→\t}\n   332→\treturn value, nil\n   333→}\n   334→\n   335→func readFeedback(workDir string) string {\n   336→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   337→\tentries, err := os.ReadDir(outputDir)\n   338→\tif err != nil {\n   339→\t\treturn \"\"\n   340→\t}\n   341→\n   342→\tvar parts []string\n   343→\tfor _, entry := range entries {\n   344→\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n   345→\t\t\tcontinue\n   346→\t\t}\n   347→\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n   348→\t\tif err != nil {\n   349→\t\t\tcontinue\n   350→\t\t}\n   351→\t\tcontent := strings.TrimSpace(string(data))\n   352→\t\tif content != \"\" {\n   353→\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n   354→\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n   355→\t\t}\n   356→\t}\n   357→\n   358→\treturn strings.Join(parts, \"\\n\\n\")\n   359→}\n   360→\n   361→func readAttemptCount(workDir, stepName string) int {\n   362→\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n   363→\tdata, err := os.ReadFile(path)\n   364→\tif err != nil {\n   365→\t\treturn 0\n   366→\t}\n   367→\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n   368→\treturn n\n   369→}\n   370→\n   371→// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\n   372→func readUserPrompt(workDir, runID string) string {\n   373→\tif runID == \"\" {\n   374→\t\treturn \"\"\n   375→\t}\n   376→\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   377→\tif data, err := os.ReadFile(path); err == nil {\n   378→\t\treturn string(data)\n   379→\t}\n   380→\treturn \"\"\n   381→}\n   382→\n   383→func incrementAttemptCount(workDir, stepName string) {\n   384→\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n   385→\t_ = os.MkdirAll(dir, 0755)\n   386→\tcount := readAttemptCount(workDir, stepName) + 1\n   387→\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n   388→}\n   389→"}]},"parent_tool_use_id":"toolu_01CH8uNhwpuQEHhUGxP5y9Cc","session_id":"65a45440-8ea2-48ce-9346-c9049e4bd586","uuid":"38e135b0-a50e-4403-aed9-31fe1ab87dcd"}
