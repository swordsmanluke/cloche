→\t\treturn nil, err\n   339→\t}\n   340→\tdefer rows.Close()\n   341→\treturn scanLogFiles(rows)\n   342→}\n   343→\n   344→func scanLogFiles(rows *sql.Rows) ([]*ports.LogFileEntry, error) {\n   345→\tvar entries []*ports.LogFileEntry\n   346→\tfor rows.Next() {\n   347→\t\te := &ports.LogFileEntry{}\n   348→\t\tvar createdAt string\n   349→\t\tif err := rows.Scan(&e.ID, &e.RunID, &e.StepName, &e.FileType, &e.FilePath, &e.FileSize, &createdAt); err != nil {\n   350→\t\t\treturn nil, err\n   351→\t\t}\n   352→\t\te.CreatedAt = parseTime(createdAt)\n   353→\t\tentries = append(entries, e)\n   354→\t}\n   355→\treturn entries, rows.Err()\n   356→}\n   357→\n   358→func (s *Store) SaveEvolution(ctx context.Context, entry *ports.EvolutionEntry) error {\n   359→\t_, err := s.db.ExecContext(ctx,\n   360→\t\t`INSERT INTO evolution_log (id, project_dir, workflow_name, trigger_run_id, created_at, classification, changes_json, knowledge_delta)\n   361→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,\n   362→\t\tentry.ID, entry.ProjectDir, entry.WorkflowName, entry.TriggerRunID,\n   363→\t\tformatTime(entry.CreatedAt), entry.Classification, entry.ChangesJSON, entry.KnowledgeDelta,\n   364→\t)\n   365→\treturn err\n   366→}\n   367→\n   368→func (s *Store) GetLastEvolution(ctx context.Context, projectDir, workflowName string) (*ports.EvolutionEntry, error) {\n   369→\trow := s.db.QueryRowContext(ctx,\n   370→\t\t`SELECT id, project_dir, workflow_name, trigger_run_id, created_at, COALESCE(classification,''), changes_json, COALESCE(knowledge_delta,'')\n   371→\t\t FROM evolution_log WHERE project_dir = ? AND workflow_name = ? ORDER BY created_at DESC LIMIT 1`,\n   372→\t\tprojectDir, workflowName)\n   373→\n   374→\tentry := &ports.EvolutionEntry{}\n   375→\tvar createdAt string\n   376→\terr := row.Scan(&entry.ID, &entry.ProjectDir, &entry.WorkflowName, &entry.TriggerRunID,\n   377→\t\t&createdAt, &entry.Classification, &entry.ChangesJSON, &entry.KnowledgeDelta)\n   378→\tif err == sql.ErrNoRows {\n   379→\t\treturn nil, nil\n   380→\t}\n   381→\tif err != nil {\n   382→\t\treturn nil, err\n   383→\t}\n   384→\tentry.CreatedAt = parseTime(createdAt)\n   385→\treturn entry, nil\n   386→}\n   387→\n   388→func (s *Store) ListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error) {\n   389→\tvar rows *sql.Rows\n   390→\tvar err error\n   391→\n   392→\tif sinceRunID == \"\" {\n   393→\t\trows, err = s.db.QueryContext(ctx,\n   394→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0)\n   395→\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? ORDER BY started_at ASC`,\n   396→\t\t\tprojectDir, workflowName)\n   397→\t} else {\n   398→\t\trows, err = s.db.QueryContext(ctx,\n   399→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0)\n   400→\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? AND started_at > (SELECT started_at FROM runs WHERE id = ?)\n   401→\t\t\t ORDER BY started_at ASC`,\n   402→\t\t\tprojectDir, workflowName, sinceRunID)\n   403→\t}\n   404→\tif err != nil {\n   405→\t\treturn nil, err\n   406→\t}\n   407→\tdefer rows.Close()\n   408→\n   409→\tvar runs []*domain.Run\n   410→\tfor rows.Next() {\n   411→\t\trun := &domain.Run{}\n   412→\t\tvar activeSteps, startedAt, completedAt string\n   413→\t\tvar containerKept int\n   414→\t\tif err := rows.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept); err != nil {\n   415→\t\t\treturn nil, err\n   416→\t\t}\n   417→\t\trun.SetActiveStepsFromString(activeSteps)\n   418→\t\trun.StartedAt = parseTime(startedAt)\n   419→\t\trun.CompletedAt = parseTime(completedAt)\n   420→\t\trun.ContainerKept = containerKept != 0\n   421→\t\truns = append(runs, run)\n   422→\t}\n   423→\treturn runs, rows.Err()\n   424→}\n   425→\n   426→\n   427→func (s *Store) EnqueueMerge(ctx context.Context, entry *ports.MergeQueueEntry) error {\n   428→\t_, err := s.db.ExecContext(ctx,\n   429→\t\t`INSERT INTO merge_queue (run_id, branch, project, status, enqueued_at)\n   430→\t\t VALUES (?, ?, ?, 'pending', ?)`,\n   431→\t\tentry.RunID, entry.Branch, entry.Project, formatTime(entry.EnqueuedAt),\n   432→\t)\n   433→\treturn err\n   434→}\n   435→\n   436→func (s *Store) NextPendingMerge(ctx context.Context, project string) (*ports.MergeQueueEntry, error) {\n   437→\ttx, err := s.db.BeginTx(ctx, nil)\n   438→\tif err != nil {\n   439→\t\treturn nil, err\n   440→\t}\n   441→\tdefer tx.Rollback()\n   442→\n   443→\t// Check if there is already an in_progress merge for this project\n   444→\tvar count int\n   445→\terr = tx.QueryRowContext(ctx,\n   446→\t\t`SELECT COUNT(*) FROM merge_queue WHERE project = ? AND status = 'in_progress'`,\n   447→\t\tproject).Scan(&count)\n   448→\tif err != nil {\n   449→\t\treturn nil, err\n   450→\t}\n   451→\tif count > 0 {\n   452→\t\treturn nil, nil // another merge is already in progress\n   453→\t}\n   454→\n   455→\t// Get the oldest pending merge for this project\n   456→\trow := tx.QueryRowContext(ctx,\n   457→\t\t`SELECT run_id, branch, project, enqueued_at FROM merge_queue\n   458→\t\t WHERE project = ? AND status = 'pending'\n   459→\t\t ORDER BY enqueued_at ASC LIMIT 1`, project)\n   460→\n   461→\tentry := &ports.MergeQueueEntry{}\n   462→\tvar enqueuedAt string\n   463→\terr = row.Scan(&entry.RunID, &entry.Branch, &entry.Project, &enqueuedAt)\n   464→\tif err == sql.ErrNoRows {\n   465→\t\treturn nil, nil\n   466→\t}\n   467→\tif err != nil {\n   468→\t\treturn nil, err\n   469→\t}\n   470→\tentry.EnqueuedAt = parseTime(enqueuedAt)\n   471→\tentry.Status = \"in_progress\"\n   472→\n   473→\t// Mark it as in_progress\n   474→\t_, err = tx.ExecContext(ctx,\n   475→\t\t`UPDATE merge_queue SET status = 'in_progress' WHERE run_id = ?`,\n   476→\t\tentry.RunID)\n   477→\tif err != nil {\n   478→\t\treturn nil, err\n   479→\t}\n   480→\n   481→\tif err := tx.Commit(); err != nil {\n   482→\t\treturn nil, err\n   483→\t}\n   484→\treturn entry, nil\n   485→}\n   486→\n   487→func (s *Store) CompleteMerge(ctx context.Context, runID string) error {\n   488→\t_, err := s.db.ExecContext(ctx,\n   489→\t\t`UPDATE merge_queue SET status = 'completed', completed_at = ? WHERE run_id = ?`,\n   490→\t\tformatTime(time.Now()), runID,\n   491→\t)\n   492→\treturn err\n   493→}\n   494→\n   495→func (s *Store) FailMerge(ctx context.Context, runID string) error {\n   496→\t_, err := s.db.ExecContext(ctx,\n   497→\t\t`UPDATE merge_queue SET status = 'failed', completed_at = ? WHERE run_id = ?`,\n   498→\t\tformatTime(time.Now()), runID,\n   499→\t)"}]},"parent_tool_use_id":"toolu_01LpuyntS16knaLtZjQj24g8","session_id":"65a45440-8ea2-48ce-9346-c9049e4bd586","uuid":"c3f768f7-15f1-41b2-9c17-4cf8e265c45c"}
