{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Dbqc5bEihuv878y7YX8Wma","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    19→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    20→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    21→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    22→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    23→\trpcgrpc \"google.golang.org/grpc\"\n    24→)\n    25→\n    26→// OnRunCompleteFunc is called after a workflow run finishes.\n    27→// It receives the project directory, run ID, and the final run state.\n    28→type OnRunCompleteFunc func(ctx context.Context, projectDir string, runID string, state domain.RunState)\n    29→\n    30→type ClocheServer struct {\n    31→\tpb.UnimplementedClocheServiceServer\n    32→\tstore         ports.RunStore\n    33→\tcaptures      ports.CaptureStore\n    34→\tlogStore      ports.LogStore\n    35→\tcontainer     ports.ContainerRuntime\n    36→\tdefaultImage  string\n    37→\tevolution     *evolution.Trigger\n    38→\tlogBroadcast  *logstream.Broadcaster\n    39→\tshutdownFn    func()\n    40→\tonRunComplete OnRunCompleteFunc\n    41→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    42→\tmu            sync.Mutex\n    43→\trunIDs        map[string]string // run_id -> container_id\n    44→}\n    45→\n    46→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    47→\treturn &ClocheServer{\n    48→\t\tstore:     store,\n    49→\t\tcontainer: container,\n    50→\t\trunIDs:    make(map[string]string),\n    51→\t}\n    52→}\n    53→\n    54→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    55→\treturn &ClocheServer{\n    56→\t\tstore:        store,\n    57→\t\tcaptures:     captures,\n    58→\t\tcontainer:    container,\n    59→\t\tdefaultImage: defaultImage,\n    60→\t\trunIDs:       make(map[string]string),\n    61→\t}\n    62→}\n    63→\n    64→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    65→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    66→\ts.logStore = ls\n    67→}\n    68→\n    69→\n    70→// SetEvolution attaches an evolution trigger to the server.\n    71→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    72→\ts.evolution = trigger\n    73→}\n    74→\n    75→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    76→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    77→\ts.logBroadcast = b\n    78→}\n    79→\n    80→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    81→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    82→\ts.shutdownFn = fn\n    83→}\n    84→\n    85→// SetOnRunComplete sets a callback invoked after each workflow run completes.\n    86→func (s *ClocheServer) SetOnRunComplete(fn OnRunCompleteFunc) {\n    87→\ts.onRunComplete = fn\n    88→}\n    89→\n    90→\n    91→// SetOrchestrateFunc sets the function invoked by the Orchestrate RPC.\n    92→func (s *ClocheServer) SetOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) {\n    93→\ts.orchestrateFn = fn\n    94→}\n    95→\n    96→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    97→\tif s.container == nil {\n    98→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    99→\t}\n   100→\n   101→\t// Generate a unique run ID, retrying on collision\n   102→\tvar runID string\n   103→\tfor attempts := 0; attempts < 10; attempts++ {\n   104→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n   105→\t\texisting, err := s.store.GetRun(ctx, runID)\n   106→\t\tif err != nil {\n   107→\t\t\tbreak // ID is free\n   108→\t\t}\n   109→\t\t// Reuse if completed more than 1 hour ago\n   110→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   111→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   112→\t\t\tbreak\n   113→\t\t}\n   114→\t}\n   115→\n   116→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   117→\tif req.Prompt != \"\" {\n   118→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   119→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   120→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   121→\t\t}\n   122→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   123→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   124→\t\t}\n   125→\t}\n   126→\trun := domain.NewRun(runID, req.WorkflowName)\n   127→\trun.ProjectDir = req.ProjectDir\n   128→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   129→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   130→\t}\n   131→\n   132→\t// Resolve image: request-level override, then server default\n   133→\timage := req.Image\n   134→\tif image == \"\" {\n   135→\t\timage = s.defaultImage\n   136→\t}\n   137→\n   138→\t// Launch container start + tracking in background so the RPC returns immediately.\n   139→\t// The run stays in \"pending\" state until the container is up.\n   140→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   141→\n   142→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   143→}\n   144→\n   145→// launchAndTrack starts the container and then tracks it to completion.\n   146→// It runs in a background goroutine with its own context, independent of the\n   147→// RPC context which may be cancelled after RunWorkflow returns.\n   148→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   149→\tctx := context.Background()\n   150→\n   151→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   152→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   153→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   154→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   155→\t\t\tif run != nil {\n   156→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   157→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   158→\t\t\t}\n   159→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   160→\t\t\treturn\n   161→\t\t}\n   162→\t}\n   163→\n   164→\tbaseSHA := gitHEAD(req.ProjectDir)\n   165→\n   166→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   167→\t\tImage:        image,\n   168→\t\tWorkflowName: req.WorkflowName,\n   169→\t\tProjectDir:   req.ProjectDir,\n   170→\t\tRunID:        runID,\n   171→\t\tNetworkAllow: []string{\"*\"},\n   172→\t})\n   173→\tif err != nil {\n   174→\t\trun, _ := s.store.GetRun(ctx, runID)\n   175→\t\tif run != nil {\n   176→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   177→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   178→\t\t}\n   179→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   180→\t\treturn\n   181→\t}\n   182→\n   183→\ts.mu.Lock()\n   184→\ts.runIDs[runID] = containerID\n   185→\ts.mu.Unlock()\n   186→\n   187→\trun, _ := s.store.GetRun(ctx, runID)\n   188→\tif run != nil {\n   189→\t\trun.Start()\n   190→\t\trun.ContainerID = containerID\n   191→\t\trun.BaseSHA = baseSHA\n   192→\t\t_ = s.store.UpdateRun(ctx, run)\n   193→\t}\n   194→\n   195→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   196→}\n   197→\n   198→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   199→\tctx := context.Background()\n   200→\n   201→\t// Attach to agent output\n   202→\treader, err := s.container.AttachOutput(ctx, containerID)\n   203→\tif err != nil {\n   204→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   205→\t\treturn\n   206→\t}\n   207→\n   208→\t// Parse JSON-lines status messages\n   209→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   210→\tscanner := bufio.NewScanner(reader)\n   211→\tfor scanner.Scan() {\n   212→\t\tvar msg protocol.StatusMessage\n   213→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   214→\t\t\tcontinue\n   215→\t\t}\n   216→\n   217→\t\t// Fast path: log messages don't need store interaction.\n   218→\t\tif msg.Type == protocol.MsgLog {\n   219→\t\t\tif s.logBroadcast != nil {\n   220→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   221→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   222→\t\t\t\t\tType:      \"llm\",\n   223→\t\t\t\t\tContent:   msg.Message,\n   224→\t\t\t\t})\n   225→\t\t\t}\n   226→\t\t\tcontinue\n   227→\t\t}\n   228→\n   229→\t\trun, err := s.store.GetRun(ctx, runID)\n   230→\t\tif err != nil {\n   231→\t\t\tcontinue\n   232→\t\t}\n   233→\n   234→\t\tswitch msg.Type {\n   235→\t\tcase protocol.MsgStepStarted:\n   236→\t\t\trun.RecordStepStart(msg.StepName)\n   237→\t\t\tif s.captures != nil {\n   238→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   239→\t\t\t\t\tStepName:  msg.StepName,\n   240→\t\t\t\t\tStartedAt: msg.Timestamp,\n   241→\t\t\t\t})\n   242→\t\t\t}\n   243→\t\tcase protocol.MsgStepCompleted:\n   244→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   245→\t\t\tif s.captures != nil {\n   246→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   247→\t\t\t\t\tStepName:    msg.StepName,\n   248→\t\t\t\t\tResult:      msg.Result,\n   249→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   250→\t\t\t\t})\n   251→\t\t\t}\n   252→\t\tcase protocol.MsgRunCompleted:\n   253→\t\t\treportedResult = msg.Result\n   254→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   255→\t\t}\n   256→\n   257→\t\t_ = s.store.UpdateRun(ctx, run)\n   258→\t}\n   259→\treader.Close()\n   260→\n   261→\t// Signal live-stream subscribers that this run is done.\n   262→\tif s.logBroadcast != nil {\n   263→\t\ts.logBroadcast.Finish(runID)\n   264→\t}\n   265→\n   266→\t// Wait for process exit\n   267→\texitCode, err := s.container.Wait(ctx, containerID)\n   268→\tif err != nil {\n   269→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   270→\t}\n   271→\n   272→\t// Extract step output files from container before it's removed\n   273→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   274→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   275→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   276→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   277→\t\t}\n   278→\t}\n   279→\n   280→\t// Capture full container stdout/stderr before the container is removed\n   281→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   282→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   283→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   284→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   285→\t\t}\n   286→\t}\n   287→\n   288→\t// Index extracted log files in the log store\n   289→\tif s.logStore != nil {\n   290→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   291→\t}\n   292→\n   293→\t// Extract results to git branch BEFORE finalizing state, so that\n   294→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   295→\t// before the run is marked complete.\n   296→\tresultLabel := reportedResult\n   297→\tif resultLabel == \"\" {\n   298→\t\tif exitCode == 0 {\n   299→\t\t\tresultLabel = \"succeeded\"\n   300→\t\t} else {\n   301→\t\t\tresultLabel = \"failed\"\n   302→\t\t}\n   303→\t}\n   304→\t{\n   305→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   306→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   307→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   308→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   309→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   310→\t\t\t} else {\n   311→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   312→\t\t\t}\n   313→\t\t} else {\n   314→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   315→\t\t}\n   316→\t}\n   317→\n   318→\t// Now finalize run state\n   319→\trun, err := s.store.GetRun(ctx, runID)\n   320→\tif err != nil {\n   321→\t\treturn\n   322→\t}\n   323→\tif run.State == domain.RunStateRunning {\n   324→\t\tif reportedResult == \"succeeded\" {\n   325→\t\t\trun.Complete(domain.RunStateSucceeded)\n   326→\t\t} else if reportedResult != \"\" {\n   327→\t\t\trun.Complete(domain.RunStateFailed)\n   328→\t\t} else if exitCode == 0 {\n   329→\t\t\trun.Complete(domain.RunStateSucceeded)\n   330→\t\t} else {\n   331→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   332→\t\t}\n   333→\t\t_ = s.store.UpdateRun(ctx, run)\n   334→\t}\n   335→\n   336→\t// Fire evolution trigger if configured\n   337→\tif s.evolution != nil {\n   338→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   339→\t}\n   340→\n   341→\t// Fire on-run-complete callback (orchestrator trigger)\n   342→\tif s.onRunComplete != nil {\n   343→\t\trunForCallback, _ := s.store.GetRun(ctx, runID)\n   344→\t\tif runForCallback != nil {\n   345→\t\t\ts.onRunComplete(ctx, projectDir, runID, runForCallback.State)\n   346→\t\t}\n   347→\t}\n   348→\n   349→\t// Merge is handled as a workflow step in host.cloche, not here.\n   350→\n   351→\t// Container retention policy:\n   352→\t// - Failed runs: always keep the container for debugging\n   353→\t// - Successful runs + --keep-container: keep the container\n   354→\t// - Successful runs without --keep-container: remove the container\n   355→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   356→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   357→\n   358→\tif keepContainer || runFailed {\n   359→\t\treason := \"--keep-container\"\n   360→\t\tif runFailed {\n   361→\t\t\treason = \"run failed\"\n   362→\t\t}\n   363→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   364→\t\tif runFinal != nil {\n   365→\t\t\trunFinal.ContainerKept = true\n   366→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   367→\t\t}\n   368→\t} else {\n   369→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   370→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   371→\t\t} else {\n   372→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   373→\t\t}\n   374→\t}\n   375→\n   376→\t// Cleanup mapping\n   377→\ts.mu.Lock()\n   378→\tdelete(s.runIDs, runID)\n   379→\ts.mu.Unlock()\n   380→}\n   381→\n   382→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   383→\tvar since time.Time\n   384→\tif !req.All {\n   385→\t\tsince = time.Now().Add(-1 * time.Hour)\n   386→\t}\n   387→\truns, err := s.store.ListRuns(ctx, since)\n   388→\tif err != nil {\n   389→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   390→\t}\n   391→\n   392→\tresp := &pb.ListRunsResponse{}\n   393→\tfor _, run := range runs {\n   394→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   395→\t\t\tRunId:        run.ID,\n   396→\t\t\tWorkflowName: run.WorkflowName,\n   397→\t\t\tState:        string(run.State),\n   398→\t\t\tStartedAt:    run.StartedAt.String(),\n   399→\t\t\tErrorMessage: run.ErrorMessage,\n   400→\t\t\tContainerId:  run.ContainerID,\n   401→\t\t})\n   402→\t}\n   403→\treturn resp, nil\n   404→}\n   405→\n   406→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   407→\trun, err := s.store.GetRun(ctx, req.RunId)\n   408→\tif err != nil {\n   409→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   410→\t}\n   411→\n   412→\tresp := &pb.GetStatusResponse{\n   413→\t\tRunId:        run.ID,\n   414→\t\tWorkflowName: run.WorkflowName,\n   415→\t\tState:        string(run.State),\n   416→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   417→\t\tErrorMessage: run.ErrorMessage,\n   418→\t\tContainerId:  run.ContainerID,\n   419→\t}\n   420→\n   421→\t// Check container liveness\n   422→\tif run.ContainerID != \"\" && s.container != nil {\n   423→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   424→\t\t\tresp.ContainerAlive = cs.Running\n   425→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   426→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   427→\t\t\t}\n   428→\t\t}\n   429→\t}\n   430→\n   431→\t// Load step executions from captures store if available\n   432→\tif s.captures != nil {\n   433→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   434→\t\tif err == nil {\n   435→\t\t\tfor _, exec := range captures {\n   436→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   437→\t\t\t\t\tStepName:    exec.StepName,\n   438→\t\t\t\t\tResult:      exec.Result,\n   439→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   440→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   441→\t\t\t\t})\n   442→\t\t\t}\n   443→\t\t}\n   444→\t} else {\n   445→\t\tfor _, exec := range run.StepExecutions {\n   446→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   447→\t\t\t\tStepName:    exec.StepName,\n   448→\t\t\t\tResult:      exec.Result,\n   449→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   450→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   451→\t\t\t})\n   452→\t\t}\n   453→\t}\n   454→\n   455→\treturn resp, nil\n   456→}\n   457→\n   458→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   459→\tctx := stream.Context()\n   460→\n   461→\t// Verify run exists\n   462→\trun, err := s.store.GetRun(ctx, req.RunId)\n   463→\tif err != nil {\n   464→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   465→\t}\n   466→\n   467→\t// If step_name or log_type filter is set, serve content directly from the log index\n   468→\tif req.StepName != \"\" || req.LogType != \"\" {\n   469→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   470→\t}\n   471→\n   472→\tif s.captures == nil {\n   473→\t\treturn fmt.Errorf(\"captures store not configured\")\n   474→\t}\n   475→\n   476→\t// Check for full.log first — if it exists, serve it as the unified log\n   477→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   478→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   479→\t\tif err := stream.Send(&pb.LogEntry{\n   480→\t\t\tType:    \"full_log\",\n   481→\t\t\tMessage: string(data),\n   482→\t\t}); err != nil {\n   483→\t\t\treturn err\n   484→\t\t}\n   485→\t\t// Still send run completion entry\n   486→\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   487→\t\t\tif err := stream.Send(&pb.LogEntry{\n   488→\t\t\t\tType:      \"run_completed\",\n   489→\t\t\t\tResult:    string(run.State),\n   490→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   491→\t\t\t\tMessage:   run.ErrorMessage,\n   492→\t\t\t}); err != nil {\n   493→\t\t\t\treturn err\n   494→\t\t\t}\n   495→\t\t}\n   496→\t\treturn nil\n   497→\t}\n   498→\n   499→\t// Fall back to capture-based streaming\n   500→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   501→\tif err != nil {\n   502→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   503→\t}\n   504→\n   505→\tfor _, exec := range captures {\n   506→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   507→\t\t// and one for step_completed (has Result).\n   508→\t\tif exec.Result == \"\" {\n   509→\t\t\tentry := &pb.LogEntry{\n   510→\t\t\t\tType:      \"step_started\",\n   511→\t\t\t\tStepName:  exec.StepName,\n   512→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   513→\t\t\t}\n   514→\t\t\tif err := stream.Send(entry); err != nil {\n   515→\t\t\t\treturn err\n   516→\t\t\t}\n   517→\t\t} else {\n   518→\t\t\t// Read step output from file, falling back to container.log\n   519→\t\t\tvar output string\n   520→\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   521→\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   522→\t\t\t\toutput = string(data)\n   523→\t\t\t} else {\n   524→\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n   525→\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n   526→\t\t\t\t\toutput = string(data)\n   527→\t\t\t\t}\n   528→\t\t\t}\n   529→\t\t\tentry := &pb.LogEntry{\n   530→\t\t\t\tType:      \"step_completed\",\n   531→\t\t\t\tStepName:  exec.StepName,\n   532→\t\t\t\tResult:    exec.Result,\n   533→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   534→\t\t\t\tMessage:   output,\n   535→\t\t\t}\n   536→\t\t\tif err := stream.Send(entry); err != nil {\n   537→\t\t\t\treturn err\n   538→\t\t\t}\n   539→\t\t}\n   540→\t}\n   541→\n   542→\t// Send run completion entry\n   543→\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   544→\t\tif err := stream.Send(&pb.LogEntry{\n   545→\t\t\tType:      \"run_completed\",\n   546→\t\t\tResult:    string(run.State),\n   547→\t\t\tTimestamp: run.CompletedAt.String(),\n   548→\t\t\tMessage:   run.ErrorMessage,\n   549→\t\t}); err != nil {\n   550→\t\t\treturn err\n   551→\t\t}\n   552→\t}\n   553→\n   554→\treturn nil\n   555→}\n   556→\n   557→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   558→// It uses the log index when available, falling back to file path conventions.\n   559→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   560→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   561→\n   562→\t// Try log index first\n   563→\tif s.logStore != nil {\n   564→\t\tvar logFiles []*ports.LogFileEntry\n   565→\t\tvar err error\n   566→\n   567→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   568→\t\t\t// Filter by both step and type\n   569→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   570→\t\t\tif err == nil {\n   571→\t\t\t\tfiltered := logFiles[:0]\n   572→\t\t\t\tfor _, lf := range logFiles {\n   573→\t\t\t\t\tif lf.FileType == req.LogType {\n   574→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   575→\t\t\t\t\t}\n   576→\t\t\t\t}\n   577→\t\t\t\tlogFiles = filtered\n   578→\t\t\t}\n   579→\t\t} else if req.StepName != \"\" {\n   580→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   581→\t\t} else {\n   582→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   583→\t\t}\n   584→\n   585→\t\tif err == nil && len(logFiles) > 0 {\n   586→\t\t\tfor _, lf := range logFiles {\n   587→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   588→\t\t\t\tif readErr != nil {\n   589→\t\t\t\t\tcontinue\n   590→\t\t\t\t}\n   591→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   592→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   593→\t\t\t\t\tStepName: lf.StepName,\n   594→\t\t\t\t\tMessage:  string(data),\n   595→\t\t\t\t}); err != nil {\n   596→\t\t\t\t\treturn err\n   597→\t\t\t\t}\n   598→\t\t\t}\n   599→\t\t\treturn nil\n   600→\t\t}\n   601→\t}\n   602→\n   603→\t// Fall back to file path conventions\n   604→\tif req.StepName != \"\" {\n   605→\t\tvar logPath string\n   606→\t\tswitch req.LogType {\n   607→\t\tcase \"llm\":\n   608→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   609→\t\tdefault:\n   610→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   611→\t\t}\n   612→\n   613→\t\tdata, err := os.ReadFile(logPath)\n   614→\t\tif err != nil {\n   615→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   616→\t\t}\n   617→\t\treturn stream.Send(&pb.LogEntry{\n   618→\t\t\tType:     \"step_log\",\n   619→\t\t\tStepName: req.StepName,\n   620→\t\t\tMessage:  string(data),\n   621→\t\t})\n   622→\t}\n   623→\n   624→\treturn fmt.Errorf(\"no log files found matching filter\")\n   625→}\n   626→\n   627→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   628→\ts.mu.Lock()\n   629→\tcontainerID, ok := s.runIDs[req.RunId]\n   630→\ts.mu.Unlock()\n   631→\n   632→\tif !ok {\n   633→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   634→\t}\n   635→\n   636→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   637→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   638→\t}\n   639→\n   640→\t// Mark as cancelled in store\n   641→\trun, err := s.store.GetRun(ctx, req.RunId)\n   642→\tif err == nil {\n   643→\t\trun.Complete(domain.RunStateCancelled)\n   644→\t\t_ = s.store.UpdateRun(ctx, run)\n   645→\t}\n   646→\n   647→\treturn &pb.StopRunResponse{}, nil\n   648→}\n   649→\n   650→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   651→\tif s.container == nil {\n   652→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   653→\t}\n   654→\n   655→\tid := req.Id\n   656→\tif id == \"\" {\n   657→\t\treturn nil, fmt.Errorf(\"id is required\")\n   658→\t}\n   659→\n   660→\t// Try to resolve as a run ID first\n   661→\tcontainerID := id\n   662→\trun, err := s.store.GetRun(ctx, id)\n   663→\tif err == nil {\n   664→\t\t// It's a run ID — use the container ID from the run record\n   665→\t\tif run.ContainerID == \"\" {\n   666→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   667→\t\t}\n   668→\t\tcontainerID = run.ContainerID\n   669→\t}\n   670→\n   671→\t// Remove the container\n   672→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   673→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   674→\t}\n   675→\n   676→\t// If we resolved a run, clear the container_kept flag\n   677→\tif run != nil {\n   678→\t\trun.ContainerKept = false\n   679→\t\t_ = s.store.UpdateRun(ctx, run)\n   680→\t}\n   681→\n   682→\treturn &pb.DeleteContainerResponse{}, nil\n   683→}\n   684→\n   685→func (s *ClocheServer) Orchestrate(ctx context.Context, req *pb.OrchestrateRequest) (*pb.OrchestrateResponse, error) {\n   686→\tif s.orchestrateFn == nil {\n   687→\t\treturn nil, fmt.Errorf(\"orchestrator not configured\")\n   688→\t}\n   689→\tdispatched, err := s.orchestrateFn(ctx, req.ProjectDir)\n   690→\tif err != nil {\n   691→\t\treturn nil, fmt.Errorf(\"orchestration failed: %w\", err)\n   692→\t}\n   693→\treturn &pb.OrchestrateResponse{Dispatched: int32(dispatched)}, nil\n   694→}\n   695→\n   696→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n   697→\tif s.shutdownFn == nil {\n   698→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n   699→\t}\n   700→\tgo s.shutdownFn()\n   701→\treturn &pb.ShutdownResponse{}, nil\n   702→}\n   703→\n   704→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n   705→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n   706→\tentries, err := os.ReadDir(outputDir)\n   707→\tif err != nil {\n   708→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n   709→\t\treturn\n   710→\t}\n   711→\n   712→\tnow := time.Now()\n   713→\tfor _, entry := range entries {\n   714→\t\tif entry.IsDir() {\n   715→\t\t\tcontinue\n   716→\t\t}\n   717→\t\tname := entry.Name()\n   718→\t\tif !strings.HasSuffix(name, \".log\") {\n   719→\t\t\tcontinue\n   720→\t\t}\n   721→\n   722→\t\tvar fileType, stepName string\n   723→\t\tbase := strings.TrimSuffix(name, \".log\")\n   724→\n   725→\t\tswitch {\n   726→\t\tcase name == \"full.log\":\n   727→\t\t\tfileType = \"full\"\n   728→\t\tcase name == \"container.log\":\n   729→\t\t\t// container.log is internal, not indexed as a user-facing log type\n   730→\t\t\tcontinue\n   731→\t\tcase strings.HasPrefix(name, \"llm-\"):\n   732→\t\t\tfileType = \"llm\"\n   733→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n   734→\t\tdefault:\n   735→\t\t\tfileType = \"script\"\n   736→\t\t\tstepName = base\n   737→\t\t}\n   738→\n   739→\t\tinfo, _ := entry.Info()\n   740→\t\tvar fileSize int64\n   741→\t\tif info != nil {\n   742→\t\t\tfileSize = info.Size()\n   743→\t\t}\n   744→\n   745→\t\tlogEntry := &ports.LogFileEntry{\n   746→\t\t\tRunID:     runID,\n   747→\t\t\tStepName:  stepName,\n   748→\t\t\tFileType:  fileType,\n   749→\t\t\tFilePath:  filepath.Join(outputDir, name),\n   750→\t\t\tFileSize:  fileSize,\n   751→\t\t\tCreatedAt: now,\n   752→\t\t}\n   753→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n   754→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n   755→\t\t}\n   756→\t}\n   757→}\n   758→\n   759→func gitHEAD(dir string) string {\n   760→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n   761→\tcmd.Dir = dir\n   762→\tout, err := cmd.Output()\n   763→\tif err != nil {\n   764→\t\treturn \"\"\n   765→\t}\n   766→\treturn strings.TrimSpace(string(out))\n   767→}\n   768→"}]},"parent_tool_use_id":null,"session_id":"65a45440-8ea2-48ce-9346-c9049e4bd586","uuid":"6ab59df8-f229-4041-8dad-3bba5434f556","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server.go","content":"package grpc\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\trpcgrpc \"google.golang.org/grpc\"\n)\n\n// OnRunCompleteFunc is called after a workflow run finishes.\n// It receives the project directory, run ID, and the final run state.\ntype OnRunCompleteFunc func(ctx context.Context, projectDir string, runID string, state domain.RunState)\n\ntype ClocheServer struct {\n\tpb.UnimplementedClocheServiceServer\n\tstore         ports.RunStore\n\tcaptures      ports.CaptureStore\n\tlogStore      ports.LogStore\n\tcontainer     ports.ContainerRuntime\n\tdefaultImage  string\n\tevolution     *evolution.Trigger\n\tlogBroadcast  *logstream.Broadcaster\n\tshutdownFn    func()\n\tonRunComplete OnRunCompleteFunc\n\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n\tmu            sync.Mutex\n\trunIDs        map[string]string // run_id -> container_id\n}\n\nfunc NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:     store,\n\t\tcontainer: container,\n\t\trunIDs:    make(map[string]string),\n\t}\n}\n\nfunc NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:        store,\n\t\tcaptures:     captures,\n\t\tcontainer:    container,\n\t\tdefaultImage: defaultImage,\n\t\trunIDs:       make(map[string]string),\n\t}\n}\n\n// SetLogStore attaches a log store to the server for indexing extracted log files.\nfunc (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n\ts.logStore = ls\n}\n\n\n// SetEvolution attaches an evolution trigger to the server.\nfunc (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n\ts.evolution = trigger\n}\n\n// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\nfunc (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n\ts.logBroadcast = b\n}\n\n// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\nfunc (s *ClocheServer) SetShutdownFunc(fn func()) {\n\ts.shutdownFn = fn\n}\n\n// SetOnRunComplete sets a callback invoked after each workflow run completes.\nfunc (s *ClocheServer) SetOnRunComplete(fn OnRunCompleteFunc) {\n\ts.onRunComplete = fn\n}\n\n\n// SetOrchestrateFunc sets the function invoked by the Orchestrate RPC.\nfunc (s *ClocheServer) SetOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) {\n\ts.orchestrateFn = fn\n}\n\nfunc (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\t// Generate a unique run ID, retrying on collision\n\tvar runID string\n\tfor attempts := 0; attempts < 10; attempts++ {\n\t\trunID = domain.GenerateRunID(req.WorkflowName)\n\t\texisting, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tbreak // ID is free\n\t\t}\n\t\t// Reuse if completed more than 1 hour ago\n\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n\t\t\t_ = s.store.DeleteRun(ctx, runID)\n\t\t\tbreak\n\t\t}\n\t}\n\n\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n\tif req.Prompt != \"\" {\n\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n\t\t}\n\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n\t\t}\n\t}\n\trun := domain.NewRun(runID, req.WorkflowName)\n\trun.ProjectDir = req.ProjectDir\n\tif err := s.store.CreateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n\t}\n\n\t// Resolve image: request-level override, then server default\n\timage := req.Image\n\tif image == \"\" {\n\t\timage = s.defaultImage\n\t}\n\n\t// Launch container start + tracking in background so the RPC returns immediately.\n\t// The run stays in \"pending\" state until the container is up.\n\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n\n\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n}\n\n// launchAndTrack starts the container and then tracks it to completion.\n// It runs in a background goroutine with its own context, independent of the\n// RPC context which may be cancelled after RunWorkflow returns.\nfunc (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n\tctx := context.Background()\n\n\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n\t\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\t\tif run != nil {\n\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t\t}\n\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n\t\t\treturn\n\t\t}\n\t}\n\n\tbaseSHA := gitHEAD(req.ProjectDir)\n\n\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n\t\tImage:        image,\n\t\tWorkflowName: req.WorkflowName,\n\t\tProjectDir:   req.ProjectDir,\n\t\tRunID:        runID,\n\t\tNetworkAllow: []string{\"*\"},\n\t})\n\tif err != nil {\n\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\tif run != nil {\n\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t}\n\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n\t\treturn\n\t}\n\n\ts.mu.Lock()\n\ts.runIDs[runID] = containerID\n\ts.mu.Unlock()\n\n\trun, _ := s.store.GetRun(ctx, runID)\n\tif run != nil {\n\t\trun.Start()\n\t\trun.ContainerID = containerID\n\t\trun.BaseSHA = baseSHA\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n}\n\nfunc (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n\tctx := context.Background()\n\n\t// Attach to agent output\n\treader, err := s.container.AttachOutput(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n\t\treturn\n\t}\n\n\t// Parse JSON-lines status messages\n\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n\tscanner := bufio.NewScanner(reader)\n\tfor scanner.Scan() {\n\t\tvar msg protocol.StatusMessage\n\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Fast path: log messages don't need store interaction.\n\t\tif msg.Type == protocol.MsgLog {\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"llm\",\n\t\t\t\t\tContent:   msg.Message,\n\t\t\t\t})\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\trun, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch msg.Type {\n\t\tcase protocol.MsgStepStarted:\n\t\t\trun.RecordStepStart(msg.StepName)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t\tStartedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgStepCompleted:\n\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:    msg.StepName,\n\t\t\t\t\tResult:      msg.Result,\n\t\t\t\t\tCompletedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgRunCompleted:\n\t\t\treportedResult = msg.Result\n\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n\t\t}\n\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\treader.Close()\n\n\t// Signal live-stream subscribers that this run is done.\n\tif s.logBroadcast != nil {\n\t\ts.logBroadcast.Finish(runID)\n\t}\n\n\t// Wait for process exit\n\texitCode, err := s.container.Wait(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n\t}\n\n\t// Extract step output files from container before it's removed\n\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n\t\t}\n\t}\n\n\t// Capture full container stdout/stderr before the container is removed\n\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n\t\t}\n\t}\n\n\t// Index extracted log files in the log store\n\tif s.logStore != nil {\n\t\ts.indexLogFiles(ctx, runID, outputDst)\n\t}\n\n\t// Extract results to git branch BEFORE finalizing state, so that\n\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n\t// before the run is marked complete.\n\tresultLabel := reportedResult\n\tif resultLabel == \"\" {\n\t\tif exitCode == 0 {\n\t\t\tresultLabel = \"succeeded\"\n\t\t} else {\n\t\t\tresultLabel = \"failed\"\n\t\t}\n\t}\n\t{\n\t\textractRun, _ := s.store.GetRun(ctx, runID)\n\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n\t\t\t} else {\n\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n\t\t\t}\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n\t\t}\n\t}\n\n\t// Now finalize run state\n\trun, err := s.store.GetRun(ctx, runID)\n\tif err != nil {\n\t\treturn\n\t}\n\tif run.State == domain.RunStateRunning {\n\t\tif reportedResult == \"succeeded\" {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else if reportedResult != \"\" {\n\t\t\trun.Complete(domain.RunStateFailed)\n\t\t} else if exitCode == 0 {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else {\n\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n\t\t}\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\t// Fire evolution trigger if configured\n\tif s.evolution != nil {\n\t\ts.evolution.Fire(projectDir, workflowName, runID)\n\t}\n\n\t// Fire on-run-complete callback (orchestrator trigger)\n\tif s.onRunComplete != nil {\n\t\trunForCallback, _ := s.store.GetRun(ctx, runID)\n\t\tif runForCallback != nil {\n\t\t\ts.onRunComplete(ctx, projectDir, runID, runForCallback.State)\n\t\t}\n\t}\n\n\t// Merge is handled as a workflow step in host.cloche, not here.\n\n\t// Container retention policy:\n\t// - Failed runs: always keep the container for debugging\n\t// - Successful runs + --keep-container: keep the container\n\t// - Successful runs without --keep-container: remove the container\n\trunFinal, _ := s.store.GetRun(ctx, runID)\n\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n\n\tif keepContainer || runFailed {\n\t\treason := \"--keep-container\"\n\t\tif runFailed {\n\t\t\treason = \"run failed\"\n\t\t}\n\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n\t\tif runFinal != nil {\n\t\t\trunFinal.ContainerKept = true\n\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n\t\t}\n\t} else {\n\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n\t\t}\n\t}\n\n\t// Cleanup mapping\n\ts.mu.Lock()\n\tdelete(s.runIDs, runID)\n\ts.mu.Unlock()\n}\n\nfunc (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n\tvar since time.Time\n\tif !req.All {\n\t\tsince = time.Now().Add(-1 * time.Hour)\n\t}\n\truns, err := s.store.ListRuns(ctx, since)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n\t}\n\n\tresp := &pb.ListRunsResponse{}\n\tfor _, run := range runs {\n\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n\t\t\tRunId:        run.ID,\n\t\t\tWorkflowName: run.WorkflowName,\n\t\t\tState:        string(run.State),\n\t\t\tStartedAt:    run.StartedAt.String(),\n\t\t\tErrorMessage: run.ErrorMessage,\n\t\t\tContainerId:  run.ContainerID,\n\t\t})\n\t}\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n\t}\n\n\tresp := &pb.GetStatusResponse{\n\t\tRunId:        run.ID,\n\t\tWorkflowName: run.WorkflowName,\n\t\tState:        string(run.State),\n\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n\t\tErrorMessage: run.ErrorMessage,\n\t\tContainerId:  run.ContainerID,\n\t}\n\n\t// Check container liveness\n\tif run.ContainerID != \"\" && s.container != nil {\n\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n\t\t\tresp.ContainerAlive = cs.Running\n\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n\t\t\t}\n\t\t}\n\t}\n\n\t// Load step executions from captures store if available\n\tif s.captures != nil {\n\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\t\tif err == nil {\n\t\t\tfor _, exec := range captures {\n\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\t\tStepName:    exec.StepName,\n\t\t\t\t\tResult:      exec.Result,\n\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, exec := range run.StepExecutions {\n\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\tStepName:    exec.StepName,\n\t\t\t\tResult:      exec.Result,\n\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t})\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tctx := stream.Context()\n\n\t// Verify run exists\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n\t}\n\n\t// If step_name or log_type filter is set, serve content directly from the log index\n\tif req.StepName != \"\" || req.LogType != \"\" {\n\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n\t}\n\n\tif s.captures == nil {\n\t\treturn fmt.Errorf(\"captures store not configured\")\n\t}\n\n\t// Check for full.log first — if it exists, serve it as the unified log\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: string(data),\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t\t// Still send run completion entry\n\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"run_completed\",\n\t\t\t\tResult:    string(run.State),\n\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}\n\n\t// Fall back to capture-based streaming\n\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n\t}\n\n\tfor _, exec := range captures {\n\t\t// Captures are stored as separate rows: one for step_started (no Result)\n\t\t// and one for step_completed (has Result).\n\t\tif exec.Result == \"\" {\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_started\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tTimestamp: exec.StartedAt.String(),\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t} else {\n\t\t\t// Read step output from file, falling back to container.log\n\t\t\tvar output string\n\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\t\t\toutput = string(data)\n\t\t\t} else {\n\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n\t\t\t\t\toutput = string(data)\n\t\t\t\t}\n\t\t\t}\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_completed\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tResult:    exec.Result,\n\t\t\t\tTimestamp: exec.CompletedAt.String(),\n\t\t\t\tMessage:   output,\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\t// Send run completion entry\n\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:      \"run_completed\",\n\t\t\tResult:    string(run.State),\n\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\tMessage:   run.ErrorMessage,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// streamFilteredLogs serves log content filtered by step name and/or log type.\n// It uses the log index when available, falling back to file path conventions.\nfunc (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n\n\t// Try log index first\n\tif s.logStore != nil {\n\t\tvar logFiles []*ports.LogFileEntry\n\t\tvar err error\n\n\t\tif req.StepName != \"\" && req.LogType != \"\" {\n\t\t\t// Filter by both step and type\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t\tif err == nil {\n\t\t\t\tfiltered := logFiles[:0]\n\t\t\t\tfor _, lf := range logFiles {\n\t\t\t\t\tif lf.FileType == req.LogType {\n\t\t\t\t\t\tfiltered = append(filtered, lf)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tlogFiles = filtered\n\t\t\t}\n\t\t} else if req.StepName != \"\" {\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t} else {\n\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n\t\t}\n\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr != nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\t\tType:     lf.FileType + \"_log\",\n\t\t\t\t\tStepName: lf.StepName,\n\t\t\t\t\tMessage:  string(data),\n\t\t\t\t}); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Fall back to file path conventions\n\tif req.StepName != \"\" {\n\t\tvar logPath string\n\t\tswitch req.LogType {\n\t\tcase \"llm\":\n\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n\t\tdefault:\n\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n\t\t}\n\n\t\tdata, err := os.ReadFile(logPath)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n\t\t}\n\t\treturn stream.Send(&pb.LogEntry{\n\t\t\tType:     \"step_log\",\n\t\t\tStepName: req.StepName,\n\t\t\tMessage:  string(data),\n\t\t})\n\t}\n\n\treturn fmt.Errorf(\"no log files found matching filter\")\n}\n\nfunc (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n\ts.mu.Lock()\n\tcontainerID, ok := s.runIDs[req.RunId]\n\ts.mu.Unlock()\n\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n\t}\n\n\tif err := s.container.Stop(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n\t}\n\n\t// Mark as cancelled in store\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err == nil {\n\t\trun.Complete(domain.RunStateCancelled)\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.StopRunResponse{}, nil\n}\n\nfunc (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\tid := req.Id\n\tif id == \"\" {\n\t\treturn nil, fmt.Errorf(\"id is required\")\n\t}\n\n\t// Try to resolve as a run ID first\n\tcontainerID := id\n\trun, err := s.store.GetRun(ctx, id)\n\tif err == nil {\n\t\t// It's a run ID — use the container ID from the run record\n\t\tif run.ContainerID == \"\" {\n\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n\t\t}\n\t\tcontainerID = run.ContainerID\n\t}\n\n\t// Remove the container\n\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n\t}\n\n\t// If we resolved a run, clear the container_kept flag\n\tif run != nil {\n\t\trun.ContainerKept = false\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.DeleteContainerResponse{}, nil\n}\n\nfunc (s *ClocheServer) Orchestrate(ctx context.Context, req *pb.OrchestrateRequest) (*pb.OrchestrateResponse, error) {\n\tif s.orchestrateFn == nil {\n\t\treturn nil, fmt.Errorf(\"orchestrator not configured\")\n\t}\n\tdispatched, err := s.orchestrateFn(ctx, req.ProjectDir)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"orchestration failed: %w\", err)\n\t}\n\treturn &pb.OrchestrateResponse{Dispatched: int32(dispatched)}, nil\n}\n\nfunc (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n\tif s.shutdownFn == nil {\n\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n\t}\n\tgo s.shutdownFn()\n\treturn &pb.ShutdownResponse{}, nil\n}\n\n// indexLogFiles scans the extracted output directory and creates log_files index entries.\nfunc (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tname := entry.Name()\n\t\tif !strings.HasSuffix(name, \".log\") {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar fileType, stepName string\n\t\tbase := strings.TrimSuffix(name, \".log\")\n\n\t\tswitch {\n\t\tcase name == \"full.log\":\n\t\t\tfileType = \"full\"\n\t\tcase name == \"container.log\":\n\t\t\t// container.log is internal, not indexed as a user-facing log type\n\t\t\tcontinue\n\t\tcase strings.HasPrefix(name, \"llm-\"):\n\t\t\tfileType = \"llm\"\n\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n\t\tdefault:\n\t\t\tfileType = \"script\"\n\t\t\tstepName = base\n\t\t}\n\n\t\tinfo, _ := entry.Info()\n\t\tvar fileSize int64\n\t\tif info != nil {\n\t\t\tfileSize = info.Size()\n\t\t}\n\n\t\tlogEntry := &ports.LogFileEntry{\n\t\t\tRunID:     runID,\n\t\t\tStepName:  stepName,\n\t\t\tFileType:  fileType,\n\t\t\tFilePath:  filepath.Join(outputDir, name),\n\t\t\tFileSize:  fileSize,\n\t\t\tCreatedAt: now,\n\t\t}\n\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n\t\t}\n\t}\n}\n\nfunc gitHEAD(dir string) string {\n\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\treturn strings.TrimSpace(string(out))\n}\n","numLines":768,"startLine":1,"totalLines":768}}}
