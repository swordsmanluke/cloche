ormatLLMContent(input)\n\tif got != \"\" {\n\t\tt.Errorf(\"expected empty for thinking-only, got %q\", got)\n\t}\n}\n\nfunc TestFormatLLMContent_AssistantToolUse(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tinput    string\n\t\tcontains string\n\t}{\n\t\t{\n\t\t\tname:     \"Read\",\n\t\t\tinput:    `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Read\",\"input\":{\"file_path\":\"/workspace/main.go\"}}]}}`,\n\t\t\tcontains: \"Read /workspace/main.go\",\n\t\t},\n\t\t{\n\t\t\tname:     \"Edit\",\n\t\t\tinput:    `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Edit\",\"input\":{\"file_path\":\"/workspace/main.go\"}}]}}`,\n\t\t\tcontains: \"Edit /workspace/main.go\",\n\t\t},\n\t\t{\n\t\t\tname:     \"Bash\",\n\t\t\tinput:    `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Bash\",\"input\":{\"command\":\"go test ./...\"}}]}}`,\n\t\t\tcontains: \"Bash: go test ./...\",\n\t\t},\n\t\t{\n\t\t\tname:     \"Grep\",\n\t\t\tinput:    `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Grep\",\"input\":{\"pattern\":\"func main\"}}]}}`,\n\t\t\tcontains: \"Grep: func main\",\n\t\t},\n\t\t{\n\t\t\tname:     \"Glob\",\n\t\t\tinput:    `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Glob\",\"input\":{\"pattern\":\"**/*.go\"}}]}}`,\n\t\t\tcontains: \"Glob: **/*.go\",\n\t\t},\n\t\t{\n\t\t\tname:     \"Agent\",\n\t\t\tinput:    `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Agent\",\"input\":{\"description\":\"search for files\"}}]}}`,\n\t\t\tcontains: \"Agent: search for files\",\n\t\t},\n\t\t{\n\t\t\tname:     \"Unknown tool\",\n\t\t\tinput:    `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"ToolSearch\",\"input\":{\"query\":\"read\"}}]}}`,\n\t\t\tcontains: \"ToolSearch\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tgot := FormatLLMContent(tt.input)\n\t\t\tif !strings.Contains(got, tt.contains) {\n\t\t\t\tt.Errorf(\"expected to contain %q, got %q\", tt.contains, got)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestFormatLLMContent_AssistantTextAndTool(t *testing.T) {\n\tinput := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"Let me read the file.\"},{\"type\":\"tool_use\",\"name\":\"Read\",\"input\":{\"file_path\":\"/workspace/main.go\"}}]}}`\n\tgot := FormatLLMContent(input)\n\tif !strings.Contains(got, \"Let me read the file.\") {\n\t\tt.Errorf(\"expected text, got %q\", got)\n\t}\n\tif !strings.Contains(got, \"Read /workspace/main.go\") {\n\t\tt.Errorf(\"expected tool summary, got %q\", got)\n\t}\n}\n\nfunc TestFormatLLMContent_ResultEvent(t *testing.T) {\n\tinput := `{\"type\":\"result\",\"subtype\":\"success\",\"duration_ms\":57032,\"num_turns\":10,\"total_cost_usd\":0.1864}`\n\tgot := FormatLLMContent(input)\n\tif !strings.Contains(got, \"Result: success\") {\n\t\tt.Errorf(\"expected result summary, got %q\", got)\n\t}\n\tif !strings.Contains(got, \"10 turns\") {\n\t\tt.Errorf(\"expected turns, got %q\", got)\n\t}\n\tif !strings.Contains(got, \"57.0s\") {\n\t\tt.Errorf(\"expected duration, got %q\", got)\n\t}\n\tif !strings.Contains(got, \"$0.1864\") {\n\t\tt.Errorf(\"expected cost, got %q\", got)\n\t}\n}\n\nfunc TestFormatLLMContent_BashTruncation(t *testing.T) {\n\tlongCmd := strings.Repeat(\"x\", 200)\n\tinput := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"Bash\",\"input\":{\"command\":\"` + longCmd + `\"}}]}}`\n\tgot := FormatLLMContent(input)\n\tif !strings.HasSuffix(got, \"...\") {\n\t\tt.Errorf(\"expected truncated command, got %q\", got)\n\t}\n\tif len(got) > 200 {\n\t\t// The prefix \"⚙ Bash: \" is ~10 chars, plus 120 chars + \"...\" = ~133\n\t\t// This is a rough check\n\t}\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,