{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DnNApe1yaWWC7Dh7UNJVAh","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"net/url\"\n    13→\t\"os\"\n    14→\t\"os/exec\"\n    15→\t\"path/filepath\"\n    16→\t\"regexp\"\n    17→\t\"sort\"\n    18→\t\"strconv\"\n    19→\t\"strings\"\n    20→\t\"time\"\n    21→\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    24→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    25→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    26→)\n    27→\n    28→// HandlerOption configures optional Handler dependencies.\n    29→type HandlerOption func(*Handler)\n    30→\n    31→// WithContainerLogger sets the container runtime for fetching live logs.\n    32→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    33→\treturn func(h *Handler) { h.container = c }\n    34→}\n    35→\n    36→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    37→func WithContainerManager(c ContainerManager) HandlerOption {\n    38→\treturn func(h *Handler) { h.container = c }\n    39→}\n    40→\n    41→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    42→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    43→\treturn func(h *Handler) { h.logBroadcast = b }\n    44→}\n    45→\n    46→// WithLogStore sets the log store for indexed log file lookups.\n    47→func WithLogStore(ls ports.LogStore) HandlerOption {\n    48→\treturn func(h *Handler) { h.logStore = ls }\n    49→}\n    50→\n    51→//go:embed templates/*.html static/*\n    52→var content embed.FS\n    53→\n    54→// Handler serves the web dashboard.\n    55→// ContainerLogger can retrieve logs from a container by ID.\n    56→type ContainerLogger interface {\n    57→\tLogs(ctx context.Context, containerID string) (string, error)\n    58→}\n    59→\n    60→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    61→type ContainerManager interface {\n    62→\tContainerLogger\n    63→\tStop(ctx context.Context, containerID string) error\n    64→\tRemove(ctx context.Context, containerID string) error\n    65→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    66→}\n    67→\n    68→type Handler struct {\n    69→\tstore        ports.RunStore\n    70→\tcaptures     ports.CaptureStore\n    71→\tlogStore     ports.LogStore\n    72→\tcontainer    ContainerLogger\n    73→\tlogBroadcast *logstream.Broadcaster\n    74→\tpages        map[string]*template.Template\n    75→\tmux          *http.ServeMux\n    76→}\n    77→\n    78→// NewHandler creates a web dashboard handler.\n    79→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    80→\tfuncMap := template.FuncMap{\n    81→\t\t\"stateColor\":       stateColor,\n    82→\t\t\"healthColor\":      healthColor,\n    83→\t\t\"formatTime\":       formatTime,\n    84→\t\t\"formatDuration\":   formatDuration,\n    85→\t\t\"formatRunTiming\":  formatRunTiming,\n    86→\t\t\"truncate\":         truncate,\n    87→\t\t\"shortContainerID\": shortContainerID,\n    88→\t}\n    89→\n    90→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n    91→\tif err != nil {\n    92→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n    93→\t}\n    94→\n    95→\tpages := map[string]*template.Template{}\n    96→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n    97→\t\tclone, err := base.Clone()\n    98→\t\tif err != nil {\n    99→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   100→\t\t}\n   101→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   102→\t\tif err != nil {\n   103→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   104→\t\t}\n   105→\t\tpages[page] = clone\n   106→\t}\n   107→\n   108→\th := &Handler{\n   109→\t\tstore:    store,\n   110→\t\tcaptures: captures,\n   111→\t\tpages:    pages,\n   112→\t\tmux:      http.NewServeMux(),\n   113→\t}\n   114→\tfor _, opt := range opts {\n   115→\t\topt(h)\n   116→\t}\n   117→\n   118→\tstaticFS, err := fs.Sub(content, \"static\")\n   119→\tif err != nil {\n   120→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   121→\t}\n   122→\n   123→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   124→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   125→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   126→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   127→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   128→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   129→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   130→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   131→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   132→\th.mux.HandleFunc(\"POST /api/runs/{id}/stop\", h.handleAPIStopRun)\n   133→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   134→\th.mux.HandleFunc(\"DELETE /api/projects/{name}/containers\", h.handleAPIDeleteProjectContainers)\n   135→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   136→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   137→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   138→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   139→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   140→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   141→\n   142→\treturn h, nil\n   143→}\n   144→\n   145→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   146→\th.mux.ServeHTTP(w, r)\n   147→}\n   148→\n   149→// --- HTML handlers ---\n   150→\n   151→// projectOverviewEntry holds data for a single project card on the landing page.\n   152→type projectOverviewEntry struct {\n   153→\tDir         string\n   154→\tLabel       string\n   155→\tHealth      domain.HealthResult\n   156→\tRecentRuns  []recentRunDot\n   157→\tActiveCount int\n   158→}\n   159→\n   160→// recentRunDot is a minimal representation of a run for the mini history display.\n   161→type recentRunDot struct {\n   162→\tID    string\n   163→\tState string\n   164→}\n   165→\n   166→const healthWindowSize = 10\n   167→\n   168→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   169→\tprojects, _ := h.store.ListProjects(r.Context())\n   170→\tlabels := projectLabels(projects)\n   171→\n   172→\tvar entries []projectOverviewEntry\n   173→\tfor _, dir := range projects {\n   174→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   175→\t\tif err != nil {\n   176→\t\t\tcontinue\n   177→\t\t}\n   178→\n   179→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   180→\t\trunValues := make([]domain.Run, len(runs))\n   181→\t\tfor i, rr := range runs {\n   182→\t\t\trunValues[i] = *rr\n   183→\t\t}\n   184→\n   185→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   186→\n   187→\t\t// Take the last N runs for the mini history (most recent first).\n   188→\t\tn := healthWindowSize\n   189→\t\tif n > len(runs) {\n   190→\t\t\tn = len(runs)\n   191→\t\t}\n   192→\t\tdots := make([]recentRunDot, n)\n   193→\t\tfor i := 0; i < n; i++ {\n   194→\t\t\tdots[i] = recentRunDot{\n   195→\t\t\t\tID:    runs[i].ID,\n   196→\t\t\t\tState: string(runs[i].State),\n   197→\t\t\t}\n   198→\t\t}\n   199→\n   200→\t\tvar activeCount int\n   201→\t\tfor _, rr := range runs {\n   202→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   203→\t\t\t\tactiveCount++\n   204→\t\t\t}\n   205→\t\t}\n   206→\n   207→\t\tentries = append(entries, projectOverviewEntry{\n   208→\t\t\tDir:         dir,\n   209→\t\t\tLabel:       labels[dir],\n   210→\t\t\tHealth:      health,\n   211→\t\t\tRecentRuns:  dots,\n   212→\t\t\tActiveCount: activeCount,\n   213→\t\t})\n   214→\t}\n   215→\n   216→\tsort.Slice(entries, func(i, j int) bool {\n   217→\t\treturn entries[i].Label < entries[j].Label\n   218→\t})\n   219→\n   220→\tdata := map[string]any{\n   221→\t\t\"Title\":    \"Projects\",\n   222→\t\t\"Projects\": entries,\n   223→\t}\n   224→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   225→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   226→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   227→\t}\n   228→}\n   229→\n   230→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   231→\tprojectFilter := r.URL.Query().Get(\"project\")\n   232→\n   233→\tvar runs []*domain.Run\n   234→\tvar err error\n   235→\tif projectFilter != \"\" {\n   236→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   237→\t} else {\n   238→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   239→\t}\n   240→\tif err != nil {\n   241→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   242→\t\treturn\n   243→\t}\n   244→\n   245→\tprojects, _ := h.store.ListProjects(r.Context())\n   246→\tlabels := projectLabels(projects)\n   247→\n   248→\t// Count retained containers per project\n   249→\tcontainerCounts := map[string]int{}\n   250→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   251→\tfor _, run := range allRuns {\n   252→\t\tif run.ContainerKept {\n   253→\t\t\tcontainerCounts[run.ProjectDir]++\n   254→\t\t}\n   255→\t}\n   256→\n   257→\tvar projectList []projectEntry\n   258→\tfor _, dir := range projects {\n   259→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   260→\t}\n   261→\tsort.Slice(projectList, func(i, j int) bool {\n   262→\t\treturn projectList[i].Label < projectList[j].Label\n   263→\t})\n   264→\n   265→\tdata := map[string]any{\n   266→\t\t\"Title\":         \"Runs\",\n   267→\t\t\"Runs\":          runs,\n   268→\t\t\"Projects\":      projectList,\n   269→\t\t\"ProjectFilter\": projectFilter,\n   270→\t\t\"ProjectLabels\": labels,\n   271→\t}\n   272→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   273→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   274→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   275→\t}\n   276→}\n   277→\n   278→// handleProjectRuns redirects /projects/{name}/runs to /runs?project=<dir>.\n   279→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   280→\tdir, _, ok := h.resolveProjectDir(w, r)\n   281→\tif !ok {\n   282→\t\treturn\n   283→\t}\n   284→\thttp.Redirect(w, r, \"/runs?project=\"+url.QueryEscape(dir), http.StatusFound)\n   285→}\n   286→\n   287→// stepEntry is a merged view of a step execution for the template.\n   288→type stepEntry struct {\n   289→\tIndex     int\n   290→\tStepName  string\n   291→\tResult    string\n   292→\tStartedAt time.Time\n   293→\tDuration  string\n   294→}\n   295→\n   296→// mergeCaptures collapses started/completed capture pairs into single entries.\n   297→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   298→\tvar entries []stepEntry\n   299→\t// Track pending started rows by step name (LIFO for retries)\n   300→\tpending := map[string]*domain.StepExecution{}\n   301→\n   302→\tfor _, c := range caps {\n   303→\t\tif c.Result == \"\" {\n   304→\t\t\t// step_started row\n   305→\t\t\tpending[c.StepName] = c\n   306→\t\t\tcontinue\n   307→\t\t}\n   308→\t\t// step_completed row — merge with pending started if available\n   309→\t\tstartedAt := c.StartedAt\n   310→\t\tif started := pending[c.StepName]; started != nil {\n   311→\t\t\tstartedAt = started.StartedAt\n   312→\t\t\tdelete(pending, c.StepName)\n   313→\t\t}\n   314→\t\tentries = append(entries, stepEntry{\n   315→\t\t\tIndex:     len(entries),\n   316→\t\t\tStepName:  c.StepName,\n   317→\t\t\tResult:    c.Result,\n   318→\t\t\tStartedAt: startedAt,\n   319→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   320→\t\t})\n   321→\t}\n   322→\n   323→\t// Append any started-but-not-completed steps (still running)\n   324→\tfor _, c := range caps {\n   325→\t\tif c.Result == \"\" {\n   326→\t\t\tif _, used := pending[c.StepName]; !used {\n   327→\t\t\t\tcontinue\n   328→\t\t\t}\n   329→\t\t\tentries = append(entries, stepEntry{\n   330→\t\t\t\tIndex:     len(entries),\n   331→\t\t\t\tStepName:  c.StepName,\n   332→\t\t\t\tStartedAt: c.StartedAt,\n   333→\t\t\t})\n   334→\t\t\tdelete(pending, c.StepName)\n   335→\t\t}\n   336→\t}\n   337→\n   338→\treturn entries\n   339→}\n   340→\n   341→// containerState inspects the container for a run and returns one of:\n   342→//   - \"running\"   – container exists and is running\n   343→//   - \"stopped\"   – container exists, not running, not kept\n   344→//   - \"available\" – container exists, not running, kept (can be deleted)\n   345→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   346→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   347→\tif run.ContainerID == \"\" {\n   348→\t\treturn \"removed\"\n   349→\t}\n   350→\tmgr, ok := h.container.(ContainerManager)\n   351→\tif !ok {\n   352→\t\treturn \"removed\"\n   353→\t}\n   354→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   355→\tif err != nil {\n   356→\t\treturn \"removed\"\n   357→\t}\n   358→\tif status.Running {\n   359→\t\treturn \"running\"\n   360→\t}\n   361→\tif run.ContainerKept {\n   362→\t\treturn \"available\"\n   363→\t}\n   364→\treturn \"stopped\"\n   365→}\n   366→\n   367→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   368→\tid := r.PathValue(\"id\")\n   369→\n   370→\trun, err := h.store.GetRun(r.Context(), id)\n   371→\tif err != nil {\n   372→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   373→\t\treturn\n   374→\t}\n   375→\n   376→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   377→\tif err != nil {\n   378→\t\tcaps = nil // non-fatal\n   379→\t}\n   380→\n   381→\tsteps := mergeCaptures(caps)\n   382→\n   383→\t// Fetch parent run if this is a child\n   384→\tvar parentRun *domain.Run\n   385→\tif run.ParentRunID != \"\" {\n   386→\t\tparentRun, _ = h.store.GetRun(r.Context(), run.ParentRunID)\n   387→\t}\n   388→\n   389→\t// Fetch child runs\n   390→\tchildRuns, _ := h.store.ListChildRuns(r.Context(), id)\n   391→\n   392→\tdata := map[string]any{\n   393→\t\t\"Title\":          \"Run \" + run.ID,\n   394→\t\t\"Run\":            run,\n   395→\t\t\"Steps\":          steps,\n   396→\t\t\"Page\":           \"detail\",\n   397→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   398→\t\t\"ParentRun\":      parentRun,\n   399→\t\t\"ChildRuns\":      childRuns,\n   400→\t}\n   401→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   402→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   403→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   404→\t}\n   405→}\n   406→\n   407→// --- JSON API handlers ---\n   408→\n   409→type apiRun struct {\n   410→\tID           string `json:\"id\"`\n   411→\tWorkflowName string `json:\"workflow_name\"`\n   412→\tProjectDir   string `json:\"project_dir\"`\n   413→\tProjectLabel string `json:\"project_label\"`\n   414→\tState        string `json:\"state\"`\n   415→\tStartedAt    string `json:\"started_at\"`\n   416→\tCompletedAt  string `json:\"completed_at\"`\n   417→\tTiming       string `json:\"timing\"`\n   418→\tContainerID  string `json:\"container_id\"`\n   419→\tErrorMessage string `json:\"error_message\"`\n   420→\tTitle        string `json:\"title\"`\n   421→\tIsHost       bool   `json:\"is_host\"`\n   422→\tParentRunID  string `json:\"parent_run_id,omitempty\"`\n   423→}\n   424→\n   425→type apiStep struct {\n   426→\tStepName    string `json:\"step_name\"`\n   427→\tResult      string `json:\"result\"`\n   428→\tStartedAt   string `json:\"started_at\"`\n   429→\tCompletedAt string `json:\"completed_at\"`\n   430→\tDuration    string `json:\"duration\"`\n   431→}\n   432→\n   433→type apiRunDetail struct {\n   434→\tapiRun\n   435→\tContainerState string    `json:\"container_state\"`\n   436→\tSteps          []apiStep `json:\"steps\"`\n   437→\tChildRuns      []apiRun  `json:\"child_runs,omitempty\"`\n   438→}\n   439→\n   440→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   441→\treturn apiRun{\n   442→\t\tID:           r.ID,\n   443→\t\tWorkflowName: r.WorkflowName,\n   444→\t\tProjectDir:   r.ProjectDir,\n   445→\t\tProjectLabel: labels[r.ProjectDir],\n   446→\t\tState:        string(r.State),\n   447→\t\tStartedAt:    formatTime(r.StartedAt),\n   448→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   449→\t\tTiming:       formatRunTiming(r.State, r.StartedAt, r.CompletedAt),\n   450→\t\tContainerID:  r.ContainerID,\n   451→\t\tErrorMessage: r.ErrorMessage,\n   452→\t\tTitle:        r.Title,\n   453→\t\tIsHost:       r.IsHost,\n   454→\t\tParentRunID:  r.ParentRunID,\n   455→\t}\n   456→}\n   457→\n   458→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   459→\tprojectFilter := r.URL.Query().Get(\"project\")\n   460→\n   461→\tvar runs []*domain.Run\n   462→\tvar err error\n   463→\tif projectFilter != \"\" {\n   464→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   465→\t} else {\n   466→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   467→\t}\n   468→\tif err != nil {\n   469→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   470→\t\treturn\n   471→\t}\n   472→\n   473→\tprojects, _ := h.store.ListProjects(r.Context())\n   474→\tlabels := projectLabels(projects)\n   475→\n   476→\tresult := make([]apiRun, len(runs))\n   477→\tfor i, run := range runs {\n   478→\t\tresult[i] = toAPIRun(run, labels)\n   479→\t}\n   480→\n   481→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   482→\tjson.NewEncoder(w).Encode(result)\n   483→}\n   484→\n   485→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   486→\tprojects, err := h.store.ListProjects(r.Context())\n   487→\tif err != nil {\n   488→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   489→\t\treturn\n   490→\t}\n   491→\tlabels := projectLabels(projects)\n   492→\n   493→\ttype apiHealth struct {\n   494→\t\tStatus string `json:\"status\"`\n   495→\t\tPassed int    `json:\"passed\"`\n   496→\t\tFailed int    `json:\"failed\"`\n   497→\t\tTotal  int    `json:\"total\"`\n   498→\t}\n   499→\ttype apiProject struct {\n   500→\t\tDir         string    `json:\"dir\"`\n   501→\t\tLabel       string    `json:\"label\"`\n   502→\t\tHealth      apiHealth `json:\"health\"`\n   503→\t\tActiveCount int       `json:\"active_count\"`\n   504→\t}\n   505→\tresult := make([]apiProject, len(projects))\n   506→\tfor i, dir := range projects {\n   507→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   508→\t\trunValues := make([]domain.Run, len(runs))\n   509→\t\tfor j, rr := range runs {\n   510→\t\t\trunValues[j] = *rr\n   511→\t\t}\n   512→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   513→\t\tvar activeCount int\n   514→\t\tfor _, rr := range runs {\n   515→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   516→\t\t\t\tactiveCount++\n   517→\t\t\t}\n   518→\t\t}\n   519→\t\tresult[i] = apiProject{\n   520→\t\t\tDir:   dir,\n   521→\t\t\tLabel: labels[dir],\n   522→\t\t\tHealth: apiHealth{\n   523→\t\t\t\tStatus: string(health.Status),\n   524→\t\t\t\tPassed: health.Passed,\n   525→\t\t\t\tFailed: health.Failed,\n   526→\t\t\t\tTotal:  health.Total,\n   527→\t\t\t},\n   528→\t\t\tActiveCount: activeCount,\n   529→\t\t}\n   530→\t}\n   531→\n   532→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   533→\tjson.NewEncoder(w).Encode(result)\n   534→}\n   535→\n   536→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   537→\tid := r.PathValue(\"id\")\n   538→\n   539→\trun, err := h.store.GetRun(r.Context(), id)\n   540→\tif err != nil {\n   541→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   542→\t\treturn\n   543→\t}\n   544→\n   545→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   546→\tif err != nil {\n   547→\t\tcaps = nil\n   548→\t}\n   549→\n   550→\tprojects, _ := h.store.ListProjects(r.Context())\n   551→\tlabels := projectLabels(projects)\n   552→\n   553→\tmerged := mergeCaptures(caps)\n   554→\tsteps := make([]apiStep, len(merged))\n   555→\tfor i, e := range merged {\n   556→\t\tsteps[i] = apiStep{\n   557→\t\t\tStepName:  e.StepName,\n   558→\t\t\tResult:    e.Result,\n   559→\t\t\tStartedAt: formatTime(e.StartedAt),\n   560→\t\t\tDuration:  e.Duration,\n   561→\t\t}\n   562→\t}\n   563→\n   564→\t// Fetch child runs for the API response\n   565→\tvar apiChildren []apiRun\n   566→\tif children, err := h.store.ListChildRuns(r.Context(), id); err == nil {\n   567→\t\tfor _, c := range children {\n   568→\t\t\tapiChildren = append(apiChildren, toAPIRun(c, labels))\n   569→\t\t}\n   570→\t}\n   571→\n   572→\tdetail := apiRunDetail{\n   573→\t\tapiRun:         toAPIRun(run, labels),\n   574→\t\tContainerState: h.containerState(r.Context(), run),\n   575→\t\tSteps:          steps,\n   576→\t\tChildRuns:      apiChildren,\n   577→\t}\n   578→\n   579→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   580→\tjson.NewEncoder(w).Encode(detail)\n   581→}\n   582→\n   583→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   584→\tid := r.PathValue(\"id\")\n   585→\tstep := r.PathValue(\"step\")\n   586→\tlogType := r.URL.Query().Get(\"type\")   // optional: \"script\", \"llm\"\n   587→\tformat := r.URL.Query().Get(\"format\")  // optional: \"raw\" to skip parsing\n   588→\n   589→\trun, err := h.store.GetRun(r.Context(), id)\n   590→\tif err != nil {\n   591→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   592→\t\treturn\n   593→\t}\n   594→\n   595→\twriteOutput := func(data []byte) {\n   596→\t\tif format != \"raw\" {\n   597→\t\t\tdata = logstream.ParseClaudeStream(data)\n   598→\t\t}\n   599→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   600→\t\tw.Write(data)\n   601→\t}\n   602→\n   603→\t// Try log index first for fast lookup\n   604→\tif h.logStore != nil {\n   605→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   606→\t\tif err == nil && len(logFiles) > 0 {\n   607→\t\t\t// If type filter specified, narrow results\n   608→\t\t\tfor _, lf := range logFiles {\n   609→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   610→\t\t\t\t\tcontinue\n   611→\t\t\t\t}\n   612→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   613→\t\t\t\tif readErr == nil && len(data) > 0 {\n   614→\t\t\t\t\twriteOutput(data)\n   615→\t\t\t\t\treturn\n   616→\t\t\t\t}\n   617→\t\t\t}\n   618→\t\t}\n   619→\t}\n   620→\n   621→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   622→\n   623→\t// Fall back to file path conventions\n   624→\t// If type is \"llm\", try llm-<step>.log\n   625→\tif logType == \"llm\" {\n   626→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   627→\t\tdata, err := os.ReadFile(llmPath)\n   628→\t\tif err == nil && len(data) > 0 {\n   629→\t\t\twriteOutput(data)\n   630→\t\t\treturn\n   631→\t\t}\n   632→\t}\n   633→\n   634→\t// Try per-step output file\n   635→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   636→\tdata, err := os.ReadFile(outputPath)\n   637→\tif err == nil && len(data) > 0 {\n   638→\t\twriteOutput(data)\n   639→\t\treturn\n   640→\t}\n   641→\n   642→\t// Do NOT fall back to container.log or live docker logs here — those\n   643→\t// contain unfiltered output from ALL steps and would show the wrong\n   644→\t// content for this specific step (the root cause of web-UI log mismatches).\n   645→\n   646→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   647→}\n   648→\n   649→func (h *Handler) handleAPIStopRun(w http.ResponseWriter, r *http.Request) {\n   650→\tid := r.PathValue(\"id\")\n   651→\n   652→\trun, err := h.store.GetRun(r.Context(), id)\n   653→\tif err != nil {\n   654→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   655→\t\tw.WriteHeader(http.StatusNotFound)\n   656→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   657→\t\treturn\n   658→\t}\n   659→\n   660→\t// Only allow stopping active runs\n   661→\tif run.State != domain.RunStatePending && run.State != domain.RunStateRunning {\n   662→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   663→\t\tw.WriteHeader(http.StatusBadRequest)\n   664→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run is not active\"})\n   665→\t\treturn\n   666→\t}\n   667→\n   668→\tmgr, ok := h.container.(ContainerManager)\n   669→\tif !ok || run.ContainerID == \"\" {\n   670→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   671→\t\tw.WriteHeader(http.StatusBadRequest)\n   672→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   673→\t\treturn\n   674→\t}\n   675→\n   676→\tif err := mgr.Stop(r.Context(), run.ContainerID); err != nil {\n   677→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   678→\t\tw.WriteHeader(http.StatusInternalServerError)\n   679→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to stop run: %v\", err)})\n   680→\t\treturn\n   681→\t}\n   682→\n   683→\trun.Complete(domain.RunStateCancelled)\n   684→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   685→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   686→\t\tw.WriteHeader(http.StatusInternalServerError)\n   687→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   688→\t\treturn\n   689→\t}\n   690→\n   691→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   692→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   693→}\n   694→\n   695→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   696→\tid := r.PathValue(\"id\")\n   697→\n   698→\trun, err := h.store.GetRun(r.Context(), id)\n   699→\tif err != nil {\n   700→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   701→\t\tw.WriteHeader(http.StatusNotFound)\n   702→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   703→\t\treturn\n   704→\t}\n   705→\n   706→\tmgr, ok := h.container.(ContainerManager)\n   707→\tif !ok || run.ContainerID == \"\" {\n   708→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   709→\t\tw.WriteHeader(http.StatusBadRequest)\n   710→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   711→\t\treturn\n   712→\t}\n   713→\n   714→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   715→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   716→\t\tw.WriteHeader(http.StatusInternalServerError)\n   717→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   718→\t\treturn\n   719→\t}\n   720→\n   721→\trun.ContainerKept = false\n   722→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   723→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   724→\t\tw.WriteHeader(http.StatusInternalServerError)\n   725→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   726→\t\treturn\n   727→\t}\n   728→\n   729→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   730→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   731→}\n   732→\n   733→// handleAPIDeleteProjectContainers mass-deletes all retained/exited containers for a project.\n   734→func (h *Handler) handleAPIDeleteProjectContainers(w http.ResponseWriter, r *http.Request) {\n   735→\tdir, _, ok := h.resolveProjectDir(w, r)\n   736→\tif !ok {\n   737→\t\treturn\n   738→\t}\n   739→\n   740→\tmgr, ok := h.container.(ContainerManager)\n   741→\tif !ok {\n   742→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   743→\t\tw.WriteHeader(http.StatusBadRequest)\n   744→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   745→\t\treturn\n   746→\t}\n   747→\n   748→\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   749→\tif err != nil {\n   750→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   751→\t\tw.WriteHeader(http.StatusInternalServerError)\n   752→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"failed to list runs\"})\n   753→\t\treturn\n   754→\t}\n   755→\n   756→\tvar deleted int\n   757→\tvar errors []string\n   758→\tfor _, run := range runs {\n   759→\t\tif !run.ContainerKept || run.ContainerID == \"\" {\n   760→\t\t\tcontinue\n   761→\t\t}\n   762→\t\t// Check container is not running\n   763→\t\tstatus, err := mgr.Inspect(r.Context(), run.ContainerID)\n   764→\t\tif err != nil {\n   765→\t\t\t// Container already gone — just clear the flag\n   766→\t\t\trun.ContainerKept = false\n   767→\t\t\th.store.UpdateRun(r.Context(), run)\n   768→\t\t\tdeleted++\n   769→\t\t\tcontinue\n   770→\t\t}\n   771→\t\tif status.Running {\n   772→\t\t\tcontinue // skip running containers\n   773→\t\t}\n   774→\t\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   775→\t\t\terrors = append(errors, fmt.Sprintf(\"%s: %v\", run.ID, err))\n   776→\t\t\tcontinue\n   777→\t\t}\n   778→\t\trun.ContainerKept = false\n   779→\t\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   780→\t\t\terrors = append(errors, fmt.Sprintf(\"%s: update failed: %v\", run.ID, err))\n   781→\t\t\tcontinue\n   782→\t\t}\n   783→\t\tdeleted++\n   784→\t}\n   785→\n   786→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   787→\tresp := map[string]any{\"deleted\": deleted}\n   788→\tif len(errors) > 0 {\n   789→\t\tresp[\"errors\"] = errors\n   790→\t}\n   791→\tjson.NewEncoder(w).Encode(resp)\n   792→}\n   793→\n   794→// handleAPIStream serves an SSE stream of log lines for a run.\n   795→// For active runs, it subscribes to the live broadcaster.\n   796→// For completed runs, it serves the archived full.log then closes.\n   797→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   798→\tid := r.PathValue(\"id\")\n   799→\n   800→\trun, err := h.store.GetRun(r.Context(), id)\n   801→\tif err != nil {\n   802→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   803→\t\treturn\n   804→\t}\n   805→\n   806→\tflusher, ok := w.(http.Flusher)\n   807→\tif !ok {\n   808→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   809→\t\treturn\n   810→\t}\n   811→\n   812→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   813→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   814→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   815→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   816→\n   817→\tisComplete := run.State == domain.RunStateSucceeded ||\n   818→\t\trun.State == domain.RunStateFailed ||\n   819→\t\trun.State == domain.RunStateCancelled\n   820→\n   821→\tif isComplete {\n   822→\t\t// Serve archived full.log\n   823→\t\th.streamFullLog(w, flusher, run)\n   824→\t\t// Send done event\n   825→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   826→\t\tflusher.Flush()\n   827→\t\treturn\n   828→\t}\n   829→\n   830→\t// Active run: subscribe to live broadcaster\n   831→\tif h.logBroadcast == nil {\n   832→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   833→\t\treturn\n   834→\t}\n   835→\n   836→\tsub := h.logBroadcast.Subscribe(id)\n   837→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   838→\n   839→\tctx := r.Context()\n   840→\tfor {\n   841→\t\tselect {\n   842→\t\tcase <-ctx.Done():\n   843→\t\t\treturn\n   844→\t\tcase line, ok := <-sub.C:\n   845→\t\t\tif !ok {\n   846→\t\t\t\t// Stream finished (run completed)\n   847→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   848→\t\t\t\tflusher.Flush()\n   849→\t\t\t\treturn\n   850→\t\t\t}\n   851→\t\t\tline = parseLLMLogLine(line)\n   852→\t\t\tif line.Type == \"\" {\n   853→\t\t\t\tcontinue // skip protocol-only llm lines\n   854→\t\t\t}\n   855→\t\t\tdata, _ := json.Marshal(line)\n   856→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   857→\t\t\tflusher.Flush()\n   858→\t\t}\n   859→\t}\n   860→}\n   861→\n   862→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   863→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   864→\n   865→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   866→// LLM-type lines are parsed from raw Claude JSON into human-readable text.\n   867→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   868→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   869→\tf, err := os.Open(logPath)\n   870→\tif err != nil {\n   871→\t\treturn\n   872→\t}\n   873→\tdefer f.Close()\n   874→\n   875→\tscanner := bufio.NewScanner(f)\n   876→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large Claude JSON lines\n   877→\tfor scanner.Scan() {\n   878→\t\ttext := scanner.Text()\n   879→\t\tline := parseFullLogLine(text)\n   880→\t\tline = parseLLMLogLine(line)\n   881→\t\tif line.Type == \"\" {\n   882→\t\t\tcontinue // skip protocol-only llm lines\n   883→\t\t}\n   884→\t\tdata, _ := json.Marshal(line)\n   885→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   886→\t\tflusher.Flush()\n   887→\t}\n   888→}\n   889→\n   890→// parseLLMLogLine parses a LogLine whose type is \"llm\". If the content is\n   891→// Claude stream JSON, it extracts the human-readable text. Protocol-only\n   892→// events return a LogLine with an empty Type (caller should skip it).\n   893→// Non-llm lines are returned unchanged.\n   894→func parseLLMLogLine(line logstream.LogLine) logstream.LogLine {\n   895→\tif line.Type != \"llm\" {\n   896→\t\treturn line\n   897→\t}\n   898→\ttext, ok := logstream.ParseClaudeLine([]byte(line.Content))\n   899→\tif !ok {\n   900→\t\treturn logstream.LogLine{} // signal to skip\n   901→\t}\n   902→\tline.Content = text\n   903→\treturn line\n   904→}\n   905→\n   906→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   907→func parseFullLogLine(text string) logstream.LogLine {\n   908→\tm := logLineRegex.FindStringSubmatch(text)\n   909→\tif m == nil {\n   910→\t\treturn logstream.LogLine{\n   911→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   912→\t\t\tType:      \"script\",\n   913→\t\t\tContent:   text,\n   914→\t\t}\n   915→\t}\n   916→\treturn logstream.LogLine{\n   917→\t\tTimestamp: m[1],\n   918→\t\tType:      m[2],\n   919→\t\tContent:   m[3],\n   920→\t}\n   921→}\n   922→\n   923→// --- Project detail handlers ---\n   924→\n   925→// resolveProjectDir resolves a project label from the URL to its directory path.\n   926→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   927→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   928→\tlabel := r.PathValue(\"name\")\n   929→\tprojects, _ := h.store.ListProjects(r.Context())\n   930→\tlabels := projectLabels(projects)\n   931→\tfor dir, l := range labels {\n   932→\t\tif l == label {\n   933→\t\t\treturn dir, label, true\n   934→\t\t}\n   935→\t}\n   936→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   937→\tw.WriteHeader(http.StatusNotFound)\n   938→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   939→\treturn \"\", \"\", false\n   940→}\n   941→\n   942→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   943→\tdir, label, ok := h.resolveProjectDir(w, r)\n   944→\tif !ok {\n   945→\t\treturn\n   946→\t}\n   947→\n   948→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   949→\tn := 10\n   950→\tif n > len(runs) {\n   951→\t\tn = len(runs)\n   952→\t}\n   953→\tdots := make([]recentRunDot, n)\n   954→\tfor i := 0; i < n; i++ {\n   955→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   956→\t}\n   957→\n   958→\tvar containerCount int\n   959→\tfor _, run := range runs {\n   960→\t\tif run.ContainerKept {\n   961→\t\t\tcontainerCount++\n   962→\t\t}\n   963→\t}\n   964→\n   965→\tdata := map[string]any{\n   966→\t\t\"Title\":          label,\n   967→\t\t\"Label\":          label,\n   968→\t\t\"Dir\":            dir,\n   969→\t\t\"RecentRuns\":     dots,\n   970→\t\t\"ContainerCount\": containerCount,\n   971→\t}\n   972→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   973→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   974→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   975→\t}\n   976→}\n   977→\n   978→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   979→\tdir, _, ok := h.resolveProjectDir(w, r)\n   980→\tif !ok {\n   981→\t\treturn\n   982→\t}\n   983→\n   984→\t// Docker image: read FROM line from Dockerfile\n   985→\tdockerImage := \"\"\n   986→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   987→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   988→\t\t// Find the last FROM line (final stage)\n   989→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   990→\t\t\ttrimmed := strings.TrimSpace(line)\n   991→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   992→\t\t\t\tparts := strings.Fields(trimmed)\n   993→\t\t\t\tif len(parts) >= 2 {\n   994→\t\t\t\t\tdockerImage = parts[1]\n   995→\t\t\t\t}\n   996→\t\t\t}\n   997→\t\t}\n   998→\t}\n   999→\n  1000→\t// Version\n  1001→\tversion := 0\n  1002→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n  1003→\tif data, err := os.ReadFile(versionPath); err == nil {\n  1004→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n  1005→\t\t\tversion = v\n  1006→\t\t}\n  1007→\t}\n  1008→\n  1009→\t// Prompt files history\n  1010→\ttype commitEntry struct {\n  1011→\t\tSHA     string `json:\"sha\"`\n  1012→\t\tDate    string `json:\"date\"`\n  1013→\t\tMessage string `json:\"message\"`\n  1014→\t}\n  1015→\ttype promptFile struct {\n  1016→\t\tPath    string        `json:\"path\"`\n  1017→\t\tHistory []commitEntry `json:\"history\"`\n  1018→\t}\n  1019→\n  1020→\tvar promptFiles []promptFile\n  1021→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n  1022→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n  1023→\t\tfor _, e := range entries {\n  1024→\t\t\tif e.IsDir() {\n  1025→\t\t\t\tcontinue\n  1026→\t\t\t}\n  1027→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n  1028→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n  1029→\t\t\tcmd.Dir = dir\n  1030→\t\t\tout, err := cmd.Output()\n  1031→\t\t\tif err != nil {\n  1032→\t\t\t\tcontinue\n  1033→\t\t\t}\n  1034→\t\t\tvar history []commitEntry\n  1035→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n  1036→\t\t\t\tif line == \"\" {\n  1037→\t\t\t\t\tcontinue\n  1038→\t\t\t\t}\n  1039→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1040→\t\t\t\tif len(parts) < 3 {\n  1041→\t\t\t\t\tcontinue\n  1042→\t\t\t\t}\n  1043→\t\t\t\t// Parse date to short form\n  1044→\t\t\t\tdateStr := parts[1]\n  1045→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1046→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1047→\t\t\t\t}\n  1048→\t\t\t\thistory = append(history, commitEntry{\n  1049→\t\t\t\t\tSHA:     parts[0][:7],\n  1050→\t\t\t\t\tDate:    dateStr,\n  1051→\t\t\t\t\tMessage: parts[2],\n  1052→\t\t\t\t})\n  1053→\t\t\t}\n  1054→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1055→\t\t}\n  1056→\t}\n  1057→\n  1058→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1059→\tjson.NewEncoder(w).Encode(map[string]any{\n  1060→\t\t\"docker_image\": dockerImage,\n  1061→\t\t\"version\":      version,\n  1062→\t\t\"prompt_files\": promptFiles,\n  1063→\t})\n  1064→}\n  1065→\n  1066→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1067→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1068→\tif !ok {\n  1069→\t\treturn\n  1070→\t}\n  1071→\tfile := r.URL.Query().Get(\"file\")\n  1072→\tsha := r.URL.Query().Get(\"sha\")\n  1073→\tif file == \"\" || sha == \"\" {\n  1074→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1075→\t\treturn\n  1076→\t}\n  1077→\n  1078→\t// Validate sha is alphanumeric to prevent injection\n  1079→\tfor _, c := range sha {\n  1080→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1081→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1082→\t\t\treturn\n  1083→\t\t}\n  1084→\t}\n  1085→\n  1086→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1087→\tcmd.Dir = dir\n  1088→\tout, err := cmd.Output()\n  1089→\tif err != nil {\n  1090→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1091→\t\treturn\n  1092→\t}\n  1093→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1094→\tw.Write(out)\n  1095→}\n  1096→\n  1097→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1098→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1099→\tif !ok {\n  1100→\t\treturn\n  1101→\t}\n  1102→\n  1103→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1104→\tentries, err := os.ReadDir(clocheDir)\n  1105→\tif err != nil {\n  1106→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1107→\t\tjson.NewEncoder(w).Encode([]any{})\n  1108→\t\treturn\n  1109→\t}\n  1110→\n  1111→\ttype apiWire struct {\n  1112→\t\tFrom   string `json:\"from\"`\n  1113→\t\tResult string `json:\"result\"`\n  1114→\t\tTo     string `json:\"to\"`\n  1115→\t}\n  1116→\ttype apiStepDef struct {\n  1117→\t\tName    string            `json:\"name\"`\n  1118→\t\tType    string            `json:\"type\"`\n  1119→\t\tResults []string          `json:\"results\"`\n  1120→\t\tConfig  map[string]string `json:\"config\"`\n  1121→\t}\n  1122→\ttype apiWorkflow struct {\n  1123→\t\tName      string       `json:\"name\"`\n  1124→\t\tFile      string       `json:\"file\"`\n  1125→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1126→\t\tWires     []apiWire    `json:\"wires\"`\n  1127→\t\tEntryStep string       `json:\"entry_step\"`\n  1128→\t}\n  1129→\n  1130→\tvar workflows []apiWorkflow\n  1131→\tfor _, e := range entries {\n  1132→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1133→\t\t\tcontinue\n  1134→\t\t}\n  1135→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1136→\t\tif err != nil {\n  1137→\t\t\tcontinue\n  1138→\t\t}\n  1139→\t\twf, err := dsl.ParseForContainer(string(data))\n  1140→\t\tif err != nil {\n  1141→\t\t\tcontinue\n  1142→\t\t}\n  1143→\t\tvar steps []apiStepDef\n  1144→\t\tfor _, s := range wf.Steps {\n  1145→\t\t\tsteps = append(steps, apiStepDef{\n  1146→\t\t\t\tName:    s.Name,\n  1147→\t\t\t\tType:    string(s.Type),\n  1148→\t\t\t\tResults: s.Results,\n  1149→\t\t\t\tConfig:  s.Config,\n  1150→\t\t\t})\n  1151→\t\t}\n  1152→\t\t// Sort steps by name for consistent ordering\n  1153→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1154→\n  1155→\t\tvar wires []apiWire\n  1156→\t\tfor _, wire := range wf.Wiring {\n  1157→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1158→\t\t}\n  1159→\n  1160→\t\tworkflows = append(workflows, apiWorkflow{\n  1161→\t\t\tName:      wf.Name,\n  1162→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1163→\t\t\tSteps:     steps,\n  1164→\t\t\tWires:     wires,\n  1165→\t\t\tEntryStep: wf.EntryStep,\n  1166→\t\t})\n  1167→\t}\n  1168→\n  1169→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1170→\tjson.NewEncoder(w).Encode(workflows)\n  1171→}\n  1172→\n  1173→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1174→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1175→\tif !ok {\n  1176→\t\treturn\n  1177→\t}\n  1178→\tworkflowName := r.PathValue(\"workflow\")\n  1179→\tstepName := r.PathValue(\"step\")\n  1180→\n  1181→\t// Find the workflow file\n  1182→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1183→\tvar wf *domain.Workflow\n  1184→\tentries, _ := os.ReadDir(clocheDir)\n  1185→\tfor _, e := range entries {\n  1186→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1187→\t\t\tcontinue\n  1188→\t\t}\n  1189→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1190→\t\tif err != nil {\n  1191→\t\t\tcontinue\n  1192→\t\t}\n  1193→\t\tparsed, err := dsl.ParseForContainer(string(data))\n  1194→\t\tif err != nil {\n  1195→\t\t\tcontinue\n  1196→\t\t}\n  1197→\t\tif parsed.Name == workflowName {\n  1198→\t\t\twf = parsed\n  1199→\t\t\tbreak\n  1200→\t\t}\n  1201→\t}\n  1202→\tif wf == nil {\n  1203→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1204→\t\treturn\n  1205→\t}\n  1206→\n  1207→\tstep, ok := wf.Steps[stepName]\n  1208→\tif !ok {\n  1209→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1210→\t\treturn\n  1211→\t}\n  1212→\n  1213→\t// Try to read the referenced file from step config\n  1214→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1215→\n  1216→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1217→\t\tcontent, err := resolveFileRef(prompt, dir)\n  1218→\t\tif err == nil {\n  1219→\t\t\tw.Write([]byte(content))\n  1220→\t\t\treturn\n  1221→\t\t}\n  1222→\t}\n  1223→\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n  1224→\t\tcontent, _ := resolveFileRef(cmd, dir)\n  1225→\t\tw.Write([]byte(content))\n  1226→\t\treturn\n  1227→\t}\n  1228→\tif script := step.Config[\"script\"]; script != \"\" {\n  1229→\t\tcontent, _ := resolveFileRef(script, dir)\n  1230→\t\tw.Write([]byte(content))\n  1231→\t\treturn\n  1232→\t}\n  1233→\n  1234→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1235→}\n  1236→\n  1237→// --- Template helpers ---\n  1238→\n  1239→// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n  1240→// If the value uses file() syntax, the referenced file is read from disk.\n  1241→// Otherwise the value is returned as-is.\n  1242→func resolveFileRef(value, baseDir string) (string, error) {\n  1243→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n  1244→\t\tpath := value[6 : len(value)-2]\n  1245→\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n  1246→\t\tif err != nil {\n  1247→\t\t\treturn \"\", err\n  1248→\t\t}\n  1249→\t\treturn string(data), nil\n  1250→\t}\n  1251→\treturn value, nil\n  1252→}\n  1253→\n  1254→func stateColor(state domain.RunState) string {\n  1255→\tswitch state {\n  1256→\tcase domain.RunStatePending:\n  1257→\t\treturn \"pending\"\n  1258→\tcase domain.RunStateRunning:\n  1259→\t\treturn \"running\"\n  1260→\tcase domain.RunStateSucceeded:\n  1261→\t\treturn \"succeeded\"\n  1262→\tcase domain.RunStateFailed:\n  1263→\t\treturn \"failed\"\n  1264→\tcase domain.RunStateCancelled:\n  1265→\t\treturn \"cancelled\"\n  1266→\tdefault:\n  1267→\t\treturn \"pending\"\n  1268→\t}\n  1269→}\n  1270→\n  1271→func healthColor(status domain.HealthStatus) string {\n  1272→\tswitch status {\n  1273→\tcase domain.HealthGreen:\n  1274→\t\treturn \"green\"\n  1275→\tcase domain.HealthYellow:\n  1276→\t\treturn \"yellow\"\n  1277→\tcase domain.HealthRed:\n  1278→\t\treturn \"red\"\n  1279→\tcase domain.HealthBlue:\n  1280→\t\treturn \"blue\"\n  1281→\tdefault:\n  1282→\t\treturn \"grey\"\n  1283→\t}\n  1284→}\n  1285→\n  1286→func formatTime(t time.Time) string {\n  1287→\tif t.IsZero() {\n  1288→\t\treturn \"\"\n  1289→\t}\n  1290→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1291→}\n  1292→\n  1293→func formatDuration(start, end time.Time) string {\n  1294→\tif start.IsZero() || end.IsZero() {\n  1295→\t\treturn \"\"\n  1296→\t}\n  1297→\td := end.Sub(start)\n  1298→\tif d < time.Second {\n  1299→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1300→\t}\n  1301→\tif d < time.Minute {\n  1302→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1303→\t}\n  1304→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1305→}\n  1306→\n  1307→// formatSmartDuration formats a duration into a human-friendly short string.\n  1308→// Examples: \"3s\", \"2m\", \"1h20m\", \"3h\".\n  1309→func formatSmartDuration(d time.Duration) string {\n  1310→\tif d < time.Minute {\n  1311→\t\treturn fmt.Sprintf(\"%ds\", int(d.Seconds()))\n  1312→\t}\n  1313→\th := int(d.Hours())\n  1314→\tm := int(d.Minutes()) % 60\n  1315→\tif h == 0 {\n  1316→\t\treturn fmt.Sprintf(\"%dm\", m)\n  1317→\t}\n  1318→\tif m == 0 {\n  1319→\t\treturn fmt.Sprintf(\"%dh\", h)\n  1320→\t}\n  1321→\treturn fmt.Sprintf(\"%dh%dm\", h, m)\n  1322→}\n  1323→\n  1324→// roundRelativeTime rounds a duration to neat display units:\n  1325→// <1m -> \"<1m ago\", then 1m,5m,10m,15m,30m,45m,1h,2h,3h,...24h,\n  1326→// then days.\n  1327→func roundRelativeTime(d time.Duration) string {\n  1328→\tif d < time.Minute {\n  1329→\t\treturn \"<1m ago\"\n  1330→\t}\n  1331→\tmins := int(d.Minutes())\n  1332→\thours := int(d.Hours())\n  1333→\tdays := hours / 24\n  1334→\n  1335→\tif days > 0 {\n  1336→\t\tif days == 1 {\n  1337→\t\t\treturn \"1 day ago\"\n  1338→\t\t}\n  1339→\t\treturn fmt.Sprintf(\"%d days ago\", days)\n  1340→\t}\n  1341→\tif hours >= 1 {\n  1342→\t\tif hours == 1 {\n  1343→\t\t\treturn \"1 hour ago\"\n  1344→\t\t}\n  1345→\t\treturn fmt.Sprintf(\"%d hours ago\", hours)\n  1346→\t}\n  1347→\t// Round minutes to neat breakpoints\n  1348→\tswitch {\n  1349→\tcase mins < 3:\n  1350→\t\treturn \"1m ago\"\n  1351→\tcase mins < 8:\n  1352→\t\treturn \"5m ago\"\n  1353→\tcase mins < 13:\n  1354→\t\treturn \"10m ago\"\n  1355→\tcase mins < 20:\n  1356→\t\treturn \"15m ago\"\n  1357→\tcase mins < 38:\n  1358→\t\treturn \"30m ago\"\n  1359→\tcase mins < 53:\n  1360→\t\treturn \"45m ago\"\n  1361→\tdefault:\n  1362→\t\treturn \"1 hour ago\"\n  1363→\t}\n  1364→}\n  1365→\n  1366→// formatRunTiming returns a smart timing string for display on the Runs page.\n  1367→// Running: \"5m\" (just duration so far)\n  1368→// Completed: \"20m, 1 hour ago\"\n  1369→// Pending: \"\"\n  1370→func formatRunTiming(state domain.RunState, startedAt, completedAt time.Time) string {\n  1371→\treturn formatRunTimingAt(state, startedAt, completedAt, time.Now())\n  1372→}\n  1373→\n  1374→// formatRunTimingAt is the testable version of formatRunTiming with an explicit \"now\".\n  1375→func formatRunTimingAt(state domain.RunState, startedAt, completedAt, now time.Time) string {\n  1376→\tif startedAt.IsZero() {\n  1377→\t\treturn \"\"\n  1378→\t}\n  1379→\tswitch state {\n  1380→\tcase domain.RunStateRunning:\n  1381→\t\td := now.Sub(startedAt)\n  1382→\t\treturn formatSmartDuration(d)\n  1383→\tdefault:\n  1384→\t\tif completedAt.IsZero() {\n  1385→\t\t\treturn \"\"\n  1386→\t\t}\n  1387→\t\td := completedAt.Sub(startedAt)\n  1388→\t\tago := now.Sub(completedAt)\n  1389→\t\treturn formatSmartDuration(d) + \", \" + roundRelativeTime(ago)\n  1390→\t}\n  1391→}\n  1392→\n  1393→func truncate(s string, n int) string {\n  1394→\tif len(s) <= n {\n  1395→\t\treturn s\n  1396→\t}\n  1397→\treturn s[:n] + \"...\"\n  1398→}\n  1399→\n  1400→func shortContainerID(id string) string {\n  1401→\tif len(id) > 12 {\n  1402→\t\treturn id[:12]\n  1403→\t}\n  1404→\treturn id\n  1405→}\n  1406→\n  1407→// projectLabels builds a mapping from full project directory paths to short\n  1408→// display labels. Each label is the final directory component (e.g.\n  1409→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1410→// the same final name, the parent directory is prepended to disambiguate\n  1411→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1412→func projectLabels(dirs []string) map[string]string {\n  1413→\tlabels := make(map[string]string, len(dirs))\n  1414→\t// Group dirs by their base name to detect conflicts.\n  1415→\tbyBase := map[string][]string{}\n  1416→\tfor _, d := range dirs {\n  1417→\t\tbase := filepath.Base(d)\n  1418→\t\tbyBase[base] = append(byBase[base], d)\n  1419→\t}\n  1420→\tfor base, paths := range byBase {\n  1421→\t\tif len(paths) == 1 {\n  1422→\t\t\tlabels[paths[0]] = base\n  1423→\t\t} else {\n  1424→\t\t\tfor _, p := range paths {\n  1425→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1426→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1427→\t\t\t}\n  1428→\t\t}\n  1429→\t}\n  1430→\treturn labels\n  1431→}\n  1432→\n  1433→type projectEntry struct {\n  1434→\tDir            string\n  1435→\tLabel          string\n  1436→\tContainerCount int\n  1437→}\n  1438→"}]},"parent_tool_use_id":"toolu_01H3SUCdYbUfGGhNHfLQkrAn","session_id":"e0fcc3bc-5e1e-4706-af96-922d8476da68","uuid":"c0e3776f-c2e9-4cfe-8966-fb6d6d5fc8cc"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CmZTp5gpsTDB1aNxmxcVvx","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n     3→\n     4→<div class=\"run-history\" style=\"margin-bottom:1rem\">\n     5→    {{range .RecentRuns}}\n     6→    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n     7→    {{end}}\n     8→    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n     9→    {{if .ContainerCount}}\n    10→    <button class=\"btn btn-danger btn-sm\" id=\"delete-containers-btn\" onclick=\"deleteAllContainers()\" style=\"margin-left:0.5rem\">Delete {{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}</button>\n    11→    {{end}}\n    12→</div>\n    13→\n    14→<!-- Panel 1: Project Info -->\n    15→<div class=\"panel\" id=\"info-panel\">\n    16→    <div class=\"panel-header\">Project Info</div>\n    17→    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n    18→</div>\n    19→\n    20→<!-- Panel 3: Workflow View -->\n    21→<div class=\"panel\" id=\"workflow-panel\">\n    22→    <div class=\"panel-header\">Workflows</div>\n    23→    <div class=\"panel-body\">\n    24→        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n    25→        <div id=\"workflow-dag\"></div>\n    26→    </div>\n    27→</div>\n    28→\n    29→<!-- Step Drawer -->\n    30→<div class=\"drawer\" id=\"step-drawer\">\n    31→    <div class=\"drawer-header\">\n    32→        <span id=\"drawer-title\"></span>\n    33→        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    34→    </div>\n    35→    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n    36→</div>\n    37→{{end}}\n    38→\n    39→{{define \"scripts\"}}\n    40→<script>\n    41→var projectLabel = {{.Label}};\n    42→\n    43→function loadProjectInfo() {\n    44→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n    45→        .then(function(r) { return r.json(); })\n    46→        .then(function(data) {\n    47→            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n    48→            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n    49→            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n    50→            html += '</dl>';\n    51→\n    52→            if (data.prompt_files && data.prompt_files.length > 0) {\n    53→                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n    54→                data.prompt_files.forEach(function(pf) {\n    55→                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n    56→                    if (pf.history && pf.history.length > 0) {\n    57→                        html += '<div style=\"margin:0.5rem 0\">';\n    58→                        pf.history.forEach(function(h) {\n    59→                            html += '<div class=\"prompt-commit\" data-file=\"' + pf.path + '\" data-sha=\"' + h.sha + '\" onclick=\"toggleDiff(this)\" style=\"cursor:pointer;padding:0.25rem 0;font-size:0.85rem\">';\n    60→                            html += '<span class=\"mono\" style=\"color:var(--link)\">' + h.sha + '</span> ';\n    61→                            html += '<span style=\"color:var(--text-muted)\">' + h.date + '</span> ';\n    62→                            html += h.message;\n    63→                            html += '</div>';\n    64→                        });\n    65→                        html += '</div>';\n    66→                    } else {\n    67→                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">No history</p>';\n    68→                    }\n    69→                    html += '</details>';\n    70→                });\n    71→            }\n    72→\n    73→            document.getElementById('project-info').innerHTML = html;\n    74→        });\n    75→}\n    76→\n    77→function toggleDiff(el) {\n    78→    var existing = el.nextElementSibling;\n    79→    if (existing && existing.classList.contains('diff-block')) {\n    80→        existing.remove();\n    81→        return;\n    82→    }\n    83→    var file = el.getAttribute('data-file');\n    84→    var sha = el.getAttribute('data-sha');\n    85→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n    86→        .then(function(r) { return r.text(); })\n    87→        .then(function(text) {\n    88→            var pre = document.createElement('pre');\n    89→            pre.className = 'diff-block';\n    90→            pre.textContent = text || '(no diff available)';\n    91→            el.parentNode.insertBefore(pre, el.nextSibling);\n    92→        });\n    93→}\n    94→\n    95→var workflowsData = [];\n    96→function loadWorkflows() {\n    97→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n    98→        .then(function(r) { return r.json(); })\n    99→        .then(function(data) {\n   100→            workflowsData = data || [];\n   101→            if (workflowsData.length === 0) {\n   102→                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n   103→                return;\n   104→            }\n   105→            var tabs = document.getElementById('workflow-tabs');\n   106→            if (workflowsData.length > 1) {\n   107→                var html = '';\n   108→                workflowsData.forEach(function(wf, i) {\n   109→                    html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showWorkflow(' + i + ')\">' + wf.name + '</button>';\n   110→                });\n   111→                tabs.innerHTML = html;\n   112→            }\n   113→            showWorkflow(0);\n   114→        });\n   115→}\n   116→\n   117→function showWorkflow(idx) {\n   118→    var btns = document.querySelectorAll('.tab-btn');\n   119→    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n   120→\n   121→    var wf = workflowsData[idx];\n   122→    var dagEl = document.getElementById('workflow-dag');\n   123→\n   124→    // Build step order via topological sort from entry\n   125→    var ordered = [];\n   126→    var visited = {};\n   127→    function visit(name) {\n   128→        if (visited[name] || name === 'done' || name === 'abort') return;\n   129→        visited[name] = true;\n   130→        ordered.push(name);\n   131→        wf.wires.forEach(function(wire) {\n   132→            if (wire.from === name) visit(wire.to);\n   133→        });\n   134→    }\n   135→    if (wf.entry_step) visit(wf.entry_step);\n   136→    // Add any unvisited steps\n   137→    wf.steps.forEach(function(s) { if (!visited[s.name]) { ordered.push(s.name); visited[s.name] = true; } });\n   138→\n   139→    // Collect terminal targets\n   140→    var terminals = {};\n   141→    wf.wires.forEach(function(wire) {\n   142→        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n   143→    });\n   144→\n   145→    var stepMap = {};\n   146→    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n   147→\n   148→    var nodeH = 48, nodeW = 180, gapY = 24, gapX = 40, padTop = 20, padLeft = 30;\n   149→\n   150→    // Assign positions\n   151→    var positions = {};\n   152→    ordered.forEach(function(name, i) {\n   153→        positions[name] = {x: padLeft, y: padTop + i * (nodeH + gapY)};\n   154→    });\n   155→    var termIdx = ordered.length;\n   156→    for (var t in terminals) {\n   157→        positions[t] = {x: padLeft, y: padTop + termIdx * (nodeH + gapY)};\n   158→        termIdx++;\n   159→    }\n   160→\n   161→    var totalH = padTop + termIdx * (nodeH + gapY) + 10;\n   162→    var totalW = padLeft + nodeW + gapX + 80;\n   163→\n   164→    var html = '<svg class=\"dag-svg\" width=\"' + totalW + '\" height=\"' + totalH + '\">';\n   165→    html += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n   166→\n   167→    // Draw wires\n   168→    wf.wires.forEach(function(wire) {\n   169→        var from = positions[wire.from];\n   170→        var to = positions[wire.to];\n   171→        if (!from || !to) return;\n   172→        var x1 = from.x + nodeW;\n   173→        var y1 = from.y + nodeH / 2;\n   174→        var x2 = to.x;\n   175→        var y2 = to.y + nodeH / 2;\n   176→        var cx = x1 + gapX / 2;\n   177→        html += '<path d=\"M' + x1 + ' ' + y1 + ' C' + cx + ' ' + y1 + ' ' + cx + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n   178→        var lx = (x1 + x2) / 2, ly = (y1 + y2) / 2 - 6;\n   179→        html += '<text x=\"' + lx + '\" y=\"' + ly + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n   180→    });\n   181→\n   182→    // Draw step nodes\n   183→    ordered.forEach(function(name) {\n   184→        var pos = positions[name];\n   185→        var s = stepMap[name];\n   186→        var icon = s && s.type === 'agent' ? '\\u{1F916}' : '\\u{1F4DC}';\n   187→        html += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + name + '\\')\" style=\"cursor:pointer\">';\n   188→        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n   189→        html += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + name + '</text>';\n   190→        html += '</g>';\n   191→    });\n   192→\n   193→    // Draw terminal nodes\n   194→    for (var t in terminals) {\n   195→        var pos = positions[t];\n   196→        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n   197→        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n   198→        html += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n   199→    }\n   200→\n   201→    html += '</svg>';\n   202→    dagEl.innerHTML = html;\n   203→}\n   204→\n   205→function openDrawer(workflowName, stepName) {\n   206→    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n   207→    if (!wf) return;\n   208→    var step = wf.steps.find(function(s) { return s.name === stepName; });\n   209→    if (!step) return;\n   210→\n   211→    document.getElementById('drawer-title').textContent = stepName;\n   212→    var body = '<dl class=\"run-meta\">';\n   213→    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n   214→    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n   215→    if (step.config) {\n   216→        for (var k in step.config) {\n   217→            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script') {\n   218→                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n   219→            }\n   220→        }\n   221→    }\n   222→    body += '</dl>';\n   223→    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n   224→\n   225→    document.getElementById('drawer-body').innerHTML = body;\n   226→    document.getElementById('step-drawer').classList.add('drawer-open');\n   227→\n   228→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n   229→        .then(function(r) { if (r.ok) return r.text(); return ''; })\n   230→        .then(function(text) {\n   231→            var el = document.getElementById('drawer-content');\n   232→            if (text) {\n   233→                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n   234→            } else {\n   235→                el.innerHTML = '<p style=\"color:var(--text-muted)\">No content available</p>';\n   236→            }\n   237→        });\n   238→}\n   239→\n   240→function closeDrawer() {\n   241→    document.getElementById('step-drawer').classList.remove('drawer-open');\n   242→}\n   243→\n   244→document.addEventListener('keydown', function(e) {\n   245→    if (e.key === 'Escape') closeDrawer();\n   246→});\n   247→\n   248→window.deleteAllContainers = function() {\n   249→    var btn = document.getElementById('delete-containers-btn');\n   250→    if (btn) btn.disabled = true;\n   251→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/containers', { method: 'DELETE' })\n   252→        .then(function(r) { return r.json(); })\n   253→        .then(function(data) {\n   254→            if (btn) {\n   255→                btn.textContent = 'Deleted ' + (data.deleted || 0) + ' container' + (data.deleted !== 1 ? 's' : '');\n   256→                btn.classList.remove('btn-danger');\n   257→                btn.classList.add('btn-secondary');\n   258→            }\n   259→        })\n   260→        .catch(function() {\n   261→            if (btn) {\n   262→                btn.textContent = 'Delete failed';\n   263→                btn.disabled = false;\n   264→            }\n   265→        });\n   266→};\n   267→\n   268→// Load all panels\n   269→loadProjectInfo();\n   270→loadWorkflows();\n   271→</script>\n   272→{{end}}\n   273→"}]},"parent_tool_use_id":"toolu_01H3SUCdYbUfGGhNHfLQkrAn","session_id":"e0fcc3bc-5e1e-4706-af96-922d8476da68","uuid":"19dde46f-4a06-49e4-ac17-78aad5701ea1"}
