  52→        --error-bg: #450a0a;\n    53→        --error-border: #7f1d1d;\n    54→        --error-text: #fca5a5;\n    55→    }\n    56→}\n    57→\n    58→*, *::before, *::after { box-sizing: border-box; }\n    59→\n    60→body {\n    61→    margin: 0;\n    62→    font-family: var(--font);\n    63→    background: var(--bg);\n    64→    color: var(--text);\n    65→    line-height: 1.5;\n    66→}\n    67→\n    68→.container {\n    69→    max-width: 1100px;\n    70→    margin: 0 auto;\n    71→    padding: 0 1rem;\n    72→}\n    73→\n    74→a { color: var(--link); text-decoration: none; }\n    75→a:hover { text-decoration: underline; }\n    76→\n    77→.navbar {\n    78→    background: var(--bg-surface);\n    79→    border-bottom: 1px solid var(--border);\n    80→    padding: 0.75rem 0;\n    81→    margin-bottom: 1.5rem;\n    82→}\n    83→\n    84→.logo {\n    85→    font-weight: 700;\n    86→    font-size: 1.1rem;\n    87→    color: var(--text);\n    88→}\n    89→.logo:hover { text-decoration: none; }\n    90→\n    91→h1 {\n    92→    font-size: 1.4rem;\n    93→    margin: 0 0 1rem;\n    94→    display: flex;\n    95→    align-items: center;\n    96→    gap: 0.5rem;\n    97→    flex-wrap: wrap;\n    98→}\n    99→\n   100→h1 a { font-weight: 400; }"}]},"parent_tool_use_id":"toolu_01H3SUCdYbUfGGhNHfLQkrAn","session_id":"e0fcc3bc-5e1e-4706-af96-922d8476da68","uuid":"32363614-d545-4282-89b6-660c7649a69b"}
