{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AT5FPFGf3uhVQ7YHBBBWCG","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n     3→\n     4→<div class=\"run-history\" style=\"margin-bottom:1rem\">\n     5→    {{range .RecentRuns}}\n     6→    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n     7→    {{end}}\n     8→    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n     9→    {{if .ContainerCount}}\n    10→    <button class=\"btn btn-danger btn-sm\" id=\"delete-containers-btn\" onclick=\"deleteAllContainers()\" style=\"margin-left:0.5rem\">Delete {{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}</button>\n    11→    {{end}}\n    12→</div>\n    13→\n    14→<!-- Panel 1: Project Info -->\n    15→<div class=\"panel\" id=\"info-panel\">\n    16→    <div class=\"panel-header\">Project Info</div>\n    17→    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n    18→</div>\n    19→\n    20→<!-- Panel 3: Workflow View -->\n    21→<div class=\"panel\" id=\"workflow-panel\">\n    22→    <div class=\"panel-header\">Workflows</div>\n    23→    <div class=\"panel-body\">\n    24→        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n    25→        <div id=\"workflow-dag\"></div>\n    26→    </div>\n    27→</div>\n    28→\n    29→<!-- Step Drawer -->\n    30→<div class=\"drawer\" id=\"step-drawer\">\n    31→    <div class=\"drawer-header\">\n    32→        <span id=\"drawer-title\"></span>\n    33→        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    34→    </div>\n    35→    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n    36→</div>\n    37→{{end}}\n    38→\n    39→{{define \"scripts\"}}\n    40→<script>\n    41→var projectLabel = {{.Label}};\n    42→\n    43→function loadProjectInfo() {\n    44→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n    45→        .then(function(r) { return r.json(); })\n    46→        .then(function(data) {\n    47→            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n    48→            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n    49→            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n    50→            html += '</dl>';\n    51→\n    52→            if (data.prompt_files && data.prompt_files.length > 0) {\n    53→                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n    54→                data.prompt_files.forEach(function(pf) {\n    55→                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n    56→                    if (pf.history && pf.history.length > 0) {\n    57→                        html += '<div style=\"margin:0.5rem 0\">';\n    58→                        pf.history.forEach(function(h) {\n    59→                            html += '<div class=\"prompt-commit\" data-file=\"' + pf.path + '\" data-sha=\"' + h.sha + '\" onclick=\"toggleDiff(this)\" style=\"cursor:pointer;padding:0.25rem 0;font-size:0.85rem\">';\n    60→                            html += '<span class=\"mono\" style=\"color:var(--link)\">' + h.sha + '</span> ';\n    61→                            html += '<span style=\"color:var(--text-muted)\">' + h.date + '</span> ';\n    62→                            html += h.message;\n    63→                            html += '</div>';\n    64→                        });\n    65→                        html += '</div>';\n    66→                    } else {\n    67→                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">No history</p>';\n    68→                    }\n    69→                    html += '</details>';\n    70→                });\n    71→            }\n    72→\n    73→            document.getElementById('project-info').innerHTML = html;\n    74→        });\n    75→}\n    76→\n    77→function toggleDiff(el) {\n    78→    var existing = el.nextElementSibling;\n    79→    if (existing && existing.classList.contains('diff-block')) {\n    80→        existing.remove();\n    81→        return;\n    82→    }\n    83→    var file = el.getAttribute('data-file');\n    84→    var sha = el.getAttribute('data-sha');\n    85→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n    86→        .then(function(r) { return r.text(); })\n    87→        .then(function(text) {\n    88→            var pre = document.createElement('pre');\n    89→            pre.className = 'diff-block';\n    90→            pre.textContent = text || '(no diff available)';\n    91→            el.parentNode.insertBefore(pre, el.nextSibling);\n    92→        });\n    93→}\n    94→\n    95→var workflowsData = [];\n    96→function loadWorkflows() {\n    97→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n    98→        .then(function(r) { return r.json(); })\n    99→        .then(function(data) {\n   100→            workflowsData = data || [];\n   101→            if (workflowsData.length === 0) {\n   102→                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n   103→                return;\n   104→            }\n   105→            var tabs = document.getElementById('workflow-tabs');\n   106→            if (workflowsData.length > 1) {\n   107→                var html = '';\n   108→                workflowsData.forEach(function(wf, i) {\n   109→                    html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showWorkflow(' + i + ')\">' + wf.name + '</button>';\n   110→                });\n   111→                tabs.innerHTML = html;\n   112→            }\n   113→            showWorkflow(0);\n   114→        });\n   115→}\n   116→\n   117→function showWorkflow(idx) {\n   118→    var btns = document.querySelectorAll('.tab-btn');\n   119→    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n   120→\n   121→    var wf = workflowsData[idx];\n   122→    var dagEl = document.getElementById('workflow-dag');\n   123→\n   124→    // Build step order via topological sort from entry\n   125→    var ordered = [];\n   126→    var visited = {};\n   127→    function visit(name) {\n   128→        if (visited[name] || name === 'done' || name === 'abort') return;\n   129→        visited[name] = true;\n   130→        ordered.push(name);\n   131→        wf.wires.forEach(function(wire) {\n   132→            if (wire.from === name) visit(wire.to);\n   133→        });\n   134→    }\n   135→    if (wf.entry_step) visit(wf.entry_step);\n   136→    // Add any unvisited steps\n   137→    wf.steps.forEach(function(s) { if (!visited[s.name]) { ordered.push(s.name); visited[s.name] = true; } });\n   138→\n   139→    // Collect terminal targets\n   140→    var terminals = {};\n   141→    wf.wires.forEach(function(wire) {\n   142→        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n   143→    });\n   144→\n   145→    var stepMap = {};\n   146→    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n   147→\n   148→    var nodeH = 48, nodeW = 180, gapY = 24, gapX = 40, padTop = 20, padLeft = 30;\n   149→\n   150→    // Assign positions\n   151→    var positions = {};\n   152→    ordered.forEach(function(name, i) {\n   153→        positions[name] = {x: padLeft, y: padTop + i * (nodeH + gapY)};\n   154→    });\n   155→    var termIdx = ordered.length;\n   156→    for (var t in terminals) {\n   157→        positions[t] = {x: padLeft, y: padTop + termIdx * (nodeH + gapY)};\n   158→        termIdx++;\n   159→    }\n   160→\n   161→    var totalH = padTop + termIdx * (nodeH + gapY) + 10;\n   162→    var totalW = padLeft + nodeW + gapX + 80;\n   163→\n   164→    var html = '<svg class=\"dag-svg\" width=\"' + totalW + '\" height=\"' + totalH + '\">';\n   165→    html += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n   166→\n   167→    // Draw wires\n   168→    wf.wires.forEach(function(wire) {\n   169→        var from = positions[wire.from];\n   170→        var to = positions[wire.to];\n   171→        if (!from || !to) return;\n   172→        var x1 = from.x + nodeW;\n   173→        var y1 = from.y + nodeH / 2;\n   174→        var x2 = to.x;\n   175→        var y2 = to.y + nodeH / 2;\n   176→        var cx = x1 + gapX / 2;\n   177→        html += '<path d=\"M' + x1 + ' ' + y1 + ' C' + cx + ' ' + y1 + ' ' + cx + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n   178→        var lx = (x1 + x2) / 2, ly = (y1 + y2) / 2 - 6;\n   179→        html += '<text x=\"' + lx + '\" y=\"' + ly + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n   180→    });\n   181→\n   182→    // Draw step nodes\n   183→    ordered.forEach(function(name) {\n   184→        var pos = positions[name];\n   185→        var s = stepMap[name];\n   186→        var icon = s && s.type === 'agent' ? '\\u{1F916}' : '\\u{1F4DC}';\n   187→        html += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + name + '\\')\" style=\"cursor:pointer\">';\n   188→        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n   189→        html += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + name + '</text>';\n   190→        html += '</g>';\n   191→    });\n   192→\n   193→    // Draw terminal nodes\n   194→    for (var t in terminals) {\n   195→        var pos = positions[t];\n   196→        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n   197→        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n   198→        html += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n   199→    }\n   200→\n   201→    html += '</svg>';\n   202→    dagEl.innerHTML = html;\n   203→}\n   204→\n   205→function openDrawer(workflowName, stepName) {\n   206→    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n   207→    if (!wf) return;\n   208→    var step = wf.steps.find(function(s) { return s.name === stepName; });\n   209→    if (!step) return;\n   210→\n   211→    document.getElementById('drawer-title').textContent = stepName;\n   212→    var body = '<dl class=\"run-meta\">';\n   213→    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n   214→    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n   215→    if (step.config) {\n   216→        for (var k in step.config) {\n   217→            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script') {\n   218→                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n   219→            }\n   220→        }\n   221→    }\n   222→    body += '</dl>';\n   223→    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n   224→\n   225→    document.getElementById('drawer-body').innerHTML = body;\n   226→    document.getElementById('step-drawer').classList.add('drawer-open');\n   227→\n   228→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n   229→        .then(function(r) { if (r.ok) return r.text(); return ''; })\n   230→        .then(function(text) {\n   231→            var el = document.getElementById('drawer-content');\n   232→            if (text) {\n   233→                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n   234→            } else {\n   235→                el.innerHTML = '<p style=\"color:var(--text-muted)\">No content available</p>';\n   236→            }\n   237→        });\n   238→}\n   239→\n   240→function closeDrawer() {\n   241→    document.getElementById('step-drawer').classList.remove('drawer-open');\n   242→}\n   243→\n   244→document.addEventListener('keydown', function(e) {\n   245→    if (e.key === 'Escape') closeDrawer();\n   246→});\n   247→\n   248→window.deleteAllContainers = function() {\n   249→    var btn = document.getElementById('delete-containers-btn');\n   250→    if (btn) btn.disabled = true;\n   251→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/containers', { method: 'DELETE' })\n   252→        .then(function(r) { return r.json(); })\n   253→        .then(function(data) {\n   254→            if (btn) {\n   255→                btn.textContent = 'Deleted ' + (data.deleted || 0) + ' container' + (data.deleted !== 1 ? 's' : '');\n   256→                btn.classList.remove('btn-danger');\n   257→                btn.classList.add('btn-secondary');\n   258→            }\n   259→        })\n   260→        .catch(function() {\n   261→            if (btn) {\n   262→                btn.textContent = 'Delete failed';\n   263→                btn.disabled = false;\n   264→            }\n   265→        });\n   266→};\n   267→\n   268→// Load all panels\n   269→loadProjectInfo();\n   270→loadWorkflows();\n   271→</script>\n   272→{{end}}\n   273→"}]},"parent_tool_use_id":null,"session_id":"e0fcc3bc-5e1e-4706-af96-922d8476da68","uuid":"8726ba0d-f9ce-4659-b085-f8a8f1118552","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/project_detail.html","content":"{{define \"content\"}}\n<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n\n<div class=\"run-history\" style=\"margin-bottom:1rem\">\n    {{range .RecentRuns}}\n    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n    {{end}}\n    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n    {{if .ContainerCount}}\n    <button class=\"btn btn-danger btn-sm\" id=\"delete-containers-btn\" onclick=\"deleteAllContainers()\" style=\"margin-left:0.5rem\">Delete {{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}</button>\n    {{end}}\n</div>\n\n<!-- Panel 1: Project Info -->\n<div class=\"panel\" id=\"info-panel\">\n    <div class=\"panel-header\">Project Info</div>\n    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n</div>\n\n<!-- Panel 3: Workflow View -->\n<div class=\"panel\" id=\"workflow-panel\">\n    <div class=\"panel-header\">Workflows</div>\n    <div class=\"panel-body\">\n        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-dag\"></div>\n    </div>\n</div>\n\n<!-- Step Drawer -->\n<div class=\"drawer\" id=\"step-drawer\">\n    <div class=\"drawer-header\">\n        <span id=\"drawer-title\"></span>\n        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    </div>\n    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n</div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\nvar projectLabel = {{.Label}};\n\nfunction loadProjectInfo() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n            html += '</dl>';\n\n            if (data.prompt_files && data.prompt_files.length > 0) {\n                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n                data.prompt_files.forEach(function(pf) {\n                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n                    if (pf.history && pf.history.length > 0) {\n                        html += '<div style=\"margin:0.5rem 0\">';\n                        pf.history.forEach(function(h) {\n                            html += '<div class=\"prompt-commit\" data-file=\"' + pf.path + '\" data-sha=\"' + h.sha + '\" onclick=\"toggleDiff(this)\" style=\"cursor:pointer;padding:0.25rem 0;font-size:0.85rem\">';\n                            html += '<span class=\"mono\" style=\"color:var(--link)\">' + h.sha + '</span> ';\n                            html += '<span style=\"color:var(--text-muted)\">' + h.date + '</span> ';\n                            html += h.message;\n                            html += '</div>';\n                        });\n                        html += '</div>';\n                    } else {\n                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">No history</p>';\n                    }\n                    html += '</details>';\n                });\n            }\n\n            document.getElementById('project-info').innerHTML = html;\n        });\n}\n\nfunction toggleDiff(el) {\n    var existing = el.nextElementSibling;\n    if (existing && existing.classList.contains('diff-block')) {\n        existing.remove();\n        return;\n    }\n    var file = el.getAttribute('data-file');\n    var sha = el.getAttribute('data-sha');\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n        .then(function(r) { return r.text(); })\n        .then(function(text) {\n            var pre = document.createElement('pre');\n            pre.className = 'diff-block';\n            pre.textContent = text || '(no diff available)';\n            el.parentNode.insertBefore(pre, el.nextSibling);\n        });\n}\n\nvar workflowsData = [];\nfunction loadWorkflows() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            workflowsData = data || [];\n            if (workflowsData.length === 0) {\n                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n                return;\n            }\n            var tabs = document.getElementById('workflow-tabs');\n            if (workflowsData.length > 1) {\n                var html = '';\n                workflowsData.forEach(function(wf, i) {\n                    html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showWorkflow(' + i + ')\">' + wf.name + '</button>';\n                });\n                tabs.innerHTML = html;\n            }\n            showWorkflow(0);\n        });\n}\n\nfunction showWorkflow(idx) {\n    var btns = document.querySelectorAll('.tab-btn');\n    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n\n    var wf = workflowsData[idx];\n    var dagEl = document.getElementById('workflow-dag');\n\n    // Build step order via topological sort from entry\n    var ordered = [];\n    var visited = {};\n    function visit(name) {\n        if (visited[name] || name === 'done' || name === 'abort') return;\n        visited[name] = true;\n        ordered.push(name);\n        wf.wires.forEach(function(wire) {\n            if (wire.from === name) visit(wire.to);\n        });\n    }\n    if (wf.entry_step) visit(wf.entry_step);\n    // Add any unvisited steps\n    wf.steps.forEach(function(s) { if (!visited[s.name]) { ordered.push(s.name); visited[s.name] = true; } });\n\n    // Collect terminal targets\n    var terminals = {};\n    wf.wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n    });\n\n    var stepMap = {};\n    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n\n    var nodeH = 48, nodeW = 180, gapY = 24, gapX = 40, padTop = 20, padLeft = 30;\n\n    // Assign positions\n    var positions = {};\n    ordered.forEach(function(name, i) {\n        positions[name] = {x: padLeft, y: padTop + i * (nodeH + gapY)};\n    });\n    var termIdx = ordered.length;\n    for (var t in terminals) {\n        positions[t] = {x: padLeft, y: padTop + termIdx * (nodeH + gapY)};\n        termIdx++;\n    }\n\n    var totalH = padTop + termIdx * (nodeH + gapY) + 10;\n    var totalW = padLeft + nodeW + gapX + 80;\n\n    var html = '<svg class=\"dag-svg\" width=\"' + totalW + '\" height=\"' + totalH + '\">';\n    html += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n\n    // Draw wires\n    wf.wires.forEach(function(wire) {\n        var from = positions[wire.from];\n        var to = positions[wire.to];\n        if (!from || !to) return;\n        var x1 = from.x + nodeW;\n        var y1 = from.y + nodeH / 2;\n        var x2 = to.x;\n        var y2 = to.y + nodeH / 2;\n        var cx = x1 + gapX / 2;\n        html += '<path d=\"M' + x1 + ' ' + y1 + ' C' + cx + ' ' + y1 + ' ' + cx + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n        var lx = (x1 + x2) / 2, ly = (y1 + y2) / 2 - 6;\n        html += '<text x=\"' + lx + '\" y=\"' + ly + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n    });\n\n    // Draw step nodes\n    ordered.forEach(function(name) {\n        var pos = positions[name];\n        var s = stepMap[name];\n        var icon = s && s.type === 'agent' ? '\\u{1F916}' : '\\u{1F4DC}';\n        html += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + name + '\\')\" style=\"cursor:pointer\">';\n        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n        html += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + name + '</text>';\n        html += '</g>';\n    });\n\n    // Draw terminal nodes\n    for (var t in terminals) {\n        var pos = positions[t];\n        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n        html += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n    }\n\n    html += '</svg>';\n    dagEl.innerHTML = html;\n}\n\nfunction openDrawer(workflowName, stepName) {\n    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n    if (!wf) return;\n    var step = wf.steps.find(function(s) { return s.name === stepName; });\n    if (!step) return;\n\n    document.getElementById('drawer-title').textContent = stepName;\n    var body = '<dl class=\"run-meta\">';\n    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n    if (step.config) {\n        for (var k in step.config) {\n            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script') {\n                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n            }\n        }\n    }\n    body += '</dl>';\n    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n\n    document.getElementById('drawer-body').innerHTML = body;\n    document.getElementById('step-drawer').classList.add('drawer-open');\n\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n        .then(function(r) { if (r.ok) return r.text(); return ''; })\n        .then(function(text) {\n            var el = document.getElementById('drawer-content');\n            if (text) {\n                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n            } else {\n                el.innerHTML = '<p style=\"color:var(--text-muted)\">No content available</p>';\n            }\n        });\n}\n\nfunction closeDrawer() {\n    document.getElementById('step-drawer').classList.remove('drawer-open');\n}\n\ndocument.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') closeDrawer();\n});\n\nwindow.deleteAllContainers = function() {\n    var btn = document.getElementById('delete-containers-btn');\n    if (btn) btn.disabled = true;\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/containers', { method: 'DELETE' })\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            if (btn) {\n                btn.textContent = 'Deleted ' + (data.deleted || 0) + ' container' + (data.deleted !== 1 ? 's' : '');\n                btn.classList.remove('btn-danger');\n                btn.classList.add('btn-secondary');\n            }\n        })\n        .catch(function() {\n            if (btn) {\n                btn.textContent = 'Delete failed';\n                btn.disabled = false;\n            }\n        });\n};\n\n// Load all panels\nloadProjectInfo();\nloadWorkflows();\n</script>\n{{end}}\n","numLines":273,"startLine":1,"totalLines":273}}}
