{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01USEZYrDFEpJ6sum6s3gRxY","type":"tool_result","content":"   362→func TestParseForHost_AllowsWorkflowSteps(t *testing.T) {\n   363→\tinput := `workflow \"main\" {\n   364→  step prepare {\n   365→    run     = \"bash scripts/prepare.sh\"\n   366→    results = [success, fail]\n   367→  }\n   368→  step develop {\n   369→    workflow_name = \"develop\"\n   370→    results       = [success, fail]\n   371→  }\n   372→  prepare:success -> develop\n   373→  prepare:fail    -> abort\n   374→  develop:success -> done\n   375→  develop:fail    -> done\n   376→}`\n   377→\twf, err := dsl.ParseForHost(input)\n   378→\trequire.NoError(t, err)\n   379→\tassert.Equal(t, domain.LocationHost, wf.Location)\n   380→\tassert.Equal(t, domain.StepTypeWorkflow, wf.Steps[\"develop\"].Type)\n   381→}\n   382→\n   383→func TestParseForContainer_RejectsWorkflowSteps(t *testing.T) {\n   384→\tinput := `workflow \"develop\" {\n   385→  step dispatch {\n   386→    workflow_name = \"implement\"\n   387→    results       = [success, fail]\n   388→  }\n   389→  dispatch:success -> done\n   390→  dispatch:fail    -> abort\n   391→}`\n   392→\t_, err := dsl.ParseForContainer(input)\n   393→\trequire.Error(t, err)\n   394→\tassert.Contains(t, err.Error(), \"workflow_name\")\n   395→\tassert.Contains(t, err.Error(), \"host workflows\")\n   396→}\n   397→\n   398→func TestParseForContainer_AllowsAgentAndScript(t *testing.T) {\n   399→\tinput := `workflow \"develop\" {\n   400→  step code {\n   401→    prompt = \"write code\"\n   402→    results = [success, fail]\n   403→  }\n   404→  step test {\n   405→    run = \"make test\"\n   406→    results = [pass, fail]\n   407→  }\n   408→  code:success -> test\n   409→  code:fail -> abort\n   410→  test:pass -> done\n   411→  test:fail -> code\n   412→}`\n   413→\twf, err := dsl.ParseForContainer(input)\n   414→\trequire.NoError(t, err)\n   415→\tassert.Equal(t, domain.LocationContainer, wf.Location)\n   416→}\n   417→\n   418→func TestParser_WireNoMappings(t *testing.T) {\n   419→\tinput := `workflow \"simple\" {\n   420→  step a {\n   421→    run = \"echo a\""}]},"parent_tool_use_id":"toolu_01UPoSiNRnEJArJL6Dn4ZqR9","session_id":"e0fcc3bc-5e1e-4706-af96-922d8476da68","uuid":"ae80dee4-958d-497c-929d-82bfd3a16836"}
