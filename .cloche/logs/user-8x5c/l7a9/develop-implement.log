flow{\n\t\t\t\t\tName:      hwf.Name,\n\t\t\t\t\tFile:      filepath.Join(\".cloche\", \"host.cloche\"),\n\t\t\t\t\tLocation:  \"host\",\n\t\t\t\t\tSteps:     steps,\n\t\t\t\t\tWires:     wires,\n\t\t\t\t\tEntryStep: hwf.EntryStep,\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":467,"cache_read_input_tokens":31566,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":467},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e0fcc3bc-5e1e-4706-af96-922d8476da68","uuid":"734e1f0f-bf9f-40d3-9847-9d3c6389f338"}
