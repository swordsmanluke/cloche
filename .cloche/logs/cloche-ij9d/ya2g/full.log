 := wf.ValidateLocation()\n/workspace/internal/domain/workflow_test.go-336-\tassert.NoError(t, err)\n/workspace/internal/domain/workflow_test.go-337-}\n/workspace/internal/domain/workflow_test.go-338-\ninternal/domain/workflow_test.go:339:func TestWorkflow_Validate_DuplicateOutputMapping_DifferentKeys(t *testing.T) {\ninternal/domain/workflow_test.go-340-\twf := &domain.Workflow{\ninternal/domain/workflow_test.go-341-\t\tName: \"test\",\ninternal/domain/workflow_test.go-342-\t\tSteps: map[string]*domain.Step{\n--\n/workspace/internal/domain/workflow_test.go-365-\t\t\t},\n/workspace/internal/domain/workflow_test.go-366-\t\t},\n/workspace/internal/domain/workflow_test.go-367-\t}\ninternal/domain/workflow_test.go:368:\terr := wf.Validate()\n/workspace/internal/domain/workflow_test.go-369-\tassert.NoError(t, err, \"different env var keys on wires to same step should be valid\")\n/workspace/internal/domain/workflow_test.go-370-}\n/workspace/internal/domain/workflow_test.go-371-\ninternal/domain/workflow_test.go:372:func TestWorkflow_Validate_DuplicateOutputMapping_SameKey(t *testing.T) {\ninternal/domain/workflow_test.go-373-\twf := &domain.Workflow{\ninternal/domain/workflow_test.go-374-\t\tName: \"test\",\ninternal/domain/workflow_test.go-375-\t\tSteps: map[string]*domain.Step{\n--\n/workspace/internal/domain/workflow_test.go-398-\t\t\t},\n/workspace/internal/domain/workflow_test.go-399-\t\t},\n/workspace/internal/domain/workflow_test.go-400-\t}\ninternal/domain/workflow_test.go:401:\terr := wf.Validate()\n/workspace/internal/domain/workflow_test.go-402-\trequire.Error(t, err)\n/workspace/internal/domain/workflow_test.go-403-\tassert.Contains(t, err.Error(), \"duplicate output mapping\")\n/workspace/internal/domain/workflow_test.go-404-\tassert.Contains(t, err.Error(), \"FOO\")\n/workspace/internal/domain/workflow_test.go-405-\tassert.Contains(t, err.Error(), \"c\")\n/workspace/internal/domain/workflow_test.go-406-}\n/workspace/internal/domain/workflow_test.go-407-\ninternal/domain/workflow_test.go:408:func TestWorkflow_Validate_DuplicateOutputMapping_SameKeyDifferentSteps(t *testing.T) {\ninternal/domain/workflow_test.go-409-\twf := &domain.Workflow{\ninternal/domain/workflow_test.go-410-\t\tName: \"test\",\ninternal/domain/workflow_test.go-411-\t\tSteps: map[string]*domain.Step{\n--\n/workspace/internal/domain/workflow_test.go-425-\t\t},\ninternal/domain/workflow_test.go-426-\t\tEntryStep: \"a\",\n/workspace/internal/domain/workflow_test.go-427-\t}\ninternal/domain/workflow_test.go:428:\terr := wf.Validate()\n/workspace/internal/domain/workflow_test.go-429-\tassert.NoError(t, err, \"same env var key on wires to different steps should be valid\")\n/workspace/internal/domain/workflow_test.go-430-}\n/workspace/internal/domain/workflow_test.go-431-\ninternal/domain/workflow_test.go:432:func TestWorkflow_Validate_DuplicateOutputMapping_NoMappings(t *testing.T) {\ninternal/domain/workflow_test.go-433-\twf := &domain.Workflow{\ninternal/domain/workflow_test.go-434-\t\tName: \"test\",\ninternal/domain/workflow_test.go-435-\t\tSteps: map[string]*domain.Step{\n--\n/workspace/internal/domain/workflow_test.go-442-\t\t},\ninternal/domain/workflow_test.go-443-\t\tEntryStep: \"a\",\n/workspace/internal/domain/workflow_test.go-444-\t}\ninternal/domain/workflow_test.go:445:\terr := wf.Validate()\n/workspace/internal/domain/workflow_test.go-446-\tassert.NoError(t, err, \"wires with no output mappings should be valid\")\n/workspace/internal/domain/workflow_test.go-447-}\n/workspace/internal/domain/workflow_test.go-448-\ninternal/domain/workflow_test.go:449:func TestWorkflow_ValidateConfig_ContainerPrefix(t *testing.T) {\ninternal/domain/workflow_test.go-450-\twf := &domain.Workflow{\ninternal/domain/workflow_test.go-451-\t\tName: \"container-keys\",\ninternal/domain/workflow_test.go-452-\t\tSteps: map[string]*domain.Step{\n--\n/workspace/internal/domain/workflow_test.go-461-\t\t\t},\n/workspace/internal/domain/workflow_test.go-462-\t\t},\n/workspace/internal/domain/workflow_test.go-463-\t}\ninternal/domain/workflow_test.go:464:\twarnings := wf.ValidateConfig()\n/workspace/internal/domain/workflow_test.go-465-\tassert.Empty(t, warnings)\n/workspace/internal/domain/workflow_test.go-466-}","numLines":284}}
