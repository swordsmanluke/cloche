{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MTDDXFZf3oiWRL3aVHWURz","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"strings\"\n     7→)\n     8→\n     9→// Classifier categorizes run prompts.\n    10→type Classifier struct {\n    11→\tLLM LLMClient\n    12→}\n    13→\n    14→type classifyResponse struct {\n    15→\tClassification string `json:\"classification\"`\n    16→}\n    17→\n    18→// Classify categorizes a run prompt into: bug, feedback, feature, enhancement, chore.\n    19→func (c *Classifier) Classify(ctx context.Context, runPrompt string) (string, error) {\n    20→\tsystemPrompt := `You are a classifier for software development tasks. Given a task description, classify it into exactly one category:\n    21→\n    22→- bug: fixing something broken, a defect, vulnerability, or regression\n    23→- feedback: code review style issues (DRY violations, SOLID principles, architectural concerns, style issues)\n    24→- feature: new functionality being added\n    25→- enhancement: improving existing functionality\n    26→- chore: maintenance tasks, dependency updates, CI changes\n    27→\n    28→Respond with JSON: {\"classification\": \"<category>\"}\n    29→Do not include any other text.`\n    30→\n    31→\tresponse, err := c.LLM.Complete(ctx, systemPrompt, runPrompt)\n    32→\tif err != nil {\n    33→\t\treturn \"feature\", nil // default on error\n    34→\t}\n    35→\n    36→\tvar resp classifyResponse\n    37→\t// Try to parse JSON from the response - it might have extra text\n    38→\tresponse = strings.TrimSpace(response)\n    39→\tif err := json.Unmarshal([]byte(response), &resp); err != nil {\n    40→\t\treturn \"feature\", nil // default on parse error\n    41→\t}\n    42→\n    43→\t// Validate the classification\n    44→\tswitch resp.Classification {\n    45→\tcase \"bug\", \"feedback\", \"feature\", \"enhancement\", \"chore\":\n    46→\t\treturn resp.Classification, nil\n    47→\tdefault:\n    48→\t\treturn \"feature\", nil\n    49→\t}\n    50→}\n    51→"}]},"parent_tool_use_id":"toolu_01AcGnYryP1XRLSdUY7xEeoF","session_id":"d40c3d83-4916-4139-bbf3-80547b0a564f","uuid":"fc9d36e3-9fa4-4115-95a3-f296ac1fe0a5"}
