{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L6kTsKbqxLDTmSpsUafrFp","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→)\n    11→\n    12→// ScriptGenerator creates new checker/linter scripts via LLM code generation.\n    13→type ScriptGenerator struct {\n    14→\tLLM LLMClient\n    15→}\n    16→\n    17→type scriptResponse struct {\n    18→\tPath    string `json:\"path\"`\n    19→\tContent string `json:\"content\"`\n    20→}\n    21→\n    22→// GeneratedScript holds the result of script generation.\n    23→type GeneratedScript struct {\n    24→\tPath    string\n    25→\tContent string\n    26→}\n    27→\n    28→// Generate creates a script file based on the lesson.\n    29→func (g *ScriptGenerator) Generate(ctx context.Context, projectDir string, lesson *Lesson) (*GeneratedScript, error) {\n    30→\tsystemPrompt := `You are a script generator for software validation workflows.\n    31→Given a description of what needs to be checked, generate a shell script that performs the check.\n    32→\n    33→Rules:\n    34→- The script should exit 0 on success, non-zero on failure\n    35→- Keep it simple and focused on one check\n    36→- Use standard tools available in a typical development container\n    37→- Include a shebang line (#!/bin/bash or #!/bin/sh)\n    38→\n    39→Respond with JSON: {\"path\": \"scripts/<name>.sh\", \"content\": \"<script content>\"}\n    40→Use \\n for newlines in the content field.\n    41→Do not include any other text.`\n    42→\n    43→\tuserPrompt := fmt.Sprintf(\"Check needed: %s\\nDetails: %s\", lesson.Insight, lesson.SuggestedAction)\n    44→\n    45→\tresponse, err := g.LLM.Complete(ctx, systemPrompt, userPrompt)\n    46→\tif err != nil {\n    47→\t\treturn nil, fmt.Errorf(\"script generator LLM call: %w\", err)\n    48→\t}\n    49→\n    50→\tvar resp scriptResponse\n    51→\tresponse = strings.TrimSpace(response)\n    52→\tif err := json.Unmarshal([]byte(response), &resp); err != nil {\n    53→\t\treturn nil, fmt.Errorf(\"parsing script generator response: %w\", err)\n    54→\t}\n    55→\n    56→\tif resp.Path == \"\" || resp.Content == \"\" {\n    57→\t\treturn nil, fmt.Errorf(\"script generator returned empty path or content\")\n    58→\t}\n    59→\n    60→\t// Create parent directories\n    61→\tfullPath := filepath.Join(projectDir, resp.Path)\n    62→\tif err := os.MkdirAll(filepath.Dir(fullPath), 0755); err != nil {\n    63→\t\treturn nil, fmt.Errorf(\"creating script directory: %w\", err)\n    64→\t}\n    65→\n    66→\t// Write with executable permissions\n    67→\tif err := os.WriteFile(fullPath, []byte(resp.Content), 0755); err != nil {\n    68→\t\treturn nil, fmt.Errorf(\"writing script file: %w\", err)\n    69→\t}\n    70→\n    71→\treturn &GeneratedScript{Path: resp.Path, Content: resp.Content}, nil\n    72→}\n    73→"}]},"parent_tool_use_id":"toolu_01AcGnYryP1XRLSdUY7xEeoF","session_id":"d40c3d83-4916-4139-bbf3-80547b0a564f","uuid":"19a6ee14-e456-44a3-902a-17cf357d4ef4"}
