{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QudGwHSEtAoaqQYjdv5vwT","type":"tool_result","content":"     1→package domain\n     2→\n     3→import (\n     4→\t\"strings\"\n     5→\t\"time\"\n     6→)\n     7→\n     8→type RunState string\n     9→\n    10→const (\n    11→\tRunStatePending   RunState = \"pending\"\n    12→\tRunStateRunning   RunState = \"running\"\n    13→\tRunStateSucceeded RunState = \"succeeded\"\n    14→\tRunStateFailed    RunState = \"failed\"\n    15→\tRunStateCancelled RunState = \"cancelled\"\n    16→)\n    17→\n    18→// RunListFilter holds optional filters for listing runs.\n    19→type RunListFilter struct {\n    20→\tProjectDir string\n    21→\tState      RunState\n    22→\tTaskID     string\n    23→\tLimit      int\n    24→\tSince      time.Time\n    25→}\n    26→\n    27→type StepExecution struct {\n    28→\tStepName    string\n    29→\tResult      string\n    30→\tStartedAt   time.Time\n    31→\tCompletedAt time.Time\n    32→\tLogs        string\n    33→\tGitRef      string // output state\n    34→}\n    35→\n    36→func (e *StepExecution) Duration() time.Duration {\n    37→\treturn e.CompletedAt.Sub(e.StartedAt)\n    38→}\n    39→\n    40→type Run struct {\n    41→\tID             string\n    42→\tWorkflowName   string\n    43→\tState          RunState\n    44→\tActiveSteps    []string\n    45→\tStepExecutions []*StepExecution\n    46→\tStartedAt      time.Time\n    47→\tCompletedAt    time.Time\n    48→\tProjectDir     string\n    49→\tErrorMessage   string\n    50→\tContainerID    string\n    51→\tBaseSHA        string // Git HEAD at run start, for result branch creation\n    52→\tContainerKept  bool   // true when the container was retained after run completion\n    53→\tTitle          string // One-line summary of the work being done\n    54→\tIsHost         bool   // true for host workflow runs (vs container runs)\n    55→\tParentRunID    string // ID of the parent (host) run, empty for top-level runs\n    56→\tTaskID         string // optional task ID this run is associated with\n    57→}\n    58→\n    59→func NewRun(id, workflowName string) *Run {\n    60→\treturn &Run{\n    61→\t\tID:           id,\n    62→\t\tWorkflowName: workflowName,\n    63→\t\tState:        RunStatePending,\n    64→\t}\n    65→}\n    66→\n    67→func (r *Run) Start() {\n    68→\tr.State = RunStateRunning\n    69→\tr.StartedAt = time.Now()\n    70→}\n    71→\n    72→func (r *Run) RecordStepStart(stepName string) {\n    73→\tr.ActiveSteps = append(r.ActiveSteps, stepName)\n    74→\tr.StepExecutions = append(r.StepExecutions, &StepExecution{\n    75→\t\tStepName:  stepName,\n    76→\t\tStartedAt: time.Now(),\n    77→\t})\n    78→}\n    79→\n    80→func (r *Run) RecordStepComplete(stepName, result string) {\n    81→\t// Remove from active steps\n    82→\tfor i, name := range r.ActiveSteps {\n    83→\t\tif name == stepName {\n    84→\t\t\tr.ActiveSteps = append(r.ActiveSteps[:i], r.ActiveSteps[i+1:]...)\n    85→\t\t\tbreak\n    86→\t\t}\n    87→\t}\n    88→\t// Mark execution complete\n    89→\tfor i := len(r.StepExecutions) - 1; i >= 0; i-- {\n    90→\t\tif r.StepExecutions[i].StepName == stepName && r.StepExecutions[i].CompletedAt.IsZero() {\n    91→\t\t\tr.StepExecutions[i].Result = result\n    92→\t\t\tr.StepExecutions[i].CompletedAt = time.Now()\n    93→\t\t\treturn\n    94→\t\t}\n    95→\t}\n    96→}\n    97→\n    98→// ActiveStepsString returns a comma-separated representation of active steps\n    99→// for backward-compatible serialization.\n   100→func (r *Run) ActiveStepsString() string {\n   101→\treturn strings.Join(r.ActiveSteps, \",\")\n   102→}\n   103→\n   104→// SetActiveStepsFromString parses a comma-separated string into ActiveSteps.\n   105→func (r *Run) SetActiveStepsFromString(s string) {\n   106→\tif s == \"\" {\n   107→\t\tr.ActiveSteps = nil\n   108→\t\treturn\n   109→\t}\n   110→\tr.ActiveSteps = strings.Split(s, \",\")\n   111→}\n   112→\n   113→func (r *Run) Complete(state RunState) {\n   114→\tr.State = state\n   115→\tr.CompletedAt = time.Now()\n   116→}\n   117→\n   118→func (r *Run) Fail(msg string) {\n   119→\tr.State = RunStateFailed\n   120→\tr.CompletedAt = time.Now()\n   121→\tr.ErrorMessage = msg\n   122→}\n   123→\n   124→// stateSeverity returns a severity score for terminal RunStates.\n   125→// Higher values indicate worse outcomes.\n   126→func stateSeverity(s RunState) int {\n   127→\tswitch s {\n   128→\tcase RunStateSucceeded:\n   129→\t\treturn 0\n   130→\tcase RunStateCancelled:\n   131→\t\treturn 1\n   132→\tcase RunStateFailed:\n   133→\t\treturn 2\n   134→\tdefault:\n   135→\t\treturn -1\n   136→\t}\n   137→}\n   138→\n   139→// WorseState returns the more severe of two terminal RunStates.\n   140→// Failed is worse than cancelled, which is worse than succeeded.\n   141→func WorseState(a, b RunState) RunState {\n   142→\tif stateSeverity(b) > stateSeverity(a) {\n   143→\t\treturn b\n   144→\t}\n   145→\treturn a\n   146→}\n   147→\n   148→// TaskAggregateStatus computes the aggregate status for a group of runs\n   149→// representing attempts at a task. Active statuses (running, pending) outweigh\n   150→// terminal ones. Among terminal runs, host runs (which represent the full\n   151→// attempt including finalize) take precedence over child container runs.\n   152→// If no host runs exist, the most recently started run determines the result.\n   153→func TaskAggregateStatus(runs []*Run) RunState {\n   154→\tif len(runs) == 0 {\n   155→\t\treturn RunStatePending\n   156→\t}\n   157→\n   158→\t// Active statuses outweigh terminal ones. Prefer running over pending.\n   159→\thasRunning := false\n   160→\thasPending := false\n   161→\tfor _, r := range runs {\n   162→\t\tswitch r.State {\n   163→\t\tcase RunStateRunning:\n   164→\t\t\thasRunning = true\n   165→\t\tcase RunStatePending:\n   166→\t\t\thasPending = true\n   167→\t\t}\n   168→\t}\n   169→\tif hasRunning {\n   170→\t\treturn RunStateRunning\n   171→\t}\n   172→\tif hasPending {\n   173→\t\treturn RunStatePending\n   174→\t}\n   175→\n   176→\t// All runs are terminal. Prefer the most recently started host run,\n   177→\t// since it reflects the full attempt outcome (including finalize).\n   178→\t// Child container runs start after their parent, so naive most-recent\n   179→\t// selection would incorrectly pick a succeeded child over a failed host.\n   180→\tvar latestHost *Run\n   181→\tvar latest *Run\n   182→\tfor _, r := range runs {\n   183→\t\tif r.IsHost && (latestHost == nil || r.StartedAt.After(latestHost.StartedAt)) {\n   184→\t\t\tlatestHost = r\n   185→\t\t}\n   186→\t\tif latest == nil || r.StartedAt.After(latest.StartedAt) {\n   187→\t\t\tlatest = r\n   188→\t\t}\n   189→\t}\n   190→\tif latestHost != nil {\n   191→\t\treturn latestHost.State\n   192→\t}\n   193→\treturn latest.State\n   194→}\n   195→"}]},"parent_tool_use_id":"toolu_01AcGnYryP1XRLSdUY7xEeoF","session_id":"d40c3d83-4916-4139-bbf3-80547b0a564f","uuid":"a4a8f997-98cb-4e82-acfa-03c99824419b"}
