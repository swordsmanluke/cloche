{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HgPnZaXToQhXzDhxtAondw","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"sync\"\n     9→\t\"testing\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    12→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    13→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14→\t\"github.com/stretchr/testify/assert\"\n    15→\t\"github.com/stretchr/testify/require\"\n    16→)\n    17→\n    18→// errLLM returns a fixed error for testing error paths.\n    19→type errLLM struct {\n    20→\terr error\n    21→}\n    22→\n    23→func (e *errLLM) Complete(ctx context.Context, system, user string) (string, error) {\n    24→\treturn \"\", e.err\n    25→}\n    26→\n    27→// callTrackingLLM records calls and returns fixed responses in order.\n    28→type callTrackingLLM struct {\n    29→\tmu        sync.Mutex\n    30→\tresponses []string\n    31→\tidx       int\n    32→\tcalls     []llmCall\n    33→}\n    34→\n    35→type llmCall struct {\n    36→\tsystem string\n    37→\tuser   string\n    38→}\n    39→\n    40→func (c *callTrackingLLM) Complete(ctx context.Context, system, user string) (string, error) {\n    41→\tc.mu.Lock()\n    42→\tdefer c.mu.Unlock()\n    43→\tc.calls = append(c.calls, llmCall{system: system, user: user})\n    44→\tif c.idx >= len(c.responses) {\n    45→\t\treturn \"\", fmt.Errorf(\"no more responses\")\n    46→\t}\n    47→\tresp := c.responses[c.idx]\n    48→\tc.idx++\n    49→\treturn resp, nil\n    50→}\n    51→\n    52→// --- Mock stores ---\n    53→\n    54→type mockEvolutionStore struct {\n    55→\tlastEvolution *ports.EvolutionEntry\n    56→\truns          []*domain.Run\n    57→\tsaved         []*ports.EvolutionEntry\n    58→\tlistCalls     []listRunsSinceCall\n    59→}\n    60→\n    61→type listRunsSinceCall struct {\n    62→\tprojectDir   string\n    63→\tworkflowName string\n    64→\tsinceRunID   string\n    65→}\n    66→\n    67→func (m *mockEvolutionStore) SaveEvolution(ctx context.Context, entry *ports.EvolutionEntry) error {\n    68→\tm.saved = append(m.saved, entry)\n    69→\treturn nil\n    70→}\n    71→\n    72→func (m *mockEvolutionStore) GetLastEvolution(ctx context.Context, projectDir, workflowName string) (*ports.EvolutionEntry, error) {\n    73→\tif m.lastEvolution != nil {\n    74→\t\treturn m.lastEvolution, nil\n    75→\t}\n    76→\treturn nil, nil\n    77→}\n    78→\n    79→func (m *mockEvolutionStore) ListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error) {\n    80→\tm.listCalls = append(m.listCalls, listRunsSinceCall{projectDir, workflowName, sinceRunID})\n    81→\treturn m.runs, nil\n    82→}\n    83→\n    84→type mockCaptureStore struct {\n    85→\tcaptures map[string][]*domain.StepExecution\n    86→}\n    87→\n    88→func (m *mockCaptureStore) SaveCapture(ctx context.Context, runID string, exec *domain.StepExecution) error {\n    89→\treturn nil\n    90→}\n    91→\n    92→func (m *mockCaptureStore) GetCaptures(ctx context.Context, runID string) ([]*domain.StepExecution, error) {\n    93→\tif m.captures != nil {\n    94→\t\treturn m.captures[runID], nil\n    95→\t}\n    96→\treturn nil, nil\n    97→}\n    98→\n    99→// ===========================================================================\n   100→// Curator corruption scenarios\n   101→// ===========================================================================\n   102→\n   103→func setupCuratorDir(t *testing.T, promptContent string) (string, string) {\n   104→\tt.Helper()\n   105→\tdir := t.TempDir()\n   106→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   107→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   108→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   109→\tos.WriteFile(promptPath, []byte(promptContent), 0644)\n   110→\treturn dir, promptPath\n   111→}\n   112→\n   113→func TestCuratorCorruption_ConversationalMetaTextNoFences(t *testing.T) {\n   114→\t// LLM returns conversational meta-text without code fences — the actual\n   115→\t// corruption pattern seen in production.\n   116→\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n   117→\tdir, promptPath := setupCuratorDir(t, original)\n   118→\n   119→\t// The LLM returns a conversational response with no code fences at all.\n   120→\tconversationalResponse := \"Sure! I've updated the prompt to include a sanitization rule. The prompt now instructs the agent to always sanitize user inputs before processing them.\"\n   121→\tllm := &fakeLLM{response: conversationalResponse}\n   122→\n   123→\taudit := &AuditLogger{ProjectDir: dir}\n   124→\tc := &Curator{LLM: llm, Audit: audit}\n   125→\tlesson := &Lesson{\n   126→\t\tTarget:          \".cloche/prompts/implement.md\",\n   127→\t\tInsight:         \"XSS in form handlers\",\n   128→\t\tSuggestedAction: \"Add sanitization rule\",\n   129→\t}\n   130→\n   131→\t// Apply succeeds — the current implementation writes whatever comes back\n   132→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   133→\trequire.NoError(t, err)\n   134→\tassert.Equal(t, \"prompt_update\", change.Type)\n   135→\n   136→\t// The file now contains the conversational text instead of a valid prompt.\n   137→\t// This test documents the corruption behavior: since there are no code\n   138→\t// fences, stripCodeFences returns the response as-is.\n   139→\tcontent, err := os.ReadFile(promptPath)\n   140→\trequire.NoError(t, err)\n   141→\n   142→\t// The content IS the conversational text (the corruption).\n   143→\tassert.Equal(t, conversationalResponse, string(content))\n   144→\t// The original prompt header is lost.\n   145→\tassert.NotContains(t, string(content), \"# Implementation Prompt\")\n   146→}\n   147→\n   148→func TestCuratorCorruption_ResponseShorterThanOriginal(t *testing.T) {\n   149→\t// LLM returns a response that is shorter than the original prompt,\n   150→\t// representing total content loss.\n   151→\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Guidelines\\n\\n- Follow best practices\\n- Use proper error handling\\n- Write tests\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n- Never trust user data\\n\"\n   152→\tdir, promptPath := setupCuratorDir(t, original)\n   153→\n   154→\t// Extremely short response — most content is lost.\n   155→\tshortResponse := \"Write good code.\"\n   156→\tllm := &fakeLLM{response: shortResponse}\n   157→\n   158→\taudit := &AuditLogger{ProjectDir: dir}\n   159→\tc := &Curator{LLM: llm, Audit: audit}\n   160→\tlesson := &Lesson{\n   161→\t\tTarget:          \".cloche/prompts/implement.md\",\n   162→\t\tInsight:         \"Missing error handling\",\n   163→\t\tSuggestedAction: \"Add error handling rule\",\n   164→\t}\n   165→\n   166→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   167→\trequire.NoError(t, err)\n   168→\tassert.NotEmpty(t, change.Snapshot) // Snapshot was taken before corruption\n   169→\n   170→\tcontent, err := os.ReadFile(promptPath)\n   171→\trequire.NoError(t, err)\n   172→\n   173→\t// Documents the content loss: the prompt is now much shorter.\n   174→\tassert.Equal(t, shortResponse, string(content))\n   175→\tassert.Less(t, len(content), len(original))\n   176→\t// All the guidelines and learned rules are gone.\n   177→\tassert.NotContains(t, string(content), \"## Guidelines\")\n   178→\tassert.NotContains(t, string(content), \"## Learned Rules\")\n   179→}\n   180→\n   181→func TestCuratorCorruption_EmptyResponse(t *testing.T) {\n   182→\t// LLM returns an empty string — complete content destruction.\n   183→\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n   184→\tdir, promptPath := setupCuratorDir(t, original)\n   185→\n   186→\tllm := &fakeLLM{response: \"\"}\n   187→\n   188→\taudit := &AuditLogger{ProjectDir: dir}\n   189→\tc := &Curator{LLM: llm, Audit: audit}\n   190→\tlesson := &Lesson{\n   191→\t\tTarget:          \".cloche/prompts/implement.md\",\n   192→\t\tInsight:         \"Test insight\",\n   193→\t\tSuggestedAction: \"Test action\",\n   194→\t}\n   195→\n   196→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   197→\trequire.NoError(t, err)\n   198→\tassert.Equal(t, \"prompt_update\", change.Type)\n   199→\n   200→\tcontent, err := os.ReadFile(promptPath)\n   201→\trequire.NoError(t, err)\n   202→\t// The file is now empty.\n   203→\tassert.Empty(t, string(content))\n   204→}\n   205→\n   206→func TestCuratorCorruption_EmptyCodeFences(t *testing.T) {\n   207→\t// LLM returns only code fences with no content between them.\n   208→\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n   209→\tdir, promptPath := setupCuratorDir(t, original)\n   210→\n   211→\tllm := &fakeLLM{response: \"```markdown\\n```\"}\n   212→\n   213→\taudit := &AuditLogger{ProjectDir: dir}\n   214→\tc := &Curator{LLM: llm, Audit: audit}\n   215→\tlesson := &Lesson{\n   216→\t\tTarget:          \".cloche/prompts/implement.md\",\n   217→\t\tInsight:         \"Test insight\",\n   218→\t\tSuggestedAction: \"Test action\",\n   219→\t}\n   220→\n   221→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   222→\trequire.NoError(t, err)\n   223→\tassert.Equal(t, \"prompt_update\", change.Type)\n   224→\n   225→\tcontent, err := os.ReadFile(promptPath)\n   226→\trequire.NoError(t, err)\n   227→\t// The file content is now empty (stripped fences with nothing between).\n   228→\tassert.Empty(t, string(content))\n   229→}\n   230→\n   231→func TestCuratorCorruption_RaceConcurrentApply(t *testing.T) {\n   232→\t// Multiple rapid Curator.Apply() calls on the same file.\n   233→\toriginal := \"# Prompt\\n\\nOriginal content.\\n\"\n   234→\tdir, promptPath := setupCuratorDir(t, original)\n   235→\n   236→\taudit := &AuditLogger{ProjectDir: dir}\n   237→\n   238→\tconst goroutines = 10\n   239→\tvar wg sync.WaitGroup\n   240→\twg.Add(goroutines)\n   241→\n   242→\terrors := make([]error, goroutines)\n   243→\n   244→\tfor i := 0; i < goroutines; i++ {\n   245→\t\tgo func(idx int) {\n   246→\t\t\tdefer wg.Done()\n   247→\t\t\tllm := &fakeLLM{\n   248→\t\t\t\tresponse: fmt.Sprintf(\"# Prompt\\n\\nUpdated by goroutine %d.\\n\", idx),\n   249→\t\t\t}\n   250→\t\t\tc := &Curator{LLM: llm, Audit: audit}\n   251→\t\t\tlesson := &Lesson{\n   252→\t\t\t\tID:              fmt.Sprintf(\"lesson-%d\", idx),\n   253→\t\t\t\tTarget:          \".cloche/prompts/implement.md\",\n   254→\t\t\t\tInsight:         fmt.Sprintf(\"Insight %d\", idx),\n   255→\t\t\t\tSuggestedAction: fmt.Sprintf(\"Action %d\", idx),\n   256→\t\t\t}\n   257→\t\t\t_, errors[idx] = c.Apply(context.Background(), dir, lesson)\n   258→\t\t}(i)\n   259→\t}\n   260→\n   261→\twg.Wait()\n   262→\n   263→\t// All calls should succeed (no panics or crashes).\n   264→\tfor i, err := range errors {\n   265→\t\tassert.NoError(t, err, \"goroutine %d failed\", i)\n   266→\t}\n   267→\n   268→\t// The file should contain valid content from one of the goroutines.\n   269→\tcontent, err := os.ReadFile(promptPath)\n   270→\trequire.NoError(t, err)\n   271→\tassert.Contains(t, string(content), \"# Prompt\")\n   272→\tassert.Contains(t, string(content), \"Updated by goroutine\")\n   273→}\n   274→\n   275→func TestStripCodeFences_EmptyFences(t *testing.T) {\n   276→\t// Fences with nothing between them.\n   277→\tassert.Equal(t, \"\", stripCodeFences(\"```\\n```\"))\n   278→\tassert.Equal(t, \"\", stripCodeFences(\"```markdown\\n```\"))\n   279→}\n   280→\n   281→func TestStripCodeFences_OnlyWhitespace(t *testing.T) {\n   282→\t// Fences with only whitespace between them.\n   283→\tresult := stripCodeFences(\"```\\n   \\n```\")\n   284→\tassert.Equal(t, \"   \\n\", result)\n   285→}\n   286→\n   287→// ===========================================================================\n   288→// Orchestrator edge case tests\n   289→// ===========================================================================\n   290→\n   291→func setupOrchestratorDir(t *testing.T, workflowContent, promptContent, kbContent string) string {\n   292→\tt.Helper()\n   293→\tdir := t.TempDir()\n   294→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   295→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   296→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   297→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n   298→\t\t[]byte(kbContent), 0644)\n   299→\tif promptContent != \"\" {\n   300→\t\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n   301→\t\t\t[]byte(promptContent), 0644)\n   302→\t}\n   303→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   304→\t\t[]byte(workflowContent), 0644)\n   305→\treturn dir\n   306→}\n   307→\n   308→func TestOrchestratorReflectorProducesDuplicateLessons(t *testing.T) {\n   309→\t// Reflector produces lessons that are already in the knowledge base.\n   310→\t// The orchestrator should still apply them (curation handles dedup).\n   311→\tkb := \"# Knowledge Base: develop\\n\\n## Learned (2026-03-15)\\n- [L001] high: Always sanitize user inputs (run-1, run-2)\\n\"\n   312→\tdir := setupOrchestratorDir(t,\n   313→\t\t`workflow \"develop\" {\n   314→  step implement {\n   315→    prompt = file(\".cloche/prompts/implement.md\")\n   316→    results = [success, fail]\n   317→  }\n   318→  implement:success -> done\n   319→  implement:fail -> abort\n   320→}`,\n   321→\t\t\"# Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n   322→\t\tkb,\n   323→\t)\n   324→\n   325→\tllm := &scriptedLLM{\n   326→\t\tresponses: []string{\n   327→\t\t\t`{\"classification\": \"bug\"}`,\n   328→\t\t\t// Reflector returns a lesson that's already in the KB\n   329→\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Always sanitize user inputs\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-3\"], \"confidence\": \"high\"}]}`,\n   330→\t\t\t// Curator returns updated content (idempotent update)\n   331→\t\t\t\"# Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n   332→\t\t},\n   333→\t}\n   334→\n   335→\torch := NewOrchestrator(OrchestratorConfig{\n   336→\t\tProjectDir:    dir,\n   337→\t\tWorkflowName:  \"develop\",\n   338→\t\tLLM:           llm,\n   339→\t\tMinConfidence: \"medium\",\n   340→\t})\n   341→\n   342→\tresult, err := orch.Run(context.Background(), \"run-3\", nil, nil)\n   343→\trequire.NoError(t, err)\n   344→\t// Should still process the lesson even though it's a duplicate\n   345→\tassert.Len(t, result.Changes, 1)\n   346→\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n   347→\n   348→\t// Knowledge base gets the lesson appended again\n   349→\tkbContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"))\n   350→\tassert.Contains(t, string(kbContent), \"L001\")\n   351→}\n   352→\n   353→func TestOrchestratorHandleNewStepAlreadyExists(t *testing.T) {\n   354→\t// handleNewStep tries to add a step whose name collides with an\n   355→\t// existing step. The mutator's AddStep should fail because the\n   356→\t// workflow already contains a step with that name.\n   357→\tdir := setupOrchestratorDir(t,\n   358→\t\t`workflow \"develop\" {\n   359→  step implement {\n   360→    prompt = file(\".cloche/prompts/implement.md\")\n   361→    results = [success, fail]\n   362→  }\n   363→  step test {\n   364→    run = \"make test\"\n   365→    results = [success, fail]\n   366→  }\n   367→  implement:success -> test\n   368→  implement:fail -> abort\n   369→  test:success -> done\n   370→  test:fail -> abort\n   371→}`,\n   372→\t\t\"Write good code.\\n\",\n   373→\t\t\"# Knowledge Base: develop\\n\",\n   374→\t)\n   375→\n   376→\tllm := &scriptedLLM{\n   377→\t\tresponses: []string{\n   378→\t\t\t`{\"classification\": \"enhancement\"}`,\n   379→\t\t\t// Reflector suggests a new step with same name as an existing one\n   380→\t\t\t`{\"lessons\": [{\"id\": \"L003\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Need tests\", \"suggested_action\": \"Add test step\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n   381→\t\t\t// ScriptGenerator uses the name \"test.sh\" which derives to step name \"test\"\n   382→\t\t\t`{\"path\": \"scripts/test.sh\", \"content\": \"#!/bin/bash\\nmake test\"}`,\n   383→\t\t},\n   384→\t}\n   385→\n   386→\torch := NewOrchestrator(OrchestratorConfig{\n   387→\t\tProjectDir:    dir,\n   388→\t\tWorkflowName:  \"develop\",\n   389→\t\tLLM:           llm,\n   390→\t\tMinConfidence: \"medium\",\n   391→\t})\n   392→\n   393→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   394→\trequire.NoError(t, err)\n   395→\t// The add_script change is recorded before the step addition fails,\n   396→\t// but add_step should not appear because the mutator rejects duplicates.\n   397→\t// The `continue` in the orchestrator swallows the error.\n   398→\thasAddStep := false\n   399→\tfor _, c := range result.Changes {\n   400→\t\tif c.Type == \"add_step\" {\n   401→\t\t\thasAddStep = true\n   402→\t\t}\n   403→\t}\n   404→\t// Check if the mutator rejected the duplicate or allowed it.\n   405→\t// Either way, the orchestrator should not crash.\n   406→\t_ = hasAddStep // The test documents the behavior.\n   407→}\n   408→\n   409→func TestOrchestratorWorkflowValidAfterMultipleEvolutionCycles(t *testing.T) {\n   410→\t// Run N evolution cycles adding new steps and verify the workflow\n   411→\t// remains valid after each cycle.\n   412→\tdir := setupOrchestratorDir(t,\n   413→\t\t`workflow \"develop\" {\n   414→  step implement {\n   415→    prompt = file(\".cloche/prompts/implement.md\")\n   416→    results = [success, fail]\n   417→  }\n   418→  implement:success -> done\n   419→  implement:fail -> abort\n   420→}`,\n   421→\t\t\"Write good code.\\n\",\n   422→\t\t\"# Knowledge Base: develop\\n\",\n   423→\t)\n   424→\n   425→\tsteps := []struct {\n   426→\t\tscriptName string\n   427→\t\tscriptPath string\n   428→\t}{\n   429→\t\t{\"lint\", \"scripts/lint.sh\"},\n   430→\t\t{\"security-scan\", \"scripts/security-scan.sh\"},\n   431→\t\t{\"format-check\", \"scripts/format-check.sh\"},\n   432→\t}\n   433→\n   434→\tfor i, step := range steps {\n   435→\t\tllm := &scriptedLLM{\n   436→\t\t\tresponses: []string{\n   437→\t\t\t\t`{\"classification\": \"enhancement\"}`,\n   438→\t\t\t\tfmt.Sprintf(`{\"lessons\": [{\"id\": \"L%d\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Need %s\", \"suggested_action\": \"Add %s\", \"evidence\": [\"run-%d\"], \"confidence\": \"high\"}]}`, i+10, step.scriptName, step.scriptName, i+1),\n   439→\t\t\t\tfmt.Sprintf(`{\"path\": \"%s\", \"content\": \"#!/bin/bash\\necho %s\"}`, step.scriptPath, step.scriptName),\n   440→\t\t\t},\n   441→\t\t}\n   442→\n   443→\t\torch := NewOrchestrator(OrchestratorConfig{\n   444→\t\t\tProjectDir:    dir,\n   445→\t\t\tWorkflowName:  \"develop\",\n   446→\t\t\tLLM:           llm,\n   447→\t\t\tMinConfidence: \"medium\",\n   448→\t\t})\n   449→\n   450→\t\tresult, err := orch.Run(context.Background(), fmt.Sprintf(\"run-%d\", i+1), nil, nil)\n   451→\t\trequire.NoError(t, err, \"cycle %d failed\", i)\n   452→\t\trequire.NotEmpty(t, result.Changes, \"cycle %d produced no changes\", i)\n   453→\n   454→\t\t// Read the updated workflow and verify it parses and validates.\n   455→\t\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   456→\t\trequire.NoError(t, err)\n   457→\n   458→\t\twf, err := dsl.Parse(string(wfContent))\n   459→\t\trequire.NoError(t, err, \"workflow failed to parse after cycle %d:\\n%s\", i, string(wfContent))\n   460→\t\trequire.NoError(t, wf.Validate(), \"workflow failed to validate after cycle %d:\\n%s\", i, string(wfContent))\n   461→\t}\n   462→}\n   463→\n   464→func TestOrchestratorErrorInOneLessonDoesNotPreventOthers(t *testing.T) {\n   465→\t// The `continue` on line 90 of orchestrator.go silently swallows errors.\n   466→\t// Verify that if one lesson fails, other lessons still get applied.\n   467→\tdir := setupOrchestratorDir(t,\n   468→\t\t`workflow \"develop\" {\n   469→  step implement {\n   470→    prompt = file(\".cloche/prompts/implement.md\")\n   471→    results = [success, fail]\n   472→  }\n   473→  implement:success -> done\n   474→  implement:fail -> abort\n   475→}`,\n   476→\t\t\"Write good code.\\n\",\n   477→\t\t\"# Knowledge Base: develop\\n\",\n   478→\t)\n   479→\n   480→\t// Also create a second prompt file that the first lesson targets.\n   481→\t// The first lesson targets a non-existent file to trigger an error.\n   482→\tllm := &callTrackingLLM{\n   483→\t\tresponses: []string{\n   484→\t\t\t// Classifier\n   485→\t\t\t`{\"classification\": \"bug\"}`,\n   486→\t\t\t// Reflector returns two lessons: first targets a nonexistent file\n   487→\t\t\t`{\"lessons\": [\n   488→\t\t\t\t{\"id\": \"L-FAIL\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/nonexistent.md\", \"insight\": \"Bad target\", \"suggested_action\": \"This should fail\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"},\n   489→\t\t\t\t{\"id\": \"L-OK\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Good insight\", \"suggested_action\": \"Add good rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}\n   490→\t\t\t]}`,\n   491→\t\t\t// Curator response for the first lesson (will fail before this is used\n   492→\t\t\t// because reading the nonexistent file fails)\n   493→\t\t\t// This response won't be consumed because the file read fails first.\n   494→\t\t\t// Curator response for the second lesson\n   495→\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Good rule applied\\n\",\n   496→\t\t},\n   497→\t}\n   498→\n   499→\torch := NewOrchestrator(OrchestratorConfig{\n   500→\t\tProjectDir:    dir,\n   501→\t\tWorkflowName:  \"develop\",\n   502→\t\tLLM:           llm,\n   503→\t\tMinConfidence: \"medium\",\n   504→\t})\n   505→\n   506→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   507→\trequire.NoError(t, err)\n   508→\n   509→\t// The first lesson should have failed (nonexistent file), but the\n   510→\t// second lesson should have succeeded.\n   511→\tassert.Len(t, result.Changes, 1)\n   512→\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n   513→\tassert.Equal(t, \".cloche/prompts/implement.md\", result.Changes[0].File)\n   514→\n   515→\t// Verify the second prompt was actually updated.\n   516→\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n   517→\trequire.NoError(t, err)\n   518→\tassert.Contains(t, string(content), \"Good rule applied\")\n   519→}\n   520→\n   521→func TestOrchestratorSavesToEvolutionStore(t *testing.T) {\n   522→\t// Verify the orchestrator saves to the evolution store when lessons\n   523→\t// are produced. Note: with zero lessons the orchestrator returns early\n   524→\t// before the store-save path.\n   525→\tdir := setupOrchestratorDir(t,\n   526→\t\t`workflow \"develop\" {\n   527→  step implement {\n   528→    prompt = file(\".cloche/prompts/implement.md\")\n   529→    results = [success, fail]\n   530→  }\n   531→  implement:success -> done\n   532→  implement:fail -> abort\n   533→}`,\n   534→\t\t\"Write good code.\\n\",\n   535→\t\t\"# Knowledge Base: develop\\n\",\n   536→\t)\n   537→\n   538→\tllm := &scriptedLLM{\n   539→\t\tresponses: []string{\n   540→\t\t\t`{\"classification\": \"bug\"}`,\n   541→\t\t\t`{\"lessons\": [{\"id\": \"L-S\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Missing validation\", \"suggested_action\": \"Add rule\", \"evidence\": [\"run-42\"], \"confidence\": \"high\"}]}`,\n   542→\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Validate inputs\\n\",\n   543→\t\t},\n   544→\t}\n   545→\n   546→\tevoStore := &mockEvolutionStore{}\n   547→\n   548→\torch := NewOrchestrator(OrchestratorConfig{\n   549→\t\tProjectDir:    dir,\n   550→\t\tWorkflowName:  \"develop\",\n   551→\t\tLLM:           llm,\n   552→\t\tMinConfidence: \"medium\",\n   553→\t})\n   554→\n   555→\tresult, err := orch.Run(context.Background(), \"run-42\", evoStore, nil)\n   556→\trequire.NoError(t, err)\n   557→\tassert.Equal(t, \"bug\", result.Classification)\n   558→\n   559→\t// Verify the evolution was saved to the store.\n   560→\trequire.Len(t, evoStore.saved, 1)\n   561→\tassert.Equal(t, \"develop\", evoStore.saved[0].WorkflowName)\n   562→\tassert.Equal(t, \"run-42\", evoStore.saved[0].TriggerRunID)\n   563→\tassert.Equal(t, \"bug\", evoStore.saved[0].Classification)\n   564→}\n   565→\n   566→// ===========================================================================\n   567→// Collector tests with store mocks\n   568→// ===========================================================================\n   569→\n   570→func TestCollectorWithEvolutionStoreMock(t *testing.T) {\n   571→\tdir := t.TempDir()\n   572→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   573→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   574→\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n   575→\n   576→\truns := []*domain.Run{\n   577→\t\t{ID: \"run-5\", WorkflowName: \"develop\", ProjectDir: dir},\n   578→\t\t{ID: \"run-6\", WorkflowName: \"develop\", ProjectDir: dir},\n   579→\t}\n   580→\tevoStore := &mockEvolutionStore{\n   581→\t\tlastEvolution: &ports.EvolutionEntry{\n   582→\t\t\tID:           \"evo-prev\",\n   583→\t\t\tTriggerRunID: \"run-4\",\n   584→\t\t},\n   585→\t\truns: runs,\n   586→\t}\n   587→\n   588→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n   589→\tdata, err := c.Collect(context.Background(), evoStore, nil)\n   590→\trequire.NoError(t, err)\n   591→\n   592→\t// Should have fetched runs from the store.\n   593→\tassert.Len(t, data.Runs, 2)\n   594→\tassert.Equal(t, \"run-5\", data.Runs[0].ID)\n   595→\tassert.Equal(t, \"run-6\", data.Runs[1].ID)\n   596→}\n   597→\n   598→func TestCollectorListRunsSinceCalledWithCorrectRunID(t *testing.T) {\n   599→\tdir := t.TempDir()\n   600→\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n   601→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   602→\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n   603→\n   604→\tevoStore := &mockEvolutionStore{\n   605→\t\tlastEvolution: &ports.EvolutionEntry{\n   606→\t\t\tID:           \"evo-42\",\n   607→\t\t\tTriggerRunID: \"run-99\",\n   608→\t\t},\n   609→\t\truns: nil,\n   610→\t}\n   611→\n   612→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n   613→\t_, err := c.Collect(context.Background(), evoStore, nil)\n   614→\trequire.NoError(t, err)\n   615→\n   616→\t// Verify ListRunsSince was called with the correct sinceRunID\n   617→\t// from the last evolution entry.\n   618→\trequire.Len(t, evoStore.listCalls, 1)\n   619→\tassert.Equal(t, dir, evoStore.listCalls[0].projectDir)\n   620→\tassert.Equal(t, \"develop\", evoStore.listCalls[0].workflowName)\n   621→\tassert.Equal(t, \"run-99\", evoStore.listCalls[0].sinceRunID)\n   622→}\n   623→\n   624→func TestCollectorListRunsSinceEmptyWhenNoLastEvolution(t *testing.T) {\n   625→\tdir := t.TempDir()\n   626→\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n   627→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   628→\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n   629→\n   630→\t// No last evolution — sinceRunID should be empty.\n   631→\tevoStore := &mockEvolutionStore{\n   632→\t\tlastEvolution: nil,\n   633→\t\truns:          nil,\n   634→\t}\n   635→\n   636→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n   637→\t_, err := c.Collect(context.Background(), evoStore, nil)\n   638→\trequire.NoError(t, err)\n   639→\n   640→\trequire.Len(t, evoStore.listCalls, 1)\n   641→\tassert.Equal(t, \"\", evoStore.listCalls[0].sinceRunID)\n   642→}\n   643→\n   644→func TestCollectorWithCaptureStoreMock(t *testing.T) {\n   645→\tdir := t.TempDir()\n   646→\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n   647→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   648→\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n   649→\n   650→\truns := []*domain.Run{\n   651→\t\t{ID: \"run-10\", WorkflowName: \"develop\"},\n   652→\t\t{ID: \"run-11\", WorkflowName: \"develop\"},\n   653→\t}\n   654→\tevoStore := &mockEvolutionStore{runs: runs}\n   655→\n   656→\tcapStore := &mockCaptureStore{\n   657→\t\tcaptures: map[string][]*domain.StepExecution{\n   658→\t\t\t\"run-10\": {\n   659→\t\t\t\t{StepName: \"implement\", Result: \"success\"},\n   660→\t\t\t},\n   661→\t\t\t\"run-11\": {\n   662→\t\t\t\t{StepName: \"implement\", Result: \"fail\"},\n   663→\t\t\t\t{StepName: \"test\", Result: \"success\"},\n   664→\t\t\t},\n   665→\t\t},\n   666→\t}\n   667→\n   668→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n   669→\tdata, err := c.Collect(context.Background(), evoStore, capStore)\n   670→\trequire.NoError(t, err)\n   671→\n   672→\tassert.Len(t, data.Captures, 2)\n   673→\tassert.Len(t, data.Captures[\"run-10\"], 1)\n   674→\tassert.Len(t, data.Captures[\"run-11\"], 2)\n   675→\tassert.Equal(t, \"implement\", data.Captures[\"run-10\"][0].StepName)\n   676→\tassert.Equal(t, \"fail\", data.Captures[\"run-11\"][0].Result)\n   677→}\n   678→\n   679→// ===========================================================================\n   680→// Integration tests\n   681→// ===========================================================================\n   682→\n   683→func TestIntegration_CorruptPromptDetectedAndFixed(t *testing.T) {\n   684→\t// Full cycle: corrupt a prompt → run evolution → verify it produces a fix.\n   685→\tdir := setupOrchestratorDir(t,\n   686→\t\t`workflow \"develop\" {\n   687→  step implement {\n   688→    prompt = file(\".cloche/prompts/implement.md\")\n   689→    results = [success, fail]\n   690→  }\n   691→  implement:success -> done\n   692→  implement:fail -> abort\n   693→}`,\n   694→\t\t// Start with a \"corrupted\" prompt (conversational text, no useful instructions)\n   695→\t\t\"Sure! I've updated the prompt to include better instructions.\",\n   696→\t\t\"# Knowledge Base: develop\\n\",\n   697→\t)\n   698→\n   699→\t// The evolution pipeline should detect the corruption and fix it.\n   700→\tllm := &scriptedLLM{\n   701→\t\tresponses: []string{\n   702→\t\t\t// Classifier\n   703→\t\t\t`{\"classification\": \"bug\"}`,\n   704→\t\t\t// Reflector identifies the corruption\n   705→\t\t\t`{\"lessons\": [{\"id\": \"L-FIX\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Prompt was corrupted with conversational text\", \"suggested_action\": \"Restore proper prompt structure\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n   706→\t\t\t// Curator returns a proper prompt\n   707→\t\t\t\"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate user inputs\\n\",\n   708→\t\t},\n   709→\t}\n   710→\n   711→\torch := NewOrchestrator(OrchestratorConfig{\n   712→\t\tProjectDir:    dir,\n   713→\t\tWorkflowName:  \"develop\",\n   714→\t\tLLM:           llm,\n   715→\t\tMinConfidence: \"medium\",\n   716→\t})\n   717→\n   718→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   719→\trequire.NoError(t, err)\n   720→\trequire.Len(t, result.Changes, 1)\n   721→\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n   722→\n   723→\t// Verify the prompt is now proper.\n   724→\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n   725→\trequire.NoError(t, err)\n   726→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   727→\tassert.Contains(t, string(content), \"Always validate user inputs\")\n   728→\tassert.NotContains(t, string(content), \"Sure!\")\n   729→}\n   730→\n   731→func TestIntegration_StabilityNoCyclesNoDrift(t *testing.T) {\n   732→\t// Stability test: run N evolution cycles where the reflector finds no\n   733→\t// lessons. The workflow should remain unchanged.\n   734→\tworkflow := `workflow \"develop\" {\n   735→  step implement {\n   736→    prompt = file(\".cloche/prompts/implement.md\")\n   737→    results = [success, fail]\n   738→  }\n   739→  implement:success -> done\n   740→  implement:fail -> abort\n   741→}`\n   742→\tprompt := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n   743→\tdir := setupOrchestratorDir(t, workflow, prompt, \"# Knowledge Base: develop\\n\")\n   744→\n   745→\toriginalWorkflow, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   746→\toriginalPrompt, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n   747→\n   748→\tconst cycles = 5\n   749→\tfor i := 0; i < cycles; i++ {\n   750→\t\tllm := &scriptedLLM{\n   751→\t\t\tresponses: []string{\n   752→\t\t\t\t`{\"classification\": \"feature\"}`,\n   753→\t\t\t\t`{\"lessons\": []}`,\n   754→\t\t\t},\n   755→\t\t}\n   756→\n   757→\t\torch := NewOrchestrator(OrchestratorConfig{\n   758→\t\t\tProjectDir:    dir,\n   759→\t\t\tWorkflowName:  \"develop\",\n   760→\t\t\tLLM:           llm,\n   761→\t\t\tMinConfidence: \"medium\",\n   762→\t\t})\n   763→\n   764→\t\tresult, err := orch.Run(context.Background(), fmt.Sprintf(\"run-%d\", i+1), nil, nil)\n   765→\t\trequire.NoError(t, err, \"cycle %d failed\", i)\n   766→\t\tassert.Empty(t, result.Changes, \"cycle %d should have no changes\", i)\n   767→\t}\n   768→\n   769→\t// After N cycles, workflow and prompt should be identical.\n   770→\tfinalWorkflow, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   771→\tfinalPrompt, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n   772→\tassert.Equal(t, string(originalWorkflow), string(finalWorkflow), \"workflow drifted after %d cycles\", cycles)\n   773→\tassert.Equal(t, string(originalPrompt), string(finalPrompt), \"prompt drifted after %d cycles\", cycles)\n   774→}\n   775→\n   776→func TestIntegration_FullCycleWithStores(t *testing.T) {\n   777→\t// End-to-end with actual store mocks: collect → classify → reflect →\n   778→\t// apply → save to store.\n   779→\tdir := setupOrchestratorDir(t,\n   780→\t\t`workflow \"develop\" {\n   781→  step implement {\n   782→    prompt = file(\".cloche/prompts/implement.md\")\n   783→    results = [success, fail]\n   784→  }\n   785→  implement:success -> done\n   786→  implement:fail -> abort\n   787→}`,\n   788→\t\t\"# Prompt\\n\\nWrite code.\\n\",\n   789→\t\t\"# Knowledge Base: develop\\n\",\n   790→\t)\n   791→\n   792→\truns := []*domain.Run{\n   793→\t\t{ID: \"run-100\", WorkflowName: \"develop\", ProjectDir: dir},\n   794→\t}\n   795→\tevoStore := &mockEvolutionStore{\n   796→\t\tlastEvolution: &ports.EvolutionEntry{TriggerRunID: \"run-99\"},\n   797→\t\truns:          runs,\n   798→\t}\n   799→\tcapStore := &mockCaptureStore{\n   800→\t\tcaptures: map[string][]*domain.StepExecution{\n   801→\t\t\t\"run-100\": {\n   802→\t\t\t\t{StepName: \"implement\", Result: \"success\"},\n   803→\t\t\t},\n   804→\t\t},\n   805→\t}\n   806→\n   807→\tllm := &scriptedLLM{\n   808→\t\tresponses: []string{\n   809→\t\t\t`{\"classification\": \"bug\"}`,\n   810→\t\t\t`{\"lessons\": [{\"id\": \"L-STORE\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Missing validation\", \"suggested_action\": \"Add validation rule\", \"evidence\": [\"run-100\"], \"confidence\": \"high\"}]}`,\n   811→\t\t\t\"# Prompt\\n\\nWrite code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n\",\n   812→\t\t},\n   813→\t}\n   814→\n   815→\torch := NewOrchestrator(OrchestratorConfig{\n   816→\t\tProjectDir:    dir,\n   817→\t\tWorkflowName:  \"develop\",\n   818→\t\tLLM:           llm,\n   819→\t\tMinConfidence: \"medium\",\n   820→\t})\n   821→\n   822→\tresult, err := orch.Run(context.Background(), \"run-100\", evoStore, capStore)\n   823→\trequire.NoError(t, err)\n   824→\tassert.Equal(t, \"bug\", result.Classification)\n   825→\tassert.Len(t, result.Changes, 1)\n   826→\n   827→\t// Verify evolution was saved to store.\n   828→\trequire.Len(t, evoStore.saved, 1)\n   829→\tassert.Equal(t, \"run-100\", evoStore.saved[0].TriggerRunID)\n   830→\n   831→\t// Verify ListRunsSince was called correctly.\n   832→\trequire.Len(t, evoStore.listCalls, 1)\n   833→\tassert.Equal(t, \"run-99\", evoStore.listCalls[0].sinceRunID)\n   834→}\n   835→"}]},"parent_tool_use_id":"toolu_01UFM7x9ZkEjoc1a9sz8V73a","session_id":"0d73752c-6f12-4bd1-98b9-ceef2d13718a","uuid":"d9d0b470-b3e3-4352-8ee2-248fa8068703"}
