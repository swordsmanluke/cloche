{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XrWDkNncLdJtLmSCNDzabM","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    11→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    12→)\n    13→\n    14→// OrchestratorConfig configures the evolution pipeline.\n    15→type OrchestratorConfig struct {\n    16→\tProjectDir    string\n    17→\tWorkflowName  string\n    18→\tLLM           LLMClient\n    19→\tMinConfidence string\n    20→}\n    21→\n    22→// Orchestrator wires all evolution pipeline stages together.\n    23→type Orchestrator struct {\n    24→\tcfg        OrchestratorConfig\n    25→\tcollector  *Collector\n    26→\tclassifier *Classifier\n    27→\treflector  *Reflector\n    28→\tcurator    *Curator\n    29→\tscriptGen  *ScriptGenerator\n    30→\tmutator    *dsl.Mutator\n    31→\taudit      *AuditLogger\n    32→}\n    33→\n    34→// NewOrchestrator creates a fully wired evolution pipeline.\n    35→func NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n    36→\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir}\n    37→\treturn &Orchestrator{\n    38→\t\tcfg:        cfg,\n    39→\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n    40→\t\tclassifier: &Classifier{LLM: cfg.LLM},\n    41→\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n    42→\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n    43→\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n    44→\t\tmutator:    &dsl.Mutator{},\n    45→\t\taudit:      audit,\n    46→\t}\n    47→}\n    48→\n    49→// Run executes the full evolution pipeline.\n    50→func (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n    51→\t// Stage 1: Collect\n    52→\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n    53→\tif err != nil {\n    54→\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n    55→\t}\n    56→\n    57→\t// Stage 2: Classify the triggering run\n    58→\tclassification, err := o.classifier.Classify(ctx, \"\")\n    59→\tif err != nil {\n    60→\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n    61→\t}\n    62→\n    63→\t// Stage 3: Reflect\n    64→\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n    65→\tif err != nil {\n    66→\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n    67→\t}\n    68→\n    69→\tresult := &EvolutionResult{\n    70→\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n    71→\t\tProjectDir:     o.cfg.ProjectDir,\n    72→\t\tWorkflowName:   o.cfg.WorkflowName,\n    73→\t\tTriggerRunID:   triggerRunID,\n    74→\t\tTimestamp:      time.Now().Format(time.RFC3339),\n    75→\t\tClassification: classification,\n    76→\t}\n    77→\n    78→\tif len(lessons) == 0 {\n    79→\t\t// No actionable lessons — log and return\n    80→\t\to.audit.Log(result)\n    81→\t\treturn result, nil\n    82→\t}\n    83→\n    84→\t// Stage 4: Execute branches based on lesson category\n    85→\tfor _, lesson := range lessons {\n    86→\t\tswitch lesson.Category {\n    87→\t\tcase \"prompt_improvement\":\n    88→\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n    89→\t\t\tif err != nil {\n    90→\t\t\t\tcontinue // log but don't fail the whole pipeline\n    91→\t\t\t}\n    92→\t\t\tresult.Changes = append(result.Changes, *change)\n    93→\n    94→\t\tcase \"new_step\":\n    95→\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n    96→\t\t\t\tcontinue\n    97→\t\t\t}\n    98→\t\t}\n    99→\t}\n   100→\n   101→\t// Stage 5: Audit\n   102→\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n   103→\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n   104→\to.audit.Log(result)\n   105→\n   106→\t// Save to store if available\n   107→\tif evoStore != nil {\n   108→\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n   109→\t\t\tID:             result.ID,\n   110→\t\t\tProjectDir:     result.ProjectDir,\n   111→\t\t\tWorkflowName:   result.WorkflowName,\n   112→\t\t\tTriggerRunID:   result.TriggerRunID,\n   113→\t\t\tCreatedAt:      time.Now(),\n   114→\t\t\tClassification: result.Classification,\n   115→\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n   116→\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n   117→\t\t})\n   118→\t}\n   119→\n   120→\treturn result, nil\n   121→}\n   122→\n   123→// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\n   124→func (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n   125→\t// Generate the script or prompt file\n   126→\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n   127→\tif err != nil {\n   128→\t\treturn err\n   129→\t}\n   130→\n   131→\tresult.Changes = append(result.Changes, Change{\n   132→\t\tType:   \"add_script\",\n   133→\t\tFile:   generated.Path,\n   134→\t\tReason: lesson.Insight,\n   135→\t})\n   136→\n   137→\t// Add step and wiring to the workflow file\n   138→\tif data.WorkflowPath == \"\" {\n   139→\t\treturn nil\n   140→\t}\n   141→\n   142→\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n   143→\tif err != nil {\n   144→\t\treturn err\n   145→\t}\n   146→\n   147→\t// Snapshot the workflow\n   148→\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n   149→\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n   150→\n   151→\t// Derive step name from the script path\n   152→\tstepName := filepath.Base(generated.Path)\n   153→\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n   154→\n   155→\t// Determine the config based on step type\n   156→\tconfig := map[string]string{}\n   157→\tswitch lesson.StepType {\n   158→\tcase \"agent\":\n   159→\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n   160→\tdefault: // script\n   161→\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n   162→\t}\n   163→\n   164→\t// Add the step\n   165→\tupdated, err := o.mutator.AddStep(string(workflowContent), dsl.StepDef{\n   166→\t\tName:    stepName,\n   167→\t\tType:    lesson.StepType,\n   168→\t\tConfig:  config,\n   169→\t\tResults: []string{\"success\", \"fail\"},\n   170→\t})\n   171→\tif err != nil {\n   172→\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n   173→\t}\n   174→\n   175→\t// Wire the new step into the existing graph by finding a wire\n   176→\t// that currently goes to \"done\" and rerouting it through the new step.\n   177→\twf, parseErr := dsl.Parse(updated)\n   178→\tif parseErr == nil {\n   179→\t\tfor _, wire := range wf.Wiring {\n   180→\t\t\tif wire.To == \"done\" {\n   181→\t\t\t\trewired, rewireErr := o.mutator.RewireResult(updated, wire.From, wire.Result, \"done\", stepName)\n   182→\t\t\t\tif rewireErr == nil {\n   183→\t\t\t\t\tupdated = rewired\n   184→\t\t\t\t\tbreak\n   185→\t\t\t\t}\n   186→\t\t\t}\n   187→\t\t}\n   188→\t}\n   189→\n   190→\t// Wire the new step's results to terminals\n   191→\twires := []dsl.WireDef{\n   192→\t\t{From: stepName, Result: \"success\", To: \"done\"},\n   193→\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n   194→\t}\n   195→\tupdated, err = o.mutator.AddWiring(updated, wires)\n   196→\tif err != nil {\n   197→\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n   198→\t}\n   199→\n   200→\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n   201→\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n   202→\t}\n   203→\n   204→\tresult.Changes = append(result.Changes, Change{\n   205→\t\tType:     \"add_step\",\n   206→\t\tFile:     wfRelPath,\n   207→\t\tReason:   lesson.Insight,\n   208→\t\tSnapshot: snapName,\n   209→\t})\n   210→\n   211→\treturn nil\n   212→}\n   213→"}]},"parent_tool_use_id":"toolu_01UFM7x9ZkEjoc1a9sz8V73a","session_id":"0d73752c-6f12-4bd1-98b9-ceef2d13718a","uuid":"bbd993f7-c54b-47de-9628-8f21238a4d46"}
