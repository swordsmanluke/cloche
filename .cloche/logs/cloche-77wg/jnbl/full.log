n   465→    fill: var(--bg);\n   466→    stroke: var(--border);\n   467→    stroke-width: 1.5;\n   468→    rx: 4;\n   469→}\n   470→\n   471→.dag-node:hover .dag-node-rect { stroke: var(--link); stroke-width: 2; }\n   472→\n   473→.dag-node-text {\n   474→    font-family: var(--font);\n   475→    font-size: 13px;\n   476→    fill: var(--text);\n   477→}\n   478→\n   479→.dag-edge {\n   480→    fill: none;\n   481→    stroke: var(--text-muted);\n   482→    stroke-width: 1.5;\n   483→}\n   484→\n   485→.dag-edge-label {\n   486→    font-family: var(--font);\n   487→    font-size: 10px;\n   488→    fill: var(--text-muted);\n   489→    text-anchor: middle;\n   490→}\n   491→\n   492→.dag-terminal-done { fill: var(--badge-succeeded-bg); stroke: var(--badge-succeeded-text); }\n   493→.dag-terminal-abort { fill: var(--badge-failed-bg); stroke: var(--badge-failed-text); }\n   494→\n   495→.dag-merge-line { stroke-dasharray: 4 3; }\n   496→.dag-merge-dot { fill: var(--text-muted); }\n   497→\n   498→/* Drawer */\n   499→.drawer {\n   500→    position: fixed;\n   501→    top: 0;\n   502→    right: -420px;\n   503→    width: 400px;\n   504→    height: 100vh;\n   505→    background: var(--bg-surface);\n   506→    border-left: 1px solid var(--border);\n   507→    box-shadow: -4px 0 12px rgba(0,0,0,0.1);\n   508→    transition: right 0.25s ease;\n   509→    z-index: 100;\n   510→    display: flex;\n   511→    flex-direction: column;\n   512→    overflow: hidden;\n   513→}\n   514→\n   515→.drawer.drawer-open { right: 0; }\n   516→\n   517→.drawer-header {\n   518→    display: flex;\n   519→    justify-content: space-between;\n   520→    align-items: center;\n   521→    padding: 0.75rem 1rem;\n   522→    border-bottom: 1px solid var(--border);\n   523→    font-weight: 700;\n   524→    font-size: 1rem;\n   525→}\n   526→\n   527→.drawer-close {\n   528→    background: none;\n   529→    border: none;\n   530→    font-size: 1.4rem;\n   531→    cursor: pointer;\n   532→    color: var(--text-muted);\n   533→    padding: 0 0.25rem;\n   534→}\n   535→\n   536→.drawer-close:hover { color: var(--text); }\n   537→\n   538→.drawer-body {\n   539→    padding: 1rem;\n   540→    overflow-y: auto;\n   541→    flex: 1;\n   542→}\n   543→\n   544→.drawer-body pre {\n   545→    background: var(--bg);\n   546→    border: 1px solid var(--border);\n   547→    border-radius: var(--radius);\n   548→    padding: 0.75rem;\n   549→    font-family: var(--mono);\n   550→    font-size: 0.8rem;\n   551→    max-height: 400px;\n   552→    overflow: auto;\n   553→    white-space: pre-wrap;\n   554→    word-break: break-word;\n   555→}\n   556→\n   557→/* Diff block */\n   558→.diff-block {\n   559→    background: var(--bg);\n   560→    border: 1px solid var(--border);\n   561→    border-radius: var(--radius);\n   562→    padding: 0.5rem;\n   563→    font-family: var(--mono);\n   564→    font-size: 0.75rem;\n   565→    max-height: 300px;\n   566→    overflow: auto;\n   567→    white-space: pre-wrap;\n   568→    word-break: break-word;\n   569→    margin: 0.25rem 0 0.5rem;\n   570→}\n   571→\n   572→/* Orchestrator status */\n   573→.orch-status { font-size: 0.9rem; }\n   574→\n   575→/* Task grouping header */\n   576→.run-task-header td {\n   577→    font-weight: 600;\n   578→    background: var(--bg-secondary);\n   579→    border-bottom: 2px solid var(--border);\n   580→    padding: 0.5rem 0.75rem;\n   581→    color: var(--text);\n   582→    font-size: 0.9rem;\n   583→}\n   584→\n   585→/* Run tree grouping */\n   586→.run-parent-row { opacity: 0.7; }\n   587→.run-parent-row td:first-child { font-weight: 600; }\n   588→.run-child-row td:first-child { padding-left: 2rem; }\n   589→.run-child-row td:first-child::before {\n   590→    content: \"\\2514\\00a0\";\n   591→    color: var(--text-muted);\n   592→}\n   593→.tree-toggle {\n   594→    cursor: pointer;\n   595→    background: none;\n   596→    border: none;\n   597→    font-size: 0.75rem;\n   598→    color: var(--text-muted);\n   599→    padding: 0 0.25rem;\n   600→    margin-right: 0.25rem;\n   601→}\n   602→.tree-toggle:hover { color: var(--text); }\n   603→.parent-run-link { font-weight: 400; color: var(--text-muted); }\n   604→.parent-run-link:hover { color: var(--link); }\n   605→\n   606→/* Responsive */\n   607→@media (max-width: 768px) {\n   608→    .runs-table { font-size: 0.8rem; }\n   609→    .runs-table th, .runs-table td { padding: 0.4rem 0.5rem; }\n   610→    .run-meta dl { grid-template-columns: 1fr; }\n   611→    .project-cards { grid-template-columns: 1fr; }\n   612→    .log-viewer { max-height: 400px; }\n   613→    .drawer { width: 100%; right: -100%; }\n   614→}\n   615→"}]},"parent_tool_use_id":null,"session_id":"c616a170-3350-4dc1-8578-799b5046f490","uuid":"7344a242-b134-4ba3-b032-f264c1d54b58","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/static/style.css","content":":root {\n    --bg: #fff;\n    --bg-surface: #f8f9fa;\n    --text: #1a1a1a;\n    --text-muted: #6b7280;\n    --border: #e5e7eb;\n    --link: #2563eb;\n    --font: system-ui, -apple-system, sans-serif;\n    --mono: ui-monospace, \"Cascadia Code\", \"Fira Code\", monospace;\n    --radius: 4px;\n\n    --badge-pending-bg: #fef3c7;\n    --badge-pending-text: #92400e;\n    --badge-running-bg: #dbeafe;\n    --badge-running-text: #1e40af;\n    --badge-succeeded-bg: #d1fae5;\n    --badge-succeeded-text: #065f46;\n    --badge-failed-bg: #fee2e2;\n    --badge-failed-text: #991b1b;\n    --badge-cancelled-bg: #f3f4f6;\n    --badge-cancelled-text: #4b5563;\n    --badge-stopped-bg: #e5e7eb;\n    --badge-stopped-text: #4b5563;\n\n    --error-bg: #fef2f2;\n    --error-border: #fca5a5;\n    --error-text: #991b1b;\n}\n\n@media (prefers-color-scheme: dark) {\n    :root {\n        --bg: #111827;\n        --bg-surface: #1f2937;\n        --text: #f3f4f6;\n        --text-muted: #9ca3af;\n        --border: #374151;\n        --link: #60a5fa;\n\n        --badge-pending-bg: #78350f;\n        --badge-pending-text: #fde68a;\n        --badge-running-bg: #1e3a5f;\n        --badge-running-text: #93c5fd;\n        --badge-succeeded-bg: #064e3b;\n        --badge-succeeded-text: #6ee7b7;\n        --badge-failed-bg: #7f1d1d;\n        --badge-failed-text: #fca5a5;\n        --badge-cancelled-bg: #374151;\n        --badge-cancelled-text: #9ca3af;\n        --badge-stopped-bg: #374151;\n        --badge-stopped-text: #9ca3af;\n\n        --error-bg: #450a0a;\n        --error-border: #7f1d1d;\n        --error-text: #fca5a5;\n    }\n}\n\n*, *::before, *::after { box-sizing: border-box; }\n\nbody {\n    margin: 0;\n    font-family: var(--font);\n    background: var(--bg);\n    color: var(--text);\n    line-height: 1.5;\n}\n\n.container {\n    max-width: 1100px;\n    margin: 0 auto;\n    padding: 0 1rem;\n}\n\na { color: var(--link); text-decoration: none; }\na:hover { text-decoration: underline; }\n\n.navbar {\n    background: var(--bg-surface);\n    border-bottom: 1px solid var(--border);\n    padding: 0.75rem 0;\n    margin-bottom: 1.5rem;\n}\n\n.logo {\n    font-weight: 700;\n    font-size: 1.1rem;\n    color: var(--text);\n}\n.logo:hover { text-decoration: none; }\n\nh1 {\n    font-size: 1.4rem;\n    margin: 0 0 1rem;\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    flex-wrap: wrap;\n}\n\nh1 a { font-weight: 400; }\n\nh2 {\n    font-size: 1.1rem;\n    margin: 1.5rem 0 0.75rem;\n}\n\n/* Badges */\n.badge {\n    display: inline-block;\n    padding: 0.15em 0.55em;\n    border-radius: var(--radius);\n    font-size: 0.8rem;\n    font-weight: 600;\n    white-space: nowrap;\n}\n\n.badge-pending  { background: var(--badge-pending-bg);  color: var(--badge-pending-text); }\n.badge-running  { background: var(--badge-running-bg);  color: var(--badge-running-text); animation: pulse 2s infinite; }\n.badge-succeeded { background: var(--badge-succeeded-bg); color: var(--badge-succeeded-text); }\n.badge-failed   { background: var(--badge-failed-bg);   color: var(--badge-failed-text); }\n.badge-cancelled { background: var(--badge-cancelled-bg); color: var(--badge-cancelled-text); }\n.badge-stopped  { background: var(--badge-stopped-bg);  color: var(--badge-stopped-text); }\n\n@keyframes pulse {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0.6; }\n}\n\n/* Tables */\n.runs-table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 0.9rem;\n}\n\n.runs-table th,\n.runs-table td {\n    padding: 0.5rem 0.75rem;\n    text-align: left;\n    border-bottom: 1px solid var(--border);\n}\n\n.runs-table th {\n    background: var(--bg-surface);\n    font-weight: 600;\n    font-size: 0.8rem;\n    text-transform: uppercase;\n    letter-spacing: 0.03em;\n    color: var(--text-muted);\n}\n\n.runs-table tr:hover { background: var(--bg-surface); }\n.detail-row:hover { background: inherit; }\n.step-row { cursor: pointer; }\n.output-row td { padding: 0 !important; }\n.step-output {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 0.75rem;\n    font-family: var(--mono);\n    font-size: 0.8rem;\n    max-height: 500px;\n    overflow: auto;\n    white-space: pre-wrap;\n    word-break: break-word;\n    margin: 0.25rem 0.75rem 0.75rem;\n}\n\n.mono { font-family: var(--mono); font-size: 0.85em; }\n.empty { color: var(--text-muted); text-align: center; padding: 2rem 0; }\n.error-cell { color: var(--badge-failed-text); font-size: 0.85em; }\n\n/* Run metadata */\n.run-meta dl {\n    display: grid;\n    grid-template-columns: auto 1fr;\n    gap: 0.25rem 1rem;\n    margin: 0 0 1rem;\n    font-size: 0.9rem;\n}\n\n.run-meta dt { color: var(--text-muted); font-weight: 600; }\n.run-meta dd { margin: 0; }\n\n/* Error box */\n.error-box {\n    background: var(--error-bg);\n    border: 1px solid var(--error-border);\n    color: var(--error-text);\n    padding: 0.75rem 1rem;\n    border-radius: var(--radius);\n    margin-bottom: 1rem;\n    font-size: 0.9rem;\n}\n\n/* Details / pre */\ndetails {\n    margin: 0.5rem 0;\n}\n\ndetails summary {\n    cursor: pointer;\n    font-weight: 600;\n    font-size: 0.85rem;\n    color: var(--text-muted);\n}\n\ndetails pre {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 0.75rem;\n    font-family: var(--mono);\n    font-size: 0.8rem;\n    max-height: 400px;\n    overflow: auto;\n    white-space: pre-wrap;\n    word-break: break-word;\n    margin: 0.5rem 0 0;\n}\n\n/* Project filter */\n.project-filter {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    margin-bottom: 1rem;\n    font-size: 0.9rem;\n}\n\n.project-filter label {\n    font-weight: 600;\n    color: var(--text-muted);\n}\n\n.project-filter select {\n    font-family: var(--font);\n    font-size: 0.9rem;\n    padding: 0.3rem 0.5rem;\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    background: var(--bg);\n    color: var(--text);\n    cursor: pointer;\n}\n\n/* Project cards */\n.project-cards {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\n    gap: 1rem;\n}\n\n.project-card {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 1rem 1.25rem;\n    display: flex;\n    flex-direction: column;\n    gap: 0.75rem;\n}\n\n.project-header {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n}\n\n.project-name {\n    font-weight: 600;\n    font-size: 1.05rem;\n}\n\n/* Health indicator dots */\n.health-dot {\n    display: inline-block;\n    width: 12px;\n    height: 12px;\n    border-radius: 50%;\n    flex-shrink: 0;\n}\n\n.health-green  { background: #22c55e; }\n.health-yellow { background: #eab308; }\n.health-red    { background: #ef4444; }\n.health-grey   { background: #9ca3af; }\n.health-blue   { background: #3b82f6; animation: pulse 2s infinite; }\n\n/* Project stats */\n.project-stats {\n    display: flex;\n    gap: 1.5rem;\n}\n\n.stat {\n    display: flex;\n    flex-direction: column;\n}\n\n.stat-value {\n    font-weight: 700;\n    font-size: 1.1rem;\n}\n\n.stat-label {\n    font-size: 0.75rem;\n    color: var(--text-muted);\n    text-transform: uppercase;\n    letter-spacing: 0.03em;\n}\n\n/* Mini run history dots */\n.run-history {\n    display: flex;\n    gap: 4px;\n    align-items: center;\n    min-height: 16px;\n}\n\n.run-dot {\n    display: inline-block;\n    width: 10px;\n    height: 10px;\n    border-radius: 50%;\n}\n\n.run-dot-succeeded { background: #22c55e; }\n.run-dot-failed    { background: #ef4444; }\n.run-dot-cancelled { background: #9ca3af; }\n.run-dot-running   { background: #3b82f6; animation: pulse 2s infinite; }\n.run-dot-pending   { background: #eab308; }\n\n/* Action buttons */\n.project-actions {\n    display: flex;\n    gap: 0.5rem;\n    margin-top: 0.25rem;\n}\n\n.btn {\n    display: inline-block;\n    padding: 0.35em 0.75em;\n    border-radius: var(--radius);\n    font-family: var(--font);\n    font-size: 0.8rem;\n    font-weight: 600;\n    border: 1px solid var(--border);\n    cursor: pointer;\n    text-decoration: none;\n    white-space: nowrap;\n}\n\n.btn:hover { text-decoration: none; }\n\n.btn-secondary {\n    background: var(--bg);\n    color: var(--link);\n}\n\n.btn-secondary:hover { background: var(--bg-surface); }\n\n.btn-primary {\n    background: var(--link);\n    color: #fff;\n    border-color: var(--link);\n}\n\n.btn-primary:hover { opacity: 0.9; }\n\n.btn-danger {\n    background: var(--badge-failed-bg);\n    color: var(--badge-failed-text);\n    border-color: var(--error-border);\n}\n\n.btn-danger:hover { opacity: 0.8; }\n\n.btn-sm { font-size: 0.75rem; padding: 0.15em 0.45em; }\n\n.btn:disabled {\n    opacity: 0.6;\n    cursor: not-allowed;\n}\n\n/* Log viewer */\n.log-viewer {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    max-height: 600px;\n    overflow: auto;\n    margin-bottom: 1.5rem;\n}\n\n.log-viewer pre {\n    margin: 0;\n    padding: 0.75rem;\n    font-family: var(--mono);\n    font-size: 0.8rem;\n    white-space: pre-wrap;\n    word-break: break-word;\n    line-height: 1.4;\n}\n\n.log-line { display: block; }\n.log-type-status { color: var(--badge-running-text); }\n.log-type-llm { color: var(--badge-succeeded-text); }\n.log-type-script { color: var(--text); }\n\n/* Panels */\n.panel {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    margin-bottom: 1rem;\n}\n\n.panel-header {\n    font-weight: 700;\n    font-size: 0.9rem;\n    padding: 0.6rem 1rem;\n    border-bottom: 1px solid var(--border);\n    text-transform: uppercase;\n    letter-spacing: 0.03em;\n    color: var(--text-muted);\n}\n\n.panel-body {\n    padding: 1rem;\n}\n\n/* Tabs */\n.tab-bar {\n    display: flex;\n    gap: 0;\n    border-bottom: 1px solid var(--border);\n    margin-bottom: 1rem;\n}\n.tab-bar:empty {\n    display: none;\n}\n\n.tab-btn {\n    padding: 0.4rem 1rem;\n    font-family: var(--font);\n    font-size: 0.85rem;\n    font-weight: 600;\n    background: none;\n    border: none;\n    border-bottom: 2px solid transparent;\n    color: var(--text-muted);\n    cursor: pointer;\n}\n\n.tab-btn:hover { color: var(--text); }\n.tab-btn.tab-active { color: var(--link); border-bottom-color: var(--link); }\n\n/* DAG */\n.dag-svg { display: block; }\n#workflow-dag { overflow-x: auto; }\n\n.dag-node-rect {\n    fill: var(--bg);\n    stroke: var(--border);\n    stroke-width: 1.5;\n    rx: 4;\n}\n\n.dag-node:hover .dag-node-rect { stroke: var(--link); stroke-width: 2; }\n\n.dag-node-text {\n    font-family: var(--font);\n    font-size: 13px;\n    fill: var(--text);\n}\n\n.dag-edge {\n    fill: none;\n    stroke: var(--text-muted);\n    stroke-width: 1.5;\n}\n\n.dag-edge-label {\n    font-family: var(--font);\n    font-size: 10px;\n    fill: var(--text-muted);\n    text-anchor: middle;\n}\n\n.dag-terminal-done { fill: var(--badge-succeeded-bg); stroke: var(--badge-succeeded-text); }\n.dag-terminal-abort { fill: var(--badge-failed-bg); stroke: var(--badge-failed-text); }\n\n.dag-merge-line { stroke-dasharray: 4 3; }\n.dag-merge-dot { fill: var(--text-muted); }\n\n/* Drawer */\n.drawer {\n    position: fixed;\n    top: 0;\n    right: -420px;\n    width: 400px;\n    height: 100vh;\n    background: var(--bg-surface);\n    border-left: 1px solid var(--border);\n    box-shadow: -4px 0 12px rgba(0,0,0,0.1);\n    transition: right 0.25s ease;\n    z-index: 100;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n}\n\n.drawer.drawer-open { right: 0; }\n\n.drawer-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 0.75rem 1rem;\n    border-bottom: 1px solid var(--border);\n    font-weight: 700;\n    font-size: 1rem;\n}\n\n.drawer-close {\n    background: none;\n    border: none;\n    font-size: 1.4rem;\n    cursor: pointer;\n    color: var(--text-muted);\n    padding: 0 0.25rem;\n}\n\n.drawer-close:hover { color: var(--text); }\n\n.drawer-body {\n    padding: 1rem;\n    overflow-y: auto;\n    flex: 1;\n}\n\n.drawer-body pre {\n    background: var(--bg);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 0.75rem;\n    font-family: var(--mono);\n    font-size: 0.8rem;\n    max-height: 400px;\n    overflow: auto;\n    white-space: pre-wrap;\n    word-break: break-word;\n}\n\n/* Diff block */\n.diff-block {\n    background: var(--bg);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 0.5rem;\n    font-family: var(--mono);\n    font-size: 0.75rem;\n    max-height: 300px;\n    overflow: auto;\n    white-space: pre-wrap;\n    word-break: break-word;\n    margin: 0.25rem 0 0.5rem;\n}\n\n/* Orchestrator status */\n.orch-status { font-size: 0.9rem; }\n\n/* Task grouping header */\n.run-task-header td {\n    font-weight: 600;\n    background: var(--bg-secondary);\n    border-bottom: 2px solid var(--border);\n    padding: 0.5rem 0.75rem;\n    color: var(--text);\n    font-size: 0.9rem;\n}\n\n/* Run tree grouping */\n.run-parent-row { opacity: 0.7; }\n.run-parent-row td:first-child { font-weight: 600; }\n.run-child-row td:first-child { padding-left: 2rem; }\n.run-child-row td:first-child::before {\n    content: \"\\2514\\00a0\";\n    color: var(--text-muted);\n}\n.tree-toggle {\n    cursor: pointer;\n    background: none;\n    border: none;\n    font-size: 0.75rem;\n    color: var(--text-muted);\n    padding: 0 0.25rem;\n    margin-right: 0.25rem;\n}\n.tree-toggle:hover { color: var(--text); }\n.parent-run-link { font-weight: 400; color: var(--text-muted); }\n.parent-run-link:hover { color: var(--link); }\n\n/* Responsive */\n@media (max-width: 768px) {\n    .runs-table { font-size: 0.8rem; }\n    .runs-table th, .runs-table td { padding: 0.4rem 0.5rem; }\n    .run-meta dl { grid-template-columns: 1fr; }\n    .project-cards { grid-template-columns: 1fr; }\n    .log-viewer { max-height: 400px; }\n    .drawer { width: 100%; right: -100%; }\n}\n","numLines":615,"startLine":1,"totalLines":615}}}
