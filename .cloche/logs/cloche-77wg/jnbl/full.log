geX - 20) + ' ' + arcY + ' ' + mergeX + ' ' + arcY + '\" class=\"' + cls + '\"/>';\n            svg += '<text x=\"' + (pt.x + dx * 0.35) + '\" y=\"' + (arcY - 6) + '\" class=\"dag-edge-label\">' + pt.result + '</text>';\n        });\n\n        // Vertical collector line\n        var mergeEnds = srcPts.map(function(pt) { return pt.y + (isSuccessResult(pt.result) ? 0 : nonsuccOffset); });\n        mergeEnds.push(termY);\n        var minY = Math.min.apply(null, mergeEnds);\n        var maxY = Math.max.apply(null, mergeEnds);\n        var hasNonSucc = tWires.some(function(w) { return !isSuccessResult(w.result); });\n        svg += '<path d=\"M' + mergeX + ' ' + minY + ' L' + mergeX + ' ' + maxY + '\" class=\"dag-edge dag-merge-line' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\"/>';\n\n        // Merge point dots (at offset positions for non-success wires)\n        srcPts.forEach(function(pt) {\n            var off = isSuccessResult(pt.result) ? 0 : nonsuccOffset;\n            svg += '<circle cx=\"' + mergeX + '\" cy=\"' + (pt.y + off) + '\" r=\"3\" class=\"dag-merge-dot\"/>';\n        });\n\n        // Single line from collector to terminal\n        var mergeMarker = hasNonSucc ? 'url(#arrowhead-fail)' : 'url(#arrowhead)';\n        svg += '<path d=\"M' + mergeX + ' ' + termY + ' L' + tpos.x + ' ' + termY + '\" class=\"dag-edge' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\" marker-end=\"' + mergeMarker + '\"/>';"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":830,"cache_read_input_tokens":63388,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":830},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c616a170-3350-4dc1-8578-799b5046f490","uuid":"9efb0d1f-7dd6-4b4f-a8b8-4fbd0a779610"}
