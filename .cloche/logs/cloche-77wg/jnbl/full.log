[2026-03-13T17:44:27Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XYbJRNvqYoRUhaLPDceX24","type":"tool_result","content":"The file /workspace/internal/adapters/web/templates/project_detail.html has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"c616a170-3350-4dc1-8578-799b5046f490","uuid":"1a343351-c304-4b0f-92fb-ab568fc9bd61","tool_use_result":{"filePath":"/workspace/internal/adapters/web/templates/project_detail.html","oldString":"    var nodeGap = 28;   // vertical gap between nodes in same layer","newString":"    var nodeGap = 28;   // vertical gap between nodes in same layer\n    var nonsuccOffset = 35; // vertical offset for non-success wires","originalFile":"{{define \"content\"}}\n<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n\n<div class=\"run-history\" style=\"margin-bottom:1rem\">\n    {{range .RecentRuns}}\n    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n    {{end}}\n    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n    {{if .ContainerCount}}\n    <button class=\"btn btn-danger btn-sm\" id=\"delete-containers-btn\" onclick=\"deleteAllContainers()\" style=\"margin-left:0.5rem\">Delete {{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}</button>\n    {{end}}\n</div>\n\n<!-- Panel 1: Project Info -->\n<div class=\"panel\" id=\"info-panel\">\n    <div class=\"panel-header\">Project Info</div>\n    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n</div>\n\n<!-- Panel 2: Tasks -->\n<div class=\"panel\" id=\"tasks-panel\">\n    <div class=\"panel-header\">Tasks</div>\n    <div class=\"panel-body\" id=\"tasks-body\">Loading...</div>\n</div>\n\n<!-- Panel 3: Workflow View -->\n<div class=\"panel\" id=\"workflow-panel\">\n    <div class=\"panel-header\">Workflows</div>\n    <div class=\"panel-body\">\n        <div id=\"location-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-dag\"></div>\n    </div>\n</div>\n\n<!-- Step Drawer -->\n<div class=\"drawer\" id=\"step-drawer\">\n    <div class=\"drawer-header\">\n        <span id=\"drawer-title\"></span>\n        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    </div>\n    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n</div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\nvar projectLabel = {{.Label}};\n\nfunction loadProjectInfo() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n            html += '</dl>';\n\n            if (data.prompt_files && data.prompt_files.length > 0) {\n                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n                data.prompt_files.forEach(function(pf) {\n                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n                    if (pf.content) {\n                        html += '<pre class=\"diff-block\">' + pf.content.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n                    } else {\n                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">Empty file</p>';\n                    }\n                    html += '</details>';\n                });\n            }\n\n            document.getElementById('project-info').innerHTML = html;\n        });\n}\n\nfunction toggleDiff(el) {\n    var existing = el.nextElementSibling;\n    if (existing && existing.classList.contains('diff-block')) {\n        existing.remove();\n        return;\n    }\n    var file = el.getAttribute('data-file');\n    var sha = el.getAttribute('data-sha');\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n        .then(function(r) { return r.text(); })\n        .then(function(text) {\n            var pre = document.createElement('pre');\n            pre.className = 'diff-block';\n            pre.textContent = text || '(no diff available)';\n            el.parentNode.insertBefore(pre, el.nextSibling);\n        });\n}\n\nvar workflowsData = [];\nvar activeLocation = 'container';\n\nfunction loadWorkflows() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            workflowsData = data || [];\n            if (workflowsData.length === 0) {\n                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n                return;\n            }\n\n            // Check which locations exist\n            var hasContainer = workflowsData.some(function(wf) { return wf.location === 'container'; });\n            var hasHost = workflowsData.some(function(wf) { return wf.location === 'host'; });\n\n            // Render location tabs if both types exist\n            var locationTabs = document.getElementById('location-tabs');\n            if (hasContainer && hasHost) {\n                var html = '';\n                html += '<button class=\"tab-btn tab-active\" onclick=\"switchLocation(\\'container\\')\">Container</button>';\n                html += '<button class=\"tab-btn\" onclick=\"switchLocation(\\'host\\')\">Host</button>';\n                locationTabs.innerHTML = html;\n            } else {\n                locationTabs.innerHTML = '';\n            }\n\n            // Default to whichever location exists\n            activeLocation = hasContainer ? 'container' : 'host';\n            renderWorkflowTabs();\n        });\n}\n\nfunction switchLocation(loc) {\n    activeLocation = loc;\n    var btns = document.querySelectorAll('#location-tabs .tab-btn');\n    btns.forEach(function(b) {\n        b.classList.toggle('tab-active', b.textContent === (loc === 'container' ? 'Container' : 'Host'));\n    });\n    renderWorkflowTabs();\n}\n\nfunction renderWorkflowTabs() {\n    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n    var tabs = document.getElementById('workflow-tabs');\n\n    if (filtered.length === 0) {\n        tabs.innerHTML = '';\n        document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No ' + activeLocation + ' workflows found</p>';\n        return;\n    }\n\n    if (filtered.length > 1) {\n        var html = '';\n        filtered.forEach(function(wf, i) {\n            html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showFilteredWorkflow(' + i + ')\">' + wf.name + '</button>';\n        });\n        tabs.innerHTML = html;\n    } else {\n        tabs.innerHTML = '';\n    }\n    showFilteredWorkflow(0);\n}\n\nfunction showFilteredWorkflow(idx) {\n    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n    var btns = document.querySelectorAll('#workflow-tabs .tab-btn');\n    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n    showWorkflow(filtered[idx]);\n}\n\nfunction showWorkflow(wf) {\n    var dagEl = document.getElementById('workflow-dag');\n\n    if (!wf.steps || wf.steps.length === 0) {\n        dagEl.innerHTML = '<p class=\"empty\">No steps defined</p>';\n        return;\n    }\n\n    var stepMap = {};\n    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n\n    var wires = wf.wires || [];\n\n    // Collect terminal targets\n    var terminals = {};\n    wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n    });\n\n    // Build adjacency maps\n    var adj = {};    // from -> [wire]\n    var revAdj = {}; // to -> [from] (unique)\n    wires.forEach(function(wire) {\n        if (!adj[wire.from]) adj[wire.from] = [];\n        adj[wire.from].push(wire);\n        if (!revAdj[wire.to]) revAdj[wire.to] = [];\n        if (revAdj[wire.to].indexOf(wire.from) === -1) revAdj[wire.to].push(wire.from);\n    });\n\n    // --- Layer assignment via longest path (Sugiyama-style) ---\n    var stepNames = wf.steps.map(function(s) { return s.name; });\n\n    // Topological sort (Kahn's algorithm)\n    var inDeg = {};\n    stepNames.forEach(function(n) { inDeg[n] = 0; });\n    wires.forEach(function(wire) {\n        if (inDeg[wire.to] !== undefined) inDeg[wire.to]++;\n    });\n\n    var queue = [];\n    stepNames.forEach(function(n) { if (inDeg[n] === 0) queue.push(n); });\n\n    var topoOrder = [];\n    while (queue.length > 0) {\n        var n = queue.shift();\n        topoOrder.push(n);\n        (adj[n] || []).forEach(function(wire) {\n            if (inDeg[wire.to] !== undefined) {\n                inDeg[wire.to]--;\n                if (inDeg[wire.to] === 0) queue.push(wire.to);\n            }\n        });\n    }\n    // Add remaining steps (cycles or disconnected)\n    stepNames.forEach(function(n) { if (topoOrder.indexOf(n) === -1) topoOrder.push(n); });\n\n    // Assign layers: longest path from any source\n    var layerOf = {};\n    topoOrder.forEach(function(n) {\n        var maxParent = -1;\n        (revAdj[n] || []).forEach(function(p) {\n            if (layerOf[p] !== undefined && layerOf[p] > maxParent) maxParent = layerOf[p];\n        });\n        layerOf[n] = maxParent + 1;\n    });\n\n    var maxLayer = 0;\n    stepNames.forEach(function(n) { if (layerOf[n] > maxLayer) maxLayer = layerOf[n]; });\n\n    // Terminals in rightmost layer\n    var termLayer = maxLayer + 1;\n    for (var t in terminals) { layerOf[t] = termLayer; }\n    var numLayers = termLayer + 1;\n\n    // --- Build layer arrays ---\n    var layers = [];\n    for (var i = 0; i < numLayers; i++) layers.push([]);\n    topoOrder.forEach(function(n) { layers[layerOf[n]].push(n); });\n    for (var t in terminals) { layers[termLayer].push(t); }\n\n    // --- Barycenter ordering to minimize edge crossings ---\n    for (var pass = 0; pass < 4; pass++) {\n        // Forward pass\n        for (var li = 1; li < numLayers; li++) {\n            var bary = {};\n            layers[li].forEach(function(n) {\n                var pars = revAdj[n] || [];\n                var sum = 0, cnt = 0;\n                pars.forEach(function(p) {\n                    var idx = layers[li - 1].indexOf(p);\n                    if (idx >= 0) { sum += idx; cnt++; }\n                });\n                bary[n] = cnt > 0 ? sum / cnt : 999;\n            });\n            layers[li].sort(function(a, b) { return bary[a] - bary[b]; });\n        }\n        // Backward pass\n        for (var li = numLayers - 2; li >= 0; li--) {\n            var baryB = {};\n            layers[li].forEach(function(n) {\n                var children = (adj[n] || []).map(function(w) { return w.to; });\n                var sum = 0, cnt = 0;\n                children.forEach(function(c) {\n                    var idx = layers[li + 1].indexOf(c);\n                    if (idx >= 0) { sum += idx; cnt++; }\n                });\n                baryB[n] = cnt > 0 ? sum / cnt : 999;\n            });\n            layers[li].sort(function(a, b) { return baryB[a] - baryB[b]; });\n        }\n    }\n\n    // --- Position calculation ---\n    var nodeW = 180, nodeH = 48;\n    var layerGap = 120; // horizontal gap between layers\n    var nodeGap = 28;   // vertical gap between nodes in same layer\n    var padL = 30, padT = 30;\n\n    var maxInLayer = 1;\n    layers.forEach(function(l) { if (l.length > maxInLayer) maxInLayer = l.length; });\n    var totalLayerH = maxInLayer * nodeH + (maxInLayer - 1) * nodeGap;\n\n    var positions = {};\n    layers.forEach(function(layer, li) {\n        var lh = layer.length * nodeH + (layer.length - 1) * nodeGap;\n        var offsetY = (totalLayerH - lh) / 2;\n        layer.forEach(function(name, ni) {\n            positions[name] = {\n                x: padL + li * (nodeW + layerGap),\n                y: padT + offsetY + ni * (nodeH + nodeGap)\n            };\n        });\n    });\n\n    var svgW = padL * 2 + numLayers * nodeW + (numLayers - 1) * layerGap;\n    var svgH = padT * 2 + totalLayerH;\n\n    // --- Generate SVG ---\n    var svg = '<svg class=\"dag-svg\" width=\"' + svgW + '\" height=\"' + svgH + '\">';\n    svg += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n\n    // Separate terminal wires (for merging) from normal wires\n    var termWires = {};\n    var normWires = [];\n    wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') {\n            if (!termWires[wire.to]) termWires[wire.to] = [];\n            termWires[wire.to].push(wire);\n        } else {\n            normWires.push(wire);\n        }\n    });\n\n    // Draw normal edges with Bezier curves\n    normWires.forEach(function(wire) {\n        var from = positions[wire.from], to = positions[wire.to];\n        if (!from || !to) return;\n        var x1 = from.x + nodeW, y1 = from.y + nodeH / 2;\n        var x2 = to.x, y2 = to.y + nodeH / 2;\n        var dx = x2 - x1;\n        svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + dx * 0.4) + ' ' + y1 + ' ' + (x1 + dx * 0.6) + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n        svg += '<text x=\"' + (x1 + dx / 2) + '\" y=\"' + ((y1 + y2) / 2 - 6) + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n    });\n\n    // Draw terminal edges with merge pattern for multiple wires\n    for (var term in termWires) {\n        var tWires = termWires[term];\n        var tpos = positions[term];\n        if (!tpos) continue;\n\n        if (tWires.length <= 1) {\n            // Single wire to terminal - draw normally\n            tWires.forEach(function(wire) {\n                var from = positions[wire.from];\n                if (!from) return;\n                var x1 = from.x + nodeW, y1 = from.y + nodeH / 2;\n                var x2 = tpos.x, y2 = tpos.y + nodeH / 2;\n                var dx = x2 - x1;\n                svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + dx * 0.4) + ' ' + y1 + ' ' + (x1 + dx * 0.6) + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n                svg += '<text x=\"' + (x1 + dx / 2) + '\" y=\"' + ((y1 + y2) / 2 - 6) + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n            });\n            continue;\n        }\n\n        // Multiple wires to same terminal: merge into a collector bus\n        var mergeX = tpos.x - 50;\n        var termY = tpos.y + nodeH / 2;\n\n        var srcPts = [];\n        tWires.forEach(function(wire) {\n            var from = positions[wire.from];\n            if (!from) return;\n            srcPts.push({ x: from.x + nodeW, y: from.y + nodeH / 2, result: wire.result });\n        });\n        srcPts.sort(function(a, b) { return a.y - b.y; });\n\n        // Individual curves from each source to the merge line\n        srcPts.forEach(function(pt) {\n            var dx = mergeX - pt.x;\n            svg += '<path d=\"M' + pt.x + ' ' + pt.y + ' C' + (pt.x + dx * 0.5) + ' ' + pt.y + ' ' + (mergeX - 20) + ' ' + pt.y + ' ' + mergeX + ' ' + pt.y + '\" class=\"dag-edge\"/>';\n            svg += '<text x=\"' + (pt.x + dx * 0.35) + '\" y=\"' + (pt.y - 6) + '\" class=\"dag-edge-label\">' + pt.result + '</text>';\n        });\n\n        // Vertical collector line\n        var minY = Math.min(srcPts[0].y, termY);\n        var maxY = Math.max(srcPts[srcPts.length - 1].y, termY);\n        svg += '<path d=\"M' + mergeX + ' ' + minY + ' L' + mergeX + ' ' + maxY + '\" class=\"dag-edge dag-merge-line\"/>';\n\n        // Merge point dots\n        srcPts.forEach(function(pt) {\n            svg += '<circle cx=\"' + mergeX + '\" cy=\"' + pt.y + '\" r=\"3\" class=\"dag-merge-dot\"/>';\n        });\n\n        // Single line from collector to terminal\n        svg += '<path d=\"M' + mergeX + ' ' + termY + ' L' + tpos.x + ' ' + termY + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n    }\n\n    // Draw step nodes\n    wf.steps.forEach(function(s) {\n        var pos = positions[s.name];\n        if (!pos) return;\n        var icon = '\\u{1F4DC}';\n        if (s.type === 'agent') icon = '\\u{1F916}';\n        else if (s.type === 'workflow') icon = '\\u{1F501}';\n        svg += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + s.name + '\\')\" style=\"cursor:pointer\">';\n        svg += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n        svg += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + s.name + '</text>';\n        svg += '</g>';\n    });\n\n    // Draw terminal nodes\n    for (var t in terminals) {\n        var pos = positions[t];\n        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n        svg += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n        svg += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n    }\n\n    svg += '</svg>';\n    dagEl.innerHTML = svg;\n}\n\nfunction openDrawer(workflowName, stepName) {\n    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n    if (!wf) return;\n    var step = wf.steps.find(function(s) { return s.name === stepName; });\n    if (!step) return;\n\n    document.getElementById('drawer-title').textContent = stepName;\n    var body = '<dl class=\"run-meta\">';\n    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n    if (step.config) {\n        for (var k in step.config) {\n            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script' || k === 'run' || k === 'workflow_name') {\n                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n            }\n        }\n    }\n    body += '</dl>';\n    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n\n    document.getElementById('drawer-body').innerHTML = body;\n    document.getElementById('step-drawer').classList.add('drawer-open');\n\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n        .then(function(r) { if (r.ok) return r.text(); return ''; })\n        .then(function(text) {\n            var el = document.getElementById('drawer-content');\n            if (text) {\n                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n            } else {\n                el.style.display = 'none';\n            }\n        });\n}\n\nfunction closeDrawer() {\n    document.getElementById('step-drawer').classList.remove('drawer-open');\n}\n\ndocument.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') closeDrawer();\n});\n\nwindow.deleteAllContainers = function() {\n    var btn = document.getElementById('delete-containers-btn');\n    if (btn) btn.disabled = true;\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/containers', { method: 'DELETE' })\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            if (btn) {\n                btn.textContent = 'Deleted ' + (data.deleted || 0) + ' container' + (data.deleted !== 1 ? 's' : '');\n                btn.classList.remove('btn-danger');\n                btn.classList.add('btn-secondary');\n            }\n        })\n        .catch(function() {\n            if (btn) {\n                btn.textContent = 'Delete failed';\n                btn.disabled = false;\n            }\n        });\n};\n\nfunction escapeHtml(s) {\n    var d = document.createElement('div');\n    d.appendChild(document.createTextNode(s));\n    return d.innerHTML;\n}\n\nfunction loadTasks() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/tasks')\n        .then(function(r) { return r.json(); })\n        .then(function(tasks) {\n            var body = document.getElementById('tasks-body');\n            if (!tasks || tasks.length === 0) {\n                body.innerHTML = '<p class=\"empty\">No tasks discovered</p>';\n                return;\n            }\n            var html = '<table class=\"runs-table\" style=\"margin:0\"><thead><tr>';\n            html += '<th>Task ID</th><th>Title</th><th>Status</th><th>Assigned</th><th>Run</th>';\n            html += '</tr></thead><tbody>';\n            for (var i = 0; i < tasks.length; i++) {\n                var t = tasks[i];\n                var statusClass = t.status === 'open' ? 'running' : (t.status === 'closed' ? 'succeeded' : 'pending');\n                html += '<tr>';\n                html += '<td class=\"mono\">' + escapeHtml(t.id) + '</td>';\n                html += '<td>' + escapeHtml(t.title || '') + '</td>';\n                html += '<td><span class=\"badge badge-' + statusClass + '\">' + escapeHtml(t.status) + '</span></td>';\n                html += '<td>' + (t.assigned ? 'Yes' : 'No') + '</td>';\n                html += '<td>' + (t.run_id ? '<a href=\"/runs/' + escapeHtml(t.run_id) + '\">' + escapeHtml(t.run_id) + '</a>' : '') + '</td>';\n                html += '</tr>';\n            }\n            html += '</tbody></table>';\n            body.innerHTML = html;\n        })\n        .catch(function() {});\n}\n\n// Load all panels\nloadProjectInfo();\nloadWorkflows();\nloadTasks();\nsetInterval(loadTasks, 5000);\n</script>\n{{end}}\n","structuredPatch":[{"oldStart":279,"oldLines":6,"newStart":279,"newLines":7,"lines":["     var nodeW = 180, nodeH = 48;","     var layerGap = 120; // horizontal gap between layers","     var nodeGap = 28;   // vertical gap between nodes in same layer","+    var nonsuccOffset = 35; // vertical offset for non-success wires","     var padL = 30, padT = 30;"," ","     var maxInLayer = 1;"]}],"userModified":false,"replaceAll":false}}
