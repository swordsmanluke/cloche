GET /projects/{name}/runs\", h.handleProjectRuns)\n   148→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   149→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   150→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   151→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   152→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   153→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   154→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   155→\th.mux.HandleFunc(\"POST /api/runs/{id}/stop\", h.handleAPIStopRun)\n   156→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   157→\th.mux.HandleFunc(\"DELETE /api/projects/{name}/containers\", h.handleAPIDeleteProjectContainers)\n   158→\th.mux.HandleFunc(\"DELETE /api/containers\", h.handleAPIDeleteAllContainers)\n   159→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   160→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   161→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   162→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   163→\th.mux.HandleFunc(\"GET /api/projects/{name}/tasks\", h.handleAPITasks)\n   164→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   165→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   166→\n   167→\treturn h, nil\n   168→}\n   169→\n   170→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   171→\th.mux.ServeHTTP(w, r)\n   172→}\n   173→\n   174→// --- HTML handlers ---\n   175→\n   176→// projectOverviewEntry holds data for a single project card on the landing page.\n   177→type projectOverviewEntry struct {\n   178→\tDir         string\n   179→\tLabel       string\n   180→\tHealth      domain.HealthResult\n   181→\tRecentRuns  []recentRunDot\n   182→\tActiveCount int\n   183→}\n   184→\n   185→// recentRunDot is a minimal representation of a run for the mini history display.\n   186→type recentRunDot struct {\n   187→\tID    string\n   188→\tState string\n   189→}\n   190→\n   191→const healthWindowSize = 10\n   192→\n   193→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   194→\tprojects, _ := h.store.ListProjects(r.Context())\n   195→\tlabels := projectLabels(projects)\n   196→\n   197→\tvar entries []projectOverviewEntry\n   198→\tfor _, dir := range projects {\n   199→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})"}]},"parent_tool_use_id":"toolu_01CDMiNsYDeokNGDGPoWKGXF","session_id":"c616a170-3350-4dc1-8578-799b5046f490","uuid":"41c4df7b-e6bb-4972-adee-faaa972b6f56"}
