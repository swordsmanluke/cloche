ss wires\n   347→            tWires.forEach(function(wire) {\n   348→                var from = positions[wire.from];\n   349→                if (!from) return;\n   350→                var x1 = from.x + nodeW, y1 = from.y + nodeH / 2;\n   351→                var x2 = tpos.x, y2 = tpos.y + nodeH / 2;\n   352→                var dx = x2 - x1;\n   353→                var isSucc = isSuccessResult(wire.result);\n   354→                var off = isSucc ? 0 : nonsuccOffset;\n   355→                var cls = 'dag-edge' + (isSucc ? '' : ' dag-edge-nonsuccess');\n   356→                var marker = isSucc ? 'url(#arrowhead)' : 'url(#arrowhead-fail)';\n   357→                svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + dx * 0.4) + ' ' + (y1 + off) + ' ' + (x1 + dx * 0.6) + ' ' + (y2 + off) + ' ' + x2 + ' ' + y2 + '\" class=\"' + cls + '\" marker-end=\"' + marker + '\"/>';\n   358→                svg += '<text x=\"' + (x1 + dx / 2) + '\" y=\"' + ((y1 + y2) / 2 + off - 6) + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n   359→            });\n   360→            continue;\n   361→        }\n   362→\n   363→        // Multiple wires to same terminal: merge into a collector bus\n   364→        var mergeX = tpos.x - 50;\n   365→        var termY = tpos.y + nodeH / 2;\n   366→\n   367→        var srcPts = [];\n   368→        tWires.forEach(function(wire) {\n   369→            var from = positions[wire.from];\n   370→            if (!from) return;\n   371→            srcPts.push({ x: from.x + nodeW, y: from.y + nodeH / 2, result: wire.result });\n   372→        });\n   373→        srcPts.sort(function(a, b) { return a.y - b.y; });\n   374→\n   375→        // Individual curves from each source to the merge line (offset non-success)\n   376→        srcPts.forEach(function(pt) {\n   377→            var isSucc = isSuccessResult(pt.result);\n   378→            var off = isSucc ? 0 : nonsuccOffset;\n   379→            var dx = mergeX - pt.x;\n   380→            var arcY = pt.y + off;\n   381→            var cls = 'dag-edge' + (isSucc ? '' : ' dag-edge-nonsuccess');\n   382→            svg += '<path d=\"M' + pt.x + ' ' + pt.y + ' C' + (pt.x + dx * 0.5) + ' ' + arcY + ' ' + (mergeX - 20) + ' ' + arcY + ' ' + mergeX + ' ' + arcY + '\" class=\"' + cls + '\"/>';\n   383→            svg += '<text x=\"' + (pt.x + dx * 0.35) + '\" y=\"' + (arcY - 6) + '\" class=\"dag-edge-label\">' + pt.result + '</text>';\n   384→        });\n   385→\n   386→        // Vertical collector line\n   387→        var mergeEnds = srcPts.map(function(pt) { return pt.y + (isSuccessResult(pt.result) ? 0 : nonsuccOffset); });\n   388→        mergeEnds.push(termY);\n   389→        var minY = Math.min.apply(null, mergeEnds);\n   390→        var maxY = Math.max.apply(null, mergeEnds);\n   391→        var hasNonSucc = tWires.some(function(w) { return !isSuccessResult(w.result); });\n   392→        svg += '<path d=\"M' + mergeX + ' ' + minY + ' L' + mergeX + ' ' + maxY + '\" class=\"dag-edge dag-merge-line' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\"/>';\n   393→\n   394→        // Merge point dots (at offset positions for non-success wires)\n   395→        srcPts.forEach(function(pt) {\n   396→            var off = isSuccessResult(pt.result) ? 0 : nonsuccOffset;\n   397→            svg += '<circle cx=\"' + mergeX + '\" cy=\"' + (pt.y + off) + '\" r=\"3\" class=\"dag-merge-dot\"/>';\n   398→        });\n   399→\n   400→        // Single line from collector to terminal\n   401→        var mergeMarker = hasNonSucc ? 'url(#arrowhead-fail)' : 'url(#arrowhead)';\n   402→        svg += '<path d=\"M' + mergeX + ' ' + termY + ' L' + tpos.x + ' ' + termY + '\" class=\"dag-edge' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\" marker-end=\"' + mergeMarker + '\"/>';\n   403→    }\n   404→\n   405→    // Draw step nodes\n   406→    wf.steps.forEach(function(s) {\n   407→        var pos = positions[s.name];"}]},"parent_tool_use_id":null,"session_id":"c616a170-3350-4dc1-8578-799b5046f490","uuid":"d2fe4ae0-96a7-4df5-b1c5-bb1372e3c9eb","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/project_detail.html","content":"    // --- Position calculation ---\n    var nodeW = 180, nodeH = 48;\n    var layerGap = 120; // horizontal gap between layers\n    var nodeGap = 28;   // vertical gap between nodes in same layer\n    var nonsuccOffset = 35; // vertical offset for non-success wires\n    var padL = 30, padT = 30;\n\n    var maxInLayer = 1;\n    layers.forEach(function(l) { if (l.length > maxInLayer) maxInLayer = l.length; });\n    var totalLayerH = maxInLayer * nodeH + (maxInLayer - 1) * nodeGap;\n\n    var positions = {};\n    layers.forEach(function(layer, li) {\n        var lh = layer.length * nodeH + (layer.length - 1) * nodeGap;\n        var offsetY = (totalLayerH - lh) / 2;\n        layer.forEach(function(name, ni) {\n            positions[name] = {\n                x: padL + li * (nodeW + layerGap),\n                y: padT + offsetY + ni * (nodeH + nodeGap)\n            };\n        });\n    });\n\n    var svgW = padL * 2 + numLayers * nodeW + (numLayers - 1) * layerGap;\n    var svgH = padT * 2 + totalLayerH + nonsuccOffset;\n\n    // --- Generate SVG ---\n    var svg = '<svg class=\"dag-svg\" width=\"' + svgW + '\" height=\"' + svgH + '\">';\n    svg += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker>';\n    svg += '<marker id=\"arrowhead-fail\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--badge-failed-text)\"/></marker></defs>';\n\n    // Separate terminal wires (for merging) from normal wires\n    var termWires = {};\n    var normWires = [];\n    wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') {\n            if (!termWires[wire.to]) termWires[wire.to] = [];\n            termWires[wire.to].push(wire);\n        } else {\n            normWires.push(wire);\n        }\n    });\n\n    // Helper: determine if a result is the success/happy-path\n    function isSuccessResult(r) { return r === 'success' || r === 'ok' || r === 'done' || r === 'pass'; }\n\n    // Draw normal edges with Bezier curves\n    normWires.forEach(function(wire) {\n        var from = positions[wire.from], to = positions[wire.to];\n        if (!from || !to) return;\n        var x1 = from.x + nodeW, y1 = from.y + nodeH / 2;\n        var x2 = to.x, y2 = to.y + nodeH / 2;\n        var dx = x2 - x1;\n        var isSucc = isSuccessResult(wire.result);\n        var off = isSucc ? 0 : nonsuccOffset;\n        var cls = 'dag-edge' + (isSucc ? '' : ' dag-edge-nonsuccess');\n        var marker = isSucc ? 'url(#arrowhead)' : 'url(#arrowhead-fail)';\n        svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + dx * 0.4) + ' ' + (y1 + off) + ' ' + (x1 + dx * 0.6) + ' ' + (y2 + off) + ' ' + x2 + ' ' + y2 + '\" class=\"' + cls + '\" marker-end=\"' + marker + '\"/>';\n        svg += '<text x=\"' + (x1 + dx / 2) + '\" y=\"' + ((y1 + y2) / 2 + off - 6) + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n    });\n\n    // Draw terminal edges with merge pattern for multiple wires\n    for (var term in termWires) {\n        var tWires = termWires[term];\n        var tpos = positions[term];\n        if (!tpos) continue;\n\n        if (tWires.length <= 1) {\n            // Single wire to terminal - offset non-success wires\n            tWires.forEach(function(wire) {\n                var from = positions[wire.from];\n                if (!from) return;\n                var x1 = from.x + nodeW, y1 = from.y + nodeH / 2;\n                var x2 = tpos.x, y2 = tpos.y + nodeH / 2;\n                var dx = x2 - x1;\n                var isSucc = isSuccessResult(wire.result);\n                var off = isSucc ? 0 : nonsuccOffset;\n                var cls = 'dag-edge' + (isSucc ? '' : ' dag-edge-nonsuccess');\n                var marker = isSucc ? 'url(#arrowhead)' : 'url(#arrowhead-fail)';\n                svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + dx * 0.4) + ' ' + (y1 + off) + ' ' + (x1 + dx * 0.6) + ' ' + (y2 + off) + ' ' + x2 + ' ' + y2 + '\" class=\"' + cls + '\" marker-end=\"' + marker + '\"/>';\n                svg += '<text x=\"' + (x1 + dx / 2) + '\" y=\"' + ((y1 + y2) / 2 + off - 6) + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n            });\n            continue;\n        }\n\n        // Multiple wires to same terminal: merge into a collector bus\n        var mergeX = tpos.x - 50;\n        var termY = tpos.y + nodeH / 2;\n\n        var srcPts = [];\n        tWires.forEach(function(wire) {\n            var from = positions[wire.from];\n            if (!from) return;\n            srcPts.push({ x: from.x + nodeW, y: from.y + nodeH / 2, result: wire.result });\n        });\n        srcPts.sort(function(a, b) { return a.y - b.y; });\n\n        // Individual curves from each source to the merge line (offset non-success)\n        srcPts.forEach(function(pt) {\n            var isSucc = isSuccessResult(pt.result);\n            var off = isSucc ? 0 : nonsuccOffset;\n            var dx = mergeX - pt.x;\n            var arcY = pt.y + off;\n            var cls = 'dag-edge' + (isSucc ? '' : ' dag-edge-nonsuccess');\n            svg += '<path d=\"M' + pt.x + ' ' + pt.y + ' C' + (pt.x + dx * 0.5) + ' ' + arcY + ' ' + (mergeX - 20) + ' ' + arcY + ' ' + mergeX + ' ' + arcY + '\" class=\"' + cls + '\"/>';\n            svg += '<text x=\"' + (pt.x + dx * 0.35) + '\" y=\"' + (arcY - 6) + '\" class=\"dag-edge-label\">' + pt.result + '</text>';\n        });\n\n        // Vertical collector line\n        var mergeEnds = srcPts.map(function(pt) { return pt.y + (isSuccessResult(pt.result) ? 0 : nonsuccOffset); });\n        mergeEnds.push(termY);\n        var minY = Math.min.apply(null, mergeEnds);\n        var maxY = Math.max.apply(null, mergeEnds);\n        var hasNonSucc = tWires.some(function(w) { return !isSuccessResult(w.result); });\n        svg += '<path d=\"M' + mergeX + ' ' + minY + ' L' + mergeX + ' ' + maxY + '\" class=\"dag-edge dag-merge-line' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\"/>';\n\n        // Merge point dots (at offset positions for non-success wires)\n        srcPts.forEach(function(pt) {\n            var off = isSuccessResult(pt.result) ? 0 : nonsuccOffset;\n            svg += '<circle cx=\"' + mergeX + '\" cy=\"' + (pt.y + off) + '\" r=\"3\" class=\"dag-merge-dot\"/>';\n        });\n\n        // Single line from collector to terminal\n        var mergeMarker = hasNonSucc ? 'url(#arrowhead-fail)' : 'url(#arrowhead)';\n        svg += '<path d=\"M' + mergeX + ' ' + termY + ' L' + tpos.x + ' ' + termY + '\" class=\"dag-edge' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\" marker-end=\"' + mergeMarker + '\"/>';\n    }\n\n    // Draw step nodes\n    wf.steps.forEach(function(s) {\n        var pos = positions[s.name];","numLines":130,"startLine":278,"totalLines":535}}}
