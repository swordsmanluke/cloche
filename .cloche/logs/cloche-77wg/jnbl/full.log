[2026-03-13T17:44:27Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UiP9SH5m477xHhPomANT93","type":"tool_result","content":"  1000→\t\tdeleted++\n  1001→\t}\n  1002→\n  1003→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1004→\tresp := map[string]any{\"deleted\": deleted}\n  1005→\tif len(errors) > 0 {\n  1006→\t\tresp[\"errors\"] = errors\n  1007→\t}\n  1008→\tjson.NewEncoder(w).Encode(resp)\n  1009→}\n  1010→\n  1011→// handleAPIStream serves an SSE stream of log lines for a run.\n  1012→// For active runs, it subscribes to the live broadcaster.\n  1013→// For completed runs, it serves the archived full.log then closes.\n  1014→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n  1015→\tid := r.PathValue(\"id\")\n  1016→\n  1017→\trun, err := h.store.GetRun(r.Context(), id)\n  1018→\tif err != nil {\n  1019→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n  1020→\t\treturn\n  1021→\t}\n  1022→\n  1023→\tflusher, ok := w.(http.Flusher)\n  1024→\tif !ok {\n  1025→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n  1026→\t\treturn\n  1027→\t}\n  1028→\n  1029→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n  1030→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n  1031→\tw.Header().Set(\"Connection\", \"keep-alive\")\n  1032→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n  1033→\n  1034→\tisComplete := run.State == domain.RunStateSucceeded ||\n  1035→\t\trun.State == domain.RunStateFailed ||\n  1036→\t\trun.State == domain.RunStateCancelled\n  1037→\n  1038→\tif isComplete {\n  1039→\t\t// Serve archived full.log\n  1040→\t\th.streamFullLog(w, flusher, run)\n  1041→\t\t// Send done event\n  1042→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n  1043→\t\tflusher.Flush()\n  1044→\t\treturn\n  1045→\t}\n  1046→\n  1047→\t// Active run: subscribe to live broadcaster\n  1048→\tif h.logBroadcast == nil {\n  1049→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n  1050→\t\treturn\n  1051→\t}\n  1052→\n  1053→\tsub := h.logBroadcast.Subscribe(id)\n  1054→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n  1055→\n  1056→\tctx := r.Context()\n  1057→\tfor {\n  1058→\t\tselect {\n  1059→\t\tcase <-ctx.Done():\n  1060→\t\t\treturn\n  1061→\t\tcase line, ok := <-sub.C:\n  1062→\t\t\tif !ok {\n  1063→\t\t\t\t// Stream finished (run completed)\n  1064→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n  1065→\t\t\t\tflusher.Flush()\n  1066→\t\t\t\treturn\n  1067→\t\t\t}\n  1068→\t\t\tline = parseLLMLogLine(line)\n  1069→\t\t\tif line.Type == \"\" {\n  1070→\t\t\t\tcontinue // skip protocol-only llm lines\n  1071→\t\t\t}\n  1072→\t\t\tdata, _ := json.Marshal(line)\n  1073→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n  1074→\t\t\tflusher.Flush()\n  1075→\t\t}\n  1076→\t}\n  1077→}\n  1078→\n  1079→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n  1080→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n  1081→\n  1082→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n  1083→// LLM-type lines are parsed from raw Claude JSON into human-readable text.\n  1084→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n  1085→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n  1086→\tf, err := os.Open(logPath)\n  1087→\tif err != nil {\n  1088→\t\treturn\n  1089→\t}\n  1090→\tdefer f.Close()\n  1091→\n  1092→\tscanner := bufio.NewScanner(f)\n  1093→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large Claude JSON lines\n  1094→\tfor scanner.Scan() {\n  1095→\t\ttext := scanner.Text()\n  1096→\t\tline := parseFullLogLine(text)\n  1097→\t\tline = parseLLMLogLine(line)\n  1098→\t\tif line.Type == \"\" {\n  1099→\t\t\tcontinue // skip protocol-only llm lines"}]},"parent_tool_use_id":"toolu_01CDMiNsYDeokNGDGPoWKGXF","session_id":"c616a170-3350-4dc1-8578-799b5046f490","uuid":"3bc61ece-a278-4290-bc7d-afd4da5df93e"}
