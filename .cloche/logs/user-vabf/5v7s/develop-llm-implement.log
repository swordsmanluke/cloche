{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GHK4aLKk18bFFF5SRPUsbY","type":"tool_result","content":"#!/usr/bin/env bash\n# Returns ready tasks from bd as a JSON array.\n# Usage: ready-tasks.sh [max]\n#   max  — maximum number of IDs to return (default: all)\nset -euo pipefail\n\nmax=\"${1:-0}\"\n\nlimit_args=()\nif [ \"$max\" -gt 0 ] 2>/dev/null; then\n  limit_args=(--limit \"$max\")\nfi\n\njson=$(bd ready --json \"${limit_args[@]}\" 2>/dev/null) || json=\"[]\"\n\necho \"$json\"","is_error":false}]},"parent_tool_use_id":"toolu_01QpZbLUrcpuknqKax6X1B89","session_id":"2613b431-515d-48d3-bbf6-bbabff4e6c49","uuid":"e0e621c1-7bc8-4e56-aec4-821b26a2384c"}
