ing{\n   436→\t\t\tEnvVar: keyTok.Literal,\n   437→\t\t\tPath:   path,\n   438→\t\t})\n   439→\n   440→\t\tif p.current.Type == TokenComma {\n   441→\t\t\tp.advance()\n   442→\t\t}\n   443→\t}\n   444→\n   445→\tif _, err := p.expect(TokenRBracket); err != nil {\n   446→\t\treturn nil, err\n   447→\t}\n   448→\n   449→\treturn mappings, nil\n   450→}\n   451→\n   452→func (p *Parser) parseOutputPath() (domain.OutputPath, error) {\n   453→\tif p.current.Type != TokenIdent || p.current.Literal != \"output\" {\n   454→\t\treturn domain.OutputPath{}, fmt.Errorf(\"line %d col %d: expected \\\"output\\\", got %q\",\n   455→\t\t\tp.current.Line, p.current.Col, p.current.Literal)\n   456→\t}\n   457→\tp.advance() // consume \"output\"\n   458→\n   459→\tvar segments []domain.PathSegment\n   460→\tfor {\n   461→\t\tif p.current.Type == TokenDot {\n   462→\t\t\tp.advance() // consume \".\"\n   463→\t\t\tfieldTok, err := p.expect(TokenIdent)\n   464→\t\t\tif err != nil {\n   465→\t\t\t\treturn domain.OutputPath{}, fmt.Errorf(\"expected field name after '.': %w\", err)\n   466→\t\t\t}\n   467→\t\t\tsegments = append(segments, domain.PathSegment{Kind: domain.SegmentField, Field: fieldTok.Literal})\n   468→\t\t} else if p.current.Type == TokenLBracket {\n   469→\t\t\tp.advance() // consume \"[\"\n   470→\t\t\tidxTok, err := p.expect(TokenInt)\n   471→\t\t\tif err != nil {\n   472→\t\t\t\treturn domain.OutputPath{}, fmt.Errorf(\"expected integer index: %w\", err)\n   473→\t\t\t}\n   474→\t\t\tidx, _ := strconv.Atoi(idxTok.Literal)\n   475→\t\t\tif _, err := p.expect(TokenRBracket); err != nil {"}]},"parent_tool_use_id":"toolu_01QpZbLUrcpuknqKax6X1B89","session_id":"2613b431-515d-48d3-bbf6-bbabff4e6c49","uuid":"52835d46-4fac-4846-bbae-aa6485c1d511"}
