[2026-03-17T15:35:07Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013uePpu8TdnidnZysX9RTLe","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→)\n    11→\n    12→// ScriptGenerator creates new checker/linter scripts via LLM code generation.\n    13→type ScriptGenerator struct {\n    14→\tLLM LLMClient\n    15→}\n    16→\n    17→type scriptResponse struct {\n    18→\tPath    string `json:\"path\"`\n    19→\tContent string `json:\"content\"`\n    20→}\n    21→\n    22→// GeneratedScript holds the result of script generation.\n    23→type GeneratedScript struct {\n    24→\tPath    string\n    25→\tContent string\n    26→}\n    27→\n    28→// validateScriptPath checks that a script path is constrained to allowed directories.\n    29→func validateScriptPath(p string) error {\n    30→\tif strings.Contains(p, \"..\") {\n    31→\t\treturn fmt.Errorf(\"path must not contain '..'\")\n    32→\t}\n    33→\n    34→\tcleaned := filepath.Clean(p)\n    35→\tif strings.HasPrefix(cleaned, \"scripts/\") || strings.HasPrefix(cleaned, \".cloche/scripts/\") {\n    36→\t\treturn nil\n    37→\t}\n    38→\treturn fmt.Errorf(\"path must start with scripts/ or .cloche/scripts/\")\n    39→}\n    40→\n    41→// Generate creates a script file based on the lesson.\n    42→func (g *ScriptGenerator) Generate(ctx context.Context, projectDir string, lesson *Lesson) (*GeneratedScript, error) {\n    43→\tsystemPrompt := `You are a script generator for software validation workflows.\n    44→Given a description of what needs to be checked, generate a shell script that performs the check.\n    45→\n    46→Rules:\n    47→- The script should exit 0 on success, non-zero on failure\n    48→- Keep it simple and focused on one check\n    49→- Use standard tools available in a typical development container\n    50→- Include a shebang line (#!/bin/bash or #!/bin/sh)\n    51→\n    52→Respond with JSON: {\"path\": \"scripts/<name>.sh\", \"content\": \"<script content>\"}\n    53→Use \\n for newlines in the content field.\n    54→Do not include any other text.`\n    55→\n    56→\tuserPrompt := fmt.Sprintf(\"Check needed: %s\\nDetails: %s\", lesson.Insight, lesson.SuggestedAction)\n    57→\n    58→\tresponse, err := g.LLM.Complete(ctx, systemPrompt, userPrompt)\n    59→\tif err != nil {\n    60→\t\treturn nil, fmt.Errorf(\"script generator LLM call: %w\", err)\n    61→\t}\n    62→\n    63→\tvar resp scriptResponse\n    64→\tresponse = strings.TrimSpace(response)\n    65→\tif err := json.Unmarshal([]byte(response), &resp); err != nil {\n    66→\t\treturn nil, fmt.Errorf(\"parsing script generator response: %w\", err)\n    67→\t}\n    68→\n    69→\tif resp.Path == \"\" || resp.Content == \"\" {\n    70→\t\treturn nil, fmt.Errorf(\"script generator returned empty path or content\")\n    71→\t}\n    72→\n    73→\t// Validate path is within allowed directories\n    74→\tif err := validateScriptPath(resp.Path); err != nil {\n    75→\t\treturn nil, fmt.Errorf(\"invalid script path %q: %w\", resp.Path, err)\n    76→\t}\n    77→\n    78→\t// Validate content starts with a shebang line\n    79→\tif !strings.HasPrefix(resp.Content, \"#!\") {\n    80→\t\treturn nil, fmt.Errorf(\"script content must start with a shebang line (e.g. #!/bin/bash)\")\n    81→\t}\n    82→\n    83→\t// Resolve full path and verify it stays within projectDir\n    84→\tfullPath := filepath.Join(projectDir, resp.Path)\n    85→\tresolved, err := filepath.Abs(fullPath)\n    86→\tif err != nil {\n    87→\t\treturn nil, fmt.Errorf(\"resolving script path: %w\", err)\n    88→\t}\n    89→\tabsProject, err := filepath.Abs(projectDir)\n    90→\tif err != nil {\n    91→\t\treturn nil, fmt.Errorf(\"resolving project dir: %w\", err)\n    92→\t}\n    93→\tif !strings.HasPrefix(resolved, absProject+string(filepath.Separator)) {\n    94→\t\treturn nil, fmt.Errorf(\"script path %q resolves outside project directory\", resp.Path)\n    95→\t}\n    96→\n    97→\t// Check if script already exists — do not overwrite\n    98→\tif _, err := os.Stat(fullPath); err == nil {\n    99→\t\treturn nil, fmt.Errorf(\"script %q already exists; will not overwrite\", resp.Path)\n   100→\t}\n   101→\n   102→\t// Create parent directories\n   103→\tif err := os.MkdirAll(filepath.Dir(fullPath), 0755); err != nil {\n   104→\t\treturn nil, fmt.Errorf(\"creating script directory: %w\", err)\n   105→\t}\n   106→\n   107→\t// Write as non-executable; the workflow engine handles execution\n   108→\tif err := os.WriteFile(fullPath, []byte(resp.Content), 0644); err != nil {\n   109→\t\treturn nil, fmt.Errorf(\"writing script file: %w\", err)\n   110→\t}\n   111→\n   112→\treturn &GeneratedScript{Path: resp.Path, Content: resp.Content}, nil\n   113→}\n   114→"}]},"parent_tool_use_id":"toolu_01K3Pcjxnz2xdtCmn1qeg5u4","session_id":"a76bb48f-05af-4174-aa66-b2697e9be94c","uuid":"8c194379-1fc4-48b4-8b9b-3f538ce63783","timestamp":"2026-03-17T15:33:20.471Z"}
