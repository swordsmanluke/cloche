{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FnDLUPz8JvZYc73aCWgptQ","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import \"math/rand\"\n     4→\n     5→// Candidate represents a prompt variant in a GEPA population that can be\n     6→// selected for the next evolution cycle.\n     7→type Candidate struct {\n     8→\tID         string        `json:\"id\"`\n     9→\tPromptID   string        `json:\"prompt_id\"`\n    10→\tContent    string        `json:\"content\"`\n    11→\tGeneration int           `json:\"generation\"`\n    12→\tParentID   string        `json:\"parent_id,omitempty\"`\n    13→\tFitness    FitnessScores `json:\"fitness\"`\n    14→}\n    15→\n    16→// FitnessScores holds multi-objective fitness values for a candidate.\n    17→type FitnessScores struct {\n    18→\tScores  map[string]float64 `json:\"scores,omitempty\"` // objective name -> score\n    19→\tTotal   float64            `json:\"total\"`\n    20→\tCount   int                `json:\"count\"`\n    21→\tAverage float64            `json:\"average\"`\n    22→}\n    23→\n    24→// SelectCandidate picks a candidate for the next evolution cycle.\n    25→// Strategy: 70% chance to pick a random candidate from the Pareto front,\n    26→// 30% chance to pick a random non-front candidate (exploration).\n    27→// Returns nil if no candidates exist.\n    28→func SelectCandidate(candidates []Candidate, fitness map[string]FitnessScores, paretoFront []string) *Candidate {\n    29→\tif len(candidates) == 0 {\n    30→\t\treturn nil\n    31→\t}\n    32→\n    33→\t// Build sets for fast lookup.\n    34→\tfrontSet := make(map[string]bool, len(paretoFront))\n    35→\tfor _, id := range paretoFront {\n    36→\t\tfrontSet[id] = true\n    37→\t}\n    38→\n    39→\tvar front, nonFront []Candidate\n    40→\tfor _, c := range candidates {\n    41→\t\tif frontSet[c.ID] {\n    42→\t\t\tfront = append(front, c)\n    43→\t\t} else {\n    44→\t\t\tnonFront = append(nonFront, c)\n    45→\t\t}\n    46→\t}\n    47→\n    48→\t// If only one pool has candidates, pick from it.\n    49→\tif len(front) == 0 && len(nonFront) == 0 {\n    50→\t\treturn nil\n    51→\t}\n    52→\tif len(front) == 0 {\n    53→\t\tpicked := nonFront[rand.Intn(len(nonFront))]\n    54→\t\treturn &picked\n    55→\t}\n    56→\tif len(nonFront) == 0 {\n    57→\t\tpicked := front[rand.Intn(len(front))]\n    58→\t\treturn &picked\n    59→\t}\n    60→\n    61→\t// 70/30 split.\n    62→\tif rand.Float64() < 0.7 {\n    63→\t\tpicked := front[rand.Intn(len(front))]\n    64→\t\treturn &picked\n    65→\t}\n    66→\tpicked := nonFront[rand.Intn(len(nonFront))]\n    67→\treturn &picked\n    68→}\n    69→"}]},"parent_tool_use_id":"toolu_01K3Pcjxnz2xdtCmn1qeg5u4","session_id":"a76bb48f-05af-4174-aa66-b2697e9be94c","uuid":"47040ede-589f-41b2-80dd-081f85b449a1","timestamp":"2026-03-17T15:33:03.243Z"}
