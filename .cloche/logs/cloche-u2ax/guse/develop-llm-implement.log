{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YMFuSU5wsRfAK9Qdr78jmr","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"regexp\"\n     9→\t\"strings\"\n    10→)\n    11→\n    12→// Curator merges lessons into prompt files using ACE-style curation.\n    13→type Curator struct {\n    14→\tLLM   LLMClient\n    15→\tAudit *AuditLogger\n    16→}\n    17→\n    18→// lessonAlreadyPresent checks whether the lesson's key insight or action is\n    19→// already present in the current prompt text (case-insensitive substring match).\n    20→func lessonAlreadyPresent(currentPrompt string, lesson *Lesson) bool {\n    21→\tlower := strings.ToLower(currentPrompt)\n    22→\tif lesson.Insight != \"\" && strings.Contains(lower, strings.ToLower(lesson.Insight)) {\n    23→\t\treturn true\n    24→\t}\n    25→\tif lesson.SuggestedAction != \"\" && strings.Contains(lower, strings.ToLower(lesson.SuggestedAction)) {\n    26→\t\treturn true\n    27→\t}\n    28→\treturn false\n    29→}\n    30→\n    31→// ErrSanityCheckFailed indicates the curated content failed the prompt sanity check.\n    32→var ErrSanityCheckFailed = fmt.Errorf(\"curation output failed sanity check\")\n    33→\n    34→// Curate performs core curation logic: reads the current prompt, calls the LLM to\n    35→// merge the lesson, and returns the updated prompt content as a string. All corruption\n    36→// safeguards (conversational guard, code-fence stripping, sanity check) are applied.\n    37→// Returns (\"\", nil) when the lesson is already present and no update is needed.\n    38→// Returns (\"\", ErrSanityCheckFailed) when the curated output fails the sanity check.\n    39→func (c *Curator) Curate(ctx context.Context, projectDir string, lesson *Lesson) (string, error) {\n    40→\ttargetPath := filepath.Join(projectDir, lesson.Target)\n    41→\tcurrent, err := os.ReadFile(targetPath)\n    42→\tif err != nil {\n    43→\t\treturn \"\", fmt.Errorf(\"reading target prompt %s: %w\", lesson.Target, err)\n    44→\t}\n    45→\n    46→\t// Guard: skip if the lesson is already incorporated in the prompt\n    47→\tif lessonAlreadyPresent(string(current), lesson) {\n    48→\t\treturn \"\", nil\n    49→\t}\n    50→\n    51→\tsystemPrompt := `You are a prompt curator using ACE (Agentic Context Engineering) principles.\n    52→Your job is to merge a new lesson into an existing prompt document.\n    53→\n    54→Rules:\n    55→- Append the lesson as a structured bullet/rule in a \"## Learned Rules\" section\n    56→- If a \"## Learned Rules\" section already exists, add to it\n    57→- If the lesson refines or duplicates an existing rule, update in place rather than appending\n    58→- Preserve ALL existing content exactly as-is\n    59→- Keep rules concise and actionable\n    60→- Do not add commentary — return only the updated prompt content`\n    61→\n    62→\tuserPrompt := fmt.Sprintf(\"## Current Prompt Content\\n```\\n%s\\n```\\n\\n## Lesson to Merge\\nInsight: %s\\nSuggested Action: %s\",\n    63→\t\tstring(current), lesson.Insight, lesson.SuggestedAction)\n    64→\n    65→\traw, err := c.LLM.Complete(ctx, systemPrompt, userPrompt)\n    66→\tif err != nil {\n    67→\t\treturn \"\", fmt.Errorf(\"curator LLM call: %w\", err)\n    68→\t}\n    69→\n    70→\tupdated := stripCodeFences(raw)\n    71→\n    72→\t// Validate that the LLM output is actual prompt content, not meta-conversation\n    73→\tif isConversationalResponse(updated) {\n    74→\t\t// Fallback: append the lesson directly rather than trusting the LLM\n    75→\t\tupdated = appendLessonDirectly(string(current), lesson)\n    76→\t}\n    77→\n    78→\t// Sanity check the curated content\n    79→\tif !promptSanityCheck(updated) {\n    80→\t\treturn \"\", ErrSanityCheckFailed\n    81→\t}\n    82→\n    83→\treturn updated, nil\n    84→}\n    85→\n    86→// Apply curates a lesson into the target prompt file.\n    87→func (c *Curator) Apply(ctx context.Context, projectDir string, lesson *Lesson) (*Change, error) {\n    88→\tupdated, err := c.Curate(ctx, projectDir, lesson)\n    89→\tif err == ErrSanityCheckFailed {\n    90→\t\t// Snapshot before rollback reporting\n    91→\t\tvar snapName string\n    92→\t\tif c.Audit != nil {\n    93→\t\t\tsnapName, _ = c.Audit.Snapshot(lesson.Target)\n    94→\t\t}\n    95→\t\treturn &Change{\n    96→\t\t\tType:     \"prompt_update_rollback\",\n    97→\t\t\tFile:     lesson.Target,\n    98→\t\t\tReason:   fmt.Sprintf(\"curation rolled back: written content failed sanity check (lesson: %s)\", lesson.Insight),\n    99→\t\t\tSnapshot: snapName,\n   100→\t\t}, nil\n   101→\t}\n   102→\tif err != nil {\n   103→\t\treturn nil, err\n   104→\t}\n   105→\n   106→\t// Empty string with nil error means lesson already present\n   107→\tif updated == \"\" {\n   108→\t\treturn nil, nil\n   109→\t}\n   110→\n   111→\t// Snapshot before writing\n   112→\tvar snapName string\n   113→\tif c.Audit != nil {\n   114→\t\tsnapName, _ = c.Audit.Snapshot(lesson.Target)\n   115→\t}\n   116→\n   117→\ttargetPath := filepath.Join(projectDir, lesson.Target)\n   118→\tif err := os.WriteFile(targetPath, []byte(updated), 0644); err != nil {\n   119→\t\treturn nil, fmt.Errorf(\"writing updated prompt: %w\", err)\n   120→\t}\n   121→\n   122→\treturn &Change{\n   123→\t\tType:     \"prompt_update\",\n   124→\t\tFile:     lesson.Target,\n   125→\t\tReason:   lesson.Insight,\n   126→\t\tSnapshot: snapName,\n   127→\t}, nil\n   128→}\n   129→\n   130→// promptSanityCheck performs basic validation on prompt content to detect corruption.\n   131→// Returns true if the content looks like a valid prompt file.\n   132→func promptSanityCheck(content string) bool {\n   133→\ttrimmed := strings.TrimSpace(content)\n   134→\n   135→\t// Empty content is never valid\n   136→\tif trimmed == \"\" {\n   137→\t\treturn false\n   138→\t}\n   139→\n   140→\t// Must not start with conversational phrases\n   141→\tif isConversationalResponse(trimmed) {\n   142→\t\treturn false\n   143→\t}\n   144→\n   145→\t// Must either start with '#' (markdown heading) or contain at least\n   146→\t// one section header somewhere in the content\n   147→\thasHeading := strings.HasPrefix(trimmed, \"#\") || strings.Contains(trimmed, \"\\n#\")\n   148→\tif !hasHeading {\n   149→\t\treturn false\n   150→\t}\n   151→\n   152→\treturn true\n   153→}\n   154→\n   155→// conversationalMarkers are patterns that indicate the LLM returned\n   156→// meta-conversation text instead of prompt content.\n   157→var conversationalMarkers = regexp.MustCompile(\n   158→\t`(?i)^(I need |I can't |I cannot |Could you |Please grant |` +\n   159→\t\t`I don't have |I do not have |permission|write access|blocked by|` +\n   160→\t\t`Here is the updated|Here's the updated|I've updated|I have updated|` +\n   161→\t\t`Let me |I'll |I will )`)\n   162→\n   163→// isConversationalResponse checks whether the LLM output appears to be\n   164→// meta-conversation text rather than actual prompt content.\n   165→func isConversationalResponse(s string) bool {\n   166→\ttrimmed := strings.TrimSpace(s)\n   167→\tif trimmed == \"\" {\n   168→\t\treturn true\n   169→\t}\n   170→\t// Check the first non-empty line for conversational markers\n   171→\tfirstLine := trimmed\n   172→\tif idx := strings.Index(trimmed, \"\\n\"); idx != -1 {\n   173→\t\tfirstLine = trimmed[:idx]\n   174→\t}\n   175→\treturn conversationalMarkers.MatchString(strings.TrimSpace(firstLine))\n   176→}\n   177→\n   178→// appendLessonDirectly adds a lesson to the prompt content without LLM help,\n   179→// used as a fallback when the LLM returns conversational text.\n   180→func appendLessonDirectly(current string, lesson *Lesson) string {\n   181→\tcurrent = strings.TrimRight(current, \"\\n\")\n   182→\tif strings.Contains(current, \"## Learned Rules\") {\n   183→\t\treturn current + fmt.Sprintf(\"\\n- %s: %s\\n\", lesson.Insight, lesson.SuggestedAction)\n   184→\t}\n   185→\treturn current + fmt.Sprintf(\"\\n\\n## Learned Rules\\n\\n- %s: %s\\n\", lesson.Insight, lesson.SuggestedAction)\n   186→}\n   187→\n   188→// stripCodeFences removes markdown code fences from an LLM response,\n   189→// extracting just the content between them. If no fences are found,\n   190→// the input is returned unchanged (trimmed).\n   191→func stripCodeFences(s string) string {\n   192→\ts = strings.TrimSpace(s)\n   193→\n   194→\topenIdx := strings.Index(s, \"```\")\n   195→\tif openIdx == -1 {\n   196→\t\treturn s\n   197→\t}\n   198→\n   199→\t// Skip the opening fence line (may include language hint like ```markdown)\n   200→\tafterOpen := s[openIdx+3:]\n   201→\tnewlineIdx := strings.Index(afterOpen, \"\\n\")\n   202→\tif newlineIdx == -1 {\n   203→\t\treturn s\n   204→\t}\n   205→\tcontentStart := openIdx + 3 + newlineIdx + 1\n   206→\n   207→\t// Find the closing fence (last ``` in the string)\n   208→\tcloseIdx := strings.LastIndex(s, \"```\")\n   209→\tif closeIdx <= openIdx {\n   210→\t\treturn s\n   211→\t}\n   212→\n   213→\treturn s[contentStart:closeIdx]\n   214→}\n   215→"}]},"parent_tool_use_id":"toolu_01K3Pcjxnz2xdtCmn1qeg5u4","session_id":"a76bb48f-05af-4174-aa66-b2697e9be94c","uuid":"3a137c40-c780-4ade-b3a3-e4eef3d33cd9","timestamp":"2026-03-17T15:33:12.166Z"}
