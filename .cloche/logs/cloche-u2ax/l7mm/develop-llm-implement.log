{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WbvideAVgYvAreReaSmkon","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"regexp\"\n     9→\t\"strings\"\n    10→)\n    11→\n    12→// Curator merges lessons into prompt files using ACE-style curation.\n    13→type Curator struct {\n    14→\tLLM   LLMClient\n    15→\tAudit *AuditLogger\n    16→}\n    17→\n    18→// lessonAlreadyPresent checks whether the lesson's key insight or action is\n    19→// already present in the current prompt text (case-insensitive substring match).\n    20→func lessonAlreadyPresent(currentPrompt string, lesson *Lesson) bool {\n    21→\tlower := strings.ToLower(currentPrompt)\n    22→\tif lesson.Insight != \"\" && strings.Contains(lower, strings.ToLower(lesson.Insight)) {\n    23→\t\treturn true\n    24→\t}\n    25→\tif lesson.SuggestedAction != \"\" && strings.Contains(lower, strings.ToLower(lesson.SuggestedAction)) {\n    26→\t\treturn true\n    27→\t}\n    28→\treturn false\n    29→}\n    30→\n    31→// Apply curates a lesson into the target prompt file.\n    32→func (c *Curator) Apply(ctx context.Context, projectDir string, lesson *Lesson) (*Change, error) {\n    33→\ttargetPath := filepath.Join(projectDir, lesson.Target)\n    34→\tcurrent, err := os.ReadFile(targetPath)\n    35→\tif err != nil {\n    36→\t\treturn nil, fmt.Errorf(\"reading target prompt %s: %w\", lesson.Target, err)\n    37→\t}\n    38→\n    39→\t// Guard: skip if the lesson is already incorporated in the prompt\n    40→\tif lessonAlreadyPresent(string(current), lesson) {\n    41→\t\treturn nil, nil\n    42→\t}\n    43→\n    44→\tsystemPrompt := `You are a prompt curator using ACE (Agentic Context Engineering) principles.\n    45→Your job is to merge a new lesson into an existing prompt document.\n    46→\n    47→Rules:\n    48→- Append the lesson as a structured bullet/rule in a \"## Learned Rules\" section\n    49→- If a \"## Learned Rules\" section already exists, add to it\n    50→- If the lesson refines or duplicates an existing rule, update in place rather than appending\n    51→- Preserve ALL existing content exactly as-is\n    52→- Keep rules concise and actionable\n    53→- Do not add commentary — return only the updated prompt content`\n    54→\n    55→\tuserPrompt := fmt.Sprintf(\"## Current Prompt Content\\n```\\n%s\\n```\\n\\n## Lesson to Merge\\nInsight: %s\\nSuggested Action: %s\",\n    56→\t\tstring(current), lesson.Insight, lesson.SuggestedAction)\n    57→\n    58→\traw, err := c.LLM.Complete(ctx, systemPrompt, userPrompt)\n    59→\tif err != nil {\n    60→\t\treturn nil, fmt.Errorf(\"curator LLM call: %w\", err)\n    61→\t}\n    62→\n    63→\tupdated := stripCodeFences(raw)\n    64→\n    65→\t// Validate that the LLM output is actual prompt content, not meta-conversation\n    66→\tif isConversationalResponse(updated) {\n    67→\t\t// Fallback: append the lesson directly rather than trusting the LLM\n    68→\t\tupdated = appendLessonDirectly(string(current), lesson)\n    69→\t}\n    70→\n    71→\t// Snapshot before writing\n    72→\tvar snapName string\n    73→\tif c.Audit != nil {\n    74→\t\tsnapName, _ = c.Audit.Snapshot(lesson.Target)\n    75→\t}\n    76→\n    77→\tif err := os.WriteFile(targetPath, []byte(updated), 0644); err != nil {\n    78→\t\treturn nil, fmt.Errorf(\"writing updated prompt: %w\", err)\n    79→\t}\n    80→\n    81→\t// Post-write sanity check: re-read and validate the written content\n    82→\twritten, err := os.ReadFile(targetPath)\n    83→\tif err != nil {\n    84→\t\treturn nil, fmt.Errorf(\"re-reading written prompt: %w\", err)\n    85→\t}\n    86→\n    87→\tif !promptSanityCheck(string(written)) {\n    88→\t\t// Rollback: restore from snapshot\n    89→\t\tif c.Audit != nil && snapName != \"\" {\n    90→\t\t\tif restoreErr := c.Audit.Restore(lesson.Target, snapName); restoreErr != nil {\n    91→\t\t\t\treturn nil, fmt.Errorf(\"rollback failed after sanity check: %w\", restoreErr)\n    92→\t\t\t}\n    93→\t\t}\n    94→\t\treturn &Change{\n    95→\t\t\tType:     \"prompt_update_rollback\",\n    96→\t\t\tFile:     lesson.Target,\n    97→\t\t\tReason:   fmt.Sprintf(\"curation rolled back: written content failed sanity check (lesson: %s)\", lesson.Insight),\n    98→\t\t\tSnapshot: snapName,\n    99→\t\t}, nil\n   100→\t}\n   101→\n   102→\treturn &Change{\n   103→\t\tType:     \"prompt_update\",\n   104→\t\tFile:     lesson.Target,\n   105→\t\tReason:   lesson.Insight,\n   106→\t\tSnapshot: snapName,\n   107→\t}, nil\n   108→}\n   109→\n   110→// promptSanityCheck performs basic validation on prompt content to detect corruption.\n   111→// Returns true if the content looks like a valid prompt file.\n   112→func promptSanityCheck(content string) bool {\n   113→\ttrimmed := strings.TrimSpace(content)\n   114→\n   115→\t// Empty content is never valid\n   116→\tif trimmed == \"\" {\n   117→\t\treturn false\n   118→\t}\n   119→\n   120→\t// Must not start with conversational phrases\n   121→\tif isConversationalResponse(trimmed) {\n   122→\t\treturn false\n   123→\t}\n   124→\n   125→\t// Must either start with '#' (markdown heading) or contain at least\n   126→\t// one section header somewhere in the content\n   127→\thasHeading := strings.HasPrefix(trimmed, \"#\") || strings.Contains(trimmed, \"\\n#\")\n   128→\tif !hasHeading {\n   129→\t\treturn false\n   130→\t}\n   131→\n   132→\treturn true\n   133→}\n   134→\n   135→// conversationalMarkers are patterns that indicate the LLM returned\n   136→// meta-conversation text instead of prompt content.\n   137→var conversationalMarkers = regexp.MustCompile(\n   138→\t`(?i)^(I need |I can't |I cannot |Could you |Please grant |` +\n   139→\t\t`I don't have |I do not have |permission|write access|blocked by|` +\n   140→\t\t`Here is the updated|Here's the updated|I've updated|I have updated|` +\n   141→\t\t`Let me |I'll |I will )`)\n   142→\n   143→// isConversationalResponse checks whether the LLM output appears to be\n   144→// meta-conversation text rather than actual prompt content.\n   145→func isConversationalResponse(s string) bool {\n   146→\ttrimmed := strings.TrimSpace(s)\n   147→\tif trimmed == \"\" {\n   148→\t\treturn true\n   149→\t}\n   150→\t// Check the first non-empty line for conversational markers\n   151→\tfirstLine := trimmed\n   152→\tif idx := strings.Index(trimmed, \"\\n\"); idx != -1 {\n   153→\t\tfirstLine = trimmed[:idx]\n   154→\t}\n   155→\treturn conversationalMarkers.MatchString(strings.TrimSpace(firstLine))\n   156→}\n   157→\n   158→// appendLessonDirectly adds a lesson to the prompt content without LLM help,\n   159→// used as a fallback when the LLM returns conversational text.\n   160→func appendLessonDirectly(current string, lesson *Lesson) string {\n   161→\tcurrent = strings.TrimRight(current, \"\\n\")\n   162→\tif strings.Contains(current, \"## Learned Rules\") {\n   163→\t\treturn current + fmt.Sprintf(\"\\n- %s: %s\\n\", lesson.Insight, lesson.SuggestedAction)\n   164→\t}\n   165→\treturn current + fmt.Sprintf(\"\\n\\n## Learned Rules\\n\\n- %s: %s\\n\", lesson.Insight, lesson.SuggestedAction)\n   166→}\n   167→\n   168→// stripCodeFences removes markdown code fences from an LLM response,\n   169→// extracting just the content between them. If no fences are found,\n   170→// the input is returned unchanged (trimmed).\n   171→func stripCodeFences(s string) string {\n   172→\ts = strings.TrimSpace(s)\n   173→\n   174→\topenIdx := strings.Index(s, \"```\")\n   175→\tif openIdx == -1 {\n   176→\t\treturn s\n   177→\t}\n   178→\n   179→\t// Skip the opening fence line (may include language hint like ```markdown)\n   180→\tafterOpen := s[openIdx+3:]\n   181→\tnewlineIdx := strings.Index(afterOpen, \"\\n\")\n   182→\tif newlineIdx == -1 {\n   183→\t\treturn s\n   184→\t}\n   185→\tcontentStart := openIdx + 3 + newlineIdx + 1\n   186→\n   187→\t// Find the closing fence (last ``` in the string)\n   188→\tcloseIdx := strings.LastIndex(s, \"```\")\n   189→\tif closeIdx <= openIdx {\n   190→\t\treturn s\n   191→\t}\n   192→\n   193→\treturn s[contentStart:closeIdx]\n   194→}\n   195→"}]},"parent_tool_use_id":"toolu_01NmesgiHcE4G9dhVoyT8RMp","session_id":"f471cee6-1691-4c3d-afcc-78ec7889b431","uuid":"a5c2ed9a-978e-491d-83dd-11158b71c1f7","timestamp":"2026-03-17T14:07:44.915Z"}
