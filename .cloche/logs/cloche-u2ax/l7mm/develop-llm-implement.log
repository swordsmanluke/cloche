ct {\n    45→\tID             string\n    46→\tProjectDir     string\n    47→\tWorkflowName   string\n    48→\tTriggerRunID   string\n    49→\tCreatedAt      time.Time\n    50→\tClassification string\n    51→\tChangesJSON    string\n    52→\tKnowledgeDelta string\n    53→}\n    54→\n    55→type EvolutionStore interface {\n    56→\tSaveEvolution(ctx context.Context, entry *EvolutionEntry) error\n    57→\tGetLastEvolution(ctx context.Context, projectDir, workflowName string) (*EvolutionEntry, error)\n    58→\tListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error)\n    59→}\n    60→"}]},"parent_tool_use_id":"toolu_01NmesgiHcE4G9dhVoyT8RMp","session_id":"f471cee6-1691-4c3d-afcc-78ec7889b431","uuid":"a890d54e-7f56-41d8-a49b-b1234ccabeca","timestamp":"2026-03-17T14:07:55.130Z"}
