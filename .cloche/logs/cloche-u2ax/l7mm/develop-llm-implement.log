{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017MgstNKrsGWWhp9K2BENoy","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"sync\"\n     5→\t\"time\"\n     6→)\n     7→\n     8→// TriggerConfig configures the evolution trigger.\n     9→type TriggerConfig struct {\n    10→\tDebounceSeconds int\n    11→\tRunFunc         func(projectDir, workflowName, runID string)\n    12→}\n    13→\n    14→// Trigger debounces evolution pipeline runs per project+workflow key.\n    15→type Trigger struct {\n    16→\tcfg    TriggerConfig\n    17→\tmu     sync.Mutex\n    18→\ttimers map[string]*time.Timer\n    19→}\n    20→\n    21→// NewTrigger creates a new evolution trigger.\n    22→func NewTrigger(cfg TriggerConfig) *Trigger {\n    23→\tif cfg.DebounceSeconds <= 0 {\n    24→\t\tcfg.DebounceSeconds = 30\n    25→\t}\n    26→\treturn &Trigger{\n    27→\t\tcfg:    cfg,\n    28→\t\ttimers: make(map[string]*time.Timer),\n    29→\t}\n    30→}\n    31→\n    32→// Fire schedules an evolution run for the given project+workflow.\n    33→// If a run is already pending for this key, it resets the debounce timer\n    34→// and uses the latest runID.\n    35→func (t *Trigger) Fire(projectDir, workflowName, runID string) {\n    36→\tkey := projectDir + \":\" + workflowName\n    37→\n    38→\tt.mu.Lock()\n    39→\tdefer t.mu.Unlock()\n    40→\n    41→\tif timer, ok := t.timers[key]; ok {\n    42→\t\ttimer.Stop()\n    43→\t}\n    44→\n    45→\tt.timers[key] = time.AfterFunc(time.Duration(t.cfg.DebounceSeconds)*time.Second, func() {\n    46→\t\tt.mu.Lock()\n    47→\t\tdelete(t.timers, key)\n    48→\t\tt.mu.Unlock()\n    49→\n    50→\t\tt.cfg.RunFunc(projectDir, workflowName, runID)\n    51→\t})\n    52→}\n    53→\n    54→// Stop cancels all pending timers.\n    55→func (t *Trigger) Stop() {\n    56→\tt.mu.Lock()\n    57→\tdefer t.mu.Unlock()\n    58→\n    59→\tfor key, timer := range t.timers {\n    60→\t\ttimer.Stop()\n    61→\t\tdelete(t.timers, key)\n    62→\t}\n    63→}\n    64→"}]},"parent_tool_use_id":"toolu_01NmesgiHcE4G9dhVoyT8RMp","session_id":"f471cee6-1691-4c3d-afcc-78ec7889b431","uuid":"2a3ab63e-6c50-4459-bf42-f575d79977df","timestamp":"2026-03-17T14:07:56.906Z"}
