etail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t\t\"ParentRun\":      parentRun,\n\t\t\"ChildRuns\":      childRuns,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":502,"cache_read_input_tokens":61265,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":502},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"daab45ac-603f-4f11-b864-beeca03c969d","uuid":"20401b66-0114-4c85-88e1-eeae8c032475"}
