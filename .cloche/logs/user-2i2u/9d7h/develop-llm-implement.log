{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DyXTk5TtxwaDak7VGP56Cg","type":"tool_result","content":"     1→package sqlite\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"database/sql\"\n     6→\t\"fmt\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11→\t_ \"modernc.org/sqlite\"\n    12→)\n    13→\n    14→type Store struct {\n    15→\tdb *sql.DB\n    16→}\n    17→\n    18→func NewStore(dsn string) (*Store, error) {\n    19→\tdb, err := sql.Open(\"sqlite\", dsn)\n    20→\tif err != nil {\n    21→\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n    22→\t}\n    23→\n    24→\t// Enable WAL mode for concurrent read/write access\n    25→\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n    26→\n    27→\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n    28→\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n    29→\n    30→\t// Serialize all Go-side access through a single connection so SQLite\n    31→\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n    32→\tdb.SetMaxOpenConns(1)\n    33→\n    34→\tif err := migrate(db); err != nil {\n    35→\t\tdb.Close()\n    36→\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n    37→\t}\n    38→\n    39→\treturn &Store{db: db}, nil\n    40→}\n    41→\n    42→func (s *Store) Close() error {\n    43→\treturn s.db.Close()\n    44→}\n    45→\n    46→func migrate(db *sql.DB) error {\n    47→\t_, err := db.Exec(`\n    48→\t\tCREATE TABLE IF NOT EXISTS runs (\n    49→\t\t\tid TEXT PRIMARY KEY,\n    50→\t\t\tworkflow_name TEXT NOT NULL,\n    51→\t\t\tstate TEXT NOT NULL,\n    52→\t\t\tactive_steps TEXT,\n    53→\t\t\tstarted_at TEXT,\n    54→\t\t\tcompleted_at TEXT\n    55→\t\t);\n    56→\t\tCREATE TABLE IF NOT EXISTS step_executions (\n    57→\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    58→\t\t\trun_id TEXT NOT NULL,\n    59→\t\t\tstep_name TEXT NOT NULL,\n    60→\t\t\tresult TEXT,\n    61→\t\t\tstarted_at TEXT NOT NULL,\n    62→\t\t\tcompleted_at TEXT,\n    63→\t\t\tlogs TEXT,\n    64→\t\t\tgit_ref TEXT,\n    65→\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    66→\t\t);\n    67→\t`)\n    68→\tif err != nil {\n    69→\t\treturn err\n    70→\t}\n    71→\n    72→\t// Evolution schema additions (idempotent)\n    73→\talterStmts := []string{\n    74→\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n    75→\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n    76→\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n    77→\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n    78→\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n    79→\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n    80→\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n    81→\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n    82→\t\t`ALTER TABLE runs ADD COLUMN title TEXT NOT NULL DEFAULT ''`,\n    83→\t\t`ALTER TABLE runs ADD COLUMN is_host INTEGER NOT NULL DEFAULT 0`,\n    84→\t}\n    85→\tfor _, stmt := range alterStmts {\n    86→\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n    87→\t}\n    88→\n    89→\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n    90→\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    91→\t\trun_id TEXT NOT NULL,\n    92→\t\tstep_name TEXT,\n    93→\t\tfile_type TEXT NOT NULL,\n    94→\t\tfile_path TEXT NOT NULL,\n    95→\t\tfile_size INTEGER,\n    96→\t\tcreated_at TEXT NOT NULL,\n    97→\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    98→\t)`)\n    99→\tif errLog != nil {\n   100→\t\treturn errLog\n   101→\t}\n   102→\n   103→\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n   104→\t\trun_id TEXT PRIMARY KEY,\n   105→\t\tbranch TEXT NOT NULL,\n   106→\t\tproject TEXT NOT NULL,\n   107→\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n   108→\t\tenqueued_at TEXT NOT NULL,\n   109→\t\tcompleted_at TEXT\n   110→\t)`)\n   111→\tif errMQ != nil {\n   112→\t\treturn errMQ\n   113→\t}\n   114→\n   115→\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n   116→\t\tid TEXT PRIMARY KEY,\n   117→\t\tproject_dir TEXT NOT NULL,\n   118→\t\tworkflow_name TEXT NOT NULL,\n   119→\t\ttrigger_run_id TEXT NOT NULL,\n   120→\t\tcreated_at TEXT NOT NULL,\n   121→\t\tclassification TEXT,\n   122→\t\tchanges_json TEXT NOT NULL,\n   123→\t\tknowledge_delta TEXT\n   124→\t)`)\n   125→\tif err2 != nil {\n   126→\t\treturn err2\n   127→\t}\n   128→\n   129→\treturn nil\n   130→}\n   131→\n   132→func (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n   133→\t_, err := s.db.ExecContext(ctx,\n   134→\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept, title, is_host)\n   135→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   136→\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n   137→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, run.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost),\n   138→\t)\n   139→\treturn err\n   140→}\n   141→\n   142→// runSelectCols is the standard column list for scanning a Run row.\n   143→const runSelectCols = `id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,''), COALESCE(is_host,0)`\n   144→\n   145→// scanRun scans a single row into a *domain.Run.\n   146→func scanRun(scanner interface{ Scan(...any) error }) (*domain.Run, error) {\n   147→\trun := &domain.Run{}\n   148→\tvar activeSteps, startedAt, completedAt string\n   149→\tvar containerKept, isHost int\n   150→\terr := scanner.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title, &isHost)\n   151→\tif err != nil {\n   152→\t\treturn nil, err\n   153→\t}\n   154→\trun.SetActiveStepsFromString(activeSteps)\n   155→\trun.StartedAt = parseTime(startedAt)\n   156→\trun.CompletedAt = parseTime(completedAt)\n   157→\trun.ContainerKept = containerKept != 0\n   158→\trun.IsHost = isHost != 0\n   159→\treturn run, nil\n   160→}\n   161→\n   162→func (s *Store) GetRun(ctx context.Context, id string) (*domain.Run, error) {\n   163→\trow := s.db.QueryRowContext(ctx,\n   164→\t\t`SELECT `+runSelectCols+` FROM runs WHERE id = ?`, id)\n   165→\n   166→\trun, err := scanRun(row)\n   167→\tif err == sql.ErrNoRows {\n   168→\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n   169→\t}\n   170→\treturn run, err\n   171→}\n   172→\n   173→func (s *Store) UpdateRun(ctx context.Context, run *domain.Run) error {\n   174→\t_, err := s.db.ExecContext(ctx,\n   175→\t\t`UPDATE runs SET state = ?, active_steps = ?, started_at = ?, completed_at = ?, error_message = ?, container_id = ?, base_sha = ?, container_kept = ?, title = ?, is_host = ? WHERE id = ?`,\n   176→\t\tstring(run.State), run.ActiveStepsString(),\n   177→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt),\n   178→\t\trun.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ID,\n   179→\t)\n   180→\treturn err\n   181→}\n   182→\n   183→func (s *Store) DeleteRun(ctx context.Context, id string) error {\n   184→\t_, err := s.db.ExecContext(ctx, `DELETE FROM step_executions WHERE run_id = ?`, id)\n   185→\tif err != nil {\n   186→\t\treturn err\n   187→\t}\n   188→\t_, err = s.db.ExecContext(ctx, `DELETE FROM runs WHERE id = ?`, id)\n   189→\treturn err\n   190→}\n   191→\n   192→func (s *Store) ListRuns(ctx context.Context, since time.Time) ([]*domain.Run, error) {\n   193→\tvar rows *sql.Rows\n   194→\tvar err error\n   195→\tif since.IsZero() {\n   196→\t\trows, err = s.db.QueryContext(ctx,\n   197→\t\t\t`SELECT `+runSelectCols+` FROM runs ORDER BY started_at DESC`)\n   198→\t} else {\n   199→\t\trows, err = s.db.QueryContext(ctx,\n   200→\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE started_at >= ? ORDER BY started_at DESC`,\n   201→\t\t\tformatTime(since))\n   202→\t}\n   203→\tif err != nil {\n   204→\t\treturn nil, err\n   205→\t}\n   206→\tdefer rows.Close()\n   207→\treturn scanRuns(rows)\n   208→}\n   209→\n   210→// scanRuns scans all rows into a []*domain.Run slice.\n   211→func scanRuns(rows *sql.Rows) ([]*domain.Run, error) {\n   212→\tvar runs []*domain.Run\n   213→\tfor rows.Next() {\n   214→\t\trun, err := scanRun(rows)\n   215→\t\tif err != nil {\n   216→\t\t\treturn nil, err\n   217→\t\t}\n   218→\t\truns = append(runs, run)\n   219→\t}\n   220→\treturn runs, rows.Err()\n   221→}\n   222→\n   223→func (s *Store) ListRunsByProject(ctx context.Context, projectDir string, since time.Time) ([]*domain.Run, error) {\n   224→\tvar rows *sql.Rows\n   225→\tvar err error\n   226→\tif since.IsZero() {\n   227→\t\trows, err = s.db.QueryContext(ctx,\n   228→\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? ORDER BY started_at DESC`,\n   229→\t\t\tprojectDir)\n   230→\t} else {\n   231→\t\trows, err = s.db.QueryContext(ctx,\n   232→\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? AND started_at >= ? ORDER BY started_at DESC`,\n   233→\t\t\tprojectDir, formatTime(since))\n   234→\t}\n   235→\tif err != nil {\n   236→\t\treturn nil, err\n   237→\t}\n   238→\tdefer rows.Close()\n   239→\treturn scanRuns(rows)\n   240→}\n   241→\n   242→func (s *Store) ListProjects(ctx context.Context) ([]string, error) {\n   243→\trows, err := s.db.QueryContext(ctx,\n   244→\t\t`SELECT DISTINCT project_dir FROM runs WHERE project_dir != '' ORDER BY project_dir`)\n   245→\tif err != nil {\n   246→\t\treturn nil, err\n   247→\t}\n   248→\tdefer rows.Close()\n   249→\n   250→\tvar projects []string\n   251→\tfor rows.Next() {\n   252→\t\tvar dir string\n   253→\t\tif err := rows.Scan(&dir); err != nil {\n   254→\t\t\treturn nil, err\n   255→\t\t}\n   256→\t\tprojects = append(projects, dir)\n   257→\t}\n   258→\treturn projects, rows.Err()\n   259→}\n   260→\n   261→func (s *Store) SaveCapture(ctx context.Context, runID string, exec *domain.StepExecution) error {\n   262→\t_, err := s.db.ExecContext(ctx,\n   263→\t\t`INSERT INTO step_executions (run_id, step_name, result, started_at, completed_at, logs, git_ref)\n   264→\t\t VALUES (?, ?, ?, ?, ?, ?, ?)`,\n   265→\t\trunID, exec.StepName, exec.Result,\n   266→\t\tformatTime(exec.StartedAt), formatTime(exec.CompletedAt),\n   267→\t\texec.Logs, exec.GitRef,\n   268→\t)\n   269→\treturn err\n   270→}\n   271→\n   272→func (s *Store) GetCaptures(ctx context.Context, runID string) ([]*domain.StepExecution, error) {\n   273→\trows, err := s.db.QueryContext(ctx,\n   274→\t\t`SELECT step_name, result, started_at, completed_at, COALESCE(logs,''), COALESCE(git_ref,'')\n   275→\t\t FROM step_executions WHERE run_id = ? ORDER BY id`, runID)\n   276→\tif err != nil {\n   277→\t\treturn nil, err\n   278→\t}\n   279→\tdefer rows.Close()\n   280→\n   281→\tvar execs []*domain.StepExecution\n   282→\tfor rows.Next() {\n   283→\t\te := &domain.StepExecution{}\n   284→\t\tvar startedAt, completedAt string\n   285→\t\tif err := rows.Scan(&e.StepName, &e.Result, &startedAt, &completedAt, &e.Logs, &e.GitRef); err != nil {\n   286→\t\t\treturn nil, err\n   287→\t\t}\n   288→\t\te.StartedAt = parseTime(startedAt)\n   289→\t\te.CompletedAt = parseTime(completedAt)\n   290→\t\texecs = append(execs, e)\n   291→\t}\n   292→\treturn execs, rows.Err()\n   293→}\n   294→\n   295→func (s *Store) SaveLogFile(ctx context.Context, entry *ports.LogFileEntry) error {\n   296→\t_, err := s.db.ExecContext(ctx,\n   297→\t\t`INSERT INTO log_files (run_id, step_name, file_type, file_path, file_size, created_at)\n   298→\t\t VALUES (?, ?, ?, ?, ?, ?)`,\n   299→\t\tentry.RunID, entry.StepName, entry.FileType, entry.FilePath, entry.FileSize,\n   300→\t\tformatTime(entry.CreatedAt),\n   301→\t)\n   302→\treturn err\n   303→}\n   304→\n   305→func (s *Store) GetLogFiles(ctx context.Context, runID string) ([]*ports.LogFileEntry, error) {\n   306→\trows, err := s.db.QueryContext(ctx,\n   307→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   308→\t\t FROM log_files WHERE run_id = ? ORDER BY id`, runID)\n   309→\tif err != nil {\n   310→\t\treturn nil, err\n   311→\t}\n   312→\tdefer rows.Close()\n   313→\treturn scanLogFiles(rows)\n   314→}\n   315→\n   316→func (s *Store) GetLogFilesByStep(ctx context.Context, runID, stepName string) ([]*ports.LogFileEntry, error) {\n   317→\trows, err := s.db.QueryContext(ctx,\n   318→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   319→\t\t FROM log_files WHERE run_id = ? AND step_name = ? ORDER BY id`, runID, stepName)\n   320→\tif err != nil {\n   321→\t\treturn nil, err\n   322→\t}\n   323→\tdefer rows.Close()\n   324→\treturn scanLogFiles(rows)\n   325→}\n   326→\n   327→func (s *Store) GetLogFileByType(ctx context.Context, runID, fileType string) ([]*ports.LogFileEntry, error) {\n   328→\trows, err := s.db.QueryContext(ctx,\n   329→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   330→\t\t FROM log_files WHERE run_id = ? AND file_type = ? ORDER BY id`, runID, fileType)\n   331→\tif err != nil {\n   332→\t\treturn nil, err\n   333→\t}\n   334→\tdefer rows.Close()\n   335→\treturn scanLogFiles(rows)\n   336→}\n   337→\n   338→func scanLogFiles(rows *sql.Rows) ([]*ports.LogFileEntry, error) {\n   339→\tvar entries []*ports.LogFileEntry\n   340→\tfor rows.Next() {\n   341→\t\te := &ports.LogFileEntry{}\n   342→\t\tvar createdAt string\n   343→\t\tif err := rows.Scan(&e.ID, &e.RunID, &e.StepName, &e.FileType, &e.FilePath, &e.FileSize, &createdAt); err != nil {\n   344→\t\t\treturn nil, err\n   345→\t\t}\n   346→\t\te.CreatedAt = parseTime(createdAt)\n   347→\t\tentries = append(entries, e)\n   348→\t}\n   349→\treturn entries, rows.Err()\n   350→}\n   351→\n   352→func (s *Store) SaveEvolution(ctx context.Context, entry *ports.EvolutionEntry) error {\n   353→\t_, err := s.db.ExecContext(ctx,\n   354→\t\t`INSERT INTO evolution_log (id, project_dir, workflow_name, trigger_run_id, created_at, classification, changes_json, knowledge_delta)\n   355→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,\n   356→\t\tentry.ID, entry.ProjectDir, entry.WorkflowName, entry.TriggerRunID,\n   357→\t\tformatTime(entry.CreatedAt), entry.Classification, entry.ChangesJSON, entry.KnowledgeDelta,\n   358→\t)\n   359→\treturn err\n   360→}\n   361→\n   362→func (s *Store) GetLastEvolution(ctx context.Context, projectDir, workflowName string) (*ports.EvolutionEntry, error) {\n   363→\trow := s.db.QueryRowContext(ctx,\n   364→\t\t`SELECT id, project_dir, workflow_name, trigger_run_id, created_at, COALESCE(classification,''), changes_json, COALESCE(knowledge_delta,'')\n   365→\t\t FROM evolution_log WHERE project_dir = ? AND workflow_name = ? ORDER BY created_at DESC LIMIT 1`,\n   366→\t\tprojectDir, workflowName)\n   367→\n   368→\tentry := &ports.EvolutionEntry{}\n   369→\tvar createdAt string\n   370→\terr := row.Scan(&entry.ID, &entry.ProjectDir, &entry.WorkflowName, &entry.TriggerRunID,\n   371→\t\t&createdAt, &entry.Classification, &entry.ChangesJSON, &entry.KnowledgeDelta)\n   372→\tif err == sql.ErrNoRows {\n   373→\t\treturn nil, nil\n   374→\t}\n   375→\tif err != nil {\n   376→\t\treturn nil, err\n   377→\t}\n   378→\tentry.CreatedAt = parseTime(createdAt)\n   379→\treturn entry, nil\n   380→}\n   381→\n   382→func (s *Store) ListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error) {\n   383→\tvar row