{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RWxSUqZAWtGBqAG5N64cLu","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1>Runs</h1>\n     3→{{if .Projects}}\n     4→<div class=\"project-filter\">\n     5→    <label for=\"project-select\">Project:</label>\n     6→    <select id=\"project-select\" onchange=\"filterByProject(this.value)\">\n     7→        <option value=\"\">All projects</option>\n     8→        {{range .Projects}}\n     9→        <option value=\"{{.Dir}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>\n    10→        {{end}}\n    11→    </select>\n    12→</div>\n    13→{{end}}\n    14→<table class=\"runs-table\">\n    15→    <thead>\n    16→        <tr>\n    17→            <th>Run ID</th>\n    18→            <th>Title</th>\n    19→            <th>Project</th>\n    20→            <th>Workflow</th>\n    21→            <th>Type</th>\n    22→            <th>State</th>\n    23→            <th>Started</th>\n    24→            <th>Completed</th>\n    25→            <th>Container</th>\n    26→            <th>Error</th>\n    27→        </tr>\n    28→    </thead>\n    29→    <tbody id=\"runs-body\">\n    30→    {{if .Runs}}\n    31→        {{range .Runs}}\n    32→        <tr>\n    33→            <td><a href=\"/runs/{{.ID}}\">{{.ID}}</a></td>\n    34→            <td>{{truncate .Title 50}}</td>\n    35→            <td>{{index $.ProjectLabels .ProjectDir}}</td>\n    36→            <td>{{.WorkflowName}}</td>\n    37→            <td>{{if .IsHost}}host{{else}}container{{end}}</td>\n    38→            <td><span class=\"badge badge-{{stateColor .State}}\">{{.State}}</span></td>\n    39→            <td>{{formatTime .StartedAt}}</td>\n    40→            <td>{{formatTime .CompletedAt}}</td>\n    41→            <td class=\"mono\">{{shortContainerID .ContainerID}}</td>\n    42→            <td class=\"error-cell\">{{truncate .ErrorMessage 80}}</td>\n    43→        </tr>\n    44→        {{end}}\n    45→    {{else}}\n    46→        <tr><td colspan=\"10\" class=\"empty\">No runs yet.</td></tr>\n    47→    {{end}}\n    48→    </tbody>\n    49→</table>\n    50→{{end}}\n    51→\n    52→{{define \"scripts\"}}\n    53→<script>\n    54→(function() {\n    55→    var currentProject = '{{.ProjectFilter}}';\n    56→\n    57→    function filterByProject(dir) {\n    58→        if (dir) {\n    59→            window.location.href = '/runs?project=' + encodeURIComponent(dir);\n    60→        } else {\n    61→            window.location.href = '/runs';\n    62→        }\n    63→    }\n    64→    window.filterByProject = filterByProject;\n    65→\n    66→    function poll() {\n    67→        var url = '/api/runs';\n    68→        if (currentProject) {\n    69→            url += '?project=' + encodeURIComponent(currentProject);\n    70→        }\n    71→        fetch(url)\n    72→            .then(function(r) { return r.json(); })\n    73→            .then(function(runs) {\n    74→                var tbody = document.getElementById('runs-body');\n    75→                if (!runs || runs.length === 0) {\n    76→                    tbody.innerHTML = '<tr><td colspan=\"10\" class=\"empty\">No runs yet.</td></tr>';\n    77→                    return;\n    78→                }\n    79→                var html = '';\n    80→                for (var i = 0; i < runs.length; i++) {\n    81→                    var r = runs[i];\n    82→                    var cid = r.container_id || '';\n    83→                    if (cid.length > 12) cid = cid.substring(0, 12);\n    84→                    var err = r.error_message || '';\n    85→                    if (err.length > 80) err = err.substring(0, 80) + '...';\n    86→                    var proj = r.project_label || '';\n    87→                    var title = r.title || '';\n    88→                    if (title.length > 50) title = title.substring(0, 47) + '...';\n    89→                    var runType = r.is_host ? 'host' : 'container';\n    90→                    html += '<tr>' +\n    91→                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n    92→                        '<td>' + escapeHtml(title) + '</td>' +\n    93→                        '<td>' + escapeHtml(proj) + '</td>' +\n    94→                        '<td>' + r.workflow_name + '</td>' +\n    95→                        '<td>' + runType + '</td>' +\n    96→                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n    97→                        '<td>' + r.started_at + '</td>' +\n    98→                        '<td>' + r.completed_at + '</td>' +\n    99→                        '<td class=\"mono\">' + cid + '</td>' +\n   100→                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n   101→                        '</tr>';\n   102→                }\n   103→                tbody.innerHTML = html;\n   104→            })\n   105→            .catch(function() {});\n   106→    }\n   107→    function escapeHtml(s) {\n   108→        var d = document.createElement('div');\n   109→        d.appendChild(document.createTextNode(s));\n   110→        return d.innerHTML;\n   111→    }\n   112→    setInterval(poll, 3000);\n   113→})();\n   114→</script>\n   115→{{end}}\n   116→"}]},"parent_tool_use_id":"toolu_019yUUVWxJFvKXV8mmuHGDBA","session_id":"daab45ac-603f-4f11-b864-beeca03c969d","uuid":"b5918501-5471-43db-a5ef-c78dedccc45a"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AXzSRYNt6koaGg5j8KGN7M","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"net/url\"\n    13→\t\"os\"\n    14→\t\"os/exec\"\n    15→\t\"path/filepath\"\n    16→\t\"regexp\"\n    17→\t\"sort\"\n    18→\t\"strconv\"\n    19→\t\"strings\"\n    20→\t\"time\"\n    21→\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    24→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    25→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    26→)\n    27→\n    28→// HandlerOption configures optional Handler dependencies.\n    29→type HandlerOption func(*Handler)\n    30→\n    31→// WithContainerLogger sets the container runtime for fetching live logs.\n    32→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    33→\treturn func(h *Handler) { h.container = c }\n    34→}\n    35→\n    36→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    37→func WithContainerManager(c ContainerManager) HandlerOption {\n    38→\treturn func(h *Handler) { h.container = c }\n    39→}\n    40→\n    41→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    42→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    43→\treturn func(h *Handler) { h.logBroadcast = b }\n    44→}\n    45→\n    46→// WithLogStore sets the log store for indexed log file lookups.\n    47→func WithLogStore(ls ports.LogStore) HandlerOption {\n    48→\treturn func(h *Handler) { h.logStore = ls }\n    49→}\n    50→\n    51→//go:embed templates/*.html static/*\n    52→var content embed.FS\n    53→\n    54→// Handler serves the web dashboard.\n    55→// ContainerLogger can retrieve logs from a container by ID.\n    56→type ContainerLogger interface {\n    57→\tLogs(ctx context.Context, containerID string) (string, error)\n    58→}\n    59→\n    60→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    61→type ContainerManager interface {\n    62→\tContainerLogger\n    63→\tStop(ctx context.Context, containerID string) error\n    64→\tRemove(ctx context.Context, containerID string) error\n    65→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    66→}\n    67→\n    68→type Handler struct {\n    69→\tstore        ports.RunStore\n    70→\tcaptures     ports.CaptureStore\n    71→\tlogStore     ports.LogStore\n    72→\tcontainer    ContainerLogger\n    73→\tlogBroadcast *logstream.Broadcaster\n    74→\tpages        map[string]*template.Template\n    75→\tmux          *http.ServeMux\n    76→}\n    77→\n    78→// NewHandler creates a web dashboard handler.\n    79→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    80→\tfuncMap := template.FuncMap{\n    81→\t\t\"stateColor\":       stateColor,\n    82→\t\t\"healthColor\":      healthColor,\n    83→\t\t\"formatTime\":       formatTime,\n    84→\t\t\"formatDuration\":   formatDuration,\n    85→\t\t\"truncate\":         truncate,\n    86→\t\t\"shortContainerID\": shortContainerID,\n    87→\t}\n    88→\n    89→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n    90→\tif err != nil {\n    91→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n    92→\t}\n    93→\n    94→\tpages := map[string]*template.Template{}\n    95→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n    96→\t\tclone, err := base.Clone()\n    97→\t\tif err != nil {\n    98→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n    99→\t\t}\n   100→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   101→\t\tif err != nil {\n   102→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   103→\t\t}\n   104→\t\tpages[page] = clone\n   105→\t}\n   106→\n   107→\th := &Handler{\n   108→\t\tstore:    store,\n   109→\t\tcaptures: captures,\n   110→\t\tpages:    pages,\n   111→\t\tmux:      http.NewServeMux(),\n   112→\t}\n   113→\tfor _, opt := range opts {\n   114→\t\topt(h)\n   115→\t}\n   116→\n   117→\tstaticFS, err := fs.Sub(content, \"static\")\n   118→\tif err != nil {\n   119→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   120→\t}\n   121→\n   122→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   123→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   124→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   125→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   126→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   127→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   128→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   129→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   130→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   131→\th.mux.HandleFunc(\"POST /api/runs/{id}/stop\", h.handleAPIStopRun)\n   132→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   133→\th.mux.HandleFunc(\"DELETE /api/projects/{name}/containers\", h.handleAPIDeleteProjectContainers)\n   134→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   135→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   136→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   137→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   138→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   139→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   140→\n   141→\treturn h, nil\n   142→}\n   143→\n   144→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   145→\th.mux.ServeHTTP(w, r)\n   146→}\n   147→\n   148→// --- HTML handlers ---\n   149→\n   150→// projectOverviewEntry holds data for a single project card on the landing page.\n   151→type projectOverviewEntry struct {\n   152→\tDir         string\n   153→\tLabel       string\n   154→\tHealth      domain.HealthResult\n   155→\tRecentRuns  []recentRunDot\n   156→\tActiveCount int\n   157→}\n   158→\n   159→// recentRunDot is a minimal representation of a run for the mini history display.\n   160→type recentRunDot struct {\n   161→\tID    string\n   162→\tState string\n   163→}\n   164→\n   165→const healthWindowSize = 10\n   166→\n   167→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   168→\tprojects, _ := h.store.ListProjects(r.Context())\n   169→\tlabels := projectLabels(projects)\n   170→\n   171→\tvar entries []projectOverviewEntry\n   172→\tfor _, dir := range projects {\n   173→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   174→\t\tif err != nil {\n   175→\t\t\tcontinue\n   176→\t\t}\n   177→\n   178→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   179→\t\trunValues := make([]domain.Run, len(runs))\n   180→\t\tfor i, rr := range runs {\n   181→\t\t\trunValues[i] = *rr\n   182→\t\t}\n   183→\n   184→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   185→\n   186→\t\t// Take the last N runs for the mini history (most recent first).\n   187→\t\tn := healthWindowSize\n   188→\t\tif n > len(runs) {\n   189→\t\t\tn = len(runs)\n   190→\t\t}\n   191→\t\tdots := make([]recentRunDot, n)\n   192→\t\tfor i := 0; i < n; i++ {\n   193→\t\t\tdots[i] = recentRunDot{\n   194→\t\t\t\tID:    runs[i].ID,\n   195→\t\t\t\tState: string(runs[i].State),\n   196→\t\t\t}\n   197→\t\t}\n   198→\n   199→\t\tvar activeCount int\n   200→\t\tfor _, rr := range runs {\n   201→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   202→\t\t\t\tactiveCount++\n   203→\t\t\t}\n   204→\t\t}\n   205→\n   206→\t\tentries = append(entries, projectOverviewEntry{\n   207→\t\t\tDir:         dir,\n   208→\t\t\tLabel:       labels[dir],\n   209→\t\t\tHealth:      health,\n   210→\t\t\tRecentRuns:  dots,\n   211→\t\t\tActiveCount: activeCount,\n   212→\t\t})\n   213→\t}\n   214→\n   215→\tsort.Slice(entries, func(i, j int) bool {\n   216→\t\treturn entries[i].Label < entries[j].Label\n   217→\t})\n   218→\n   219→\tdata := map[string]any{\n   220→\t\t\"Title\":    \"Projects\",\n   221→\t\t\"Projects\": entries,\n   222→\t}\n   223→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   224→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   225→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   226→\t}\n   227→}\n   228→\n   229→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   230→\tprojectFilter := r.URL.Query().Get(\"project\")\n   231→\n   232→\tvar runs []*domain.Run\n   233→\tvar err error\n   234→\tif projectFilter != \"\" {\n   235→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   236→\t} else {\n   237→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   238→\t}\n   239→\tif err != nil {\n   240→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   241→\t\treturn\n   242→\t}\n   243→\n   244→\tprojects, _ := h.store.ListProjects(r.Context())\n   245→\tlabels := projectLabels(projects)\n   246→\n   247→\t// Count retained containers per project\n   248→\tcontainerCounts := map[string]int{}\n   249→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   250→\tfor _, run := range allRuns {\n   251→\t\tif run.ContainerKept {\n   252→\t\t\tcontainerCounts[run.ProjectDir]++\n   253→\t\t}\n   254→\t}\n   255→\n   256→\tvar projectList []projectEntry\n   257→\tfor _, dir := range projects {\n   258→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   259→\t}\n   260→\tsort.Slice(projectList, func(i, j int) bool {\n   261→\t\treturn projectList[i].Label < projectList[j].Label\n   262→\t})\n   263→\n   264→\tdata := map[string]any{\n   265→\t\t\"Title\":         \"Runs\",\n   266→\t\t\"Runs\":          runs,\n   267→\t\t\"Projects\":      projectList,\n   268→\t\t\"ProjectFilter\": projectFilter,\n   269→\t\t\"ProjectLabels\": labels,\n   270→\t}\n   271→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   272→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   273→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   274→\t}\n   275→}\n   276→\n   277→// handleProjectRuns redirects /projects/{name}/runs to /runs?project=<dir>.\n   278→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   279→\tdir, _, ok := h.resolveProjectDir(w, r)\n   280→\tif !ok {\n   281→\t\treturn\n   282→\t}\n   283→\thttp.Redirect(w, r, \"/runs?project=\"+url.QueryEscape(dir), http.StatusFound)\n   284→}\n   285→\n   286→// stepEntry is a merged view of a step execution for the template.\n   287→type stepEntry struct {\n   288→\tIndex     int\n   289→\tStepName  string\n   290→\tResult    string\n   291→\tStartedAt time.Time\n   292→\tDuration  string\n   293→}\n   294→\n   295→// mergeCaptures collapses started/completed capture pairs into single entries.\n   296→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   297→\tvar entries []stepEntry\n   298→\t// Track pending started rows by step name (LIFO for retries)\n   299→\tpending := map[string]*domain.StepExecution{}\n   300→\n   301→\tfor _, c := range caps {\n   302→\t\tif c.Result == \"\" {\n   303→\t\t\t// step_started row\n   304→\t\t\tpending[c.StepName] = c\n   305→\t\t\tcontinue\n   306→\t\t}\n   307→\t\t// step_completed row — merge with pending started if available\n   308→\t\tstartedAt := c.StartedAt\n   309→\t\tif started := pending[c.StepName]; started != nil {\n   310→\t\t\tstartedAt = started.StartedAt\n   311→\t\t\tdelete(pending, c.StepName)\n   312→\t\t}\n   313→\t\tentries = append(entries, stepEntry{\n   314→\t\t\tIndex:     len(entries),\n   315→\t\t\tStepName:  c.StepName,\n   316→\t\t\tResult:    c.Result,\n   317→\t\t\tStartedAt: startedAt,\n   318→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   319→\t\t})\n   320→\t}\n   321→\n   322→\t// Append any started-but-not-completed steps (still running)\n   323→\tfor _, c := range caps {\n   324→\t\tif c.Result == \"\" {\n   325→\t\t\tif _, used := pending[c.StepName]; !used {\n   326→\t\t\t\tcontinue\n   327→\t\t\t}\n   328→\t\t\tentries = append(entries, stepEntry{\n   329→\t\t\t\tIndex:     len(entries),\n   330→\t\t\t\tStepName:  c.StepName,\n   331→\t\t\t\tStartedAt: c.StartedAt,\n   332→\t\t\t})\n   333→\t\t\tdelete(pending, c.StepName)\n   334→\t\t}\n   335→\t}\n   336→\n   337→\treturn entries\n   338→}\n   339→\n   340→// containerState inspects the container for a run and returns one of:\n   341→//   - \"running\"   – container exists and is running\n   342→//   - \"stopped\"   – container exists, not running, not kept\n   343→//   - \"available\" – container exists, not running, kept (can be deleted)\n   344→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   345→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   346→\tif run.ContainerID == \"\" {\n   347→\t\treturn \"removed\"\n   348→\t}\n   349→\tmgr, ok := h.container.(ContainerManager)\n   350→\tif !ok {\n   351→\t\treturn \"removed\"\n   352→\t}\n   353→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   354→\tif err != nil {\n   355→\t\treturn \"removed\"\n   356→\t}\n   357→\tif status.Running {\n   358→\t\treturn \"running\"\n   359→\t}\n   360→\tif run.ContainerKept {\n   361→\t\treturn \"available\"\n   362→\t}\n   363→\treturn \"stopped\"\n   364→}\n   365→\n   366→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   367→\tid := r.PathValue(\"id\")\n   368→\n   369→\trun, err := h.store.GetRun(r.Context(), id)\n   370→\tif err != nil {\n   371→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   372→\t\treturn\n   373→\t}\n   374→\n   375→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   376→\tif err != nil {\n   377→\t\tcaps = nil // non-fatal\n   378→\t}\n   379→\n   380→\tsteps := mergeCaptures(caps)\n   381→\n   382→\tdata := map[string]any{\n   383→\t\t\"Title\":          \"Run \" + run.ID,\n   384→\t\t\"Run\":            run,\n   385→\t\t\"Steps\":          steps,\n   386→\t\t\"Page\":           \"detail\",\n   387→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   388→\t}\n   389→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   390→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   391→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   392→\t}\n   393→}\n   394→\n   395→// --- JSON API handlers ---\n   396→\n   397→type apiRun struct {\n   398→\tID           string `json:\"id\"`\n   399→\tWorkflowName string `json:\"workflow_name\"`\n   400→\tProjectDir   string `json:\"project_dir\"`\n   401→\tProjectLabel string `json:\"project_label\"`\n   402→\tState        string `json:\"state\"`\n   403→\tStartedAt    string `json:\"started_at\"`\n   404→\tCompletedAt  string `json:\"completed_at\"`\n   405→\tContainerID  string `json:\"container_id\"`\n   406→\tErrorMessage string `json:\"error_message\"`\n   407→\tTitle        string `json:\"title\"`\n   408→\tIsHost       bool   `json:\"is_host\"`\n   409→}\n   410→\n   411→type apiStep struct {\n   412→\tStepName    string `json:\"step_name\"`\n   413→\tResult      string `json:\"result\"`\n   414→\tStartedAt   string `json:\"started_at\"`\n   415→\tCompletedAt string `json:\"completed_at\"`\n   416→\tDuration    string `json:\"duration\"`\n   417→}\n   418→\n   419→type apiRunDetail struct {\n   420→\tapiRun\n   421→\tContainerState string    `json:\"container_state\"`\n   422→\tSteps          []apiStep `json:\"steps\"`\n   423→}\n   424→\n   425→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   426→\treturn apiRun{\n   427→\t\tID:           r.ID,\n   428→\t\tWorkflowName: r.WorkflowName,\n   429→\t\tProjectDir:   r.ProjectDir,\n   430→\t\tProjectLabel: labels[r.ProjectDir],\n   431→\t\tState:        string(r.State),\n   432→\t\tStartedAt:    formatTime(r.StartedAt),\n   433→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   434→\t\tContainerID:  r.ContainerID,\n   435→\t\tErrorMessage: r.ErrorMessage,\n   436→\t\tTitle:        r.Title,\n   437→\t\tIsHost:       r.IsHost,\n   438→\t}\n   439→}\n   440→\n   441→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   442→\tprojectFilter := r.URL.Query().Get(\"project\")\n   443→\n   444→\tvar runs []*domain.Run\n   445→\tvar err error\n   446→\tif projectFilter != \"\" {\n   447→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   448→\t} else {\n   449→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   450→\t}\n   451→\tif err != nil {\n   452→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   453→\t\treturn\n   454→\t}\n   455→\n   456→\tprojects, _ := h.store.ListProjects(r.Context())\n   457→\tlabels := projectLabels(projects)\n   458→\n   459→\tresult := make([]apiRun, len(runs))\n   460→\tfor i, run := range runs {\n   461→\t\tresult[i] = toAPIRun(run, labels)\n   462→\t}\n   463→\n   464→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   465→\tjson.NewEncoder(w).Encode(result)\n   466→}\n   467→\n   468→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   469→\tprojects, err := h.store.ListProjects(r.Context())\n   470→\tif err != nil {\n   471→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   472→\t\treturn\n   473→\t}\n   474→\tlabels := projectLabels(projects)\n   475→\n   476→\ttype apiHealth struct {\n   477→\t\tStatus string `json:\"status\"`\n   478→\t\tPassed int    `json:\"passed\"`\n   479→\t\tFailed int    `json:\"failed\"`\n   480→\t\tTotal  int    `json:\"total\"`\n   481→\t}\n   482→\ttype apiProject struct {\n   483→\t\tDir         string    `json:\"dir\"`\n   484→\t\tLabel       string    `json:\"label\"`\n   485→\t\tHealth      apiHealth `json:\"health\"`\n   486→\t\tActiveCount int       `json:\"active_count\"`\n   487→\t}\n   488→\tresult := make([]apiProject, len(projects))\n   489→\tfor i, dir := range projects {\n   490→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   491→\t\trunValues := make([]domain.Run, len(runs))\n   492→\t\tfor j, rr := range runs {\n   493→\t\t\trunValues[j] = *rr\n   494→\t\t}\n   495→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   496→\t\tvar activeCount int\n   497→\t\tfor _, rr := range runs {\n   498→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   499→\t\t\t\tactiveCount++\n   500→\t\t\t}\n   501→\t\t}\n   502→\t\tresult[i] = apiProject{\n   503→\t\t\tDir:   dir,\n   504→\t\t\tLabel: labels[dir],\n   505→\t\t\tHealth: apiHealth{\n   506→\t\t\t\tStatus: string(health.Status),\n   507→\t\t\t\tPassed: health.Passed,\n   508→\t\t\t\tFailed: health.Failed,\n   509→\t\t\t\tTotal:  health.Total,\n   510→\t\t\t},\n   511→\t\t\tActiveCount: activeCount,\n   512→\t\t}\n   513→\t}\n   514→\n   515→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   516→\tjson.NewEncoder(w).Encode(result)\n   517→}\n   518→\n   519→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   520→\tid := r.PathValue(\"id\")\n   521→\n   522→\trun, err := h.store.GetRun(r.Context(), id)\n   523→\tif err != nil {\n   524→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   525→\t\treturn\n   526→\t}\n   527→\n   528→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   529→\tif err != nil {\n   530→\t\tcaps = nil\n   531→\t}\n   532→\n   533→\tprojects, _ := h.store.ListProjects(r.Context())\n   534→\tlabels := projectLabels(projects)\n   535→\n   536→\tmerged := mergeCaptures(caps)\n   537→\tsteps := make([]apiStep, len(merged))\n   538→\tfor i, e := range merged {\n   539→\t\tsteps[i] = apiStep{\n   540→\t\t\tStepName:  e.StepName,\n   541→\t\t\tResult:    e.Result,\n   542→\t\t\tStartedAt: formatTime(e.StartedAt),\n   543→\t\t\tDuration:  e.Duration,\n   544→\t\t}\n   545→\t}\n   546→\n   547→\tdetail := apiRunDetail{\n   548→\t\tapiRun:         toAPIRun(run, labels),\n   549→\t\tContainerState: h.containerState(r.Context(), run),\n   550→\t\tSteps:          steps,\n   551→\t}\n   552→\n   553→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   554→\tjson.NewEncoder(w).Encode(detail)\n   555→}\n   556→\n   557→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   558→\tid := r.PathValue(\"id\")\n   559→\tstep := r.PathValue(\"step\")\n   560→\tlogType := r.URL.Query().Get(\"type\")   // optional: \"script\", \"llm\"\n   561→\tformat := r.URL.Query().Get(\"format\")  // optional: \"raw\" to skip parsing\n   562→\n   563→\trun, err := h.store.GetRun(r.Context(), id)\n   564→\tif err != nil {\n   565→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   566→\t\treturn\n   567→\t}\n   568→\n   569→\twriteOutput := func(data []byte) {\n   570→\t\tif format != \"raw\" {\n   571→\t\t\tdata = logstream.ParseClaudeStream(data)\n   572→\t\t}\n   573→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   574→\t\tw.Write(data)\n   575→\t}\n   576→\n   577→\t// Try log index first for fast lookup\n   578→\tif h.logStore != nil {\n   579→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   580→\t\tif err == nil && len(logFiles) > 0 {\n   581→\t\t\t// If type filter specified, narrow results\n   582→\t\t\tfor _, lf := range logFiles {\n   583→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   584→\t\t\t\t\tcontinue\n   585→\t\t\t\t}\n   586→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   587→\t\t\t\tif readErr == nil && len(data) > 0 {\n   588→\t\t\t\t\twriteOutput(data)\n   589→\t\t\t\t\treturn\n   590→\t\t\t\t}\n   591→\t\t\t}\n   592→\t\t}\n   593→\t}\n   594→\n   595→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   596→\n   597→\t// Fall back to file path conventions\n   598→\t// If type is \"llm\", try llm-<step>.log\n   599→\tif logType == \"llm\" {\n   600→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   601→\t\tdata, err := os.ReadFile(llmPath)\n   602→\t\tif err == nil && len(data) > 0 {\n   603→\t\t\twriteOutput(data)\n   604→\t\t\treturn\n   605→\t\t}\n   606→\t}\n   607→\n   608→\t// Try per-step output first, fall back to container.log, then live docker logs\n   609→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   610→\tdata, err := os.ReadFile(outputPath)\n   611→\tif err == nil && len(data) > 0 {\n   612→\t\twriteOutput(data)\n   613→\t\treturn\n   614→\t}\n   615→\n   616→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   617→\tdata, err = os.ReadFile(containerLog)\n   618→\tif err == nil && len(data) > 0 {\n   619→\t\twriteOutput(data)\n   620→\t\treturn\n   621→\t}\n   622→\n   623→\t// Last resort: try live docker logs from still-existing container\n   624→\tif h.container != nil && run.ContainerID != \"\" {\n   625→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   626→\t\t\twriteOutput([]byte(logs))\n   627→\t\t\treturn\n   628→\t\t}\n   629→\t}\n   630→\n   631→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   632→}\n   633→\n   634→func (h *Handler) handleAPIStopRun(w http.ResponseWriter, r *http.Request) {\n   635→\tid := r.PathValue(\"id\")\n   636→\n   637→\trun, err := h.store.GetRun(r.Context(), id)\n   638→\tif err != nil {\n   639→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   640→\t\tw.WriteHeader(http.StatusNotFound)\n   641→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   642→\t\treturn\n   643→\t}\n   644→\n   645→\t// Only allow stopping active runs\n   646→\tif run.State != domain.RunStatePending && run.State != domain.RunStateRunning {\n   647→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   648→\t\tw.WriteHeader(http.StatusBadRequest)\n   649→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run is not active\"})\n   650→\t\treturn\n   651→\t}\n   652→\n   653→\tmgr, ok := h.container.(ContainerManager)\n   654→\tif !ok || run.ContainerID == \"\" {\n   655→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   656→\t\tw.WriteHeader(http.StatusBadRequest)\n   657→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   658→\t\treturn\n   659→\t}\n   660→\n   661→\tif err := mgr.Stop(r.Context(), run.ContainerID); err != nil {\n   662→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   663→\t\tw.WriteHeader(http.StatusInternalServerError)\n   664→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to stop run: %v\", err)})\n   665→\t\treturn\n   666→\t}\n   667→\n   668→\trun.Complete(domain.RunStateCancelled)\n   669→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   670→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   671→\t\tw.WriteHeader(http.StatusInternalServerError)\n   672→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   673→\t\treturn\n   674→\t}\n   675→\n   676→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   677→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   678→}\n   679→\n   680→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   681→\tid := r.PathValue(\"id\")\n   682→\n   683→\trun, err := h.store.GetRun(r.Context(), id)\n   684→\tif err != nil {\n   685→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   686→\t\tw.WriteHeader(http.StatusNotFound)\n   687→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   688→\t\treturn\n   689→\t}\n   690→\n   691→\tmgr, ok := h.container.(ContainerManager)\n   692→\tif !ok || run.ContainerID == \"\" {\n   693→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   694→\t\tw.WriteHeader(http.StatusBadRequest)\n   695→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   696→\t\treturn\n   697→\t}\n   698→\n   699→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   700→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   701→\t\tw.WriteHeader(http.StatusInternalServerError)\n   702→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   703→\t\treturn\n   704→\t}\n   705→\n   706→\trun.ContainerKept = false\n   707→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   708→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   709→\t\tw.WriteHeader(http.StatusInternalServerError)\n   710→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   711→\t\treturn\n   712→\t}\n   713→\n   714→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   715→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   716→}\n   717→\n   718→// handleAPIDeleteProjectContainers mass-deletes all retained/exited containers for a project.\n   719→func (h *Handler) handleAPIDeleteProjectContainers(w http.ResponseWriter, r *http.Request) {\n   720→\tdir, _, ok := h.resolveProjectDir(w, r)\n   721→\tif !ok {\n   722→\t\treturn\n   723→\t}\n   724→\n   725→\tmgr, ok := h.container.(ContainerManager)\n   726→\tif !ok {\n   727→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   728→\t\tw.WriteHeader(http.StatusBadRequest)\n   729→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   730→\t\treturn\n   731→\t}\n   732→\n   733→\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   734→\tif err != nil {\n   735→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   736→\t\tw.WriteHeader(http.StatusInternalServerError)\n   737→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"failed to list runs\"})\n   738→\t\treturn\n   739→\t}\n   740→\n   741→\tvar deleted int\n   742→\tvar errors []string\n   743→\tfor _, run := range runs {\n   744→\t\tif !run.ContainerKept || run.ContainerID == \"\" {\n   745→\t\t\tcontinue\n   746→\t\t}\n   747→\t\t// Check container is not running\n   748→\t\tstatus, err := mgr.Inspect(r.Context(), run.ContainerID)\n   749→\t\tif err != nil {\n   750→\t\t\t// Container already gone — just clear the flag\n   751→\t\t\trun.ContainerKept = false\n   752→\t\t\th.store.UpdateRun(r.Context(), run)\n   753→\t\t\tdeleted++\n   754→\t\t\tcontinue\n   755→\t\t}\n   756→\t\tif status.Running {\n   757→\t\t\tcontinue // skip running containers\n   758→\t\t}\n   759→\t\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   760→\t\t\terrors = append(errors, fmt.Sprintf(\"%s: %v\", run.ID, err))\n   761→\t\t\tcontinue\n   762→\t\t}\n   763→\t\trun.ContainerKept = false\n   764→\t\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   765→\t\t\terrors = append(errors, fmt.Sprintf(\"%s: update failed: %v\", run.ID, err))\n   766→\t\t\tcontinue\n   767→\t\t}\n   768→\t\tdeleted++\n   769→\t}\n   770→\n   771→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   772→\tresp := map[string]any{\"deleted\": deleted}\n   773→\tif len(errors) > 0 {\n   774→\t\tresp[\"errors\"] = errors\n   775→\t}\n   776→\tjson.NewEncoder(w).Encode(resp)\n   777→}\n   778→\n   779→// handleAPIStream serves an SSE stream of log lines for a run.\n   780→// For active runs, it subscribes to the live broadcaster.\n   781→// For completed runs, it serves the archived full.log then closes.\n   782→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   783→\tid := r.PathValue(\"id\")\n   784→\n   785→\trun, err := h.store.GetRun(r.Context(), id)\n   786→\tif err != nil {\n   787→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   788→\t\treturn\n   789→\t}\n   790→\n   791→\tflusher, ok := w.(http.Flusher)\n   792→\tif !ok {\n   793→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   794→\t\treturn\n   795→\t}\n   796→\n   797→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   798→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   799→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   800→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   801→\n   802→\tisComplete := run.State == domain.RunStateSucceeded ||\n   803→\t\trun.State == domain.RunStateFailed ||\n   804→\t\trun.State == domain.RunStateCancelled\n   805→\n   806→\tif isComplete {\n   807→\t\t// Serve archived full.log\n   808→\t\th.streamFullLog(w, flusher, run)\n   809→\t\t// Send done event\n   810→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   811→\t\tflusher.Flush()\n   812→\t\treturn\n   813→\t}\n   814→\n   815→\t// Active run: subscribe to live broadcaster\n   816→\tif h.logBroadcast == nil {\n   817→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   818→\t\treturn\n   819→\t}\n   820→\n   821→\tsub := h.logBroadcast.Subscribe(id)\n   822→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   823→\n   824→\tctx := r.Context()\n   825→\tfor {\n   826→\t\tselect {\n   827→\t\tcase <-ctx.Done():\n   828→\t\t\treturn\n   829→\t\tcase line, ok := <-sub.C:\n   830→\t\t\tif !ok {\n   831→\t\t\t\t// Stream finished (run completed)\n   832→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   833→\t\t\t\tflusher.Flush()\n   834→\t\t\t\treturn\n   835→\t\t\t}\n   836→\t\t\tline = parseLLMLogLine(line)\n   837→\t\t\tif line.Type == \"\" {\n   838→\t\t\t\tcontinue // skip protocol-only llm lines\n   839→\t\t\t}\n   840→\t\t\tdata, _ := json.Marshal(line)\n   841→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   842→\t\t\tflusher.Flush()\n   843→\t\t}\n   844→\t}\n   845→}\n   846→\n   847→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   848→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   849→\n   850→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   851→// LLM-type lines are parsed from raw Claude JSON into human-readable text.\n   852→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   853→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   854→\tf, err := os.Open(logPath)\n   855→\tif err != nil {\n   856→\t\treturn\n   857→\t}\n   858→\tdefer f.Close()\n   859→\n   860→\tscanner := bufio.NewScanner(f)\n   861→\tfor scanner.Scan() {\n   862→\t\ttext := scanner.Text()\n   863→\t\tline := parseFullLogLine(text)\n   864→\t\tline = parseLLMLogLine(line)\n   865→\t\tif line.Type == \"\" {\n   866→\t\t\tcontinue // skip protocol-only llm lines\n   867→\t\t}\n   868→\t\tdata, _ := json.Marshal(line)\n   869→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   870→\t\tflusher.Flush()\n   871→\t}\n   872→}\n   873→\n   874→// parseLLMLogLine parses a LogLine whose type is \"llm\". If the content is\n   875→// Claude stream JSON, it extracts the human-readable text. Protocol-only\n   876→// events return a LogLine with an empty Type (caller should skip it).\n   877→// Non-llm lines are returned unchanged.\n   878→func parseLLMLogLine(line logstream.LogLine) logstream.LogLine {\n   879→\tif line.Type != \"llm\" {\n   880→\t\treturn line\n   881→\t}\n   882→\ttext, ok := logstream.ParseClaudeLine([]byte(line.Content))\n   883→\tif !ok {\n   884→\t\treturn logstream.LogLine{} // signal to skip\n   885→\t}\n   886→\tline.Content = text\n   887→\treturn line\n   888→}\n   889→\n   890→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   891→func parseFullLogLine(text string) logstream.LogLine {\n   892→\tm := logLineRegex.FindStringSubmatch(text)\n   893→\tif m == nil {\n   894→\t\treturn logstream.LogLine{\n   895→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   896→\t\t\tType:      \"script\",\n   897→\t\t\tContent:   text,\n   898→\t\t}\n   899→\t}\n   900→\treturn logstream.LogLine{\n   901→\t\tTimestamp: m[1],\n   902→\t\tType:      m[2],\n   903→\t\tContent:   m[3],\n   904→\t}\n   905→}\n   906→\n   907→// --- Project detail handlers ---\n   908→\n   909→// resolveProjectDir resolves a project label from the URL to its directory path.\n   910→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   911→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   912→\tlabel := r.PathValue(\"name\")\n   913→\tprojects, _ := h.store.ListProjects(r.Context())\n   914→\tlabels := projectLabels(projects)\n   915→\tfor dir, l := range labels {\n   916→\t\tif l == label {\n   917→\t\t\treturn dir, label, true\n   918→\t\t}\n   919→\t}\n   920→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   921→\tw.WriteHeader(http.StatusNotFound)\n   922→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   923→\treturn \"\", \"\", false\n   924→}\n   925→\n   926→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   927→\tdir, label, ok := h.resolveProjectDir(w, r)\n   928→\tif !ok {\n   929→\t\treturn\n   930→\t}\n   931→\n   932→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   933→\tn := 10\n   934→\tif n > len(runs) {\n   935→\t\tn = len(runs)\n   936→\t}\n   937→\tdots := make([]recentRunDot, n)\n   938→\tfor i := 0; i < n; i++ {\n   939→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   940→\t}\n   941→\n   942→\tvar containerCount int\n   943→\tfor _, run := range runs {\n   944→\t\tif run.ContainerKept {\n   945→\t\t\tcontainerCount++\n   946→\t\t}\n   947→\t}\n   948→\n   949→\tdata := map[string]any{\n   950→\t\t\"Title\":          label,\n   951→\t\t\"Label\":          label,\n   952→\t\t\"Dir\":            dir,\n   953→\t\t\"RecentRuns\":     dots,\n   954→\t\t\"ContainerCount\": containerCount,\n   955→\t}\n   956→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   957→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   958→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   959→\t}\n   960→}\n   961→\n   962→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   963→\tdir, _, ok := h.resolveProjectDir(w, r)\n   964→\tif !ok {\n   965→\t\treturn\n   966→\t}\n   967→\n   968→\t// Docker image: read FROM line from Dockerfile\n   969→\tdockerImage := \"\"\n   970→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   971→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   972→\t\t// Find the last FROM line (final stage)\n   973→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   974→\t\t\ttrimmed := strings.TrimSpace(line)\n   975→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   976→\t\t\t\tparts := strings.Fields(trimmed)\n   977→\t\t\t\tif len(parts) >= 2 {\n   978→\t\t\t\t\tdockerImage = parts[1]\n   979→\t\t\t\t}\n   980→\t\t\t}\n   981→\t\t}\n   982→\t}\n   983→\n   984→\t// Version\n   985→\tversion := 0\n   986→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   987→\tif data, err := os.ReadFile(versionPath); err == nil {\n   988→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   989→\t\t\tversion = v\n   990→\t\t}\n   991→\t}\n   992→\n   993→\t// Prompt files history\n   994→\ttype commitEntry struct {\n   995→\t\tSHA     string `json:\"sha\"`\n   996→\t\tDate    string `json:\"date\"`\n   997→\t\tMessage string `json:\"message\"`\n   998→\t}\n   999→\ttype promptFile struct {\n  1000→\t\tPath    string        `json:\"path\"`\n  1001→\t\tHistory []commitEntry `json:\"history\"`\n  1002→\t}\n  1003→\n  1004→\tvar promptFiles []promptFile\n  1005→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n  1006→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n  1007→\t\tfor _, e := range entries {\n  1008→\t\t\tif e.IsDir() {\n  1009→\t\t\t\tcontinue\n  1010→\t\t\t}\n  1011→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n  1012→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n  1013→\t\t\tcmd.Dir = dir\n  1014→\t\t\tout, err := cmd.Output()\n  1015→\t\t\tif err != nil {\n  1016→\t\t\t\tcontinue\n  1017→\t\t\t}\n  1018→\t\t\tvar history []commitEntry\n  1019→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n  1020→\t\t\t\tif line == \"\" {\n  1021→\t\t\t\t\tcontinue\n  1022→\t\t\t\t}\n  1023→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1024→\t\t\t\tif len(parts) < 3 {\n  1025→\t\t\t\t\tcontinue\n  1026→\t\t\t\t}\n  1027→\t\t\t\t// Parse date to short form\n  1028→\t\t\t\tdateStr := parts[1]\n  1029→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1030→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1031→\t\t\t\t}\n  1032→\t\t\t\thistory = append(history, commitEntry{\n  1033→\t\t\t\t\tSHA:     parts[0][:7],\n  1034→\t\t\t\t\tDate:    dateStr,\n  1035→\t\t\t\t\tMessage: parts[2],\n  1036→\t\t\t\t})\n  1037→\t\t\t}\n  1038→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1039→\t\t}\n  1040→\t}\n  1041→\n  1042→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1043→\tjson.NewEncoder(w).Encode(map[string]any{\n  1044→\t\t\"docker_image\": dockerImage,\n  1045→\t\t\"version\":      version,\n  1046→\t\t\"prompt_files\": promptFiles,\n  1047→\t})\n  1048→}\n  1049→\n  1050→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1051→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1052→\tif !ok {\n  1053→\t\treturn\n  1054→\t}\n  1055→\tfile := r.URL.Query().Get(\"file\")\n  1056→\tsha := r.URL.Query().Get(\"sha\")\n  1057→\tif file == \"\" || sha == \"\" {\n  1058→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1059→\t\treturn\n  1060→\t}\n  1061→\n  1062→\t// Validate sha is alphanumeric to prevent injection\n  1063→\tfor _, c := range sha {\n  1064→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1065→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1066→\t\t\treturn\n  1067→\t\t}\n  1068→\t}\n  1069→\n  1070→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1071→\tcmd.Dir = dir\n  1072→\tout, err := cmd.Output()\n  1073→\tif err != nil {\n  1074→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1075→\t\treturn\n  1076→\t}\n  1077→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1078→\tw.Write(out)\n  1079→}\n  1080→\n  1081→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1082→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1083→\tif !ok {\n  1084→\t\treturn\n  1085→\t}\n  1086→\n  1087→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1088→\tentries, err := os.ReadDir(clocheDir)\n  1089→\tif err != nil {\n  1090→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1091→\t\tjson.NewEncoder(w).Encode([]any{})\n  1092→\t\treturn\n  1093→\t}\n  1094→\n  1095→\ttype apiWire struct {\n  1096→\t\tFrom   string `json:\"from\"`\n  1097→\t\tResult string `json:\"result\"`\n  1098→\t\tTo     string `json:\"to\"`\n  1099→\t}\n  1100→\ttype apiStepDef struct {\n  1101→\t\tName    string            `json:\"name\"`\n  1102→\t\tType    string            `json:\"type\"`\n  1103→\t\tResults []string          `json:\"results\"`\n  1104→\t\tConfig  map[string]string `json:\"config\"`\n  1105→\t}\n  1106→\ttype apiWorkflow struct {\n  1107→\t\tName      string       `json:\"name\"`\n  1108→\t\tFile      string       `json:\"file\"`\n  1109→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1110→\t\tWires     []apiWire    `json:\"wires\"`\n  1111→\t\tEntryStep string       `json:\"entry_step\"`\n  1112→\t}\n  1113→\n  1114→\tvar workflows []apiWorkflow\n  1115→\tfor _, e := range entries {\n  1116→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1117→\t\t\tcontinue\n  1118→\t\t}\n  1119→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1120→\t\tif err != nil {\n  1121→\t\t\tcontinue\n  1122→\t\t}\n  1123→\t\twf, err := dsl.ParseForContainer(string(data))\n  1124→\t\tif err != nil {\n  1125→\t\t\tcontinue\n  1126→\t\t}\n  1127→\t\tvar steps []apiStepDef\n  1128→\t\tfor _, s := range wf.Steps {\n  1129→\t\t\tsteps = append(steps, apiStepDef{\n  1130→\t\t\t\tName:    s.Name,\n  1131→\t\t\t\tType:    string(s.Type),\n  1132→\t\t\t\tResults: s.Results,\n  1133→\t\t\t\tConfig:  s.Config,\n  1134→\t\t\t})\n  1135→\t\t}\n  1136→\t\t// Sort steps by name for consistent ordering\n  1137→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1138→\n  1139→\t\tvar wires []apiWire\n  1140→\t\tfor _, wire := range wf.Wiring {\n  1141→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1142→\t\t}\n  1143→\n  1144→\t\tworkflows = append(workflows, apiWorkflow{\n  1145→\t\t\tName:      wf.Name,\n  1146→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1147→\t\t\tSteps:     steps,\n  1148→\t\t\tWires:     wires,\n  1149→\t\t\tEntryStep: wf.EntryStep,\n  1150→\t\t})\n  1151→\t}\n  1152→\n  1153→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1154→\tjson.NewEncoder(w).Encode(workflows)\n  1155→}\n  1156→\n  1157→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1158→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1159→\tif !ok {\n  1160→\t\treturn\n  1161→\t}\n  1162→\tworkflowName := r.PathValue(\"workflow\")\n  1163→\tstepName := r.PathValue(\"step\")\n  1164→\n  1165→\t// Find the workflow file\n  1166→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1167→\tvar wf *domain.Workflow\n  1168→\tentries, _ := os.ReadDir(clocheDir)\n  1169→\tfor _, e := range entries {\n  1170→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1171→\t\t\tcontinue\n  1172→\t\t}\n  1173→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1174→\t\tif err != nil {\n  1175→\t\t\tcontinue\n  1176→\t\t}\n  1177→\t\tparsed, err := dsl.ParseForContainer(string(data))\n  1178→\t\tif err != nil {\n  1179→\t\t\tcontinue\n  1180→\t\t}\n  1181→\t\tif parsed.Name == workflowName {\n  1182→\t\t\twf = parsed\n  1183→\t\t\tbreak\n  1184→\t\t}\n  1185→\t}\n  1186→\tif wf == nil {\n  1187→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1188→\t\treturn\n  1189→\t}\n  1190→\n  1191→\tstep, ok := wf.Steps[stepName]\n  1192→\tif !ok {\n  1193→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1194→\t\treturn\n  1195→\t}\n  1196→\n  1197→\t// Try to read the referenced file from step config\n  1198→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1199→\n  1200→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1201→\t\tcontent, err := resolveFileRef(prompt, dir)\n  1202→\t\tif err == nil {\n  1203→\t\t\tw.Write([]byte(content))\n  1204→\t\t\treturn\n  1205→\t\t}\n  1206→\t}\n  1207→\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n  1208→\t\tcontent, _ := resolveFileRef(cmd, dir)\n  1209→\t\tw.Write([]byte(content))\n  1210→\t\treturn\n  1211→\t}\n  1212→\tif script := step.Config[\"script\"]; script != \"\" {\n  1213→\t\tcontent, _ := resolveFileRef(script, dir)\n  1214→\t\tw.Write([]byte(content))\n  1215→\t\treturn\n  1216→\t}\n  1217→\n  1218→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1219→}\n  1220→\n  1221→// --- Template helpers ---\n  1222→\n  1223→// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n  1224→// If the value uses file() syntax, the referenced file is read from disk.\n  1225→// Otherwise the value is returned as-is.\n  1226→func resolveFileRef(value, baseDir string) (string, error) {\n  1227→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n  1228→\t\tpath := value[6 : len(value)-2]\n  1229→\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n  1230→\t\tif err != nil {\n  1231→\t\t\treturn \"\", err\n  1232→\t\t}\n  1233→\t\treturn string(data), nil\n  1234→\t}\n  1235→\treturn value, nil\n  1236→}\n  1237→\n  1238→func stateColor(state domain.RunState) string {\n  1239→\tswitch state {\n  1240→\tcase domain.RunStatePending:\n  1241→\t\treturn \"pending\"\n  1242→\tcase domain.RunStateRunning:\n  1243→\t\treturn \"running\"\n  1244→\tcase domain.RunStateSucceeded:\n  1245→\t\treturn \"succeeded\"\n  1246→\tcase domain.RunStateFailed:\n  1247→\t\treturn \"failed\"\n  1248→\tcase domain.RunStateCancelled:\n  1249→\t\treturn \"cancelled\"\n  1250→\tdefault:\n  1251→\t\treturn \"pending\"\n  1252→\t}\n  1253→}\n  1254→\n  1255→func healthColor(status domain.HealthStatus) string {\n  1256→\tswitch status {\n  1257→\tcase domain.HealthGreen:\n  1258→\t\treturn \"green\"\n  1259→\tcase domain.HealthYellow:\n  1260→\t\treturn \"yellow\"\n  1261→\tcase domain.HealthRed:\n  1262→\t\treturn \"red\"\n  1263→\tcase domain.HealthBlue:\n  1264→\t\treturn \"blue\"\n  1265→\tdefault:\n  1266→\t\treturn \"grey\"\n  1267→\t}\n  1268→}\n  1269→\n  1270→func formatTime(t time.Time) string {\n  1271→\tif t.IsZero() {\n  1272→\t\treturn \"\"\n  1273→\t}\n  1274→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1275→}\n  1276→\n  1277→func formatDuration(start, end time.Time) string {\n  1278→\tif start.IsZero() || end.IsZero() {\n  1279→\t\treturn \"\"\n  1280→\t}\n  1281→\td := end.Sub(start)\n  1282→\tif d < time.Second {\n  1283→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1284→\t}\n  1285→\tif d < time.Minute {\n  1286→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1287→\t}\n  1288→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1289→}\n  1290→\n  1291→func truncate(s string, n int) string {\n  1292→\tif len(s) <= n {\n  1293→\t\treturn s\n  1294→\t}\n  1295→\treturn s[:n] + \"...\"\n  1296→}\n  1297→\n  1298→func shortContainerID(id string) string {\n  1299→\tif len(id) > 12 {\n  1300→\t\treturn id[:12]\n  1301→\t}\n  1302→\treturn id\n  1303→}\n  1304→\n  1305→// projectLabels builds a mapping from full project directory paths to short\n  1306→// display labels. Each label is the final directory component (e.g.\n  1307→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1308→// the same final name, the parent directory is prepended to disambiguate\n  1309→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1310→func projectLabels(dirs []string) map[string]string {\n  1311→\tlabels := make(map[string]string, len(dirs))\n  1312→\t// Group dirs by their base name to detect conflicts.\n  1313→\tbyBase := map[string][]string{}\n  1314→\tfor _, d := range dirs {\n  1315→\t\tbase := filepath.Base(d)\n  1316→\t\tbyBase[base] = append(byBase[base], d)\n  1317→\t}\n  1318→\tfor base, paths := range byBase {\n  1319→\t\tif len(paths) == 1 {\n  1320→\t\t\tlabels[paths[0]] = base\n  1321→\t\t} else {\n  1322→\t\t\tfor _, p := range paths {\n  1323→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1324→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1325→\t\t\t}\n  1326→\t\t}\n  1327→\t}\n  1328→\treturn labels\n  1329→}\n  1330→\n  1331→type projectEntry struct {\n  1332→\tDir            string\n  1333→\tLabel          string\n  1334→\tContainerCount int\n  1335→}\n  1336→"}]},"parent_tool_use_id":"toolu_019yUUVWxJFvKXV8mmuHGDBA","session_id":"daab45ac-603f-4f11-b864-beeca03c969d","uuid":"1a675091-2c12-4b41-99a2-0920a7550123"}
