{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MozhAWFFHHkovutLYq3aFb","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    12→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    13→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14→)\n    15→\n    16→// Ensure hostStatusHandler implements engine.StatusHandler.\n    17→var _ engine.StatusHandler = (*hostStatusHandler)(nil)\n    18→\n    19→// Runner executes a host workflow by parsing host.cloche and walking the step graph.\n    20→type Runner struct {\n    21→\tDispatcher RunDispatcher\n    22→\tStore      ports.RunStore\n    23→}\n    24→\n    25→// RunResult contains the outcome of a host workflow execution.\n    26→type RunResult struct {\n    27→\tRunID string\n    28→\tState domain.RunState\n    29→}\n    30→\n    31→// Run parses .cloche/host.cloche from projectDir and executes the \"main\" workflow.\n    32→func (r *Runner) Run(ctx context.Context, projectDir string) (*RunResult, error) {\n    33→\treturn r.RunWithID(ctx, projectDir, domain.GenerateRunID(\"main\"))\n    34→}\n    35→\n    36→// RunWithID is like Run but uses the provided run ID instead of generating one.\n    37→func (r *Runner) RunWithID(ctx context.Context, projectDir string, orchRunID string) (*RunResult, error) {\n    38→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n    39→\tdata, err := os.ReadFile(hostPath)\n    40→\tif err != nil {\n    41→\t\treturn nil, fmt.Errorf(\"reading host.cloche: %w\", err)\n    42→\t}\n    43→\n    44→\twf, err := dsl.ParseForHost(string(data))\n    45→\tif err != nil {\n    46→\t\treturn nil, fmt.Errorf(\"parsing host.cloche: %w\", err)\n    47→\t}\n    48→\n    49→\tif wf.Name != \"main\" {\n    50→\t\treturn nil, fmt.Errorf(\"host.cloche workflow is %q, expected \\\"main\\\"\", wf.Name)\n    51→\t}\n    52→\n    53→\t// Create output directory for step outputs\n    54→\toutputDir := filepath.Join(projectDir, \".cloche\", orchRunID, \"output\")\n    55→\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n    56→\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n    57→\t}\n    58→\n    59→\tlog.Printf(\"host workflow: starting %q for project %s (run %s)\", wf.Name, projectDir, orchRunID)\n    60→\n    61→\t// Persist the host run in the store so it appears in list/status/logs.\n    62→\thostRun := domain.NewRun(orchRunID, wf.Name)\n    63→\thostRun.ProjectDir = projectDir\n    64→\thostRun.IsHost = true\n    65→\tif err := r.Store.CreateRun(ctx, hostRun); err != nil {\n    66→\t\treturn nil, fmt.Errorf(\"creating host run record: %w\", err)\n    67→\t}\n    68→\thostRun.Start()\n    69→\t_ = r.Store.UpdateRun(ctx, hostRun)\n    70→\n    71→\texecutor := &Executor{\n    72→\t\tProjectDir: projectDir,\n    73→\t\tDispatcher: r.Dispatcher,\n    74→\t\tStore:      r.Store,\n    75→\t\tOutputDir:  outputDir,\n    76→\t\tWires:      wf.Wiring,\n    77→\t}\n    78→\n    79→\teng := engine.New(executor)\n    80→\teng.SetStatusHandler(&hostStatusHandler{\n    81→\t\tprojectDir: projectDir,\n    82→\t\torchRunID:  orchRunID,\n    83→\t\tstore:      r.Store,\n    84→\t})\n    85→\n    86→\trun, runErr := eng.Run(ctx, wf)\n    87→\n    88→\tresult := &RunResult{\n    89→\t\tRunID: orchRunID,\n    90→\t\tState: domain.RunStateFailed,\n    91→\t}\n    92→\tif run != nil {\n    93→\t\tresult.State = run.State\n    94→\t}\n    95→\n    96→\t// Persist final state.\n    97→\thostRun, _ = r.Store.GetRun(ctx, orchRunID)\n    98→\tif hostRun != nil {\n    99→\t\tif runErr != nil {\n   100→\t\t\thostRun.Fail(runErr.Error())\n   101→\t\t} else {\n   102→\t\t\thostRun.Complete(result.State)\n   103→\t\t}\n   104→\t\thostRun.ActiveSteps = nil\n   105→\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n   106→\t}\n   107→\n   108→\tif runErr != nil {\n   109→\t\tlog.Printf(\"host workflow: %q failed for %s: %v\", wf.Name, projectDir, runErr)\n   110→\t\treturn result, runErr\n   111→\t}\n   112→\n   113→\tlog.Printf(\"host workflow: %q completed for %s with state %s\", wf.Name, projectDir, run.State)\n   114→\treturn result, nil\n   115→}\n   116→\n   117→// hostStatusHandler logs host workflow step events and persists them to the store.\n   118→type hostStatusHandler struct {\n   119→\tprojectDir string\n   120→\torchRunID  string\n   121→\tstore      ports.RunStore\n   122→}\n   123→\n   124→func (h *hostStatusHandler) OnStepStart(_ *domain.Run, step *domain.Step) {\n   125→\tlog.Printf(\"host workflow [%s]: step %q started\", h.orchRunID, step.Name)\n   126→\tif h.store != nil {\n   127→\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n   128→\t\t\tr.RecordStepStart(step.Name)\n   129→\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n   130→\t\t}\n   131→\t}\n   132→}\n   133→\n   134→func (h *hostStatusHandler) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   135→\tlog.Printf(\"host workflow [%s]: step %q completed with result %q\", h.orchRunID, step.Name, result)\n   136→\tif h.store != nil {\n   137→\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n   138→\t\t\tr.RecordStepComplete(step.Name, result)\n   139→\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n   140→\t\t}\n   141→\t}\n   142→}\n   143→\n   144→func (h *hostStatusHandler) OnRunComplete(run *domain.Run) {\n   145→\tlog.Printf(\"host workflow [%s]: run completed with state %s\", h.orchRunID, run.State)\n   146→}\n   147→"}]},"parent_tool_use_id":null,"session_id":"daab45ac-603f-4f11-b864-beeca03c969d","uuid":"ca43b084-f3ce-4de8-9907-a20f8879f8b3","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/runner.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// Ensure hostStatusHandler implements engine.StatusHandler.\nvar _ engine.StatusHandler = (*hostStatusHandler)(nil)\n\n// Runner executes a host workflow by parsing host.cloche and walking the step graph.\ntype Runner struct {\n\tDispatcher RunDispatcher\n\tStore      ports.RunStore\n}\n\n// RunResult contains the outcome of a host workflow execution.\ntype RunResult struct {\n\tRunID string\n\tState domain.RunState\n}\n\n// Run parses .cloche/host.cloche from projectDir and executes the \"main\" workflow.\nfunc (r *Runner) Run(ctx context.Context, projectDir string) (*RunResult, error) {\n\treturn r.RunWithID(ctx, projectDir, domain.GenerateRunID(\"main\"))\n}\n\n// RunWithID is like Run but uses the provided run ID instead of generating one.\nfunc (r *Runner) RunWithID(ctx context.Context, projectDir string, orchRunID string) (*RunResult, error) {\n\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n\tdata, err := os.ReadFile(hostPath)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading host.cloche: %w\", err)\n\t}\n\n\twf, err := dsl.ParseForHost(string(data))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing host.cloche: %w\", err)\n\t}\n\n\tif wf.Name != \"main\" {\n\t\treturn nil, fmt.Errorf(\"host.cloche workflow is %q, expected \\\"main\\\"\", wf.Name)\n\t}\n\n\t// Create output directory for step outputs\n\toutputDir := filepath.Join(projectDir, \".cloche\", orchRunID, \"output\")\n\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n\t}\n\n\tlog.Printf(\"host workflow: starting %q for project %s (run %s)\", wf.Name, projectDir, orchRunID)\n\n\t// Persist the host run in the store so it appears in list/status/logs.\n\thostRun := domain.NewRun(orchRunID, wf.Name)\n\thostRun.ProjectDir = projectDir\n\thostRun.IsHost = true\n\tif err := r.Store.CreateRun(ctx, hostRun); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating host run record: %w\", err)\n\t}\n\thostRun.Start()\n\t_ = r.Store.UpdateRun(ctx, hostRun)\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tDispatcher: r.Dispatcher,\n\t\tStore:      r.Store,\n\t\tOutputDir:  outputDir,\n\t\tWires:      wf.Wiring,\n\t}\n\n\teng := engine.New(executor)\n\teng.SetStatusHandler(&hostStatusHandler{\n\t\tprojectDir: projectDir,\n\t\torchRunID:  orchRunID,\n\t\tstore:      r.Store,\n\t})\n\n\trun, runErr := eng.Run(ctx, wf)\n\n\tresult := &RunResult{\n\t\tRunID: orchRunID,\n\t\tState: domain.RunStateFailed,\n\t}\n\tif run != nil {\n\t\tresult.State = run.State\n\t}\n\n\t// Persist final state.\n\thostRun, _ = r.Store.GetRun(ctx, orchRunID)\n\tif hostRun != nil {\n\t\tif runErr != nil {\n\t\t\thostRun.Fail(runErr.Error())\n\t\t} else {\n\t\t\thostRun.Complete(result.State)\n\t\t}\n\t\thostRun.ActiveSteps = nil\n\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n\t}\n\n\tif runErr != nil {\n\t\tlog.Printf(\"host workflow: %q failed for %s: %v\", wf.Name, projectDir, runErr)\n\t\treturn result, runErr\n\t}\n\n\tlog.Printf(\"host workflow: %q completed for %s with state %s\", wf.Name, projectDir, run.State)\n\treturn result, nil\n}\n\n// hostStatusHandler logs host workflow step events and persists them to the store.\ntype hostStatusHandler struct {\n\tprojectDir string\n\torchRunID  string\n\tstore      ports.RunStore\n}\n\nfunc (h *hostStatusHandler) OnStepStart(_ *domain.Run, step *domain.Step) {\n\tlog.Printf(\"host workflow [%s]: step %q started\", h.orchRunID, step.Name)\n\tif h.store != nil {\n\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n\t\t\tr.RecordStepStart(step.Name)\n\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n\t\t}\n\t}\n}\n\nfunc (h *hostStatusHandler) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n\tlog.Printf(\"host workflow [%s]: step %q completed with result %q\", h.orchRunID, step.Name, result)\n\tif h.store != nil {\n\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n\t\t\tr.RecordStepComplete(step.Name, result)\n\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n\t\t}\n\t}\n}\n\nfunc (h *hostStatusHandler) OnRunComplete(run *domain.Run) {\n\tlog.Printf(\"host workflow [%s]: run completed with state %s\", h.orchRunID, run.State)\n}\n","numLines":147,"startLine":1,"totalLines":147}}}
