{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011pABXyZRFEr4KxPUU7C5zp","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"net/url\"\n    13→\t\"os\"\n    14→\t\"os/exec\"\n    15→\t\"path/filepath\"\n    16→\t\"regexp\"\n    17→\t\"sort\"\n    18→\t\"strconv\"\n    19→\t\"strings\"\n    20→\t\"time\"\n    21→\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    24→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    25→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    26→)\n    27→\n    28→// HandlerOption configures optional Handler dependencies.\n    29→type HandlerOption func(*Handler)\n    30→\n    31→// WithContainerLogger sets the container runtime for fetching live logs.\n    32→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    33→\treturn func(h *Handler) { h.container = c }\n    34→}\n    35→\n    36→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    37→func WithContainerManager(c ContainerManager) HandlerOption {\n    38→\treturn func(h *Handler) { h.container = c }\n    39→}\n    40→\n    41→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    42→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    43→\treturn func(h *Handler) { h.logBroadcast = b }\n    44→}\n    45→\n    46→// WithLogStore sets the log store for indexed log file lookups.\n    47→func WithLogStore(ls ports.LogStore) HandlerOption {\n    48→\treturn func(h *Handler) { h.logStore = ls }\n    49→}\n    50→\n    51→//go:embed templates/*.html static/*\n    52→var content embed.FS\n    53→\n    54→// Handler serves the web dashboard.\n    55→// ContainerLogger can retrieve logs from a container by ID.\n    56→type ContainerLogger interface {\n    57→\tLogs(ctx context.Context, containerID string) (string, error)\n    58→}\n    59→\n    60→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    61→type ContainerManager interface {\n    62→\tContainerLogger\n    63→\tRemove(ctx context.Context, containerID string) error\n    64→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    65→}\n    66→\n    67→type Handler struct {\n    68→\tstore        ports.RunStore\n    69→\tcaptures     ports.CaptureStore\n    70→\tlogStore     ports.LogStore\n    71→\tcontainer    ContainerLogger\n    72→\tlogBroadcast *logstream.Broadcaster\n    73→\tpages        map[string]*template.Template\n    74→\tmux          *http.ServeMux\n    75→}\n    76→\n    77→// NewHandler creates a web dashboard handler.\n    78→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    79→\tfuncMap := template.FuncMap{\n    80→\t\t\"stateColor\":       stateColor,\n    81→\t\t\"healthColor\":      healthColor,\n    82→\t\t\"formatTime\":       formatTime,\n    83→\t\t\"formatDuration\":   formatDuration,\n    84→\t\t\"truncate\":         truncate,\n    85→\t\t\"shortContainerID\": shortContainerID,\n    86→\t}\n    87→\n    88→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n    89→\tif err != nil {\n    90→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n    91→\t}\n    92→\n    93→\tpages := map[string]*template.Template{}\n    94→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n    95→\t\tclone, err := base.Clone()\n    96→\t\tif err != nil {\n    97→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n    98→\t\t}\n    99→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   100→\t\tif err != nil {\n   101→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   102→\t\t}\n   103→\t\tpages[page] = clone\n   104→\t}\n   105→\n   106→\th := &Handler{\n   107→\t\tstore:    store,\n   108→\t\tcaptures: captures,\n   109→\t\tpages:    pages,\n   110→\t\tmux:      http.NewServeMux(),\n   111→\t}\n   112→\tfor _, opt := range opts {\n   113→\t\topt(h)\n   114→\t}\n   115→\n   116→\tstaticFS, err := fs.Sub(content, \"static\")\n   117→\tif err != nil {\n   118→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   119→\t}\n   120→\n   121→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   122→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   123→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   124→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   125→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   126→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   127→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   128→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   129→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   130→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   131→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   132→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   133→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   134→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   135→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   136→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   137→\n   138→\treturn h, nil\n   139→}\n   140→\n   141→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   142→\th.mux.ServeHTTP(w, r)\n   143→}\n   144→\n   145→// --- HTML handlers ---\n   146→\n   147→// projectOverviewEntry holds data for a single project card on the landing page.\n   148→type projectOverviewEntry struct {\n   149→\tDir         string\n   150→\tLabel       string\n   151→\tHealth      domain.HealthResult\n   152→\tRecentRuns  []recentRunDot\n   153→\tActiveCount int\n   154→}\n   155→\n   156→// recentRunDot is a minimal representation of a run for the mini history display.\n   157→type recentRunDot struct {\n   158→\tID    string\n   159→\tState string\n   160→}\n   161→\n   162→const healthWindowSize = 10\n   163→\n   164→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   165→\tprojects, _ := h.store.ListProjects(r.Context())\n   166→\tlabels := projectLabels(projects)\n   167→\n   168→\tvar entries []projectOverviewEntry\n   169→\tfor _, dir := range projects {\n   170→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   171→\t\tif err != nil {\n   172→\t\t\tcontinue\n   173→\t\t}\n   174→\n   175→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   176→\t\trunValues := make([]domain.Run, len(runs))\n   177→\t\tfor i, rr := range runs {\n   178→\t\t\trunValues[i] = *rr\n   179→\t\t}\n   180→\n   181→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   182→\n   183→\t\t// Take the last N runs for the mini history (most recent first).\n   184→\t\tn := healthWindowSize\n   185→\t\tif n > len(runs) {\n   186→\t\t\tn = len(runs)\n   187→\t\t}\n   188→\t\tdots := make([]recentRunDot, n)\n   189→\t\tfor i := 0; i < n; i++ {\n   190→\t\t\tdots[i] = recentRunDot{\n   191→\t\t\t\tID:    runs[i].ID,\n   192→\t\t\t\tState: string(runs[i].State),\n   193→\t\t\t}\n   194→\t\t}\n   195→\n   196→\t\tvar activeCount int\n   197→\t\tfor _, rr := range runs {\n   198→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   199→\t\t\t\tactiveCount++\n   200→\t\t\t}\n   201→\t\t}\n   202→\n   203→\t\tentries = append(entries, projectOverviewEntry{\n   204→\t\t\tDir:         dir,\n   205→\t\t\tLabel:       labels[dir],\n   206→\t\t\tHealth:      health,\n   207→\t\t\tRecentRuns:  dots,\n   208→\t\t\tActiveCount: activeCount,\n   209→\t\t})\n   210→\t}\n   211→\n   212→\tsort.Slice(entries, func(i, j int) bool {\n   213→\t\treturn entries[i].Label < entries[j].Label\n   214→\t})\n   215→\n   216→\tdata := map[string]any{\n   217→\t\t\"Title\":    \"Projects\",\n   218→\t\t\"Projects\": entries,\n   219→\t}\n   220→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   221→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   222→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   223→\t}\n   224→}\n   225→\n   226→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   227→\tprojectFilter := r.URL.Query().Get(\"project\")\n   228→\n   229→\tvar runs []*domain.Run\n   230→\tvar err error\n   231→\tif projectFilter != \"\" {\n   232→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   233→\t} else {\n   234→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   235→\t}\n   236→\tif err != nil {\n   237→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   238→\t\treturn\n   239→\t}\n   240→\n   241→\tprojects, _ := h.store.ListProjects(r.Context())\n   242→\tlabels := projectLabels(projects)\n   243→\n   244→\t// Count retained containers per project\n   245→\tcontainerCounts := map[string]int{}\n   246→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   247→\tfor _, run := range allRuns {\n   248→\t\tif run.ContainerKept {\n   249→\t\t\tcontainerCounts[run.ProjectDir]++\n   250→\t\t}\n   251→\t}\n   252→\n   253→\tvar projectList []projectEntry\n   254→\tfor _, dir := range projects {\n   255→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   256→\t}\n   257→\tsort.Slice(projectList, func(i, j int) bool {\n   258→\t\treturn projectList[i].Label < projectList[j].Label\n   259→\t})\n   260→\n   261→\tdata := map[string]any{\n   262→\t\t\"Title\":         \"Runs\",\n   263→\t\t\"Runs\":          runs,\n   264→\t\t\"Projects\":      projectList,\n   265→\t\t\"ProjectFilter\": projectFilter,\n   266→\t\t\"ProjectLabels\": labels,\n   267→\t}\n   268→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   269→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   270→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   271→\t}\n   272→}\n   273→\n   274→// handleProjectRuns redirects /projects/{name}/runs to /runs?project=<dir>.\n   275→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   276→\tdir, _, ok := h.resolveProjectDir(w, r)\n   277→\tif !ok {\n   278→\t\treturn\n   279→\t}\n   280→\thttp.Redirect(w, r, \"/runs?project=\"+url.QueryEscape(dir), http.StatusFound)\n   281→}\n   282→\n   283→// stepEntry is a merged view of a step execution for the template.\n   284→type stepEntry struct {\n   285→\tIndex     int\n   286→\tStepName  string\n   287→\tResult    string\n   288→\tStartedAt time.Time\n   289→\tDuration  string\n   290→}\n   291→\n   292→// mergeCaptures collapses started/completed capture pairs into single entries.\n   293→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   294→\tvar entries []stepEntry\n   295→\t// Track pending started rows by step name (LIFO for retries)\n   296→\tpending := map[string]*domain.StepExecution{}\n   297→\n   298→\tfor _, c := range caps {\n   299→\t\tif c.Result == \"\" {\n   300→\t\t\t// step_started row\n   301→\t\t\tpending[c.StepName] = c\n   302→\t\t\tcontinue\n   303→\t\t}\n   304→\t\t// step_completed row — merge with pending started if available\n   305→\t\tstartedAt := c.StartedAt\n   306→\t\tif started := pending[c.StepName]; started != nil {\n   307→\t\t\tstartedAt = started.StartedAt\n   308→\t\t\tdelete(pending, c.StepName)\n   309→\t\t}\n   310→\t\tentries = append(entries, stepEntry{\n   311→\t\t\tIndex:     len(entries),\n   312→\t\t\tStepName:  c.StepName,\n   313→\t\t\tResult:    c.Result,\n   314→\t\t\tStartedAt: startedAt,\n   315→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   316→\t\t})\n   317→\t}\n   318→\n   319→\t// Append any started-but-not-completed steps (still running)\n   320→\tfor _, c := range caps {\n   321→\t\tif c.Result == \"\" {\n   322→\t\t\tif _, used := pending[c.StepName]; !used {\n   323→\t\t\t\tcontinue\n   324→\t\t\t}\n   325→\t\t\tentries = append(entries, stepEntry{\n   326→\t\t\t\tIndex:     len(entries),\n   327→\t\t\t\tStepName:  c.StepName,\n   328→\t\t\t\tStartedAt: c.StartedAt,\n   329→\t\t\t})\n   330→\t\t\tdelete(pending, c.StepName)\n   331→\t\t}\n   332→\t}\n   333→\n   334→\treturn entries\n   335→}\n   336→\n   337→// containerState inspects the container for a run and returns one of:\n   338→//   - \"running\"   – container exists and is running\n   339→//   - \"stopped\"   – container exists, not running, not kept\n   340→//   - \"available\" – container exists, not running, kept (can be deleted)\n   341→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   342→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   343→\tif run.ContainerID == \"\" {\n   344→\t\treturn \"removed\"\n   345→\t}\n   346→\tmgr, ok := h.container.(ContainerManager)\n   347→\tif !ok {\n   348→\t\treturn \"removed\"\n   349→\t}\n   350→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   351→\tif err != nil {\n   352→\t\treturn \"removed\"\n   353→\t}\n   354→\tif status.Running {\n   355→\t\treturn \"running\"\n   356→\t}\n   357→\tif run.ContainerKept {\n   358→\t\treturn \"available\"\n   359→\t}\n   360→\treturn \"stopped\"\n   361→}\n   362→\n   363→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   364→\tid := r.PathValue(\"id\")\n   365→\n   366→\trun, err := h.store.GetRun(r.Context(), id)\n   367→\tif err != nil {\n   368→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   369→\t\treturn\n   370→\t}\n   371→\n   372→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   373→\tif err != nil {\n   374→\t\tcaps = nil // non-fatal\n   375→\t}\n   376→\n   377→\tsteps := mergeCaptures(caps)\n   378→\n   379→\tdata := map[string]any{\n   380→\t\t\"Title\":          \"Run \" + run.ID,\n   381→\t\t\"Run\":            run,\n   382→\t\t\"Steps\":          steps,\n   383→\t\t\"Page\":           \"detail\",\n   384→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   385→\t}\n   386→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   387→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   388→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   389→\t}\n   390→}\n   391→\n   392→// --- JSON API handlers ---\n   393→\n   394→type apiRun struct {\n   395→\tID           string `json:\"id\"`\n   396→\tWorkflowName string `json:\"workflow_name\"`\n   397→\tProjectDir   string `json:\"project_dir\"`\n   398→\tProjectLabel string `json:\"project_label\"`\n   399→\tState        string `json:\"state\"`\n   400→\tStartedAt    string `json:\"started_at\"`\n   401→\tCompletedAt  string `json:\"completed_at\"`\n   402→\tContainerID  string `json:\"container_id\"`\n   403→\tErrorMessage string `json:\"error_message\"`\n   404→\tTitle        string `json:\"title\"`\n   405→}\n   406→\n   407→type apiStep struct {\n   408→\tStepName    string `json:\"step_name\"`\n   409→\tResult      string `json:\"result\"`\n   410→\tStartedAt   string `json:\"started_at\"`\n   411→\tCompletedAt string `json:\"completed_at\"`\n   412→\tDuration    string `json:\"duration\"`\n   413→}\n   414→\n   415→type apiRunDetail struct {\n   416→\tapiRun\n   417→\tContainerState string    `json:\"container_state\"`\n   418→\tSteps          []apiStep `json:\"steps\"`\n   419→}\n   420→\n   421→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   422→\treturn apiRun{\n   423→\t\tID:           r.ID,\n   424→\t\tWorkflowName: r.WorkflowName,\n   425→\t\tProjectDir:   r.ProjectDir,\n   426→\t\tProjectLabel: labels[r.ProjectDir],\n   427→\t\tState:        string(r.State),\n   428→\t\tStartedAt:    formatTime(r.StartedAt),\n   429→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   430→\t\tContainerID:  r.ContainerID,\n   431→\t\tErrorMessage: r.ErrorMessage,\n   432→\t\tTitle:        r.Title,\n   433→\t}\n   434→}\n   435→\n   436→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   437→\tprojectFilter := r.URL.Query().Get(\"project\")\n   438→\n   439→\tvar runs []*domain.Run\n   440→\tvar err error\n   441→\tif projectFilter != \"\" {\n   442→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   443→\t} else {\n   444→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   445→\t}\n   446→\tif err != nil {\n   447→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   448→\t\treturn\n   449→\t}\n   450→\n   451→\tprojects, _ := h.store.ListProjects(r.Context())\n   452→\tlabels := projectLabels(projects)\n   453→\n   454→\tresult := make([]apiRun, len(runs))\n   455→\tfor i, run := range runs {\n   456→\t\tresult[i] = toAPIRun(run, labels)\n   457→\t}\n   458→\n   459→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   460→\tjson.NewEncoder(w).Encode(result)\n   461→}\n   462→\n   463→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   464→\tprojects, err := h.store.ListProjects(r.Context())\n   465→\tif err != nil {\n   466→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   467→\t\treturn\n   468→\t}\n   469→\tlabels := projectLabels(projects)\n   470→\n   471→\ttype apiHealth struct {\n   472→\t\tStatus string `json:\"status\"`\n   473→\t\tPassed int    `json:\"passed\"`\n   474→\t\tFailed int    `json:\"failed\"`\n   475→\t\tTotal  int    `json:\"total\"`\n   476→\t}\n   477→\ttype apiProject struct {\n   478→\t\tDir         string    `json:\"dir\"`\n   479→\t\tLabel       string    `json:\"label\"`\n   480→\t\tHealth      apiHealth `json:\"health\"`\n   481→\t\tActiveCount int       `json:\"active_count\"`\n   482→\t}\n   483→\tresult := make([]apiProject, len(projects))\n   484→\tfor i, dir := range projects {\n   485→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   486→\t\trunValues := make([]domain.Run, len(runs))\n   487→\t\tfor j, rr := range runs {\n   488→\t\t\trunValues[j] = *rr\n   489→\t\t}\n   490→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   491→\t\tvar activeCount int\n   492→\t\tfor _, rr := range runs {\n   493→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   494→\t\t\t\tactiveCount++\n   495→\t\t\t}\n   496→\t\t}\n   497→\t\tresult[i] = apiProject{\n   498→\t\t\tDir:   dir,\n   499→\t\t\tLabel: labels[dir],\n   500→\t\t\tHealth: apiHealth{\n   501→\t\t\t\tStatus: string(health.Status),\n   502→\t\t\t\tPassed: health.Passed,\n   503→\t\t\t\tFailed: health.Failed,\n   504→\t\t\t\tTotal:  health.Total,\n   505→\t\t\t},\n   506→\t\t\tActiveCount: activeCount,\n   507→\t\t}\n   508→\t}\n   509→\n   510→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   511→\tjson.NewEncoder(w).Encode(result)\n   512→}\n   513→\n   514→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   515→\tid := r.PathValue(\"id\")\n   516→\n   517→\trun, err := h.store.GetRun(r.Context(), id)\n   518→\tif err != nil {\n   519→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   520→\t\treturn\n   521→\t}\n   522→\n   523→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   524→\tif err != nil {\n   525→\t\tcaps = nil\n   526→\t}\n   527→\n   528→\tprojects, _ := h.store.ListProjects(r.Context())\n   529→\tlabels := projectLabels(projects)\n   530→\n   531→\tmerged := mergeCaptures(caps)\n   532→\tsteps := make([]apiStep, len(merged))\n   533→\tfor i, e := range merged {\n   534→\t\tsteps[i] = apiStep{\n   535→\t\t\tStepName:  e.StepName,\n   536→\t\t\tResult:    e.Result,\n   537→\t\t\tStartedAt: formatTime(e.StartedAt),\n   538→\t\t\tDuration:  e.Duration,\n   539→\t\t}\n   540→\t}\n   541→\n   542→\tdetail := apiRunDetail{\n   543→\t\tapiRun:         toAPIRun(run, labels),\n   544→\t\tContainerState: h.containerState(r.Context(), run),\n   545→\t\tSteps:          steps,\n   546→\t}\n   547→\n   548→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   549→\tjson.NewEncoder(w).Encode(detail)\n   550→}\n   551→\n   552→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   553→\tid := r.PathValue(\"id\")\n   554→\tstep := r.PathValue(\"step\")\n   555→\tlogType := r.URL.Query().Get(\"type\")   // optional: \"script\", \"llm\"\n   556→\tformat := r.URL.Query().Get(\"format\")  // optional: \"raw\" to skip parsing\n   557→\n   558→\trun, err := h.store.GetRun(r.Context(), id)\n   559→\tif err != nil {\n   560→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   561→\t\treturn\n   562→\t}\n   563→\n   564→\twriteOutput := func(data []byte) {\n   565→\t\tif format != \"raw\" {\n   566→\t\t\tdata = logstream.ParseClaudeStream(data)\n   567→\t\t}\n   568→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   569→\t\tw.Write(data)\n   570→\t}\n   571→\n   572→\t// Try log index first for fast lookup\n   573→\tif h.logStore != nil {\n   574→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   575→\t\tif err == nil && len(logFiles) > 0 {\n   576→\t\t\t// If type filter specified, narrow results\n   577→\t\t\tfor _, lf := range logFiles {\n   578→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   579→\t\t\t\t\tcontinue\n   580→\t\t\t\t}\n   581→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   582→\t\t\t\tif readErr == nil && len(data) > 0 {\n   583→\t\t\t\t\twriteOutput(data)\n   584→\t\t\t\t\treturn\n   585→\t\t\t\t}\n   586→\t\t\t}\n   587→\t\t}\n   588→\t}\n   589→\n   590→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   591→\n   592→\t// Fall back to file path conventions\n   593→\t// If type is \"llm\", try llm-<step>.log\n   594→\tif logType == \"llm\" {\n   595→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   596→\t\tdata, err := os.ReadFile(llmPath)\n   597→\t\tif err == nil && len(data) > 0 {\n   598→\t\t\twriteOutput(data)\n   599→\t\t\treturn\n   600→\t\t}\n   601→\t}\n   602→\n   603→\t// Try per-step output first, fall back to container.log, then live docker logs\n   604→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   605→\tdata, err := os.ReadFile(outputPath)\n   606→\tif err == nil && len(data) > 0 {\n   607→\t\twriteOutput(data)\n   608→\t\treturn\n   609→\t}\n   610→\n   611→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   612→\tdata, err = os.ReadFile(containerLog)\n   613→\tif err == nil && len(data) > 0 {\n   614→\t\twriteOutput(data)\n   615→\t\treturn\n   616→\t}\n   617→\n   618→\t// Last resort: try live docker logs from still-existing container\n   619→\tif h.container != nil && run.ContainerID != \"\" {\n   620→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   621→\t\t\twriteOutput([]byte(logs))\n   622→\t\t\treturn\n   623→\t\t}\n   624→\t}\n   625→\n   626→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   627→}\n   628→\n   629→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   630→\tid := r.PathValue(\"id\")\n   631→\n   632→\trun, err := h.store.GetRun(r.Context(), id)\n   633→\tif err != nil {\n   634→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   635→\t\tw.WriteHeader(http.StatusNotFound)\n   636→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   637→\t\treturn\n   638→\t}\n   639→\n   640→\tmgr, ok := h.container.(ContainerManager)\n   641→\tif !ok || run.ContainerID == \"\" {\n   642→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   643→\t\tw.WriteHeader(http.StatusBadRequest)\n   644→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   645→\t\treturn\n   646→\t}\n   647→\n   648→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   649→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   650→\t\tw.WriteHeader(http.StatusInternalServerError)\n   651→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   652→\t\treturn\n   653→\t}\n   654→\n   655→\trun.ContainerKept = false\n   656→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   657→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   658→\t\tw.WriteHeader(http.StatusInternalServerError)\n   659→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   660→\t\treturn\n   661→\t}\n   662→\n   663→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   664→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   665→}\n   666→\n   667→// handleAPIStream serves an SSE stream of log lines for a run.\n   668→// For active runs, it subscribes to the live broadcaster.\n   669→// For completed runs, it serves the archived full.log then closes.\n   670→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   671→\tid := r.PathValue(\"id\")\n   672→\n   673→\trun, err := h.store.GetRun(r.Context(), id)\n   674→\tif err != nil {\n   675→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   676→\t\treturn\n   677→\t}\n   678→\n   679→\tflusher, ok := w.(http.Flusher)\n   680→\tif !ok {\n   681→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   682→\t\treturn\n   683→\t}\n   684→\n   685→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   686→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   687→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   688→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   689→\n   690→\tisComplete := run.State == domain.RunStateSucceeded ||\n   691→\t\trun.State == domain.RunStateFailed ||\n   692→\t\trun.State == domain.RunStateCancelled\n   693→\n   694→\tif isComplete {\n   695→\t\t// Serve archived full.log\n   696→\t\th.streamFullLog(w, flusher, run)\n   697→\t\t// Send done event\n   698→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   699→\t\tflusher.Flush()\n   700→\t\treturn\n   701→\t}\n   702→\n   703→\t// Active run: subscribe to live broadcaster\n   704→\tif h.logBroadcast == nil {\n   705→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   706→\t\treturn\n   707→\t}\n   708→\n   709→\tsub := h.logBroadcast.Subscribe(id)\n   710→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   711→\n   712→\tctx := r.Context()\n   713→\tfor {\n   714→\t\tselect {\n   715→\t\tcase <-ctx.Done():\n   716→\t\t\treturn\n   717→\t\tcase line, ok := <-sub.C:\n   718→\t\t\tif !ok {\n   719→\t\t\t\t// Stream finished (run completed)\n   720→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   721→\t\t\t\tflusher.Flush()\n   722→\t\t\t\treturn\n   723→\t\t\t}\n   724→\t\t\tline = parseLLMLogLine(line)\n   725→\t\t\tif line.Type == \"\" {\n   726→\t\t\t\tcontinue // skip protocol-only llm lines\n   727→\t\t\t}\n   728→\t\t\tdata, _ := json.Marshal(line)\n   729→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   730→\t\t\tflusher.Flush()\n   731→\t\t}\n   732→\t}\n   733→}\n   734→\n   735→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   736→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   737→\n   738→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   739→// LLM-type lines are parsed from raw Claude JSON into human-readable text.\n   740→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   741→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   742→\tf, err := os.Open(logPath)\n   743→\tif err != nil {\n   744→\t\treturn\n   745→\t}\n   746→\tdefer f.Close()\n   747→\n   748→\tscanner := bufio.NewScanner(f)\n   749→\tfor scanner.Scan() {\n   750→\t\ttext := scanner.Text()\n   751→\t\tline := parseFullLogLine(text)\n   752→\t\tline = parseLLMLogLine(line)\n   753→\t\tif line.Type == \"\" {\n   754→\t\t\tcontinue // skip protocol-only llm lines\n   755→\t\t}\n   756→\t\tdata, _ := json.Marshal(line)\n   757→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   758→\t\tflusher.Flush()\n   759→\t}\n   760→}\n   761→\n   762→// parseLLMLogLine parses a LogLine whose type is \"llm\". If the content is\n   763→// Claude stream JSON, it extracts the human-readable text. Protocol-only\n   764→// events return a LogLine with an empty Type (caller should skip it).\n   765→// Non-llm lines are returned unchanged.\n   766→func parseLLMLogLine(line logstream.LogLine) logstream.LogLine {\n   767→\tif line.Type != \"llm\" {\n   768→\t\treturn line\n   769→\t}\n   770→\ttext, ok := logstream.ParseClaudeLine([]byte(line.Content))\n   771→\tif !ok {\n   772→\t\treturn logstream.LogLine{} // signal to skip\n   773→\t}\n   774→\tline.Content = text\n   775→\treturn line\n   776→}\n   777→\n   778→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   779→func parseFullLogLine(text string) logstream.LogLine {\n   780→\tm := logLineRegex.FindStringSubmatch(text)\n   781→\tif m == nil {\n   782→\t\treturn logstream.LogLine{\n   783→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   784→\t\t\tType:      \"script\",\n   785→\t\t\tContent:   text,\n   786→\t\t}\n   787→\t}\n   788→\treturn logstream.LogLine{\n   789→\t\tTimestamp: m[1],\n   790→\t\tType:      m[2],\n   791→\t\tContent:   m[3],\n   792→\t}\n   793→}\n   794→\n   795→// --- Project detail handlers ---\n   796→\n   797→// resolveProjectDir resolves a project label from the URL to its directory path.\n   798→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   799→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   800→\tlabel := r.PathValue(\"name\")\n   801→\tprojects, _ := h.store.ListProjects(r.Context())\n   802→\tlabels := projectLabels(projects)\n   803→\tfor dir, l := range labels {\n   804→\t\tif l == label {\n   805→\t\t\treturn dir, label, true\n   806→\t\t}\n   807→\t}\n   808→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   809→\tw.WriteHeader(http.StatusNotFound)\n   810→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   811→\treturn \"\", \"\", false\n   812→}\n   813→\n   814→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   815→\tdir, label, ok := h.resolveProjectDir(w, r)\n   816→\tif !ok {\n   817→\t\treturn\n   818→\t}\n   819→\n   820→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   821→\tn := 10\n   822→\tif n > len(runs) {\n   823→\t\tn = len(runs)\n   824→\t}\n   825→\tdots := make([]recentRunDot, n)\n   826→\tfor i := 0; i < n; i++ {\n   827→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   828→\t}\n   829→\n   830→\tdata := map[string]any{\n   831→\t\t\"Title\":      label,\n   832→\t\t\"Label\":      label,\n   833→\t\t\"Dir\":        dir,\n   834→\t\t\"RecentRuns\": dots,\n   835→\t}\n   836→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   837→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   838→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   839→\t}\n   840→}\n   841→\n   842→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   843→\tdir, _, ok := h.resolveProjectDir(w, r)\n   844→\tif !ok {\n   845→\t\treturn\n   846→\t}\n   847→\n   848→\t// Docker image: read FROM line from Dockerfile\n   849→\tdockerImage := \"\"\n   850→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   851→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   852→\t\t// Find the last FROM line (final stage)\n   853→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   854→\t\t\ttrimmed := strings.TrimSpace(line)\n   855→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   856→\t\t\t\tparts := strings.Fields(trimmed)\n   857→\t\t\t\tif len(parts) >= 2 {\n   858→\t\t\t\t\tdockerImage = parts[1]\n   859→\t\t\t\t}\n   860→\t\t\t}\n   861→\t\t}\n   862→\t}\n   863→\n   864→\t// Version\n   865→\tversion := 0\n   866→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   867→\tif data, err := os.ReadFile(versionPath); err == nil {\n   868→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   869→\t\t\tversion = v\n   870→\t\t}\n   871→\t}\n   872→\n   873→\t// Prompt files history\n   874→\ttype commitEntry struct {\n   875→\t\tSHA     string `json:\"sha\"`\n   876→\t\tDate    string `json:\"date\"`\n   877→\t\tMessage string `json:\"message\"`\n   878→\t}\n   879→\ttype promptFile struct {\n   880→\t\tPath    string        `json:\"path\"`\n   881→\t\tHistory []commitEntry `json:\"history\"`\n   882→\t}\n   883→\n   884→\tvar promptFiles []promptFile\n   885→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   886→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n   887→\t\tfor _, e := range entries {\n   888→\t\t\tif e.IsDir() {\n   889→\t\t\t\tcontinue\n   890→\t\t\t}\n   891→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n   892→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n   893→\t\t\tcmd.Dir = dir\n   894→\t\t\tout, err := cmd.Output()\n   895→\t\t\tif err != nil {\n   896→\t\t\t\tcontinue\n   897→\t\t\t}\n   898→\t\t\tvar history []commitEntry\n   899→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n   900→\t\t\t\tif line == \"\" {\n   901→\t\t\t\t\tcontinue\n   902→\t\t\t\t}\n   903→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n   904→\t\t\t\tif len(parts) < 3 {\n   905→\t\t\t\t\tcontinue\n   906→\t\t\t\t}\n   907→\t\t\t\t// Parse date to short form\n   908→\t\t\t\tdateStr := parts[1]\n   909→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n   910→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n   911→\t\t\t\t}\n   912→\t\t\t\thistory = append(history, commitEntry{\n   913→\t\t\t\t\tSHA:     parts[0][:7],\n   914→\t\t\t\t\tDate:    dateStr,\n   915→\t\t\t\t\tMessage: parts[2],\n   916→\t\t\t\t})\n   917→\t\t\t}\n   918→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n   919→\t\t}\n   920→\t}\n   921→\n   922→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   923→\tjson.NewEncoder(w).Encode(map[string]any{\n   924→\t\t\"docker_image\": dockerImage,\n   925→\t\t\"version\":      version,\n   926→\t\t\"prompt_files\": promptFiles,\n   927→\t})\n   928→}\n   929→\n   930→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n   931→\tdir, _, ok := h.resolveProjectDir(w, r)\n   932→\tif !ok {\n   933→\t\treturn\n   934→\t}\n   935→\tfile := r.URL.Query().Get(\"file\")\n   936→\tsha := r.URL.Query().Get(\"sha\")\n   937→\tif file == \"\" || sha == \"\" {\n   938→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n   939→\t\treturn\n   940→\t}\n   941→\n   942→\t// Validate sha is alphanumeric to prevent injection\n   943→\tfor _, c := range sha {\n   944→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n   945→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n   946→\t\t\treturn\n   947→\t\t}\n   948→\t}\n   949→\n   950→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n   951→\tcmd.Dir = dir\n   952→\tout, err := cmd.Output()\n   953→\tif err != nil {\n   954→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n   955→\t\treturn\n   956→\t}\n   957→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   958→\tw.Write(out)\n   959→}\n   960→\n   961→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n   962→\tdir, _, ok := h.resolveProjectDir(w, r)\n   963→\tif !ok {\n   964→\t\treturn\n   965→\t}\n   966→\n   967→\tclocheDir := filepath.Join(dir, \".cloche\")\n   968→\tentries, err := os.ReadDir(clocheDir)\n   969→\tif err != nil {\n   970→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   971→\t\tjson.NewEncoder(w).Encode([]any{})\n   972→\t\treturn\n   973→\t}\n   974→\n   975→\ttype apiWire struct {\n   976→\t\tFrom   string `json:\"from\"`\n   977→\t\tResult string `json:\"result\"`\n   978→\t\tTo     string `json:\"to\"`\n   979→\t}\n   980→\ttype apiStepDef struct {\n   981→\t\tName    string            `json:\"name\"`\n   982→\t\tType    string            `json:\"type\"`\n   983→\t\tResults []string          `json:\"results\"`\n   984→\t\tConfig  map[string]string `json:\"config\"`\n   985→\t}\n   986→\ttype apiWorkflow struct {\n   987→\t\tName      string       `json:\"name\"`\n   988→\t\tFile      string       `json:\"file\"`\n   989→\t\tSteps     []apiStepDef `json:\"steps\"`\n   990→\t\tWires     []apiWire    `json:\"wires\"`\n   991→\t\tEntryStep string       `json:\"entry_step\"`\n   992→\t}\n   993→\n   994→\tvar workflows []apiWorkflow\n   995→\tfor _, e := range entries {\n   996→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n   997→\t\t\tcontinue\n   998→\t\t}\n   999→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1000→\t\tif err != nil {\n  1001→\t\t\tcontinue\n  1002→\t\t}\n  1003→\t\twf, err := dsl.ParseForContainer(string(data))\n  1004→\t\tif err != nil {\n  1005→\t\t\tcontinue\n  1006→\t\t}\n  1007→\t\tvar steps []apiStepDef\n  1008→\t\tfor _, s := range wf.Steps {\n  1009→\t\t\tsteps = append(steps, apiStepDef{\n  1010→\t\t\t\tName:    s.Name,\n  1011→\t\t\t\tType:    string(s.Type),\n  1012→\t\t\t\tResults: s.Results,\n  1013→\t\t\t\tConfig:  s.Config,\n  1014→\t\t\t})\n  1015→\t\t}\n  1016→\t\t// Sort steps by name for consistent ordering\n  1017→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1018→\n  1019→\t\tvar wires []apiWire\n  1020→\t\tfor _, wire := range wf.Wiring {\n  1021→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1022→\t\t}\n  1023→\n  1024→\t\tworkflows = append(workflows, apiWorkflow{\n  1025→\t\t\tName:      wf.Name,\n  1026→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1027→\t\t\tSteps:     steps,\n  1028→\t\t\tWires:     wires,\n  1029→\t\t\tEntryStep: wf.EntryStep,\n  1030→\t\t})\n  1031→\t}\n  1032→\n  1033→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1034→\tjson.NewEncoder(w).Encode(workflows)\n  1035→}\n  1036→\n  1037→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1038→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1039→\tif !ok {\n  1040→\t\treturn\n  1041→\t}\n  1042→\tworkflowName := r.PathValue(\"workflow\")\n  1043→\tstepName := r.PathValue(\"step\")\n  1044→\n  1045→\t// Find the workflow file\n  1046→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1047→\tvar wf *domain.Workflow\n  1048→\tentries, _ := os.ReadDir(clocheDir)\n  1049→\tfor _, e := range entries {\n  1050→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1051→\t\t\tcontinue\n  1052→\t\t}\n  1053→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1054→\t\tif err != nil {\n  1055→\t\t\tcontinue\n  1056→\t\t}\n  1057→\t\tparsed, err := dsl.ParseForContainer(string(data))\n  1058→\t\tif err != nil {\n  1059→\t\t\tcontinue\n  1060→\t\t}\n  1061→\t\tif parsed.Name == workflowName {\n  1062→\t\t\twf = parsed\n  1063→\t\t\tbreak\n  1064→\t\t}\n  1065→\t}\n  1066→\tif wf == nil {\n  1067→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1068→\t\treturn\n  1069→\t}\n  1070→\n  1071→\tstep, ok := wf.Steps[stepName]\n  1072→\tif !ok {\n  1073→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1074→\t\treturn\n  1075→\t}\n  1076→\n  1077→\t// Try to read the referenced file from step config\n  1078→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1079→\n  1080→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1081→\t\tcontent, err := resolveFileRef(prompt, dir)\n  1082→\t\tif err == nil {\n  1083→\t\t\tw.Write([]byte(content))\n  1084→\t\t\treturn\n  1085→\t\t}\n  1086→\t}\n  1087→\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n  1088→\t\tcontent, _ := resolveFileRef(cmd, dir)\n  1089→\t\tw.Write([]byte(content))\n  1090→\t\treturn\n  1091→\t}\n  1092→\tif script := step.Config[\"script\"]; script != \"\" {\n  1093→\t\tcontent, _ := resolveFileRef(script, dir)\n  1094→\t\tw.Write([]byte(content))\n  1095→\t\treturn\n  1096→\t}\n  1097→\n  1098→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1099→}\n  1100→\n  1101→// --- Template helpers ---\n  1102→\n  1103→// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n  1104→// If the value uses file() syntax, the referenced file is read from disk.\n  1105→// Otherwise the value is returned as-is.\n  1106→func resolveFileRef(value, baseDir string) (string, error) {\n  1107→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n  1108→\t\tpath := value[6 : len(value)-2]\n  1109→\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n  1110→\t\tif err != nil {\n  1111→\t\t\treturn \"\", err\n  1112→\t\t}\n  1113→\t\treturn string(data), nil\n  1114→\t}\n  1115→\treturn value, nil\n  1116→}\n  1117→\n  1118→func stateColor(state domain.RunState) string {\n  1119→\tswitch state {\n  1120→\tcase domain.RunStatePending:\n  1121→\t\treturn \"pending\"\n  1122→\tcase domain.RunStateRunning:\n  1123→\t\treturn \"running\"\n  1124→\tcase domain.RunStateSucceeded:\n  1125→\t\treturn \"succeeded\"\n  1126→\tcase domain.RunStateFailed:\n  1127→\t\treturn \"failed\"\n  1128→\tcase domain.RunStateCancelled:\n  1129→\t\treturn \"cancelled\"\n  1130→\tdefault:\n  1131→\t\treturn \"pending\"\n  1132→\t}\n  1133→}\n  1134→\n  1135→func healthColor(status domain.HealthStatus) string {\n  1136→\tswitch status {\n  1137→\tcase domain.HealthGreen:\n  1138→\t\treturn \"green\"\n  1139→\tcase domain.HealthYellow:\n  1140→\t\treturn \"yellow\"\n  1141→\tcase domain.HealthRed:\n  1142→\t\treturn \"red\"\n  1143→\tcase domain.HealthBlue:\n  1144→\t\treturn \"blue\"\n  1145→\tdefault:\n  1146→\t\treturn \"grey\"\n  1147→\t}\n  1148→}\n  1149→\n  1150→func formatTime(t time.Time) string {\n  1151→\tif t.IsZero() {\n  1152→\t\treturn \"\"\n  1153→\t}\n  1154→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1155→}\n  1156→\n  1157→func formatDuration(start, end time.Time) string {\n  1158→\tif start.IsZero() || end.IsZero() {\n  1159→\t\treturn \"\"\n  1160→\t}\n  1161→\td := end.Sub(start)\n  1162→\tif d < time.Second {\n  1163→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1164→\t}\n  1165→\tif d < time.Minute {\n  1166→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1167→\t}\n  1168→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1169→}\n  1170→\n  1171→func truncate(s string, n int) string {\n  1172→\tif len(s) <= n {\n  1173→\t\treturn s\n  1174→\t}\n  1175→\treturn s[:n] + \"...\"\n  1176→}\n  1177→\n  1178→func shortContainerID(id string) string {\n  1179→\tif len(id) > 12 {\n  1180→\t\treturn id[:12]\n  1181→\t}\n  1182→\treturn id\n  1183→}\n  1184→\n  1185→// projectLabels builds a mapping from full project directory paths to short\n  1186→// display labels. Each label is the final directory component (e.g.\n  1187→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1188→// the same final name, the parent directory is prepended to disambiguate\n  1189→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1190→func projectLabels(dirs []string) map[string]string {\n  1191→\tlabels := make(map[string]string, len(dirs))\n  1192→\t// Group dirs by their base name to detect conflicts.\n  1193→\tbyBase := map[string][]string{}\n  1194→\tfor _, d := range dirs {\n  1195→\t\tbase := filepath.Base(d)\n  1196→\t\tbyBase[base] = append(byBase[base], d)\n  1197→\t}\n  1198→\tfor base, paths := range byBase {\n  1199→\t\tif len(paths) == 1 {\n  1200→\t\t\tlabels[paths[0]] = base\n  1201→\t\t} else {\n  1202→\t\t\tfor _, p := range paths {\n  1203→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1204→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1205→\t\t\t}\n  1206→\t\t}\n  1207→\t}\n  1208→\treturn labels\n  1209→}\n  1210→\n  1211→type projectEntry struct {\n  1212→\tDir            string\n  1213→\tLabel          string\n  1214→\tContainerCount int\n  1215→}\n  1216→"}]},"parent_tool_use_id":null,"session_id":"bdac9138-b825-4d68-8fcd-895e48604ce0","uuid":"43876c60-badf-49b2-8576-16991eb3ba58","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"net/url\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogStore     ports.LogStore\n\tcontainer    ContainerLogger\n\tlogBroadcast *logstream.Broadcaster\n\tpages        map[string]*template.Template\n\tmux          *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// handleProjectRuns redirects /projects/{name}/runs to /runs?project=<dir>.\nfunc (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\thttp.Redirect(w, r, \"/runs?project=\"+url.QueryEscape(dir), http.StatusFound)\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n\tTitle        string `json:\"title\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t\tTitle:        r.Title,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\")   // optional: \"script\", \"llm\"\n\tformat := r.URL.Query().Get(\"format\")  // optional: \"raw\" to skip parsing\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\twriteOutput := func(data []byte) {\n\t\tif format != \"raw\" {\n\t\t\tdata = logstream.ParseClaudeStream(data)\n\t\t}\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\twriteOutput(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\twriteOutput(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\twriteOutput(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\twriteOutput(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\twriteOutput([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tline = parseLLMLogLine(line)\n\t\t\tif line.Type == \"\" {\n\t\t\t\tcontinue // skip protocol-only llm lines\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n// LLM-type lines are parsed from raw Claude JSON into human-readable text.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tline = parseLLMLogLine(line)\n\t\tif line.Type == \"\" {\n\t\t\tcontinue // skip protocol-only llm lines\n\t\t}\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseLLMLogLine parses a LogLine whose type is \"llm\". If the content is\n// Claude stream JSON, it extracts the human-readable text. Protocol-only\n// events return a LogLine with an empty Type (caller should skip it).\n// Non-llm lines are returned unchanged.\nfunc parseLLMLogLine(line logstream.LogLine) logstream.LogLine {\n\tif line.Type != \"llm\" {\n\t\treturn line\n\t}\n\ttext, ok := logstream.ParseClaudeLine([]byte(line.Content))\n\tif !ok {\n\t\treturn logstream.LogLine{} // signal to skip\n\t}\n\tline.Content = text\n\treturn line\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.ParseForContainer(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.ParseForContainer(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tcontent, err := resolveFileRef(prompt, dir)\n\t\tif err == nil {\n\t\t\tw.Write([]byte(content))\n\t\t\treturn\n\t\t}\n\t}\n\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n\t\tcontent, _ := resolveFileRef(cmd, dir)\n\t\tw.Write([]byte(content))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tcontent, _ := resolveFileRef(script, dir)\n\t\tw.Write([]byte(content))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\n// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n// If the value uses file() syntax, the referenced file is read from disk.\n// Otherwise the value is returned as-is.\nfunc resolveFileRef(value, baseDir string) (string, error) {\n\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n\t\tpath := value[6 : len(value)-2]\n\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n\t\tif err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\treturn string(data), nil\n\t}\n\treturn value, nil\n}\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1216,"startLine":1,"totalLines":1216}}}
