{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011vfHx6qdacqtFw74s8MfDm","type":"tool_result","content":"     1→syntax = \"proto3\";\n     2→\n     3→package cloche.v1;\n     4→\n     5→option go_package = \"github.com/cloche-dev/cloche/api/clochepb\";\n     6→\n     7→service ClocheService {\n     8→  rpc RunWorkflow(RunWorkflowRequest) returns (RunWorkflowResponse);\n     9→  rpc GetStatus(GetStatusRequest) returns (GetStatusResponse);\n    10→  rpc StreamLogs(StreamLogsRequest) returns (stream LogEntry);\n    11→  rpc StopRun(StopRunRequest) returns (StopRunResponse);\n    12→  rpc ListRuns(ListRunsRequest) returns (ListRunsResponse);\n    13→  rpc Shutdown(ShutdownRequest) returns (ShutdownResponse);\n    14→  rpc DeleteContainer(DeleteContainerRequest) returns (DeleteContainerResponse);\n    15→}\n    16→\n    17→message RunWorkflowRequest {\n    18→  string workflow_name = 1;\n    19→  string project_dir = 2;\n    20→  string image = 3;\n    21→  string prompt = 4;\n    22→  bool keep_container = 5;\n    23→  string title = 6;\n    24→}\n    25→\n    26→message RunWorkflowResponse {\n    27→  string run_id = 1;\n    28→}\n    29→\n    30→message GetStatusRequest {\n    31→  string run_id = 1;\n    32→}\n    33→\n    34→message GetStatusResponse {\n    35→  string run_id = 1;\n    36→  string workflow_name = 2;\n    37→  string state = 3;\n    38→  string current_step = 4;\n    39→  repeated StepExecutionStatus step_executions = 5;\n    40→  string error_message = 6;\n    41→  string container_id = 7;\n    42→  bool container_alive = 8;\n    43→  string container_dead_since = 9;\n    44→  string title = 10;\n    45→}\n    46→\n    47→message StepExecutionStatus {\n    48→  string step_name = 1;\n    49→  string result = 2;\n    50→  string started_at = 3;\n    51→  string completed_at = 4;\n    52→}\n    53→\n    54→message StreamLogsRequest {\n    55→  string run_id = 1;\n    56→  string step_name = 2;\n    57→  string log_type = 3;\n    58→}\n    59→\n    60→message LogEntry {\n    61→  string type = 1;\n    62→  string step_name = 2;\n    63→  string result = 3;\n    64→  string message = 4;\n    65→  string timestamp = 5;\n    66→}\n    67→\n    68→message StopRunRequest {\n    69→  string run_id = 1;\n    70→}\n    71→\n    72→message StopRunResponse {}\n    73→\n    74→message ShutdownRequest {}\n    75→\n    76→message ShutdownResponse {}\n    77→\n    78→message DeleteContainerRequest {\n    79→  string id = 1;\n    80→}\n    81→\n    82→message DeleteContainerResponse {}\n    83→\n    84→message ListRunsRequest {\n    85→  bool all = 1;\n    86→}\n    87→\n    88→message ListRunsResponse {\n    89→  repeated RunSummary runs = 1;\n    90→}\n    91→\n    92→message RunSummary {\n    93→  string run_id = 1;\n    94→  string workflow_name = 2;\n    95→  string state = 3;\n    96→  string started_at = 4;\n    97→  string error_message = 5;\n    98→  string container_id = 6;\n    99→  string title = 7;\n   100→}\n   101→"}]},"parent_tool_use_id":"toolu_01AzarRAMPGBPEX9A84eRtqF","session_id":"bdac9138-b825-4d68-8fcd-895e48604ce0","uuid":"80743568-9747-4830-a5f3-f313da287195"}
