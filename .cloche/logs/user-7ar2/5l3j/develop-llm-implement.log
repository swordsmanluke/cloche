{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AZE2fTkX9MCXmoJmJzykrQ","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    19→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    20→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    21→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    22→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    23→\trpcgrpc \"google.golang.org/grpc\"\n    24→)\n    25→\n    26→type ClocheServer struct {\n    27→\tpb.UnimplementedClocheServiceServer\n    28→\tstore        ports.RunStore\n    29→\tcaptures     ports.CaptureStore\n    30→\tlogStore     ports.LogStore\n    31→\tcontainer    ports.ContainerRuntime\n    32→\tdefaultImage string\n    33→\tevolution    *evolution.Trigger\n    34→\tlogBroadcast *logstream.Broadcaster\n    35→\tshutdownFn   func()\n    36→\tmu           sync.Mutex\n    37→\trunIDs       map[string]string // run_id -> container_id\n    38→}\n    39→\n    40→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    41→\treturn &ClocheServer{\n    42→\t\tstore:     store,\n    43→\t\tcontainer: container,\n    44→\t\trunIDs:    make(map[string]string),\n    45→\t}\n    46→}\n    47→\n    48→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    49→\treturn &ClocheServer{\n    50→\t\tstore:        store,\n    51→\t\tcaptures:     captures,\n    52→\t\tcontainer:    container,\n    53→\t\tdefaultImage: defaultImage,\n    54→\t\trunIDs:       make(map[string]string),\n    55→\t}\n    56→}\n    57→\n    58→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    59→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    60→\ts.logStore = ls\n    61→}\n    62→\n    63→\n    64→// SetEvolution attaches an evolution trigger to the server.\n    65→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    66→\ts.evolution = trigger\n    67→}\n    68→\n    69→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    70→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    71→\ts.logBroadcast = b\n    72→}\n    73→\n    74→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    75→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    76→\ts.shutdownFn = fn\n    77→}\n    78→\n    79→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    80→\tif s.container == nil {\n    81→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    82→\t}\n    83→\n    84→\t// Generate a unique run ID, retrying on collision\n    85→\tvar runID string\n    86→\tfor attempts := 0; attempts < 10; attempts++ {\n    87→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    88→\t\texisting, err := s.store.GetRun(ctx, runID)\n    89→\t\tif err != nil {\n    90→\t\t\tbreak // ID is free\n    91→\t\t}\n    92→\t\t// Reuse if completed more than 1 hour ago\n    93→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n    94→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n    95→\t\t\tbreak\n    96→\t\t}\n    97→\t}\n    98→\n    99→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   100→\tif req.Prompt != \"\" {\n   101→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   102→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   103→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   104→\t\t}\n   105→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   106→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   107→\t\t}\n   108→\t}\n   109→\trun := domain.NewRun(runID, req.WorkflowName)\n   110→\trun.ProjectDir = req.ProjectDir\n   111→\trun.Title = req.Title\n   112→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   113→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   114→\t}\n   115→\n   116→\t// Resolve image: request-level override, then server default\n   117→\timage := req.Image\n   118→\tif image == \"\" {\n   119→\t\timage = s.defaultImage\n   120→\t}\n   121→\n   122→\t// Launch container start + tracking in background so the RPC returns immediately.\n   123→\t// The run stays in \"pending\" state until the container is up.\n   124→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   125→\n   126→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   127→}\n   128→\n   129→// launchAndTrack starts the container and then tracks it to completion.\n   130→// It runs in a background goroutine with its own context, independent of the\n   131→// RPC context which may be cancelled after RunWorkflow returns.\n   132→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   133→\tctx := context.Background()\n   134→\n   135→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   136→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   137→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   138→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   139→\t\t\tif run != nil {\n   140→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   141→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   142→\t\t\t}\n   143→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   144→\t\t\t\treturn\n   145→\t\t}\n   146→\t}\n   147→\n   148→\tbaseSHA := gitHEAD(req.ProjectDir)\n   149→\n   150→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   151→\t\tImage:        image,\n   152→\t\tWorkflowName: req.WorkflowName,\n   153→\t\tProjectDir:   req.ProjectDir,\n   154→\t\tRunID:        runID,\n   155→\t\tNetworkAllow: []string{\"*\"},\n   156→\t})\n   157→\tif err != nil {\n   158→\t\trun, _ := s.store.GetRun(ctx, runID)\n   159→\t\tif run != nil {\n   160→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   161→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   162→\t\t}\n   163→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   164→\t\treturn\n   165→\t}\n   166→\n   167→\ts.mu.Lock()\n   168→\ts.runIDs[runID] = containerID\n   169→\ts.mu.Unlock()\n   170→\n   171→\trun, _ := s.store.GetRun(ctx, runID)\n   172→\tif run != nil {\n   173→\t\trun.Start()\n   174→\t\trun.ContainerID = containerID\n   175→\t\trun.BaseSHA = baseSHA\n   176→\t\t_ = s.store.UpdateRun(ctx, run)\n   177→\t}\n   178→\n   179→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   180→}\n   181→\n   182→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   183→\tctx := context.Background()\n   184→\n   185→\t// Attach to agent output\n   186→\treader, err := s.container.AttachOutput(ctx, containerID)\n   187→\tif err != nil {\n   188→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   189→\t\t\treturn\n   190→\t}\n   191→\n   192→\t// Parse JSON-lines status messages\n   193→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   194→\tscanner := bufio.NewScanner(reader)\n   195→\tfor scanner.Scan() {\n   196→\t\tvar msg protocol.StatusMessage\n   197→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   198→\t\t\tcontinue\n   199→\t\t}\n   200→\n   201→\t\t// Fast path: log messages don't need store interaction.\n   202→\t\tif msg.Type == protocol.MsgLog {\n   203→\t\t\tif s.logBroadcast != nil {\n   204→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   205→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   206→\t\t\t\t\tType:      \"llm\",\n   207→\t\t\t\t\tContent:   msg.Message,\n   208→\t\t\t\t})\n   209→\t\t\t}\n   210→\t\t\tcontinue\n   211→\t\t}\n   212→\n   213→\t\trun, err := s.store.GetRun(ctx, runID)\n   214→\t\tif err != nil {\n   215→\t\t\tcontinue\n   216→\t\t}\n   217→\n   218→\t\tswitch msg.Type {\n   219→\t\tcase protocol.MsgStepStarted:\n   220→\t\t\trun.RecordStepStart(msg.StepName)\n   221→\t\t\tif s.captures != nil {\n   222→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   223→\t\t\t\t\tStepName:  msg.StepName,\n   224→\t\t\t\t\tStartedAt: msg.Timestamp,\n   225→\t\t\t\t})\n   226→\t\t\t}\n   227→\t\tcase protocol.MsgStepCompleted:\n   228→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   229→\t\t\tif s.captures != nil {\n   230→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   231→\t\t\t\t\tStepName:    msg.StepName,\n   232→\t\t\t\t\tResult:      msg.Result,\n   233→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   234→\t\t\t\t})\n   235→\t\t\t}\n   236→\t\tcase protocol.MsgRunTitle:\n   237→\t\t\tif run.Title == \"\" {\n   238→\t\t\t\trun.Title = msg.Message\n   239→\t\t\t}\n   240→\t\tcase protocol.MsgRunCompleted:\n   241→\t\t\treportedResult = msg.Result\n   242→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   243→\t\t}\n   244→\n   245→\t\t_ = s.store.UpdateRun(ctx, run)\n   246→\t}\n   247→\treader.Close()\n   248→\n   249→\t// Signal live-stream subscribers that this run is done.\n   250→\tif s.logBroadcast != nil {\n   251→\t\ts.logBroadcast.Finish(runID)\n   252→\t}\n   253→\n   254→\t// Wait for process exit\n   255→\texitCode, err := s.container.Wait(ctx, containerID)\n   256→\tif err != nil {\n   257→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   258→\t}\n   259→\n   260→\t// Extract step output files from container before it's removed\n   261→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   262→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   263→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   264→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   265→\t\t}\n   266→\t}\n   267→\n   268→\t// Capture full container stdout/stderr before the container is removed\n   269→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   270→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   271→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   272→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   273→\t\t}\n   274→\t}\n   275→\n   276→\t// Index extracted log files in the log store\n   277→\tif s.logStore != nil {\n   278→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   279→\t}\n   280→\n   281→\t// Extract results to git branch BEFORE finalizing state, so that\n   282→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   283→\t// before the run is marked complete.\n   284→\tresultLabel := reportedResult\n   285→\tif resultLabel == \"\" {\n   286→\t\tif exitCode == 0 {\n   287→\t\t\tresultLabel = \"succeeded\"\n   288→\t\t} else {\n   289→\t\t\tresultLabel = \"failed\"\n   290→\t\t}\n   291→\t}\n   292→\t{\n   293→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   294→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   295→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   296→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   297→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   298→\t\t\t} else {\n   299→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   300→\t\t\t}\n   301→\t\t} else {\n   302→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   303→\t\t}\n   304→\t}\n   305→\n   306→\t// Now finalize run state\n   307→\trun, err := s.store.GetRun(ctx, runID)\n   308→\tif err != nil {\n   309→\t\treturn\n   310→\t}\n   311→\tif run.State == domain.RunStateRunning {\n   312→\t\tif reportedResult == \"succeeded\" {\n   313→\t\t\trun.Complete(domain.RunStateSucceeded)\n   314→\t\t} else if reportedResult != \"\" {\n   315→\t\t\trun.Complete(domain.RunStateFailed)\n   316→\t\t} else if exitCode == 0 {\n   317→\t\t\trun.Complete(domain.RunStateSucceeded)\n   318→\t\t} else {\n   319→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   320→\t\t}\n   321→\t\t_ = s.store.UpdateRun(ctx, run)\n   322→\t}\n   323→\n   324→\t// Fire evolution trigger if configured\n   325→\tif s.evolution != nil {\n   326→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   327→\t}\n   328→\n   329→\t// Merge is handled as a workflow step in host.cloche, not here.\n   330→\n   331→\t// Container retention policy:\n   332→\t// - Failed runs: always keep the container for debugging\n   333→\t// - Successful runs + --keep-container: keep the container\n   334→\t// - Successful runs without --keep-container: remove the container\n   335→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   336→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   337→\n   338→\tif keepContainer || runFailed {\n   339→\t\treason := \"--keep-container\"\n   340→\t\tif runFailed {\n   341→\t\t\treason = \"run failed\"\n   342→\t\t}\n   343→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   344→\t\tif runFinal != nil {\n   345→\t\t\trunFinal.ContainerKept = true\n   346→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   347→\t\t}\n   348→\t} else {\n   349→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   350→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   351→\t\t} else {\n   352→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   353→\t\t}\n   354→\t}\n   355→\n   356→\t// Cleanup mapping\n   357→\ts.mu.Lock()\n   358→\tdelete(s.runIDs, runID)\n   359→\ts.mu.Unlock()\n   360→}\n   361→\n   362→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   363→\tvar since time.Time\n   364→\tif !req.All {\n   365→\t\tsince = time.Now().Add(-1 * time.Hour)\n   366→\t}\n   367→\truns, err := s.store.ListRuns(ctx, since)\n   368→\tif err != nil {\n   369→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   370→\t}\n   371→\n   372→\tresp := &pb.ListRunsResponse{}\n   373→\tfor _, run := range runs {\n   374→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   375→\t\t\tRunId:        run.ID,\n   376→\t\t\tWorkflowName: run.WorkflowName,\n   377→\t\t\tState:        string(run.State),\n   378→\t\t\tStartedAt:    run.StartedAt.String(),\n   379→\t\t\tErrorMessage: run.ErrorMessage,\n   380→\t\t\tContainerId:  run.ContainerID,\n   381→\t\t\tTitle:        run.Title,\n   382→\t\t})\n   383→\t}\n   384→\treturn resp, nil\n   385→}\n   386→\n   387→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   388→\trun, err := s.store.GetRun(ctx, req.RunId)\n   389→\tif err != nil {\n   390→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   391→\t}\n   392→\n   393→\tresp := &pb.GetStatusResponse{\n   394→\t\tRunId:        run.ID,\n   395→\t\tWorkflowName: run.WorkflowName,\n   396→\t\tState:        string(run.State),\n   397→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   398→\t\tErrorMessage: run.ErrorMessage,\n   399→\t\tContainerId:  run.ContainerID,\n   400→\t\tTitle:        run.Title,\n   401→\t}\n   402→\n   403→\t// Check container liveness\n   404→\tif run.ContainerID != \"\" && s.container != nil {\n   405→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   406→\t\t\tresp.ContainerAlive = cs.Running\n   407→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   408→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   409→\t\t\t}\n   410→\t\t}\n   411→\t}\n   412→\n   413→\t// Load step executions from captures store if available\n   414→\tif s.captures != nil {\n   415→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   416→\t\tif err == nil {\n   417→\t\t\tfor _, exec := range captures {\n   418→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   419→\t\t\t\t\tStepName:    exec.StepName,\n   420→\t\t\t\t\tResult:      exec.Result,\n   421→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   422→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   423→\t\t\t\t})\n   424→\t\t\t}\n   425→\t\t}\n   426→\t} else {\n   427→\t\tfor _, exec := range run.StepExecutions {\n   428→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   429→\t\t\t\tStepName:    exec.StepName,\n   430→\t\t\t\tResult:      exec.Result,\n   431→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   432→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   433→\t\t\t})\n   434→\t\t}\n   435→\t}\n   436→\n   437→\treturn resp, nil\n   438→}\n   439→\n   440→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   441→\tctx := stream.Context()\n   442→\n   443→\t// Verify run exists\n   444→\trun, err := s.store.GetRun(ctx, req.RunId)\n   445→\tif err != nil {\n   446→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   447→\t}\n   448→\n   449→\t// If step_name or log_type filter is set, serve content directly from the log index\n   450→\tif req.StepName != \"\" || req.LogType != \"\" {\n   451→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   452→\t}\n   453→\n   454→\tif s.captures == nil {\n   455→\t\treturn fmt.Errorf(\"captures store not configured\")\n   456→\t}\n   457→\n   458→\t// Check for full.log first — if it exists, serve it as the unified log\n   459→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   460→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   461→\t\tif err := stream.Send(&pb.LogEntry{\n   462→\t\t\tType:    \"full_log\",\n   463→\t\t\tMessage: string(data),\n   464→\t\t}); err != nil {\n   465→\t\t\treturn err\n   466→\t\t}\n   467→\t\t// Still send run completion entry\n   468→\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   469→\t\t\tif err := stream.Send(&pb.LogEntry{\n   470→\t\t\t\tType:      \"run_completed\",\n   471→\t\t\t\tResult:    string(run.State),\n   472→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   473→\t\t\t\tMessage:   run.ErrorMessage,\n   474→\t\t\t}); err != nil {\n   475→\t\t\t\treturn err\n   476→\t\t\t}\n   477→\t\t}\n   478→\t\treturn nil\n   479→\t}\n   480→\n   481→\t// Fall back to capture-based streaming\n   482→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   483→\tif err != nil {\n   484→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   485→\t}\n   486→\n   487→\tfor _, exec := range captures {\n   488→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   489→\t\t// and one for step_completed (has Result).\n   490→\t\tif exec.Result == \"\" {\n   491→\t\t\tentry := &pb.LogEntry{\n   492→\t\t\t\tType:      \"step_started\",\n   493→\t\t\t\tStepName:  exec.StepName,\n   494→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   495→\t\t\t}\n   496→\t\t\tif err := stream.Send(entry); err != nil {\n   497→\t\t\t\treturn err\n   498→\t\t\t}\n   499→\t\t} else {\n   500→\t\t\t// Read step output from file, falling back to container.log\n   501→\t\t\tvar output string\n   502→\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   503→\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   504→\t\t\t\toutput = string(data)\n   505→\t\t\t} else {\n   506→\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n   507→\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n   508→\t\t\t\t\toutput = string(data)\n   509→\t\t\t\t}\n   510→\t\t\t}\n   511→\t\t\tentry := &pb.LogEntry{\n   512→\t\t\t\tType:      \"step_completed\",\n   513→\t\t\t\tStepName:  exec.StepName,\n   514→\t\t\t\tResult:    exec.Result,\n   515→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   516→\t\t\t\tMessage:   output,\n   517→\t\t\t}\n   518→\t\t\tif err := stream.Send(entry); err != nil {\n   519→\t\t\t\treturn err\n   520→\t\t\t}\n   521→\t\t}\n   522→\t}\n   523→\n   524→\t// Send run completion entry\n   525→\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   526→\t\tif err := stream.Send(&pb.LogEntry{\n   527→\t\t\tType:      \"run_completed\",\n   528→\t\t\tResult:    string(run.State),\n   529→\t\t\tTimestamp: run.CompletedAt.String(),\n   530→\t\t\tMessage:   run.ErrorMessage,\n   531→\t\t}); err != nil {\n   532→\t\t\treturn err\n   533→\t\t}\n   534→\t}\n   535→\n   536→\treturn nil\n   537→}\n   538→\n   539→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   540→// It uses the log index when available, falling back to file path conventions.\n   541→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   542→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   543→\n   544→\t// Try log index first\n   545→\tif s.logStore != nil {\n   546→\t\tvar logFiles []*ports.LogFileEntry\n   547→\t\tvar err error\n   548→\n   549→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   550→\t\t\t// Filter by both step and type\n   551→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   552→\t\t\tif err == nil {\n   553→\t\t\t\tfiltered := logFiles[:0]\n   554→\t\t\t\tfor _, lf := range logFiles {\n   555→\t\t\t\t\tif lf.FileType == req.LogType {\n   556→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   557→\t\t\t\t\t}\n   558→\t\t\t\t}\n   559→\t\t\t\tlogFiles = filtered\n   560→\t\t\t}\n   561→\t\t} else if req.StepName != \"\" {\n   562→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   563→\t\t} else {\n   564→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   565→\t\t}\n   566→\n   567→\t\tif err == nil && len(logFiles) > 0 {\n   568→\t\t\tfor _, lf := range logFiles {\n   569→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   570→\t\t\t\tif readErr != nil {\n   571→\t\t\t\t\tcontinue\n   572→\t\t\t\t}\n   573→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   574→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   575→\t\t\t\t\tStepName: lf.StepName,\n   576→\t\t\t\t\tMessage:  string(data),\n   577→\t\t\t\t}); err != nil {\n   578→\t\t\t\t\treturn err\n   579→\t\t\t\t}\n   580→\t\t\t}\n   581→\t\t\treturn nil\n   582→\t\t}\n   583→\t}\n   584→\n   585→\t// Fall back to file path conventions\n   586→\tif req.StepName != \"\" {\n   587→\t\tvar logPath string\n   588→\t\tswitch req.LogType {\n   589→\t\tcase \"llm\":\n   590→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   591→\t\tdefault:\n   592→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   593→\t\t}\n   594→\n   595→\t\tdata, err := os.ReadFile(logPath)\n   596→\t\tif err != nil {\n   597→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   598→\t\t}\n   599→\t\treturn stream.Send(&pb.LogEntry{\n   600→\t\t\tType:     \"step_log\",\n   601→\t\t\tStepName: req.StepName,\n   602→\t\t\tMessage:  string(data),\n   603→\t\t})\n   604→\t}\n   605→\n   606→\treturn fmt.Errorf(\"no log files found matching filter\")\n   607→}\n   608→\n   609→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   610→\ts.mu.Lock()\n   611→\tcontainerID, ok := s.runIDs[req.RunId]\n   612→\ts.mu.Unlock()\n   613→\n   614→\tif !ok {\n   615→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   616→\t}\n   617→\n   618→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   619→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   620→\t}\n   621→\n   622→\t// Mark as cancelled in store\n   623→\trun, err := s.store.GetRun(ctx, req.RunId)\n   624→\tif err == nil {\n   625→\t\trun.Complete(domain.RunStateCancelled)\n   626→\t\t_ = s.store.UpdateRun(ctx, run)\n   627→\t}\n   628→\n   629→\treturn &pb.StopRunResponse{}, nil\n   630→}\n   631→\n   632→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   633→\tif s.container == nil {\n   634→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   635→\t}\n   636→\n   637→\tid := req.Id\n   638→\tif id == \"\" {\n   639→\t\treturn nil, fmt.Errorf(\"id is required\")\n   640→\t}\n   641→\n   642→\t// Try to resolve as a run ID first\n   643→\tcontainerID := id\n   644→\trun, err := s.store.GetRun(ctx, id)\n   645→\tif err == nil {\n   646→\t\t// It's a run ID — use the container ID from the run record\n   647→\t\tif run.ContainerID == \"\" {\n   648→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   649→\t\t}\n   650→\t\tcontainerID = run.ContainerID\n   651→\t}\n   652→\n   653→\t// Remove the container\n   654→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   655→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   656→\t}\n   657→\n   658→\t// If we resolved a run, clear the container_kept flag\n   659→\tif run != nil {\n   660→\t\trun.ContainerKept = false\n   661→\t\t_ = s.store.UpdateRun(ctx, run)\n   662→\t}\n   663→\n   664→\treturn &pb.DeleteContainerResponse{}, nil\n   665→}\n   666→\n   667→func (s *ClocheServer) Orchestrate(ctx context.Context, req *pb.OrchestrateRequest) (*pb.OrchestrateResponse, error) {\n   668→\treturn nil, fmt.Errorf(\"orchestrator has been removed; use host workflow instead\")\n   669→}\n   670→\n   671→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n   672→\tif s.shutdownFn == nil {\n   673→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n   674→\t}\n   675→\tgo s.shutdownFn()\n   676→\treturn &pb.ShutdownResponse{}, nil\n   677→}\n   678→\n   679→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n   680→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n   681→\tentries, err := os.ReadDir(outputDir)\n   682→\tif err != nil {\n   683→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n   684→\t\treturn\n   685→\t}\n   686→\n   687→\tnow := time.Now()\n   688→\tfor _, entry := range entries {\n   689→\t\tif entry.IsDir() {\n   690→\t\t\tcontinue\n   691→\t\t}\n   692→\t\tname := entry.Name()\n   693→\t\tif !strings.HasSuffix(name, \".log\") {\n   694→\t\t\tcontinue\n   695→\t\t}\n   696→\n   697→\t\tvar fileType, stepName string\n   698→\t\tbase := strings.TrimSuffix(name, \".log\")\n   699→\n   700→\t\tswitch {\n   701→\t\tcase name == \"full.log\":\n   702→\t\t\tfileType = \"full\"\n   703→\t\tcase name == \"container.log\":\n   704→\t\t\t// container.log is internal, not indexed as a user-facing log type\n   705→\t\t\tcontinue\n   706→\t\tcase strings.HasPrefix(name, \"llm-\"):\n   707→\t\t\tfileType = \"llm\"\n   708→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n   709→\t\tdefault:\n   710→\t\t\tfileType = \"script\"\n   711→\t\t\tstepName = base\n   712→\t\t}\n   713→\n   714→\t\tinfo, _ := entry.Info()\n   715→\t\tvar fileSize int64\n   716→\t\tif info != nil {\n   717→\t\t\tfileSize = info.Size()\n   718→\t\t}\n   719→\n   720→\t\tlogEntry := &ports.LogFileEntry{\n   721→\t\t\tRunID:     runID,\n   722→\t\t\tStepName:  stepName,\n   723→\t\t\tFileType:  fileType,\n   724→\t\t\tFilePath:  filepath.Join(outputDir, name),\n   725→\t\t\tFileSize:  fileSize,\n   726→\t\t\tCreatedAt: now,\n   727→\t\t}\n   728→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n   729→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n   730→\t\t}\n   731→\t}\n   732→}\n   733→\n   734→func gitHEAD(dir string) string {\n   735→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n   736→\tcmd.Dir = dir\n   737→\tout, err := cmd.Output()\n   738→\tif err != nil {\n   739→\t\treturn \"\"\n   740→\t}\n   741→\treturn strings.TrimSpace(string(out))\n   742→}\n   743→"}]},"parent_tool_use_id":null,"session_id":"bdac9138-b825-4d68-8fcd-895e48604ce0","uuid":"817bc3b1-aeb1-4aee-af4b-83db47997577","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server.go","content":"package grpc\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\trpcgrpc \"google.golang.org/grpc\"\n)\n\ntype ClocheServer struct {\n\tpb.UnimplementedClocheServiceServer\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogStore     ports.LogStore\n\tcontainer    ports.ContainerRuntime\n\tdefaultImage string\n\tevolution    *evolution.Trigger\n\tlogBroadcast *logstream.Broadcaster\n\tshutdownFn   func()\n\tmu           sync.Mutex\n\trunIDs       map[string]string // run_id -> container_id\n}\n\nfunc NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:     store,\n\t\tcontainer: container,\n\t\trunIDs:    make(map[string]string),\n\t}\n}\n\nfunc NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:        store,\n\t\tcaptures:     captures,\n\t\tcontainer:    container,\n\t\tdefaultImage: defaultImage,\n\t\trunIDs:       make(map[string]string),\n\t}\n}\n\n// SetLogStore attaches a log store to the server for indexing extracted log files.\nfunc (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n\ts.logStore = ls\n}\n\n\n// SetEvolution attaches an evolution trigger to the server.\nfunc (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n\ts.evolution = trigger\n}\n\n// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\nfunc (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n\ts.logBroadcast = b\n}\n\n// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\nfunc (s *ClocheServer) SetShutdownFunc(fn func()) {\n\ts.shutdownFn = fn\n}\n\nfunc (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\t// Generate a unique run ID, retrying on collision\n\tvar runID string\n\tfor attempts := 0; attempts < 10; attempts++ {\n\t\trunID = domain.GenerateRunID(req.WorkflowName)\n\t\texisting, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tbreak // ID is free\n\t\t}\n\t\t// Reuse if completed more than 1 hour ago\n\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n\t\t\t_ = s.store.DeleteRun(ctx, runID)\n\t\t\tbreak\n\t\t}\n\t}\n\n\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n\tif req.Prompt != \"\" {\n\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n\t\t}\n\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n\t\t}\n\t}\n\trun := domain.NewRun(runID, req.WorkflowName)\n\trun.ProjectDir = req.ProjectDir\n\trun.Title = req.Title\n\tif err := s.store.CreateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n\t}\n\n\t// Resolve image: request-level override, then server default\n\timage := req.Image\n\tif image == \"\" {\n\t\timage = s.defaultImage\n\t}\n\n\t// Launch container start + tracking in background so the RPC returns immediately.\n\t// The run stays in \"pending\" state until the container is up.\n\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n\n\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n}\n\n// launchAndTrack starts the container and then tracks it to completion.\n// It runs in a background goroutine with its own context, independent of the\n// RPC context which may be cancelled after RunWorkflow returns.\nfunc (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n\tctx := context.Background()\n\n\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n\t\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\t\tif run != nil {\n\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t\t}\n\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n\t\t\t\treturn\n\t\t}\n\t}\n\n\tbaseSHA := gitHEAD(req.ProjectDir)\n\n\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n\t\tImage:        image,\n\t\tWorkflowName: req.WorkflowName,\n\t\tProjectDir:   req.ProjectDir,\n\t\tRunID:        runID,\n\t\tNetworkAllow: []string{\"*\"},\n\t})\n\tif err != nil {\n\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\tif run != nil {\n\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t}\n\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n\t\treturn\n\t}\n\n\ts.mu.Lock()\n\ts.runIDs[runID] = containerID\n\ts.mu.Unlock()\n\n\trun, _ := s.store.GetRun(ctx, runID)\n\tif run != nil {\n\t\trun.Start()\n\t\trun.ContainerID = containerID\n\t\trun.BaseSHA = baseSHA\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n}\n\nfunc (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n\tctx := context.Background()\n\n\t// Attach to agent output\n\treader, err := s.container.AttachOutput(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n\t\t\treturn\n\t}\n\n\t// Parse JSON-lines status messages\n\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n\tscanner := bufio.NewScanner(reader)\n\tfor scanner.Scan() {\n\t\tvar msg protocol.StatusMessage\n\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Fast path: log messages don't need store interaction.\n\t\tif msg.Type == protocol.MsgLog {\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"llm\",\n\t\t\t\t\tContent:   msg.Message,\n\t\t\t\t})\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\trun, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch msg.Type {\n\t\tcase protocol.MsgStepStarted:\n\t\t\trun.RecordStepStart(msg.StepName)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t\tStartedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgStepCompleted:\n\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:    msg.StepName,\n\t\t\t\t\tResult:      msg.Result,\n\t\t\t\t\tCompletedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgRunTitle:\n\t\t\tif run.Title == \"\" {\n\t\t\t\trun.Title = msg.Message\n\t\t\t}\n\t\tcase protocol.MsgRunCompleted:\n\t\t\treportedResult = msg.Result\n\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n\t\t}\n\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\treader.Close()\n\n\t// Signal live-stream subscribers that this run is done.\n\tif s.logBroadcast != nil {\n\t\ts.logBroadcast.Finish(runID)\n\t}\n\n\t// Wait for process exit\n\texitCode, err := s.container.Wait(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n\t}\n\n\t// Extract step output files from container before it's removed\n\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n\t\t}\n\t}\n\n\t// Capture full container stdout/stderr before the container is removed\n\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n\t\t}\n\t}\n\n\t// Index extracted log files in the log store\n\tif s.logStore != nil {\n\t\ts.indexLogFiles(ctx, runID, outputDst)\n\t}\n\n\t// Extract results to git branch BEFORE finalizing state, so that\n\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n\t// before the run is marked complete.\n\tresultLabel := reportedResult\n\tif resultLabel == \"\" {\n\t\tif exitCode == 0 {\n\t\t\tresultLabel = \"succeeded\"\n\t\t} else {\n\t\t\tresultLabel = \"failed\"\n\t\t}\n\t}\n\t{\n\t\textractRun, _ := s.store.GetRun(ctx, runID)\n\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n\t\t\t} else {\n\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n\t\t\t}\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n\t\t}\n\t}\n\n\t// Now finalize run state\n\trun, err := s.store.GetRun(ctx, runID)\n\tif err != nil {\n\t\treturn\n\t}\n\tif run.State == domain.RunStateRunning {\n\t\tif reportedResult == \"succeeded\" {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else if reportedResult != \"\" {\n\t\t\trun.Complete(domain.RunStateFailed)\n\t\t} else if exitCode == 0 {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else {\n\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n\t\t}\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\t// Fire evolution trigger if configured\n\tif s.evolution != nil {\n\t\ts.evolution.Fire(projectDir, workflowName, runID)\n\t}\n\n\t// Merge is handled as a workflow step in host.cloche, not here.\n\n\t// Container retention policy:\n\t// - Failed runs: always keep the container for debugging\n\t// - Successful runs + --keep-container: keep the container\n\t// - Successful runs without --keep-container: remove the container\n\trunFinal, _ := s.store.GetRun(ctx, runID)\n\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n\n\tif keepContainer || runFailed {\n\t\treason := \"--keep-container\"\n\t\tif runFailed {\n\t\t\treason = \"run failed\"\n\t\t}\n\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n\t\tif runFinal != nil {\n\t\t\trunFinal.ContainerKept = true\n\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n\t\t}\n\t} else {\n\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n\t\t}\n\t}\n\n\t// Cleanup mapping\n\ts.mu.Lock()\n\tdelete(s.runIDs, runID)\n\ts.mu.Unlock()\n}\n\nfunc (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n\tvar since time.Time\n\tif !req.All {\n\t\tsince = time.Now().Add(-1 * time.Hour)\n\t}\n\truns, err := s.store.ListRuns(ctx, since)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n\t}\n\n\tresp := &pb.ListRunsResponse{}\n\tfor _, run := range runs {\n\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n\t\t\tRunId:        run.ID,\n\t\t\tWorkflowName: run.WorkflowName,\n\t\t\tState:        string(run.State),\n\t\t\tStartedAt:    run.StartedAt.String(),\n\t\t\tErrorMessage: run.ErrorMessage,\n\t\t\tContainerId:  run.ContainerID,\n\t\t\tTitle:        run.Title,\n\t\t})\n\t}\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n\t}\n\n\tresp := &pb.GetStatusResponse{\n\t\tRunId:        run.ID,\n\t\tWorkflowName: run.WorkflowName,\n\t\tState:        string(run.State),\n\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n\t\tErrorMessage: run.ErrorMessage,\n\t\tContainerId:  run.ContainerID,\n\t\tTitle:        run.Title,\n\t}\n\n\t// Check container liveness\n\tif run.ContainerID != \"\" && s.container != nil {\n\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n\t\t\tresp.ContainerAlive = cs.Running\n\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n\t\t\t}\n\t\t}\n\t}\n\n\t// Load step executions from captures store if available\n\tif s.captures != nil {\n\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\t\tif err == nil {\n\t\t\tfor _, exec := range captures {\n\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\t\tStepName:    exec.StepName,\n\t\t\t\t\tResult:      exec.Result,\n\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, exec := range run.StepExecutions {\n\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\tStepName:    exec.StepName,\n\t\t\t\tResult:      exec.Result,\n\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t})\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tctx := stream.Context()\n\n\t// Verify run exists\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n\t}\n\n\t// If step_name or log_type filter is set, serve content directly from the log index\n\tif req.StepName != \"\" || req.LogType != \"\" {\n\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n\t}\n\n\tif s.captures == nil {\n\t\treturn fmt.Errorf(\"captures store not configured\")\n\t}\n\n\t// Check for full.log first — if it exists, serve it as the unified log\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: string(data),\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t\t// Still send run completion entry\n\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"run_completed\",\n\t\t\t\tResult:    string(run.State),\n\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}\n\n\t// Fall back to capture-based streaming\n\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n\t}\n\n\tfor _, exec := range captures {\n\t\t// Captures are stored as separate rows: one for step_started (no Result)\n\t\t// and one for step_completed (has Result).\n\t\tif exec.Result == \"\" {\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_started\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tTimestamp: exec.StartedAt.String(),\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t} else {\n\t\t\t// Read step output from file, falling back to container.log\n\t\t\tvar output string\n\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\t\t\toutput = string(data)\n\t\t\t} else {\n\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n\t\t\t\t\toutput = string(data)\n\t\t\t\t}\n\t\t\t}\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_completed\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tResult:    exec.Result,\n\t\t\t\tTimestamp: exec.CompletedAt.String(),\n\t\t\t\tMessage:   output,\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\t// Send run completion entry\n\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:      \"run_completed\",\n\t\t\tResult:    string(run.State),\n\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\tMessage:   run.ErrorMessage,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// streamFilteredLogs serves log content filtered by step name and/or log type.\n// It uses the log index when available, falling back to file path conventions.\nfunc (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n\n\t// Try log index first\n\tif s.logStore != nil {\n\t\tvar logFiles []*ports.LogFileEntry\n\t\tvar err error\n\n\t\tif req.StepName != \"\" && req.LogType != \"\" {\n\t\t\t// Filter by both step and type\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t\tif err == nil {\n\t\t\t\tfiltered := logFiles[:0]\n\t\t\t\tfor _, lf := range logFiles {\n\t\t\t\t\tif lf.FileType == req.LogType {\n\t\t\t\t\t\tfiltered = append(filtered, lf)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tlogFiles = filtered\n\t\t\t}\n\t\t} else if req.StepName != \"\" {\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t} else {\n\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n\t\t}\n\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr != nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\t\tType:     lf.FileType + \"_log\",\n\t\t\t\t\tStepName: lf.StepName,\n\t\t\t\t\tMessage:  string(data),\n\t\t\t\t}); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Fall back to file path conventions\n\tif req.StepName != \"\" {\n\t\tvar logPath string\n\t\tswitch req.LogType {\n\t\tcase \"llm\":\n\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n\t\tdefault:\n\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n\t\t}\n\n\t\tdata, err := os.ReadFile(logPath)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n\t\t}\n\t\treturn stream.Send(&pb.LogEntry{\n\t\t\tType:     \"step_log\",\n\t\t\tStepName: req.StepName,\n\t\t\tMessage:  string(data),\n\t\t})\n\t}\n\n\treturn fmt.Errorf(\"no log files found matching filter\")\n}\n\nfunc (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n\ts.mu.Lock()\n\tcontainerID, ok := s.runIDs[req.RunId]\n\ts.mu.Unlock()\n\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n\t}\n\n\tif err := s.container.Stop(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n\t}\n\n\t// Mark as cancelled in store\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err == nil {\n\t\trun.Complete(domain.RunStateCancelled)\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.StopRunResponse{}, nil\n}\n\nfunc (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\tid := req.Id\n\tif id == \"\" {\n\t\treturn nil, fmt.Errorf(\"id is required\")\n\t}\n\n\t// Try to resolve as a run ID first\n\tcontainerID := id\n\trun, err := s.store.GetRun(ctx, id)\n\tif err == nil {\n\t\t// It's a run ID — use the container ID from the run record\n\t\tif run.ContainerID == \"\" {\n\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n\t\t}\n\t\tcontainerID = run.ContainerID\n\t}\n\n\t// Remove the container\n\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n\t}\n\n\t// If we resolved a run, clear the container_kept flag\n\tif run != nil {\n\t\trun.ContainerKept = false\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.DeleteContainerResponse{}, nil\n}\n\nfunc (s *ClocheServer) Orchestrate(ctx context.Context, req *pb.OrchestrateRequest) (*pb.OrchestrateResponse, error) {\n\treturn nil, fmt.Errorf(\"orchestrator has been removed; use host workflow instead\")\n}\n\nfunc (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n\tif s.shutdownFn == nil {\n\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n\t}\n\tgo s.shutdownFn()\n\treturn &pb.ShutdownResponse{}, nil\n}\n\n// indexLogFiles scans the extracted output directory and creates log_files index entries.\nfunc (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tname := entry.Name()\n\t\tif !strings.HasSuffix(name, \".log\") {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar fileType, stepName string\n\t\tbase := strings.TrimSuffix(name, \".log\")\n\n\t\tswitch {\n\t\tcase name == \"full.log\":\n\t\t\tfileType = \"full\"\n\t\tcase name == \"container.log\":\n\t\t\t// container.log is internal, not indexed as a user-facing log type\n\t\t\tcontinue\n\t\tcase strings.HasPrefix(name, \"llm-\"):\n\t\t\tfileType = \"llm\"\n\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n\t\tdefault:\n\t\t\tfileType = \"script\"\n\t\t\tstepName = base\n\t\t}\n\n\t\tinfo, _ := entry.Info()\n\t\tvar fileSize int64\n\t\tif info != nil {\n\t\t\tfileSize = info.Size()\n\t\t}\n\n\t\tlogEntry := &ports.LogFileEntry{\n\t\t\tRunID:     runID,\n\t\t\tStepName:  stepName,\n\t\t\tFileType:  fileType,\n\t\t\tFilePath:  filepath.Join(outputDir, name),\n\t\t\tFileSize:  fileSize,\n\t\t\tCreatedAt: now,\n\t\t}\n\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n\t\t}\n\t}\n}\n\nfunc gitHEAD(dir string) string {\n\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\treturn strings.TrimSpace(string(out))\n}\n","numLines":743,"startLine":1,"totalLines":743}}}
