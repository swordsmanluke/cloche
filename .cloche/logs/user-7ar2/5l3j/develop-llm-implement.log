{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019QobDGTSv2F5n3HdKrQ49n","type":"tool_result","content":"     1→package sqlite\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"database/sql\"\n     6→\t\"fmt\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11→\t_ \"modernc.org/sqlite\"\n    12→)\n    13→\n    14→type Store struct {\n    15→\tdb *sql.DB\n    16→}\n    17→\n    18→func NewStore(dsn string) (*Store, error) {\n    19→\tdb, err := sql.Open(\"sqlite\", dsn)\n    20→\tif err != nil {\n    21→\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n    22→\t}\n    23→\n    24→\t// Enable WAL mode for concurrent read/write access\n    25→\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n    26→\n    27→\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n    28→\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n    29→\n    30→\t// Serialize all Go-side access through a single connection so SQLite\n    31→\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n    32→\tdb.SetMaxOpenConns(1)\n    33→\n    34→\tif err := migrate(db); err != nil {\n    35→\t\tdb.Close()\n    36→\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n    37→\t}\n    38→\n    39→\treturn &Store{db: db}, nil\n    40→}\n    41→\n    42→func (s *Store) Close() error {\n    43→\treturn s.db.Close()\n    44→}\n    45→\n    46→func migrate(db *sql.DB) error {\n    47→\t_, err := db.Exec(`\n    48→\t\tCREATE TABLE IF NOT EXISTS runs (\n    49→\t\t\tid TEXT PRIMARY KEY,\n    50→\t\t\tworkflow_name TEXT NOT NULL,\n    51→\t\t\tstate TEXT NOT NULL,\n    52→\t\t\tactive_steps TEXT,\n    53→\t\t\tstarted_at TEXT,\n    54→\t\t\tcompleted_at TEXT\n    55→\t\t);\n    56→\t\tCREATE TABLE IF NOT EXISTS step_executions (\n    57→\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    58→\t\t\trun_id TEXT NOT NULL,\n    59→\t\t\tstep_name TEXT NOT NULL,\n    60→\t\t\tresult TEXT,\n    61→\t\t\tstarted_at TEXT NOT NULL,\n    62→\t\t\tcompleted_at TEXT,\n    63→\t\t\tlogs TEXT,\n    64→\t\t\tgit_ref TEXT,\n    65→\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    66→\t\t);\n    67→\t`)\n    68→\tif err != nil {\n    69→\t\treturn err\n    70→\t}\n    71→\n    72→\t// Evolution schema additions (idempotent)\n    73→\talterStmts := []string{\n    74→\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n    75→\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n    76→\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n    77→\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n    78→\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n    79→\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n    80→\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n    81→\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n    82→\t\t`ALTER TABLE runs ADD COLUMN title TEXT NOT NULL DEFAULT ''`,\n    83→\t}\n    84→\tfor _, stmt := range alterStmts {\n    85→\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n    86→\t}\n    87→\n    88→\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n    89→\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    90→\t\trun_id TEXT NOT NULL,\n    91→\t\tstep_name TEXT,\n    92→\t\tfile_type TEXT NOT NULL,\n    93→\t\tfile_path TEXT NOT NULL,\n    94→\t\tfile_size INTEGER,\n    95→\t\tcreated_at TEXT NOT NULL,\n    96→\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    97→\t)`)\n    98→\tif errLog != nil {\n    99→\t\treturn errLog\n   100→\t}\n   101→\n   102→\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n   103→\t\trun_id TEXT PRIMARY KEY,\n   104→\t\tbranch TEXT NOT NULL,\n   105→\t\tproject TEXT NOT NULL,\n   106→\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n   107→\t\tenqueued_at TEXT NOT NULL,\n   108→\t\tcompleted_at TEXT\n   109→\t)`)\n   110→\tif errMQ != nil {\n   111→\t\treturn errMQ\n   112→\t}\n   113→\n   114→\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n   115→\t\tid TEXT PRIMARY KEY,\n   116→\t\tproject_dir TEXT NOT NULL,\n   117→\t\tworkflow_name TEXT NOT NULL,\n   118→\t\ttrigger_run_id TEXT NOT NULL,\n   119→\t\tcreated_at TEXT NOT NULL,\n   120→\t\tclassification TEXT,\n   121→\t\tchanges_json TEXT NOT NULL,\n   122→\t\tknowledge_delta TEXT\n   123→\t)`)\n   124→\tif err2 != nil {\n   125→\t\treturn err2\n   126→\t}\n   127→\n   128→\treturn nil\n   129→}\n   130→\n   131→func (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n   132→\t_, err := s.db.ExecContext(ctx,\n   133→\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept, title)\n   134→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   135→\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n   136→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, run.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title,\n   137→\t)\n   138→\treturn err\n   139→}\n   140→\n   141→func (s *Store) GetRun(ctx context.Context, id string) (*domain.Run, error) {\n   142→\trow := s.db.QueryRowContext(ctx,\n   143→\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,'') FROM runs WHERE id = ?`, id)\n   144→\n   145→\trun := &domain.Run{}\n   146→\tvar activeSteps, startedAt, completedAt string\n   147→\tvar containerKept int\n   148→\terr := row.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title)\n   149→\tif err == sql.ErrNoRows {\n   150→\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n   151→\t}\n   152→\tif err != nil {\n   153→\t\treturn nil, err\n   154→\t}\n   155→\n   156→\trun.SetActiveStepsFromString(activeSteps)\n   157→\trun.StartedAt = parseTime(startedAt)\n   158→\trun.CompletedAt = parseTime(completedAt)\n   159→\trun.ContainerKept = containerKept != 0\n   160→\treturn run, nil\n   161→}\n   162→\n   163→func (s *Store) UpdateRun(ctx context.Context, run *domain.Run) error {\n   164→\t_, err := s.db.ExecContext(ctx,\n   165→\t\t`UPDATE runs SET state = ?, active_steps = ?, started_at = ?, completed_at = ?, error_message = ?, container_id = ?, base_sha = ?, container_kept = ?, title = ? WHERE id = ?`,\n   166→\t\tstring(run.State), run.ActiveStepsString(),\n   167→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt),\n   168→\t\trun.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, run.ID,\n   169→\t)\n   170→\treturn err\n   171→}\n   172→\n   173→func (s *Store) DeleteRun(ctx context.Context, id string) error {\n   174→\t_, err := s.db.ExecContext(ctx, `DELETE FROM step_executions WHERE run_id = ?`, id)\n   175→\tif err != nil {\n   176→\t\treturn err\n   177→\t}\n   178→\t_, err = s.db.ExecContext(ctx, `DELETE FROM runs WHERE id = ?`, id)\n   179→\treturn err\n   180→}\n   181→\n   182→func (s *Store) ListRuns(ctx context.Context, since time.Time) ([]*domain.Run, error) {\n   183→\tvar rows *sql.Rows\n   184→\tvar err error\n   185→\tif since.IsZero() {\n   186→\t\trows, err = s.db.QueryContext(ctx,\n   187→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,'') FROM runs ORDER BY started_at DESC`)\n   188→\t} else {\n   189→\t\trows, err = s.db.QueryContext(ctx,\n   190→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,'') FROM runs WHERE started_at >= ? ORDER BY started_at DESC`,\n   191→\t\t\tformatTime(since))\n   192→\t}\n   193→\tif err != nil {\n   194→\t\treturn nil, err\n   195→\t}\n   196→\tdefer rows.Close()\n   197→\n   198→\tvar runs []*domain.Run\n   199→\tfor rows.Next() {\n   200→\t\trun := &domain.Run{}\n   201→\t\tvar activeSteps, startedAt, completedAt string\n   202→\t\tvar containerKept int\n   203→\t\tif err := rows.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title); err != nil {\n   204→\t\t\treturn nil, err\n   205→\t\t}\n   206→\t\trun.SetActiveStepsFromString(activeSteps)\n   207→\t\trun.StartedAt = parseTime(startedAt)\n   208→\t\trun.CompletedAt = parseTime(completedAt)\n   209→\t\trun.ContainerKept = containerKept != 0\n   210→\t\truns = append(runs, run)\n   211→\t}\n   212→\treturn runs, rows.Err()\n   213→}\n   214→\n   215→func (s *Store) ListRunsByProject(ctx context.Context, projectDir string, since time.Time) ([]*domain.Run, error) {\n   216→\tvar rows *sql.Rows\n   217→\tvar err error\n   218→\tif since.IsZero() {\n   219→\t\trows, err = s.db.QueryContext(ctx,\n   220→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,'') FROM runs WHERE project_dir = ? ORDER BY started_at DESC`,\n   221→\t\t\tprojectDir)\n   222→\t} else {\n   223→\t\trows, err = s.db.QueryContext(ctx,\n   224→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,'') FROM runs WHERE project_dir = ? AND started_at >= ? ORDER BY started_at DESC`,\n   225→\t\t\tpro