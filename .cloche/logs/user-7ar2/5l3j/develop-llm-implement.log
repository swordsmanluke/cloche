{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011qPvKdHTT6rezGNjP1EzGB","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"fmt\"\n     6→\t\"testing\"\n     7→)\n     8→\n     9→func TestOrchestrateOutput(t *testing.T) {\n    10→\ttests := []struct {\n    11→\t\tdispatched int32\n    12→\t\twant       string\n    13→\t}{\n    14→\t\t{0, \"No ready work found.\\n\"},\n    15→\t\t{1, \"Dispatched 1 run(s).\\n\"},\n    16→\t\t{5, \"Dispatched 5 run(s).\\n\"},\n    17→\t}\n    18→\tfor _, tt := range tests {\n    19→\t\tvar buf bytes.Buffer\n    20→\t\tif tt.dispatched == 0 {\n    21→\t\t\tfmt.Fprintln(&buf, \"No ready work found.\")\n    22→\t\t} else {\n    23→\t\t\tfmt.Fprintf(&buf, \"Dispatched %d run(s).\\n\", tt.dispatched)\n    24→\t\t}\n    25→\t\tif buf.String() != tt.want {\n    26→\t\t\tt.Errorf(\"dispatched=%d: got %q, want %q\", tt.dispatched, buf.String(), tt.want)\n    27→\t\t}\n    28→\t}\n    29→}\n    30→"}]},"parent_tool_use_id":"toolu_01AzarRAMPGBPEX9A84eRtqF","session_id":"bdac9138-b825-4d68-8fcd-895e48604ce0","uuid":"12501397-02bc-4be4-8fcd-9cd20b44d0e2"}
