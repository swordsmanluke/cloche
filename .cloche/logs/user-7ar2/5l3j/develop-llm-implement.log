{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019RAY3oRWgBgMuDh2MiWCom","type":"tool_result","content":"     1→package sqlite\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"database/sql\"\n     6→\t\"fmt\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11→\t_ \"modernc.org/sqlite\"\n    12→)\n    13→\n    14→type Store struct {\n    15→\tdb *sql.DB\n    16→}\n    17→\n    18→func NewStore(dsn string) (*Store, error) {\n    19→\tdb, err := sql.Open(\"sqlite\", dsn)\n    20→\tif err != nil {\n    21→\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n    22→\t}\n    23→\n    24→\t// Enable WAL mode for concurrent read/write access\n    25→\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n    26→\n    27→\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n    28→\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n    29→\n    30→\t// Serialize all Go-side access through a single connection so SQLite\n    31→\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n    32→\tdb.SetMaxOpenConns(1)\n    33→\n    34→\tif err := migrate(db); err != nil {\n    35→\t\tdb.Close()\n    36→\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n    37→\t}\n    38→\n    39→\treturn &Store{db: db}, nil\n    40→}\n    41→\n    42→func (s *Store) Close() error {\n    43→\treturn s.db.Close()\n    44→}\n    45→\n    46→func migrate(db *sql.DB) error {\n    47→\t_, err := db.Exec(`\n    48→\t\tCREATE TABLE IF NOT EXISTS runs (\n    49→\t\t\tid TEXT PRIMARY KEY,\n    50→\t\t\tworkflow_name TEXT NOT NULL,\n    51→\t\t\tstate TEXT NOT NULL,\n    52→\t\t\tactive_steps TEXT,\n    53→\t\t\tstarted_at TEXT,\n    54→\t\t\tcompleted_at TEXT\n    55→\t\t);\n    56→\t\tCREATE TABLE IF NOT EXISTS step_executions (\n    57→\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    58→\t\t\trun_id TEXT NOT NULL,\n    59→\t\t\tstep_name TEXT NOT NULL,\n    60→\t\t\tresult TEXT,\n    61→\t\t\tstarted_at TEXT NOT NULL,\n    62→\t\t\tcompleted_at TEXT,\n    63→\t\t\tlogs TEXT,\n    64→\t\t\tgit_ref TEXT,\n    65→\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    66→\t\t);\n    67→\t`)\n    68→\tif err != nil {\n    69→\t\treturn err\n    70→\t}\n    71→\n    72→\t// Evolution schema additions (idempotent)\n    73→\talterStmts := []string{\n    74→\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n    75→\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n    76→\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n    77→\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n    78→\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n    79→\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n    80→\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n    81→\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n    82→\t\t`ALTER TABLE runs ADD COLUMN title TEXT NOT NULL DEFAULT ''`,\n    83→\t}\n    84→\tfor _, stmt := range alterStmts {\n    85→\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n    86→\t}\n    87→\n    88→\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n    89→\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    90→\t\trun_id TEXT NOT NULL,\n    91→\t\tstep_name TEXT,\n    92→\t\tfile_type TEXT NOT NULL,\n    93→\t\tfile_path TEXT NOT NULL,\n    94→\t\tfile_size INTEGER,\n    95→\t\tcreated_at TEXT NOT NULL,\n    96→\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    97→\t)`)\n    98→\tif errLog != nil {\n    99→\t\treturn errLog\n   100→\t}\n   101→\n   102→\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n   103→\t\trun_id TEXT PRIMARY KEY,\n   104→\t\tbranch TEXT NOT NULL,\n   105→\t\tproject TEXT NOT NULL,\n   106→\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n   107→\t\tenqueued_at TEXT NOT NULL,\n   108→\t\tcompleted_at TEXT\n   109→\t)`)\n   110→\tif errMQ != nil {\n   111→\t\treturn errMQ\n   112→\t}\n   113→\n   114→\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n   115→\t\tid TEXT PRIMARY KEY,\n   116→\t\tproject_dir TEXT NOT NULL,\n   117→\t\tworkflow_name TEXT NOT NULL,\n   118→\t\ttrigger_run_id TEXT NOT NULL,\n   119→\t\tcreated_at TEXT NOT NULL,\n   120→\t\tclassification TEXT,\n   121→\t\tchanges_json TEXT NOT NULL,\n   122→\t\tknowledge_delta TEXT\n   123→\t)`)\n   124→\tif err2 != nil {\n   125→\t\treturn err2\n   126→\t}\n   127→\n   128→\treturn nil\n   129→}\n   130→\n   131→func (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n   132→\t_, err := s.db.ExecContext(ctx,\n   133→\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept, title)\n   134→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   135→\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n   136→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, run.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title,\n   137→\t)\n   138→\treturn err\n   139→}\n   140→\n   141→func (s *Store) GetRun(ctx context.Context, id string) (*domain.Run, error) {\n   142→\trow := s.db.QueryRowContext(ctx,\n   143→\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,'') FROM runs WHERE id = ?`, id)\n   144→\n   145→\trun := &domain.Run{}\n   146→\tvar activeSteps, startedAt, completedAt string\n   147→\tvar containerKept int\n   148→\terr := row.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title)\n   149→\tif err == sql.ErrNoRows {\n   150→\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n   151→\t}\n   152→\tif err != nil {\n   153→\t\treturn nil, err\n   154→\t}\n   155→\n   156→\trun.SetActiveStepsFromString(activeSteps)\n   157→\trun.StartedAt = parseTime(startedAt)\n   158→\trun.CompletedAt = parseTime(completedAt)\n   159→\trun.ContainerKept = containerKept != 0\n   160→\treturn run, nil\n   161→}\n   162→\n   163→func (s *Store) UpdateRun(ctx context.Context, run *domain.Run) error {\n   164→\t_, err := s.db.ExecContext(ctx,\n   165→\t\t`UPDATE runs SET state = ?, active_steps = ?, started_at = ?, completed_at = ?, error_message = ?, container_id = ?, base_sha = ?, container_kept = ?, title = ? WHERE id = ?`,\n   166→\t\tstring(run.State), run.ActiveStepsString(),\n   167→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt),\n   168→\t\trun.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, run.ID,\n   169→\t)\n   170→\treturn err\n   171→}\n   172→\n   173→func (s *Store) DeleteRun(ctx context.Context, id string) error {\n   174→\t_, err := s.db.ExecContext(ctx, `DELETE FROM step_executions WHERE run_id = ?`, id)\n   175→\tif err != nil {\n   176→\t\treturn err\n   177→\t}\n   178→\t_, err = s.db.ExecContext(ctx, `DELETE FROM runs WHERE id = ?`, id)\n   179→\treturn err\n   180→}\n   181→\n   182→func (s *Store) ListRuns(ctx context.Context, since time.Time) ([]*domain.Run, error) {\n   183→\tvar rows *sql.Rows\n   184→\tvar err error\n   185→\tif since.IsZero() {\n   186→\t\trows, err = s.db.QueryContext(ctx,\n   187→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,'') FROM runs ORDER BY started_at DESC`)\n   188→\t} else {\n   189→\t\trows, err = s.db.QueryContext(ctx,\n   190→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,'') FROM runs WHERE started_at >= ? ORDER BY started_at DESC`,\n   191→\t\t\tformatTime(since))\n   192→\t}\n   193→\tif err != nil {\n   194→\t\treturn nil, err\n   195→\t}\n   196→\tdefer rows.Close()\n   197→\n   198→\tvar runs []*domain.Run\n   199→\tfor rows.Next() {\n   200→\t\trun := &domain.Run{}\n   201→\t\tvar activeSteps, startedAt, completedAt string\n   202→\t\tvar containerKept int\n   203→\t\tif err := rows.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title); err != nil {\n   204→\t\t\treturn nil, err\n   205→\t\t}\n   206→\t\trun.SetActiveStepsFromString(activeSteps)\n   207→\t\trun.StartedAt = parseTime(startedAt)\n   208→\t\trun.CompletedAt = parseTime(completedAt)\n   209→\t\trun.ContainerKept = containerKept != 0\n   210→\t\truns = append(runs, run)\n   211→\t}\n   212→\treturn runs, rows.Err()\n   213→}\n   214→\n   215→func (s *Store) ListRunsByProject(ctx context.Context, projectDir string, since time.Time) ([]*domain.Run, error) {\n   216→\tvar rows *sql.Rows\n   217→\tvar err error\n   218→\tif since.IsZero() {\n   219→\t\trows, err = s.db.QueryContext(ctx,\n   220→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,'') FROM runs WHERE project_dir = ? ORDER BY started_at DESC`,\n   221→\t\t\tprojectDir)\n   222→\t} else {\n   223→\t\trows, err = s.db.QueryContext(ctx,\n   224→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,'') FROM runs WHERE project_dir = ? AND started_at >= ? ORDER BY started_at DESC`,\n   225→\t\t\tprojectDir, formatTime(since))\n   226→\t}\n   227→\tif err != nil {\n   228→\t\treturn nil, err\n   229→\t}\n   230→\tdefer rows.Close()\n   231→\n   232→\tvar runs []*domain.Run\n   233→\tfor rows.Next() {\n   234→\t\trun := &domain.Run{}\n   235→\t\tvar activeSteps, startedAt, completedAt string\n   236→\t\tvar containerKept int\n   237→\t\tif err := rows.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title); err != nil {\n   238→\t\t\treturn nil, err\n   239→\t\t}\n   240→\t\trun.SetActiveStepsFromString(activeSteps)\n   241→\t\trun.StartedAt = parseTime(startedAt)\n   242→\t\trun.CompletedAt = parseTime(completedAt)\n   243→\t\trun.ContainerKept = containerKept != 0\n   244→\t\truns = append(runs, run)\n   245→\t}\n   246→\treturn runs, rows.Err()\n   247→}\n   248→\n   249→func (s *Store) ListProjects(ctx context.Context) ([]string, error) {\n   250→\trows, err := s.db.QueryContext(ctx,\n   251→\t\t`SELECT DISTINCT project_dir FROM runs WHERE project_dir != '' ORDER BY project_dir`)\n   252→\tif err != nil {\n   253→\t\treturn nil, err\n   254→\t}\n   255→\tdefer rows.Close()\n   256→\n   257→\tvar projects []string\n   258→\tfor rows.Next() {\n   259→\t\tvar dir string\n   260→\t\tif err := rows.Scan(&dir); err != nil {\n   261→\t\t\treturn nil, err\n   262→\t\t}\n   263→\t\tprojects = append(projects, dir)\n   264→\t}\n   265→\treturn projects, rows.Err()\n   266→}\n   267→\n   268→func (s *Store) SaveCapture(ctx context.Context, runID string, exec *domain.StepExecution) error {\n   269→\t_, err := s.db.ExecContext(ctx,\n   270→\t\t`INSERT INTO step_executions (run_id, step_name, result, started_at, completed_at, logs, git_ref)\n   271→\t\t VALUES (?, ?, ?, ?, ?, ?, ?)`,\n   272→\t\trunID, exec.StepName, exec.Result,\n   273→\t\tformatTime(exec.StartedAt), formatTime(exec.CompletedAt),\n   274→\t\texec.Logs, exec.GitRef,\n   275→\t)\n   276→\treturn err\n   277→}\n   278→\n   279→func (s *Store) GetCaptures(ctx context.Context, runID string) ([]*domain.StepExecution, error) {\n   280→\trows, err := s.db.QueryContext(ctx,\n   281→\t\t`SELECT step_name, result, started_at, completed_at, COALESCE(logs,''), COALESCE(git_ref,'')\n   282→\t\t FROM step_executions WHERE run_id = ? ORDER BY id`, runID)\n   283→\tif err != nil {\n   284→\t\treturn nil, err\n   285→\t}\n   286→\tdefer rows.Close()\n   287→\n   288→\tvar execs []*domain.StepExecution\n   289→\tfor rows.Next() {\n   290→\t\te := &domain.StepExecution{}\n   291→\t\tvar startedAt, completedAt string\n   292→\t\tif err := rows.Scan(&e.StepName, &e.Result, &startedAt, &completedAt, &e.Logs, &e.GitRef); err != nil {\n   293→\t\t\treturn nil, err\n   294→\t\t}\n   295→\t\te.StartedAt = parseTime(startedAt)\n   296→\t\te.CompletedAt = parseTime(completedAt)\n   297→\t\texecs = append(execs, e)\n   298→\t}\n   299→\treturn execs, rows.Err()\n   300→}\n   301→\n   302→func (s *Store) SaveLogFile(ctx context.Context, entry *ports.LogFileEntry) error {\n   303→\t_, err := s.db.ExecContext(ctx,\n   304→\t\t`INSERT INTO log_files (run_id, step_name, file_type, file_path, file_size, created_at)\n   305→\t\t VALUES (?, ?, ?, ?, ?, ?)`,\n   306→\t\tentry.RunID, entry.StepName, entry.FileType, entry.FilePath, entry.FileSize,\n   307→\t\tformatTime(entry.CreatedAt),\n   308→\t)\n   309→\treturn err\n   310→}\n   311→\n   312→func (s *Store) GetLogFiles(ctx context.Context, runID string) ([]*ports.LogFileEntry, error) {\n   313→\trows, err := s.db.QueryContext(ctx,\n   314→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   315→\t\t FROM log_files WHERE run_id = ? ORDER BY id`, runID)\n   316→\tif err != nil {\n   317→\t\treturn nil, err\n   318→\t}\n   319→\tdefer rows.Close()\n   320→\treturn scanLogFiles(rows)\n   321→}\n   322→\n   323→func (s *Store) GetLogFilesByStep(ctx context.Context, runID, stepName string) ([]*ports.LogFileEntry, error) {\n   324→\trows, err := s.db.QueryContext(ctx,\n   325→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   326→\t\t FROM log_files WHERE run_id = ? AND step_name = ? ORDER BY id`, runID, stepName)\n   327→\tif err != nil {\n   328→\t\treturn nil, err\n   329→\t}\n   330→\tdefer rows.Close()\n   331→\treturn scanLogFiles(rows)\n   332→}\n   333→\n   334→func (s *Store) GetLogFileByType(ctx context.Context, runID, fileType string) ([]*ports.LogFileEntry, error) {\n   335→\trows, err := s.db.QueryContext(ctx,\n   336→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   337→\t\t FROM log_files WHERE run_id = ? AND file_type = ? ORDER BY id`, runID, fileType)\n   338→\tif err != nil {\n   339→\t\treturn nil, err\n   340→\t}\n   341→\tdefer rows.Close()\n   342→\treturn scanLogFiles(rows)\n   343→}\n   344→\n   345→func scanLogFiles(rows *sql.Rows) ([]*ports.LogFileEntry, error) {\n   346→\tvar entries []*ports.LogFileEntry\n   347→\tfor rows.Next() {\n   348→\t\te := &ports.LogFileEntry{}\n   349→\t\tvar createdAt string\n   350→\t\tif err := rows.Scan(&e.ID, &e.RunID, &e.StepName, &e.FileType, &e.FilePath, &e.FileSize, &createdAt); err != nil {\n   351→\t\t\treturn nil, err\n   352→\t\t}\n   353→\t\te.CreatedAt = parseTime(createdAt)\n   354→\t\tentries = append(entries, e)\n   355→\t}\n   356→\treturn entries, rows.Err()\n   357→}\n   358→\n   359→func (s *Store) SaveEvolution(ctx context.Context, entry *ports.EvolutionEntry) error {\n   360→\t_, err := s.db.ExecContext(ctx,\n   361→\t\t`INSERT INTO evolution_log (id, project_dir, workflow_name, trigger_run_id, created_at, classification, changes_json, knowledge_delta)\n   362→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,\n   363→\t\tentry.ID, entry.ProjectDir, entry.WorkflowName, entry.TriggerRunID,\n   364→\t\tformatTime(entry.CreatedAt), entry.Classification, entry.ChangesJSON, entry.KnowledgeDelta,\n   365→\t)\n   366→\treturn err\n   367→}\n   368→\n   369→func (s *Store) GetLastEvolution(ctx context.Context, projectDir, workflowName string) (*ports.EvolutionEntry, error) {\n   370→\trow := s.db.QueryRowContext(ctx,\n   371→\t\t`SELECT id, project_dir, workflow_name, trigger_run_id, created_at, COALESCE(classification,''), changes_json, COALESCE(knowledge_delta,'')\n   372→\t\t FROM evolution_log WHERE project_dir = ? AND workflow_name = ? ORDER BY created_at DESC LIMIT 1`,\n   373→\t\tprojectDir, workflowName)\n   374→\n   375→\tentry := &ports.EvolutionEntry{}\n   376→\tvar createdAt string\n   377→\terr := row.Scan(&entry.ID, &entry.ProjectDir, &entry.WorkflowName, &entry.TriggerRunID,\n   378→\t\t&createdAt, &entry.Classification, &entry.ChangesJSON, &entry.KnowledgeDelta)\n   379→\tif err == sql.ErrNoRows {\n   380→\t\treturn nil, nil\n   381→\t}\n   382→\tif err != nil {\n   383→\t\treturn nil, err\n   384→\t}\n   385→\tentry.CreatedAt = parseTime(createdAt)\n   386→\treturn entry, nil\n   387→}\n   388→\n   389→func (s *Store) ListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error) {\n   390→\tvar rows *sql.Rows\n   391→\tvar err error\n   392→\n   393→\tif sinceRunID == \"\" {\n   394→\t\trows, err = s.db.QueryContext(ctx,\n   395→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,'')\n   396→\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? ORDER BY started_at ASC`,\n   397→\t\t\tprojectDir, workflowName)\n   398→\t} else {\n   399→\t\trows, err = s.db.QueryContext(ctx,\n   400→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,'')\n   401→\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? AND started_at > (SELECT started_at FROM runs WHERE id = ?)\n   402→\t\t\t ORDER BY started_at ASC`,\n   403→\t\t\tprojectDir, workflowName, sinceRunID)\n   404→\t}\n   405→\tif err != nil {\n   406→\t\treturn nil, err\n   407→\t}\n   408→\tdefer rows.Close()\n   409→\n   410→\tvar runs []*domain.Run\n   411→\tfor rows.Next() {\n   412→\t\trun := &domain.Run{}\n   413→\t\tvar activeSteps, startedAt, completedAt string\n   414→\t\tvar containerKept int\n   415→\t\tif err := rows.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title); err != nil {\n   416→\t\t\treturn nil, err\n   417→\t\t}\n   418→\t\trun.SetActiveStepsFromString(activeSteps)\n   419→\t\trun.StartedAt = parseTime(startedAt)\n   420→\t\trun.CompletedAt = parseTime(completedAt)\n   421→\t\trun.ContainerKept = containerKept != 0\n   422→\t\truns = append(runs, run)\n   423→\t}\n   424→\treturn runs, rows.Err()\n   425→}\n   426→\n   427→\n   428→func (s *Store) FailStaleRuns(ctx context.Context) (int64, error) {\n   429→\tnow := formatTime(time.Now())\n   430→\tres, err := s.db.ExecContext(ctx,\n   431→\t\t`UPDATE runs SET state = 'failed', completed_at = ?, error_message = 'daemon restarted while run was active'\n   432→\t\t WHERE state IN ('pending', 'running')`,\n   433→\t\tnow,\n   434→\t)\n   435→\tif err != nil {\n   436→\t\treturn 0, err\n   437→\t}\n   438→\treturn res.RowsAffected()\n   439→}\n   440→\n   441→func formatTime(t time.Time) string {\n   442→\tif t.IsZero() {\n   443→\t\treturn \"\"\n   444→\t}\n   445→\treturn t.Format(time.RFC3339Nano)\n   446→}\n   447→\n   448→func parseTime(s string) time.Time {\n   449→\tif s == \"\" {\n   450→\t\treturn time.Time{}\n   451→\t}\n   452→\tt, _ := time.Parse(time.RFC3339Nano, s)\n   453→\treturn t\n   454→}\n   455→\n   456→func boolToInt(b bool) int {\n   457→\tif b {\n   458→\t\treturn 1\n   459→\t}\n   460→\treturn 0\n   461→}\n   462→"}]},"parent_tool_use_id":"toolu_01AzarRAMPGBPEX9A84eRtqF","session_id":"bdac9138-b825-4d68-8fcd-895e48604ce0","uuid":"734600bb-507c-4696-8f84-c96bc287154a"}
