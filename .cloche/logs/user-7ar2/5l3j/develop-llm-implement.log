ite/store_test.go`**: `TestRunIsHost` (CRUD + list), `TestRunIsHost_BackwardCompat`\n- **`internal/host/executor_test.go`**: `TestRunner_PersistsHostRun`, `TestRunner_PersistsHostRunOnFailure`\n\nCLOCHE_RESULT:success"}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":680,"cache_read_input_tokens":150800,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":680},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"bdac9138-b825-4d68-8fcd-895e48604ce0","uuid":"a932ca7c-a9f1-4e01-90e0-f3ba2a53d1de"}
