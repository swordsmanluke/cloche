{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DRcwd9oXxz1BLQF3Mu3vSD","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1>\n     3→    <a href=\"/runs\">Runs</a> / {{.Run.ID}}\n     4→    <span class=\"badge badge-{{stateColor .Run.State}}\">{{.Run.State}}</span>\n     5→</h1>\n     6→\n     7→<div class=\"run-meta\">\n     8→    <dl>\n     9→        {{if .Run.Title}}<dt>Title</dt><dd>{{.Run.Title}}</dd>{{end}}\n    10→        <dt>Workflow</dt><dd>{{.Run.WorkflowName}}</dd>\n    11→        <dt>Started</dt><dd>{{formatTime .Run.StartedAt}}</dd>\n    12→        <dt>Completed</dt><dd>{{formatTime .Run.CompletedAt}}</dd>\n    13→        <dt>Container</dt><dd class=\"mono\">{{.Run.ContainerID}}</dd>\n    14→        <dt>Container Status</dt>\n    15→        <dd id=\"container-status\">\n    16→            {{if eq .ContainerState \"running\"}}\n    17→                <span class=\"badge badge-running\">Container running</span>\n    18→            {{else if eq .ContainerState \"stopped\"}}\n    19→                <span class=\"badge badge-stopped\">Container stopped</span>\n    20→                {{if or (eq .Run.State \"succeeded\") (eq .Run.State \"failed\") (eq .Run.State \"cancelled\")}}\n    21→                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n    22→                {{end}}\n    23→            {{else if eq .ContainerState \"available\"}}\n    24→                <span class=\"badge badge-succeeded\">Container available</span>\n    25→                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n    26→            {{else}}\n    27→                <span class=\"badge badge-pending\">Container removed</span>\n    28→            {{end}}\n    29→        </dd>\n    30→    </dl>\n    31→</div>\n    32→\n    33→{{if .Run.ErrorMessage}}\n    34→<div class=\"error-box\">{{.Run.ErrorMessage}}</div>\n    35→{{end}}\n    36→\n    37→<h2>Steps</h2>\n    38→<table class=\"runs-table\">\n    39→    <thead>\n    40→        <tr>\n    41→            <th>Step</th>\n    42→            <th>Result</th>\n    43→            <th>Started</th>\n    44→            <th>Duration</th>\n    45→        </tr>\n    46→    </thead>\n    47→    <tbody id=\"steps-body\">\n    48→    {{if .Steps}}\n    49→        {{range .Steps}}\n    50→        <tr class=\"step-row\" data-run-id=\"{{$.Run.ID}}\" data-step=\"{{.StepName}}\" data-index=\"{{.Index}}\">\n    51→            <td>{{.StepName}}</td>\n    52→            <td>{{if .Result}}<span class=\"badge badge-{{if eq .Result \"success\"}}succeeded{{else if eq .Result \"fail\"}}failed{{else}}pending{{end}}\">{{.Result}}</span>{{else}}<span class=\"badge badge-running\">running</span>{{end}}</td>\n    53→            <td>{{formatTime .StartedAt}}</td>\n    54→            <td>{{.Duration}}</td>\n    55→        </tr>\n    56→        <tr class=\"output-row\" id=\"output-{{.Index}}\" style=\"display:none\">\n    57→            <td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>\n    58→        </tr>\n    59→        {{end}}\n    60→    {{else}}\n    61→        <tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>\n    62→    {{end}}\n    63→    </tbody>\n    64→</table>\n    65→\n    66→<h2>\n    67→    Log\n    68→    <span id=\"log-status\" class=\"badge badge-running\" style=\"font-size:0.7rem; margin-left:0.5rem;\">Live</span>\n    69→</h2>\n    70→<div id=\"log-viewer\" class=\"log-viewer\"><pre id=\"log-content\"></pre></div>\n    71→{{end}}\n    72→\n    73→{{define \"scripts\"}}\n    74→<script>\n    75→(function() {\n    76→    var runState = '{{.Run.State}}';\n    77→    var runID = '{{.Run.ID}}';\n    78→\n    79→    // --- Log Viewer ---\n    80→    var logContent = document.getElementById('log-content');\n    81→    var logViewer = document.getElementById('log-viewer');\n    82→    var logStatus = document.getElementById('log-status');\n    83→    var autoScroll = true;\n    84→\n    85→    // Track scroll position to enable/disable auto-scroll\n    86→    logViewer.addEventListener('scroll', function() {\n    87→        var atBottom = logViewer.scrollHeight - logViewer.scrollTop - logViewer.clientHeight < 40;\n    88→        autoScroll = atBottom;\n    89→    });\n    90→\n    91→    function appendLogLine(line) {\n    92→        var span = document.createElement('span');\n    93→        span.className = 'log-line log-type-' + (line.type || 'script');\n    94→        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';\n    95→        logContent.appendChild(span);\n    96→        if (autoScroll) {\n    97→            logViewer.scrollTop = logViewer.scrollHeight;\n    98→        }\n    99→    }\n   100→\n   101→    function markComplete() {\n   102→        logStatus.textContent = 'Complete';\n   103→        logStatus.className = 'badge badge-succeeded';\n   104→    }\n   105→\n   106→    // Connect to SSE stream\n   107→    var source = new EventSource('/api/runs/' + runID + '/stream');\n   108→    source.onmessage = function(e) {\n   109→        try {\n   110→            var line = JSON.parse(e.data);\n   111→            appendLogLine(line);\n   112→        } catch(err) {}\n   113→    };\n   114→    source.addEventListener('done', function(e) {\n   115→        markComplete();\n   116→        source.close();\n   117→    });\n   118→    source.onerror = function() {\n   119→        markComplete();\n   120→        source.close();\n   121→    };\n   122→\n   123→    // If already complete, mark the badge immediately\n   124→    if (runState === 'succeeded' || runState === 'failed' || runState === 'cancelled') {\n   125→        logStatus.textContent = 'Complete';\n   126→        logStatus.className = 'badge badge-succeeded';\n   127→    }\n   128→\n   129→    // --- Steps Polling (for active runs) ---\n   130→    if (runState !== 'succeeded' && runState !== 'failed' && runState !== 'cancelled') {\n   131→        function poll() {\n   132→            fetch('/api/runs/' + runID)\n   133→                .then(function(r) { return r.json(); })\n   134→                .then(function(data) {\n   135→                    if (data.state !== runState) {\n   136→                        location.reload();\n   137→                        return;\n   138→                    }\n   139→                    // Update container status\n   140→                    var statusEl = document.getElementById('container-status');\n   141→                    if (statusEl && data.container_state) {\n   142→                        var cs = data.container_state;\n   143→                        if (cs === 'running') {\n   144→                            statusEl.innerHTML = '<span class=\"badge badge-running\">Container running</span>';\n   145→                        } else if (cs === 'stopped') {\n   146→                            var stoppedHtml = '<span class=\"badge badge-stopped\">Container stopped</span>';\n   147→                            if (data.state === 'succeeded' || data.state === 'failed' || data.state === 'cancelled') {\n   148→                                stoppedHtml += ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n   149→                            }\n   150→                            statusEl.innerHTML = stoppedHtml;\n   151→                        } else if (cs === 'available') {\n   152→                            statusEl.innerHTML = '<span class=\"badge badge-succeeded\">Container available</span>' +\n   153→                                ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n   154→                        } else {\n   155→                            statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n   156→                        }\n   157→                    }\n   158→                    var tbody = document.getElementById('steps-body');\n   159→                    if (!data.steps || data.steps.length === 0) {\n   160→                        tbody.innerHTML = '<tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>';\n   161→                        return;\n   162→                    }\n   163→\n   164→                    // Capture current accordion state before updating\n   165→                    var openAccordions = {};\n   166→                    var loadedOutputs = {};\n   167→                    var outputRows = tbody.querySelectorAll('.output-row');\n   168→                    for (var j = 0; j < outputRows.length; j++) {\n   169→                        var id = outputRows[j].id;\n   170→                        if (outputRows[j].style.display !== 'none') {\n   171→                            openAccordions[id] = true;\n   172→                        }\n   173→                        var pre = outputRows[j].querySelector('.step-output');\n   174→                        if (pre && pre.textContent !== 'Loading...') {\n   175→                            loadedOutputs[id] = pre.textContent;\n   176→                        }\n   177→                    }\n   178→\n   179→                    // Build updated step rows, preserving accordion state\n   180→                    var html = '';\n   181→                    for (var i = 0; i < data.steps.length; i++) {\n   182→                        var s = data.steps[i];\n   183→                        var badge = '';\n   184→                        if (s.result) {\n   185→                            var cls = s.result === 'success' ? 'succeeded' : s.result === 'fail' ? 'failed' : 'pending';\n   186→                            badge = '<span class=\"badge badge-' + cls + '\">' + escapeHtml(s.result) + '</span>';\n   187→                        } else {\n   188→                            badge = '<span class=\"badge badge-running\">running</span>';\n   189→                        }\n   190→                        var outputId = 'output-' + i;\n   191→                        var isOpen = openAccordions[outputId];\n   192→                        html += '<tr class=\"step-row\" data-run-id=\"' + escapeHtml(runID) + '\" data-step=\"' + escapeHtml(s.step_name) + '\" data-index=\"' + i + '\">' +\n   193→                            '<td>' + escapeHtml(s.step_name) + '</td>' +\n   194→                            '<td>' + badge + '</td>' +\n   195→                            '<td>' + s.started_at + '</td>' +\n   196→                            '<td>' + s.duration + '</td>' +\n   197→                            '</tr>' +\n   198→                            '<tr class=\"output-row\" id=\"' + outputId + '\"' + (isOpen ? '' : ' style=\"display:none\"') + '>' +\n   199→                            '<td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>' +\n   200→                            '</tr>';\n   201→                    }\n   202→                    tbody.innerHTML = html;\n   203→\n   204→                    // Restore loaded output content for open accordions\n   205→                    for (var key in loadedOutputs) {\n   206→                        var row = document.getElementById(key);\n   207→                        if (row) {\n   208→                            var pre = row.querySelector('.step-output');\n   209→                            if (pre) {\n   210→                                pre.textContent = loadedOutputs[key];\n   211→                            }\n   212→                        }\n   213→                    }\n   214→\n   215→                    // Re-fetch output for accordions that were open but had no cached content\n   216→                    for (var key in openAccordions) {\n   217→                        if (!loadedOutputs[key]) {\n   218→                            var row = document.getElementById(key);\n   219→                            if (row) {\n   220→                                var stepRow = row.previousElementSibling;\n   221→                                if (stepRow && stepRow.dataset.runId && stepRow.dataset.step) {\n   222→                                    (function(r, rid, sname) {\n   223→                                        var pre = r.querySelector('.step-output');\n   224→                                        fetch('/api/runs/' + rid + '/steps/' + sname + '/output')\n   225→                                            .then(function(resp) {\n   226→                                                if (!resp.ok) return 'No output available.';\n   227→                                                return resp.text();\n   228→                                            })\n   229→                                            .then(function(text) { pre.textContent = text; })\n   230→                                            .catch(function() { pre.textContent = 'Failed to load output.'; });\n   231→                                    })(row, stepRow.dataset.runId, stepRow.dataset.step);\n   232→                                }\n   233→                            }\n   234→                        }\n   235→                    }\n   236→                })\n   237→                .catch(function() {});\n   238→        }\n   239→        setInterval(poll, 2000);\n   240→    }\n   241→\n   242→    function escapeHtml(s) {\n   243→        if (!s) return '';\n   244→        var d = document.createElement('div');\n   245→        d.appendChild(document.createTextNode(s));\n   246→        return d.innerHTML;\n   247→    }\n   248→})();\n   249→\n   250→// Delete container\n   251→    window.deleteContainer = function(runID) {\n   252→        var btn = document.getElementById('delete-container-btn');\n   253→        if (btn) btn.disabled = true;\n   254→        fetch('/api/runs/' + runID + '/container', { method: 'DELETE' })\n   255→            .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })\n   256→            .then(function(res) {\n   257→                var statusEl = document.getElementById('container-status');\n   258→                if (res.ok) {\n   259→                    statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n   260→                } else {\n   261→                    if (btn) btn.disabled = false;\n   262→                    alert('Failed to delete container: ' + (res.data.error || 'unknown error'));\n   263→                }\n   264→            })\n   265→            .catch(function() {\n   266→                if (btn) btn.disabled = false;\n   267→                alert('Failed to delete container');\n   268→            });\n   269→    };\n   270→\n   271→    // Toggle step output rows\n   272→document.addEventListener('click', function(e) {\n   273→    var row = e.target.closest('.step-row');\n   274→    if (!row) return;\n   275→    var idx = row.dataset.index;\n   276→    var outputRow = document.getElementById('output-' + idx);\n   277→    if (!outputRow) return;\n   278→\n   279→    if (outputRow.style.display === 'none') {\n   280→        outputRow.style.display = '';\n   281→        var pre = outputRow.querySelector('.step-output');\n   282→        if (pre.textContent === 'Loading...') {\n   283→            var runId = row.dataset.runId;\n   284→            var step = row.dataset.step;\n   285→            fetch('/api/runs/' + runId + '/steps/' + step + '/output')\n   286→                .then(function(r) {\n   287→                    if (!r.ok) return 'No output available.';\n   288→                    return r.text();\n   289→                })\n   290→                .then(function(text) { pre.textContent = text; })\n   291→                .catch(function() { pre.textContent = 'Failed to load output.'; });\n   292→        }\n   293→    } else {\n   294→        outputRow.style.display = 'none';\n   295→    }\n   296→});\n   297→</script>\n   298→{{end}}\n   299→"}]},"parent_tool_use_id":null,"session_id":"bdac9138-b825-4d68-8fcd-895e48604ce0","uuid":"d28b3905-e8d0-4747-93be-06bc5e658d69","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/run_detail.html","content":"{{define \"content\"}}\n<h1>\n    <a href=\"/runs\">Runs</a> / {{.Run.ID}}\n    <span class=\"badge badge-{{stateColor .Run.State}}\">{{.Run.State}}</span>\n</h1>\n\n<div class=\"run-meta\">\n    <dl>\n        {{if .Run.Title}}<dt>Title</dt><dd>{{.Run.Title}}</dd>{{end}}\n        <dt>Workflow</dt><dd>{{.Run.WorkflowName}}</dd>\n        <dt>Started</dt><dd>{{formatTime .Run.StartedAt}}</dd>\n        <dt>Completed</dt><dd>{{formatTime .Run.CompletedAt}}</dd>\n        <dt>Container</dt><dd class=\"mono\">{{.Run.ContainerID}}</dd>\n        <dt>Container Status</dt>\n        <dd id=\"container-status\">\n            {{if eq .ContainerState \"running\"}}\n                <span class=\"badge badge-running\">Container running</span>\n            {{else if eq .ContainerState \"stopped\"}}\n                <span class=\"badge badge-stopped\">Container stopped</span>\n                {{if or (eq .Run.State \"succeeded\") (eq .Run.State \"failed\") (eq .Run.State \"cancelled\")}}\n                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n                {{end}}\n            {{else if eq .ContainerState \"available\"}}\n                <span class=\"badge badge-succeeded\">Container available</span>\n                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n            {{else}}\n                <span class=\"badge badge-pending\">Container removed</span>\n            {{end}}\n        </dd>\n    </dl>\n</div>\n\n{{if .Run.ErrorMessage}}\n<div class=\"error-box\">{{.Run.ErrorMessage}}</div>\n{{end}}\n\n<h2>Steps</h2>\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Step</th>\n            <th>Result</th>\n            <th>Started</th>\n            <th>Duration</th>\n        </tr>\n    </thead>\n    <tbody id=\"steps-body\">\n    {{if .Steps}}\n        {{range .Steps}}\n        <tr class=\"step-row\" data-run-id=\"{{$.Run.ID}}\" data-step=\"{{.StepName}}\" data-index=\"{{.Index}}\">\n            <td>{{.StepName}}</td>\n            <td>{{if .Result}}<span class=\"badge badge-{{if eq .Result \"success\"}}succeeded{{else if eq .Result \"fail\"}}failed{{else}}pending{{end}}\">{{.Result}}</span>{{else}}<span class=\"badge badge-running\">running</span>{{end}}</td>\n            <td>{{formatTime .StartedAt}}</td>\n            <td>{{.Duration}}</td>\n        </tr>\n        <tr class=\"output-row\" id=\"output-{{.Index}}\" style=\"display:none\">\n            <td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>\n        </tr>\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n\n<h2>\n    Log\n    <span id=\"log-status\" class=\"badge badge-running\" style=\"font-size:0.7rem; margin-left:0.5rem;\">Live</span>\n</h2>\n<div id=\"log-viewer\" class=\"log-viewer\"><pre id=\"log-content\"></pre></div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var runState = '{{.Run.State}}';\n    var runID = '{{.Run.ID}}';\n\n    // --- Log Viewer ---\n    var logContent = document.getElementById('log-content');\n    var logViewer = document.getElementById('log-viewer');\n    var logStatus = document.getElementById('log-status');\n    var autoScroll = true;\n\n    // Track scroll position to enable/disable auto-scroll\n    logViewer.addEventListener('scroll', function() {\n        var atBottom = logViewer.scrollHeight - logViewer.scrollTop - logViewer.clientHeight < 40;\n        autoScroll = atBottom;\n    });\n\n    function appendLogLine(line) {\n        var span = document.createElement('span');\n        span.className = 'log-line log-type-' + (line.type || 'script');\n        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';\n        logContent.appendChild(span);\n        if (autoScroll) {\n            logViewer.scrollTop = logViewer.scrollHeight;\n        }\n    }\n\n    function markComplete() {\n        logStatus.textContent = 'Complete';\n        logStatus.className = 'badge badge-succeeded';\n    }\n\n    // Connect to SSE stream\n    var source = new EventSource('/api/runs/' + runID + '/stream');\n    source.onmessage = function(e) {\n        try {\n            var line = JSON.parse(e.data);\n            appendLogLine(line);\n        } catch(err) {}\n    };\n    source.addEventListener('done', function(e) {\n        markComplete();\n        source.close();\n    });\n    source.onerror = function() {\n        markComplete();\n        source.close();\n    };\n\n    // If already complete, mark the badge immediately\n    if (runState === 'succeeded' || runState === 'failed' || runState === 'cancelled') {\n        logStatus.textContent = 'Complete';\n        logStatus.className = 'badge badge-succeeded';\n    }\n\n    // --- Steps Polling (for active runs) ---\n    if (runState !== 'succeeded' && runState !== 'failed' && runState !== 'cancelled') {\n        function poll() {\n            fetch('/api/runs/' + runID)\n                .then(function(r) { return r.json(); })\n                .then(function(data) {\n                    if (data.state !== runState) {\n                        location.reload();\n                        return;\n                    }\n                    // Update container status\n                    var statusEl = document.getElementById('container-status');\n                    if (statusEl && data.container_state) {\n                        var cs = data.container_state;\n                        if (cs === 'running') {\n                            statusEl.innerHTML = '<span class=\"badge badge-running\">Container running</span>';\n                        } else if (cs === 'stopped') {\n                            var stoppedHtml = '<span class=\"badge badge-stopped\">Container stopped</span>';\n                            if (data.state === 'succeeded' || data.state === 'failed' || data.state === 'cancelled') {\n                                stoppedHtml += ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n                            }\n                            statusEl.innerHTML = stoppedHtml;\n                        } else if (cs === 'available') {\n                            statusEl.innerHTML = '<span class=\"badge badge-succeeded\">Container available</span>' +\n                                ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n                        } else {\n                            statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n                        }\n                    }\n                    var tbody = document.getElementById('steps-body');\n                    if (!data.steps || data.steps.length === 0) {\n                        tbody.innerHTML = '<tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>';\n                        return;\n                    }\n\n                    // Capture current accordion state before updating\n                    var openAccordions = {};\n                    var loadedOutputs = {};\n                    var outputRows = tbody.querySelectorAll('.output-row');\n                    for (var j = 0; j < outputRows.length; j++) {\n                        var id = outputRows[j].id;\n                        if (outputRows[j].style.display !== 'none') {\n                            openAccordions[id] = true;\n                        }\n                        var pre = outputRows[j].querySelector('.step-output');\n                        if (pre && pre.textContent !== 'Loading...') {\n                            loadedOutputs[id] = pre.textContent;\n                        }\n                    }\n\n                    // Build updated step rows, preserving accordion state\n                    var html = '';\n                    for (var i = 0; i < data.steps.length; i++) {\n                        var s = data.steps[i];\n                        var badge = '';\n                        if (s.result) {\n                            var cls = s.result === 'success' ? 'succeeded' : s.result === 'fail' ? 'failed' : 'pending';\n                            badge = '<span class=\"badge badge-' + cls + '\">' + escapeHtml(s.result) + '</span>';\n                        } else {\n                            badge = '<span class=\"badge badge-running\">running</span>';\n                        }\n                        var outputId = 'output-' + i;\n                        var isOpen = openAccordions[outputId];\n                        html += '<tr class=\"step-row\" data-run-id=\"' + escapeHtml(runID) + '\" data-step=\"' + escapeHtml(s.step_name) + '\" data-index=\"' + i + '\">' +\n                            '<td>' + escapeHtml(s.step_name) + '</td>' +\n                            '<td>' + badge + '</td>' +\n                            '<td>' + s.started_at + '</td>' +\n                            '<td>' + s.duration + '</td>' +\n                            '</tr>' +\n                            '<tr class=\"output-row\" id=\"' + outputId + '\"' + (isOpen ? '' : ' style=\"display:none\"') + '>' +\n                            '<td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>' +\n                            '</tr>';\n                    }\n                    tbody.innerHTML = html;\n\n                    // Restore loaded output content for open accordions\n                    for (var key in loadedOutputs) {\n                        var row = document.getElementById(key);\n                        if (row) {\n                            var pre = row.querySelector('.step-output');\n                            if (pre) {\n                                pre.textContent = loadedOutputs[key];\n                            }\n                        }\n                    }\n\n                    // Re-fetch output for accordions that were open but had no cached content\n                    for (var key in openAccordions) {\n                        if (!loadedOutputs[key]) {\n                            var row = document.getElementById(key);\n                            if (row) {\n                                var stepRow = row.previousElementSibling;\n                                if (stepRow && stepRow.dataset.runId && stepRow.dataset.step) {\n                                    (function(r, rid, sname) {\n                                        var pre = r.querySelector('.step-output');\n                                        fetch('/api/runs/' + rid + '/steps/' + sname + '/output')\n                                            .then(function(resp) {\n                                                if (!resp.ok) return 'No output available.';\n                                                return resp.text();\n                                            })\n                                            .then(function(text) { pre.textContent = text; })\n                                            .catch(function() { pre.textContent = 'Failed to load output.'; });\n                                    })(row, stepRow.dataset.runId, stepRow.dataset.step);\n                                }\n                            }\n                        }\n                    }\n                })\n                .catch(function() {});\n        }\n        setInterval(poll, 2000);\n    }\n\n    function escapeHtml(s) {\n        if (!s) return '';\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n})();\n\n// Delete container\n    window.deleteContainer = function(runID) {\n        var btn = document.getElementById('delete-container-btn');\n        if (btn) btn.disabled = true;\n        fetch('/api/runs/' + runID + '/container', { method: 'DELETE' })\n            .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })\n            .then(function(res) {\n                var statusEl = document.getElementById('container-status');\n                if (res.ok) {\n                    statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n                } else {\n                    if (btn) btn.disabled = false;\n                    alert('Failed to delete container: ' + (res.data.error || 'unknown error'));\n                }\n            })\n            .catch(function() {\n                if (btn) btn.disabled = false;\n                alert('Failed to delete container');\n            });\n    };\n\n    // Toggle step output rows\ndocument.addEventListener('click', function(e) {\n    var row = e.target.closest('.step-row');\n    if (!row) return;\n    var idx = row.dataset.index;\n    var outputRow = document.getElementById('output-' + idx);\n    if (!outputRow) return;\n\n    if (outputRow.style.display === 'none') {\n        outputRow.style.display = '';\n        var pre = outputRow.querySelector('.step-output');\n        if (pre.textContent === 'Loading...') {\n            var runId = row.dataset.runId;\n            var step = row.dataset.step;\n            fetch('/api/runs/' + runId + '/steps/' + step + '/output')\n                .then(function(r) {\n                    if (!r.ok) return 'No output available.';\n                    return r.text();\n                })\n                .then(function(text) { pre.textContent = text; })\n                .catch(function() { pre.textContent = 'Failed to load output.'; });\n        }\n    } else {\n        outputRow.style.display = 'none';\n    }\n});\n</script>\n{{end}}\n","numLines":299,"startLine":1,"totalLines":299}}}
