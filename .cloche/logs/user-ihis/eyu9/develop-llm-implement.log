\n    56→\trequire.Error(t, err)\n    57→\tassert.Contains(t, err.Error(), \"fail\")\n    58→}\n    59→\n    60→func TestWorkflow_Validate_OrphanStep(t *testing.T) {\n    61→\twf := &domain.Workflow{\n    62→\t\tName: \"test-workflow\",\n    63→\t\tSteps: map[string]*domain.Step{\n    64→\t\t\t\"code\": {\n    65→\t\t\t\tName:    \"code\",\n    66→\t\t\t\tType:    domain.StepTypeAgent,\n    67→\t\t\t\tResults: []string{\"success\"},\n    68→\t\t\t},\n    69→\t\t\t\"orphan\": {\n    70→\t\t\t\tName:    \"orphan\",\n    71→\t\t\t\tType:    domain.StepTypeScript,\n    72→\t\t\t\tResults: []string{\"done\"},\n    73→\t\t\t},\n    74→\t\t},\n    75→\t\tWiring: []domain.Wire{\n    76→\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n    77→\t\t\t{From: \"orphan\", Result: \"done\", To: domain.StepDone},\n    78→\t\t},\n    79→\t\tEntryStep: \"code\",\n    80→\t}\n    81→\n    82→\terr := wf.Validate()\n    83→\trequire.Error(t, err)\n    84→\tassert.Contains(t, err.Error(), \"orphan\")\n    85→}\n    86→\n    87→func TestWorkflow_Validate_NoEntryStep(t *testing.T) {\n    88→\twf := &domain.Workflow{\n    89→\t\tName:      \"test-workflow\",\n    90→\t\tSteps:     map[string]*domain.Step{},\n    91→\t\tWiring:    []domain.Wire{},\n    92→\t\tEntryStep: \"\",\n    93→\t}\n    94→\n    95→\terr := wf.Validate()\n    96→\trequire.Error(t, err)\n    97→\tassert.Contains(t, err.Error(), \"entry\")\n    98→}\n    99→\n   100→func TestWorkflow_NextSteps(t *testing.T) {\n   101→\twf := &domain.Workflow{\n   102→\t\tName: \"test-workflow\",\n   103→\t\tSteps: map[string]*domain.Step{\n   104→\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   105→\t\t\t\"check\": {Name: \"check\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n   106→\t\t},\n   107→\t\tWiring: []domain.Wire{\n   108→\t\t\t{From: \"code\", Result: \"success\", To: \"check\"},\n   109→\t\t\t{From: \"check\", Result: \"pass\", To: domain.StepDone},\n   110→\t\t},\n   111→\t\tEntryStep: \"code\",\n   112→\t}\n   113→\n   114→\tnext, err := wf.NextSteps(\"code\", \"success\")\n   115→\trequire.NoError(t, err)\n   116→\tassert.Equal(t, []string{\"check\"}, next)\n   117→\n   118→\tnext, err = wf.NextSteps(\"check\", \"pass\")\n   119→\trequire.NoError(t, err)\n   120→\tassert.Equal(t, []string{domain.StepDone}, next)\n   121→\n   122→\tnext, err = wf.NextSteps(\"code\", \"nonexistent\")\n   123→\tassert.Error(t, err)\n   124→\tassert.Nil(t, next)\n   125→}\n   126→\n   127→func TestWorkflow_NextSteps_Fanout(t *testing.T) {\n   128→\twf := &domain.Workflow{\n   129→\t\tName: \"fanout\",\n   130→\t\tSteps: map[string]*domain.Step{\n   131→\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   132→\t\t\t\"test\": {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n   133→\t\t\t\"lint\": {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n   134→\t\t},\n   135→\t\tWiring: []domain.Wire{\n   136→\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n   137→\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n   138→\t\t\t{From: \"test\", Result: \"pass\", To: domain.StepDone},\n   139→\t\t\t{From: \"lint\", Result: \"pass\", To: domain.StepDone},\n   140→\t\t},\n   141→\t\tEntryStep: \"code\",\n   142→\t}\n   143→\n   144→\tnext, err := wf.NextSteps(\"code\", \"success\")\n   145→\trequire.NoError(t, err)\n   146→\tassert.Equal(t, []string{\"test\", \"lint\"}, next)\n   147→}\n   148→\n   149→func TestWorkflow_Validate_CollectValid(t *testing.T) {\n   150→\twf := &domain.Workflow{\n   151→\t\tName: \"parallel\",\n   152→\t\tSteps: map[string]*domain.Step{\n   153→\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   154→\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n   155→\t\t\t\"lint\":  {Name: \"lint\"