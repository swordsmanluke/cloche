  71→// Evaluate navigates the raw output bytes using the path segments.\n    72→// With no segments, it returns the raw output as a string.\n    73→// With segments, it parses the raw bytes as JSON and navigates using\n    74→// field access (SegmentField) and array indexing (SegmentIndex).\n    75→func (p OutputPath) Evaluate(raw []byte) (string, error) {\n    76→\tif len(p.Segments) == 0 {\n    77→\t\treturn string(raw), nil\n    78→\t}\n    79→\n    80→\tvar val any\n    81→\tif err := json.Unmarshal(raw, &val); err != nil {\n    82→\t\treturn \"\", fmt.Errorf(\"output is not valid JSON\")\n    83→\t}\n    84→\n    85→\tfor _, seg := range p.Segments {\n    86→\t\tswitch seg.Kind {\n    87→\t\tcase SegmentField:\n    88→\t\t\tm, ok := val.(map[string]any)\n    89→\t\t\tif !ok {\n    90→\t\t\t\treturn \"\", fmt.Errorf(\"expected object for .%s\", seg.Field)\n    91→\t\t\t}\n    92→\t\t\tval, ok = m[seg.Field]\n    93→\t\t\tif !ok {\n    94→\t\t\t\treturn \"\", fmt.Errorf(\"field %q not found\", seg.Field)\n    95→\t\t\t}\n    96→\t\tcase SegmentIndex:\n    97→\t\t\tarr, ok := val.([]any)\n    98→\t\t\tif !ok {\n    99→\t\t\t\treturn \"\", fmt.Errorf(\"expected array for [%d]\", seg.Index)\n   100→\t\t\t}\n   101→\t\t\tif seg.Index < 0 || seg.Index >= len(arr) {\n   102→\t\t\t\treturn \"\", fmt.Errorf(\"index %d out of range (len %d)\", seg.Index, len(arr))\n   103→\t\t\t}\n   104→\t\t\tval = arr[seg.Index]\n   105→\t\t}\n   106→\t}\n   107→\n   108→\tswitch v := val.(type) {\n   109→\tcase string:\n   110→\t\treturn v, nil\n   111→\tdefault:\n   112→\t\tb, _ := json.Marshal(v)\n   113→\t\treturn string(b), nil\n   114→\t}\n   115→}\n   116→\n   117→type CollectMode string\n   118→\n   119→const (\n   120→\tCollectAll CollectMode = \"all\"\n   121→\tCollectAny CollectMode = \"any\"\n   122→)\n   123→\n   124→type WireCondition struct {\n   125→\tStep   string\n   126→\tResult string\n   127→}\n   128→\n   129→type Collect struct {\n   130→\tMode       CollectMode\n   131→\tConditions []WireCondition\n   132→\tTo         string\n   133→}\n   134→\n   135→type Workflow struct {\n   136→\tName      string\n   137→\tLocation  WorkflowLocation  // host or container\n   138→\tSteps     map[string]*Step\n   139→\tWiring    []Wire\n   140→\tCollects  []Collect\n   141→\tEntryStep string\n   142→\tConfig    map[string]string // workflow-level config (e.g. \"container.image\")\n   143→}\n   144→\n   145→func (w *Workflow) Validate() error {\n   146→\tif w.EntryStep == \"\" {\n   147→\t\treturn fmt.Errorf(\"workflow %q: no entry step defined\", w.Name)\n   148→\t}\n   149→\tif _, ok := w.Steps[w.EntryStep]; !ok {\n   150→\t\treturn fmt.Errorf(\"workflow %q: entry step %q not found\", w.Name, w.EntryStep)\n   151→\t}\n   152→\n   153→\twired := make(map[string]map[string]bool)\n   154→\treachable := map[string]bool{w.EntryStep: true}\n   155→\tfor _, wire := range w.Wiring {\n   156→\t\tif wired[wire.From] == nil {\n   157→\t\t\twired[wire.From] = make(map[string]bool)\n   158→\t\t}\n   159→\t\twired[wire.From][wire.Result] = true\n   160→\t\tif wire.To != StepDone && wire.To != StepAbort {\n   161→\t\t\treachable[wire.To] = true\n   162→\t\t}\n   163→\t}\n   164→\n   165→\t// Validate collects and count their results as wired\n   166→\tfor _, c := range w.Collects {\n   167→\t\t// Validate target step exists\n   168→\t\tif c.To != StepDone && c.To != StepAbort {\n   169→\t\t\tif _, ok := w.Steps[c.To]; !ok {\n   170→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect target step %q not found\", w.Name, c.To)\n   171→\t\t\t}\n   172→\t\t\treachable[c.To] = true\n   173→\t\t}\n   174→\n   175→\t\tfor _, cond := range c.Conditions {\n   176→\t\t\t// Validate condition step exists\n   177→\t\t\tstep, ok := w.Steps[cond.Step]\n   178→\t\t\tif !ok {\n   179→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references unknown step %q\", w.Name, cond.Step)\n   180→\t\t\t}\n   181→\t\t\t// Validate condition result is declared\n   182→\t\t\tfound := false\n   183→\t\t\tfor _, r := range step.Results {\n   184→\t\t\t\tif r == cond.Result {\n   185→\t\t\t\t\tfound = true\n   186→\t\t\t\t\tbreak\n   187→\t\t\t\t}\n   188→\t\t\t}\n   189→\t\t\tif !found {\n   190→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references undeclared result %q on step %q\", w.Name, cond.Result, cond.Step)\n   191→\t\t\t}\n   192→\t\t\t// Mark as wired so the \"every result must be wired\" check passes\n   193→\t\t\tif wired[cond.Step] == nil {\n   194→\t\t\t\twired[cond.Step] = make(map[string]bool)\n   195→\t\t\t}\n   196→\t\t\twired[cond.Step][cond.Result] = true\n   197→\t\t}\n   198→\t}\n   199→\n   200→\tfor name, step := range w.Steps {\n   201→\t\tfor _, result := range step.Results {\n   202→\t\t\tif !wired[name][result] {\n   203→\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q result %q is not wired\", w.Name, name, result)\n   204→\t\t\t}\n   205→\t\t}\n   206→\t}\n   207→\n   208→\tfor name := range w.Steps {\n   209→\t\tif !reachable[name] {\n   210→\t\t\treturn fmt.Errorf(\"workflow %q: step %q is orphaned (unreachable)\", w.Name, name)\n   211→\t\t}\n   212→\t}\n   213→\n   214→\treturn nil\n   215→}\n   216→\n   217→// ValidateLocation checks that step types are compatible with the workflow location.\n   218→// workflow_name steps are only allowed in host workflows.\n   219→func (w *Workflow) ValidateLocation() error {\n   220→\tif w.Location == LocationContainer {\n   221→\t\tfor name, step := range w.Steps {\n   222→\t\t\tif step.Type == StepTypeWorkflow {\n   223→\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q uses workflow_name, which is only allowed in host workflows (host.cloche)\", w.Name, name)\n   224→\t\t\t}\n   225→\t\t}\n   226→\t}\n   227→\treturn nil\n   228→}\n   229→\n   230→// knownStepConfigKeys lists recognized step-level config keys.\n   231→// Keys with a \"container.\" prefix are also allowed.\n   232→var knownStepConfigKeys = map[string]bool{\n   233→\t\"prompt\":        true,\n   234→\t\"run\":           true,\n   235→\t\"max_attempts\":  true,\n   236→\t\"timeout\":       true,\n   237→\t\"agent_command\": true,\n   238→\t\"agent_args\":    true,\n   239→\t\"results\":       true,\n   240→\t\"feedback\":      true,\n   241→\t\"workflow_name\": true,\n   242→\t\"prompt_step\":   true,\n   243→}\n   244→\n   245→// ValidateConfig checks step config keys against known keys and returns\n   246→// warnings for any unrecognized keys (likely typos).\n   247→func (w *Workflow) ValidateConfig() []string {\n   248→\tvar warnings []string\n   249→\tfor name, step := range w.Steps {\n   250→\t\tfor key := range step.Config {\n   251→\t\t\tif knownStepConfigKeys[key] {\n   252→\t\t\t\tcontinue\n   253→\t\t\t}\n   254→\t\t\tif strings.HasPrefix(key, \"container.\") {\n   255→\t\t\t\tcontinue\n   256→\t\t\t}\n   257→\t\t\twarnings = append(warnings, fmt.Sprintf(\n   258→\t\t\t\t\"workflow %q: step %q has unrecognized config key %q\", w.Name, name, key))\n   259→\t\t}\n   260→\t}\n   261→\treturn warnings\n   262→}\n   263→\n   264→// NextSteps returns all target step names wired from the given (stepName, result) pair.\n   265→// Multiple targets indicate fanout — parallel branches launched by the engine.\n   266→func (w *Workflow) NextSteps(stepName, result string) ([]string, error) {\n   267→\tvar targets []string\n   268→\tfor _, wire := range w.Wiring {\n   269→\t\tif wire.From == stepName && wire.Result == result {\n   270→\t\t\ttargets = append(targets, wire.To)\n   271→\t\t}\n   272→\t}\n   273→\tif len(targets) == 0 {\n   274→\t\treturn nil, fmt.Errorf(\"workflow %q: no wiring for step %q result %q\", w.Name, stepName, result)\n   275→\t}\n   276→\treturn targets, nil\n   277→}\n   278→\n   279→// Deprecated: NextStep returns the first target only. Use NextSteps for fanout support.\n   280→func (w *Workflow) NextStep(stepName, result string) (string, error) {\n   281→\ttargets, err := w.NextSteps(stepName, result)\n   282→\tif err != nil {\n   283→\t\treturn \"\", err\n   284→\t}\n   285→\treturn targets[0], nil\n   286→}\n   287→"}]},"parent_tool_use_id":null,"session_id":"1be03ddf-4515-4c42-8f69-2b04ab925fc3","uuid":"6bb8e727-c245-4ad5-aef4-ea71f0e0db23","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/domain/workflow.go","content":"package domain\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"strings\"\n)\n\nconst (\n\tStepDone  = \"done\"\n\tStepAbort = \"abort\"\n)\n\ntype StepType string\n\nconst (\n\tStepTypeAgent    StepType = \"agent\"\n\tStepTypeScript   StepType = \"script\"\n\tStepTypeWorkflow StepType = \"workflow\"\n)\n\n// WorkflowLocation indicates where a workflow is intended to run.\ntype WorkflowLocation string\n\nconst (\n\t// LocationContainer is for workflows that run inside a Docker container.\n\t// These are all .cloche/*.cloche files except host.cloche.\n\tLocationContainer WorkflowLocation = \"container\"\n\n\t// LocationHost is for workflows that run on the host machine.\n\t// Only .cloche/host.cloche uses this location.\n\tLocationHost WorkflowLocation = \"host\"\n)\n\ntype Step struct {\n\tName    string\n\tType    StepType\n\tResults []string\n\tConfig  map[string]string\n}\n\ntype Wire struct {\n\tFrom      string\n\tResult    string\n\tTo        string\n\tOutputMap []OutputMapping\n}\n\ntype SegmentKind int\n\nconst (\n\tSegmentField SegmentKind = iota\n\tSegmentIndex\n)\n\ntype PathSegment struct {\n\tKind  SegmentKind\n\tField string // for SegmentField\n\tIndex int    // for SegmentIndex\n}\n\ntype OutputPath struct {\n\tSegments []PathSegment\n}\n\ntype OutputMapping struct {\n\tEnvVar string\n\tPath   OutputPath\n}\n\n// Evaluate navigates the raw output bytes using the path segments.\n// With no segments, it returns the raw output as a string.\n// With segments, it parses the raw bytes as JSON and navigates using\n// field access (SegmentField) and array indexing (SegmentIndex).\nfunc (p OutputPath) Evaluate(raw []byte) (string, error) {\n\tif len(p.Segments) == 0 {\n\t\treturn string(raw), nil\n\t}\n\n\tvar val any\n\tif err := json.Unmarshal(raw, &val); err != nil {\n\t\treturn \"\", fmt.Errorf(\"output is not valid JSON\")\n\t}\n\n\tfor _, seg := range p.Segments {\n\t\tswitch seg.Kind {\n\t\tcase SegmentField:\n\t\t\tm, ok := val.(map[string]any)\n\t\t\tif !ok {\n\t\t\t\treturn \"\", fmt.Errorf(\"expected object for .%s\", seg.Field)\n\t\t\t}\n\t\t\tval, ok = m[seg.Field]\n\t\t\tif !ok {\n\t\t\t\treturn \"\", fmt.Errorf(\"field %q not found\", seg.Field)\n\t\t\t}\n\t\tcase SegmentIndex:\n\t\t\tarr, ok := val.([]any)\n\t\t\tif !ok {\n\t\t\t\treturn \"\", fmt.Errorf(\"expected array for [%d]\", seg.Index)\n\t\t\t}\n\t\t\tif seg.Index < 0 || seg.Index >= len(arr) {\n\t\t\t\treturn \"\", fmt.Errorf(\"index %d out of range (len %d)\", seg.Index, len(arr))\n\t\t\t}\n\t\t\tval = arr[seg.Index]\n\t\t}\n\t}\n\n\tswitch v := val.(type) {\n\tcase string:\n\t\treturn v, nil\n\tdefault:\n\t\tb, _ := json.Marshal(v)\n\t\treturn string(b), nil\n\t}\n}\n\ntype CollectMode string\n\nconst (\n\tCollectAll CollectMode = \"all\"\n\tCollectAny CollectMode = \"any\"\n)\n\ntype WireCondition struct {\n\tStep   string\n\tResult string\n}\n\ntype Collect struct {\n\tMode       CollectMode\n\tConditions []WireCondition\n\tTo         string\n}\n\ntype Workflow struct {\n\tName      string\n\tLocation  WorkflowLocation  // host or container\n\tSteps     map[string]*Step\n\tWiring    []Wire\n\tCollects  []Collect\n\tEntryStep string\n\tConfig    map[string]string // workflow-level config (e.g. \"container.image\")\n}\n\nfunc (w *Workflow) Validate() error {\n\tif w.EntryStep == \"\" {\n\t\treturn fmt.Errorf(\"workflow %q: no entry step defined\", w.Name)\n\t}\n\tif _, ok := w.Steps[w.EntryStep]; !ok {\n\t\treturn fmt.Errorf(\"workflow %q: entry step %q not found\", w.Name, w.EntryStep)\n\t}\n\n\twired := make(map[string]map[string]bool)\n\treachable := map[string]bool{w.EntryStep: true}\n\tfor _, wire := range w.Wiring {\n\t\tif wired[wire.From] == nil {\n\t\t\twired[wire.From] = make(map[string]bool)\n\t\t}\n\t\twired[wire.From][wire.Result] = true\n\t\tif wire.To != StepDone && wire.To != StepAbort {\n\t\t\treachable[wire.To] = true\n\t\t}\n\t}\n\n\t// Validate collects and count their results as wired\n\tfor _, c := range w.Collects {\n\t\t// Validate target step exists\n\t\tif c.To != StepDone && c.To != StepAbort {\n\t\t\tif _, ok := w.Steps[c.To]; !ok {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: collect target step %q not found\", w.Name, c.To)\n\t\t\t}\n\t\t\treachable[c.To] = true\n\t\t}\n\n\t\tfor _, cond := range c.Conditions {\n\t\t\t// Validate condition step exists\n\t\t\tstep, ok := w.Steps[cond.Step]\n\t\t\tif !ok {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references unknown step %q\", w.Name, cond.Step)\n\t\t\t}\n\t\t\t// Validate condition result is declared\n\t\t\tfound := false\n\t\t\tfor _, r := range step.Results {\n\t\t\t\tif r == cond.Result {\n\t\t\t\t\tfound = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !found {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references undeclared result %q on step %q\", w.Name, cond.Result, cond.Step)\n\t\t\t}\n\t\t\t// Mark as wired so the \"every result must be wired\" check passes\n\t\t\tif wired[cond.Step] == nil {\n\t\t\t\twired[cond.Step] = make(map[string]bool)\n\t\t\t}\n\t\t\twired[cond.Step][cond.Result] = true\n\t\t}\n\t}\n\n\tfor name, step := range w.Steps {\n\t\tfor _, result := range step.Results {\n\t\t\tif !wired[name][result] {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q result %q is not wired\", w.Name, name, result)\n\t\t\t}\n\t\t}\n\t}\n\n\tfor name := range w.Steps {\n\t\tif !reachable[name] {\n\t\t\treturn fmt.Errorf(\"workflow %q: step %q is orphaned (unreachable)\", w.Name, name)\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// ValidateLocation checks that step types are compatible with the workflow location.\n// workflow_name steps are only allowed in host workflows.\nfunc (w *Workflow) ValidateLocation() error {\n\tif w.Location == LocationContainer {\n\t\tfor name, step := range w.Steps {\n\t\t\tif step.Type == StepTypeWorkflow {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q uses workflow_name, which is only allowed in host workflows (host.cloche)\", w.Name, name)\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\n// knownStepConfigKeys lists recognized step-level config keys.\n// Keys with a \"container.\" prefix are also allowed.\nvar knownStepConfigKeys = map[string]bool{\n\t\"prompt\":        true,\n\t\"run\":           true,\n\t\"max_attempts\":  true,\n\t\"timeout\":       true,\n\t\"agent_command\": true,\n\t\"agent_args\":    true,\n\t\"results\":       true,\n\t\"feedback\":      true,\n\t\"workflow_name\": true,\n\t\"prompt_step\":   true,\n}\n\n// ValidateConfig checks step config keys against known keys and returns\n// warnings for any unrecognized keys (likely typos).\nfunc (w *Workflow) ValidateConfig() []string {\n\tvar warnings []string\n\tfor name, step := range w.Steps {\n\t\tfor key := range step.Config {\n\t\t\tif knownStepConfigKeys[key] {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif strings.HasPrefix(key, \"container.\") {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\twarnings = append(warnings, fmt.Sprintf(\n\t\t\t\t\"workflow %q: step %q has unrecognized config key %q\", w.Name, name, key))\n\t\t}\n\t}\n\treturn warnings\n}\n\n// NextSteps returns all target step names wired from the given (stepName, result) pair.\n// Multiple targets indicate fanout — parallel branches launched by the engine.\nfunc (w *Workflow) NextSteps(stepName, result string) ([]string, error) {\n\tvar targets []string\n\tfor _, wire := range w.Wiring {\n\t\tif wire.From == stepName && wire.Result == result {\n\t\t\ttargets = append(targets, wire.To)\n\t\t}\n\t}\n\tif len(targets) == 0 {\n\t\treturn nil, fmt.Errorf(\"workflow %q: no wiring for step %q result %q\", w.Name, stepName, result)\n\t}\n\treturn targets, nil\n}\n\n// Deprecated: NextStep returns the first target only. Use NextSteps for fanout support.\nfunc (w *Workflow) NextStep(stepName, result string) (string, error) {\n\ttargets, err := w.NextSteps(stepName, result)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn targets[0], nil\n}\n","numLines":287,"startLine":1,"totalLines":287}}}
