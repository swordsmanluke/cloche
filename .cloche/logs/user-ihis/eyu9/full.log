[2026-03-09T22:36:07Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017Qh5K3K3h2HBk3UVbZHVuz","type":"tool_result","content":"     1→package domain\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"strings\"\n     6→)\n     7→\n     8→const (\n     9→\tStepDone  = \"done\"\n    10→\tStepAbort = \"abort\"\n    11→)\n    12→\n    13→type StepType string\n    14→\n    15→const (\n    16→\tStepTypeAgent    StepType = \"agent\"\n    17→\tStepTypeScript   StepType = \"script\"\n    18→\tStepTypeWorkflow StepType = \"workflow\"\n    19→)\n    20→\n    21→// WorkflowLocation indicates where a workflow is intended to run.\n    22→type WorkflowLocation string\n    23→\n    24→const (\n    25→\t// LocationContainer is for workflows that run inside a Docker container.\n    26→\t// These are all .cloche/*.cloche files except host.cloche.\n    27→\tLocationContainer WorkflowLocation = \"container\"\n    28→\n    29→\t// LocationHost is for workflows that run on the host machine.\n    30→\t// Only .cloche/host.cloche uses this location.\n    31→\tLocationHost WorkflowLocation = \"host\"\n    32→)\n    33→\n    34→type Step struct {\n    35→\tName    string\n    36→\tType    StepType\n    37→\tResults []string\n    38→\tConfig  map[string]string\n    39→}\n    40→\n    41→type Wire struct {\n    42→\tFrom   string\n    43→\tResult string\n    44→\tTo     string\n    45→}\n    46→\n    47→type CollectMode string\n    48→\n    49→const (\n    50→\tCollectAll CollectMode = \"all\"\n    51→\tCollectAny CollectMode = \"any\"\n    52→)\n    53→\n    54→type WireCondition struct {\n    55→\tStep   string\n    56→\tResult string\n    57→}\n    58→\n    59→type Collect struct {\n    60→\tMode       CollectMode\n    61→\tConditions []WireCondition\n    62→\tTo         string\n    63→}\n    64→\n    65→type Workflow struct {\n    66→\tName      string\n    67→\tLocation  WorkflowLocation  // host or container\n    68→\tSteps     map[string]*Step\n    69→\tWiring    []Wire\n    70→\tCollects  []Collect\n    71→\tEntryStep string\n    72→\tConfig    map[string]string // workflow-level config (e.g. \"container.image\")\n    73→}\n    74→\n    75→func (w *Workflow) Validate() error {\n    76→\tif w.EntryStep == \"\" {\n    77→\t\treturn fmt.Errorf(\"workflow %q: no entry step defined\", w.Name)\n    78→\t}\n    79→\tif _, ok := w.Steps[w.EntryStep]; !ok {\n    80→\t\treturn fmt.Errorf(\"workflow %q: entry step %q not found\", w.Name, w.EntryStep)\n    81→\t}\n    82→\n    83→\twired := make(map[string]map[string]bool)\n    84→\treachable := map[string]bool{w.EntryStep: true}\n    85→\tfor _, wire := range w.Wiring {\n    86→\t\tif wired[wire.From] == nil {\n    87→\t\t\twired[wire.From] = make(map[string]bool)\n    88→\t\t}\n    89→\t\twired[wire.From][wire.Result] = true\n    90→\t\tif wire.To != StepDone && wire.To != StepAbort {\n    91→\t\t\treachable[wire.To] = true\n    92→\t\t}\n    93→\t}\n    94→\n    95→\t// Validate collects and count their results as wired\n    96→\tfor _, c := range w.Collects {\n    97→\t\t// Validate target step exists\n    98→\t\tif c.To != StepDone && c.To != StepAbort {\n    99→\t\t\tif _, ok := w.Steps[c.To]; !ok {\n   100→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect target step %q not found\", w.Name, c.To)\n   101→\t\t\t}\n   102→\t\t\treachable[c.To] = true\n   103→\t\t}\n   104→\n   105→\t\tfor _, cond := range c.Conditions {\n   106→\t\t\t// Validate condition step exists\n   107→\t\t\tstep, ok := w.Steps[cond.Step]\n   108→\t\t\tif !ok {\n   109→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references unknown step %q\", w.Name, cond.Step)\n   110→\t\t\t}\n   111→\t\t\t// Validate condition result is declared\n   112→\t\t\tfound := false\n   113→\t\t\tfor _, r := range step.Results {\n   114→\t\t\t\tif r == cond.Result {\n   115→\t\t\t\t\tfound = true\n   116→\t\t\t\t\tbreak\n   117→\t\t\t\t}\n   118→\t\t\t}\n   119→\t\t\tif !found {\n   120→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references undeclared result %q on step %q\", w.Name, cond.Result, cond.Step)\n   121→\t\t\t}\n   122→\t\t\t// Mark as wired so the \"every result must be wired\" check passes\n   123→\t\t\tif wired[cond.Step] == nil {\n   124→\t\t\t\twired[cond.Step] = make(map[string]bool)\n   125→\t\t\t}\n   126→\t\t\twired[cond.Step][cond.Result] = true\n   127→\t\t}\n   128→\t}\n   129→\n   130→\tfor name, step := range w.Steps {\n   131→\t\tfor _, result := range step.Results {\n   132→\t\t\tif !wired[name][result] {\n   133→\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q result %q is not wired\", w.Name, name, result)\n   134→\t\t\t}\n   135→\t\t}\n   136→\t}\n   137→\n   138→\tfor name := range w.Steps {\n   139→\t\tif !reachable[name] {\n   140→\t\t\treturn fmt.Errorf(\"workflow %q: step %q is orphaned (unreachable)\", w.Name, name)\n   141→\t\t}\n   142→\t}\n   143→\n   144→\treturn nil\n   145→}\n   146→\n   147→// ValidateLocation checks that step types are compatible with the workflow location.\n   148→// workflow_name steps are only allowed in host workflows.\n   149→func (w *Workflow) ValidateLocation() error {\n   150→\tif w.Location == LocationContainer {\n   151→\t\tfor name, step := range w.Steps {\n   152→\t\t\tif step.Type == StepTypeWorkflow {\n   153→\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q uses workflow_name, which is only allowed in host workflows (host.cloche)\", w.Name, name)\n   154→\t\t\t}\n   155→\t\t}\n   156→\t}\n   157→\treturn nil\n   158→}\n   159→\n   160→// knownStepConfigKeys lists recognized step-level config keys.\n   161→// Keys with a \"container.\" prefix are also allowed.\n   162→var knownStepConfigKeys = map[string]bool{\n   163→\t\"prompt\":        true,\n   164→\t\"run\":           true,\n   165→\t\"max_attempts\":  true,\n   166→\t\"timeout\":       true,\n   167→\t\"agent_command\": true,\n   168→\t\"agent_args\":    true,\n   169→\t\"results\":       true,\n   170→\t\"feedback\":      true,\n   171→\t\"workflow_name\": true,\n   172→\t\"prompt_step\":   true,\n   173→}\n   174→\n   175→// ValidateConfig checks step config keys against known keys and returns\n   176→// warnings for any unrecognized keys (likely typos).\n   177→func (w *Workflow) ValidateConfig() []string {\n   178→\tvar warnings []string\n   179→\tfor name, step := range w.Steps {\n   180→\t\tfor key := range step.Config {\n   181→\t\t\tif knownStepConfigKeys[key] {\n   182→\t\t\t\tcontinue\n   183→\t\t\t}\n   184→\t\t\tif strings.HasPrefix(key, \"container.\") {\n   185→\t\t\t\tcontinue\n   186→\t\t\t}\n   187→\t\t\twarnings = append(warnings, fmt.Sprintf(\n   188→\t\t\t\t\"workflow %q: step %q has unrecognized config key %q\", w.Name, name, key))\n   189→\t\t}\n   190→\t}\n   191→\treturn warnings\n   192→}\n   193→\n   194→// NextSteps returns all target step names wired from the given (stepName, result) pair.\n   195→// Multiple targets indicate fanout — parallel branches launched by the engine.\n   196→func (w *Workflow) NextSteps(stepName, result string) ([]string, error) {\n   197→\tvar targets []string\n   198→\tfor _, wire := range w.Wiring {\n   199→\t\tif wire.From == stepName && wire.Result == result {\n   200→\t\t\ttargets = append(targets, wire.To)\n   201→\t\t}\n   202→\t}\n   203→\tif len(targets) == 0 {\n   204→\t\treturn nil, fmt.Errorf(\"workflow %q: no wiring for step %q result %q\", w.Name, stepName, result)\n   205→\t}\n   206→\treturn targets, nil\n   207→}\n   208→\n   209→// Deprecated: NextStep returns the first target only. Use NextSteps for fanout support.\n   210→func (w *Workflow) NextStep(stepName, result string) (string, error) {\n   211→\ttargets, err := w.NextSteps(stepName, result)\n   212→\tif err != nil {\n   213→\t\treturn \"\", err\n   214→\t}\n   215→\treturn targets[0], nil\n   216→}\n   217→"}]},"parent_tool_use_id":null,"session_id":"7e4628cb-a058-4967-963c-3c64dcc3045c","uuid":"ade0f399-9fc3-4ffd-b9dc-e00d829a80f9","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/domain/workflow.go","content":"package domain\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n)\n\nconst (\n\tStepDone  = \"done\"\n\tStepAbort = \"abort\"\n)\n\ntype StepType string\n\nconst (\n\tStepTypeAgent    StepType = \"agent\"\n\tStepTypeScript   StepType = \"script\"\n\tStepTypeWorkflow StepType = \"workflow\"\n)\n\n// WorkflowLocation indicates where a workflow is intended to run.\ntype WorkflowLocation string\n\nconst (\n\t// LocationContainer is for workflows that run inside a Docker container.\n\t// These are all .cloche/*.cloche files except host.cloche.\n\tLocationContainer WorkflowLocation = \"container\"\n\n\t// LocationHost is for workflows that run on the host machine.\n\t// Only .cloche/host.cloche uses this location.\n\tLocationHost WorkflowLocation = \"host\"\n)\n\ntype Step struct {\n\tName    string\n\tType    StepType\n\tResults []string\n\tConfig  map[string]string\n}\n\ntype Wire struct {\n\tFrom   string\n\tResult string\n\tTo     string\n}\n\ntype CollectMode string\n\nconst (\n\tCollectAll CollectMode = \"all\"\n\tCollectAny CollectMode = \"any\"\n)\n\ntype WireCondition struct {\n\tStep   string\n\tResult string\n}\n\ntype Collect struct {\n\tMode       CollectMode\n\tConditions []WireCondition\n\tTo         string\n}\n\ntype Workflow struct {\n\tName      string\n\tLocation  WorkflowLocation  // host or container\n\tSteps     map[string]*Step\n\tWiring    []Wire\n\tCollects  []Collect\n\tEntryStep string\n\tConfig    map[string]string // workflow-level config (e.g. \"container.image\")\n}\n\nfunc (w *Workflow) Validate() error {\n\tif w.EntryStep == \"\" {\n\t\treturn fmt.Errorf(\"workflow %q: no entry step defined\", w.Name)\n\t}\n\tif _, ok := w.Steps[w.EntryStep]; !ok {\n\t\treturn fmt.Errorf(\"workflow %q: entry step %q not found\", w.Name, w.EntryStep)\n\t}\n\n\twired := make(map[string]map[string]bool)\n\treachable := map[string]bool{w.EntryStep: true}\n\tfor _, wire := range w.Wiring {\n\t\tif wired[wire.From] == nil {\n\t\t\twired[wire.From] = make(map[string]bool)\n\t\t}\n\t\twired[wire.From][wire.Result] = true\n\t\tif wire.To != StepDone && wire.To != StepAbort {\n\t\t\treachable[wire.To] = true\n\t\t}\n\t}\n\n\t// Validate collects and count their results as wired\n\tfor _, c := range w.Collects {\n\t\t// Validate target step exists\n\t\tif c.To != StepDone && c.To != StepAbort {\n\t\t\tif _, ok := w.Steps[c.To]; !ok {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: collect target step %q not found\", w.Name, c.To)\n\t\t\t}\n\t\t\treachable[c.To] = true\n\t\t}\n\n\t\tfor _, cond := range c.Conditions {\n\t\t\t// Validate condition step exists\n\t\t\tstep, ok := w.Steps[cond.Step]\n\t\t\tif !ok {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references unknown step %q\", w.Name, cond.Step)\n\t\t\t}\n\t\t\t// Validate condition result is declared\n\t\t\tfound := false\n\t\t\tfor _, r := range step.Results {\n\t\t\t\tif r == cond.Result {\n\t\t\t\t\tfound = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !found {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references undeclared result %q on step %q\", w.Name, cond.Result, cond.Step)\n\t\t\t}\n\t\t\t// Mark as wired so the \"every result must be wired\" check passes\n\t\t\tif wired[cond.Step] == nil {\n\t\t\t\twired[cond.Step] = make(map[string]bool)\n\t\t\t}\n\t\t\twired[cond.Step][cond.Result] = true\n\t\t}\n\t}\n\n\tfor name, step := range w.Steps {\n\t\tfor _, result := range step.Results {\n\t\t\tif !wired[name][result] {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q result %q is not wired\", w.Name, name, result)\n\t\t\t}\n\t\t}\n\t}\n\n\tfor name := range w.Steps {\n\t\tif !reachable[name] {\n\t\t\treturn fmt.Errorf(\"workflow %q: step %q is orphaned (unreachable)\", w.Name, name)\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// ValidateLocation checks that step types are compatible with the workflow location.\n// workflow_name steps are only allowed in host workflows.\nfunc (w *Workflow) ValidateLocation() error {\n\tif w.Location == LocationContainer {\n\t\tfor name, step := range w.Steps {\n\t\t\tif step.Type == StepTypeWorkflow {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q uses workflow_name, which is only allowed in host workflows (host.cloche)\", w.Name, name)\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\n// knownStepConfigKeys lists recognized step-level config keys.\n// Keys with a \"container.\" prefix are also allowed.\nvar knownStepConfigKeys = map[string]bool{\n\t\"prompt\":        true,\n\t\"run\":           true,\n\t\"max_attempts\":  true,\n\t\"timeout\":       true,\n\t\"agent_command\": true,\n\t\"agent_args\":    true,\n\t\"results\":       true,\n\t\"feedback\":      true,\n\t\"workflow_name\": true,\n\t\"prompt_step\":   true,\n}\n\n// ValidateConfig checks step config keys against known keys and returns\n// warnings for any unrecognized keys (likely typos).\nfunc (w *Workflow) ValidateConfig() []string {\n\tvar warnings []string\n\tfor name, step := range w.Steps {\n\t\tfor key := range step.Config {\n\t\t\tif knownStepConfigKeys[key] {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif strings.HasPrefix(key, \"container.\") {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\twarnings = append(warnings, fmt.Sprintf(\n\t\t\t\t\"workflow %q: step %q has unrecognized config key %q\", w.Name, name, key))\n\t\t}\n\t}\n\treturn warnings\n}\n\n// NextSteps returns all target step names wired from the given (stepName, result) pair.\n// Multiple targets indicate fanout — parallel branches launched by the engine.\nfunc (w *Workflow) NextSteps(stepName, result string) ([]string, error) {\n\tvar targets []string\n\tfor _, wire := range w.Wiring {\n\t\tif wire.From == stepName && wire.Result == result {\n\t\t\ttargets = append(targets, wire.To)\n\t\t}\n\t}\n\tif len(targets) == 0 {\n\t\treturn nil, fmt.Errorf(\"workflow %q: no wiring for step %q result %q\", w.Name, stepName, result)\n\t}\n\treturn targets, nil\n}\n\n// Deprecated: NextStep returns the first target only. Use NextSteps for fanout support.\nfunc (w *Workflow) NextStep(stepName, result string) (string, error) {\n\ttargets, err := w.NextSteps(stepName, result)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn targets[0], nil\n}\n","numLines":217,"startLine":1,"totalLines":217}}}
[2026-03-09T22:36:07Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01B5pYXrzswC1iMtZo6XdakK","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018ccuNsfX6RjXDvbZD26VpP","name":"Read","input":{"file_path":"/workspace/docs/plans/2026-03-09-wire-output-mapping-design.md"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":6024,"cache_read_input_tokens":9257,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":6024},"output_tokens":9,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7e4628cb-a058-4967-963c-3c64dcc3045c","uuid":"5f5eafdc-8241-4661-8ebd-946f8885f634"}
[2026-03-09T22:36:07Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018ccuNsfX6RjXDvbZD26VpP","type":"tool_result","content":"     1→# Wire Output Mapping\n     2→\n     3→**Date:** 2026-03-09\n     4→**Status:** Proposed\n     5→\n     6→## Problem\n     7→\n     8→Host workflow steps produce output that downstream steps need as structured\n     9→input. Today the only mechanism is `CLOCHE_PREV_OUTPUT`, a file path to the\n    10→previous step's raw output. Steps that need specific fields must parse the\n    11→output themselves, and there's no way to express \"extract field X from step A's\n    12→JSON output and inject it as env var Y into step B\" in the DSL.\n    13→\n    14→This came up immediately: `ready-tasks` outputs JSON from `bd ready --json`,\n    15→and `prepare-prompt` needs `CLOCHE_TASK_TITLE` and `CLOCHE_TASK_BODY` as env\n    16→vars. Without DSL-level mapping, every step needs bespoke shell glue.\n    17→\n    18→## Design\n    19→\n    20→### Syntax\n    21→\n    22→Output mappings live on wires, not on step declarations. A wire describes data\n    23→flow between two steps, so the mapping belongs there:\n    24→\n    25→```\n    26→step-a:success -> step-b [ ENV_VAR = output.field, OTHER = output.list[0].name ]\n    27→```\n    28→\n    29→The general form:\n    30→\n    31→```\n    32→FROM:RESULT -> TO [ KEY = EXPR, KEY = EXPR, ... ]\n    33→```\n    34→\n    35→Where:\n    36→- `KEY` is the environment variable name injected into the target step\n    37→- `EXPR` is an output path expression (see below)\n    38→\n    39→### Output Path Expressions\n    40→\n    41→All expressions start with `output`, which refers to the source step's output.\n    42→\n    43→| Expression | Meaning |\n    44→|---|---|\n    45→| `output` | Raw output (full string) |\n    46→| `output.key` | JSON object field access |\n    47→| `output[N]` | JSON array index (0-based) |\n    48→| `output.key[N]` | Chained: field then index |\n    49→| `output[N].key` | Chained: index then field |\n    50→| `output.a.b.c` | Deeply nested field access |\n    51→| `output.a[0].b[1].c` | Arbitrary nesting |\n    52→\n    53→If the source step's output is valid JSON, path expressions navigate the parsed\n    54→structure. If the output is plain text, only bare `output` is valid — any `.key`\n    55→or `[N]` access is a runtime error.\n    56→\n    57→The resolved value is always converted to a string for injection as an env var.\n    58→JSON objects and arrays are re-serialized as JSON strings. Scalars use their\n    59→natural string representation.\n    60→\n    61→### Examples\n    62→\n    63→```\n    64→workflow \"main\" {\n    65→  step get-tasks {\n    66→    run     = \"bd ready --json --limit 1\"\n    67→    results = [success, fail]\n    68→  }\n    69→\n    70→  step prepare-prompt {\n    71→    run     = \"bash .cloche/scripts/prepare-prompt.sh\"\n    72→    results = [success, fail]\n    73→  }\n    74→\n    75→  step develop {\n    76→    workflow_name = \"develop\"\n    77→    results       = [success, fail]\n    78→  }\n    79→\n    80→  get-tasks:success -> prepare-prompt [\n    81→    CLOCHE_TASK_ID    = output[0].id,\n    82→    CLOCHE_TASK_TITLE = output[0].title,\n    83→    CLOCHE_TASK_BODY  = output[0].description\n    84→  ]\n    85→  get-tasks:fail       -> abort\n    86→  prepare-prompt:success -> develop\n    87→  develop:success        -> done\n    88→  develop:fail           -> abort\n    89→}\n    90→```\n    91→\n    92→Multiple wires into the same step merge their mappings. If two wires map the\n    93→same key, that's a validation error (ambiguous).\n    94→\n    95→### Interaction with CLOCHE_PREV_OUTPUT\n    96→\n    97→`CLOCHE_PREV_OUTPUT` continues to work as before — it always points to the\n    98→previous step's raw output file. Output mappings are additive: they inject\n    99→extra env vars alongside the existing ones. A step can use both the mapped\n   100→vars and read the raw file if needed.\n   101→\n   102→## Implementation\n   103→\n   104→### Domain Changes\n   105→\n   106→Add an `OutputMap` field to `Wire`:\n   107→\n   108→```go\n   109→type Wire struct {\n   110→    From      string\n   111→    Result    string\n   112→    To        string\n   113→    OutputMap []OutputMapping  // new\n   114→}\n   115→\n   116→type OutputMapping struct {\n   117→    EnvVar string     // e.g. \"CLOCHE_TASK_ID\"\n   118→    Path   OutputPath // parsed expression\n   119→}\n   120→\n   121→type OutputPath struct {\n   122→    Segments []PathSegment\n   123→}\n   124→\n   125→type PathSegment struct {\n   126→    Kind  SegmentKind // SegmentField or SegmentIndex\n   127→    Field string      // for SegmentField\n   128→    Index int         // for SegmentIndex\n   129→}\n   130→```\n   131→\n   132→### Lexer Changes\n   133→\n   134→The lexer already supports `[`, `]`, `.`, `=`, `,`, and identifiers. Integer\n   135→literals are needed for array indices — add `TokenInt`.\n   136→\n   137→### Parser Changes\n   138→\n   139→After parsing `FROM:RESULT -> TO`, check for an optional `[` token. If present,\n   140→parse a comma-separated list of `IDENT = output PATH` mappings until `]`.\n   141→\n   142→The `output` keyword is a contextual identifier — it's only special inside\n   143→mapping brackets. No new reserved words needed.\n   144→\n   145→```\n   146→parseWire():\n   147→    from  = expect(TokenIdent)\n   148→    _     = expect(TokenColon)\n   149→    result = expect(TokenIdent)\n   150→    _     = expect(TokenArrow)\n   151→    to    = expect(TokenIdent)\n   152→    if peek() == TokenLBracket:\n   153→        mappings = parseOutputMappings()\n   154→    return Wire{from, result, to, mappings}\n   155→\n   156→parseOutputMappings():\n   157→    expect(TokenLBracket)\n   158→    mappings = []\n   159→    loop:\n   160→        key  = expect(TokenIdent)\n   161→        _    = expect(TokenEquals)\n   162→        path = parseOutputPath()\n   163→        mappings.append({key, path})\n   164→        if peek() != TokenComma: break\n   165→        expect(TokenComma)\n   166→    expect(TokenRBracket)\n   167→    return mappings\n   168→\n   169→parseOutputPath():\n   170→    expect(TokenIdent, \"output\")  // must start with \"output\"\n   171→    segments = []\n   172→    loop:\n   173→        if peek() == TokenDot:\n   174→            expect(TokenDot)\n   175→            segments.append(FieldSegment{expect(TokenIdent)})\n   176→        else if peek() == TokenLBracket:\n   177→            expect(TokenLBracket)\n   178→            segments.append(IndexSegment{expect(TokenInt)})\n   179→            expect(TokenRBracket)\n   180→        else:\n   181→            break\n   182→    return OutputPath{segments}\n   183→```\n   184→\n   185→### Validation Changes\n   186→\n   187→In `Workflow.Validate()`:\n   188→- If two wires target the same step and both map the same env var key, error.\n   189→- Output path expressions are syntactically validated at parse time (no runtime\n   190→  path validation — the output isn't known until execution).\n   191→\n   192→### Executor Changes\n   193→\n   194→In `internal/host/executor.go`, when launching a step:\n   195→\n   196→1. Find all wires that target this step.\n   197→2. For each wire with output mappings, read the source step's output file.\n   198→3. Try to parse the output as JSON. If it's valid JSON, evaluate each path\n   199→   expression against the parsed value. If it's not JSON and any path has\n   200→   segments, return an error.\n   201→4. Add resolved values to the step's env as `KEY=value`.\n   202→\n   203→```go\n   204→func (e *Executor) resolveOutputMappings(step string, wires []domain.Wire) ([]string, error) {\n   205→    var env []string\n   206→    for _, w := range wires {\n   207→        if w.To != step || len(w.OutputMap) == 0 {\n   208→            continue\n   209→        }\n   210→        data, err := os.ReadFile(e.stepOutputPath(w.From))\n   211→        if err != nil {\n   212→            return nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n   213→        }\n   214→        for _, m := range w.OutputMap {\n   215→            val, err := m.Path.Evaluate(data)\n   216→            if err != nil {\n   217→                return nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, step, err)\n   218→            }\n   219→            env = append(env, m.EnvVar+\"=\"+val)\n   220→        }\n   221→    }\n   222→    return env, nil\n   223→}\n   224→```\n   225→\n   226→### Path Evaluation\n   227→\n   228→```go\n   229→func (p OutputPath) Evaluate(raw []byte) (string, error) {\n   230→    if len(p.Segments) == 0 {\n   231→        return string(raw), nil // bare \"output\"\n   232→    }\n   233→\n   234→    var val any\n   235→    if err := json.Unmarshal(raw, &val); err != nil {\n   236→        return \"\", fmt.Errorf(\"output is not valid JSON\")\n   237→    }\n   238→\n   239→    for _, seg := range p.Segments {\n   240→        switch seg.Kind {\n   241→        case SegmentField:\n   242→            m, ok := val.(map[string]any)\n   243→            if !ok { return \"\", fmt.Errorf(\"expected object for .%s\", seg.Field) }\n   244→            val, ok = m[seg.Field]\n   245→            if !ok { return \"\", fmt.Errorf(\"field %q not found\", seg.Field) }\n   246→        case SegmentIndex:\n   247→            arr, ok := val.([]any)\n   248→            if !ok { return \"\", fmt.Errorf(\"expected array for [%d]\", seg.Index) }\n   249→            if seg.Index < 0 || seg.Index >= len(arr) {\n   250→                return \"\", fmt.Errorf(\"index %d out of range (len %d)\", seg.Index, len(arr))\n   251→            }\n   252→            val = arr[seg.Index]\n   253→        }\n   254→    }\n   255→\n   256→    // Convert resolved value to string\n   257→    switch v := val.(type) {\n   258→    case string:\n   259→        return v, nil\n   260→    default:\n   261→        b, _ := json.Marshal(v)\n   262→        return string(b), nil\n   263→    }\n   264→}\n   265→```\n   266→\n   267→## Task Breakdown\n   268→\n   269→1. **Add `TokenInt` to lexer** — Recognize integer literals for array indices.\n   270→   Update lexer tests.\n   271→\n   272→2. **Add `OutputMapping` and `OutputPath` types to domain** — New types in\n   273→   `internal/domain/workflow.go`. Add `OutputMap` field to `Wire`. Add\n   274→   `Evaluate` method to `OutputPath`. Unit test path evaluation.\n   275→\n   276→3. **Extend parser to handle wire output mappings** — Parse `[ KEY = EXPR ]`\n   277→   after wire targets. Update parser tests with mapping syntax.\n   278→\n   279→4. **Add validation for duplicate mappings** — Error if two wires into the\n   280→   same step map the same env var. Update validation tests.\n   281→\n   282→5. **Wire mapping resolution in host executor** — Read source output, evaluate\n   283→   paths, inject env vars. Update executor tests.\n   284→\n   285→6. **Update host.cloche to use mappings** — Replace the current\n   286→   `prepare-prompt` step to consume mapped vars instead of relying on\n   287→   pre-set env.\n   288→"}]},"parent_tool_use_id":null,"session_id":"7e4628cb-a058-4967-963c-3c64dcc3045c","uuid":"2a1506cc-1a29-47c7-89ac-e978807f1fec","tool_use_result":{"type":"text","file":{"filePath":"/workspace/docs/plans/2026-03-09-wire-output-mapping-design.md","content":"# Wire Output Mapping\n\n**Date:** 2026-03-09\n**Status:** Proposed\n\n## Problem\n\nHost workflow steps produce output that downstream steps need as structured\ninput. Today the only mechanism is `CLOCHE_PREV_OUTPUT`, a file path to the\nprevious step's raw output. Steps that need specific fields must parse the\noutput themselves, and there's no way to express \"extract field X from step A's\nJSON output and inject it as env var Y into step B\" in the DSL.\n\nThis came up immediately: `ready-tasks` outputs JSON from `bd ready --json`,\nand `prepare-prompt` needs `CLOCHE_TASK_TITLE` and `CLOCHE_TASK_BODY` as env\nvars. Without DSL-level mapping, every step needs bespoke shell glue.\n\n## Design\n\n### Syntax\n\nOutput mappings live on wires, not on step declarations. A wire describes data\nflow between two steps, so the mapping belongs there:\n\n```\nstep-a:success -> step-b [ ENV_VAR = output.field, OTHER = output.list[0].name ]\n```\n\nThe general form:\n\n```\nFROM:RESULT -> TO [ KEY = EXPR, KEY = EXPR, ... ]\n```\n\nWhere:\n- `KEY` is the environment variable name injected into the target step\n- `EXPR` is an output path expression (see below)\n\n### Output Path Expressions\n\nAll expressions start with `output`, which refers to the source step's output.\n\n| Expression | Meaning |\n|---|---|\n| `output` | Raw output (full string) |\n| `output.key` | JSON object field access |\n| `output[N]` | JSON array index (0-based) |\n| `output.key[N]` | Chained: field then index |\n| `output[N].key` | Chained: index then field |\n| `output.a.b.c` | Deeply nested field access |\n| `output.a[0].b[1].c` | Arbitrary nesting |\n\nIf the source step's output is valid JSON, path expressions navigate the parsed\nstructure. If the output is plain text, only bare `output` is valid — any `.key`\nor `[N]` access is a runtime error.\n\nThe resolved value is always converted to a string for injection as an env var.\nJSON objects and arrays are re-serialized as JSON strings. Scalars use their\nnatural string representation.\n\n### Examples\n\n```\nworkflow \"main\" {\n  step get-tasks {\n    run     = \"bd ready --json --limit 1\"\n    results = [success, fail]\n  }\n\n  step prepare-prompt {\n    run     = \"bash .cloche/scripts/prepare-prompt.sh\"\n    results = [success, fail]\n  }\n\n  step develop {\n    workflow_name = \"develop\"\n    results       = [success, fail]\n  }\n\n  get-tasks:success -> prepare-prompt [\n    CLOCHE_TASK_ID    = output[0].id,\n    CLOCHE_TASK_TITLE = output[0].title,\n    CLOCHE_TASK_BODY  = output[0].description\n  ]\n  get-tasks:fail       -> abort\n  prepare-prompt:success -> develop\n  develop:success        -> done\n  develop:fail           -> abort\n}\n```\n\nMultiple wires into the same step merge their mappings. If two wires map the\nsame key, that's a validation error (ambiguous).\n\n### Interaction with CLOCHE_PREV_OUTPUT\n\n`CLOCHE_PREV_OUTPUT` continues to work as before — it always points to the\nprevious step's raw output file. Output mappings are additive: they inject\nextra env vars alongside the existing ones. A step can use both the mapped\nvars and read the raw file if needed.\n\n## Implementation\n\n### Domain Changes\n\nAdd an `OutputMap` field to `Wire`:\n\n```go\ntype Wire struct {\n    From      string\n    Result    string\n    To        string\n    OutputMap []OutputMapping  // new\n}\n\ntype OutputMapping struct {\n    EnvVar string     // e.g. \"CLOCHE_TASK_ID\"\n    Path   OutputPath // parsed expression\n}\n\ntype OutputPath struct {\n    Segments []PathSegment\n}\n\ntype PathSegment struct {\n    Kind  SegmentKind // SegmentField or SegmentIndex\n    Field string      // for SegmentField\n    Index int         // for SegmentIndex\n}\n```\n\n### Lexer Changes\n\nThe lexer already supports `[`, `]`, `.`, `=`, `,`, and identifiers. Integer\nliterals are needed for array indices — add `TokenInt`.\n\n### Parser Changes\n\nAfter parsing `FROM:RESULT -> TO`, check for an optional `[` token. If present,\nparse a comma-separated list of `IDENT = output PATH` mappings until `]`.\n\nThe `output` keyword is a contextual identifier — it's only special inside\nmapping brackets. No new reserved words needed.\n\n```\nparseWire():\n    from  = expect(TokenIdent)\n    _     = expect(TokenColon)\n    result = expect(TokenIdent)\n    _     = expect(TokenArrow)\n    to    = expect(TokenIdent)\n    if peek() == TokenLBracket:\n        mappings = parseOutputMappings()\n    return Wire{from, result, to, mappings}\n\nparseOutputMappings():\n    expect(TokenLBracket)\n    mappings = []\n    loop:\n        key  = expect(TokenIdent)\n        _    = expect(TokenEquals)\n        path = parseOutputPath()\n        mappings.append({key, path})\n        if peek() != TokenComma: break\n        expect(TokenComma)\n    expect(TokenRBracket)\n    return mappings\n\nparseOutputPath():\n    expect(TokenIdent, \"output\")  // must start with \"output\"\n    segments = []\n    loop:\n        if peek() == TokenDot:\n            expect(TokenDot)\n            segments.append(FieldSegment{expect(TokenIdent)})\n        else if peek() == TokenLBracket:\n            expect(TokenLBracket)\n            segments.append(IndexSegment{expect(TokenInt)})\n            expect(TokenRBracket)\n        else:\n            break\n    return OutputPath{segments}\n```\n\n### Validation Changes\n\nIn `Workflow.Validate()`:\n- If two wires target the same step and both map the same env var key, error.\n- Output path expressions are syntactically validated at parse time (no runtime\n  path validation — the output isn't known until execution).\n\n### Executor Changes\n\nIn `internal/host/executor.go`, when launching a step:\n\n1. Find all wires that target this step.\n2. For each wire with output mappings, read the source step's output file.\n3. Try to parse the output as JSON. If it's valid JSON, evaluate each path\n   expression against the parsed value. If it's not JSON and any path has\n   segments, return an error.\n4. Add resolved values to the step's env as `KEY=value`.\n\n```go\nfunc (e *Executor) resolveOutputMappings(step string, wires []domain.Wire) ([]string, error) {\n    var env []string\n    for _, w := range wires {\n        if w.To != step || len(w.OutputMap) == 0 {\n            continue\n        }\n        data, err := os.ReadFile(e.stepOutputPath(w.From))\n        if err != nil {\n            return nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n        }\n        for _, m := range w.OutputMap {\n            val, err := m.Path.Evaluate(data)\n            if err != nil {\n                return nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, step, err)\n            }\n            env = append(env, m.EnvVar+\"=\"+val)\n        }\n    }\n    return env, nil\n}\n```\n\n### Path Evaluation\n\n```go\nfunc (p OutputPath) Evaluate(raw []byte) (string, error) {\n    if len(p.Segments) == 0 {\n        return string(raw), nil // bare \"output\"\n    }\n\n    var val any\n    if err := json.Unmarshal(raw, &val); err != nil {\n        return \"\", fmt.Errorf(\"output is not valid JSON\")\n    }\n\n    for _, seg := range p.Segments {\n        switch seg.Kind {\n        case SegmentField:\n            m, ok := val.(map[string]any)\n            if !ok { return \"\", fmt.Errorf(\"expected object for .%s\", seg.Field) }\n            val, ok = m[seg.Field]\n            if !ok { return \"\", fmt.Errorf(\"field %q not found\", seg.Field) }\n        case SegmentIndex:\n            arr, ok := val.([]any)\n            if !ok { return \"\", fmt.Errorf(\"expected array for [%d]\", seg.Index) }\n            if seg.Index < 0 || seg.Index >= len(arr) {\n                return \"\", fmt.Errorf(\"index %d out of range (len %d)\", seg.Index, len(arr))\n            }\n            val = arr[seg.Index]\n        }\n    }\n\n    // Convert resolved value to string\n    switch v := val.(type) {\n    case string:\n        return v, nil\n    default:\n        b, _ := json.Marshal(v)\n        return string(b), nil\n    }\n}\n```\n\n## Task Breakdown\n\n1. **Add `TokenInt` to lexer** — Recognize integer literals for array indices.\n   Update lexer tests.\n\n2. **Add `OutputMapping` and `OutputPath` types to domain** — New types in\n   `internal/domain/workflow.go`. Add `OutputMap` field to `Wire`. Add\n   `Evaluate` method to `OutputPath`. Unit test path evaluation.\n\n3. **Extend parser to handle wire output mappings** — Parse `[ KEY = EXPR ]`\n   after wire targets. Update parser tests with mapping syntax.\n\n4. **Add validation for duplicate mappings** — Error if two wires into the\n   same step map the same env var. Update validation tests.\n\n5. **Wire mapping resolution in host executor** — Read source output, evaluate\n   paths, inject env vars. Update executor tests.\n\n6. **Update host.cloche to use mappings** — Replace the current\n   `prepare-prompt` step to consume mapped vars instead of relying on\n   pre-set env.\n","numLines":288,"startLine":1,"totalLines":288}}}
