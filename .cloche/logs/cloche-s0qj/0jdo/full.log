[2026-03-15T16:17:16Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017JovQvNxHXNtFHqaG1iSaw","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"strings\"\n     9→\t\"time\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    12→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    13→)\n    14→\n    15→// OrchestratorConfig configures the evolution pipeline.\n    16→type OrchestratorConfig struct {\n    17→\tProjectDir    string\n    18→\tWorkflowName  string\n    19→\tLLM           LLMClient\n    20→\tMinConfidence string\n    21→}\n    22→\n    23→// Orchestrator wires all evolution pipeline stages together.\n    24→type Orchestrator struct {\n    25→\tcfg        OrchestratorConfig\n    26→\tcollector  *Collector\n    27→\tclassifier *Classifier\n    28→\treflector  *Reflector\n    29→\tcurator    *Curator\n    30→\tscriptGen  *ScriptGenerator\n    31→\tmutator    *dsl.Mutator\n    32→\taudit      *AuditLogger\n    33→}\n    34→\n    35→// NewOrchestrator creates a fully wired evolution pipeline.\n    36→func NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n    37→\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir}\n    38→\treturn &Orchestrator{\n    39→\t\tcfg:        cfg,\n    40→\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n    41→\t\tclassifier: &Classifier{LLM: cfg.LLM},\n    42→\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n    43→\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n    44→\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n    45→\t\tmutator:    &dsl.Mutator{},\n    46→\t\taudit:      audit,\n    47→\t}\n    48→}\n    49→\n    50→// Run executes the full evolution pipeline.\n    51→func (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n    52→\t// Stage 1: Collect\n    53→\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n    54→\tif err != nil {\n    55→\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n    56→\t}\n    57→\n    58→\t// Stage 2: Classify the triggering run\n    59→\tclassification, err := o.classifier.Classify(ctx, \"\")\n    60→\tif err != nil {\n    61→\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n    62→\t}\n    63→\n    64→\t// Stage 3: Reflect\n    65→\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n    66→\tif err != nil {\n    67→\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n    68→\t}\n    69→\n    70→\t// Filter out lessons whose IDs are already recorded in the knowledge base.\n    71→\t// This guards against the Reflector re-surfacing previously applied lessons.\n    72→\tif data.KnowledgeBase != \"\" {\n    73→\t\tvar fresh []Lesson\n    74→\t\tfor _, l := range lessons {\n    75→\t\t\tif l.ID != \"\" && strings.Contains(data.KnowledgeBase, l.ID) {\n    76→\t\t\t\tcontinue\n    77→\t\t\t}\n    78→\t\t\tfresh = append(fresh, l)\n    79→\t\t}\n    80→\t\tlessons = fresh\n    81→\t}\n    82→\n    83→\tresult := &EvolutionResult{\n    84→\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n    85→\t\tProjectDir:     o.cfg.ProjectDir,\n    86→\t\tWorkflowName:   o.cfg.WorkflowName,\n    87→\t\tTriggerRunID:   triggerRunID,\n    88→\t\tTimestamp:      time.Now().Format(time.RFC3339),\n    89→\t\tClassification: classification,\n    90→\t}\n    91→\n    92→\tif len(lessons) == 0 {\n    93→\t\t// No actionable lessons — log and return\n    94→\t\to.audit.Log(result)\n    95→\t\treturn result, nil\n    96→\t}\n    97→\n    98→\t// Stage 4: Execute branches based on lesson category\n    99→\tfor _, lesson := range lessons {\n   100→\t\tswitch lesson.Category {\n   101→\t\tcase \"prompt_improvement\":\n   102→\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n   103→\t\t\tif err != nil {\n   104→\t\t\t\tcontinue // log but don't fail the whole pipeline\n   105→\t\t\t}\n   106→\t\t\tif change == nil {\n   107→\t\t\t\tcontinue // lesson already present in prompt — no change needed\n   108→\t\t\t}\n   109→\t\t\tresult.Changes = append(result.Changes, *change)\n   110→\n   111→\t\tcase \"new_step\":\n   112→\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n   113→\t\t\t\tcontinue\n   114→\t\t\t}\n   115→\t\t}\n   116→\t}\n   117→\n   118→\t// Stage 5: Audit\n   119→\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n   120→\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n   121→\to.audit.Log(result)\n   122→\n   123→\t// Save to store if available\n   124→\tif evoStore != nil {\n   125→\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n   126→\t\t\tID:             result.ID,\n   127→\t\t\tProjectDir:     result.ProjectDir,\n   128→\t\t\tWorkflowName:   result.WorkflowName,\n   129→\t\t\tTriggerRunID:   result.TriggerRunID,\n   130→\t\t\tCreatedAt:      time.Now(),\n   131→\t\t\tClassification: result.Classification,\n   132→\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n   133→\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n   134→\t\t})\n   135→\t}\n   136→\n   137→\treturn result, nil\n   138→}\n   139→\n   140→// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\n   141→func (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n   142→\t// Generate the script or prompt file\n   143→\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n   144→\tif err != nil {\n   145→\t\treturn err\n   146→\t}\n   147→\n   148→\tresult.Changes = append(result.Changes, Change{\n   149→\t\tType:   \"add_script\",\n   150→\t\tFile:   generated.Path,\n   151→\t\tReason: lesson.Insight,\n   152→\t})\n   153→\n   154→\t// Add step and wiring to the workflow file\n   155→\tif data.WorkflowPath == \"\" {\n   156→\t\treturn nil\n   157→\t}\n   158→\n   159→\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n   160→\tif err != nil {\n   161→\t\treturn err\n   162→\t}\n   163→\n   164→\t// Snapshot the workflow\n   165→\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n   166→\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n   167→\toriginal := string(workflowContent)\n   168→\n   169→\t// Derive step name from the script path\n   170→\tstepName := filepath.Base(generated.Path)\n   171→\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n   172→\n   173→\t// Check if a step with this name already exists — skip if so\n   174→\texistingWf, parseErr := dsl.Parse(original)\n   175→\tif parseErr == nil {\n   176→\t\tif _, exists := existingWf.Steps[stepName]; exists {\n   177→\t\t\treturn nil\n   178→\t\t}\n   179→\t}\n   180→\n   181→\t// Determine the config based on step type\n   182→\tconfig := map[string]string{}\n   183→\tswitch lesson.StepType {\n   184→\tcase \"agent\":\n   185→\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n   186→\tdefault: // script\n   187→\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n   188→\t}\n   189→\n   190→\t// Add the step\n   191→\tupdated, err := o.mutator.AddStep(original, dsl.StepDef{\n   192→\t\tName:    stepName,\n   193→\t\tType:    lesson.StepType,\n   194→\t\tConfig:  config,\n   195→\t\tResults: []string{\"success\", \"fail\"},\n   196→\t})\n   197→\tif err != nil {\n   198→\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n   199→\t}\n   200→\n   201→\t// Wire the new step into the existing graph by finding a wire\n   202→\t// that currently goes to \"done\" and rerouting it through the new step.\n   203→\twf, parseErr := dsl.Parse(updated)\n   204→\tif parseErr == nil {\n   205→\t\tfor _, wire := range wf.Wiring {\n   206→\t\t\tif wire.To == \"done\" {\n   207→\t\t\t\trewired, rewireErr := o.mutator.RewireResult(updated, wire.From, wire.Result, \"done\", stepName)\n   208→\t\t\t\tif rewireErr == nil {\n   209→\t\t\t\t\tupdated = rewired\n   210→\t\t\t\t\tbreak\n   211→\t\t\t\t}\n   212→\t\t\t}\n   213→\t\t}\n   214→\t}\n   215→\n   216→\t// Wire the new step's results to terminals\n   217→\twires := []dsl.WireDef{\n   218→\t\t{From: stepName, Result: \"success\", To: \"done\"},\n   219→\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n   220→\t}\n   221→\tupdated, err = o.mutator.AddWiring(updated, wires)\n   222→\tif err != nil {\n   223→\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n   224→\t}\n   225→\n   226→\t// Validate the final workflow graph — roll back on failure\n   227→\tfinalWf, parseErr := dsl.Parse(updated)\n   228→\tif parseErr != nil {\n   229→\t\treturn fmt.Errorf(\"parsing updated workflow: %w\", parseErr)\n   230→\t}\n   231→\tif valErr := finalWf.Validate(); valErr != nil {\n   232→\t\treturn fmt.Errorf(\"workflow validation failed after adding step %q: %w\", stepName, valErr)\n   233→\t}\n   234→\n   235→\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n   236→\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n   237→\t}\n   238→\n   239→\tresult.Changes = append(result.Changes, Change{\n   240→\t\tType:     \"add_step\",\n   241→\t\tFile:     wfRelPath,\n   242→\t\tReason:   lesson.Insight,\n   243→\t\tSnapshot: snapName,\n   244→\t})\n   245→\n   246→\treturn nil\n   247→}\n   248→"}]},"parent_tool_use_id":null,"session_id":"f9cd3635-7b59-4df8-9a88-6beef5e619d5","uuid":"4105ed08-a1e0-4d28-b7a2-709eedc05b06","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/orchestrator.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// OrchestratorConfig configures the evolution pipeline.\ntype OrchestratorConfig struct {\n\tProjectDir    string\n\tWorkflowName  string\n\tLLM           LLMClient\n\tMinConfidence string\n}\n\n// Orchestrator wires all evolution pipeline stages together.\ntype Orchestrator struct {\n\tcfg        OrchestratorConfig\n\tcollector  *Collector\n\tclassifier *Classifier\n\treflector  *Reflector\n\tcurator    *Curator\n\tscriptGen  *ScriptGenerator\n\tmutator    *dsl.Mutator\n\taudit      *AuditLogger\n}\n\n// NewOrchestrator creates a fully wired evolution pipeline.\nfunc NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir}\n\treturn &Orchestrator{\n\t\tcfg:        cfg,\n\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n\t\tclassifier: &Classifier{LLM: cfg.LLM},\n\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n\t\tmutator:    &dsl.Mutator{},\n\t\taudit:      audit,\n\t}\n}\n\n// Run executes the full evolution pipeline.\nfunc (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n\t// Stage 1: Collect\n\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n\t}\n\n\t// Stage 2: Classify the triggering run\n\tclassification, err := o.classifier.Classify(ctx, \"\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n\t}\n\n\t// Stage 3: Reflect\n\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n\t}\n\n\t// Filter out lessons whose IDs are already recorded in the knowledge base.\n\t// This guards against the Reflector re-surfacing previously applied lessons.\n\tif data.KnowledgeBase != \"\" {\n\t\tvar fresh []Lesson\n\t\tfor _, l := range lessons {\n\t\t\tif l.ID != \"\" && strings.Contains(data.KnowledgeBase, l.ID) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfresh = append(fresh, l)\n\t\t}\n\t\tlessons = fresh\n\t}\n\n\tresult := &EvolutionResult{\n\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n\t\tProjectDir:     o.cfg.ProjectDir,\n\t\tWorkflowName:   o.cfg.WorkflowName,\n\t\tTriggerRunID:   triggerRunID,\n\t\tTimestamp:      time.Now().Format(time.RFC3339),\n\t\tClassification: classification,\n\t}\n\n\tif len(lessons) == 0 {\n\t\t// No actionable lessons — log and return\n\t\to.audit.Log(result)\n\t\treturn result, nil\n\t}\n\n\t// Stage 4: Execute branches based on lesson category\n\tfor _, lesson := range lessons {\n\t\tswitch lesson.Category {\n\t\tcase \"prompt_improvement\":\n\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // log but don't fail the whole pipeline\n\t\t\t}\n\t\t\tif change == nil {\n\t\t\t\tcontinue // lesson already present in prompt — no change needed\n\t\t\t}\n\t\t\tresult.Changes = append(result.Changes, *change)\n\n\t\tcase \"new_step\":\n\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\t}\n\n\t// Stage 5: Audit\n\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n\to.audit.Log(result)\n\n\t// Save to store if available\n\tif evoStore != nil {\n\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n\t\t\tID:             result.ID,\n\t\t\tProjectDir:     result.ProjectDir,\n\t\t\tWorkflowName:   result.WorkflowName,\n\t\t\tTriggerRunID:   result.TriggerRunID,\n\t\t\tCreatedAt:      time.Now(),\n\t\t\tClassification: result.Classification,\n\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n\t\t})\n\t}\n\n\treturn result, nil\n}\n\n// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\nfunc (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n\t// Generate the script or prompt file\n\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tresult.Changes = append(result.Changes, Change{\n\t\tType:   \"add_script\",\n\t\tFile:   generated.Path,\n\t\tReason: lesson.Insight,\n\t})\n\n\t// Add step and wiring to the workflow file\n\tif data.WorkflowPath == \"\" {\n\t\treturn nil\n\t}\n\n\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// Snapshot the workflow\n\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n\toriginal := string(workflowContent)\n\n\t// Derive step name from the script path\n\tstepName := filepath.Base(generated.Path)\n\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n\n\t// Check if a step with this name already exists — skip if so\n\texistingWf, parseErr := dsl.Parse(original)\n\tif parseErr == nil {\n\t\tif _, exists := existingWf.Steps[stepName]; exists {\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Determine the config based on step type\n\tconfig := map[string]string{}\n\tswitch lesson.StepType {\n\tcase \"agent\":\n\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n\tdefault: // script\n\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n\t}\n\n\t// Add the step\n\tupdated, err := o.mutator.AddStep(original, dsl.StepDef{\n\t\tName:    stepName,\n\t\tType:    lesson.StepType,\n\t\tConfig:  config,\n\t\tResults: []string{\"success\", \"fail\"},\n\t})\n\tif err != nil {\n\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n\t}\n\n\t// Wire the new step into the existing graph by finding a wire\n\t// that currently goes to \"done\" and rerouting it through the new step.\n\twf, parseErr := dsl.Parse(updated)\n\tif parseErr == nil {\n\t\tfor _, wire := range wf.Wiring {\n\t\t\tif wire.To == \"done\" {\n\t\t\t\trewired, rewireErr := o.mutator.RewireResult(updated, wire.From, wire.Result, \"done\", stepName)\n\t\t\t\tif rewireErr == nil {\n\t\t\t\t\tupdated = rewired\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Wire the new step's results to terminals\n\twires := []dsl.WireDef{\n\t\t{From: stepName, Result: \"success\", To: \"done\"},\n\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n\t}\n\tupdated, err = o.mutator.AddWiring(updated, wires)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n\t}\n\n\t// Validate the final workflow graph — roll back on failure\n\tfinalWf, parseErr := dsl.Parse(updated)\n\tif parseErr != nil {\n\t\treturn fmt.Errorf(\"parsing updated workflow: %w\", parseErr)\n\t}\n\tif valErr := finalWf.Validate(); valErr != nil {\n\t\treturn fmt.Errorf(\"workflow validation failed after adding step %q: %w\", stepName, valErr)\n\t}\n\n\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n\t}\n\n\tresult.Changes = append(result.Changes, Change{\n\t\tType:     \"add_step\",\n\t\tFile:     wfRelPath,\n\t\tReason:   lesson.Insight,\n\t\tSnapshot: snapName,\n\t})\n\n\treturn nil\n}\n","numLines":248,"startLine":1,"totalLines":248}}}
