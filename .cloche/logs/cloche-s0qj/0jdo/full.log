[2026-03-15T16:16:15Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013mRMY4rXAbxnbYcwkW868B","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    11→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    12→)\n    13→\n    14→// OrchestratorConfig configures the evolution pipeline.\n    15→type OrchestratorConfig struct {\n    16→\tProjectDir    string\n    17→\tWorkflowName  string\n    18→\tLLM           LLMClient\n    19→\tMinConfidence string\n    20→}\n    21→\n    22→// Orchestrator wires all evolution pipeline stages together.\n    23→type Orchestrator struct {\n    24→\tcfg        OrchestratorConfig\n    25→\tcollector  *Collector\n    26→\tclassifier *Classifier\n    27→\treflector  *Reflector\n    28→\tcurator    *Curator\n    29→\tscriptGen  *ScriptGenerator\n    30→\tmutator    *dsl.Mutator\n    31→\taudit      *AuditLogger\n    32→}\n    33→\n    34→// NewOrchestrator creates a fully wired evolution pipeline.\n    35→func NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n    36→\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir}\n    37→\treturn &Orchestrator{\n    38→\t\tcfg:        cfg,\n    39→\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n    40→\t\tclassifier: &Classifier{LLM: cfg.LLM},\n    41→\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n    42→\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n    43→\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n    44→\t\tmutator:    &dsl.Mutator{},\n    45→\t\taudit:      audit,\n    46→\t}\n    47→}\n    48→\n    49→// Run executes the full evolution pipeline.\n    50→func (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n    51→\t// Stage 1: Collect\n    52→\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n    53→\tif err != nil {\n    54→\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n    55→\t}\n    56→\n    57→\t// Stage 2: Classify the triggering run\n    58→\tclassification, err := o.classifier.Classify(ctx, \"\")\n    59→\tif err != nil {\n    60→\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n    61→\t}\n    62→\n    63→\t// Stage 3: Reflect\n    64→\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n    65→\tif err != nil {\n    66→\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n    67→\t}\n    68→\n    69→\tresult := &EvolutionResult{\n    70→\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n    71→\t\tProjectDir:     o.cfg.ProjectDir,\n    72→\t\tWorkflowName:   o.cfg.WorkflowName,\n    73→\t\tTriggerRunID:   triggerRunID,\n    74→\t\tTimestamp:      time.Now().Format(time.RFC3339),\n    75→\t\tClassification: classification,\n    76→\t}\n    77→\n    78→\tif len(lessons) == 0 {\n    79→\t\t// No actionable lessons — log and return\n    80→\t\to.audit.Log(result)\n    81→\t\treturn result, nil\n    82→\t}\n    83→\n    84→\t// Stage 4: Execute branches based on lesson category\n    85→\tfor _, lesson := range lessons {\n    86→\t\tswitch lesson.Category {\n    87→\t\tcase \"prompt_improvement\":\n    88→\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n    89→\t\t\tif err != nil {\n    90→\t\t\t\tcontinue // log but don't fail the whole pipeline\n    91→\t\t\t}\n    92→\t\t\tresult.Changes = append(result.Changes, *change)\n    93→\n    94→\t\tcase \"new_step\":\n    95→\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n    96→\t\t\t\tcontinue\n    97→\t\t\t}\n    98→\t\t}\n    99→\t}\n   100→\n   101→\t// Stage 5: Audit\n   102→\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n   103→\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n   104→\to.audit.Log(result)\n   105→\n   106→\t// Save to store if available\n   107→\tif evoStore != nil {\n   108→\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n   109→\t\t\tID:             result.ID,\n   110→\t\t\tProjectDir:     result.ProjectDir,\n   111→\t\t\tWorkflowName:   result.WorkflowName,\n   112→\t\t\tTriggerRunID:   result.TriggerRunID,\n   113→\t\t\tCreatedAt:      time.Now(),\n   114→\t\t\tClassification: result.Classification,\n   115→\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n   116→\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n   117→\t\t})\n   118→\t}\n   119→\n   120→\treturn result, nil\n   121→}\n   122→\n   123→// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\n   124→func (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n   125→\t// Generate the script or prompt file\n   126→\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n   127→\tif err != nil {\n   128→\t\treturn err\n   129→\t}\n   130→\n   131→\tresult.Changes = append(result.Changes, Change{\n   132→\t\tType:   \"add_script\",\n   133→\t\tFile:   generated.Path,\n   134→\t\tReason: lesson.Insight,\n   135→\t})\n   136→\n   137→\t// Add step and wiring to the workflow file\n   138→\tif data.WorkflowPath == \"\" {\n   139→\t\treturn nil\n   140→\t}\n   141→\n   142→\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n   143→\tif err != nil {\n   144→\t\treturn err\n   145→\t}\n   146→\n   147→\t// Snapshot the workflow\n   148→\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n   149→\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n   150→\toriginal := string(workflowContent)\n   151→\n   152→\t// Derive step name from the script path\n   153→\tstepName := filepath.Base(generated.Path)\n   154→\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n   155→\n   156→\t// Check if a step with this name already exists — skip if so\n   157→\texistingWf, parseErr := dsl.Parse(original)\n   158→\tif parseErr == nil {\n   159→\t\tif _, exists := existingWf.Steps[stepName]; exists {\n   160→\t\t\treturn nil\n   161→\t\t}\n   162→\t}\n   163→\n   164→\t// Determine the config based on step type\n   165→\tconfig := map[string]string{}\n   166→\tswitch lesson.StepType {\n   167→\tcase \"agent\":\n   168→\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n   169→\tdefault: // script\n   170→\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n   171→\t}\n   172→\n   173→\t// Add the step\n   174→\tupdated, err := o.mutator.AddStep(original, dsl.StepDef{\n   175→\t\tName:    stepName,\n   176→\t\tType:    lesson.StepType,\n   177→\t\tConfig:  config,\n   178→\t\tResults: []string{\"success\", \"fail\"},\n   179→\t})\n   180→\tif err != nil {\n   181→\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n   182→\t}\n   183→\n   184→\t// Wire the new step into the existing graph by finding a wire\n   185→\t// that currently goes to \"done\" and rerouting it through the new step.\n   186→\twf, parseErr := dsl.Parse(updated)\n   187→\tif parseErr == nil {\n   188→\t\tfor _, wire := range wf.Wiring {\n   189→\t\t\tif wire.To == \"done\" {\n   190→\t\t\t\trewired, rewireErr := o.mutator.RewireResult(updated, wire.From, wire.Result, \"done\", stepName)\n   191→\t\t\t\tif rewireErr == nil {\n   192→\t\t\t\t\tupdated = rewired\n   193→\t\t\t\t\tbreak\n   194→\t\t\t\t}\n   195→\t\t\t}\n   196→\t\t}\n   197→\t}\n   198→\n   199→\t// Wire the new step's results to terminals\n   200→\twires := []dsl.WireDef{\n   201→\t\t{From: stepName, Result: \"success\", To: \"done\"},\n   202→\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n   203→\t}\n   204→\tupdated, err = o.mutator.AddWiring(updated, wires)\n   205→\tif err != nil {\n   206→\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n   207→\t}\n   208→\n   209→\t// Validate the final workflow graph — roll back on failure\n   210→\tfinalWf, parseErr := dsl.Parse(updated)\n   211→\tif parseErr != nil {\n   212→\t\treturn fmt.Errorf(\"parsing updated workflow: %w\", parseErr)\n   213→\t}\n   214→\tif valErr := finalWf.Validate(); valErr != nil {\n   215→\t\treturn fmt.Errorf(\"workflow validation failed after adding step %q: %w\", stepName, valErr)\n   216→\t}\n   217→\n   218→\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n   219→\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n   220→\t}\n   221→\n   222→\tresult.Changes = append(result.Changes, Change{\n   223→\t\tType:     \"add_step\",\n   224→\t\tFile:     wfRelPath,\n   225→\t\tReason:   lesson.Insight,\n   226→\t\tSnapshot: snapName,\n   227→\t})\n   228→\n   229→\treturn nil\n   230→}\n   231→"}]},"parent_tool_use_id":null,"session_id":"0f52420b-6a9a-40b5-a8a8-07211229ec2e","uuid":"78cd74f1-91bb-470c-aa41-f2c1bfd72fa7","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/orchestrator.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// OrchestratorConfig configures the evolution pipeline.\ntype OrchestratorConfig struct {\n\tProjectDir    string\n\tWorkflowName  string\n\tLLM           LLMClient\n\tMinConfidence string\n}\n\n// Orchestrator wires all evolution pipeline stages together.\ntype Orchestrator struct {\n\tcfg        OrchestratorConfig\n\tcollector  *Collector\n\tclassifier *Classifier\n\treflector  *Reflector\n\tcurator    *Curator\n\tscriptGen  *ScriptGenerator\n\tmutator    *dsl.Mutator\n\taudit      *AuditLogger\n}\n\n// NewOrchestrator creates a fully wired evolution pipeline.\nfunc NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir}\n\treturn &Orchestrator{\n\t\tcfg:        cfg,\n\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n\t\tclassifier: &Classifier{LLM: cfg.LLM},\n\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n\t\tmutator:    &dsl.Mutator{},\n\t\taudit:      audit,\n\t}\n}\n\n// Run executes the full evolution pipeline.\nfunc (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n\t// Stage 1: Collect\n\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n\t}\n\n\t// Stage 2: Classify the triggering run\n\tclassification, err := o.classifier.Classify(ctx, \"\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n\t}\n\n\t// Stage 3: Reflect\n\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n\t}\n\n\tresult := &EvolutionResult{\n\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n\t\tProjectDir:     o.cfg.ProjectDir,\n\t\tWorkflowName:   o.cfg.WorkflowName,\n\t\tTriggerRunID:   triggerRunID,\n\t\tTimestamp:      time.Now().Format(time.RFC3339),\n\t\tClassification: classification,\n\t}\n\n\tif len(lessons) == 0 {\n\t\t// No actionable lessons — log and return\n\t\to.audit.Log(result)\n\t\treturn result, nil\n\t}\n\n\t// Stage 4: Execute branches based on lesson category\n\tfor _, lesson := range lessons {\n\t\tswitch lesson.Category {\n\t\tcase \"prompt_improvement\":\n\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // log but don't fail the whole pipeline\n\t\t\t}\n\t\t\tresult.Changes = append(result.Changes, *change)\n\n\t\tcase \"new_step\":\n\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\t}\n\n\t// Stage 5: Audit\n\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n\to.audit.Log(result)\n\n\t// Save to store if available\n\tif evoStore != nil {\n\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n\t\t\tID:             result.ID,\n\t\t\tProjectDir:     result.ProjectDir,\n\t\t\tWorkflowName:   result.WorkflowName,\n\t\t\tTriggerRunID:   result.TriggerRunID,\n\t\t\tCreatedAt:      time.Now(),\n\t\t\tClassification: result.Classification,\n\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n\t\t})\n\t}\n\n\treturn result, nil\n}\n\n// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\nfunc (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n\t// Generate the script or prompt file\n\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tresult.Changes = append(result.Changes, Change{\n\t\tType:   \"add_script\",\n\t\tFile:   generated.Path,\n\t\tReason: lesson.Insight,\n\t})\n\n\t// Add step and wiring to the workflow file\n\tif data.WorkflowPath == \"\" {\n\t\treturn nil\n\t}\n\n\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// Snapshot the workflow\n\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n\toriginal := string(workflowContent)\n\n\t// Derive step name from the script path\n\tstepName := filepath.Base(generated.Path)\n\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n\n\t// Check if a step with this name already exists — skip if so\n\texistingWf, parseErr := dsl.Parse(original)\n\tif parseErr == nil {\n\t\tif _, exists := existingWf.Steps[stepName]; exists {\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Determine the config based on step type\n\tconfig := map[string]string{}\n\tswitch lesson.StepType {\n\tcase \"agent\":\n\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n\tdefault: // script\n\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n\t}\n\n\t// Add the step\n\tupdated, err := o.mutator.AddStep(original, dsl.StepDef{\n\t\tName:    stepName,\n\t\tType:    lesson.StepType,\n\t\tConfig:  config,\n\t\tResults: []string{\"success\", \"fail\"},\n\t})\n\tif err != nil {\n\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n\t}\n\n\t// Wire the new step into the existing graph by finding a wire\n\t// that currently goes to \"done\" and rerouting it through the new step.\n\twf, parseErr := dsl.Parse(updated)\n\tif parseErr == nil {\n\t\tfor _, wire := range wf.Wiring {\n\t\t\tif wire.To == \"done\" {\n\t\t\t\trewired, rewireErr := o.mutator.RewireResult(updated, wire.From, wire.Result, \"done\", stepName)\n\t\t\t\tif rewireErr == nil {\n\t\t\t\t\tupdated = rewired\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Wire the new step's results to terminals\n\twires := []dsl.WireDef{\n\t\t{From: stepName, Result: \"success\", To: \"done\"},\n\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n\t}\n\tupdated, err = o.mutator.AddWiring(updated, wires)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n\t}\n\n\t// Validate the final workflow graph — roll back on failure\n\tfinalWf, parseErr := dsl.Parse(updated)\n\tif parseErr != nil {\n\t\treturn fmt.Errorf(\"parsing updated workflow: %w\", parseErr)\n\t}\n\tif valErr := finalWf.Validate(); valErr != nil {\n\t\treturn fmt.Errorf(\"workflow validation failed after adding step %q: %w\", stepName, valErr)\n\t}\n\n\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n\t}\n\n\tresult.Changes = append(result.Changes, Change{\n\t\tType:     \"add_step\",\n\t\tFile:     wfRelPath,\n\t\tReason:   lesson.Insight,\n\t\tSnapshot: snapName,\n\t})\n\n\treturn nil\n}\n","numLines":231,"startLine":1,"totalLines":231}}}
