t}\n    44→\n    45→\tupdated := stripCodeFences(raw)\n    46→\n    47→\t// Validate that the LLM output is actual prompt content, not meta-conversation\n    48→\tif isConversationalResponse(updated) {\n    49→\t\t// Fallback: append the lesson directly rather than trusting the LLM\n    50→\t\tupdated = appendLessonDirectly(string(current), lesson)\n    51→\t}\n    52→\n    53→\t// Snapshot before writing\n    54→\tvar snapName string\n    55→\tif c.Audit != nil {\n    56→\t\tsnapName, _ = c.Audit.Snapshot(lesson.Target)\n    57→\t}\n    58→\n    59→\tif err := os.WriteFile(targetPath, []byte(updated), 0644); err != nil {\n    60→\t\treturn nil, fmt.Errorf(\"writing updated prompt: %w\", err)\n    61→\t}\n    62→\n    63→\treturn &Change{\n    64→\t\tType:     \"prompt_update\",\n    65→\t\tFile:     lesson.Target,\n    66→\t\tReason:   lesson.Insight,\n    67→\t\tSnapshot: snapName,\n    68→\t}, nil\n    69→}\n    70→\n    71→// conversationalMarkers are patterns that indicate the LLM returned\n    72→// meta-conversation text instead of prompt content.\n    73→var conversationalMarkers = regexp.MustCompile(\n    74→\t`(?i)^(I need |I can't |I cannot |Could you |Please grant |` +\n    75→\t\t`I don't have |I do not have |permission|write access|blocked by|` +\n    76→\t\t`Here is the updated|Here's the updated|I've updated|I have updated|` +\n    77→\t\t`Let me |I'll |I will )`)\n    78→\n    79→// isConversationalResponse checks whether the LLM output appears to be\n    80→// meta-conversation text rather than actual prompt content.\n    81→func isConversationalResponse(s string) bool {\n    82→\ttrimmed := strings.TrimSpace(s)\n    83→\tif trimmed == \"\" {\n    84→\t\treturn true\n    85→\t}\n    86→\t// Check the first non-empty line for conversational markers\n    87→\tfirstLine := trimmed\n    88→\tif idx := strings.Index(trimmed, \"\\n\"); idx != -1 {\n    89→\t\tfirstLine = trimmed[:idx]\n    90→\t}\n    91→\treturn conversationalMarkers.MatchString(strings