[2026-03-15T16:17:16Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TKZVxNWxrbF8pUK17sSZpx","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"strings\"\n     9→\t\"testing\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    12→\t\"github.com/stretchr/testify/assert\"\n    13→\t\"github.com/stretchr/testify/require\"\n    14→)\n    15→\n    16→// fakeLLM returns a fixed response for testing.\n    17→type fakeLLM struct {\n    18→\tresponse string\n    19→}\n    20→\n    21→func (f *fakeLLM) Complete(ctx context.Context, system, user string) (string, error) {\n    22→\treturn f.response, nil\n    23→}\n    24→\n    25→// --- Collector tests ---\n    26→\n    27→func TestCollectorGathersData(t *testing.T) {\n    28→\tdir := t.TempDir()\n    29→\n    30→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n    31→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n    32→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n    33→\t\t[]byte(\"# Knowledge Base\\n\"), 0644)\n    34→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n    35→\t\t[]byte(\"Write good code\"), 0644)\n    36→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n    37→\t\t[]byte(`workflow \"develop\" {\n    38→  step impl {\n    39→    prompt = file(\".cloche/prompts/implement.md\")\n    40→    results = [success]\n    41→  }\n    42→  impl:success -> done\n    43→}`), 0644)\n    44→\n    45→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n    46→\tdata, err := c.Collect(context.Background(), nil, nil)\n    47→\trequire.NoError(t, err)\n    48→\n    49→\tassert.Equal(t, \"# Knowledge Base\\n\", data.KnowledgeBase)\n    50→\tassert.Contains(t, data.CurrentPrompts, \".cloche/prompts/implement.md\")\n    51→\tassert.Equal(t, \"Write good code\", data.CurrentPrompts[\".cloche/prompts/implement.md\"])\n    52→\tassert.NotEmpty(t, data.CurrentWorkflow)\n    53→\tassert.Equal(t, dir, data.ProjectDir)\n    54→\tassert.Equal(t, \"develop\", data.WorkflowName)\n    55→}\n    56→\n    57→func TestCollectorNoKnowledgeBase(t *testing.T) {\n    58→\tdir := t.TempDir()\n    59→\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n    60→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n    61→\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n    62→\n    63→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n    64→\tdata, err := c.Collect(context.Background(), nil, nil)\n    65→\trequire.NoError(t, err)\n    66→\tassert.Empty(t, data.KnowledgeBase)\n    67→}\n    68→\n    69→func TestExtractPromptFiles(t *testing.T) {\n    70→\tworkflow := `step impl { prompt = file(\".cloche/prompts/implement.md\") }\n    71→step fix { prompt = file(\".cloche/prompts/fix.md\") }\n    72→step test { run = \"make test\" }`\n    73→\n    74→\tfiles := extractPromptFiles(workflow)\n    75→\tassert.Len(t, files, 2)\n    76→\tassert.Contains(t, files, \".cloche/prompts/implement.md\")\n    77→\tassert.Contains(t, files, \".cloche/prompts/fix.md\")\n    78→}\n    79→\n    80→// --- Classifier tests ---\n    81→\n    82→func TestClassifierCategorizesRun(t *testing.T) {\n    83→\ttests := []struct {\n    84→\t\tname     string\n    85→\t\tresponse string\n    86→\t\texpected string\n    87→\t}{\n    88→\t\t{\"bug\", `{\"classification\": \"bug\"}`, \"bug\"},\n    89→\t\t{\"feature\", `{\"classification\": \"feature\"}`, \"feature\"},\n    90→\t\t{\"feedback\", `{\"classification\": \"feedback\"}`, \"feedback\"},\n    91→\t\t{\"enhancement\", `{\"classification\": \"enhancement\"}`, \"enhancement\"},\n    92→\t\t{\"chore\", `{\"classification\": \"chore\"}`, \"chore\"},\n    93→\t\t{\"invalid defaults to feature\", `{\"classification\": \"unknown\"}`, \"feature\"},\n    94→\t\t{\"malformed JSON defaults to feature\", `not json`, \"feature\"},\n    95→\t}\n    96→\n    97→\tfor _, tt := range tests {\n    98→\t\tt.Run(tt.name, func(t *testing.T) {\n    99→\t\t\tllm := &fakeLLM{response: tt.response}\n   100→\t\t\tc := &Classifier{LLM: llm}\n   101→\t\t\tresult, err := c.Classify(context.Background(), \"some prompt\")\n   102→\t\t\trequire.NoError(t, err)\n   103→\t\t\tassert.Equal(t, tt.expected, result)\n   104→\t\t})\n   105→\t}\n   106→}\n   107→\n   108→// --- Reflector tests ---\n   109→\n   110→func TestReflectorExtractsLessons(t *testing.T) {\n   111→\tlessonsJSON, _ := json.Marshal(map[string]any{\n   112→\t\t\"lessons\": []map[string]any{\n   113→\t\t\t{\n   114→\t\t\t\t\"id\":               \"lesson-001\",\n   115→\t\t\t\t\"category\":         \"prompt_improvement\",\n   116→\t\t\t\t\"target\":           \".cloche/prompts/implement.md\",\n   117→\t\t\t\t\"insight\":          \"Agent produces unsanitized HTML\",\n   118→\t\t\t\t\"suggested_action\": \"Add sanitization rule\",\n   119→\t\t\t\t\"evidence\":         []string{\"run-1\", \"run-2\"},\n   120→\t\t\t\t\"confidence\":       \"high\",\n   121→\t\t\t},\n   122→\t\t},\n   123→\t})\n   124→\n   125→\tllm := &fakeLLM{response: string(lessonsJSON)}\n   126→\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n   127→\n   128→\tdata := &CollectedData{WorkflowName: \"develop\", KnowledgeBase: \"# KB\\n\"}\n   129→\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n   130→\trequire.NoError(t, err)\n   131→\trequire.Len(t, lessons, 1)\n   132→\tassert.Equal(t, \"prompt_improvement\", lessons[0].Category)\n   133→\tassert.Equal(t, \"high\", lessons[0].Confidence)\n   134→}\n   135→\n   136→func TestReflectorFiltersLowConfidence(t *testing.T) {\n   137→\tlessonsJSON, _ := json.Marshal(map[string]any{\n   138→\t\t\"lessons\": []map[string]any{\n   139→\t\t\t{\"id\": \"L1\", \"category\": \"new_step\", \"confidence\": \"low\"},\n   140→\t\t\t{\"id\": \"L2\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n   141→\t\t},\n   142→\t})\n   143→\n   144→\tllm := &fakeLLM{response: string(lessonsJSON)}\n   145→\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n   146→\n   147→\tlessons, err := r.Reflect(context.Background(), &CollectedData{}, \"bug\")\n   148→\trequire.NoError(t, err)\n   149→\tassert.Len(t, lessons, 1)\n   150→\tassert.Equal(t, \"L2\", lessons[0].ID)\n   151→}\n   152→\n   153→func TestConfidenceLevel(t *testing.T) {\n   154→\tassert.Equal(t, 3, confidenceLevel(\"high\"))\n   155→\tassert.Equal(t, 2, confidenceLevel(\"medium\"))\n   156→\tassert.Equal(t, 1, confidenceLevel(\"low\"))\n   157→\tassert.Equal(t, 0, confidenceLevel(\"\"))\n   158→}\n   159→\n   160→// --- Audit Logger tests ---\n   161→\n   162→func TestAuditLoggerAppendsJSONL(t *testing.T) {\n   163→\tdir := t.TempDir()\n   164→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\"), 0755)\n   165→\n   166→\tlogger := &AuditLogger{ProjectDir: dir}\n   167→\n   168→\tresult1 := &EvolutionResult{\n   169→\t\tID:           \"evo-1\",\n   170→\t\tWorkflowName: \"develop\",\n   171→\t\tChanges:      []Change{{Type: \"prompt_update\", File: \".cloche/prompts/impl.md\"}},\n   172→\t}\n   173→\trequire.NoError(t, logger.Log(result1))\n   174→\n   175→\tresult2 := &EvolutionResult{\n   176→\t\tID:           \"evo-2\",\n   177→\t\tWorkflowName: \"develop\",\n   178→\t\tChanges:      []Change{{Type: \"add_step\", File: \".cloche/develop.cloche\"}},\n   179→\t}\n   180→\trequire.NoError(t, logger.Log(result2))\n   181→\n   182→\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n   183→\trequire.NoError(t, err)\n   184→\n   185→\tlines := strings.Split(strings.TrimSpace(string(content)), \"\\n\")\n   186→\tassert.Len(t, lines, 2)\n   187→\n   188→\tvar entry1 EvolutionResult\n   189→\trequire.NoError(t, json.Unmarshal([]byte(lines[0]), &entry1))\n   190→\tassert.Equal(t, \"evo-1\", entry1.ID)\n   191→}\n   192→\n   193→func TestAuditLoggerSnapshot(t *testing.T) {\n   194→\tdir := t.TempDir()\n   195→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   196→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   197→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"original content\"), 0644)\n   198→\n   199→\tlogger := &AuditLogger{ProjectDir: dir}\n   200→\tsnapName, err := logger.Snapshot(\".cloche/prompts/implement.md\")\n   201→\trequire.NoError(t, err)\n   202→\tassert.NotEmpty(t, snapName)\n   203→\n   204→\tsnapPath := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\", snapName)\n   205→\tcontent, err := os.ReadFile(snapPath)\n   206→\trequire.NoError(t, err)\n   207→\tassert.Equal(t, \"original content\", string(content))\n   208→}\n   209→\n   210→func TestAuditLoggerUpdatesKnowledge(t *testing.T) {\n   211→\tdir := t.TempDir()\n   212→\tkbDir := filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\")\n   213→\tos.MkdirAll(kbDir, 0755)\n   214→\tos.WriteFile(filepath.Join(kbDir, \"develop.md\"), []byte(\"# Knowledge Base: develop workflow\\n\"), 0644)\n   215→\n   216→\tlogger := &AuditLogger{ProjectDir: dir}\n   217→\tlessons := []Lesson{\n   218→\t\t{\n   219→\t\t\tID:              \"P001\",\n   220→\t\t\tCategory:        \"prompt_improvement\",\n   221→\t\t\tConfidence:      \"high\",\n   222→\t\t\tInsight:         \"Always sanitize HTML inputs\",\n   223→\t\t\tSuggestedAction: \"Add rule to implement prompt\",\n   224→\t\t\tEvidence:        []string{\"run-1\", \"run-2\"},\n   225→\t\t},\n   226→\t}\n   227→\n   228→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", lessons))\n   229→\n   230→\tcontent, err := os.ReadFile(filepath.Join(kbDir, \"develop.md\"))\n   231→\trequire.NoError(t, err)\n   232→\tassert.Contains(t, string(content), \"[P001]\")\n   233→\tassert.Contains(t, string(content), \"sanitize HTML\")\n   234→\tassert.Contains(t, string(content), \"run-1, run-2\")\n   235→}\n   236→\n   237→// --- LLM Client tests ---\n   238→\n   239→// --- Curator tests ---\n   240→\n   241→func TestCuratorUpdatesPrompt(t *testing.T) {\n   242→\tdir := t.TempDir()\n   243→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   244→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   245→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   246→\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   247→\n   248→\tupdatedContent := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"\n   249→\tllm := &fakeLLM{response: updatedContent}\n   250→\n   251→\taudit := &AuditLogger{ProjectDir: dir}\n   252→\tc := &Curator{LLM: llm, Audit: audit}\n   253→\tlesson := &Lesson{\n   254→\t\tID:              \"lesson-001\",\n   255→\t\tCategory:        \"prompt_improvement\",\n   256→\t\tTarget:          \".cloche/prompts/implement.md\",\n   257→\t\tInsight:         \"XSS vulnerabilities in form handlers\",\n   258→\t\tSuggestedAction: \"Add sanitization rule\",\n   259→\t}\n   260→\n   261→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   262→\trequire.NoError(t, err)\n   263→\tassert.Equal(t, \"prompt_update\", change.Type)\n   264→\tassert.Equal(t, \".cloche/prompts/implement.md\", change.File)\n   265→\tassert.NotEmpty(t, change.Snapshot)\n   266→\n   267→\tcontent, err := os.ReadFile(promptPath)\n   268→\trequire.NoError(t, err)\n   269→\tassert.Contains(t, string(content), \"sanitize user inputs\")\n   270→}\n   271→\n   272→// --- stripCodeFences tests ---\n   273→\n   274→func TestStripCodeFences(t *testing.T) {\n   275→\ttests := []struct {\n   276→\t\tname     string\n   277→\t\tinput    string\n   278→\t\texpected string\n   279→\t}{\n   280→\t\t{\n   281→\t\t\tname:     \"no fences returns as-is\",\n   282→\t\t\tinput:    \"# Prompt\\n\\nDo good work.\\n\",\n   283→\t\t\texpected: \"# Prompt\\n\\nDo good work.\",\n   284→\t\t},\n   285→\t\t{\n   286→\t\t\tname:     \"plain code fence\",\n   287→\t\t\tinput:    \"```\\n# Prompt\\n\\nDo good work.\\n```\",\n   288→\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   289→\t\t},\n   290→\t\t{\n   291→\t\t\tname:     \"code fence with language hint\",\n   292→\t\t\tinput:    \"```markdown\\n# Prompt\\n\\nDo good work.\\n```\",\n   293→\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   294→\t\t},\n   295→\t\t{\n   296→\t\t\tname:     \"commentary before and after fence\",\n   297→\t\t\tinput:    \"Here's the updated prompt:\\n\\n```markdown\\n# Prompt\\n\\nDo good work.\\n```\\n\\nI've added the rule as requested.\",\n   298→\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   299→\t\t},\n   300→\t\t{\n   301→\t\t\tname:     \"no closing fence returns as-is\",\n   302→\t\t\tinput:    \"```markdown\\n# Prompt\\n\",\n   303→\t\t\texpected: \"```markdown\\n# Prompt\",\n   304→\t\t},\n   305→\t}\n   306→\n   307→\tfor _, tt := range tests {\n   308→\t\tt.Run(tt.name, func(t *testing.T) {\n   309→\t\t\tassert.Equal(t, tt.expected, stripCodeFences(tt.input))\n   310→\t\t})\n   311→\t}\n   312→}\n   313→\n   314→func TestCuratorStripsCodeFencesFromResponse(t *testing.T) {\n   315→\tdir := t.TempDir()\n   316→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   317→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   318→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   319→\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   320→\n   321→\t// LLM returns content wrapped in code fences with commentary\n   322→\tfencedResponse := \"Here is the updated prompt:\\n\\n```markdown\\n# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n```\\n\\nI added the validation rule.\"\n   323→\tllm := &fakeLLM{response: fencedResponse}\n   324→\n   325→\taudit := &AuditLogger{ProjectDir: dir}\n   326→\tc := &Curator{LLM: llm, Audit: audit}\n   327→\tlesson := &Lesson{\n   328→\t\tTarget:          \".cloche/prompts/implement.md\",\n   329→\t\tInsight:         \"Missing input validation\",\n   330→\t\tSuggestedAction: \"Add validation rule\",\n   331→\t}\n   332→\n   333→\t_, err := c.Apply(context.Background(), dir, lesson)\n   334→\trequire.NoError(t, err)\n   335→\n   336→\tcontent, err := os.ReadFile(promptPath)\n   337→\trequire.NoError(t, err)\n   338→\n   339→\t// Should contain the actual prompt content, not the commentary\n   340→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   341→\tassert.Contains(t, string(content), \"Always validate inputs\")\n   342→\tassert.NotContains(t, string(content), \"Here is the updated prompt\")\n   343→\tassert.NotContains(t, string(content), \"I added the validation rule\")\n   344→\tassert.NotContains(t, string(content), \"```\")\n   345→}\n   346→\n   347→func TestCuratorRejectsConversationalMetaText(t *testing.T) {\n   348→\tdir := t.TempDir()\n   349→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"fix.md\")\n   350→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   351→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   352→\toriginal := \"# Fix Prompt\\n\\nFix bugs carefully.\\n\"\n   353→\tos.WriteFile(promptPath, []byte(original), 0644)\n   354→\n   355→\t// LLM returns conversational meta-text\n   356→\tllm := &fakeLLM{response: \"I need write permission to update the file. Could you grant access to .cloche/prompts/fix.md?\"}\n   357→\taudit := &AuditLogger{ProjectDir: dir}\n   358→\tc := &Curator{LLM: llm, Audit: audit}\n   359→\tlesson := &Lesson{\n   360→\t\tTarget:          \".cloche/prompts/fix.md\",\n   361→\t\tInsight:         \"Missing error context\",\n   362→\t\tSuggestedAction: \"Wrap errors with context\",\n   363→\t}\n   364→\n   365→\t_, err := c.Apply(context.Background(), dir, lesson)\n   366→\trequire.NoError(t, err)\n   367→\n   368→\tcontent, err := os.ReadFile(promptPath)\n   369→\trequire.NoError(t, err)\n   370→\t// Must NOT contain the conversational text\n   371→\tassert.NotContains(t, string(content), \"I need write permission\")\n   372→\tassert.NotContains(t, string(content), \"Could you grant access\")\n   373→\t// Should contain the original content and the lesson appended directly\n   374→\tassert.Contains(t, string(content), \"# Fix Prompt\")\n   375→\tassert.Contains(t, string(content), \"Missing error context\")\n   376→}\n   377→\n   378→func TestCuratorRejectsUnfencedConversationalPrefix(t *testing.T) {\n   379→\tdir := t.TempDir()\n   380→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   381→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   382→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   383→\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n   384→\tos.WriteFile(promptPath, []byte(original), 0644)\n   385→\n   386→\t// LLM returns \"Here is the updated prompt:\" with NO code fences\n   387→\tllm := &fakeLLM{response: \"Here is the updated prompt:\\n\\n# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Validate inputs\\n\"}\n   388→\taudit := &AuditLogger{ProjectDir: dir}\n   389→\tc := &Curator{LLM: llm, Audit: audit}\n   390→\tlesson := &Lesson{\n   391→\t\tTarget:          \".cloche/prompts/implement.md\",\n   392→\t\tInsight:         \"Missing validation\",\n   393→\t\tSuggestedAction: \"Add input validation\",\n   394→\t}\n   395→\n   396→\t_, err := c.Apply(context.Background(), dir, lesson)\n   397→\trequire.NoError(t, err)\n   398→\n   399→\tcontent, err := os.ReadFile(promptPath)\n   400→\trequire.NoError(t, err)\n   401→\t// The conversational prefix must not appear\n   402→\tassert.NotContains(t, string(content), \"Here is the updated prompt\")\n   403→\t// Original content preserved, lesson appended via fallback\n   404→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   405→\tassert.Contains(t, string(content), \"Missing validation\")\n   406→}\n   407→\n   408→func TestCuratorAcceptsValidPromptWithoutFences(t *testing.T) {\n   409→\tdir := t.TempDir()\n   410→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   411→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   412→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   413→\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   414→\n   415→\t// LLM returns valid prompt content without code fences\n   416→\tvalidResponse := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n\"\n   417→\tllm := &fakeLLM{response: validResponse}\n   418→\taudit := &AuditLogger{ProjectDir: dir}\n   419→\tc := &Curator{LLM: llm, Audit: audit}\n   420→\tlesson := &Lesson{\n   421→\t\tTarget:          \".cloche/prompts/implement.md\",\n   422→\t\tInsight:         \"Missing validation\",\n   423→\t\tSuggestedAction: \"Add validation rule\",\n   424→\t}\n   425→\n   426→\t_, err := c.Apply(context.Background(), dir, lesson)\n   427→\trequire.NoError(t, err)\n   428→\n   429→\tcontent, err := os.ReadFile(promptPath)\n   430→\trequire.NoError(t, err)\n   431→\t// Should write the LLM response (after stripCodeFences trimming) since it's valid prompt content\n   432→\tassert.Contains(t, string(content), \"Always validate inputs\")\n   433→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   434→\tassert.NotContains(t, string(content), \"Missing validation\")\n   435→}\n   436→\n   437→func TestIsConversationalResponse(t *testing.T) {\n   438→\ttests := []struct {\n   439→\t\tname     string\n   440→\t\tinput    string\n   441→\t\texpected bool\n   442→\t}{\n   443→\t\t{\"permission request\", \"I need write permission to update the file\", true},\n   444→\t\t{\"grant request\", \"Could you grant access to the file?\", true},\n   445→\t\t{\"blocked message\", \"Permission blocked by sandbox\", true},\n   446→\t\t{\"here is updated\", \"Here is the updated prompt:\\n\\n# Prompt\", true},\n   447→\t\t{\"heres updated\", \"Here's the updated prompt:\\n\\n# Prompt\", true},\n   448→\t\t{\"ive updated\", \"I've updated the prompt with the new rule\", true},\n   449→\t\t{\"let me\", \"Let me update the file for you\", true},\n   450→\t\t{\"valid markdown heading\", \"# Prompt\\n\\nDo good work.\", false},\n   451→\t\t{\"valid bullet list\", \"- Rule one\\n- Rule two\", false},\n   452→\t\t{\"empty string\", \"\", true},\n   453→\t\t{\"valid content no heading\", \"Write good code and test everything.\", false},\n   454→\t}\n   455→\n   456→\tfor _, tt := range tests {\n   457→\t\tt.Run(tt.name, func(t *testing.T) {\n   458→\t\t\tassert.Equal(t, tt.expected, isConversationalResponse(tt.input))\n   459→\t\t})\n   460→\t}\n   461→}\n   462→\n   463→func TestAppendLessonDirectly(t *testing.T) {\n   464→\tt.Run(\"creates learned rules section\", func(t *testing.T) {\n   465→\t\tresult := appendLessonDirectly(\"# Prompt\\n\\nDo good work.\\n\", &Lesson{\n   466→\t\t\tInsight:         \"Missing validation\",\n   467→\t\t\tSuggestedAction: \"Add validation\",\n   468→\t\t})\n   469→\t\tassert.Contains(t, result, \"## Learned Rules\")\n   470→\t\tassert.Contains(t, result, \"Missing validation: Add validation\")\n   471→\t})\n   472→\n   473→\tt.Run(\"appends to existing learned rules\", func(t *testing.T) {\n   474→\t\texisting := \"# Prompt\\n\\n## Learned Rules\\n\\n- Existing rule\\n\"\n   475→\t\tresult := appendLessonDirectly(existing, &Lesson{\n   476→\t\t\tInsight:         \"New insight\",\n   477→\t\t\tSuggestedAction: \"New action\",\n   478→\t\t})\n   479→\t\tassert.Contains(t, result, \"- Existing rule\")\n   480→\t\tassert.Contains(t, result, \"- New insight: New action\")\n   481→\t\t// Should not create a duplicate section\n   482→\t\tassert.Equal(t, 1, strings.Count(result, \"## Learned Rules\"))\n   483→\t})\n   484→}\n   485→\n   486→// --- Script Generator tests ---\n   487→\n   488→func TestScriptGeneratorCreatesScript(t *testing.T) {\n   489→\tdir := t.TempDir()\n   490→\n   491→\tllm := &fakeLLM{response: `{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`}\n   492→\tg := &ScriptGenerator{LLM: llm}\n   493→\n   494→\tlesson := &Lesson{\n   495→\t\tID:              \"lesson-001\",\n   496→\t\tCategory:        \"new_step\",\n   497→\t\tStepType:        \"script\",\n   498→\t\tInsight:         \"No security scanning\",\n   499→\t\tSuggestedAction: \"Add gosec security scan\",\n   500→\t}\n   501→\n   502→\tresult, err := g.Generate(context.Background(), dir, lesson)\n   503→\trequire.NoError(t, err)\n   504→\tassert.Equal(t, \"scripts/security-scan.sh\", result.Path)\n   505→\n   506→\tcontent, err := os.ReadFile(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n   507→\trequire.NoError(t, err)\n   508→\tassert.Contains(t, string(content), \"gosec\")\n   509→\n   510→\tinfo, err := os.Stat(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n   511→\trequire.NoError(t, err)\n   512→\tassert.NotZero(t, info.Mode()&0111) // executable\n   513→}\n   514→\n   515→// --- LLM Client tests ---\n   516→\n   517→func TestCommandLLMClientPrintMode(t *testing.T) {\n   518→\t// Use a shell script that dumps its args and stdin so we can verify\n   519→\t// that the client passes the right flags and prompt separation.\n   520→\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   521→\tos.WriteFile(script, []byte(`#!/bin/sh\n   522→echo \"ARGS:$*\"\n   523→echo \"STDIN:$(cat)\"\n   524→`), 0755)\n   525→\n   526→\tc := &CommandLLMClient{Command: script, Args: []string{}}\n   527→\tresult, err := c.Complete(context.Background(), \"You are a helpful assistant.\", \"Summarize this text\")\n   528→\trequire.NoError(t, err)\n   529→\n   530→\t// Should include -p flag for print/non-interactive mode\n   531→\tassert.Contains(t, result, \"-p\")\n   532→\n   533→\t// Should pass system prompt via --system-prompt flag\n   534→\tassert.Contains(t, result, \"--system-prompt\")\n   535→\tassert.Contains(t, result, \"You are a helpful assistant.\")\n   536→\n   537→\t// Should pass --output-format text\n   538→\tassert.Contains(t, result, \"--output-format text\")\n   539→\n   540→\t// Stdin should contain only the user prompt, not the system prompt\n   541→\tassert.Contains(t, result, \"STDIN:Summarize this text\")\n   542→\tassert.NotContains(t, result, \"STDIN:You are a helpful assistant\")\n   543→}\n   544→\n   545→func TestCommandLLMClientEmptySystemPrompt(t *testing.T) {\n   546→\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   547→\tos.WriteFile(script, []byte(`#!/bin/sh\n   548→echo \"ARGS:$*\"\n   549→echo \"STDIN:$(cat)\"\n   550→`), 0755)\n   551→\n   552→\tc := &CommandLLMClient{Command: script, Args: []string{}}\n   553→\tresult, err := c.Complete(context.Background(), \"\", \"just user prompt\")\n   554→\trequire.NoError(t, err)\n   555→\n   556→\t// Should NOT include --system-prompt when system prompt is empty\n   557→\tassert.NotContains(t, result, \"--system-prompt\")\n   558→\t// Should still have -p and --output-format\n   559→\tassert.Contains(t, result, \"-p\")\n   560→\tassert.Contains(t, result, \"--output-format text\")\n   561→\tassert.Contains(t, result, \"STDIN:just user prompt\")\n   562→}\n   563→\n   564→func TestCommandLLMClientExtraArgs(t *testing.T) {\n   565→\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   566→\tos.WriteFile(script, []byte(`#!/bin/sh\n   567→echo \"ARGS:$*\"\n   568→echo \"STDIN:$(cat)\"\n   569→`), 0755)\n   570→\n   571→\tc := &CommandLLMClient{Command: script, Args: []string{\"--model\", \"sonnet\"}}\n   572→\tresult, err := c.Complete(context.Background(), \"sys\", \"usr\")\n   573→\trequire.NoError(t, err)\n   574→\n   575→\t// Extra args should appear before the appended flags\n   576→\tassert.Contains(t, result, \"--model sonnet\")\n   577→\tassert.Contains(t, result, \"-p\")\n   578→}\n   579→\n   580→func TestCommandLLMClientDoesNotMutateArgs(t *testing.T) {\n   581→\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   582→\tos.WriteFile(script, []byte(\"#!/bin/sh\\ncat\\n\"), 0755)\n   583→\n   584→\toriginal := []string{\"--verbose\"}\n   585→\tc := &CommandLLMClient{Command: script, Args: original}\n   586→\t_, err := c.Complete(context.Background(), \"sys\", \"usr\")\n   587→\trequire.NoError(t, err)\n   588→\n   589→\t// The original Args slice should not be modified between calls.\n   590→\tassert.Equal(t, []string{\"--verbose\"}, original)\n   591→}\n   592→\n   593→// --- Orchestrator tests ---\n   594→\n   595→// scriptedLLM returns responses in order.\n   596→type scriptedLLM struct {\n   597→\tresponses []string\n   598→\tidx       int\n   599→}\n   600→\n   601→func (s *scriptedLLM) Complete(ctx context.Context, system, user string) (string, error) {\n   602→\tresp := s.responses[s.idx]\n   603→\ts.idx++\n   604→\treturn resp, nil\n   605→}\n   606→\n   607→func TestOrchestratorEndToEnd(t *testing.T) {\n   608→\tdir := t.TempDir()\n   609→\n   610→\t// Set up project structure\n   611→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   612→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   613→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   614→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n   615→\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n   616→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n   617→\t\t[]byte(\"Write good code.\\n\"), 0644)\n   618→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   619→\t\t[]byte(`workflow \"develop\" {\n   620→  step implement {\n   621→    prompt = file(\".cloche/prompts/implement.md\")\n   622→    results = [success, fail]\n   623→  }\n   624→  step test {\n   625→    run = \"make test\"\n   626→    results = [success, fail]\n   627→  }\n   628→  implement:success -> test\n   629→  test:success -> done\n   630→  test:fail -> abort\n   631→}`), 0644)\n   632→\n   633→\t// Fake LLM that returns appropriate responses per stage\n   634→\tllm := &scriptedLLM{\n   635→\t\tresponses: []string{\n   636→\t\t\t// Classifier\n   637→\t\t\t`{\"classification\": \"bug\"}`,\n   638→\t\t\t// Reflector\n   639→\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n   640→\t\t\t// Curator\n   641→\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n   642→\t\t},\n   643→\t}\n   644→\n   645→\torch := NewOrchestrator(OrchestratorConfig{\n   646→\t\tProjectDir:    dir,\n   647→\t\tWorkflowName:  \"develop\",\n   648→\t\tLLM:           llm,\n   649→\t\tMinConfidence: \"medium\",\n   650→\t})\n   651→\n   652→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   653→\trequire.NoError(t, err)\n   654→\tassert.Equal(t, \"bug\", result.Classification)\n   655→\trequire.Len(t, result.Changes, 1)\n   656→\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n   657→\n   658→\t// Verify prompt was actually updated\n   659→\tcontent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n   660→\tassert.Contains(t, string(content), \"sanitize user inputs\")\n   661→\n   662→\t// Verify audit log was written\n   663→\tlogContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n   664→\tassert.Contains(t, string(logContent), \"prompt_update\")\n   665→\tassert.Contains(t, string(logContent), \"XSS pattern\")\n   666→\n   667→\t// Verify knowledge base was updated\n   668→\tkbContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"))\n   669→\tassert.Contains(t, string(kbContent), \"L001\")\n   670→}\n   671→\n   672→func TestOrchestratorNewStepWiredIntoGraph(t *testing.T) {\n   673→\tdir := t.TempDir()\n   674→\n   675→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   676→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   677→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n   678→\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n   679→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   680→\t\t[]byte(`workflow \"develop\" {\n   681→  step implement {\n   682→    prompt = file(\".cloche/prompts/implement.md\")\n   683→    results = [success, fail]\n   684→  }\n   685→  step test {\n   686→    run = \"make test\"\n   687→    results = [success, fail]\n   688→  }\n   689→  implement:success -> test\n   690→  implement:fail -> abort\n   691→  test:success -> done\n   692→  test:fail -> abort\n   693→}`), 0644)\n   694→\n   695→\tllm := &scriptedLLM{\n   696→\t\tresponses: []string{\n   697→\t\t\t// Classifier\n   698→\t\t\t`{\"classification\": \"enhancement\"}`,\n   699→\t\t\t// Reflector\n   700→\t\t\t`{\"lessons\": [{\"id\": \"L002\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"No security scanning\", \"suggested_action\": \"Add gosec scan\", \"evidence\": [\"run-2\"], \"confidence\": \"high\"}]}`,\n   701→\t\t\t// ScriptGenerator\n   702→\t\t\t`{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`,\n   703→\t\t},\n   704→\t}\n   705→\n   706→\torch := NewOrchestrator(OrchestratorConfig{\n   707→\t\tProjectDir:    dir,\n   708→\t\tWorkflowName:  \"develop\",\n   709→\t\tLLM:           llm,\n   710→\t\tMinConfidence: \"medium\",\n   711→\t})\n   712→\n   713→\tresult, err := orch.Run(context.Background(), \"run-2\", nil, nil)\n   714→\trequire.NoError(t, err)\n   715→\trequire.Len(t, result.Changes, 2) // add_script + add_step\n   716→\tassert.Equal(t, \"add_script\", result.Changes[0].Type)\n   717→\tassert.Equal(t, \"add_step\", result.Changes[1].Type)\n   718→\n   719→\t// Read the updated workflow and verify the new step is reachable\n   720→\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   721→\trequire.NoError(t, err)\n   722→\n   723→\twfStr := string(wfContent)\n   724→\t// The new step should be wired into the graph\n   725→\tassert.Contains(t, wfStr, \"step security-scan\")\n   726→\t// An existing step should wire to the new step (rewired from -> done)\n   727→\tassert.Contains(t, wfStr, \"test:success -> security-scan\")\n   728→\t// The new step should wire its results to terminals\n   729→\tassert.Contains(t, wfStr, \"security-scan:success -> done\")\n   730→\tassert.Contains(t, wfStr, \"security-scan:fail -> abort\")\n   731→\n   732→\t// Verify the workflow parses and validates\n   733→\twf, err := dsl.Parse(wfStr)\n   734→\trequire.NoError(t, err)\n   735→\trequire.NoError(t, wf.Validate())\n   736→}\n   737→\n   738→func TestHandleNewStepSkipsDuplicate(t *testing.T) {\n   739→\tdir := t.TempDir()\n   740→\n   741→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   742→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   743→\n   744→\t// Workflow already contains a step named \"security-scan\"\n   745→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   746→\t\t[]byte(`workflow \"develop\" {\n   747→  step implement {\n   748→    prompt = file(\".cloche/prompts/implement.md\")\n   749→    results = [success, fail]\n   750→  }\n   751→  step security-scan {\n   752→    run = \"scripts/security-scan.sh\"\n   753→    results = [success, fail]\n   754→  }\n   755→  implement:success -> security-scan\n   756→  implement:fail -> abort\n   757→  security-scan:success -> done\n   758→  security-scan:fail -> abort\n   759→}`), 0644)\n   760→\n   761→\tllm := &scriptedLLM{\n   762→\t\tresponses: []string{\n   763→\t\t\t// Classifier\n   764→\t\t\t`{\"classification\": \"enhancement\"}`,\n   765→\t\t\t// Reflector — lesson wants to add \"security-scan\" again\n   766→\t\t\t`{\"lessons\": [{\"id\": \"L003\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add security scanning\", \"suggested_action\": \"Add gosec scan\", \"evidence\": [\"run-3\"], \"confidence\": \"high\"}]}`,\n   767→\t\t\t// ScriptGenerator\n   768→\t\t\t`{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`,\n   769→\t\t},\n   770→\t}\n   771→\n   772→\torch := NewOrchestrator(OrchestratorConfig{\n   773→\t\tProjectDir:    dir,\n   774→\t\tWorkflowName:  \"develop\",\n   775→\t\tLLM:           llm,\n   776→\t\tMinConfidence: \"medium\",\n   777→\t})\n   778→\n   779→\tresult, err := orch.Run(context.Background(), \"run-3\", nil, nil)\n   780→\trequire.NoError(t, err)\n   781→\n   782→\t// Should have add_script change but NOT add_step (skipped as duplicate)\n   783→\tstepChanges := 0\n   784→\tfor _, c := range result.Changes {\n   785→\t\tif c.Type == \"add_step\" {\n   786→\t\t\tstepChanges++\n   787→\t\t}\n   788→\t}\n   789→\tassert.Equal(t, 0, stepChanges, \"should not add a duplicate step\")\n   790→\n   791→\t// Workflow should be unchanged — still valid, no duplicates\n   792→\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   793→\trequire.NoError(t, err)\n   794→\twf, err := dsl.Parse(string(wfContent))\n   795→\trequire.NoError(t, err)\n   796→\trequire.NoError(t, wf.Validate())\n   797→\tassert.Equal(t, 2, len(wf.Steps), \"should still have exactly 2 steps\")\n   798→}\n   799→\n   800→func TestHandleNewStepNoDoneEdge(t *testing.T) {\n   801→\tdir := t.TempDir()\n   802→\n   803→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   804→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   805→\n   806→\t// Workflow has no -> done edges (all go to abort)\n   807→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   808→\t\t[]byte(`workflow \"develop\" {\n   809→  step implement {\n   810→    prompt = file(\".cloche/prompts/implement.md\")\n   811→    results = [success, fail]\n   812→  }\n   813→  implement:success -> done\n   814→  implement:fail -> abort\n   815→}`), 0644)\n   816→\n   817→\tllm := &scriptedLLM{\n   818→\t\tresponses: []string{\n   819→\t\t\t`{\"classification\": \"enhancement\"}`,\n   820→\t\t\t`{\"lessons\": [{\"id\": \"L004\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add linting\", \"suggested_action\": \"Add lint step\", \"evidence\": [\"run-4\"], \"confidence\": \"high\"}]}`,\n   821→\t\t\t`{\"path\": \"scripts/lint.sh\", \"content\": \"#!/bin/bash\\ngolangci-lint run\"}`,\n   822→\t\t},\n   823→\t}\n   824→\n   825→\torch := NewOrchestrator(OrchestratorConfig{\n   826→\t\tProjectDir:    dir,\n   827→\t\tWorkflowName:  \"develop\",\n   828→\t\tLLM:           llm,\n   829→\t\tMinConfidence: \"medium\",\n   830→\t})\n   831→\n   832→\tresult, err := orch.Run(context.Background(), \"run-4\", nil, nil)\n   833→\trequire.NoError(t, err)\n   834→\n   835→\t// The new step should be added and the resulting workflow must validate\n   836→\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   837→\trequire.NoError(t, err)\n   838→\twf, err := dsl.Parse(string(wfContent))\n   839→\trequire.NoError(t, err)\n   840→\trequire.NoError(t, wf.Validate(), \"resulting workflow should have no orphaned steps\")\n   841→\n   842→\t// The new step should be reachable\n   843→\t_, hasStep := wf.Steps[\"lint\"]\n   844→\tassert.True(t, hasStep, \"lint step should exist\")\n   845→\n   846→\t// Verify add_step change was recorded\n   847→\thasAddStep := false\n   848→\tfor _, c := range result.Changes {\n   849→\t\tif c.Type == \"add_step\" {\n   850→\t\t\thasAddStep = true\n   851→\t\t}\n   852→\t}\n   853→\tassert.True(t, hasAddStep, \"should have recorded add_step change\")\n   854→}\n   855→\n   856→func TestHandleNewStepValidatesResultingWorkflow(t *testing.T) {\n   857→\tdir := t.TempDir()\n   858→\n   859→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   860→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   861→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   862→\t\t[]byte(`workflow \"develop\" {\n   863→  step implement {\n   864→    prompt = file(\".cloche/prompts/implement.md\")\n   865→    results = [success, fail]\n   866→  }\n   867→  step test {\n   868→    run = \"make test\"\n   869→    results = [success, fail]\n   870→  }\n   871→  implement:success -> test\n   872→  implement:fail -> abort\n   873→  test:success -> done\n   874→  test:fail -> abort\n   875→}`), 0644)\n   876→\n   877→\tllm := &scriptedLLM{\n   878→\t\tresponses: []string{\n   879→\t\t\t`{\"classification\": \"enhancement\"}`,\n   880→\t\t\t`{\"lessons\": [{\"id\": \"L005\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add formatting check\", \"suggested_action\": \"Add gofmt check\", \"evidence\": [\"run-5\"], \"confidence\": \"high\"}]}`,\n   881→\t\t\t`{\"path\": \"scripts/format-check.sh\", \"content\": \"#!/bin/bash\\ngofmt -l .\"}`,\n   882→\t\t},\n   883→\t}\n   884→\n   885→\torch := NewOrchestrator(OrchestratorConfig{\n   886→\t\tProjectDir:    dir,\n   887→\t\tWorkflowName:  \"develop\",\n   888→\t\tLLM:           llm,\n   889→\t\tMinConfidence: \"medium\",\n   890→\t})\n   891→\n   892→\tresult, err := orch.Run(context.Background(), \"run-5\", nil, nil)\n   893→\trequire.NoError(t, err)\n   894→\n   895→\t// Read and fully validate the workflow\n   896→\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   897→\trequire.NoError(t, err)\n   898→\twf, err := dsl.Parse(string(wfContent))\n   899→\trequire.NoError(t, err)\n   900→\trequire.NoError(t, wf.Validate())\n   901→\n   902→\t// Verify we got 3 steps now\n   903→\tassert.Equal(t, 3, len(wf.Steps))\n   904→\n   905→\t// Verify we got the add_step change\n   906→\thasAddStep := false\n   907→\tfor _, c := range result.Changes {\n   908→\t\tif c.Type == \"add_step\" {\n   909→\t\t\thasAddStep = true\n   910→\t\t}\n   911→\t}\n   912→\tassert.True(t, hasAddStep)\n   913→}\n   914→\n   915→func TestOrchestratorNoLessons(t *testing.T) {\n   916→\tdir := t.TempDir()\n   917→\n   918→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   919→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   920→\t\t[]byte(`workflow \"develop\" {\n   921→  step s {\n   922→    run = \"echo hi\"\n   923→    results = [success]\n   924→  }\n   925→  s:success -> done\n   926→}`), 0644)\n   927→\n   928→\tllm := &scriptedLLM{\n   929→\t\tresponses: []string{\n   930→\t\t\t// Classifier\n   931→\t\t\t`{\"classification\": \"feature\"}`,\n   932→\t\t\t// Reflector — no lessons\n   933→\t\t\t`{\"lessons\": []}`,\n   934→\t\t},\n   935→\t}\n   936→\n   937→\torch := NewOrchestrator(OrchestratorConfig{\n   938→\t\tProjectDir:    dir,\n   939→\t\tWorkflowName:  \"develop\",\n   940→\t\tLLM:           llm,\n   941→\t\tMinConfidence: \"medium\",\n   942→\t})\n   943→\n   944→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   945→\trequire.NoError(t, err)\n   946→\tassert.Equal(t, \"feature\", result.Classification)\n   947→\tassert.Empty(t, result.Changes)\n   948→}\n   949→\n   950→// --- Content-change guard tests ---\n   951→\n   952→func TestLessonAlreadyPresent(t *testing.T) {\n   953→\ttests := []struct {\n   954→\t\tname    string\n   955→\t\tprompt  string\n   956→\t\tlesson  *Lesson\n   957→\t\tpresent bool\n   958→\t}{\n   959→\t\t{\n   960→\t\t\tname:    \"insight present\",\n   961→\t\t\tprompt:  \"# Prompt\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n   962→\t\t\tlesson:  &Lesson{Insight: \"Always sanitize user inputs\", SuggestedAction: \"Add rule\"},\n   963→\t\t\tpresent: true,\n   964→\t\t},\n   965→\t\t{\n   966→\t\t\tname:    \"action present\",\n   967→\t\t\tprompt:  \"# Prompt\\n\\n## Learned Rules\\n\\n- Add input validation for all forms\\n\",\n   968→\t\t\tlesson:  &Lesson{Insight: \"Forms lack validation\", SuggestedAction: \"Add input validation for all forms\"},\n   969→\t\t\tpresent: true,\n   970→\t\t},\n   971→\t\t{\n   972→\t\t\tname:    \"case insensitive match\",\n   973→\t\t\tprompt:  \"# Prompt\\n\\n## Learned Rules\\n\\n- always sanitize user inputs\\n\",\n   974→\t\t\tlesson:  &Lesson{Insight: \"Always Sanitize User Inputs\", SuggestedAction: \"Do it\"},\n   975→\t\t\tpresent: true,\n   976→\t\t},\n   977→\t\t{\n   978→\t\t\tname:    \"not present\",\n   979→\t\t\tprompt:  \"# Prompt\\n\\nWrite good code.\\n\",\n   980→\t\t\tlesson:  &Lesson{Insight: \"Always sanitize user inputs\", SuggestedAction: \"Add sanitization\"},\n   981→\t\t\tpresent: false,\n   982→\t\t},\n   983→\t\t{\n   984→\t\t\tname:    \"empty insight and action\",\n   985→\t\t\tprompt:  \"# Prompt\\n\\nWrite good code.\\n\",\n   986→\t\t\tlesson:  &Lesson{Insight: \"\", SuggestedAction: \"\"},\n   987→\t\t\tpresent: false,\n   988→\t\t},\n   989→\t}\n   990→\n   991→\tfor _, tt := range tests {\n   992→\t\tt.Run(tt.name, func(t *testing.T) {\n   993→\t\t\tassert.Equal(t, tt.present, lessonAlreadyPresent(tt.prompt, tt.lesson))\n   994→\t\t})\n   995→\t}\n   996→}\n   997→\n   998→func TestCuratorSkipsWhenLessonAlreadyPresent(t *testing.T) {\n   999→\tdir := t.TempDir()\n  1000→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n  1001→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n  1002→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n  1003→\n  1004→\t// Prompt already contains the lesson insight\n  1005→\tos.WriteFile(promptPath, []byte(\"# Prompt\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"), 0644)\n  1006→\n  1007→\t// LLM should NOT be called — use a response that would change the file\n  1008→\tllm := &fakeLLM{response: \"THIS SHOULD NOT APPEAR\"}\n  1009→\taudit := &AuditLogger{ProjectDir: dir}\n  1010→\tc := &Curator{LLM: llm, Audit: audit}\n  1011→\tlesson := &Lesson{\n  1012→\t\tTarget:          \".cloche/prompts/implement.md\",\n  1013→\t\tInsight:         \"Always sanitize user inputs\",\n  1014→\t\tSuggestedAction: \"Add sanitization rule\",\n  1015→\t}\n  1016→\n  1017→\tchange, err := c.Apply(context.Background(), dir, lesson)\n  1018→\trequire.NoError(t, err)\n  1019→\tassert.Nil(t, change, \"should return nil change when lesson already present\")\n  1020→\n  1021→\t// File should be unchanged\n  1022→\tcontent, _ := os.ReadFile(promptPath)\n  1023→\tassert.NotContains(t, string(content), \"THIS SHOULD NOT APPEAR\")\n  1024→}\n  1025→\n  1026→func TestReflectorFiltersAlreadyAppliedLessons(t *testing.T) {\n  1027→\tlessonsJSON, _ := json.Marshal(map[string]any{\n  1028→\t\t\"lessons\": []map[string]any{\n  1029→\t\t\t{\"id\": \"lesson-001\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n  1030→\t\t\t{\"id\": \"lesson-002\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n  1031→\t\t},\n  1032→\t})\n  1033→\n  1034→\tllm := &fakeLLM{response: string(lessonsJSON)}\n  1035→\tr := &Reflector{LLM: llm, MinConfidence: \"low\"}\n  1036→\n  1037→\t// Knowledge base already contains lesson-001\n  1038→\tdata := &CollectedData{\n  1039→\t\tKnowledgeBase: \"# Knowledge Base\\n\\n- **[lesson-001]** (prompt_improvement, confidence: high) Old insight\\n\",\n  1040→\t}\n  1041→\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n  1042→\trequire.NoError(t, err)\n  1043→\trequire.Len(t, lessons, 1)\n  1044→\tassert.Equal(t, \"lesson-002\", lessons[0].ID)\n  1045→}\n  1046→\n  1047→func TestOrchestratorSkipsAlreadyAppliedLessons(t *testing.T) {\n  1048→\tdir := t.TempDir()\n  1049→\n  1050→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n  1051→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n  1052→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n  1053→\t\t[]byte(\"# Knowledge Base\\n\\n- **[L001]** (prompt_improvement, confidence: high) XSS pattern\\n\"), 0644)\n  1054→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n  1055→\t\t[]byte(\"Write good code.\\n\"), 0644)\n  1056→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n  1057→\t\t[]byte(`workflow \"develop\" {\n  1058→  step s {\n  1059→    run = \"echo hi\"\n  1060→    results = [success]\n  1061→  }\n  1062→  s:success -> done\n  1063→}`), 0644)\n  1064→\n  1065→\t// Reflector returns a lesson that's already in the knowledge base\n  1066→\tllm := &scriptedLLM{\n  1067→\t\tresponses: []string{\n  1068→\t\t\t`{\"classification\": \"bug\"}`,\n  1069→\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n  1070→\t\t},\n  1071→\t}\n  1072→\n  1073→\torch := NewOrchestrator(OrchestratorConfig{\n  1074→\t\tProjectDir:    dir,\n  1075→\t\tWorkflowName:  \"develop\",\n  1076→\t\tLLM:           llm,\n  1077→\t\tMinConfidence: \"low\",\n  1078→\t})\n  1079→\n  1080→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n  1081→\trequire.NoError(t, err)\n  1082→\tassert.Empty(t, result.Changes, \"should produce zero changes for already-applied lesson\")\n  1083→}\n  1084→\n  1085→func TestOrchestratorSecondRunProducesNoChanges(t *testing.T) {\n  1086→\tdir := t.TempDir()\n  1087→\n  1088→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n  1089→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n  1090→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n  1091→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n  1092→\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n  1093→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n  1094→\t\t[]byte(\"Write good code.\\n\"), 0644)\n  1095→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n  1096→\t\t[]byte(`workflow \"develop\" {\n  1097→  step implement {\n  1098→    prompt = file(\".cloche/prompts/implement.md\")\n  1099→    results = [success, fail]\n  1100→  }\n  1101→  implement:success -> done\n  1102→  implement:fail -> abort\n  1103→}`), 0644)\n  1104→\n  1105→\t// First run: lesson gets applied\n  1106→\tllm1 := &scriptedLLM{\n  1107→\t\tresponses: []string{\n  1108→\t\t\t`{\"classification\": \"bug\"}`,\n  1109→\t\t\t`{\"lessons\": [{\"id\": \"L010\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Always sanitize user inputs\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n  1110→\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n  1111→\t\t},\n  1112→\t}\n  1113→\n  1114→\torch1 := NewOrchestrator(OrchestratorConfig{\n  1115→\t\tProjectDir:    dir,\n  1116→\t\tWorkflowName:  \"develop\",\n  1117→\t\tLLM:           llm1,\n  1118→\t\tMinConfidence: \"low\",\n  1119→\t})\n  1120→\n  1121→\tresult1, err := orch1.Run(context.Background(), \"run-1\", nil, nil)\n  1122→\trequire.NoError(t, err)\n  1123→\trequire.Len(t, result1.Changes, 1, \"first run should produce one change\")\n  1124→\n  1125→\t// Second run: same lesson ID — the knowledge base now contains L010,\n  1126→\t// and the prompt contains the insight text.\n  1127→\tllm2 := &scriptedLLM{\n  1128→\t\tresponses: []string{\n  1129→\t\t\t`{\"classification\": \"bug\"}`,\n  1130→\t\t\t`{\"lessons\": [{\"id\": \"L010\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Always sanitize user inputs\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n  1131→\t\t},\n  1132→\t}\n  1133→\n  1134→\torch2 := NewOrchestrator(OrchestratorConfig{\n  1135→\t\tProjectDir:    dir,\n  1136→\t\tWorkflowName:  \"develop\",\n  1137→\t\tLLM:           llm2,\n  1138→\t\tMinConfidence: \"low\",\n  1139→\t})\n  1140→\n  1141→\tresult2, err := orch2.Run(context.Background(), \"run-2\", nil, nil)\n  1142→\trequire.NoError(t, err)\n  1143→\tassert.Empty(t, result2.Changes, \"second run should produce zero changes\")\n  1144→}\n  1145→"}]},"parent_tool_use_id":null,"session_id":"f9cd3635-7b59-4df8-9a88-6beef5e619d5","uuid":"a1457ba4-eebd-412e-940a-b4452220b391","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/evolution_test.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// fakeLLM returns a fixed response for testing.\ntype fakeLLM struct {\n\tresponse string\n}\n\nfunc (f *fakeLLM) Complete(ctx context.Context, system, user string) (string, error) {\n\treturn f.response, nil\n}\n\n// --- Collector tests ---\n\nfunc TestCollectorGathersData(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n\t\t[]byte(\"# Knowledge Base\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"Write good code\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step impl {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success]\n  }\n  impl:success -> done\n}`), 0644)\n\n\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n\tdata, err := c.Collect(context.Background(), nil, nil)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, \"# Knowledge Base\\n\", data.KnowledgeBase)\n\tassert.Contains(t, data.CurrentPrompts, \".cloche/prompts/implement.md\")\n\tassert.Equal(t, \"Write good code\", data.CurrentPrompts[\".cloche/prompts/implement.md\"])\n\tassert.NotEmpty(t, data.CurrentWorkflow)\n\tassert.Equal(t, dir, data.ProjectDir)\n\tassert.Equal(t, \"develop\", data.WorkflowName)\n}\n\nfunc TestCollectorNoKnowledgeBase(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n\n\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n\tdata, err := c.Collect(context.Background(), nil, nil)\n\trequire.NoError(t, err)\n\tassert.Empty(t, data.KnowledgeBase)\n}\n\nfunc TestExtractPromptFiles(t *testing.T) {\n\tworkflow := `step impl { prompt = file(\".cloche/prompts/implement.md\") }\nstep fix { prompt = file(\".cloche/prompts/fix.md\") }\nstep test { run = \"make test\" }`\n\n\tfiles := extractPromptFiles(workflow)\n\tassert.Len(t, files, 2)\n\tassert.Contains(t, files, \".cloche/prompts/implement.md\")\n\tassert.Contains(t, files, \".cloche/prompts/fix.md\")\n}\n\n// --- Classifier tests ---\n\nfunc TestClassifierCategorizesRun(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tresponse string\n\t\texpected string\n\t}{\n\t\t{\"bug\", `{\"classification\": \"bug\"}`, \"bug\"},\n\t\t{\"feature\", `{\"classification\": \"feature\"}`, \"feature\"},\n\t\t{\"feedback\", `{\"classification\": \"feedback\"}`, \"feedback\"},\n\t\t{\"enhancement\", `{\"classification\": \"enhancement\"}`, \"enhancement\"},\n\t\t{\"chore\", `{\"classification\": \"chore\"}`, \"chore\"},\n\t\t{\"invalid defaults to feature\", `{\"classification\": \"unknown\"}`, \"feature\"},\n\t\t{\"malformed JSON defaults to feature\", `not json`, \"feature\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tllm := &fakeLLM{response: tt.response}\n\t\t\tc := &Classifier{LLM: llm}\n\t\t\tresult, err := c.Classify(context.Background(), \"some prompt\")\n\t\t\trequire.NoError(t, err)\n\t\t\tassert.Equal(t, tt.expected, result)\n\t\t})\n\t}\n}\n\n// --- Reflector tests ---\n\nfunc TestReflectorExtractsLessons(t *testing.T) {\n\tlessonsJSON, _ := json.Marshal(map[string]any{\n\t\t\"lessons\": []map[string]any{\n\t\t\t{\n\t\t\t\t\"id\":               \"lesson-001\",\n\t\t\t\t\"category\":         \"prompt_improvement\",\n\t\t\t\t\"target\":           \".cloche/prompts/implement.md\",\n\t\t\t\t\"insight\":          \"Agent produces unsanitized HTML\",\n\t\t\t\t\"suggested_action\": \"Add sanitization rule\",\n\t\t\t\t\"evidence\":         []string{\"run-1\", \"run-2\"},\n\t\t\t\t\"confidence\":       \"high\",\n\t\t\t},\n\t\t},\n\t})\n\n\tllm := &fakeLLM{response: string(lessonsJSON)}\n\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n\n\tdata := &CollectedData{WorkflowName: \"develop\", KnowledgeBase: \"# KB\\n\"}\n\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n\trequire.NoError(t, err)\n\trequire.Len(t, lessons, 1)\n\tassert.Equal(t, \"prompt_improvement\", lessons[0].Category)\n\tassert.Equal(t, \"high\", lessons[0].Confidence)\n}\n\nfunc TestReflectorFiltersLowConfidence(t *testing.T) {\n\tlessonsJSON, _ := json.Marshal(map[string]any{\n\t\t\"lessons\": []map[string]any{\n\t\t\t{\"id\": \"L1\", \"category\": \"new_step\", \"confidence\": \"low\"},\n\t\t\t{\"id\": \"L2\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n\t\t},\n\t})\n\n\tllm := &fakeLLM{response: string(lessonsJSON)}\n\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n\n\tlessons, err := r.Reflect(context.Background(), &CollectedData{}, \"bug\")\n\trequire.NoError(t, err)\n\tassert.Len(t, lessons, 1)\n\tassert.Equal(t, \"L2\", lessons[0].ID)\n}\n\nfunc TestConfidenceLevel(t *testing.T) {\n\tassert.Equal(t, 3, confidenceLevel(\"high\"))\n\tassert.Equal(t, 2, confidenceLevel(\"medium\"))\n\tassert.Equal(t, 1, confidenceLevel(\"low\"))\n\tassert.Equal(t, 0, confidenceLevel(\"\"))\n}\n\n// --- Audit Logger tests ---\n\nfunc TestAuditLoggerAppendsJSONL(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\"), 0755)\n\n\tlogger := &AuditLogger{ProjectDir: dir}\n\n\tresult1 := &EvolutionResult{\n\t\tID:           \"evo-1\",\n\t\tWorkflowName: \"develop\",\n\t\tChanges:      []Change{{Type: \"prompt_update\", File: \".cloche/prompts/impl.md\"}},\n\t}\n\trequire.NoError(t, logger.Log(result1))\n\n\tresult2 := &EvolutionResult{\n\t\tID:           \"evo-2\",\n\t\tWorkflowName: \"develop\",\n\t\tChanges:      []Change{{Type: \"add_step\", File: \".cloche/develop.cloche\"}},\n\t}\n\trequire.NoError(t, logger.Log(result2))\n\n\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n\trequire.NoError(t, err)\n\n\tlines := strings.Split(strings.TrimSpace(string(content)), \"\\n\")\n\tassert.Len(t, lines, 2)\n\n\tvar entry1 EvolutionResult\n\trequire.NoError(t, json.Unmarshal([]byte(lines[0]), &entry1))\n\tassert.Equal(t, \"evo-1\", entry1.ID)\n}\n\nfunc TestAuditLoggerSnapshot(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"original content\"), 0644)\n\n\tlogger := &AuditLogger{ProjectDir: dir}\n\tsnapName, err := logger.Snapshot(\".cloche/prompts/implement.md\")\n\trequire.NoError(t, err)\n\tassert.NotEmpty(t, snapName)\n\n\tsnapPath := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\", snapName)\n\tcontent, err := os.ReadFile(snapPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"original content\", string(content))\n}\n\nfunc TestAuditLoggerUpdatesKnowledge(t *testing.T) {\n\tdir := t.TempDir()\n\tkbDir := filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\")\n\tos.MkdirAll(kbDir, 0755)\n\tos.WriteFile(filepath.Join(kbDir, \"develop.md\"), []byte(\"# Knowledge Base: develop workflow\\n\"), 0644)\n\n\tlogger := &AuditLogger{ProjectDir: dir}\n\tlessons := []Lesson{\n\t\t{\n\t\t\tID:              \"P001\",\n\t\t\tCategory:        \"prompt_improvement\",\n\t\t\tConfidence:      \"high\",\n\t\t\tInsight:         \"Always sanitize HTML inputs\",\n\t\t\tSuggestedAction: \"Add rule to implement prompt\",\n\t\t\tEvidence:        []string{\"run-1\", \"run-2\"},\n\t\t},\n\t}\n\n\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", lessons))\n\n\tcontent, err := os.ReadFile(filepath.Join(kbDir, \"develop.md\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"[P001]\")\n\tassert.Contains(t, string(content), \"sanitize HTML\")\n\tassert.Contains(t, string(content), \"run-1, run-2\")\n}\n\n// --- LLM Client tests ---\n\n// --- Curator tests ---\n\nfunc TestCuratorUpdatesPrompt(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n\n\tupdatedContent := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"\n\tllm := &fakeLLM{response: updatedContent}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tID:              \"lesson-001\",\n\t\tCategory:        \"prompt_improvement\",\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"XSS vulnerabilities in form handlers\",\n\t\tSuggestedAction: \"Add sanitization rule\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"prompt_update\", change.Type)\n\tassert.Equal(t, \".cloche/prompts/implement.md\", change.File)\n\tassert.NotEmpty(t, change.Snapshot)\n\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"sanitize user inputs\")\n}\n\n// --- stripCodeFences tests ---\n\nfunc TestStripCodeFences(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tinput    string\n\t\texpected string\n\t}{\n\t\t{\n\t\t\tname:     \"no fences returns as-is\",\n\t\t\tinput:    \"# Prompt\\n\\nDo good work.\\n\",\n\t\t\texpected: \"# Prompt\\n\\nDo good work.\",\n\t\t},\n\t\t{\n\t\t\tname:     \"plain code fence\",\n\t\t\tinput:    \"```\\n# Prompt\\n\\nDo good work.\\n```\",\n\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n\t\t},\n\t\t{\n\t\t\tname:     \"code fence with language hint\",\n\t\t\tinput:    \"```markdown\\n# Prompt\\n\\nDo good work.\\n```\",\n\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n\t\t},\n\t\t{\n\t\t\tname:     \"commentary before and after fence\",\n\t\t\tinput:    \"Here's the updated prompt:\\n\\n```markdown\\n# Prompt\\n\\nDo good work.\\n```\\n\\nI've added the rule as requested.\",\n\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n\t\t},\n\t\t{\n\t\t\tname:     \"no closing fence returns as-is\",\n\t\t\tinput:    \"```markdown\\n# Prompt\\n\",\n\t\t\texpected: \"```markdown\\n# Prompt\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, tt.expected, stripCodeFences(tt.input))\n\t\t})\n\t}\n}\n\nfunc TestCuratorStripsCodeFencesFromResponse(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n\n\t// LLM returns content wrapped in code fences with commentary\n\tfencedResponse := \"Here is the updated prompt:\\n\\n```markdown\\n# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n```\\n\\nI added the validation rule.\"\n\tllm := &fakeLLM{response: fencedResponse}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Missing input validation\",\n\t\tSuggestedAction: \"Add validation rule\",\n\t}\n\n\t_, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\n\t// Should contain the actual prompt content, not the commentary\n\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n\tassert.Contains(t, string(content), \"Always validate inputs\")\n\tassert.NotContains(t, string(content), \"Here is the updated prompt\")\n\tassert.NotContains(t, string(content), \"I added the validation rule\")\n\tassert.NotContains(t, string(content), \"```\")\n}\n\nfunc TestCuratorRejectsConversationalMetaText(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"fix.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\toriginal := \"# Fix Prompt\\n\\nFix bugs carefully.\\n\"\n\tos.WriteFile(promptPath, []byte(original), 0644)\n\n\t// LLM returns conversational meta-text\n\tllm := &fakeLLM{response: \"I need write permission to update the file. Could you grant access to .cloche/prompts/fix.md?\"}\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/fix.md\",\n\t\tInsight:         \"Missing error context\",\n\t\tSuggestedAction: \"Wrap errors with context\",\n\t}\n\n\t_, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\t// Must NOT contain the conversational text\n\tassert.NotContains(t, string(content), \"I need write permission\")\n\tassert.NotContains(t, string(content), \"Could you grant access\")\n\t// Should contain the original content and the lesson appended directly\n\tassert.Contains(t, string(content), \"# Fix Prompt\")\n\tassert.Contains(t, string(content), \"Missing error context\")\n}\n\nfunc TestCuratorRejectsUnfencedConversationalPrefix(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n\tos.WriteFile(promptPath, []byte(original), 0644)\n\n\t// LLM returns \"Here is the updated prompt:\" with NO code fences\n\tllm := &fakeLLM{response: \"Here is the updated prompt:\\n\\n# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Validate inputs\\n\"}\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Missing validation\",\n\t\tSuggestedAction: \"Add input validation\",\n\t}\n\n\t_, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\t// The conversational prefix must not appear\n\tassert.NotContains(t, string(content), \"Here is the updated prompt\")\n\t// Original content preserved, lesson appended via fallback\n\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n\tassert.Contains(t, string(content), \"Missing validation\")\n}\n\nfunc TestCuratorAcceptsValidPromptWithoutFences(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n\n\t// LLM returns valid prompt content without code fences\n\tvalidResponse := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n\"\n\tllm := &fakeLLM{response: validResponse}\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Missing validation\",\n\t\tSuggestedAction: \"Add validation rule\",\n\t}\n\n\t_, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\t// Should write the LLM response (after stripCodeFences trimming) since it's valid prompt content\n\tassert.Contains(t, string(content), \"Always validate inputs\")\n\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n\tassert.NotContains(t, string(content), \"Missing validation\")\n}\n\nfunc TestIsConversationalResponse(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tinput    string\n\t\texpected bool\n\t}{\n\t\t{\"permission request\", \"I need write permission to update the file\", true},\n\t\t{\"grant request\", \"Could you grant access to the file?\", true},\n\t\t{\"blocked message\", \"Permission blocked by sandbox\", true},\n\t\t{\"here is updated\", \"Here is the updated prompt:\\n\\n# Prompt\", true},\n\t\t{\"heres updated\", \"Here's the updated prompt:\\n\\n# Prompt\", true},\n\t\t{\"ive updated\", \"I've updated the prompt with the new rule\", true},\n\t\t{\"let me\", \"Let me update the file for you\", true},\n\t\t{\"valid markdown heading\", \"# Prompt\\n\\nDo good work.\", false},\n\t\t{\"valid bullet list\", \"- Rule one\\n- Rule two\", false},\n\t\t{\"empty string\", \"\", true},\n\t\t{\"valid content no heading\", \"Write good code and test everything.\", false},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, tt.expected, isConversationalResponse(tt.input))\n\t\t})\n\t}\n}\n\nfunc TestAppendLessonDirectly(t *testing.T) {\n\tt.Run(\"creates learned rules section\", func(t *testing.T) {\n\t\tresult := appendLessonDirectly(\"# Prompt\\n\\nDo good work.\\n\", &Lesson{\n\t\t\tInsight:         \"Missing validation\",\n\t\t\tSuggestedAction: \"Add validation\",\n\t\t})\n\t\tassert.Contains(t, result, \"## Learned Rules\")\n\t\tassert.Contains(t, result, \"Missing validation: Add validation\")\n\t})\n\n\tt.Run(\"appends to existing learned rules\", func(t *testing.T) {\n\t\texisting := \"# Prompt\\n\\n## Learned Rules\\n\\n- Existing rule\\n\"\n\t\tresult := appendLessonDirectly(existing, &Lesson{\n\t\t\tInsight:         \"New insight\",\n\t\t\tSuggestedAction: \"New action\",\n\t\t})\n\t\tassert.Contains(t, result, \"- Existing rule\")\n\t\tassert.Contains(t, result, \"- New insight: New action\")\n\t\t// Should not create a duplicate section\n\t\tassert.Equal(t, 1, strings.Count(result, \"## Learned Rules\"))\n\t})\n}\n\n// --- Script Generator tests ---\n\nfunc TestScriptGeneratorCreatesScript(t *testing.T) {\n\tdir := t.TempDir()\n\n\tllm := &fakeLLM{response: `{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`}\n\tg := &ScriptGenerator{LLM: llm}\n\n\tlesson := &Lesson{\n\t\tID:              \"lesson-001\",\n\t\tCategory:        \"new_step\",\n\t\tStepType:        \"script\",\n\t\tInsight:         \"No security scanning\",\n\t\tSuggestedAction: \"Add gosec security scan\",\n\t}\n\n\tresult, err := g.Generate(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"scripts/security-scan.sh\", result.Path)\n\n\tcontent, err := os.ReadFile(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"gosec\")\n\n\tinfo, err := os.Stat(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n\trequire.NoError(t, err)\n\tassert.NotZero(t, info.Mode()&0111) // executable\n}\n\n// --- LLM Client tests ---\n\nfunc TestCommandLLMClientPrintMode(t *testing.T) {\n\t// Use a shell script that dumps its args and stdin so we can verify\n\t// that the client passes the right flags and prompt separation.\n\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n\tos.WriteFile(script, []byte(`#!/bin/sh\necho \"ARGS:$*\"\necho \"STDIN:$(cat)\"\n`), 0755)\n\n\tc := &CommandLLMClient{Command: script, Args: []string{}}\n\tresult, err := c.Complete(context.Background(), \"You are a helpful assistant.\", \"Summarize this text\")\n\trequire.NoError(t, err)\n\n\t// Should include -p flag for print/non-interactive mode\n\tassert.Contains(t, result, \"-p\")\n\n\t// Should pass system prompt via --system-prompt flag\n\tassert.Contains(t, result, \"--system-prompt\")\n\tassert.Contains(t, result, \"You are a helpful assistant.\")\n\n\t// Should pass --output-format text\n\tassert.Contains(t, result, \"--output-format text\")\n\n\t// Stdin should contain only the user prompt, not the system prompt\n\tassert.Contains(t, result, \"STDIN:Summarize this text\")\n\tassert.NotContains(t, result, \"STDIN:You are a helpful assistant\")\n}\n\nfunc TestCommandLLMClientEmptySystemPrompt(t *testing.T) {\n\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n\tos.WriteFile(script, []byte(`#!/bin/sh\necho \"ARGS:$*\"\necho \"STDIN:$(cat)\"\n`), 0755)\n\n\tc := &CommandLLMClient{Command: script, Args: []string{}}\n\tresult, err := c.Complete(context.Background(), \"\", \"just user prompt\")\n\trequire.NoError(t, err)\n\n\t// Should NOT include --system-prompt when system prompt is empty\n\tassert.NotContains(t, result, \"--system-prompt\")\n\t// Should still have -p and --output-format\n\tassert.Contains(t, result, \"-p\")\n\tassert.Contains(t, result, \"--output-format text\")\n\tassert.Contains(t, result, \"STDIN:just user prompt\")\n}\n\nfunc TestCommandLLMClientExtraArgs(t *testing.T) {\n\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n\tos.WriteFile(script, []byte(`#!/bin/sh\necho \"ARGS:$*\"\necho \"STDIN:$(cat)\"\n`), 0755)\n\n\tc := &CommandLLMClient{Command: script, Args: []string{\"--model\", \"sonnet\"}}\n\tresult, err := c.Complete(context.Background(), \"sys\", \"usr\")\n\trequire.NoError(t, err)\n\n\t// Extra args should appear before the appended flags\n\tassert.Contains(t, result, \"--model sonnet\")\n\tassert.Contains(t, result, \"-p\")\n}\n\nfunc TestCommandLLMClientDoesNotMutateArgs(t *testing.T) {\n\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n\tos.WriteFile(script, []byte(\"#!/bin/sh\\ncat\\n\"), 0755)\n\n\toriginal := []string{\"--verbose\"}\n\tc := &CommandLLMClient{Command: script, Args: original}\n\t_, err := c.Complete(context.Background(), \"sys\", \"usr\")\n\trequire.NoError(t, err)\n\n\t// The original Args slice should not be modified between calls.\n\tassert.Equal(t, []string{\"--verbose\"}, original)\n}\n\n// --- Orchestrator tests ---\n\n// scriptedLLM returns responses in order.\ntype scriptedLLM struct {\n\tresponses []string\n\tidx       int\n}\n\nfunc (s *scriptedLLM) Complete(ctx context.Context, system, user string) (string, error) {\n\tresp := s.responses[s.idx]\n\ts.idx++\n\treturn resp, nil\n}\n\nfunc TestOrchestratorEndToEnd(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Set up project structure\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"Write good code.\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n  implement:success -> test\n  test:success -> done\n  test:fail -> abort\n}`), 0644)\n\n\t// Fake LLM that returns appropriate responses per stage\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t// Reflector\n\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t\t// Curator\n\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"bug\", result.Classification)\n\trequire.Len(t, result.Changes, 1)\n\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n\n\t// Verify prompt was actually updated\n\tcontent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n\tassert.Contains(t, string(content), \"sanitize user inputs\")\n\n\t// Verify audit log was written\n\tlogContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n\tassert.Contains(t, string(logContent), \"prompt_update\")\n\tassert.Contains(t, string(logContent), \"XSS pattern\")\n\n\t// Verify knowledge base was updated\n\tkbContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"))\n\tassert.Contains(t, string(kbContent), \"L001\")\n}\n\nfunc TestOrchestratorNewStepWiredIntoGraph(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n  implement:success -> test\n  implement:fail -> abort\n  test:success -> done\n  test:fail -> abort\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"enhancement\"}`,\n\t\t\t// Reflector\n\t\t\t`{\"lessons\": [{\"id\": \"L002\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"No security scanning\", \"suggested_action\": \"Add gosec scan\", \"evidence\": [\"run-2\"], \"confidence\": \"high\"}]}`,\n\t\t\t// ScriptGenerator\n\t\t\t`{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-2\", nil, nil)\n\trequire.NoError(t, err)\n\trequire.Len(t, result.Changes, 2) // add_script + add_step\n\tassert.Equal(t, \"add_script\", result.Changes[0].Type)\n\tassert.Equal(t, \"add_step\", result.Changes[1].Type)\n\n\t// Read the updated workflow and verify the new step is reachable\n\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n\trequire.NoError(t, err)\n\n\twfStr := string(wfContent)\n\t// The new step should be wired into the graph\n\tassert.Contains(t, wfStr, \"step security-scan\")\n\t// An existing step should wire to the new step (rewired from -> done)\n\tassert.Contains(t, wfStr, \"test:success -> security-scan\")\n\t// The new step should wire its results to terminals\n\tassert.Contains(t, wfStr, \"security-scan:success -> done\")\n\tassert.Contains(t, wfStr, \"security-scan:fail -> abort\")\n\n\t// Verify the workflow parses and validates\n\twf, err := dsl.Parse(wfStr)\n\trequire.NoError(t, err)\n\trequire.NoError(t, wf.Validate())\n}\n\nfunc TestHandleNewStepSkipsDuplicate(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\n\t// Workflow already contains a step named \"security-scan\"\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  step security-scan {\n    run = \"scripts/security-scan.sh\"\n    results = [success, fail]\n  }\n  implement:success -> security-scan\n  implement:fail -> abort\n  security-scan:success -> done\n  security-scan:fail -> abort\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"enhancement\"}`,\n\t\t\t// Reflector — lesson wants to add \"security-scan\" again\n\t\t\t`{\"lessons\": [{\"id\": \"L003\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add security scanning\", \"suggested_action\": \"Add gosec scan\", \"evidence\": [\"run-3\"], \"confidence\": \"high\"}]}`,\n\t\t\t// ScriptGenerator\n\t\t\t`{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-3\", nil, nil)\n\trequire.NoError(t, err)\n\n\t// Should have add_script change but NOT add_step (skipped as duplicate)\n\tstepChanges := 0\n\tfor _, c := range result.Changes {\n\t\tif c.Type == \"add_step\" {\n\t\t\tstepChanges++\n\t\t}\n\t}\n\tassert.Equal(t, 0, stepChanges, \"should not add a duplicate step\")\n\n\t// Workflow should be unchanged — still valid, no duplicates\n\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n\trequire.NoError(t, err)\n\twf, err := dsl.Parse(string(wfContent))\n\trequire.NoError(t, err)\n\trequire.NoError(t, wf.Validate())\n\tassert.Equal(t, 2, len(wf.Steps), \"should still have exactly 2 steps\")\n}\n\nfunc TestHandleNewStepNoDoneEdge(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\n\t// Workflow has no -> done edges (all go to abort)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  implement:success -> done\n  implement:fail -> abort\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"enhancement\"}`,\n\t\t\t`{\"lessons\": [{\"id\": \"L004\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add linting\", \"suggested_action\": \"Add lint step\", \"evidence\": [\"run-4\"], \"confidence\": \"high\"}]}`,\n\t\t\t`{\"path\": \"scripts/lint.sh\", \"content\": \"#!/bin/bash\\ngolangci-lint run\"}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-4\", nil, nil)\n\trequire.NoError(t, err)\n\n\t// The new step should be added and the resulting workflow must validate\n\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n\trequire.NoError(t, err)\n\twf, err := dsl.Parse(string(wfContent))\n\trequire.NoError(t, err)\n\trequire.NoError(t, wf.Validate(), \"resulting workflow should have no orphaned steps\")\n\n\t// The new step should be reachable\n\t_, hasStep := wf.Steps[\"lint\"]\n\tassert.True(t, hasStep, \"lint step should exist\")\n\n\t// Verify add_step change was recorded\n\thasAddStep := false\n\tfor _, c := range result.Changes {\n\t\tif c.Type == \"add_step\" {\n\t\t\thasAddStep = true\n\t\t}\n\t}\n\tassert.True(t, hasAddStep, \"should have recorded add_step change\")\n}\n\nfunc TestHandleNewStepValidatesResultingWorkflow(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n  implement:success -> test\n  implement:fail -> abort\n  test:success -> done\n  test:fail -> abort\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"enhancement\"}`,\n\t\t\t`{\"lessons\": [{\"id\": \"L005\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add formatting check\", \"suggested_action\": \"Add gofmt check\", \"evidence\": [\"run-5\"], \"confidence\": \"high\"}]}`,\n\t\t\t`{\"path\": \"scripts/format-check.sh\", \"content\": \"#!/bin/bash\\ngofmt -l .\"}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-5\", nil, nil)\n\trequire.NoError(t, err)\n\n\t// Read and fully validate the workflow\n\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n\trequire.NoError(t, err)\n\twf, err := dsl.Parse(string(wfContent))\n\trequire.NoError(t, err)\n\trequire.NoError(t, wf.Validate())\n\n\t// Verify we got 3 steps now\n\tassert.Equal(t, 3, len(wf.Steps))\n\n\t// Verify we got the add_step change\n\thasAddStep := false\n\tfor _, c := range result.Changes {\n\t\tif c.Type == \"add_step\" {\n\t\t\thasAddStep = true\n\t\t}\n\t}\n\tassert.True(t, hasAddStep)\n}\n\nfunc TestOrchestratorNoLessons(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step s {\n    run = \"echo hi\"\n    results = [success]\n  }\n  s:success -> done\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"feature\"}`,\n\t\t\t// Reflector — no lessons\n\t\t\t`{\"lessons\": []}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"feature\", result.Classification)\n\tassert.Empty(t, result.Changes)\n}\n\n// --- Content-change guard tests ---\n\nfunc TestLessonAlreadyPresent(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tprompt  string\n\t\tlesson  *Lesson\n\t\tpresent bool\n\t}{\n\t\t{\n\t\t\tname:    \"insight present\",\n\t\t\tprompt:  \"# Prompt\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n\t\t\tlesson:  &Lesson{Insight: \"Always sanitize user inputs\", SuggestedAction: \"Add rule\"},\n\t\t\tpresent: true,\n\t\t},\n\t\t{\n\t\t\tname:    \"action present\",\n\t\t\tprompt:  \"# Prompt\\n\\n## Learned Rules\\n\\n- Add input validation for all forms\\n\",\n\t\t\tlesson:  &Lesson{Insight: \"Forms lack validation\", SuggestedAction: \"Add input validation for all forms\"},\n\t\t\tpresent: true,\n\t\t},\n\t\t{\n\t\t\tname:    \"case insensitive match\",\n\t\t\tprompt:  \"# Prompt\\n\\n## Learned Rules\\n\\n- always sanitize user inputs\\n\",\n\t\t\tlesson:  &Lesson{Insight: \"Always Sanitize User Inputs\", SuggestedAction: \"Do it\"},\n\t\t\tpresent: true,\n\t\t},\n\t\t{\n\t\t\tname:    \"not present\",\n\t\t\tprompt:  \"# Prompt\\n\\nWrite good code.\\n\",\n\t\t\tlesson:  &Lesson{Insight: \"Always sanitize user inputs\", SuggestedAction: \"Add sanitization\"},\n\t\t\tpresent: false,\n\t\t},\n\t\t{\n\t\t\tname:    \"empty insight and action\",\n\t\t\tprompt:  \"# Prompt\\n\\nWrite good code.\\n\",\n\t\t\tlesson:  &Lesson{Insight: \"\", SuggestedAction: \"\"},\n\t\t\tpresent: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, tt.present, lessonAlreadyPresent(tt.prompt, tt.lesson))\n\t\t})\n\t}\n}\n\nfunc TestCuratorSkipsWhenLessonAlreadyPresent(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\n\t// Prompt already contains the lesson insight\n\tos.WriteFile(promptPath, []byte(\"# Prompt\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"), 0644)\n\n\t// LLM should NOT be called — use a response that would change the file\n\tllm := &fakeLLM{response: \"THIS SHOULD NOT APPEAR\"}\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Always sanitize user inputs\",\n\t\tSuggestedAction: \"Add sanitization rule\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Nil(t, change, \"should return nil change when lesson already present\")\n\n\t// File should be unchanged\n\tcontent, _ := os.ReadFile(promptPath)\n\tassert.NotContains(t, string(content), \"THIS SHOULD NOT APPEAR\")\n}\n\nfunc TestReflectorFiltersAlreadyAppliedLessons(t *testing.T) {\n\tlessonsJSON, _ := json.Marshal(map[string]any{\n\t\t\"lessons\": []map[string]any{\n\t\t\t{\"id\": \"lesson-001\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n\t\t\t{\"id\": \"lesson-002\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n\t\t},\n\t})\n\n\tllm := &fakeLLM{response: string(lessonsJSON)}\n\tr := &Reflector{LLM: llm, MinConfidence: \"low\"}\n\n\t// Knowledge base already contains lesson-001\n\tdata := &CollectedData{\n\t\tKnowledgeBase: \"# Knowledge Base\\n\\n- **[lesson-001]** (prompt_improvement, confidence: high) Old insight\\n\",\n\t}\n\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n\trequire.NoError(t, err)\n\trequire.Len(t, lessons, 1)\n\tassert.Equal(t, \"lesson-002\", lessons[0].ID)\n}\n\nfunc TestOrchestratorSkipsAlreadyAppliedLessons(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n\t\t[]byte(\"# Knowledge Base\\n\\n- **[L001]** (prompt_improvement, confidence: high) XSS pattern\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"Write good code.\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step s {\n    run = \"echo hi\"\n    results = [success]\n  }\n  s:success -> done\n}`), 0644)\n\n\t// Reflector returns a lesson that's already in the knowledge base\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"low\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\tassert.Empty(t, result.Changes, \"should produce zero changes for already-applied lesson\")\n}\n\nfunc TestOrchestratorSecondRunProducesNoChanges(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"Write good code.\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  implement:success -> done\n  implement:fail -> abort\n}`), 0644)\n\n\t// First run: lesson gets applied\n\tllm1 := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t`{\"lessons\": [{\"id\": \"L010\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Always sanitize user inputs\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n\t\t},\n\t}\n\n\torch1 := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm1,\n\t\tMinConfidence: \"low\",\n\t})\n\n\tresult1, err := orch1.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\trequire.Len(t, result1.Changes, 1, \"first run should produce one change\")\n\n\t// Second run: same lesson ID — the knowledge base now contains L010,\n\t// and the prompt contains the insight text.\n\tllm2 := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t`{\"lessons\": [{\"id\": \"L010\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Always sanitize user inputs\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t},\n\t}\n\n\torch2 := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm2,\n\t\tMinConfidence: \"low\",\n\t})\n\n\tresult2, err := orch2.Run(context.Background(), \"run-2\", nil, nil)\n\trequire.NoError(t, err)\n\tassert.Empty(t, result2.Changes, \"second run should produce zero changes\")\n}\n","numLines":1145,"startLine":1,"totalLines":1145}}}
