{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JpokN4f5DvegC7BwNYWfFV","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"regexp\"\n     9→\t\"strings\"\n    10→)\n    11→\n    12→// Curator merges lessons into prompt files using ACE-style curation.\n    13→type Curator struct {\n    14→\tLLM   LLMClient\n    15→\tAudit *AuditLogger\n    16→}\n    17→\n    18→// lessonAlreadyPresent checks whether the lesson's key insight or action is\n    19→// already present in the current prompt text (case-insensitive substring match).\n    20→func lessonAlreadyPresent(currentPrompt string, lesson *Lesson) bool {\n    21→\tlower := strings.ToLower(currentPrompt)\n    22→\tif lesson.Insight != \"\" && strings.Contains(lower, strings.ToLower(lesson.Insight)) {\n    23→\t\treturn true\n    24→\t}\n    25→\tif lesson.SuggestedAction != \"\" && strings.Contains(lower, strings.ToLower(lesson.SuggestedAction)) {\n    26→\t\treturn true\n    27→\t}\n    28→\treturn false\n    29→}\n    30→\n    31→// Apply curates a lesson into the target prompt file.\n    32→func (c *Curator) Apply(ctx context.Context, projectDir string, lesson *Lesson) (*Change, error) {\n    33→\ttargetPath := filepath.Join(projectDir, lesson.Target)\n    34→\tcurrent, err := os.ReadFile(targetPath)\n    35→\tif err != nil {\n    36→\t\treturn nil, fmt.Errorf(\"reading target prompt %s: %w\", lesson.Target, err)\n    37→\t}\n    38→\n    39→\t// Guard: skip if the lesson is already incorporated in the prompt\n    40→\tif lessonAlreadyPresent(string(current), lesson) {\n    41→\t\treturn nil, nil\n    42→\t}\n    43→\n    44→\tsystemPrompt := `You are a prompt curator using ACE (Agentic Context Engineering) principles.\n    45→Your job is to merge a new lesson into an existing prompt document.\n    46→\n    47→Rules:\n    48→- Append the lesson as a structured bullet/rule in a \"## Learned Rules\" section\n    49→- If a \"## Learned Rules\" section already exists, add to it\n    50→- If the lesson refines or duplicates an existing rule, update in place rather than appending\n    51→- Preserve ALL existing content exactly as-is\n    52→- Keep rules concise and actionable\n    53→- Do not add commentary — return only the updated prompt content`\n    54→\n    55→\tuserPrompt := fmt.Sprintf(\"## Current Prompt Content\\n```\\n%s\\n```\\n\\n## Lesson to Merge\\nInsight: %s\\nSuggested Action: %s\",\n    56→\t\tstring(current), lesson.Insight, lesson.SuggestedAction)\n    57→\n    58→\traw, err := c.LLM.Complete(ctx, systemPrompt, userPrompt)\n    59→\tif err != nil {\n    60→\t\treturn nil, fmt.Errorf(\"curator LLM call: %w\", err)\n    61→\t}\n    62→\n    63→\tupdated := stripCodeFences(raw)\n    64→\n    65→\t// Validate that the LLM output is actual prompt content, not meta-conversation\n    66→\tif isConversationalResponse(updated) {\n    67→\t\t// Fallback: append the lesson directly rather than trusting the LLM\n    68→\t\tupdated = appendLessonDirectly(string(current), lesson)\n    69→\t}\n    70→\n    71→\t// Snapshot before writing\n    72→\tvar snapName string\n    73→\tif c.Audit != nil {\n    74→\t\tsnapName, _ = c.Audit.Snapshot(lesson.Target)\n    75→\t}\n    76→\n    77→\tif err := os.WriteFile(targetPath, []byte(updated), 0644); err != nil {\n    78→\t\treturn nil, fmt.Errorf(\"writing updated prompt: %w\", err)\n    79→\t}\n    80→\n    81→\treturn &Change{\n    82→\t\tType:     \"prompt_update\",\n    83→\t\tFile:     lesson.Target,\n    84→\t\tReason:   lesson.Insight,\n    85→\t\tSnapshot: snapName,\n    86→\t}, nil\n    87→}\n    88→\n    89→// conversationalMarkers are patterns that indicate the LLM returned\n    90→// meta-conversation text instead of prompt content.\n    91→var conversationalMarkers = regexp.MustCompile(\n    92→\t`(?i)^(I need |I can't |I cannot |Could you |Please grant |` +\n    93→\t\t`I don't have |I do not have |permission|write access|blocked by|` +\n    94→\t\t`Here is the updated|Here's the updated|I've updated|I have updated|` +\n    95→\t\t`Let me |I'll |I will )`)\n    96→\n    97→// isConversationalResponse checks whether the LLM output appears to be\n    98→// meta-conversation text rather than actual prompt content.\n    99→func isConversationalResponse(s string) bool {\n   100→\ttrimmed := strings.TrimSpace(s)\n   101→\tif trimmed == \"\" {\n   102→\t\treturn true\n   103→\t}\n   104→\t// Check the first non-empty line for conversational markers\n   105→\tfirstLine := trimmed\n   106→\tif idx := strings.Index(trimmed, \"\\n\"); idx != -1 {\n   107→\t\tfirstLine = trimmed[:idx]\n   108→\t}\n   109→\treturn conversationalMarkers.MatchString(strings.TrimSpace(firstLine))\n   110→}\n   111→\n   112→// appendLessonDirectly adds a lesson to the prompt content without LLM help,\n   113→// used as a fallback when the LLM returns conversational text.\n   114→func appendLessonDirectly(current string, lesson *Lesson) string {\n   115→\tcurrent = strings.TrimRight(current, \"\\n\")\n   116→\tif strings.Contains(current, \"## Learned Rules\") {\n   117→\t\treturn current + fmt.Sprintf(\"\\n- %s: %s\\n\", lesson.Insight, lesson.SuggestedAction)\n   118→\t}\n   119→\treturn current + fmt.Sprintf(\"\\n\\n## Learned Rules\\n\\n- %s: %s\\n\", lesson.Insight, lesson.SuggestedAction)\n   120→}\n   121→\n   122→// stripCodeFences removes markdown code fences from an LLM response,\n   123→// extracting just the content between them. If no fences are found,\n   124→// the input is returned unchanged (trimmed).\n   125→func stripCodeFences(s string) string {\n   126→\ts = strings.TrimSpace(s)\n   127→\n   128→\topenIdx := strings.Index(s, \"```\")\n   129→\tif openIdx == -1 {\n   130→\t\treturn s\n   131→\t}\n   132→\n   133→\t// Skip the opening fence line (may include language hint like ```markdown)\n   134→\tafterOpen := s[openIdx+3:]\n   135→\tnewlineIdx := strings.Index(afterOpen, \"\\n\")\n   136→\tif newlineIdx == -1 {\n   137→\t\treturn s\n   138→\t}\n   139→\tcontentStart := openIdx + 3 + newlineIdx + 1\n   140→\n   141→\t// Find the closing fence (last ``` in the string)\n   142→\tcloseIdx := strings.LastIndex(s, \"```\")\n   143→\tif closeIdx <= openIdx {\n   144→\t\treturn s\n   145→\t}\n   146→\n   147→\treturn s[contentStart:closeIdx]\n   148→}\n   149→"}]},"parent_tool_use_id":null,"session_id":"f9cd3635-7b59-4df8-9a88-6beef5e619d5","uuid":"b89f8b3a-b1aa-4d9b-9420-a02075684419","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/curator.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"strings\"\n)\n\n// Curator merges lessons into prompt files using ACE-style curation.\ntype Curator struct {\n\tLLM   LLMClient\n\tAudit *AuditLogger\n}\n\n// lessonAlreadyPresent checks whether the lesson's key insight or action is\n// already present in the current prompt text (case-insensitive substring match).\nfunc lessonAlreadyPresent(currentPrompt string, lesson *Lesson) bool {\n\tlower := strings.ToLower(currentPrompt)\n\tif lesson.Insight != \"\" && strings.Contains(lower, strings.ToLower(lesson.Insight)) {\n\t\treturn true\n\t}\n\tif lesson.SuggestedAction != \"\" && strings.Contains(lower, strings.ToLower(lesson.SuggestedAction)) {\n\t\treturn true\n\t}\n\treturn false\n}\n\n// Apply curates a lesson into the target prompt file.\nfunc (c *Curator) Apply(ctx context.Context, projectDir string, lesson *Lesson) (*Change, error) {\n\ttargetPath := filepath.Join(projectDir, lesson.Target)\n\tcurrent, err := os.ReadFile(targetPath)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading target prompt %s: %w\", lesson.Target, err)\n\t}\n\n\t// Guard: skip if the lesson is already incorporated in the prompt\n\tif lessonAlreadyPresent(string(current), lesson) {\n\t\treturn nil, nil\n\t}\n\n\tsystemPrompt := `You are a prompt curator using ACE (Agentic Context Engineering) principles.\nYour job is to merge a new lesson into an existing prompt document.\n\nRules:\n- Append the lesson as a structured bullet/rule in a \"## Learned Rules\" section\n- If a \"## Learned Rules\" section already exists, add to it\n- If the lesson refines or duplicates an existing rule, update in place rather than appending\n- Preserve ALL existing content exactly as-is\n- Keep rules concise and actionable\n- Do not add commentary — return only the updated prompt content`\n\n\tuserPrompt := fmt.Sprintf(\"## Current Prompt Content\\n```\\n%s\\n```\\n\\n## Lesson to Merge\\nInsight: %s\\nSuggested Action: %s\",\n\t\tstring(current), lesson.Insight, lesson.SuggestedAction)\n\n\traw, err := c.LLM.Complete(ctx, systemPrompt, userPrompt)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"curator LLM call: %w\", err)\n\t}\n\n\tupdated := stripCodeFences(raw)\n\n\t// Validate that the LLM output is actual prompt content, not meta-conversation\n\tif isConversationalResponse(updated) {\n\t\t// Fallback: append the lesson directly rather than trusting the LLM\n\t\tupdated = appendLessonDirectly(string(current), lesson)\n\t}\n\n\t// Snapshot before writing\n\tvar snapName string\n\tif c.Audit != nil {\n\t\tsnapName, _ = c.Audit.Snapshot(lesson.Target)\n\t}\n\n\tif err := os.WriteFile(targetPath, []byte(updated), 0644); err != nil {\n\t\treturn nil, fmt.Errorf(\"writing updated prompt: %w\", err)\n\t}\n\n\treturn &Change{\n\t\tType:     \"prompt_update\",\n\t\tFile:     lesson.Target,\n\t\tReason:   lesson.Insight,\n\t\tSnapshot: snapName,\n\t}, nil\n}\n\n// conversationalMarkers are patterns that indicate the LLM returned\n// meta-conversation text instead of prompt content.\nvar conversationalMarkers = regexp.MustCompile(\n\t`(?i)^(I need |I can't |I cannot |Could you |Please grant |` +\n\t\t`I don't have |I do not have |permission|write access|blocked by|` +\n\t\t`Here is the updated|Here's the updated|I've updated|I have updated|` +\n\t\t`Let me |I'll |I will )`)\n\n// isConversationalResponse checks whether the LLM output appears to be\n// meta-conversation text rather than actual prompt content.\nfunc isConversationalResponse(s string) bool {\n\ttrimmed := strings.TrimSpace(s)\n\tif trimmed == \"\" {\n\t\treturn true\n\t}\n\t// Check the first non-empty line for conversational markers\n\tfirstLine := trimmed\n\tif idx := strings.Index(trimmed, \"\\n\"); idx != -1 {\n\t\tfirstLine = trimmed[:idx]\n\t}\n\treturn conversationalMarkers.MatchString(strings.TrimSpace(firstLine))\n}\n\n// appendLessonDirectly adds a lesson to the prompt content without LLM help,\n// used as a fallback when the LLM returns conversational text.\nfunc appendLessonDirectly(current string, lesson *Lesson) string {\n\tcurrent = strings.TrimRight(current, \"\\n\")\n\tif strings.Contains(current, \"## Learned Rules\") {\n\t\treturn current + fmt.Sprintf(\"\\n- %s: %s\\n\", lesson.Insight, lesson.SuggestedAction)\n\t}\n\treturn current + fmt.Sprintf(\"\\n\\n## Learned Rules\\n\\n- %s: %s\\n\", lesson.Insight, lesson.SuggestedAction)\n}\n\n// stripCodeFences removes markdown code fences from an LLM response,\n// extracting just the content between them. If no fences are found,\n// the input is returned unchanged (trimmed).\nfunc stripCodeFences(s string) string {\n\ts = strings.TrimSpace(s)\n\n\topenIdx := strings.Index(s, \"```\")\n\tif openIdx == -1 {\n\t\treturn s\n\t}\n\n\t// Skip the opening fence line (may include language hint like ```markdown)\n\tafterOpen := s[openIdx+3:]\n\tnewlineIdx := strings.Index(afterOpen, \"\\n\")\n\tif newlineIdx == -1 {\n\t\treturn s\n\t}\n\tcontentStart := openIdx + 3 + newlineIdx + 1\n\n\t// Find the closing fence (last ``` in the string)\n\tcloseIdx := strings.LastIndex(s, \"```\")\n\tif closeIdx <= openIdx {\n\t\treturn s\n\t}\n\n\treturn s[contentStart:closeIdx]\n}\n","numLines":149,"startLine":1,"totalLines":149}}}
