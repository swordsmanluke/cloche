nID == \"\" {\n   435ŌåÆ\t\trows, err = s.db.QueryContext(ctx,\n   436ŌåÆ\t\t\t`SELECT `+runSelectCols+`\n   437ŌåÆ\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? ORDER BY started_at ASC`,\n   438ŌåÆ\t\t\tprojectDir, workflowName)\n   439ŌåÆ\t} else {\n   440ŌåÆ\t\trows, err = s.db.QueryContext(ctx,\n   441ŌåÆ\t\t\t`SELECT `+runSelectCols+`\n   442ŌåÆ\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? AND started_at > (SELECT started_at FROM runs WHERE id = ?)\n   443ŌåÆ\t\t\t ORDER BY started_at ASC`,\n   444ŌåÆ\t\t\tprojectDir, workflowName, sinceRunID)\n   445ŌåÆ\t}\n   446ŌåÆ\tif err != nil {\n   447ŌåÆ\t\treturn nil, err\n   448ŌåÆ\t}\n   449ŌåÆ\tdefer rows.Close()\n   450ŌåÆ\treturn scanRuns(rows)\n   451ŌåÆ}\n   452ŌåÆ\n   453ŌåÆ\n   454ŌåÆfunc (s *Store) FailStaleRuns(ctx context.Context) (int64, error) {\n   455ŌåÆ\tnow := formatTime(time.Now())\n   456ŌåÆ\tres, err := s.db.ExecContext(ctx,\n   457ŌåÆ\t\t`UPDATE runs SET state = 'failed', completed_at = ?, error_message = 'daemon restarted while run was active'\n   458ŌåÆ\t\t WHERE state IN ('pending', 'running')`,\n   459ŌåÆ\t\tnow,\n   460ŌåÆ\t)\n   461ŌåÆ\tif err != nil {\n   462ŌåÆ\t\treturn 0, err\n   463ŌåÆ\t}\n   464ŌåÆ\treturn res.RowsAffected()\n   465ŌåÆ}\n   466ŌåÆ\n   467ŌåÆfunc formatTime(t time.Time) string {\n   468ŌåÆ\tif t.IsZero() {\n   469ŌåÆ\t\treturn \"\"\n   470ŌåÆ\t}\n   471ŌåÆ\treturn t.Format(time.RFC3339Nano)\n   472ŌåÆ}\n   473ŌåÆ\n   474ŌåÆfunc parseTime(s string) time.Time {\n   475ŌåÆ\tif s == \"\" {\n   476ŌåÆ\t\treturn time.Time{}\n   477ŌåÆ\t}\n   478ŌåÆ\tt, _ := time.Parse(time.RFC3339Nano, s)\n   479ŌåÆ\treturn t\n   480ŌåÆ}\n   481ŌåÆ\n   482ŌåÆfunc boolToInt(b bool) int {\n   483ŌåÆ\tif b {\n   484ŌåÆ\t\treturn 1\n   485ŌåÆ\t}\n   486ŌåÆ\treturn 0\n   487ŌåÆ}\n   488ŌåÆ\n   489ŌåÆconst maxErrorMessageLen = 1000\n   490ŌåÆ\n   491ŌåÆ// truncateErrorMessage caps s to maxErrorMessageLen characters to prevent\n   492ŌåÆ// oversized agent output dumps from bloating the database. Full error\n   493ŌåÆ// details remain available in step logs.\n   494ŌåÆfunc truncateErrorMessage(s string) string {\n   495ŌåÆ\tif len(s) <= maxErrorMessageLen {\n   496ŌåÆ\t\treturn s\n   497ŌåÆ\t}\n   498ŌåÆ\treturn s[:maxErrorMessageLen] + \"... (truncated)\"\n   499ŌåÆ}\n   500ŌåÆ"}]},"parent_tool_use_id":"toolu_01LT97MYBGAi8gkxnHwbV9DE","session_id":"feb5bdf8-ca69-4cf3-a66e-11041ffe134a","uuid":"1427abe4-ce40-45a2-96df-1b5908ed729b","timestamp":"2026-03-17T14:12:38.774Z"}
