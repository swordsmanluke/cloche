[2026-03-17T14:15:48Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GfTxDzQZoHTLZzYTRjcDiy","type":"tool_result","content":"     1ŌåÆpackage evolution\n     2ŌåÆ\n     3ŌåÆimport (\n     4ŌåÆ\t\"context\"\n     5ŌåÆ\t\"fmt\"\n     6ŌåÆ\t\"os\"\n     7ŌåÆ\t\"path/filepath\"\n     8ŌåÆ\t\"strings\"\n     9ŌåÆ\t\"time\"\n    10ŌåÆ\n    11ŌåÆ\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    12ŌåÆ\t\"github.com/cloche-dev/cloche/internal/ports\"\n    13ŌåÆ)\n    14ŌåÆ\n    15ŌåÆ// OrchestratorConfig configures the evolution pipeline.\n    16ŌåÆtype OrchestratorConfig struct {\n    17ŌåÆ\tProjectDir       string\n    18ŌåÆ\tWorkflowName     string\n    19ŌåÆ\tLLM              LLMClient\n    20ŌåÆ\tMinConfidence    string\n    21ŌåÆ\tMaxPromptBullets int\n    22ŌåÆ}\n    23ŌåÆ\n    24ŌåÆ// Orchestrator wires all evolution pipeline stages together.\n    25ŌåÆtype Orchestrator struct {\n    26ŌåÆ\tcfg        OrchestratorConfig\n    27ŌåÆ\tcollector  *Collector\n    28ŌåÆ\tclassifier *Classifier\n    29ŌåÆ\treflector  *Reflector\n    30ŌåÆ\tcurator    *Curator\n    31ŌåÆ\tscriptGen  *ScriptGenerator\n    32ŌåÆ\tmutator    *dsl.Mutator\n    33ŌåÆ\taudit      *AuditLogger\n    34ŌåÆ}\n    35ŌåÆ\n    36ŌåÆ// NewOrchestrator creates a fully wired evolution pipeline.\n    37ŌåÆfunc NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n    38ŌåÆ\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir, MaxPromptBullets: cfg.MaxPromptBullets}\n    39ŌåÆ\treturn &Orchestrator{\n    40ŌåÆ\t\tcfg:        cfg,\n    41ŌåÆ\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n    42ŌåÆ\t\tclassifier: &Classifier{LLM: cfg.LLM},\n    43ŌåÆ\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n    44ŌåÆ\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n    45ŌåÆ\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n    46ŌåÆ\t\tmutator:    &dsl.Mutator{},\n    47ŌåÆ\t\taudit:      audit,\n    48ŌåÆ\t}\n    49ŌåÆ}\n    50ŌåÆ\n    51ŌåÆ// Run executes the full evolution pipeline.\n    52ŌåÆfunc (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n    53ŌåÆ\t// Stage 1: Collect\n    54ŌåÆ\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n    55ŌåÆ\tif err != nil {\n    56ŌåÆ\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n    57ŌåÆ\t}\n    58ŌåÆ\n    59ŌåÆ\t// Stage 2: Classify the triggering run\n    60ŌåÆ\tclassification, err := o.classifier.Classify(ctx, \"\")\n    61ŌåÆ\tif err != nil {\n    62ŌåÆ\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n    63ŌåÆ\t}\n    64ŌåÆ\n    65ŌåÆ\t// Stage 3: Reflect\n    66ŌåÆ\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n    67ŌåÆ\tif err != nil {\n    68ŌåÆ\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n    69ŌåÆ\t}\n    70ŌåÆ\n    71ŌåÆ\t// Filter out lessons whose IDs are already recorded in the knowledge base.\n    72ŌåÆ\t// This guards against the Reflector re-surfacing previously applied lessons.\n    73ŌåÆ\tif data.KnowledgeBase != \"\" {\n    74ŌåÆ\t\tvar fresh []Lesson\n    75ŌåÆ\t\tfor _, l := range lessons {\n    76ŌåÆ\t\t\tif l.ID != \"\" && strings.Contains(data.KnowledgeBase, l.ID) {\n    77ŌåÆ\t\t\t\tcontinue\n    78ŌåÆ\t\t\t}\n    79ŌåÆ\t\t\tfresh = append(fresh, l)\n    80ŌåÆ\t\t}\n    81ŌåÆ\t\tlessons = fresh\n    82ŌåÆ\t}\n    83ŌåÆ\n    84ŌåÆ\tresult := &EvolutionResult{\n    85ŌåÆ\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n    86ŌåÆ\t\tProjectDir:     o.cfg.ProjectDir,\n    87ŌåÆ\t\tWorkflowName:   o.cfg.WorkflowName,\n    88ŌåÆ\t\tTriggerRunID:   triggerRunID,\n    89ŌåÆ\t\tTimestamp:      time.Now().Format(time.RFC3339),\n    90ŌåÆ\t\tClassification: classification,\n    91ŌåÆ\t}\n    92ŌåÆ\n    93ŌåÆ\tif len(lessons) == 0 {\n    94ŌåÆ\t\t// No actionable lessons ŌĆö log and return\n    95ŌåÆ\t\to.audit.Log(result)\n    96ŌåÆ\t\treturn result, nil\n    97ŌåÆ\t}\n    98ŌåÆ\n    99ŌåÆ\t// Stage 4: Execute branches based on lesson category\n   100ŌåÆ\tfor _, lesson := range lessons {\n   101ŌåÆ\t\tswitch lesson.Category {\n   102ŌåÆ\t\tcase \"prompt_improvement\":\n   103ŌåÆ\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n   104ŌåÆ\t\t\tif err != nil {\n   105ŌåÆ\t\t\t\tcontinue // log but don't fail the whole pipeline\n   106ŌåÆ\t\t\t}\n   107ŌåÆ\t\t\tif change == nil {\n   108ŌåÆ\t\t\t\tcontinue // lesson already present in prompt ŌĆö no change needed\n   109ŌåÆ\t\t\t}\n   110ŌåÆ\t\t\tresult.Changes = append(result.Changes, *change)\n   111ŌåÆ\n   112ŌåÆ\t\tcase \"new_step\":\n   113ŌåÆ\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n   114ŌåÆ\t\t\t\tcontinue\n   115ŌåÆ\t\t\t}\n   116ŌåÆ\t\t}\n   117ŌåÆ\t}\n   118ŌåÆ\n   119ŌåÆ\t// Stage 5: Audit\n   120ŌåÆ\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n   121ŌåÆ\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n   122ŌåÆ\to.audit.Log(result)\n   123ŌåÆ\n   124ŌåÆ\t// Save to store if available\n   125ŌåÆ\tif evoStore != nil {\n   126ŌåÆ\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n   127ŌåÆ\t\t\tID:             result.ID,\n   128ŌåÆ\t\t\tProjectDir:     result.ProjectDir,\n   129ŌåÆ\t\t\tWorkflowName:   result.WorkflowName,\n   130ŌåÆ\t\t\tTriggerRunID:   result.TriggerRunID,\n   131ŌåÆ\t\t\tCreatedAt:      time.Now(),\n   132ŌåÆ\t\t\tClassification: result.Classification,\n   133ŌåÆ\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n   134ŌåÆ\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n   135ŌåÆ\t\t})\n   136ŌåÆ\t}\n   137ŌåÆ\n   138ŌåÆ\treturn result, nil\n   139ŌåÆ}\n   140ŌåÆ\n   141ŌåÆ// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\n   142ŌåÆfunc (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n   143ŌåÆ\t// Generate the script or prompt file\n   144ŌåÆ\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n   145ŌåÆ\tif err != nil {\n   146ŌåÆ\t\treturn err\n   147ŌåÆ\t}\n   148ŌåÆ\n   149ŌåÆ\tresult.Changes = append(result.Changes, Change{\n   150ŌåÆ\t\tType:   \"add_script\",\n   151ŌåÆ\t\tFile:   generated.Path,\n   152ŌåÆ\t\tReason: lesson.Insight,\n   153ŌåÆ\t})\n   154ŌåÆ\n   155ŌåÆ\t// Add step and wiring to the workflow file\n   156ŌåÆ\tif data.WorkflowPath == \"\" {\n   157ŌåÆ\t\treturn nil\n   158ŌåÆ\t}\n   159ŌåÆ\n   160ŌåÆ\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n   161ŌåÆ\tif err != nil {\n   162ŌåÆ\t\treturn err\n   163ŌåÆ\t}\n   164ŌåÆ\n   165ŌåÆ\t// Snapshot the workflow\n   166ŌåÆ\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n   167ŌåÆ\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n   168ŌåÆ\toriginal := string(workflowContent)\n   169ŌåÆ\n   170ŌåÆ\t// Derive step name from the script path\n   171ŌåÆ\tstepName := filepath.Base(generated.Path)\n   172ŌåÆ\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n   173ŌåÆ\n   174ŌåÆ\t// Check if a step with this name already exists ŌĆö skip if so\n   175ŌåÆ\texistingWf, parseErr := dsl.Parse(original)\n   176ŌåÆ\tif parseErr == nil {\n   177ŌåÆ\t\tif _, exists := existingWf.Steps[stepName]; exists {\n   178ŌåÆ\t\t\treturn nil\n   179ŌåÆ\t\t}\n   180ŌåÆ\t}\n   181ŌåÆ\n   182ŌåÆ\t// Determine the config based on step type\n   183ŌåÆ\tconfig := map[string]string{}\n   184ŌåÆ\tswitch lesson.StepType {\n   185ŌåÆ\tcase \"agent\":\n   186ŌåÆ\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n   187ŌåÆ\tdefault: // script\n   188ŌåÆ\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n   189ŌåÆ\t}\n   190ŌåÆ\n   191ŌåÆ\t// Add the step\n   192ŌåÆ\tupdated, err := o.mutator.AddStep(original, dsl.StepDef{\n   193ŌåÆ\t\tName:    stepName,\n   194ŌåÆ\t\tType:    lesson.StepType,\n   195ŌåÆ\t\tConfig:  config,\n   196ŌåÆ\t\tResults: []string{\"success\", \"fail\"},\n   197ŌåÆ\t})\n   198ŌåÆ\tif err != nil {\n   199ŌåÆ\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n   200ŌåÆ\t}\n   201ŌåÆ\n   202ŌåÆ\t// Wire the new step into the existing graph by finding a wire\n   203ŌåÆ\t// that currently goes to \"done\" and rerouting it through the new step.\n   204ŌåÆ\twf, parseErr := dsl.Parse(updated)\n   205ŌåÆ\tif parseErr == nil {\n   206ŌåÆ\t\tfor _, wire := range wf.Wiring {\n   207ŌåÆ\t\t\tif wire.To == \"done\" {\n   208ŌåÆ\t\t\t\trewired, rewireErr := o.mutator.RewireResult(updated, wire.From, wire.Result, \"done\", stepName)\n   209ŌåÆ\t\t\t\tif rewireErr == nil {\n   210ŌåÆ\t\t\t\t\tupdated = rewired\n   211ŌåÆ\t\t\t\t\tbreak\n   212ŌåÆ\t\t\t\t}\n   213ŌåÆ\t\t\t}\n   214ŌåÆ\t\t}\n   215ŌåÆ\t}\n   216ŌåÆ\n   217ŌåÆ\t// Wire the new step's results to terminals\n   218ŌåÆ\twires := []dsl.WireDef{\n   219ŌåÆ\t\t{From: stepName, Result: \"success\", To: \"done\"},\n   220ŌåÆ\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n   221ŌåÆ\t}\n   222ŌåÆ\tupdated, err = o.mutator.AddWiring(updated, wires)\n   223ŌåÆ\tif err != nil {\n   224ŌåÆ\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n   225ŌåÆ\t}\n   226ŌåÆ\n   227ŌåÆ\t// Validate the final workflow graph ŌĆö roll back on failure\n   228ŌåÆ\tfinalWf, parseErr := dsl.Parse(updated)\n   229ŌåÆ\tif parseErr != nil {\n   230ŌåÆ\t\treturn fmt.Errorf(\"parsing updated workflow: %w\", parseErr)\n   231ŌåÆ\t}\n   232ŌåÆ\tif valErr := finalWf.Validate(); valErr != nil {\n   233ŌåÆ\t\treturn fmt.Errorf(\"workflow validation failed after adding step %q: %w\", stepName, valErr)\n   234ŌåÆ\t}\n   235ŌåÆ\n   236ŌåÆ\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n   237ŌåÆ\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n   238ŌåÆ\t}\n   239ŌåÆ\n   240ŌåÆ\tresult.Changes = append(result.Changes, Change{\n   241ŌåÆ\t\tType:     \"add_step\",\n   242ŌåÆ\t\tFile:     wfRelPath,\n   243ŌåÆ\t\tReason:   lesson.Insight,\n   244ŌåÆ\t\tSnapshot: snapName,\n   245ŌåÆ\t})\n   246ŌåÆ\n   247ŌåÆ\treturn nil\n   248ŌåÆ}\n   249ŌåÆ"}]},"parent_tool_use_id":"toolu_01LT97MYBGAi8gkxnHwbV9DE","session_id":"feb5bdf8-ca69-4cf3-a66e-11041ffe134a","uuid":"90568c3a-2023-4522-aade-617110298543","timestamp":"2026-03-17T14:12:29.642Z"}
