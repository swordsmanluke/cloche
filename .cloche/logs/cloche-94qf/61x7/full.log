RunWorkflowResponse {\n    42ŌåÆ  string run_id = 1;\n    43ŌåÆ}\n    44ŌåÆ\n    45ŌåÆmessage GetStatusRequest {\n    46ŌåÆ  string run_id = 1;\n    47ŌåÆ}\n    48ŌåÆ\n    49ŌåÆmessage GetStatusResponse {\n    50ŌåÆ  string run_id = 1;\n    51ŌåÆ  string workflow_name = 2;\n    52ŌåÆ  string state = 3;\n    53ŌåÆ  string current_step = 4;\n    54ŌåÆ  repeated StepExecutionStatus step_executions = 5;\n    55ŌåÆ  string error_message = 6;\n    56ŌåÆ  string container_id = 7;\n    57ŌåÆ  bool container_alive = 8;\n    58ŌåÆ  string container_dead_since = 9;\n    59ŌåÆ  string title = 10;\n    60ŌåÆ  bool is_host = 11;\n    61ŌåÆ}\n    62ŌåÆ\n    63ŌåÆmessage StepExecutionStatus {\n    64ŌåÆ  string step_name = 1;\n    65ŌåÆ  string result = 2;\n    66ŌåÆ  string started_at = 3;\n    67ŌåÆ  string completed_at = 4;\n    68ŌåÆ}\n    69ŌåÆ\n    70ŌåÆmessage StreamLogsRequest {\n    71ŌåÆ  string run_id = 1;\n    72ŌåÆ  string step_name = 2;\n    73ŌåÆ  string log_type = 3;\n    74ŌåÆ  bool follow = 4;  // When true, stream existing logs then continue tailing new lines (like tail -f).\n    75ŌåÆ                     // Passed via gRPC metadata header \"x-cloche-follow\" until proto is regenerated.\n    76ŌåÆ  int32 limit = 5;  // When > 0, display only the last N lines of output.\n    77ŌåÆ                     // Passed via gRPC metadata header \"x-cloche-limit\" until proto is regenerated.\n    78ŌåÆ}\n    79ŌåÆ\n    80ŌåÆmessage LogEntry {\n    81ŌåÆ  string type = 1;\n    82ŌåÆ  string step_name = 2;\n    83ŌåÆ  string result = 3;\n    84ŌåÆ  string message = 4;\n    85ŌåÆ  string timestamp = 5;\n    86ŌåÆ}\n    87ŌåÆ\n    88ŌåÆmessage StopRunRequest {\n    89ŌåÆ  string run_id = 1;\n    90ŌåÆ}\n    91ŌåÆ\n    92ŌåÆmessage StopRunResponse {}\n    93ŌåÆ\n    94ŌåÆmessage ShutdownRequest {\n    95ŌåÆ  bool force = 1;  // If false, reject shutdown when runs are active.\n    96ŌåÆ}\n    97ŌåÆ\n    98ŌåÆmessage ShutdownResponse {}\n    99ŌåÆ\n   100ŌåÆmessage DeleteContainerRequest {"}]},"parent_tool_use_id":"toolu_01LT97MYBGAi8gkxnHwbV9DE","session_id":"feb5bdf8-ca69-4cf3-a66e-11041ffe134a","uuid":"444a8f2d-6e7d-4348-b94d-ac04941ad9db","timestamp":"2026-03-17T14:12:55.189Z"}
