5ŌåÆfunc (r *Run) SetActiveStepsFromString(s string) {\n   106ŌåÆ\tif s == \"\" {\n   107ŌåÆ\t\tr.ActiveSteps = nil\n   108ŌåÆ\t\treturn\n   109ŌåÆ\t}\n   110ŌåÆ\tr.ActiveSteps = strings.Split(s, \",\")\n   111ŌåÆ}\n   112ŌåÆ\n   113ŌåÆfunc (r *Run) Complete(state RunState) {\n   114ŌåÆ\tr.State = state\n   115ŌåÆ\tr.CompletedAt = time.Now()\n   116ŌåÆ}\n   117ŌåÆ\n   118ŌåÆfunc (r *Run) Fail(msg string) {\n   119ŌåÆ\tr.State = RunStateFailed\n   120ŌåÆ\tr.CompletedAt = time.Now()\n   121ŌåÆ\tr.ErrorMessage = msg\n   122ŌåÆ}\n   123ŌåÆ\n   124ŌåÆ// FindFirstFailedStep returns the name of the first step that produced a\n   125ŌåÆ// failure result (fail/error) in the run's step executions.\n   126ŌåÆ// Returns empty string if no failed step is found.\n   127ŌåÆfunc (r *Run) FindFirstFailedStep() string {\n   128ŌåÆ\tfor _, exec := range r.StepExecutions {\n   129ŌåÆ\t\tif exec.Result == \"fail\" || exec.Result == \"error\" {\n   130ŌåÆ\t\t\treturn exec.StepName\n   131ŌåÆ\t\t}\n   132ŌåÆ\t}\n   133ŌåÆ\treturn \"\"\n   134ŌåÆ}\n   135ŌåÆ\n   136ŌåÆ// stateSeverity returns a severity score for terminal RunStates.\n   137ŌåÆ// Higher values indicate worse outcomes.\n   138ŌåÆfunc stateSeverity(s RunState) int {\n   139ŌåÆ\tswitch s {\n   140ŌåÆ\tcase RunStateSucceeded:\n   141ŌåÆ\t\treturn 0\n   142ŌåÆ\tcase RunStateCancelled:\n   143ŌåÆ\t\treturn 1\n   144ŌåÆ\tcase RunStateFailed:\n   145ŌåÆ\t\treturn 2\n   146ŌåÆ\tdefault:\n   147ŌåÆ\t\treturn -1\n   148ŌåÆ\t}\n   149ŌåÆ}\n   150ŌåÆ\n   151ŌåÆ// WorseState returns the more severe of two terminal RunStates.\n   152ŌåÆ// Failed is worse than cancelled, which is worse than succeeded.\n   153ŌåÆfunc WorseState(a, b RunState) RunState {\n   154ŌåÆ\tif stateSeverity(b) > stateSeverity(a) {\n   155ŌåÆ\t\treturn b\n   156ŌåÆ\t}\n   157ŌåÆ\treturn a\n   158ŌåÆ}\n   159ŌåÆ\n   160ŌåÆ// TaskAggregateStatus computes the aggregate status for a group of runs\n   161ŌåÆ// representing attempts at a task. Active statuses (running, pending) outweigh\n   162ŌåÆ// terminal ones. Among terminal runs, host runs (which represent the full\n   163ŌåÆ// attempt including finalize) take precedence over child container runs.\n   164ŌåÆ// If no host runs exist, the most recently started run determines the result.\n   165ŌåÆfunc TaskAggregateStatus(runs []*Run) RunState {\n   166ŌåÆ\tif len(runs) == 0 {\n   167ŌåÆ\t\treturn RunStatePending\n   168ŌåÆ\t}\n   169ŌåÆ\n   170ŌåÆ\t// Active statuses outweigh terminal ones. Prefer running over pending.\n   171ŌåÆ\thasRunning := false\n   172ŌåÆ\thasPending := false\n   173ŌåÆ\tfor _, r := range runs {\n   174ŌåÆ\t\tswitch r.State {\n   175ŌåÆ\t\tcase RunStateRunning:\n   176ŌåÆ\t\t\thasRunning = true\n   177ŌåÆ\t\tcase RunStatePending:\n   178ŌåÆ\t\t\thasPending = true\n   179ŌåÆ\t\t}\n   180ŌåÆ\t}\n   181ŌåÆ\tif hasRunning {\n   182ŌåÆ\t\treturn RunStateRunning\n   183ŌåÆ\t}\n   184ŌåÆ\tif hasPending {\n   185ŌåÆ\t\treturn RunStatePending\n   186ŌåÆ\t}\n   187ŌåÆ\n   188ŌåÆ\t// All runs are terminal. Prefer the most recently started host run,\n   189ŌåÆ\t// since it reflects the full attempt outcome (including finalize).\n   190ŌåÆ\t// Child container runs start after their parent, so naive most-recent\n   191ŌåÆ\t// selection would incorrectly pick a succeeded child over a failed host.\n   192ŌåÆ\tvar latestHost *Run\n   193ŌåÆ\tvar latest *Run\n   194ŌåÆ\tfor _, r := range runs {\n   195ŌåÆ\t\tif r.IsHost && (latestHost == nil || r.StartedAt.After(latestHost.StartedAt)) {\n   196ŌåÆ\t\t\tlatestHost = r\n   197ŌåÆ\t\t}\n   198ŌåÆ\t\tif latest == nil || r.StartedAt.After(latest.StartedAt) {\n   199ŌåÆ\t\t\tlatest = r\n   200ŌåÆ\t\t}\n   201ŌåÆ\t}\n   202ŌåÆ\tif latestHost != nil {\n   203ŌåÆ\t\treturn latestHost.State\n   204ŌåÆ\t}\n   205ŌåÆ\treturn latest.State\n   206ŌåÆ}\n   207ŌåÆ"}]},"parent_tool_use_id":"toolu_01LT97MYBGAi8gkxnHwbV9DE","session_id":"feb5bdf8-ca69-4cf3-a66e-11041ffe134a","uuid":"527cc8bf-ee66-4005-b263-128dc6592996","timestamp":"2026-03-17T