  144ŌåÆ// runSelectCols is the standard column list for scanning a Run row.\n   145ŌåÆconst runSelectCols = `id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,''), COALESCE(is_host,0), COALESCE(parent_run_id,''), COALESCE(task_id,'')`\n   146ŌåÆ\n   147ŌåÆ// scanRun scans a single row into a *domain.Run.\n   148ŌåÆfunc scanRun(scanner interface{ Scan(...any) error }) (*domain.Run, error) {\n   149ŌåÆ\trun := &domain.Run{}\n   150ŌåÆ\tvar activeSteps, startedAt, completedAt string\n   151ŌåÆ\tvar containerKept, isHost int\n   152ŌåÆ\terr := scanner.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title, &isHost, &run.ParentRunID, &run.TaskID)\n   153ŌåÆ\tif err != nil {\n   154ŌåÆ\t\treturn nil, err\n   155ŌåÆ\t}\n   156ŌåÆ\trun.SetActiveStepsFromString(activeSteps)\n   157ŌåÆ\trun.StartedAt = parseTime(startedAt)\n   158ŌåÆ\trun.CompletedAt = parseTime(completedAt)\n   159ŌåÆ\trun.ContainerKept = containerKept != 0\n   160ŌåÆ\trun.IsHost = isHost != 0\n   161ŌåÆ\treturn run, nil\n   162ŌåÆ}\n   163ŌåÆ\n   164ŌåÆfunc (s *Store) GetRun(ctx context.Context, id string) (*domain.Run, error) {\n   165ŌåÆ\trow := s.db.QueryRowContext(ctx,\n   166ŌåÆ\t\t`SELECT `+runSelectCols+` FROM runs WHERE id = ?`, id)\n   167ŌåÆ\n   168ŌåÆ\trun, err := scanRun(row)\n   169ŌåÆ\tif err == sql.ErrNoRows {\n   170ŌåÆ\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n   171ŌåÆ\t}\n   172ŌåÆ\treturn run, err\n   173ŌåÆ}\n   174ŌåÆ\n   175ŌåÆfunc (s *Store) UpdateRun(ctx context.Context, run *domain.Run) error {\n   176ŌåÆ\t_, err := s.db.ExecContext(ctx,\n   177ŌåÆ\t\t`UPDATE runs SET state = ?, active_steps = ?, started_at = ?, completed_at = ?, error_message = ?, container_id = ?, base_sha = ?, container_kept = ?, title = ?, is_host = ?, parent_run_id = ?, task_id = ? WHERE id = ?`,\n   178ŌåÆ\t\tstring(run.State), run.ActiveStepsString(),\n   179ŌåÆ\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt),\n   180ŌåÆ\t\ttruncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID, run.ID,\n   181ŌåÆ\t)\n   182ŌåÆ\treturn err\n   183ŌåÆ}\n   184ŌåÆ\n   185ŌåÆfunc (s *Store) DeleteRun(ctx context.Context, id string) error {\n   186ŌåÆ\t_, err := s.db.ExecContext(ctx, `DELETE FROM step_executions WHERE run_id = ?`, id)\n   187ŌåÆ\tif err != nil {\n   188ŌåÆ\t\treturn err\n   189ŌåÆ\t}\n   190ŌåÆ\t_, err = s.db.ExecContext(ctx, `DELETE FROM runs WHERE id = ?`, id)\n   191ŌåÆ\treturn err\n   192ŌåÆ}\n   193ŌåÆ\n   194ŌåÆfunc (s *Store) ListRuns(ctx context.Context, since time.Time) ([]*domain.Run, error) {\n   195ŌåÆ\tvar rows *sql.Rows\n   196ŌåÆ\tvar err error\n   197ŌåÆ\tif since.IsZero() {\n   198ŌåÆ\t\trows, err = s.db.QueryContext(ctx,\n   199ŌåÆ\t\t\t`SELECT `+runSelectCols+` FROM runs ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`)\n   200ŌåÆ\t} else {\n   201ŌåÆ\t\trows, err = s.db.QueryContext(ctx,\n   202ŌåÆ\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   203ŌåÆ\t\t\tformatTime(since))\n   204ŌåÆ\t}\n   205ŌåÆ\tif err != nil {\n   206ŌåÆ\t\treturn nil, err\n   207ŌåÆ\t}\n   208ŌåÆ\tdefer rows.Close()\n   209ŌåÆ\treturn scanRuns(rows)\n   210ŌåÆ}\n   211ŌåÆ\n   212ŌåÆ// scanRuns scans all rows into a []*domain.Run slice.\n   213ŌåÆfunc scanRuns(rows *sql.Rows) ([]*domain.Run, error) {\n   214ŌåÆ\tvar runs []*domain.Run\n   215ŌåÆ\tfor rows.Next() {\n   216ŌåÆ\t\trun, err := scanRun(rows)\n   217ŌåÆ\t\tif err != nil {\n   218ŌåÆ\t\t\treturn nil, err\n   219ŌåÆ\t\t}\n   220ŌåÆ\t\truns = append(runs, run)\n   221ŌåÆ\t}\n   222ŌåÆ\treturn runs, rows.Err()\n   223ŌåÆ}\n   224ŌåÆ\n   225ŌåÆfunc (s *Store) ListRunsByProject(ctx context.Context, projectDir string, since time.Time) ([]*domain.Run, error) {\n   226ŌåÆ\tvar rows *sql.Rows\n   227ŌåÆ\tvar err error\n   228ŌåÆ\tif since.IsZero() {\n   229ŌåÆ\t\trows, err = s.db.QueryContext(ctx,\n   230ŌåÆ\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   231ŌåÆ\t\t\tprojectDir)\n   232ŌåÆ\t} else {\n   233ŌåÆ\t\trows, err = s.db.QueryContext(ctx,\n   234ŌåÆ\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? AND started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   235ŌåÆ\t\t\tprojectDir, formatTime(since))\n   236ŌåÆ\t}\n   237ŌåÆ\tif err != nil {\n   238ŌåÆ\t\treturn nil, err\n   239ŌåÆ\t}\n   240ŌåÆ\tdefer rows.Close()\n   241ŌåÆ\treturn scanRuns(rows)\n   242ŌåÆ}\n   243ŌåÆ\n   244ŌåÆfunc (s *Store) ListRunsFiltered(ctx context.Context, filter domain.RunListFilter) ([]*domain.Run, error) {\n   245ŌåÆ\tquery := `SELECT ` + runSelectCols + ` FROM runs WHERE 1=1`\n   246ŌåÆ\tvar args []interface{}\n   247ŌåÆ\n   248ŌåÆ\tif filter.ProjectDir != \"\" {\n   249ŌåÆ\t\tquery += ` AND project_dir = ?`"}]},"parent_tool_use_id":"toolu_01LT97MYBGAi8gkxnHwbV9DE","session_id":"feb5bdf8-ca69-4cf3-a66e-11041ffe134a","uuid":"0cdb6f9d-82dc-40e6-b85f-84bb5fad752b","timestamp":"2026-03-17T14:12:35.330Z"}
