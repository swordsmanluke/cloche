\n   151ŌåÆ\tabsBase := basePath\n   152ŌåÆ\tif !filepath.IsAbs(basePath) {\n   153ŌåÆ\t\tabsBase = filepath.Join(p.ProjectDir, basePath)\n   154ŌåÆ\t}\n   155ŌåÆ\n   156ŌåÆ\tbaseData, err := os.ReadFile(absBase)\n   157ŌåÆ\tif err != nil && !os.IsNotExist(err) {\n   158ŌåÆ\t\treturn fmt.Errorf(\"reading base prompt: %w\", err)\n   159ŌåÆ\t}\n   160ŌåÆ\n   161ŌåÆ\tif err == nil {\n   162ŌåÆ\t\tsnapName := fmt.Sprintf(\"%s-%s-base%s\",\n   163ŌåÆ\t\t\ttime.Now().UTC().Format(\"20060102T150405\"),\n   164ŌåÆ\t\t\tp.StepName,\n   165ŌåÆ\t\t\tfilepath.Ext(basePath),\n   166ŌåÆ\t\t)\n   167ŌåÆ\t\tif err := os.WriteFile(filepath.Join(snapDir, snapName), baseData, 0644); err != nil {\n   168ŌåÆ\t\t\treturn fmt.Errorf(\"writing snapshot: %w\", err)\n   169ŌåÆ\t\t}\n   170ŌåÆ\t}\n   171ŌåÆ\n   172ŌåÆ\t// Copy winner content to base path.\n   173ŌåÆ\twinnerContent, err := p.GetContent(winnerID)\n   174ŌåÆ\tif err != nil {\n   175ŌåÆ\t\treturn fmt.Errorf(\"reading winner content: %w\", err)\n   176ŌåÆ\t}\n   177ŌåÆ\tif err := os.MkdirAll(filepath.Dir(absBase), 0755); err != nil {\n   178ŌåÆ\t\treturn fmt.Errorf(\"creating base dir: %w\", err)\n   179ŌåÆ\t}\n   180ŌåÆ\tif err := os.WriteFile(absBase, []byte(winnerContent), 0644); err != nil {\n   181ŌåÆ\t\treturn fmt.Errorf(\"writing promoted content to base: %w\", err)\n   182ŌåÆ\t}\n   183ŌåÆ\n   184ŌåÆ\t// Update statuses: winner -> promoted, others -> archived.\n   185ŌåÆ\tfor i := range all {\n   186ŌåÆ\t\tif all[i].Status != candidateStatusActive {\n   187ŌåÆ\t\t\tcontinue\n   188ŌåÆ\t\t}\n   189ŌåÆ\t\tif all[i].ID == winnerID {\n   190ŌåÆ\t\t\tall[i].Status = candidateStatusPromoted\n   191ŌåÆ\t\t} else {\n   192ŌåÆ\t\t\tall[i].Status = candidateStatusArchived\n   193ŌåÆ\t\t}\n   194ŌåÆ\t}\n   195ŌåÆ\n   196ŌåÆ\treturn p.writeMeta(all)\n   197ŌåÆ}\n   198ŌåÆ\n   199ŌåÆ// RecordAssignment tracks which candidate was used for a workflow run.\n   200ŌåÆfunc (p *Population) RecordAssignment(runID, candidateID string) error {\n   201ŌåÆ\tdir := p.populationDir()\n   202ŌåÆ\tif err := os.MkdirAll(dir, 0755); err != nil {\n   203ŌåÆ\t\treturn fmt.Errorf(\"creating population dir: %w\", err)\n   204ŌåÆ\t}\n   205ŌåÆ\n   206ŌåÆ\ta := Assignment{\n   207ŌåÆ\t\tRunID:       runID,\n   208ŌåÆ\t\tCandidateID: candidateID,\n   209ŌåÆ\t\tAssignedAt:  time.Now().UTC().Format(time.RFC3339),\n   210ŌåÆ\t}\n   211ŌåÆ\n   212ŌåÆ\tdata, err := json.Marshal(a)\n   213ŌåÆ\tif err != nil {\n   214ŌåÆ\t\treturn fmt.Errorf(\"marshaling assignment: %w\", err)\n   215ŌåÆ\t}\n   216ŌåÆ\n   217ŌåÆ\tf, err := os.OpenFile(p.assignmentsPath(), os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644)\n   218ŌåÆ\tif err != nil {\n   219ŌåÆ\t\treturn fmt.Errorf(\"opening assignments file: %w\", err)\n   220ŌåÆ\t}\n   221ŌåÆ\tdefer f.Close()\n   222ŌåÆ\n   223ŌåÆ\tif _, err := f.Write(append(data, '\\n')); err != nil {\n   224ŌåÆ\t\treturn fmt.Errorf(\"writing assignment: %w\", err)\n   225ŌåÆ\t}\n   226ŌåÆ\n   227ŌåÆ\treturn nil\n   228ŌåÆ}\n   229ŌåÆ\n   230ŌåÆ// GetAssignment returns the candidate ID assigned to a run, or empty string if none.\n   231ŌåÆfunc (p *Population) GetAssignment(runID string) (string, error) {\n   232ŌåÆ\tdata, err := os.ReadFile(p.assignmentsPath())\n   233ŌåÆ\tif os.IsNotExist(err) {\n   234ŌåÆ\t\treturn \"\", nil\n   235ŌåÆ\t}\n   236ŌåÆ\tif err != nil {\n   237ŌåÆ\t\treturn \"\", fmt.Errorf(\"reading assignments: %w\", err)\n   238ŌåÆ\t}\n   239ŌåÆ\n   240ŌåÆ\tfor _, line := range strings.Split(strings.TrimSpace(string(data)), \"\\n\") {\n   241ŌåÆ\t\tline = strings.TrimSpace(line)\n   242ŌåÆ\t\tif line == \"\" {\n   243ŌåÆ\t\t\tcontinue\n   244ŌåÆ\t\t}\n   245ŌåÆ\t\tvar a Assignment\n   246ŌåÆ\t\tif err := json.Unmarshal([]byte(line), &a); err != nil {\n   247ŌåÆ\t\t\tcontinue\n   248ŌåÆ\t\t}\n   249ŌåÆ\t\tif a.RunID == runID {\n   250ŌåÆ\t\t\treturn a.CandidateID, nil\n   251ŌåÆ\t\t}\n   252ŌåÆ\t}\n   253ŌåÆ\n   254ŌåÆ\treturn \"\", nil\n   255ŌåÆ}\n   256ŌåÆ\n   257ŌåÆ// readMeta reads all entries