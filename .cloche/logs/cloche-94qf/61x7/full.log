os.MkdirAll(snapDir, 0755); err != nil {\n    49ŌåÆ\t\treturn \"\", fmt.Errorf(\"creating snapshots dir: %w\", err)\n    50ŌåÆ\t}\n    51ŌåÆ\n    52ŌåÆ\tbasename := filepath.Base(relativePath)\n    53ŌåÆ\tsnapName := fmt.Sprintf(\"%s-%s\", time.Now().Format(\"20060102T150405\"), basename)\n    54ŌåÆ\tdstPath := filepath.Join(snapDir, snapName)\n    55ŌåÆ\n    56ŌåÆ\tsrc, err := os.Open(srcPath)\n    57ŌåÆ\tif err != nil {\n    58ŌåÆ\t\treturn \"\", fmt.Errorf(\"opening source for snapshot: %w\", err)\n    59ŌåÆ\t}\n    60ŌåÆ\tdefer src.Close()\n    61ŌåÆ\n    62ŌåÆ\tdst, err := os.Create(dstPath)\n    63ŌåÆ\tif err != nil {\n    64ŌåÆ\t\treturn \"\", fmt.Errorf(\"creating snapshot file: %w\", err)\n    65ŌåÆ\t}\n    66ŌåÆ\tdefer dst.Close()\n    67ŌåÆ\n    68ŌåÆ\tif _, err := io.Copy(dst, src); err != nil {\n    69ŌåÆ\t\treturn \"\", fmt.Errorf(\"copying to snapshot: %w\", err)\n    70ŌåÆ\t}\n    71ŌåÆ\n    72ŌåÆ\treturn snapName, nil\n    73ŌåÆ}\n    74ŌåÆ\n    75ŌåÆ// Restore copies a snapshot back to the original file location.\n    76ŌåÆfunc (a *AuditLogger) Restore(relativePath, snapName string) error {\n    77ŌåÆ\tsnapDir := filepath.Join(a.ProjectDir, \".cloche\", \"evolution\", \"snapshots\")\n    78ŌåÆ\tsrcPath := filepath.Join(snapDir, snapName)\n    79ŌåÆ\tdstPath := filepath.Join(a.ProjectDir, relativePath)\n    80ŌåÆ\n    81ŌåÆ\tdata, err := os.ReadFile(srcPath)\n    82ŌåÆ\tif err != nil {\n    83ŌåÆ\t\treturn fmt.Errorf(\"reading snapshot %s: %w\", snapName, err)\n    84ŌåÆ\t}\n    85ŌåÆ\n    86ŌåÆ\tif err := os.WriteFile(dstPath, data, 0644); err != nil {\n    87ŌåÆ\t\treturn fmt.Errorf(\"restoring snapshot to %s: %w\", relativePath, err)\n    88ŌåÆ\t}\n    89ŌåÆ\n    90ŌåÆ\treturn nil\n    91ŌåÆ}\n    92ŌåÆ\n    93ŌåÆ// KnowledgePath returns the JSONL knowledge base path for a workflow.\n    94ŌåÆfunc (a *AuditLogger) KnowledgePath(workflowName string) string {\n    95ŌåÆ\treturn filepath.Join(a.ProjectDir, \".cloche\", \"evolution\", \"knowledge\", workflowName+\".jsonl\")\n    96ŌåÆ}\n    97ŌåÆ\n    98ŌåÆ// readKnowledge reads existing lessons from the JSONL knowledge base.\n    99ŌåÆfunc readKnowledge(path string) ([]Lesson, error) {\n   100ŌåÆ\tdata, err := os.ReadFile(path)\n   101ŌåÆ\tif os.IsNotExist(err) {\n   102ŌåÆ\t\treturn nil, nil\n   103ŌåÆ\t}\n   104ŌåÆ\tif err != nil {\n   105ŌåÆ\t\treturn nil, err\n   106ŌåÆ\t}\n   107ŌåÆ\n   108ŌåÆ\tvar lessons []Lesson\n   109ŌåÆ\tfor _, line := range strings.Split(strings.TrimSpace(string(data)), \"\\n\") {\n   110ŌåÆ\t\tline = strings.TrimSpace(line)\n   111ŌåÆ\t\tif line == \"\" {\n   112ŌåÆ\t\t\tcontinue\n   113ŌåÆ\t\t}\n   114ŌåÆ\t\tvar l Lesson\n   115ŌåÆ\t\tif err := json.Unmarshal([]byte(line), &l); err != nil {\n   116ŌåÆ\t\t\tcontinue // skip malformed lines\n   117ŌåÆ\t\t}\n   118ŌåÆ\t\tlessons = append(lessons, l)\n   119ŌåÆ\t}\n   120ŌåÆ\treturn lessons, nil\n   121ŌåÆ}\n   122ŌåÆ\n   123ŌåÆ// writeKnowledge writes lessons as JSONL, one per line.\n   124ŌåÆfunc writeKnowledge(path string, lessons []Lesson) error {\n   125ŌåÆ\tif err := os.MkdirAll(filepath.Dir(path), 0755); err != nil {\n   126ŌåÆ\t\treturn fmt.Errorf(\"creating knowledge dir: %w\", err)\n   127ŌåÆ\t}\n   128ŌåÆ\n   129ŌåÆ\tvar sb strings.Builder\n   130ŌåÆ\tfor _, l := range lessons {\n   131ŌåÆ\t\tdata, err := json.Marshal(l)\n   132ŌåÆ\t\tif err != nil {\n   133ŌåÆ\t\t\tcontinue\n   134ŌåÆ\t\t}\n   135ŌåÆ\t\tsb.Write(data)\n   136ŌåÆ\t\tsb.WriteByte('\\n')\n   137ŌåÆ\t}\n   138ŌåÆ\treturn os.WriteFile(path, []byte(sb.String()), 0644)\n   139ŌåÆ}\n   140ŌåÆ\n   141ŌåÆ// UpdateKnowledge merges lessons into the knowledge base with deduplication\n   142ŌåÆ// and optional pruning when MaxPromptBullets is exceeded.\n   143ŌåÆfunc (a *AuditLogger) UpdateKnowledge(workflowName string, lessons []Lesson) error {\n   144ŌåÆ\tkbPath := a.KnowledgePath(workflowName)\n   145ŌåÆ\n   146ŌåÆ\texisting, err := readKnowledge(kbPath)\n   147ŌåÆ\tif err != nil {\n   148ŌåÆ\t\treturn fmt.Errorf(\"reading knowledge base: %w\", err)\n   149ŌåÆ\t}\n   150ŌåÆ\n   151ŌåÆ\t// Build index of existing lesson IDs\n   152ŌåÆ\tidIndex := make(map[string]int, len(existing))\n   153ŌåÆ\tfor i, l := range existing {\n   154ŌåÆ\t\tidIndex[l.ID] = i\n   155ŌåÆ\t}\n   156ŌåÆ\n   157ŌåÆ\t// Merge: update in place if ID exists, append if new\n   158ŌåÆ\tfor _, l := range lessons {\n   159ŌåÆ\t\tif idx, ok := idIndex[l.ID]; ok {\n   160ŌåÆ\t\t\texisting[idx] = l // update existing entry\n   161ŌåÆ\t\t} else {\n   162ŌåÆ\t\t\texisting = append(existing, l)\n   163ŌåÆ\t\t\tidIndex[l.ID] = len(existing) - 1\n   164ŌåÆ\t\t}\n   165ŌåÆ\t}\n   166ŌåÆ\n   167ŌåÆ\t// Prune oldest entries if MaxPromptBullets is set and exceeded\n   168ŌåÆ\tif a.MaxPromptBullets > 0 && len(existing) > a.MaxPromptBullets {\n   169ŌåÆ\t\texisting = existing[len(existing)-a.MaxPromptBullets:]\n   170ŌåÆ\t}\n   171ŌåÆ\n   172ŌåÆ\treturn writeKnowledge(kbPath, existing)\n   173ŌåÆ}\n   174ŌåÆ"}]},"parent_tool_use_id":null,"session_id":"feb5bdf8-ca69-4cf3-a66e-11041ffe134a","uuid":"414470df-4b07-4c8a-b9b7-21f135e0e5b6","timestamp":"2026-03-17T14:13:23.473Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/audit.go","content":"package evolution\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n)\n\n// AuditLogger records evolution actions and manages snapshots.\ntype AuditLogger struct {\n\tProjectDir       string\n\tMaxPromptBullets int // 0 means unlimited\n}\n\n// Log appends an EvolutionResult as a JSONL entry.\nfunc (a *AuditLogger) Log(result *EvolutionResult) error {\n\tlogPath := filepath.Join(a.ProjectDir, \".cloche\", \"evolution\", \"log.jsonl\")\n\tif err := os.MkdirAll(filepath.Dir(logPath), 0755); err != nil {\n\t\treturn fmt.Errorf(\"creating evolution log dir: %w\", err)\n\t}\n\n\tf, err := os.OpenFile(logPath, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"opening evolution log: %w\", err)\n\t}\n\tdefer f.Close()\n\n\tdata, err := json.Marshal(result)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"marshaling evolution result: %w\", err)\n\t}\n\n\tif _, err := f.Write(append(data, '\\n')); err != nil {\n\t\treturn fmt.Errorf(\"writing evolution log: %w\", err)\n\t}\n\n\treturn nil\n}\n\n// Snapshot copies a file to the snapshots directory and returns the snapshot filename.\nfunc (a *AuditLogger) Snapshot(relativePath string) (string, error) {\n\tsrcPath := filepath.Join(a.ProjectDir, relativePath)\n\tsnapDir := filepath.Join(a.ProjectDir, \".cloche\", \"evolution\", \"snapshots\")\n\tif err := os.MkdirAll(snapDir, 0755); err != nil {\n\t\treturn \"\", fmt.Errorf(\"creating snapshots dir: %w\", err)\n\t}\n\n\tbasename := filepath.Base(relativePath)\n\tsnapName := fmt.Sprintf(\"%s-%s\", time.Now().Format(\"20060102T150405\"), basename)\n\tdstPath := filepath.Join(snapDir, snapName)\n\n\tsrc, err := os.Open(srcPath)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"opening source for snapshot: %w\", err)\n\t}\n\tdefer src.Close()\n\n\tdst, err := os.Create(dstPath)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"creating snapshot file: %w\", err)\n\t}\n\tdefer dst.Close()\n\n\tif _, err := io.Copy(dst, src); err != nil {\n\t\treturn \"\", fmt.Errorf(\"copying to snapshot: %w\", err)\n\t}\n\n\treturn snapName, nil\n}\n\n// Restore copies a snapshot back to the original file location.\nfunc (a *AuditLogger) Restore(relativePath, snapName string) error {\n\tsnapDir := filepath.Join(a.ProjectDir, \".cloche\", \"evolution\", \"snapshots\")\n\tsrcPath := filepath.Join(snapDir, snapName)\n\tdstPath := filepath.Join(a.ProjectDir, relativePath)\n\n\tdata, err := os.ReadFile(srcPath)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"reading snapshot %s: %w\", snapName, err)\n\t}\n\n\tif err := os.WriteFile(dstPath, data, 0644); err != nil {\n\t\treturn fmt.Errorf(\"restoring snapshot to %s: %w\", relativePath, err)\n\t}\n\n\treturn nil\n}\n\n// KnowledgePath returns the JSONL knowledge base path for a workflow.\nfunc (a *AuditLogger) KnowledgePath(workflowName string) string {\n\treturn filepath.Join(a.ProjectDir, \".cloche\", \"evolution\", \"knowledge\", workflowName+\".jsonl\")\n}\n\n// readKnowledge reads existing lessons from the JSONL knowledge base.\nfunc readKnowledge(path string) ([]Lesson, error) {\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn nil, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar lessons []Lesson\n\tfor _, line := range strings.Split(strings.TrimSpace(string(data)), \"\\n\") {\n\t\tline = strings.TrimSpace(line)\n\t\tif line == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tvar l Lesson\n\t\tif err := json.Unmarshal([]byte(line), &l); err != nil {\n\t\t\tcontinue // skip malformed lines\n\t\t}\n\t\tlessons = append(lessons, l)\n\t}\n\treturn lessons, nil\n}\n\n// writeKnowledge writes lessons as JSONL, one per line.\nfunc writeKnowledge(path string, lessons []Lesson) error {\n\tif err := os.MkdirAll(filepath.Dir(path), 0755); err != nil {\n\t\treturn fmt.Errorf(\"creating knowledge dir: %w\", err)\n\t}\n\n\tvar sb strings.Builder\n\tfor _, l := range lessons {\n\t\tdata, err := json.Marshal(l)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tsb.Write(data)\n\t\tsb.WriteByte('\\n')\n\t}\n\treturn os.WriteFile(path, []byte(sb.String()), 0644)\n}\n\n// UpdateKnowledge merges lessons into the knowledge base with deduplication\n// and optional pruning when MaxPromptBullets is exceeded.\nfunc (a *AuditLogger) UpdateKnowledge(workflowName string, lessons []Lesson) error {\n\tkbPath := a.KnowledgePath(workflowName)\n\n\texisting, err := readKnowledge(kbPath)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"reading knowledge base: %w\", err)\n\t}\n\n\t// Build index of existing lesson IDs\n\tidIndex := make(map[string]int, len(existing))\n\tfor i, l := range existing {\n\t\tidIndex[l.ID] = i\n\t}\n\n\t// Merge: update in place if ID exists, append if new\n\tfor _, l := range lessons {\n\t\tif idx, ok := idIndex[l.ID]; ok {\n\t\t\texisting[idx] = l // update existing entry\n\t\t} else {\n\t\t\texisting = append(existing, l)\n\t\t\tidIndex[l.ID] = len(existing) - 1\n\t\t}\n\t}\n\n\t// Prune oldest entries if MaxPromptBullets is set and exceeded\n\tif a.MaxPromptBullets > 0 && len(existing) > a.MaxPromptBullets {\n\t\texisting = existing[len(existing)-a.MaxPromptBullets:]\n\t}\n\n\treturn writeKnowledge(kbPath, existing)\n}\n","numLines":174,"startLine":1,"totalLines":174}}}
