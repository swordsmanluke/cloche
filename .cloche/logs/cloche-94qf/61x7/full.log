t.Context, runID, fileType string) ([]*LogFileEntry, error)\n    42ŌåÆ}\n    43ŌåÆ\n    44ŌåÆtype EvolutionEntry struct {\n    45ŌåÆ\tID             string\n    46ŌåÆ\tProjectDir     string\n    47ŌåÆ\tWorkflowName   string\n    48ŌåÆ\tTriggerRunID   string\n    49ŌåÆ\tCreatedAt      time.Time\n    50ŌåÆ\tClassification string\n    51ŌåÆ\tChangesJSON    string\n    52ŌåÆ\tKnowledgeDelta string\n    53ŌåÆ}\n    54ŌåÆ\n    55ŌåÆtype EvolutionStore interface {\n    56ŌåÆ\tSaveEvolution(ctx context.Context, entry *EvolutionEntry) error\n    57ŌåÆ\tGetLastEvolution(ctx context.Context, projectDir, workflowName string) (*EvolutionEntry, error)\n    58ŌåÆ\tListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error)\n    59ŌåÆ}\n    60ŌåÆ"}]},"parent_tool_use_id":"toolu_01LT97MYBGAi8gkxnHwbV9DE","session_id":"feb5bdf8-ca69-4cf3-a66e-11041ffe134a","uuid":"a599bcf1-b89b-4a65-80f7-8430bf4fa310","timestamp":"2026-03-17T14:12:26.646Z"}
