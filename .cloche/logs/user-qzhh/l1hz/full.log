[2026-03-08T04:14:16Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TinLRchmSuT1R67EtXeKtS","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"os/exec\"\n    14→\t\"path/filepath\"\n    15→\t\"regexp\"\n    16→\t\"sort\"\n    17→\t\"strconv\"\n    18→\t\"strings\"\n    19→\t\"time\"\n    20→\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→)\n    26→\n    27→// HandlerOption configures optional Handler dependencies.\n    28→type HandlerOption func(*Handler)\n    29→\n    30→// WithContainerLogger sets the container runtime for fetching live logs.\n    31→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32→\treturn func(h *Handler) { h.container = c }\n    33→}\n    34→\n    35→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36→func WithContainerManager(c ContainerManager) HandlerOption {\n    37→\treturn func(h *Handler) { h.container = c }\n    38→}\n    39→\n    40→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42→\treturn func(h *Handler) { h.logBroadcast = b }\n    43→}\n    44→\n    45→// WithLogStore sets the log store for indexed log file lookups.\n    46→func WithLogStore(ls ports.LogStore) HandlerOption {\n    47→\treturn func(h *Handler) { h.logStore = ls }\n    48→}\n    49→\n    50→// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    51→func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    52→\treturn func(h *Handler) { h.orchestrateFn = fn }\n    53→}\n    54→\n    55→// OrchestratorController provides per-project orchestrator control.\n    56→type OrchestratorController interface {\n    57→\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    58→\tSetEnabled(dir string, enabled bool)\n    59→\tSetConcurrency(dir string, concurrency int)\n    60→}\n    61→\n    62→// WithOrchestrator sets the orchestrator controller for project-level control.\n    63→func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    64→\treturn func(h *Handler) { h.orchestrator = oc }\n    65→}\n    66→\n    67→//go:embed templates/*.html static/*\n    68→var content embed.FS\n    69→\n    70→// Handler serves the web dashboard.\n    71→// ContainerLogger can retrieve logs from a container by ID.\n    72→type ContainerLogger interface {\n    73→\tLogs(ctx context.Context, containerID string) (string, error)\n    74→}\n    75→\n    76→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    77→type ContainerManager interface {\n    78→\tContainerLogger\n    79→\tRemove(ctx context.Context, containerID string) error\n    80→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    81→}\n    82→\n    83→type Handler struct {\n    84→\tstore         ports.RunStore\n    85→\tcaptures      ports.CaptureStore\n    86→\tlogStore      ports.LogStore\n    87→\tcontainer     ContainerLogger\n    88→\tlogBroadcast  *logstream.Broadcaster\n    89→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    90→\torchestrator  OrchestratorController\n    91→\tpages         map[string]*template.Template\n    92→\tmux           *http.ServeMux\n    93→}\n    94→\n    95→// NewHandler creates a web dashboard handler.\n    96→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    97→\tfuncMap := template.FuncMap{\n    98→\t\t\"stateColor\":       stateColor,\n    99→\t\t\"healthColor\":      healthColor,\n   100→\t\t\"formatTime\":       formatTime,\n   101→\t\t\"formatDuration\":   formatDuration,\n   102→\t\t\"truncate\":         truncate,\n   103→\t\t\"shortContainerID\": shortContainerID,\n   104→\t}\n   105→\n   106→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   107→\tif err != nil {\n   108→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   109→\t}\n   110→\n   111→\tpages := map[string]*template.Template{}\n   112→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   113→\t\tclone, err := base.Clone()\n   114→\t\tif err != nil {\n   115→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   116→\t\t}\n   117→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   118→\t\tif err != nil {\n   119→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   120→\t\t}\n   121→\t\tpages[page] = clone\n   122→\t}\n   123→\n   124→\th := &Handler{\n   125→\t\tstore:    store,\n   126→\t\tcaptures: captures,\n   127→\t\tpages:    pages,\n   128→\t\tmux:      http.NewServeMux(),\n   129→\t}\n   130→\tfor _, opt := range opts {\n   131→\t\topt(h)\n   132→\t}\n   133→\n   134→\tstaticFS, err := fs.Sub(content, \"static\")\n   135→\tif err != nil {\n   136→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   137→\t}\n   138→\n   139→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   140→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   141→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   142→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRunsList)\n   143→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   144→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   145→\th.mux.HandleFunc(\"GET /api/projects/{name}/runs\", h.handleAPIProjectRuns)\n   146→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   147→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   148→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   149→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   150→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   151→\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   152→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   153→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   154→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   155→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   156→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   157→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   158→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   159→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   160→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   161→\n   162→\treturn h, nil\n   163→}\n   164→\n   165→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   166→\th.mux.ServeHTTP(w, r)\n   167→}\n   168→\n   169→// --- HTML handlers ---\n   170→\n   171→// projectOverviewEntry holds data for a single project card on the landing page.\n   172→type projectOverviewEntry struct {\n   173→\tDir         string\n   174→\tLabel       string\n   175→\tHealth      domain.HealthResult\n   176→\tRecentRuns  []recentRunDot\n   177→\tActiveCount int\n   178→}\n   179→\n   180→// recentRunDot is a minimal representation of a run for the mini history display.\n   181→type recentRunDot struct {\n   182→\tID    string\n   183→\tState string\n   184→}\n   185→\n   186→const healthWindowSize = 10\n   187→\n   188→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   189→\tprojects, _ := h.store.ListProjects(r.Context())\n   190→\tlabels := projectLabels(projects)\n   191→\n   192→\tvar entries []projectOverviewEntry\n   193→\tfor _, dir := range projects {\n   194→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   195→\t\tif err != nil {\n   196→\t\t\tcontinue\n   197→\t\t}\n   198→\n   199→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   200→\t\trunValues := make([]domain.Run, len(runs))\n   201→\t\tfor i, rr := range runs {\n   202→\t\t\trunValues[i] = *rr\n   203→\t\t}\n   204→\n   205→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   206→\n   207→\t\t// Take the last N runs for the mini history (most recent first).\n   208→\t\tn := healthWindowSize\n   209→\t\tif n > len(runs) {\n   210→\t\t\tn = len(runs)\n   211→\t\t}\n   212→\t\tdots := make([]recentRunDot, n)\n   213→\t\tfor i := 0; i < n; i++ {\n   214→\t\t\tdots[i] = recentRunDot{\n   215→\t\t\t\tID:    runs[i].ID,\n   216→\t\t\t\tState: string(runs[i].State),\n   217→\t\t\t}\n   218→\t\t}\n   219→\n   220→\t\tvar activeCount int\n   221→\t\tfor _, rr := range runs {\n   222→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   223→\t\t\t\tactiveCount++\n   224→\t\t\t}\n   225→\t\t}\n   226→\n   227→\t\tentries = append(entries, projectOverviewEntry{\n   228→\t\t\tDir:         dir,\n   229→\t\t\tLabel:       labels[dir],\n   230→\t\t\tHealth:      health,\n   231→\t\t\tRecentRuns:  dots,\n   232→\t\t\tActiveCount: activeCount,\n   233→\t\t})\n   234→\t}\n   235→\n   236→\tsort.Slice(entries, func(i, j int) bool {\n   237→\t\treturn entries[i].Label < entries[j].Label\n   238→\t})\n   239→\n   240→\tdata := map[string]any{\n   241→\t\t\"Title\":    \"Projects\",\n   242→\t\t\"Projects\": entries,\n   243→\t}\n   244→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   245→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   246→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   247→\t}\n   248→}\n   249→\n   250→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   251→\truns, err := h.store.ListRuns(r.Context(), time.Time{})\n   252→\tif err != nil {\n   253→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   254→\t\treturn\n   255→\t}\n   256→\n   257→\tprojects, _ := h.store.ListProjects(r.Context())\n   258→\tlabels := projectLabels(projects)\n   259→\n   260→\t// Count retained containers per project\n   261→\tcontainerCounts := map[string]int{}\n   262→\tfor _, run := range runs {\n   263→\t\tif run.ContainerKept {\n   264→\t\t\tcontainerCounts[run.ProjectDir]++\n   265→\t\t}\n   266→\t}\n   267→\n   268→\tvar projectList []projectEntry\n   269→\tfor _, dir := range projects {\n   270→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   271→\t}\n   272→\tsort.Slice(projectList, func(i, j int) bool {\n   273→\t\treturn projectList[i].Label < projectList[j].Label\n   274→\t})\n   275→\n   276→\tdata := map[string]any{\n   277→\t\t\"Title\":         \"Runs\",\n   278→\t\t\"Runs\":          runs,\n   279→\t\t\"Projects\":      projectList,\n   280→\t\t\"ProjectFilter\": \"\",\n   281→\t\t\"ProjectLabels\": labels,\n   282→\t\t\"ProjectLabel\":  \"\",\n   283→\t}\n   284→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   285→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   286→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   287→\t}\n   288→}\n   289→\n   290→func (h *Handler) handleProjectRunsList(w http.ResponseWriter, r *http.Request) {\n   291→\tdir, label, ok := h.resolveProjectDir(w, r)\n   292→\tif !ok {\n   293→\t\treturn\n   294→\t}\n   295→\n   296→\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   297→\tif err != nil {\n   298→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   299→\t\treturn\n   300→\t}\n   301→\n   302→\tprojects, _ := h.store.ListProjects(r.Context())\n   303→\tlabels := projectLabels(projects)\n   304→\n   305→\t// Count retained containers per project\n   306→\tcontainerCounts := map[string]int{}\n   307→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   308→\tfor _, run := range allRuns {\n   309→\t\tif run.ContainerKept {\n   310→\t\t\tcontainerCounts[run.ProjectDir]++\n   311→\t\t}\n   312→\t}\n   313→\n   314→\tvar projectList []projectEntry\n   315→\tfor _, dir := range projects {\n   316→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   317→\t}\n   318→\tsort.Slice(projectList, func(i, j int) bool {\n   319→\t\treturn projectList[i].Label < projectList[j].Label\n   320→\t})\n   321→\n   322→\tdata := map[string]any{\n   323→\t\t\"Title\":         label + \" — Runs\",\n   324→\t\t\"Runs\":          runs,\n   325→\t\t\"Projects\":      projectList,\n   326→\t\t\"ProjectFilter\": dir,\n   327→\t\t\"ProjectLabels\": labels,\n   328→\t\t\"ProjectLabel\":  label,\n   329→\t}\n   330→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   331→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   332→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   333→\t}\n   334→}\n   335→\n   336→// stepEntry is a merged view of a step execution for the template.\n   337→type stepEntry struct {\n   338→\tIndex     int\n   339→\tStepName  string\n   340→\tResult    string\n   341→\tStartedAt time.Time\n   342→\tDuration  string\n   343→}\n   344→\n   345→// mergeCaptures collapses started/completed capture pairs into single entries.\n   346→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   347→\tvar entries []stepEntry\n   348→\t// Track pending started rows by step name (LIFO for retries)\n   349→\tpending := map[string]*domain.StepExecution{}\n   350→\n   351→\tfor _, c := range caps {\n   352→\t\tif c.Result == \"\" {\n   353→\t\t\t// step_started row\n   354→\t\t\tpending[c.StepName] = c\n   355→\t\t\tcontinue\n   356→\t\t}\n   357→\t\t// step_completed row — merge with pending started if available\n   358→\t\tstartedAt := c.StartedAt\n   359→\t\tif started := pending[c.StepName]; started != nil {\n   360→\t\t\tstartedAt = started.StartedAt\n   361→\t\t\tdelete(pending, c.StepName)\n   362→\t\t}\n   363→\t\tentries = append(entries, stepEntry{\n   364→\t\t\tIndex:     len(entries),\n   365→\t\t\tStepName:  c.StepName,\n   366→\t\t\tResult:    c.Result,\n   367→\t\t\tStartedAt: startedAt,\n   368→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   369→\t\t})\n   370→\t}\n   371→\n   372→\t// Append any started-but-not-completed steps (still running)\n   373→\tfor _, c := range caps {\n   374→\t\tif c.Result == \"\" {\n   375→\t\t\tif _, used := pending[c.StepName]; !used {\n   376→\t\t\t\tcontinue\n   377→\t\t\t}\n   378→\t\t\tentries = append(entries, stepEntry{\n   379→\t\t\t\tIndex:     len(entries),\n   380→\t\t\t\tStepName:  c.StepName,\n   381→\t\t\t\tStartedAt: c.StartedAt,\n   382→\t\t\t})\n   383→\t\t\tdelete(pending, c.StepName)\n   384→\t\t}\n   385→\t}\n   386→\n   387→\treturn entries\n   388→}\n   389→\n   390→// containerState inspects the container for a run and returns one of:\n   391→//   - \"running\"   – container exists and is running\n   392→//   - \"stopped\"   – container exists, not running, not kept\n   393→//   - \"available\" – container exists, not running, kept (can be deleted)\n   394→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   395→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   396→\tif run.ContainerID == \"\" {\n   397→\t\treturn \"removed\"\n   398→\t}\n   399→\tmgr, ok := h.container.(ContainerManager)\n   400→\tif !ok {\n   401→\t\treturn \"removed\"\n   402→\t}\n   403→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   404→\tif err != nil {\n   405→\t\treturn \"removed\"\n   406→\t}\n   407→\tif status.Running {\n   408→\t\treturn \"running\"\n   409→\t}\n   410→\tif run.ContainerKept {\n   411→\t\treturn \"available\"\n   412→\t}\n   413→\treturn \"stopped\"\n   414→}\n   415→\n   416→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   417→\tid := r.PathValue(\"id\")\n   418→\n   419→\trun, err := h.store.GetRun(r.Context(), id)\n   420→\tif err != nil {\n   421→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   422→\t\treturn\n   423→\t}\n   424→\n   425→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   426→\tif err != nil {\n   427→\t\tcaps = nil // non-fatal\n   428→\t}\n   429→\n   430→\tsteps := mergeCaptures(caps)\n   431→\n   432→\tdata := map[string]any{\n   433→\t\t\"Title\":          \"Run \" + run.ID,\n   434→\t\t\"Run\":            run,\n   435→\t\t\"Steps\":          steps,\n   436→\t\t\"Page\":           \"detail\",\n   437→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   438→\t}\n   439→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   440→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   441→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   442→\t}\n   443→}\n   444→\n   445→// --- JSON API handlers ---\n   446→\n   447→type apiRun struct {\n   448→\tID           string `json:\"id\"`\n   449→\tWorkflowName string `json:\"workflow_name\"`\n   450→\tProjectDir   string `json:\"project_dir\"`\n   451→\tProjectLabel string `json:\"project_label\"`\n   452→\tState        string `json:\"state\"`\n   453→\tStartedAt    string `json:\"started_at\"`\n   454→\tCompletedAt  string `json:\"completed_at\"`\n   455→\tContainerID  string `json:\"container_id\"`\n   456→\tErrorMessage string `json:\"error_message\"`\n   457→}\n   458→\n   459→type apiStep struct {\n   460→\tStepName    string `json:\"step_name\"`\n   461→\tResult      string `json:\"result\"`\n   462→\tStartedAt   string `json:\"started_at\"`\n   463→\tCompletedAt string `json:\"completed_at\"`\n   464→\tDuration    string `json:\"duration\"`\n   465→}\n   466→\n   467→type apiRunDetail struct {\n   468→\tapiRun\n   469→\tContainerState string    `json:\"container_state\"`\n   470→\tSteps          []apiStep `json:\"steps\"`\n   471→}\n   472→\n   473→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   474→\treturn apiRun{\n   475→\t\tID:           r.ID,\n   476→\t\tWorkflowName: r.WorkflowName,\n   477→\t\tProjectDir:   r.ProjectDir,\n   478→\t\tProjectLabel: labels[r.ProjectDir],\n   479→\t\tState:        string(r.State),\n   480→\t\tStartedAt:    formatTime(r.StartedAt),\n   481→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   482→\t\tContainerID:  r.ContainerID,\n   483→\t\tErrorMessage: r.ErrorMessage,\n   484→\t}\n   485→}\n   486→\n   487→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   488→\truns, err := h.store.ListRuns(r.Context(), time.Time{})\n   489→\tif err != nil {\n   490→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   491→\t\treturn\n   492→\t}\n   493→\n   494→\tprojects, _ := h.store.ListProjects(r.Context())\n   495→\tlabels := projectLabels(projects)\n   496→\n   497→\tresult := make([]apiRun, len(runs))\n   498→\tfor i, run := range runs {\n   499→\t\tresult[i] = toAPIRun(run, labels)\n   500→\t}\n   501→\n   502→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   503→\tjson.NewEncoder(w).Encode(result)\n   504→}\n   505→\n   506→func (h *Handler) handleAPIProjectRuns(w http.ResponseWriter, r *http.Request) {\n   507→\tdir, _, ok := h.resolveProjectDir(w, r)\n   508→\tif !ok {\n   509→\t\treturn\n   510→\t}\n   511→\n   512→\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   513→\tif err != nil {\n   514→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   515→\t\treturn\n   516→\t}\n   517→\n   518→\tprojects, _ := h.store.ListProjects(r.Context())\n   519→\tlabels := projectLabels(projects)\n   520→\n   521→\tresult := make([]apiRun, len(runs))\n   522→\tfor i, run := range runs {\n   523→\t\tresult[i] = toAPIRun(run, labels)\n   524→\t}\n   525→\n   526→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   527→\tjson.NewEncoder(w).Encode(result)\n   528→}\n   529→\n   530→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   531→\tprojects, err := h.store.ListProjects(r.Context())\n   532→\tif err != nil {\n   533→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   534→\t\treturn\n   535→\t}\n   536→\tlabels := projectLabels(projects)\n   537→\n   538→\ttype apiHealth struct {\n   539→\t\tStatus string `json:\"status\"`\n   540→\t\tPassed int    `json:\"passed\"`\n   541→\t\tFailed int    `json:\"failed\"`\n   542→\t\tTotal  int    `json:\"total\"`\n   543→\t}\n   544→\ttype apiProject struct {\n   545→\t\tDir         string    `json:\"dir\"`\n   546→\t\tLabel       string    `json:\"label\"`\n   547→\t\tHealth      apiHealth `json:\"health\"`\n   548→\t\tActiveCount int       `json:\"active_count\"`\n   549→\t}\n   550→\tresult := make([]apiProject, len(projects))\n   551→\tfor i, dir := range projects {\n   552→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   553→\t\trunValues := make([]domain.Run, len(runs))\n   554→\t\tfor j, rr := range runs {\n   555→\t\t\trunValues[j] = *rr\n   556→\t\t}\n   557→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   558→\t\tvar activeCount int\n   559→\t\tfor _, rr := range runs {\n   560→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   561→\t\t\t\tactiveCount++\n   562→\t\t\t}\n   563→\t\t}\n   564→\t\tresult[i] = apiProject{\n   565→\t\t\tDir:   dir,\n   566→\t\t\tLabel: labels[dir],\n   567→\t\t\tHealth: apiHealth{\n   568→\t\t\t\tStatus: string(health.Status),\n   569→\t\t\t\tPassed: health.Passed,\n   570→\t\t\t\tFailed: health.Failed,\n   571→\t\t\t\tTotal:  health.Total,\n   572→\t\t\t},\n   573→\t\t\tActiveCount: activeCount,\n   574→\t\t}\n   575→\t}\n   576→\n   577→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   578→\tjson.NewEncoder(w).Encode(result)\n   579→}\n   580→\n   581→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   582→\tid := r.PathValue(\"id\")\n   583→\n   584→\trun, err := h.store.GetRun(r.Context(), id)\n   585→\tif err != nil {\n   586→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   587→\t\treturn\n   588→\t}\n   589→\n   590→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   591→\tif err != nil {\n   592→\t\tcaps = nil\n   593→\t}\n   594→\n   595→\tprojects, _ := h.store.ListProjects(r.Context())\n   596→\tlabels := projectLabels(projects)\n   597→\n   598→\tmerged := mergeCaptures(caps)\n   599→\tsteps := make([]apiStep, len(merged))\n   600→\tfor i, e := range merged {\n   601→\t\tsteps[i] = apiStep{\n   602→\t\t\tStepName:  e.StepName,\n   603→\t\t\tResult:    e.Result,\n   604→\t\t\tStartedAt: formatTime(e.StartedAt),\n   605→\t\t\tDuration:  e.Duration,\n   606→\t\t}\n   607→\t}\n   608→\n   609→\tdetail := apiRunDetail{\n   610→\t\tapiRun:         toAPIRun(run, labels),\n   611→\t\tContainerState: h.containerState(r.Context(), run),\n   612→\t\tSteps:          steps,\n   613→\t}\n   614→\n   615→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   616→\tjson.NewEncoder(w).Encode(detail)\n   617→}\n   618→\n   619→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   620→\tid := r.PathValue(\"id\")\n   621→\tstep := r.PathValue(\"step\")\n   622→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   623→\n   624→\trun, err := h.store.GetRun(r.Context(), id)\n   625→\tif err != nil {\n   626→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   627→\t\treturn\n   628→\t}\n   629→\n   630→\t// Try log index first for fast lookup\n   631→\tif h.logStore != nil {\n   632→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   633→\t\tif err == nil && len(logFiles) > 0 {\n   634→\t\t\t// If type filter specified, narrow results\n   635→\t\t\tfor _, lf := range logFiles {\n   636→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   637→\t\t\t\t\tcontinue\n   638→\t\t\t\t}\n   639→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   640→\t\t\t\tif readErr == nil && len(data) > 0 {\n   641→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   642→\t\t\t\t\tw.Write(data)\n   643→\t\t\t\t\treturn\n   644→\t\t\t\t}\n   645→\t\t\t}\n   646→\t\t}\n   647→\t}\n   648→\n   649→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   650→\n   651→\t// Fall back to file path conventions\n   652→\t// If type is \"llm\", try llm-<step>.log\n   653→\tif logType == \"llm\" {\n   654→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   655→\t\tdata, err := os.ReadFile(llmPath)\n   656→\t\tif err == nil && len(data) > 0 {\n   657→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   658→\t\t\tw.Write(data)\n   659→\t\t\treturn\n   660→\t\t}\n   661→\t}\n   662→\n   663→\t// Try per-step output first, fall back to container.log, then live docker logs\n   664→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   665→\tdata, err := os.ReadFile(outputPath)\n   666→\tif err == nil && len(data) > 0 {\n   667→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   668→\t\tw.Write(data)\n   669→\t\treturn\n   670→\t}\n   671→\n   672→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   673→\tdata, err = os.ReadFile(containerLog)\n   674→\tif err == nil && len(data) > 0 {\n   675→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   676→\t\tw.Write(data)\n   677→\t\treturn\n   678→\t}\n   679→\n   680→\t// Last resort: try live docker logs from still-existing container\n   681→\tif h.container != nil && run.ContainerID != \"\" {\n   682→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   683→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   684→\t\t\tw.Write([]byte(logs))\n   685→\t\t\treturn\n   686→\t\t}\n   687→\t}\n   688→\n   689→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   690→}\n   691→\n   692→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   693→\tid := r.PathValue(\"id\")\n   694→\n   695→\trun, err := h.store.GetRun(r.Context(), id)\n   696→\tif err != nil {\n   697→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   698→\t\tw.WriteHeader(http.StatusNotFound)\n   699→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   700→\t\treturn\n   701→\t}\n   702→\n   703→\tmgr, ok := h.container.(ContainerManager)\n   704→\tif !ok || run.ContainerID == \"\" {\n   705→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   706→\t\tw.WriteHeader(http.StatusBadRequest)\n   707→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   708→\t\treturn\n   709→\t}\n   710→\n   711→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   712→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   713→\t\tw.WriteHeader(http.StatusInternalServerError)\n   714→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   715→\t\treturn\n   716→\t}\n   717→\n   718→\trun.ContainerKept = false\n   719→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   720→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   721→\t\tw.WriteHeader(http.StatusInternalServerError)\n   722→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   723→\t\treturn\n   724→\t}\n   725→\n   726→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   727→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   728→}\n   729→\n   730→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   731→\tlabel := r.PathValue(\"name\")\n   732→\n   733→\t// Resolve label back to project directory via the store.\n   734→\tprojects, _ := h.store.ListProjects(r.Context())\n   735→\tlabels := projectLabels(projects)\n   736→\tvar projectDir string\n   737→\tfor dir, l := range labels {\n   738→\t\tif l == label {\n   739→\t\t\tprojectDir = dir\n   740→\t\t\tbreak\n   741→\t\t}\n   742→\t}\n   743→\tif projectDir == \"\" {\n   744→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   745→\t\tw.WriteHeader(http.StatusNotFound)\n   746→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   747→\t\treturn\n   748→\t}\n   749→\n   750→\tif h.orchestrateFn == nil {\n   751→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   752→\t\tw.WriteHeader(http.StatusNotImplemented)\n   753→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   754→\t\treturn\n   755→\t}\n   756→\n   757→\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   758→\tif err != nil {\n   759→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   760→\t\tw.WriteHeader(http.StatusInternalServerError)\n   761→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   762→\t\treturn\n   763→\t}\n   764→\n   765→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   766→\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   767→}\n   768→\n   769→// handleAPIStream serves an SSE stream of log lines for a run.\n   770→// For active runs, it subscribes to the live broadcaster.\n   771→// For completed runs, it serves the archived full.log then closes.\n   772→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   773→\tid := r.PathValue(\"id\")\n   774→\n   775→\trun, err := h.store.GetRun(r.Context(), id)\n   776→\tif err != nil {\n   777→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   778→\t\treturn\n   779→\t}\n   780→\n   781→\tflusher, ok := w.(http.Flusher)\n   782→\tif !ok {\n   783→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   784→\t\treturn\n   785→\t}\n   786→\n   787→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   788→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   789→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   790→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   791→\n   792→\tisComplete := run.State == domain.RunStateSucceeded ||\n   793→\t\trun.State == domain.RunStateFailed ||\n   794→\t\trun.State == domain.RunStateCancelled\n   795→\n   796→\tif isComplete {\n   797→\t\t// Serve archived full.log\n   798→\t\th.streamFullLog(w, flusher, run)\n   799→\t\t// Send done event\n   800→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   801→\t\tflusher.Flush()\n   802→\t\treturn\n   803→\t}\n   804→\n   805→\t// Active run: subscribe to live broadcaster\n   806→\tif h.logBroadcast == nil {\n   807→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   808→\t\treturn\n   809→\t}\n   810→\n   811→\tsub := h.logBroadcast.Subscribe(id)\n   812→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   813→\n   814→\tctx := r.Context()\n   815→\tfor {\n   816→\t\tselect {\n   817→\t\tcase <-ctx.Done():\n   818→\t\t\treturn\n   819→\t\tcase line, ok := <-sub.C:\n   820→\t\t\tif !ok {\n   821→\t\t\t\t// Stream finished (run completed)\n   822→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   823→\t\t\t\tflusher.Flush()\n   824→\t\t\t\treturn\n   825→\t\t\t}\n   826→\t\t\tdata, _ := json.Marshal(line)\n   827→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   828→\t\t\tflusher.Flush()\n   829→\t\t}\n   830→\t}\n   831→}\n   832→\n   833→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   834→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   835→\n   836→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   837→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   838→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   839→\tf, err := os.Open(logPath)\n   840→\tif err != nil {\n   841→\t\treturn\n   842→\t}\n   843→\tdefer f.Close()\n   844→\n   845→\tscanner := bufio.NewScanner(f)\n   846→\tfor scanner.Scan() {\n   847→\t\ttext := scanner.Text()\n   848→\t\tline := parseFullLogLine(text)\n   849→\t\tdata, _ := json.Marshal(line)\n   850→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   851→\t\tflusher.Flush()\n   852→\t}\n   853→}\n   854→\n   855→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   856→func parseFullLogLine(text string) logstream.LogLine {\n   857→\tm := logLineRegex.FindStringSubmatch(text)\n   858→\tif m == nil {\n   859→\t\treturn logstream.LogLine{\n   860→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   861→\t\t\tType:      \"script\",\n   862→\t\t\tContent:   text,\n   863→\t\t}\n   864→\t}\n   865→\treturn logstream.LogLine{\n   866→\t\tTimestamp: m[1],\n   867→\t\tType:      m[2],\n   868→\t\tContent:   m[3],\n   869→\t}\n   870→}\n   871→\n   872→// --- Project detail handlers ---\n   873→\n   874→// resolveProjectDir resolves a project label from the URL to its directory path.\n   875→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   876→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   877→\tlabel := r.PathValue(\"name\")\n   878→\tprojects, _ := h.store.ListProjects(r.Context())\n   879→\tlabels := projectLabels(projects)\n   880→\tfor dir, l := range labels {\n   881→\t\tif l == label {\n   882→\t\t\treturn dir, label, true\n   883→\t\t}\n   884→\t}\n   885→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   886→\tw.WriteHeader(http.StatusNotFound)\n   887→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   888→\treturn \"\", \"\", false\n   889→}\n   890→\n   891→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   892→\tdir, label, ok := h.resolveProjectDir(w, r)\n   893→\tif !ok {\n   894→\t\treturn\n   895→\t}\n   896→\n   897→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   898→\tn := 10\n   899→\tif n > len(runs) {\n   900→\t\tn = len(runs)\n   901→\t}\n   902→\tdots := make([]recentRunDot, n)\n   903→\tfor i := 0; i < n; i++ {\n   904→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   905→\t}\n   906→\n   907→\tdata := map[string]any{\n   908→\t\t\"Title\":      label,\n   909→\t\t\"Label\":      label,\n   910→\t\t\"Dir\":        dir,\n   911→\t\t\"RecentRuns\": dots,\n   912→\t}\n   913→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   914→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   915→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   916→\t}\n   917→}\n   918→\n   919→func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   920→\tdir, _, ok := h.resolveProjectDir(w, r)\n   921→\tif !ok {\n   922→\t\treturn\n   923→\t}\n   924→\tif h.orchestrator == nil {\n   925→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   926→\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   927→\t\treturn\n   928→\t}\n   929→\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   930→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   931→\tjson.NewEncoder(w).Encode(map[string]any{\n   932→\t\t\"enabled\":     enabled,\n   933→\t\t\"in_flight\":   inFlight,\n   934→\t\t\"concurrency\": concurrency,\n   935→\t})\n   936→}\n   937→\n   938→func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   939→\tdir, _, ok := h.resolveProjectDir(w, r)\n   940→\tif !ok {\n   941→\t\treturn\n   942→\t}\n   943→\tif h.orchestrator == nil {\n   944→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   945→\t\tw.WriteHeader(http.StatusNotImplemented)\n   946→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   947→\t\treturn\n   948→\t}\n   949→\th.orchestrator.SetEnabled(dir, true)\n   950→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   951→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   952→}\n   953→\n   954→func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   955→\tdir, _, ok := h.resolveProjectDir(w, r)\n   956→\tif !ok {\n   957→\t\treturn\n   958→\t}\n   959→\tif h.orchestrator == nil {\n   960→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   961→\t\tw.WriteHeader(http.StatusNotImplemented)\n   962→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   963→\t\treturn\n   964→\t}\n   965→\th.orchestrator.SetEnabled(dir, false)\n   966→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   967→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   968→}\n   969→\n   970→func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   971→\tdir, _, ok := h.resolveProjectDir(w, r)\n   972→\tif !ok {\n   973→\t\treturn\n   974→\t}\n   975→\tif h.orchestrator == nil {\n   976→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   977→\t\tw.WriteHeader(http.StatusNotImplemented)\n   978→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   979→\t\treturn\n   980→\t}\n   981→\tvar body struct {\n   982→\t\tConcurrency int `json:\"concurrency\"`\n   983→\t}\n   984→\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n   985→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   986→\t\tw.WriteHeader(http.StatusBadRequest)\n   987→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n   988→\t\treturn\n   989→\t}\n   990→\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n   991→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   992→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   993→}\n   994→\n   995→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   996→\tdir, _, ok := h.resolveProjectDir(w, r)\n   997→\tif !ok {\n   998→\t\treturn\n   999→\t}\n  1000→\n  1001→\t// Docker image: read FROM line from Dockerfile\n  1002→\tdockerImage := \"\"\n  1003→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n  1004→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n  1005→\t\t// Find the last FROM line (final stage)\n  1006→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n  1007→\t\t\ttrimmed := strings.TrimSpace(line)\n  1008→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n  1009→\t\t\t\tparts := strings.Fields(trimmed)\n  1010→\t\t\t\tif len(parts) >= 2 {\n  1011→\t\t\t\t\tdockerImage = parts[1]\n  1012→\t\t\t\t}\n  1013→\t\t\t}\n  1014→\t\t}\n  1015→\t}\n  1016→\n  1017→\t// Version\n  1018→\tversion := 0\n  1019→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n  1020→\tif data, err := os.ReadFile(versionPath); err == nil {\n  1021→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n  1022→\t\t\tversion = v\n  1023→\t\t}\n  1024→\t}\n  1025→\n  1026→\t// Prompt files history\n  1027→\ttype commitEntry struct {\n  1028→\t\tSHA     string `json:\"sha\"`\n  1029→\t\tDate    string `json:\"date\"`\n  1030→\t\tMessage string `json:\"message\"`\n  1031→\t}\n  1032→\ttype promptFile struct {\n  1033→\t\tPath    string        `json:\"path\"`\n  1034→\t\tHistory []commitEntry `json:\"history\"`\n  1035→\t}\n  1036→\n  1037→\tvar promptFiles []promptFile\n  1038→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n  1039→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n  1040→\t\tfor _, e := range entries {\n  1041→\t\t\tif e.IsDir() {\n  1042→\t\t\t\tcontinue\n  1043→\t\t\t}\n  1044→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n  1045→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n  1046→\t\t\tcmd.Dir = dir\n  1047→\t\t\tout, err := cmd.Output()\n  1048→\t\t\tif err != nil {\n  1049→\t\t\t\tcontinue\n  1050→\t\t\t}\n  1051→\t\t\tvar history []commitEntry\n  1052→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n  1053→\t\t\t\tif line == \"\" {\n  1054→\t\t\t\t\tcontinue\n  1055→\t\t\t\t}\n  1056→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1057→\t\t\t\tif len(parts) < 3 {\n  1058→\t\t\t\t\tcontinue\n  1059→\t\t\t\t}\n  1060→\t\t\t\t// Parse date to short form\n  1061→\t\t\t\tdateStr := parts[1]\n  1062→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1063→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1064→\t\t\t\t}\n  1065→\t\t\t\thistory = append(history, commitEntry{\n  1066→\t\t\t\t\tSHA:     parts[0][:7],\n  1067→\t\t\t\t\tDate:    dateStr,\n  1068→\t\t\t\t\tMessage: parts[2],\n  1069→\t\t\t\t})\n  1070→\t\t\t}\n  1071→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1072→\t\t}\n  1073→\t}\n  1074→\n  1075→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1076→\tjson.NewEncoder(w).Encode(map[string]any{\n  1077→\t\t\"docker_image\": dockerImage,\n  1078→\t\t\"version\":      version,\n  1079→\t\t\"prompt_files\": promptFiles,\n  1080→\t})\n  1081→}\n  1082→\n  1083→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1084→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1085→\tif !ok {\n  1086→\t\treturn\n  1087→\t}\n  1088→\tfile := r.URL.Query().Get(\"file\")\n  1089→\tsha := r.URL.Query().Get(\"sha\")\n  1090→\tif file == \"\" || sha == \"\" {\n  1091→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1092→\t\treturn\n  1093→\t}\n  1094→\n  1095→\t// Validate sha is alphanumeric to prevent injection\n  1096→\tfor _, c := range sha {\n  1097→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1098→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1099→\t\t\treturn\n  1100→\t\t}\n  1101→\t}\n  1102→\n  1103→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1104→\tcmd.Dir = dir\n  1105→\tout, err := cmd.Output()\n  1106→\tif err != nil {\n  1107→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1108→\t\treturn\n  1109→\t}\n  1110→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1111→\tw.Write(out)\n  1112→}\n  1113→\n  1114→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1115→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1116→\tif !ok {\n  1117→\t\treturn\n  1118→\t}\n  1119→\n  1120→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1121→\tentries, err := os.ReadDir(clocheDir)\n  1122→\tif err != nil {\n  1123→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1124→\t\tjson.NewEncoder(w).Encode([]any{})\n  1125→\t\treturn\n  1126→\t}\n  1127→\n  1128→\ttype apiWire struct {\n  1129→\t\tFrom   string `json:\"from\"`\n  1130→\t\tResult string `json:\"result\"`\n  1131→\t\tTo     string `json:\"to\"`\n  1132→\t}\n  1133→\ttype apiStepDef struct {\n  1134→\t\tName    string            `json:\"name\"`\n  1135→\t\tType    string            `json:\"type\"`\n  1136→\t\tResults []string          `json:\"results\"`\n  1137→\t\tConfig  map[string]string `json:\"config\"`\n  1138→\t}\n  1139→\ttype apiWorkflow struct {\n  1140→\t\tName      string       `json:\"name\"`\n  1141→\t\tFile      string       `json:\"file\"`\n  1142→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1143→\t\tWires     []apiWire    `json:\"wires\"`\n  1144→\t\tEntryStep string       `json:\"entry_step\"`\n  1145→\t}\n  1146→\n  1147→\tvar workflows []apiWorkflow\n  1148→\tfor _, e := range entries {\n  1149→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1150→\t\t\tcontinue\n  1151→\t\t}\n  1152→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1153→\t\tif err != nil {\n  1154→\t\t\tcontinue\n  1155→\t\t}\n  1156→\t\twf, err := dsl.Parse(string(data))\n  1157→\t\tif err != nil {\n  1158→\t\t\tcontinue\n  1159→\t\t}\n  1160→\t\tvar steps []apiStepDef\n  1161→\t\tfor _, s := range wf.Steps {\n  1162→\t\t\tsteps = append(steps, apiStepDef{\n  1163→\t\t\t\tName:    s.Name,\n  1164→\t\t\t\tType:    string(s.Type),\n  1165→\t\t\t\tResults: s.Results,\n  1166→\t\t\t\tConfig:  s.Config,\n  1167→\t\t\t})\n  1168→\t\t}\n  1169→\t\t// Sort steps by name for consistent ordering\n  1170→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1171→\n  1172→\t\tvar wires []apiWire\n  1173→\t\tfor _, wire := range wf.Wiring {\n  1174→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1175→\t\t}\n  1176→\n  1177→\t\tworkflows = append(workflows, apiWorkflow{\n  1178→\t\t\tName:      wf.Name,\n  1179→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1180→\t\t\tSteps:     steps,\n  1181→\t\t\tWires:     wires,\n  1182→\t\t\tEntryStep: wf.EntryStep,\n  1183→\t\t})\n  1184→\t}\n  1185→\n  1186→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1187→\tjson.NewEncoder(w).Encode(workflows)\n  1188→}\n  1189→\n  1190→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1191→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1192→\tif !ok {\n  1193→\t\treturn\n  1194→\t}\n  1195→\tworkflowName := r.PathValue(\"workflow\")\n  1196→\tstepName := r.PathValue(\"step\")\n  1197→\n  1198→\t// Find the workflow file\n  1199→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1200→\tvar wf *domain.Workflow\n  1201→\tentries, _ := os.ReadDir(clocheDir)\n  1202→\tfor _, e := range entries {\n  1203→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1204→\t\t\tcontinue\n  1205→\t\t}\n  1206→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1207→\t\tif err != nil {\n  1208→\t\t\tcontinue\n  1209→\t\t}\n  1210→\t\tparsed, err := dsl.Parse(string(data))\n  1211→\t\tif err != nil {\n  1212→\t\t\tcontinue\n  1213→\t\t}\n  1214→\t\tif parsed.Name == workflowName {\n  1215→\t\t\twf = parsed\n  1216→\t\t\tbreak\n  1217→\t\t}\n  1218→\t}\n  1219→\tif wf == nil {\n  1220→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1221→\t\treturn\n  1222→\t}\n  1223→\n  1224→\tstep, ok := wf.Steps[stepName]\n  1225→\tif !ok {\n  1226→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1227→\t\treturn\n  1228→\t}\n  1229→\n  1230→\t// Try to read the referenced file from step config\n  1231→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1232→\n  1233→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1234→\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1235→\t\tif err == nil {\n  1236→\t\t\tw.Write(data)\n  1237→\t\t\treturn\n  1238→\t\t}\n  1239→\t}\n  1240→\tif script := step.Config[\"command\"]; script != \"\" {\n  1241→\t\tw.Write([]byte(script))\n  1242→\t\treturn\n  1243→\t}\n  1244→\tif script := step.Config[\"script\"]; script != \"\" {\n  1245→\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1246→\t\tif err == nil {\n  1247→\t\t\tw.Write(data)\n  1248→\t\t\treturn\n  1249→\t\t}\n  1250→\t\tw.Write([]byte(script))\n  1251→\t\treturn\n  1252→\t}\n  1253→\n  1254→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1255→}\n  1256→\n  1257→// --- Template helpers ---\n  1258→\n  1259→func stateColor(state domain.RunState) string {\n  1260→\tswitch state {\n  1261→\tcase domain.RunStatePending:\n  1262→\t\treturn \"pending\"\n  1263→\tcase domain.RunStateRunning:\n  1264→\t\treturn \"running\"\n  1265→\tcase domain.RunStateSucceeded:\n  1266→\t\treturn \"succeeded\"\n  1267→\tcase domain.RunStateFailed:\n  1268→\t\treturn \"failed\"\n  1269→\tcase domain.RunStateCancelled:\n  1270→\t\treturn \"cancelled\"\n  1271→\tdefault:\n  1272→\t\treturn \"pending\"\n  1273→\t}\n  1274→}\n  1275→\n  1276→func healthColor(status domain.HealthStatus) string {\n  1277→\tswitch status {\n  1278→\tcase domain.HealthGreen:\n  1279→\t\treturn \"green\"\n  1280→\tcase domain.HealthYellow:\n  1281→\t\treturn \"yellow\"\n  1282→\tcase domain.HealthRed:\n  1283→\t\treturn \"red\"\n  1284→\tcase domain.HealthBlue:\n  1285→\t\treturn \"blue\"\n  1286→\tdefault:\n  1287→\t\treturn \"grey\"\n  1288→\t}\n  1289→}\n  1290→\n  1291→func formatTime(t time.Time) string {\n  1292→\tif t.IsZero() {\n  1293→\t\treturn \"\"\n  1294→\t}\n  1295→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1296→}\n  1297→\n  1298→func formatDuration(start, end time.Time) string {\n  1299→\tif start.IsZero() || end.IsZero() {\n  1300→\t\treturn \"\"\n  1301→\t}\n  1302→\td := end.Sub(start)\n  1303→\tif d < time.Second {\n  1304→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1305→\t}\n  1306→\tif d < time.Minute {\n  1307→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1308→\t}\n  1309→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1310→}\n  1311→\n  1312→func truncate(s string, n int) string {\n  1313→\tif len(s) <= n {\n  1314→\t\treturn s\n  1315→\t}\n  1316→\treturn s[:n] + \"...\"\n  1317→}\n  1318→\n  1319→func shortContainerID(id string) string {\n  1320→\tif len(id) > 12 {\n  1321→\t\treturn id[:12]\n  1322→\t}\n  1323→\treturn id\n  1324→}\n  1325→\n  1326→// projectLabels builds a mapping from full project directory paths to short\n  1327→// display labels. Each label is the final directory component (e.g.\n  1328→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1329→// the same final name, the parent directory is prepended to disambiguate\n  1330→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1331→func projectLabels(dirs []string) map[string]string {\n  1332→\tlabels := make(map[string]string, len(dirs))\n  1333→\t// Group dirs by their base name to detect conflicts.\n  1334→\tbyBase := map[string][]string{}\n  1335→\tfor _, d := range dirs {\n  1336→\t\tbase := filepath.Base(d)\n  1337→\t\tbyBase[base] = append(byBase[base], d)\n  1338→\t}\n  1339→\tfor base, paths := range byBase {\n  1340→\t\tif len(paths) == 1 {\n  1341→\t\t\tlabels[paths[0]] = base\n  1342→\t\t} else {\n  1343→\t\t\tfor _, p := range paths {\n  1344→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1345→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1346→\t\t\t}\n  1347→\t\t}\n  1348→\t}\n  1349→\treturn labels\n  1350→}\n  1351→\n  1352→type projectEntry struct {\n  1353→\tDir            string\n  1354→\tLabel          string\n  1355→\tContainerCount int\n  1356→}\n  1357→"}]},"parent_tool_use_id":null,"session_id":"1f381966-6d97-478e-905f-20141d255bac","uuid":"7bba29ba-02ea-49c8-87ff-dc25c93b56bd","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\nfunc WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n\treturn func(h *Handler) { h.orchestrateFn = fn }\n}\n\n// OrchestratorController provides per-project orchestrator control.\ntype OrchestratorController interface {\n\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n\tSetEnabled(dir string, enabled bool)\n\tSetConcurrency(dir string, concurrency int)\n}\n\n// WithOrchestrator sets the orchestrator controller for project-level control.\nfunc WithOrchestrator(oc OrchestratorController) HandlerOption {\n\treturn func(h *Handler) { h.orchestrator = oc }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore         ports.RunStore\n\tcaptures      ports.CaptureStore\n\tlogStore      ports.LogStore\n\tcontainer     ContainerLogger\n\tlogBroadcast  *logstream.Broadcaster\n\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n\torchestrator  OrchestratorController\n\tpages         map[string]*template.Template\n\tmux           *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRunsList)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/runs\", h.handleAPIProjectRuns)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\truns, err := h.store.ListRuns(r.Context(), time.Time{})\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tfor _, run := range runs {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": \"\",\n\t\t\"ProjectLabels\": labels,\n\t\t\"ProjectLabel\":  \"\",\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleProjectRunsList(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         label + \" — Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": dir,\n\t\t\"ProjectLabels\": labels,\n\t\t\"ProjectLabel\":  label,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\truns, err := h.store.ListRuns(r.Context(), time.Time{})\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjectRuns(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\n\t// Resolve label back to project directory via the store.\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tvar projectDir string\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\tprojectDir = dir\n\t\t\tbreak\n\t\t}\n\t}\n\tif projectDir == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\t\treturn\n\t}\n\n\tif h.orchestrateFn == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\n\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n\t\treturn\n\t}\n\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"enabled\":     enabled,\n\t\t\"in_flight\":   inFlight,\n\t\t\"concurrency\": concurrency,\n\t})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, true)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, false)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\tvar body struct {\n\t\tConcurrency int `json:\"concurrency\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n\t\treturn\n\t}\n\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\tif script := step.Config[\"command\"]; script != \"\" {\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1357,"startLine":1,"totalLines":1357}}}
