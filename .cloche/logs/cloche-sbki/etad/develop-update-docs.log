{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ShaWNgCrkzUEEWrDUAkNgo","type":"tool_result","content":"     1→package agent\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"io\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n    12→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    15→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    17→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    18→)\n    19→\n    20→type RunnerConfig struct {\n    21→\tWorkflowPath   string\n    22→\tWorkDir        string\n    23→\tStatusOutput   io.Writer\n    24→\tRunID          string\n    25→\tResumeFromStep string // when non-empty, resume the workflow from this step\n    26→}\n    27→\n    28→type Runner struct {\n    29→\tcfg RunnerConfig\n    30→}\n    31→\n    32→func NewRunner(cfg RunnerConfig) *Runner {\n    33→\treturn &Runner{\n    34→\t\tcfg: cfg,\n    35→\t}\n    36→}\n    37→\n    38→func (r *Runner) Run(ctx context.Context) error {\n    39→\tdata, err := os.ReadFile(r.cfg.WorkflowPath)\n    40→\tif err != nil {\n    41→\t\treturn fmt.Errorf(\"reading workflow file: %w\", err)\n    42→\t}\n    43→\n    44→\twf, err := dsl.ParseForContainer(string(data))\n    45→\tif err != nil {\n    46→\t\treturn fmt.Errorf(\"parsing workflow: %w\", err)\n    47→\t}\n    48→\n    49→\tstatusWriter := protocol.NewStatusWriter(r.cfg.StatusOutput)\n    50→\tgenericAdapter := generic.New()\n    51→\tgenericAdapter.RunID = r.cfg.RunID\n    52→\tpromptAdapter := prompt.New()\n    53→\tpromptAdapter.RunID = r.cfg.RunID\n    54→\tpromptAdapter.StatusWriter = statusWriter\n    55→\tif cmd, ok := os.LookupEnv(\"CLOCHE_AGENT_COMMAND\"); ok {\n    56→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    57→\t}\n    58→\tif cmd := wf.Config[\"container.agent_command\"]; cmd != \"\" {\n    59→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    60→\t}\n    61→\tif args := wf.Config[\"container.agent_args\"]; args != \"\" {\n    62→\t\tpromptAdapter.ExplicitArgs = strings.Fields(args)\n    63→\t}\n    64→\n    65→\t// Reset per-run state from any previous run — but preserve outputs when resuming\n    66→\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"attempt_count\"))\n    67→\tif r.cfg.ResumeFromStep == \"\" {\n    68→\t\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"output\"))\n    69→\t}\n    70→\n    71→\t// Create unified log writer\n    72→\tulog, err := logstream.New(r.cfg.WorkDir)\n    73→\tif err != nil {\n    74→\t\treturn fmt.Errorf(\"creating unified log: %w\", err)\n    75→\t}\n    76→\tdefer ulog.Close()\n    77→\n    78→\tgenericAdapter.StatusWriter = statusWriter\n    79→\n    80→\texecutor := &stepExecutor{\n    81→\t\tworkDir:        r.cfg.WorkDir,\n    82→\t\tgeneric:        genericAdapter,\n    83→\t\tprompt:         promptAdapter,\n    84→\t\tlogStream:      ulog,\n    85→\t\tstatusWriter:   statusWriter,\n    86→\t\tresumeFromStep: r.cfg.ResumeFromStep,\n    87→\t}\n    88→\n    89→\teng := engine.New(executor)\n    90→\teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n    91→\n    92→\t// Resume mode: load completed step results and configure engine\n    93→\tif r.cfg.ResumeFromStep != \"\" {\n    94→\t\tpreloaded, err := loadCompletedStepResults(r.cfg.WorkDir, wf, r.cfg.ResumeFromStep)\n    95→\t\tif err != nil {\n    96→\t\t\treturn fmt.Errorf(\"loading completed step results for resume: %w\", err)\n    97→\t\t}\n    98→\t\teng.SetPreloadedResults(preloaded)\n    99→\t}\n   100→\n   101→\t// Generate a run title from the prompt if one was not provided by the caller.\n   102→\t// The daemon sets title from --title; if empty, the agent extracts from prompt.\n   103→\tif title := extractTitle(r.cfg.WorkDir, r.cfg.RunID); title != \"\" {\n   104→\t\tstatusWriter.RunTitle(title)\n   105→\t}\n   106→\n   107→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n   108→\n   109→\trun, runErr := eng.Run(ctx, wf)\n   110→\tif runErr != nil {\n   111→\t\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:failed\")\n   112→\t\tulog.Log(logstream.TypeStatus, \"error: \"+runErr.Error())\n   113→\t\tulog.Log(logstream.TypeStatus, \"run_completed: failed\")\n   114→\t\t// Extract the failed step name from step executions so the daemon\n   115→\t\t// can display which step caused the failure.\n   116→\t\tfailedStep := \"\"\n   117→\t\tif run != nil {\n   118→\t\t\tfor _, se := range run.StepExecutions {\n   119→\t\t\t\tif se.Result == \"error\" || se.Result == \"fail\" {\n   120→\t\t\t\t\tfailedStep = se.StepName\n   121→\t\t\t\t}\n   122→\t\t\t}\n   123→\t\t}\n   124→\t\tstatusWriter.Error(failedStep, runErr.Error())\n   125→\t\tstatusWriter.RunCompleted(\"failed\")\n   126→\t\treturn runErr\n   127→\t}\n   128→\n   129→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:\"+string(run.State))\n   130→\n   131→\tulog.Log(logstream.TypeStatus, \"run_completed: \"+string(run.State))\n   132→\tstatusWriter.RunCompleted(string(run.State))\n   133→\treturn nil\n   134→}\n   135→\n   136→type stepExecutor struct {\n   137→\tworkDir        string\n   138→\tgeneric        *generic.Adapter\n   139→\tprompt         *prompt.Adapter\n   140→\tlogStream      *logstream.Writer\n   141→\tstatusWriter   *protocol.StatusWriter\n   142→\tresumeFromStep string // the step being resumed (for prompt resume mode)\n   143→}\n   144→\n   145→func (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n   146→\tswitch step.Type {\n   147→\tcase domain.StepTypeScript:\n   148→\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   149→\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   150→\t\treturn result, err\n   151→\tcase domain.StepTypeAgent:\n   152→\t\tif _, ok := step.Config[\"run\"]; ok {\n   153→\t\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   154→\t\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   155→\t\t\treturn result, err\n   156→\t\t}\n   157→\t\tif _, ok := step.Config[\"prompt\"]; ok {\n   158→\t\t\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   159→\t\t\t\te.prompt.Commands = prompt.ParseCommands(cmd)\n   160→\t\t\t}\n   161→\t\t\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   162→\t\t\t\te.prompt.ExplicitArgs = strings.Fields(args)\n   163→\t\t\t}\n   164→\t\t\t// Resume mode: if this is the step being resumed, use conversation resume\n   165→\t\t\tif e.resumeFromStep == step.Name {\n   166→\t\t\t\te.prompt.ResumeConversation = true\n   167→\t\t\t\tdefer func() { e.prompt.ResumeConversation = false }()\n   168→\t\t\t}\n   169→\t\t\tresult, err := e.prompt.Execute(ctx, step, e.workDir)\n   170→\t\t\te.copyToLLMLog(step.Name)\n   171→\t\t\te.logStepOutput(step.Name, logstream.TypeLLM)\n   172→\t\t\treturn result, err\n   173→\t\t}\n   174→\t\treturn \"\", fmt.Errorf(\"agent step %q requires either 'run' or 'prompt' config\", step.Name)\n   175→\tdefault:\n   176→\t\treturn \"\", fmt.Errorf(\"unknown step type: %s\", step.Type)\n   177→\t}\n   178→}\n   179→\n   180→// logStepOutput reads the per-step log file and writes its contents to the unified log.\n   181→func (e *stepExecutor) logStepOutput(stepName string, typ logstream.EntryType) {\n   182→\tpath := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   183→\tdata, err := os.ReadFile(path)\n   184→\tif err != nil || len(data) == 0 {\n   185→\t\treturn\n   186→\t}\n   187→\te.logStream.Log(typ, string(data))\n   188→}\n   189→\n   190→// copyToLLMLog copies <step>.log to llm-<step>.log for agent prompt steps.\n   191→func (e *stepExecutor) copyToLLMLog(stepName string) {\n   192→\tsrc := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   193→\tdst := filepath.Join(e.workDir, \".cloche\", \"output\", \"llm-\"+stepName+\".log\")\n   194→\tdata, err := os.ReadFile(src)\n   195→\tif err != nil {\n   196→\t\treturn\n   197→\t}\n   198→\t_ = os.WriteFile(dst, data, 0644)\n   199→}\n   200→\n   201→type statusReporter struct {\n   202→\twriter    *protocol.StatusWriter\n   203→\tlogStream *logstream.Writer\n   204→}\n   205→\n   206→func (s *statusReporter) OnStepStart(_ *domain.Run, step *domain.Step) {\n   207→\ts.writer.StepStarted(step.Name)\n   208→\ts.logStream.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n   209→}\n   210→\n   211→func (s *statusReporter) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   212→\ts.writer.StepCompleted(step.Name, result)\n   213→\ts.logStream.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n   214→}\n   215→\n   216→func (s *statusReporter) OnRunComplete(_ *domain.Run) {}\n   217→\n   218→// loadCompletedStepResults builds a map of step_name -> result for all steps\n   219→// that completed successfully before the resume point. It walks the workflow\n   220→// graph from the entry step, following wires, collecting results from the\n   221→// history log. Steps at or after the resumeFrom step are excluded.\n   222→func loadCompletedStepResults(workDir string, wf *domain.Workflow, resumeFrom string) (map[string]string, error) {\n   223→\tpreloaded := make(map[string]string)\n   224→\n   225→\t// Parse step results from history.log\n   226→\thistoryPath := filepath.Join(workDir, \".cloche\", \"history.log\")\n   227→\tdata, err := os.ReadFile(historyPath)\n   228→\tif err != nil {\n   229→\t\treturn nil, fmt.Errorf(\"reading history log: %w\", err)\n   230→\t}\n   231→\n   232→\t// Extract step:result pairs from history entries\n   233→\tstepResults := make(map[string]string)\n   234→\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   235→\t\t// History format: [timestamp] step:<name> result:<result> ...\n   236→\t\tif !strings.Contains(line, \"step:\") || !strings.Contains(line, \"result:\") {\n   237→\t\t\tcontinue\n   238→\t\t}\n   239→\t\tvar stepName, result string\n   240→\t\tfor _, field := range strings.Fields(line) {\n   241→\t\t\tif strings.HasPrefix(field, \"step:\") {\n   242→\t\t\t\tstepName = strings.TrimPrefix(field, \"step:\")\n   243→\t\t\t}\n   244→\t\t\tif strings.HasPrefix(field, \"result:\") {\n   245→\t\t\t\tresult = strings.TrimPrefix(field, \"result:\")\n   246→\t\t\t}\n   247→\t\t}\n   248→\t\tif stepName != \"\" && result != \"\" {\n   249→\t\t\tstepResults[stepName] = result\n   250→\t\t}\n   251→\t}\n   252→\n   253→\t// Walk the workflow graph from entry step, collecting completed steps\n   254→\t// until we reach the resume step\n   255→\tvisited := make(map[string]bool)\n   256→\tvar walk func(stepName string)\n   257→\twalk = func(stepName string) {\n   258→\t\tif visited[stepName] || stepName == resumeFrom {\n   259→\t\t\treturn\n   260→\t\t}\n   261→\t\tvisited[stepName] = true\n   262→\n   263→\t\tresult, ok := stepResults[stepName]\n   264→\t\tif !ok {\n   265→\t\t\treturn\n   266→\t\t}\n   267→\t\tpreloaded[stepName] = result\n   268→\n   269→\t\t// Follow wires from this step's result\n   270→\t\tnextSteps, err := wf.NextSteps(stepName, result)\n   271→\t\tif err != nil {\n   272→\t\t\treturn\n   273→\t\t}\n   274→\t\tfor _, next := range nextSteps {\n   275→\t\t\tif next != domain.StepDone && next != domain.StepAbort {\n   276→\t\t\t\twalk(next)\n   277→\t\t\t}\n   278→\t\t}\n   279→\t}\n   280→\n   281→\twalk(wf.EntryStep)\n   282→\treturn preloaded, nil\n   283→}\n   284→\n   285→// extractTitle tries to derive a one-line summary from the run's prompt content.\n   286→// It reads the per-run prompt.txt file (written by the daemon before container start),\n   287→// then returns the first non-empty line, truncated to 100 characters.\n   288→func extractTitle(workDir string, runID string) string {\n   289→\t// Try the per-run prompt file\n   290→\tpromptPath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   291→\tif _, err := os.Stat(promptPath); err != nil {\n   292→\t\t// Fall back to legacy path\n   293→\t\tpromptPath = filepath.Join(workDir, \".cloche\", \"prompt.txt\")\n   294→\t}\n   295→\tdata, err := os.ReadFile(promptPath)\n   296→\tif err != nil || len(data) == 0 {\n   297→\t\treturn \"\"\n   298→\t}\n   299→\n   300→\ttext := strings.TrimSpace(string(data))\n   301→\tif text == \"\" {\n   302→\t\treturn \"\"\n   303→\t}\n   304→\n   305→\t// Take first non-empty line as the title\n   306→\tfor _, line := range strings.Split(text, \"\\n\") {\n   307→\t\tline = strings.TrimSpace(line)\n   308→\t\t// Skip markdown headers, comment markers, and blank lines\n   309→\t\tif line == \"\" || line == \"---\" || line == \"```\" {\n   310→\t\t\tcontinue\n   311→\t\t}\n   312→\t\t// Strip leading markdown header markers\n   313→\t\tline = strings.TrimLeft(line, \"# \")\n   314→\t\tline = strings.TrimSpace(line)\n   315→\t\tif line == \"\" {\n   316→\t\t\tcontinue\n   317→\t\t}\n   318→\t\tif len(line) > 100 {\n   319→\t\t\tline = line[:97] + \"...\"\n   320→\t\t}\n   321→\t\treturn line\n   322→\t}\n   323→\treturn \"\"\n   324→}\n   325→"}]},"parent_tool_use_id":"toolu_01JBcSznxqHEKxbG5yXzGdkP","session_id":"a1496100-58bb-4933-86a8-269a722f19f5","uuid":"947558bf-98e0-4e11-99e8-928bfb778e28"}
