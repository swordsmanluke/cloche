{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ngs4TbUmy3dQYWNhQSctYK","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"sort\"\n    13→\t\"strconv\"\n    14→\t\"strings\"\n    15→\t\"sync\"\n    16→\t\"time\"\n    17→\n    18→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    20→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    21→\t\"github.com/cloche-dev/cloche/internal/config\"\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    24→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    25→\t\"github.com/cloche-dev/cloche/internal/host\"\n    26→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    27→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    28→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    29→\t\"github.com/cloche-dev/cloche/internal/version\"\n    30→\trpcgrpc \"google.golang.org/grpc\"\n    31→\t\"google.golang.org/grpc/metadata\"\n    32→)\n    33→\n    34→type ClocheServer struct {\n    35→\tpb.UnimplementedClocheServiceServer\n    36→\tstore        ports.RunStore\n    37→\tcaptures     ports.CaptureStore\n    38→\tlogStore     ports.LogStore\n    39→\tcontainer    ports.ContainerRuntime\n    40→\tdefaultImage string\n    41→\tevolution    *evolution.Trigger\n    42→\tlogBroadcast *logstream.Broadcaster\n    43→\tshutdownFn   func()\n    44→\tmu           sync.Mutex\n    45→\trunIDs       map[string]string      // run_id -> container_id\n    46→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    47→}\n    48→\n    49→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    50→\treturn &ClocheServer{\n    51→\t\tstore:     store,\n    52→\t\tcontainer: container,\n    53→\t\trunIDs:    make(map[string]string),\n    54→\t\tloops:     make(map[string]*host.Loop),\n    55→\t}\n    56→}\n    57→\n    58→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    59→\treturn &ClocheServer{\n    60→\t\tstore:        store,\n    61→\t\tcaptures:     captures,\n    62→\t\tcontainer:    container,\n    63→\t\tdefaultImage: defaultImage,\n    64→\t\trunIDs:       make(map[string]string),\n    65→\t\tloops:        make(map[string]*host.Loop),\n    66→\t}\n    67→}\n    68→\n    69→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    70→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    71→\ts.logStore = ls\n    72→}\n    73→\n    74→\n    75→// SetEvolution attaches an evolution trigger to the server.\n    76→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    77→\ts.evolution = trigger\n    78→}\n    79→\n    80→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    81→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    82→\ts.logBroadcast = b\n    83→}\n    84→\n    85→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    86→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    87→\ts.shutdownFn = fn\n    88→}\n    89→\n    90→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    91→\t// Check for resume mode via gRPC metadata\n    92→\tif resumeRunID := resumeRunIDFromContext(ctx); resumeRunID != \"\" {\n    93→\t\treturn s.resumeRun(ctx, resumeRunID, resumeStepFromContext(ctx))\n    94→\t}\n    95→\n    96→\t// Check if this is a host workflow (has host {} block).\n    97→\tif hostWFs, err := host.FindHostWorkflows(req.ProjectDir); err == nil {\n    98→\t\tif _, isHost := hostWFs[req.WorkflowName]; isHost {\n    99→\t\t\treturn s.runHostWorkflow(ctx, req)\n   100→\t\t}\n   101→\t}\n   102→\n   103→\tif s.container == nil {\n   104→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   105→\t}\n   106→\n   107→\t// Generate a unique run ID, retrying on collision\n   108→\tvar runID string\n   109→\tfor attempts := 0; attempts < 10; attempts++ {\n   110→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n   111→\t\texisting, err := s.store.GetRun(ctx, runID)\n   112→\t\tif err != nil {\n   113→\t\t\tbreak // ID is free\n   114→\t\t}\n   115→\t\t// Reuse if completed more than 1 hour ago\n   116→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   117→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   118→\t\t\tbreak\n   119→\t\t}\n   120→\t}\n   121→\n   122→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   123→\tif req.Prompt != \"\" {\n   124→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   125→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   126→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   127→\t\t}\n   128→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   129→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   130→\t\t}\n   131→\t}\n   132→\trun := domain.NewRun(runID, req.WorkflowName)\n   133→\trun.ProjectDir = req.ProjectDir\n   134→\trun.Title = req.Title\n   135→\trun.TaskID = req.IssueId\n   136→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   137→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   138→\t}\n   139→\n   140→\t// Resolve image: request-level override, then server default\n   141→\timage := req.Image\n   142→\tif image == \"\" {\n   143→\t\timage = s.defaultImage\n   144→\t}\n   145→\n   146→\t// Launch container start + tracking in background so the RPC returns immediately.\n   147→\t// The run stays in \"pending\" state until the container is up.\n   148→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   149→\n   150→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   151→}\n   152→\n   153→// runHostWorkflow dispatches a host workflow via the host runner, returning\n   154→// immediately while the workflow runs in a background goroutine.\n   155→func (s *ClocheServer) runHostWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n   156→\trunID := domain.GenerateRunID(req.WorkflowName)\n   157→\n   158→\trunner := &host.Runner{\n   159→\t\tDispatcher:   s,\n   160→\t\tStore:        s.store,\n   161→\t\tCaptures:     s.captures,\n   162→\t\tLogBroadcast: s.logBroadcast,\n   163→\t\tTaskID:       req.IssueId,\n   164→\t}\n   165→\n   166→\tgo func() {\n   167→\t\trunner.RunNamedWithID(context.Background(), req.ProjectDir, req.WorkflowName, runID)\n   168→\t}()\n   169→\n   170→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   171→}\n   172→\n   173→// resumeRunIDFromContext extracts the resume run ID from gRPC metadata.\n   174→func resumeRunIDFromContext(ctx context.Context) string {\n   175→\tmd, ok := metadata.FromIncomingContext(ctx)\n   176→\tif !ok {\n   177→\t\treturn \"\"\n   178→\t}\n   179→\tvals := md.Get(\"x-cloche-resume-run-id\")\n   180→\tif len(vals) == 0 {\n   181→\t\treturn \"\"\n   182→\t}\n   183→\treturn vals[0]\n   184→}\n   185→\n   186→// resumeStepFromContext extracts the resume step name from gRPC metadata.\n   187→func resumeStepFromContext(ctx context.Context) string {\n   188→\tmd, ok := metadata.FromIncomingContext(ctx)\n   189→\tif !ok {\n   190→\t\treturn \"\"\n   191→\t}\n   192→\tvals := md.Get(\"x-cloche-resume-step\")\n   193→\tif len(vals) == 0 {\n   194→\t\treturn \"\"\n   195→\t}\n   196→\treturn vals[0]\n   197→}\n   198→\n   199→// resumeRun resumes a failed workflow run from a specific step.\n   200→func (s *ClocheServer) resumeRun(ctx context.Context, runID, stepName string) (*pb.RunWorkflowResponse, error) {\n   201→\trun, err := s.store.GetRun(ctx, runID)\n   202→\tif err != nil {\n   203→\t\treturn nil, fmt.Errorf(\"run %q not found: %w\", runID, err)\n   204→\t}\n   205→\n   206→\tif run.State != domain.RunStateFailed {\n   207→\t\treturn nil, fmt.Errorf(\"run %q is in state %q, only failed runs can be resumed\", runID, run.State)\n   208→\t}\n   209→\n   210→\t// Determine the resume step: use provided step name, or find first failed step\n   211→\tif stepName == \"\" {\n   212→\t\tstepName = run.FindFirstFailedStep()\n   213→\t\tif stepName == \"\" {\n   214→\t\t\treturn nil, fmt.Errorf(\"run %q has no failed step to resume from\", runID)\n   215→\t\t}\n   216→\t}\n   217→\n   218→\tif run.IsHost {\n   219→\t\treturn s.resumeHostRun(ctx, run, stepName)\n   220→\t}\n   221→\treturn s.resumeContainerRun(ctx, run, stepName)\n   222→}\n   223→\n   224→// resumeHostRun resumes a failed host workflow run.\n   225→func (s *ClocheServer) resumeHostRun(ctx context.Context, run *domain.Run, stepName string) (*pb.RunWorkflowResponse, error) {\n   226→\trunner := &host.Runner{\n   227→\t\tDispatcher:   s,\n   228→\t\tStore:        s.store,\n   229→\t\tCaptures:     s.captures,\n   230→\t\tLogBroadcast: s.logBroadcast,\n   231→\t\tTaskID:       run.TaskID,\n   232→\t}\n   233→\n   234→\tgo func() {\n   235→\t\trunner.ResumeRun(context.Background(), run, stepName)\n   236→\t}()\n   237→\n   238→\treturn &pb.RunWorkflowResponse{RunId: run.ID}, nil\n   239→}\n   240→\n   241→// resumeContainerRun resumes a failed container workflow run.\n   242→func (s *ClocheServer) resumeContainerRun(ctx context.Context, run *domain.Run, stepName string) (*pb.RunWorkflowResponse, error) {\n   243→\tif s.container == nil {\n   244→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   245→\t}\n   246→\n   247→\t// Verify container still exists\n   248→\tcs, err := s.container.Inspect(ctx, run.ContainerID)\n   249→\tif err != nil {\n   250→\t\treturn nil, fmt.Errorf(\"container %s not found (may have been cleaned up): %w\", run.ContainerID, err)\n   251→\t}\n   252→\tif cs.Running {\n   253→\t\treturn nil, fmt.Errorf(\"container %s is still running\", run.ContainerID)\n   254→\t}\n   255→\n   256→\t// Commit the container to preserve its filesystem state\n   257→\tcommitter, ok := s.container.(ports.ContainerCommitter)\n   258→\tif !ok {\n   259→\t\treturn nil, fmt.Errorf(\"container runtime does not support resume (no commit capability)\")\n   260→\t}\n   261→\n   262→\timageID, err := committer.Commit(ctx, run.ContainerID)\n   263→\tif err != nil {\n   264→\t\treturn nil, fmt.Errorf(\"committing container state: %w\", err)\n   265→\t}\n   266→\n   267→\t// Copy updated scripts and overrides from host into the committed image\n   268→\t// by starting a new container with the resume command\n   269→\tresumeCmd := []string{\n   270→\t\t\"cloche-agent\", \".cloche/\" + run.WorkflowName + \".cloche\",\n   271→\t\t\"--resume-from\", stepName,\n   272→\t}\n   273→\n   274→\t// Reset run state\n   275→\trun.State = domain.RunStateRunning\n   276→\trun.ErrorMessage = \"\"\n   277→\trun.CompletedAt = time.Time{}\n   278→\trun.ActiveSteps = nil\n   279→\t_ = s.store.UpdateRun(ctx, run)\n   280→\n   281→\t// Start new container from committed image with resume command\n   282→\tgo s.launchResumeContainer(run, imageID, resumeCmd)\n   283→\n   284→\treturn &pb.RunWorkflowResponse{RunId: run.ID}, nil\n   285→}\n   286→\n   287→// launchResumeContainer starts a new container from a committed image with\n   288→// the resume command, then tracks it to completion.\n   289→func (s *ClocheServer) launchResumeContainer(run *domain.Run, image string, cmd []string) {\n   290→\tctx := context.Background()\n   291→\n   292→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   293→\t\tImage:        image,\n   294→\t\tWorkflowName: run.WorkflowName,\n   295→\t\tProjectDir:   run.ProjectDir,\n   296→\t\tRunID:        run.ID,\n   297→\t\tNetworkAllow: []string{\"*\"},\n   298→\t\tCmd:          cmd,\n   299→\t})\n   300→\tif err != nil {\n   301→\t\trun.Fail(fmt.Sprintf(\"failed to start resume container: %v\", err))\n   302→\t\t_ = s.store.UpdateRun(ctx, run)\n   303→\t\tlog.Printf(\"run %s: failed to start resume container: %v\", run.ID, err)\n   304→\t\treturn\n   305→\t}\n   306→\n   307→\ts.mu.Lock()\n   308→\ts.runIDs[run.ID] = containerID\n   309→\ts.mu.Unlock()\n   310→\n   311→\trun.ContainerID = containerID\n   312→\t_ = s.store.UpdateRun(ctx, run)\n   313→\n   314→\ts.trackRun(run.ID, containerID, run.ProjectDir, run.WorkflowName, true)\n   315→}\n   316→\n   317→// launchAndTrack starts the container and then tracks it to completion.\n   318→// It runs in a background goroutine with its own context, independent of the\n   319→// RPC context which may be cancelled after RunWorkflow returns.\n   320→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   321→\tctx := context.Background()\n   322→\n   323→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   324→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   325→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   326→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   327→\t\t\tif run != nil {\n   328→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   329→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   330→\t\t\t}\n   331→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   332→\t\t\t\treturn\n   333→\t\t}\n   334→\t}\n   335→\n   336→\tbaseSHA := gitHEAD(req.ProjectDir)\n   337→\n   338→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   339→\t\tImage:        image,\n   340→\t\tWorkflowName: req.WorkflowName,\n   341→\t\tProjectDir:   req.ProjectDir,\n   342→\t\tRunID:        runID,\n   343→\t\tNetworkAllow: []string{\"*\"},\n   344→\t})\n   345→\tif err != nil {\n   346→\t\trun, _ := s.store.GetRun(ctx, runID)\n   347→\t\tif run != nil {\n   348→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   349→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   350→\t\t}\n   351→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   352→\t\treturn\n   353→\t}\n   354→\n   355→\ts.mu.Lock()\n   356→\ts.runIDs[runID] = containerID\n   357→\ts.mu.Unlock()\n   358→\n   359→\trun, _ := s.store.GetRun(ctx, runID)\n   360→\tif run != nil {\n   361→\t\trun.Start()\n   362→\t\trun.ContainerID = containerID\n   363→\t\trun.BaseSHA = baseSHA\n   364→\t\t_ = s.store.UpdateRun(ctx, run)\n   365→\t}\n   366→\n   367→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   368→}\n   369→\n   370→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   371→\tctx := context.Background()\n   372→\n   373→\t// Attach to agent output\n   374→\treader, err := s.container.AttachOutput(ctx, containerID)\n   375→\tif err != nil {\n   376→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   377→\t\t\treturn\n   378→\t}\n   379→\n   380→\t// Parse JSON-lines status messages\n   381→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   382→\tvar reportedError string  // captured from MsgError, used to set ErrorMessage on failed runs\n   383→\tscanner := bufio.NewScanner(reader)\n   384→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   385→\tfor scanner.Scan() {\n   386→\t\tvar msg protocol.StatusMessage\n   387→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   388→\t\t\tcontinue\n   389→\t\t}\n   390→\n   391→\t\t// Fast path: log messages don't need store interaction.\n   392→\t\tif msg.Type == protocol.MsgLog {\n   393→\t\t\tif s.logBroadcast != nil {\n   394→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   395→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   396→\t\t\t\t\tType:      \"llm\",\n   397→\t\t\t\t\tContent:   msg.Message,\n   398→\t\t\t\t\tStepName:  msg.StepName,\n   399→\t\t\t\t})\n   400→\t\t\t}\n   401→\t\t\tcontinue\n   402→\t\t}\n   403→\n   404→\t\trun, err := s.store.GetRun(ctx, runID)\n   405→\t\tif err != nil {\n   406→\t\t\tcontinue\n   407→\t\t}\n   408→\n   409→\t\tswitch msg.Type {\n   410→\t\tcase protocol.MsgStepStarted:\n   411→\t\t\trun.RecordStepStart(msg.StepName)\n   412→\t\t\tif s.captures != nil {\n   413→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   414→\t\t\t\t\tStepName:  msg.StepName,\n   415→\t\t\t\t\tStartedAt: msg.Timestamp,\n   416→\t\t\t\t})\n   417→\t\t\t}\n   418→\t\t\tif s.logBroadcast != nil {\n   419→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   420→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   421→\t\t\t\t\tType:      \"status\",\n   422→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   423→\t\t\t\t\tStepName:  msg.StepName,\n   424→\t\t\t\t})\n   425→\t\t\t}\n   426→\t\tcase protocol.MsgStepCompleted:\n   427→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   428→\t\t\tif s.captures != nil {\n   429→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   430→\t\t\t\t\tStepName:    msg.StepName,\n   431→\t\t\t\t\tResult:      msg.Result,\n   432→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   433→\t\t\t\t})\n   434→\t\t\t}\n   435→\t\t\tif s.logBroadcast != nil {\n   436→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   437→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   438→\t\t\t\t\tType:      \"status\",\n   439→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   440→\t\t\t\t\tStepName:  msg.StepName,\n   441→\t\t\t\t})\n   442→\t\t\t}\n   443→\t\tcase protocol.MsgRunTitle:\n   444→\t\t\tif run.Title == \"\" {\n   445→\t\t\t\trun.Title = msg.Message\n   446→\t\t\t}\n   447→\t\tcase protocol.MsgError:\n   448→\t\t\treportedError = msg.Message\n   449→\t\t\tcontinue // Don't persist; used during finalization\n   450→\t\tcase protocol.MsgRunCompleted:\n   451→\t\t\treportedResult = msg.Result\n   452→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   453→\t\t}\n   454→\n   455→\t\t_ = s.store.UpdateRun(ctx, run)\n   456→\t}\n   457→\treader.Close()\n   458→\n   459→\t// Signal live-stream subscribers that this run is done.\n   460→\tif s.logBroadcast != nil {\n   461→\t\ts.logBroadcast.Finish(runID)\n   462→\t}\n   463→\n   464→\t// Wait for process exit\n   465→\texitCode, err := s.container.Wait(ctx, containerID)\n   466→\tif err != nil {\n   467→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   468→\t}\n   469→\n   470→\t// Extract step output files from container before it's removed\n   471→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   472→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   473→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   474→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   475→\t\t}\n   476→\t}\n   477→\n   478→\t// Capture full container stdout/stderr before the container is removed\n   479→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   480→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   481→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   482→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   483→\t\t}\n   484→\t}\n   485→\n   486→\t// Index extracted log files in the log store\n   487→\tif s.logStore != nil {\n   488→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   489→\t}\n   490→\n   491→\t// Extract results to git branch BEFORE finalizing state, so that\n   492→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   493→\t// before the run is marked complete.\n   494→\tresultLabel := reportedResult\n   495→\tif resultLabel == \"\" {\n   496→\t\tif exitCode == 0 {\n   497→\t\t\tresultLabel = \"succeeded\"\n   498→\t\t} else {\n   499→\t\t\tresultLabel = \"failed\"\n   500→\t\t}"}]},"parent_tool_use_id":"toolu_01JBcSznxqHEKxbG5yXzGdkP","session_id":"a1496100-58bb-4933-86a8-269a722f19f5","uuid":"e46d76fa-a242-4f02-8429-87f323994285"}
