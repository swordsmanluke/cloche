{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017tF3aUCMyf43VwF8NYCMuS","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"testing\"\n     5→\n     6→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     7→\t\"github.com/stretchr/testify/assert\"\n     8→)\n     9→\n    10→func TestBuildPreloadedResults_LinearWorkflow(t *testing.T) {\n    11→\twf := &domain.Workflow{\n    12→\t\tName: \"test\",\n    13→\t\tSteps: map[string]*domain.Step{\n    14→\t\t\t\"build\":  {Name: \"build\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n    15→\t\t\t\"test\":   {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"pass\", \"fail\"}},\n    16→\t\t\t\"deploy\": {Name: \"deploy\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n    17→\t\t},\n    18→\t\tWiring: []domain.Wire{\n    19→\t\t\t{From: \"build\", Result: \"success\", To: \"test\"},\n    20→\t\t\t{From: \"test\", Result: \"pass\", To: \"deploy\"},\n    21→\t\t\t{From: \"test\", Result: \"fail\", To: domain.StepAbort},\n    22→\t\t\t{From: \"deploy\", Result: \"success\", To: domain.StepDone},\n    23→\t\t},\n    24→\t\tEntryStep: \"build\",\n    25→\t}\n    26→\n    27→\trun := &domain.Run{\n    28→\t\tStepExecutions: []*domain.StepExecution{\n    29→\t\t\t{StepName: \"build\", Result: \"success\"},\n    30→\t\t\t{StepName: \"test\", Result: \"fail\"},\n    31→\t\t},\n    32→\t}\n    33→\n    34→\t// Resume from test: build should be preloaded\n    35→\tpreloaded := buildPreloadedResults(run, wf, \"test\")\n    36→\tassert.Equal(t, map[string]string{\"build\": \"success\"}, preloaded)\n    37→}\n    38→\n    39→func TestBuildPreloadedResults_ResumeFromFirst(t *testing.T) {\n    40→\twf := &domain.Workflow{\n    41→\t\tName: \"test\",\n    42→\t\tSteps: map[string]*domain.Step{\n    43→\t\t\t\"build\": {Name: \"build\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n    44→\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n    45→\t\t},\n    46→\t\tWiring: []domain.Wire{\n    47→\t\t\t{From: \"build\", Result: \"success\", To: \"test\"},\n    48→\t\t\t{From: \"build\", Result: \"fail\", To: domain.StepAbort},\n    49→\t\t\t{From: \"test\", Result: \"pass\", To: domain.StepDone},\n    50→\t\t},\n    51→\t\tEntryStep: \"build\",\n    52→\t}\n    53→\n    54→\trun := &domain.Run{\n    55→\t\tStepExecutions: []*domain.StepExecution{\n    56→\t\t\t{StepName: \"build\", Result: \"fail\"},\n    57→\t\t},\n    58→\t}\n    59→\n    60→\t// Resume from build (entry step): nothing should be preloaded\n    61→\tpreloaded := buildPreloadedResults(run, wf, \"build\")\n    62→\tassert.Empty(t, preloaded)\n    63→}\n    64→\n    65→func TestBuildPreloadedResults_MultipleCompleted(t *testing.T) {\n    66→\twf := &domain.Workflow{\n    67→\t\tName: \"test\",\n    68→\t\tSteps: map[string]*domain.Step{\n    69→\t\t\t\"a\": {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n    70→\t\t\t\"b\": {Name: \"b\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n    71→\t\t\t\"c\": {Name: \"c\", Type: domain.StepTypeScript, Results: []string{\"ok\", \"fail\"}},\n    72→\t\t\t\"d\": {Name: \"d\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n    73→\t\t},\n    74→\t\tWiring: []domain.Wire{\n    75→\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n    76→\t\t\t{From: \"b\", Result: \"ok\", To: \"c\"},\n    77→\t\t\t{From: \"c\", Result: \"ok\", To: \"d\"},\n    78→\t\t\t{From: \"c\", Result: \"fail\", To: domain.StepAbort},\n    79→\t\t\t{From: \"d\", Result: \"ok\", To: domain.StepDone},\n    80→\t\t},\n    81→\t\tEntryStep: \"a\",\n    82→\t}\n    83→\n    84→\trun := &domain.Run{\n    85→\t\tStepExecutions: []*domain.StepExecution{\n    86→\t\t\t{StepName: \"a\", Result: \"ok\"},\n    87→\t\t\t{StepName: \"b\", Result: \"ok\"},\n    88→\t\t\t{StepName: \"c\", Result: \"fail\"},\n    89→\t\t},\n    90→\t}\n    91→\n    92→\t// Resume from c: a and b should be preloaded\n    93→\tpreloaded := buildPreloadedResults(run, wf, \"c\")\n    94→\tassert.Equal(t, map[string]string{\"a\": \"ok\", \"b\": \"ok\"}, preloaded)\n    95→}\n    96→\n    97→func TestBuildPreloadedResults_SkipsErrorResults(t *testing.T) {\n    98→\twf := &domain.Workflow{\n    99→\t\tName: \"test\",\n   100→\t\tSteps: map[string]*domain.Step{\n   101→\t\t\t\"build\": {Name: \"build\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   102→\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"pass\", \"fail\"}},\n   103→\t\t},\n   104→\t\tWiring: []domain.Wire{\n   105→\t\t\t{From: \"build\", Result: \"success\", To: \"test\"},\n   106→\t\t\t{From: \"test\", Result: \"pass\", To: domain.StepDone},\n   107→\t\t\t{From: \"test\", Result: \"fail\", To: domain.StepAbort},\n   108→\t\t},\n   109→\t\tEntryStep: \"build\",\n   110→\t}\n   111→\n   112→\trun := &domain.Run{\n   113→\t\tStepExecutions: []*domain.StepExecution{\n   114→\t\t\t{StepName: \"build\", Result: \"error\"}, // error results should be excluded\n   115→\t\t\t{StepName: \"test\", Result: \"fail\"},\n   116→\t\t},\n   117→\t}\n   118→\n   119→\t// Resume from build: nothing should be preloaded because build had \"error\"\n   120→\tpreloaded := buildPreloadedResults(run, wf, \"build\")\n   121→\tassert.Empty(t, preloaded)\n   122→}\n   123→\n   124→func TestFindFirstFailedStep(t *testing.T) {\n   125→\ttests := []struct {\n   126→\t\tname     string\n   127→\t\trun      *domain.Run\n   128→\t\texpected string\n   129→\t}{\n   130→\t\t{\n   131→\t\t\tname: \"finds first fail\",\n   132→\t\t\trun: &domain.Run{\n   133→\t\t\t\tStepExecutions: []*domain.StepExecution{\n   134→\t\t\t\t\t{StepName: \"build\", Result: \"success\"},\n   135→\t\t\t\t\t{StepName: \"test\", Result: \"fail\"},\n   136→\t\t\t\t},\n   137→\t\t\t},\n   138→\t\t\texpected: \"test\",\n   139→\t\t},\n   140→\t\t{\n   141→\t\t\tname: \"finds error result\",\n   142→\t\t\trun: &domain.Run{\n   143→\t\t\t\tStepExecutions: []*domain.StepExecution{\n   144→\t\t\t\t\t{StepName: \"build\", Result: \"success\"},\n   145→\t\t\t\t\t{StepName: \"deploy\", Result: \"error\"},\n   146→\t\t\t\t},\n   147→\t\t\t},\n   148→\t\t\texpected: \"deploy\",\n   149→\t\t},\n   150→\t\t{\n   151→\t\t\tname: \"no failures\",\n   152→\t\t\trun: &domain.Run{\n   153→\t\t\t\tStepExecutions: []*domain.StepExecution{\n   154→\t\t\t\t\t{StepName: \"build\", Result: \"success\"},\n   155→\t\t\t\t},\n   156→\t\t\t},\n   157→\t\t\texpected: \"\",\n   158→\t\t},\n   159→\t\t{\n   160→\t\t\tname:     \"empty executions\",\n   161→\t\t\trun:      &domain.Run{},\n   162→\t\t\texpected: \"\",\n   163→\t\t},\n   164→\t}\n   165→\n   166→\tfor _, tt := range tests {\n   167→\t\tt.Run(tt.name, func(t *testing.T) {\n   168→\t\t\tresult := tt.run.FindFirstFailedStep()\n   169→\t\t\tassert.Equal(t, tt.expected, result)\n   170→\t\t})\n   171→\t}\n   172→}\n   173→"}]},"parent_tool_use_id":"toolu_01PMzXEFt6XKjsQHNS83B3Mt","session_id":"a1496100-58bb-4933-86a8-269a722f19f5","uuid":"7b085db9-4efb-4e76-9837-780d53e69818"}
