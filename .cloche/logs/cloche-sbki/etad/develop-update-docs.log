{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011gGXPCxfyywiXFc1avnJgf","type":"tool_result","content":"     1→package docker\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"context\"\n     6→\t\"fmt\"\n     7→\t\"io\"\n     8→\t\"os\"\n     9→\t\"os/exec\"\n    10→\t\"path/filepath\"\n    11→\t\"strconv\"\n    12→\t\"strings\"\n    13→\t\"time\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    16→)\n    17→\n    18→type Runtime struct{}\n    19→\n    20→func NewRuntime() (*Runtime, error) {\n    21→\tif _, err := exec.LookPath(\"docker\"); err != nil {\n    22→\t\treturn nil, fmt.Errorf(\"docker not found in PATH: %w\", err)\n    23→\t}\n    24→\treturn &Runtime{}, nil\n    25→}\n    26→\n    27→func (r *Runtime) Start(ctx context.Context, cfg ports.ContainerConfig) (string, error) {\n    28→\t// Build docker create args\n    29→\tcontainerCmd := cfg.Cmd\n    30→\tuseDefaultCmd := len(containerCmd) == 0\n    31→\tif useDefaultCmd {\n    32→\t\tcontainerCmd = []string{\"cloche-agent\", \".cloche/\" + cfg.WorkflowName + \".cloche\"}\n    33→\t}\n    34→\n    35→\targs := []string{\n    36→\t\t\"create\",\n    37→\t\t\"--workdir\", \"/workspace\",\n    38→\t\t\"--add-host=host.docker.internal:host-gateway\",\n    39→\t}\n    40→\n    41→\t// When using the default command, run as root and wrap with chown + su agent\n    42→\t// so the workspace is owned by the agent user. Custom Cmd runs as-is.\n    43→\tif useDefaultCmd {\n    44→\t\targs = append(args, \"--user\", \"root\")\n    45→\t}\n    46→\n    47→\t// Pass run ID into container\n    48→\tif cfg.RunID != \"\" {\n    49→\t\targs = append(args, \"-e\", \"CLOCHE_RUN_ID=\"+cfg.RunID)\n    50→\t}\n    51→\t// Pass ANTHROPIC_API_KEY into container if set\n    52→\tif key := os.Getenv(\"ANTHROPIC_API_KEY\"); key != \"\" {\n    53→\t\targs = append(args, \"-e\", \"ANTHROPIC_API_KEY\")\n    54→\t}\n    55→\n    56→\t// Claude auth files are copied (not mounted) after docker create so each\n    57→\t// container gets its own copy — avoids concurrent write conflicts.\n    58→\n    59→\t// Support extra volume mounts via CLOCHE_EXTRA_MOUNTS (comma-separated host:container pairs)\n    60→\tif mounts := os.Getenv(\"CLOCHE_EXTRA_MOUNTS\"); mounts != \"\" {\n    61→\t\tfor _, m := range strings.Split(mounts, \",\") {\n    62→\t\t\tif strings.Contains(m, \":\") {\n    63→\t\t\t\targs = append(args, \"-v\", m)\n    64→\t\t\t}\n    65→\t\t}\n    66→\t}\n    67→\n    68→\t// Support extra env vars via CLOCHE_EXTRA_ENV (comma-separated KEY=VALUE pairs)\n    69→\tif extraEnv := os.Getenv(\"CLOCHE_EXTRA_ENV\"); extraEnv != \"\" {\n    70→\t\tfor _, e := range strings.Split(extraEnv, \",\") {\n    71→\t\t\tif strings.Contains(e, \"=\") {\n    72→\t\t\t\targs = append(args, \"-e\", e)\n    73→\t\t\t}\n    74→\t\t}\n    75→\t}\n    76→\n    77→\t// No --network none: agent needs network for git push and API access\n    78→\n    79→\tif useDefaultCmd {\n    80→\t\t// Wrap: chown workspace, strip host-side tools (e.g. Serena MCP) that\n    81→\t\t// cause the agent to waste time on onboarding, then exec as agent.\n    82→\t\twrappedCmd := fmt.Sprintf(\n    83→\t\t\t\"chown -R agent:agent /workspace\"+\n    84→\t\t\t\t\" && chown -R agent:agent /home/agent/.claude /home/agent/.claude.json 2>/dev/null\"+\n    85→\t\t\t\t\" && rm -rf /workspace/.serena\"+\n    86→\t\t\t\t\" && f=/home/agent/.claude/settings.json\"+\n    87→\t\t\t\t` && [ -f \"$f\" ] && sed -i '/\"enabledPlugins\"/,/}/d' \"$f\"`+\n    88→\t\t\t\t\"; exec su agent -s /bin/sh -c %q\",\n    89→\t\t\tstrings.Join(containerCmd, \" \"),\n    90→\t\t)\n    91→\t\targs = append(args, cfg.Image, \"sh\", \"-c\", wrappedCmd)\n    92→\t} else {\n    93→\t\targs = append(args, cfg.Image)\n    94→\t\targs = append(args, containerCmd...)\n    95→\t}\n    96→\n    97→\t// docker create\n    98→\tcreateCmd := exec.CommandContext(ctx, \"docker\", args...)\n    99→\tvar stdout, stderr bytes.Buffer\n   100→\tcreateCmd.Stdout = &stdout\n   101→\tcreateCmd.Stderr = &stderr\n   102→\tif err := createCmd.Run(); err != nil {\n   103→\t\treturn \"\", fmt.Errorf(\"creating container: %s: %w\", stderr.String(), err)\n   104→\t}\n   105→\tcontainerID := strings.TrimSpace(stdout.String())\n   106→\n   107→\t// 3. Copy project files into container (no bind mount)\n   108→\tif cfg.ProjectDir != \"\" {\n   109→\t\tcpCmd := exec.CommandContext(ctx, \"docker\", \"cp\", cfg.ProjectDir+\"/.\", containerID+\":/workspace/\")\n   110→\t\tvar cpStderr bytes.Buffer\n   111→\t\tcpCmd.Stderr = &cpStderr\n   112→\t\tif err := cpCmd.Run(); err != nil {\n   113→\t\t\t// Cleanup on failure\n   114→\t\t\texec.CommandContext(ctx, \"docker\", \"rm\", \"-f\", containerID).Run()\n   115→\t\t\treturn \"\", fmt.Errorf(\"copying files to container: %s: %w\", cpStderr.String(), err)\n   116→\t\t}\n   117→\n   118→\t\t// Apply override files from .cloche/overrides/ on top of workspace\n   119→\t\toverridesDir := filepath.Join(cfg.ProjectDir, \".cloche\", \"overrides\")\n   120→\t\tif _, err := os.Stat(overridesDir); err == nil {\n   121→\t\t\toverrideCmd := exec.CommandContext(ctx, \"docker\", \"cp\", overridesDir+\"/.\", containerID+\":/workspace/\")\n   122→\t\t\toverrideCmd.Stderr = &cpStderr\n   123→\t\t\tif err := overrideCmd.Run(); err != nil {\n   124→\t\t\t\t// Non-fatal: log but don't fail the run\n   125→\t\t\t\tfmt.Fprintf(os.Stderr, \"warning: copying overrides: %s\\n\", cpStderr.String())\n   126→\t\t\t}\n   127→\t\t}\n   128→\t}\n   129→\n   130→\t// 4. Copy Claude auth files into container (each gets its own copy)\n   131→\tif home, err := os.UserHomeDir(); err == nil {\n   132→\t\tclaudeDir := home + \"/.claude\"\n   133→\t\tif _, err := os.Stat(claudeDir); err == nil {\n   134→\t\t\texec.CommandContext(ctx, \"docker\", \"cp\", claudeDir, containerID+\":/home/agent/.claude\").Run()\n   135→\t\t}\n   136→\t\tclaudeJSON := home + \"/.claude.json\"\n   137→\t\tif _, err := os.Stat(claudeJSON); err == nil {\n   138→\t\t\texec.CommandContext(ctx, \"docker\", \"cp\", claudeJSON, containerID+\":/home/agent/.claude.json\").Run()\n   139→\t\t}\n   140→\t}\n   141→\n   142→\t// 5. Start the container\n   143→\tstartCmd := exec.CommandContext(ctx, \"docker\", \"start\", containerID)\n   144→\tvar startStderr bytes.Buffer\n   145→\tstartCmd.Stderr = &startStderr\n   146→\tif err := startCmd.Run(); err != nil {\n   147→\t\texec.CommandContext(ctx, \"docker\", \"rm\", \"-f\", containerID).Run()\n   148→\t\treturn \"\", fmt.Errorf(\"starting container: %s: %w\", startStderr.String(), err)\n   149→\t}\n   150→\n   151→\treturn containerID, nil\n   152→}\n   153→\n   154→func (r *Runtime) Stop(ctx context.Context, containerID string) error {\n   155→\tcmd := exec.CommandContext(ctx, \"docker\", \"stop\", containerID)\n   156→\tvar stderr bytes.Buffer\n   157→\tcmd.Stderr = &stderr\n   158→\n   159→\tif err := cmd.Run(); err != nil {\n   160→\t\treturn fmt.Errorf(\"stopping container: %s: %w\", stderr.String(), err)\n   161→\t}\n   162→\treturn nil\n   163→}\n   164→\n   165→func (r *Runtime) AttachOutput(ctx context.Context, containerID string) (io.ReadCloser, error) {\n   166→\tcmd := exec.CommandContext(ctx, \"docker\", \"logs\", \"-f\", containerID)\n   167→\tstdout, err := cmd.StdoutPipe()\n   168→\tif err != nil {\n   169→\t\treturn nil, fmt.Errorf(\"creating stdout pipe: %w\", err)\n   170→\t}\n   171→\n   172→\tif err := cmd.Start(); err != nil {\n   173→\t\treturn nil, fmt.Errorf(\"attaching to container output: %w\", err)\n   174→\t}\n   175→\n   176→\treturn &cmdReadCloser{ReadCloser: stdout, cmd: cmd}, nil\n   177→}\n   178→\n   179→func (r *Runtime) Wait(ctx context.Context, containerID string) (int, error) {\n   180→\tcmd := exec.CommandContext(ctx, \"docker\", \"wait\", containerID)\n   181→\tvar stdout, stderr bytes.Buffer\n   182→\tcmd.Stdout = &stdout\n   183→\tcmd.Stderr = &stderr\n   184→\n   185→\tif err := cmd.Run(); err != nil {\n   186→\t\treturn -1, fmt.Errorf(\"waiting for container: %s: %w\", stderr.String(), err)\n   187→\t}\n   188→\n   189→\tcode, err := strconv.Atoi(strings.TrimSpace(stdout.String()))\n   190→\tif err != nil {\n   191→\t\treturn -1, fmt.Errorf(\"parsing exit code %q: %w\", stdout.String(), err)\n   192→\t}\n   193→\treturn code, nil\n   194→}\n   195→\n   196→func (r *Runtime) CopyFrom(ctx context.Context, containerID string, srcPath, dstPath string) error {\n   197→\tcmd := exec.CommandContext(ctx, \"docker\", \"cp\", containerID+\":\"+srcPath, dstPath)\n   198→\tvar stderr bytes.Buffer\n   199→\tcmd.Stderr = &stderr\n   200→\tif err := cmd.Run(); err != nil {\n   201→\t\treturn fmt.Errorf(\"copying from container: %s: %w\", stderr.String(), err)\n   202→\t}\n   203→\treturn nil\n   204→}\n   205→\n   206→func (r *Runtime) Logs(ctx context.Context, containerID string) (string, error) {\n   207→\tcmd := exec.CommandContext(ctx, \"docker\", \"logs\", containerID)\n   208→\tvar stdout, stderr bytes.Buffer\n   209→\tcmd.Stdout = &stdout\n   210→\tcmd.Stderr = &stderr\n   211→\tif err := cmd.Run(); err != nil {\n   212→\t\treturn \"\", fmt.Errorf(\"getting container logs: %s: %w\", stderr.String(), err)\n   213→\t}\n   214→\t// Combine stdout and stderr\n   215→\tcombined := stdout.String() + stderr.String()\n   216→\treturn combined, nil\n   217→}\n   218→\n   219→func (r *Runtime) Remove(ctx context.Context, containerID string) error {\n   220→\tcmd := exec.CommandContext(ctx, \"docker\", \"rm\", \"-f\", containerID)\n   221→\tvar stderr bytes.Buffer\n   222→\tcmd.Stderr = &stderr\n   223→\tif err := cmd.Run(); err != nil {\n   224→\t\treturn fmt.Errorf(\"removing container: %s: %w\", stderr.String(), err)\n   225→\t}\n   226→\treturn nil\n   227→}\n   228→\n   229→func (r *Runtime) Inspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error) {\n   230→\tcmd := exec.CommandContext(ctx, \"docker\", \"inspect\",\n   231→\t\t\"--format\", \"{{.State.Running}} {{.State.ExitCode}} {{.State.FinishedAt}}\",\n   232→\t\tcontainerID)\n   233→\tvar stdout, stderr bytes.Buffer\n   234→\tcmd.Stdout = &stdout\n   235→\tcmd.Stderr = &stderr\n   236→\tif err := cmd.Run(); err != nil {\n   237→\t\treturn nil, fmt.Errorf(\"inspecting container: %s: %w\", stderr.String(), err)\n   238→\t}\n   239→\n   240→\tparts := strings.SplitN(strings.TrimSpace(stdout.String()), \" \", 3)\n   241→\tif len(parts) < 3 {\n   242→\t\treturn nil, fmt.Errorf(\"unexpected inspect output: %s\", stdout.String())\n   243→\t}\n   244→\n   245→\trunning := parts[0] == \"true\"\n   246→\texitCode := 0\n   247→\tfmt.Sscanf(parts[1], \"%d\", &exitCode)\n   248→\tfinishedAt, _ := time.Parse(time.RFC3339Nano, parts[2])\n   249→\n   250→\treturn &ports.ContainerStatus{\n   251→\t\tRunning:    running,\n   252→\t\tExitCode:   exitCode,\n   253→\t\tFinishedAt: finishedAt,\n   254→\t}, nil\n   255→}\n   256→\n   257→func (r *Runtime) Commit(ctx context.Context, containerID string) (string, error) {\n   258→\tshort := containerID\n   259→\tif len(short) > 12 {\n   260→\t\tshort = short[:12]\n   261→\t}\n   262→\ttag := \"cloche-resume-\" + short\n   263→\tcmd := exec.CommandContext(ctx, \"docker\", \"commit\", containerID, tag)\n   264→\tvar stdout, stderr bytes.Buffer\n   265→\tcmd.Stdout = &stdout\n   266→\tcmd.Stderr = &stderr\n   267→\tif err := cmd.Run(); err != nil {\n   268→\t\treturn \"\", fmt.Errorf(\"committing container: %s: %w\", stderr.String(), err)\n   269→\t}\n   270→\treturn tag, nil\n   271→}\n   272→\n   273→func (r *Runtime) CopyTo(ctx context.Context, containerID string, srcPath, dstPath string) error {\n   274→\tcmd := exec.CommandContext(ctx, \"docker\", \"cp\", srcPath, containerID+\":\"+dstPath)\n   275→\tvar stderr bytes.Buffer\n   276→\tcmd.Stderr = &stderr\n   277→\tif err := cmd.Run(); err != nil {\n   278→\t\treturn fmt.Errorf(\"copying to container: %s: %w\", stderr.String(), err)\n   279→\t}\n   280→\treturn nil\n   281→}\n   282→\n   283→type cmdReadCloser struct {\n   284→\tio.ReadCloser\n   285→\tcmd *exec.Cmd\n   286→}\n   287→\n   288→func (c *cmdReadCloser) Close() error {\n   289→\terr := c.ReadCloser.Close()\n   290→\tc.cmd.Wait()\n   291→\treturn err\n   292→}"}]},"parent_tool_use_id":"toolu_01JBcSznxqHEKxbG5yXzGdkP","session_id":"a1496100-58bb-4933-86a8-269a722f19f5","uuid":"574a485f-ac35-4094-9c57-e1457340aae1"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FxUdEQZRsVDPcKoksAA1GJ","type":"tool_result","content":"     1→# Cloche System Design\n     2→\n     3→## Overview\n     4→\n     5→Cloche is a system for grow-coding high quality applications. It provides containerized\n     6→environments for coding agents to operate in isolation, a workflow DSL for linking\n     7→agentic and script-driven tasks, validated code pipelines, and self-evolving tooling.\n     8→\n     9→This document describes the architecture for the MVP (v0.1).\n    10→\n    11→## System Components\n    12→\n    13→Cloche is a Go monorepo producing three binaries:\n    14→\n    15→```\n    16→cmd/\n    17→  cloche/         # CLI client (short-lived)\n    18→  cloched/        # Daemon/orchestrator (long-running)\n    19→  cloche-agent/   # In-container entrypoint (autonomous)\n    20→```\n    21→\n    22→### cloche (CLI)\n    23→\n    24→Short-lived process. Talks to `cloched` over gRPC (Unix socket locally, TCP remotely).\n    25→\n    26→Subcommands:\n    27→- `run <workflow>` — Launch a new workflow run\n    28→- `status [run-id]` — Check run status\n    29→- `logs <run-id>` — Stream logs from a running workflow (bidirectional gRPC stream)\n    30→- `stop <run-id>` — Cancel a running workflow (signals container with SIGTERM)\n    31→\n    32→Accepts prompt files or stdin input for user commands.\n    33→\n    34→### cloched (Daemon)\n    35→\n    36→Long-running process. Responsibilities:\n    37→- Launch and manage Docker containers for workflow runs\n    38→- Listen to status streams from running agents\n    39→- Record captures (step inputs, outputs, results, logs)\n    40→- Expose gRPC API for the CLI\n    41→- Persist state via pluggable storage (SQLite initially)\n    42→\n    43→The daemon does NOT interpret workflow logic. It knows \"container X is running workflow Y\"\n    44→and collects status. The agent is self-directing.\n    45→\n    46→### cloche-agent (In-Container Runtime)\n    47→\n    48→Autonomous process running inside the Docker container. Responsibilities:\n    49→- Parse the workflow DSL (workflow files live in the codebase)\n    50→- Walk the workflow graph, executing steps and following results\n    51→- Invoke coding agents (Claude Code, custom commands) and scripts\n    52→- Stream structured status events back to `cloched`\n    53→- Run to completion (`done` or `abort`) without human intervention\n    54→\n    55→The agent is told which workflow to execute at launch. It handles everything else.\n    56→\n    57→## Communication\n    58→\n    59→### CLI <-> Daemon: gRPC\n    60→\n    61→- Protobuf contracts define the API (the API is the spec)\n    62→- Bidirectional streaming for `logs` (tail container output in real-time)\n    63→- Unix socket for local communication, TCP for remote\n    64→\n    65→### Agent <-> Daemon: Structured JSON over stdout\n    66→\n    67→- The agent writes JSON-lines to stdout with status updates\n    68→- `cloched` attaches to the container's stdout stream via Docker API\n    69→- Messages include: step started, step completed (with result name), logs, errors\n    70→- Kill/cancel: daemon sends SIGTERM to container, agent handles graceful shutdown\n    71→\n    72→## Workflow DSL\n    73→\n    74→### Vocabulary\n    75→\n    76→| Concept  | Description                                                        |\n    77→|----------|--------------------------------------------------------------------|\n    78→| workflow | A named graph of steps connected by result wiring                  |\n    79→| step     | A unit of work (type: `agent` or `script`)                         |\n    80→| result   | A named outcome reported by a step (e.g. \"success\", \"fail\")       |\n    81→| wiring   | Maps a step's result to the next step                              |\n    82→| done     | Built-in terminal step indicating successful completion            |\n    83→| abort    | Built-in terminal step indicating failure (reports error and exits)|\n    84→\n    85→### Syntax\n    86→\n    87→```\n    88→workflow \"implement-feature\" {\n    89→  step code {\n    90→    prompt = file(\"prompts/implement.md\")\n    91→    container {\n    92→      image = \"cloche/agent:latest\"\n    93→      network_allow = [\"docs.python.org\", \"internal-docs.company.com\"]\n    94→    }\n    95→    results = [success, fail, retry_with_feedback]\n    96→  }\n    97→\n    98→  step check {\n    99→    run = \"make test && make lint\"\n   100→    results = [pass, fail]\n   101→  }\n   102→\n   103→  step review {\n   104→    prompt = file(\"prompts/review.md\")\n   105→    input = step.code.output\n   106→    results = [approved, changes_requested]\n   107→  }\n   108→\n   109→  code:success -> check\n   110→  code:fail -> abort\n   111→  code:retry_with_feedback -> code\n   112→\n   113→  check:pass -> review\n   114→  check:fail -> code:retry_with_feedback\n   115→\n   116→  review:approved -> done\n   117→  review:changes_requested -> code\n   118→}\n   119→```\n   120→\n   121→### Key Properties\n   122→\n   123→- Step type is inferred from content: `prompt` field → agent step, `run` field → script step.\n   124→- Steps declare which results they can emit. The step decides at runtime which result to report.\n   125→- Wiring is separate from step definitions. This enables runtime injection of new steps\n   126→  (the self-evolution feature) — insert a new check between existing steps by rewiring,\n   127→  without modifying either step.\n   128→- `file()` loads external content (prompt files, scripts).\n   129→- Step inputs can reference other step outputs (`step.code.output`).\n   130→- The graph engine validates at parse time: all declared results are wired, no orphan steps,\n   131→  entry point exists.\n   132→\n   133→## Hexagonal Architecture\n   134→\n   135→The core domain is independent of Docker, gRPC, SQLite, or any other infrastructure.\n   136→\n   137→### Domain\n   138→\n   139→```\n   140→internal/domain/\n   141→  workflow.go    # Workflow, Step, Result, Graph types\n   142→  run.go         # Run, RunState, StepExecution types\n   143→  capture.go     # CapturedInput, CapturedOutput for replay\n   144→```\n   145→\n   146→### Ports (interfaces)\n   147→\n   148→```\n   149→internal/ports/\n   150→  store.go       # RunStore, WorkflowStore, CaptureStore\n   151→  container.go   # ContainerRuntime (start, stop, attach, logs)\n   152→  agent.go       # AgentAdapter (how to invoke an agent)\n   153→  notifier.go    # StatusNotifier (how to report progress)\n   154→```\n   155→\n   156→### Adapters (implementations)\n   157→\n   158→```\n   159→internal/adapters/\n   160→  docker/        # ContainerRuntime via Docker API\n   161→  sqlite/        # Store implementations via SQLite\n   162→  grpc/          # gRPC server (daemon) and client (CLI)\n   163→  agents/\n   164→    claudecode/  # AgentAdapter for Claude Code\n   165→    generic/     # AgentAdapter for arbitrary commands\n   166→```\n   167→\n   168→### Key Interfaces\n   169→\n   170→- **ContainerRuntime** — Start/stop containers, attach to stdout, copy files in/out.\n   171→  Docker today, Podman or Firecracker later.\n   172→- **RunStore** — Persist run state (active step, reported results, timestamps).\n   173→- **CaptureStore** — Store step inputs/outputs for replay. Git refs serve as pointers\n   174→  to file states; metadata lives in the store.\n   175→- **AgentAdapter** — Translates between Cloche's step protocol and a specific agent's\n   176→  interface. Claude Code adapter knows how to invoke `claude` CLI. Generic adapter runs\n   177→  any command.\n   178→- **StatusNotifier** — How the agent reports progress. Stdout JSON-lines initially.\n   179→\n   180→## Container Model\n   181→\n   182→### One Container Per Workflow Run\n   183→\n   184→A container is spun up for a workflow run. All steps execute inside the same container.\n   185→File state accumulates naturally across steps (agent modifies code, then test script\n   186→runs against those modifications).\n   187→\n   188→### Lifecycle\n   189→\n   190→1. `cloched` pulls/builds the container image\n   191→2. Copies project files into the container at `/workspace`\n   192→3. Starts the container with `cloche-agent` as entrypoint, passing the workflow name\n   193→4. `cloche-agent` parses the workflow, walks the graph, executes steps\n   194→5. Agent streams status events to `cloched` via stdout\n   195→6. At step boundaries, modified files are pushed to the host via git (agent-specific branch)\n   196→7. On completion (`done`/`abort`), container is stopped\n   197→\n   198→### File Extraction via Git\n   199→\n   200→The container's git remote is configured to push to the host repository. Each run pushes\n   201→to a unique branch (e.g. `cloche/run-<id>/step-<name>`). This provides:\n   202→- Full git history of what the agent did\n   203→- Trivial diffs between input and output states\n   204→- Clean branch-per-step organization\n   205→- No bind mounts (maintains isolation)\n   206→\n   207→### Security Boundaries\n   208→\n   209→1. **Filesystem** — No access beyond `/workspace`. Copy-in at start, git push for extraction.\n   210→2. **Network** — `--network none` by default. If `network_allow` is specified, Cloche creates\n   211→   a custom Docker network restricting egress to allowlisted domains via DNS proxy.\n   212→3. **Environment** — Configured in Dockerfile/image. Cloche does not inject env vars.\n   213→\n   214→## Capture System\n   215→\n   216→Each step execution is captured for later inspection and replay.\n   217→\n   218→### What Gets Captured\n   219→\n   220→- Step config (prompt, type, container settings)\n   221→- Input state (git ref of what was provided to the step)\n   222→- Output state (git ref of what the step produced)\n   223→- Result reported (which result name)\n   224→- Stdout/stderr logs\n   225→- Timing metadata\n   226→\n   227→### Storage\n   228→\n   229→Metadata in the store (SQLite initially). Git refs serve as pointers to actual file\n   230→states — no duplication of file content.\n   231→\n   232→## MVP Scope (v0.1)\n   233→\n   234→### In Scope\n   235→\n   236→- `cloche` CLI: `run`, `status`, `logs`, `stop`\n   237→- `cloched` daemon: container lifecycle, status collection, gRPC API, SQLite store\n   238→- `cloche-agent`: DSL parser, graph engine, agent/script execution, status reporting\n   239→- Workflow DSL: steps, results, wiring, `done`/`abort` terminals, `file()` references\n   240→- Container model: Docker, copy-in project files, git push for extraction, network allowlist\n   241→- Agent adapters: Generic (run a command) + Claude Code\n   242→- Capture system: Record step inputs/outputs/results\n   243→\n   244→### Post-MVP\n   245→\n   246→- Self-evolution: failure pattern analysis, automatic step injection into workflows\n   247→- Replay system: partial/full/dry replay of captured runs\n   248→- Auto-split commits into stacked branches\n   249→- Additional agent adapters\n   250→- Alternative storage backends (Postgres, DynamoDB)\n   251→- Alternative container runtimes (Podman, Firecracker)\n   252→"}]},"parent_tool_use_id":"toolu_01JUnpJzSHuhmadkgcFGRrK6","session_id":"a1496100-58bb-4933-86a8-269a722f19f5","uuid":"dd62300a-ba1e-409d-969d-c5725b8e7056"}
