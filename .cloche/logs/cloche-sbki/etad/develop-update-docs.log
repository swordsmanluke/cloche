{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CPtwJAiGQwhJvDhbjE77jP","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"strings\"\n     5→\t\"testing\"\n     6→)\n     7→\n     8→func TestHasHelpFlag(t *testing.T) {\n     9→\ttests := []struct {\n    10→\t\targs []string\n    11→\t\twant bool\n    12→\t}{\n    13→\t\t{nil, false},\n    14→\t\t{[]string{}, false},\n    15→\t\t{[]string{\"--workflow\", \"develop\"}, false},\n    16→\t\t{[]string{\"--help\"}, true},\n    17→\t\t{[]string{\"-h\"}, true},\n    18→\t\t{[]string{\"--workflow\", \"develop\", \"--help\"}, true},\n    19→\t\t{[]string{\"-h\", \"--workflow\", \"develop\"}, true},\n    20→\t}\n    21→\n    22→\tfor _, tt := range tests {\n    23→\t\tgot := hasHelpFlag(tt.args)\n    24→\t\tif got != tt.want {\n    25→\t\t\tt.Errorf(\"hasHelpFlag(%v) = %v, want %v\", tt.args, got, tt.want)\n    26→\t\t}\n    27→\t}\n    28→}\n    29→\n    30→func TestSubcommandHelpExists(t *testing.T) {\n    31→\tcommands := []string{\n    32→\t\t\"init\", \"health\", \"run\", \"resume\", \"status\", \"logs\", \"poll\",\n    33→\t\t\"list\", \"stop\", \"delete\", \"tasks\", \"loop\", \"get\", \"set\", \"shutdown\",\n    34→\t\t\"workflow\", \"project\",\n    35→\t}\n    36→\n    37→\tfor _, cmd := range commands {\n    38→\t\ttext, ok := subcommandHelp[cmd]\n    39→\t\tif !ok {\n    40→\t\t\tt.Errorf(\"missing help text for subcommand %q\", cmd)\n    41→\t\t\tcontinue\n    42→\t\t}\n    43→\t\tif text == \"\" {\n    44→\t\t\tt.Errorf(\"empty help text for subcommand %q\", cmd)\n    45→\t\t}\n    46→\t}\n    47→}\n    48→\n    49→func TestSubcommandHelpContainsUsage(t *testing.T) {\n    50→\tfor cmd, text := range subcommandHelp {\n    51→\t\tif !strings.Contains(text, \"Usage:\") {\n    52→\t\t\tt.Errorf(\"help for %q missing Usage: section\", cmd)\n    53→\t\t}\n    54→\t\tif !strings.Contains(text, \"Examples:\") {\n    55→\t\t\tt.Errorf(\"help for %q missing Examples: section\", cmd)\n    56→\t\t}\n    57→\t\tif !strings.Contains(text, \"cloche \"+cmd) {\n    58→\t\t\tt.Errorf(\"help for %q missing usage line with 'cloche %s'\", cmd, cmd)\n    59→\t\t}\n    60→\t}\n    61→}\n    62→\n    63→func TestPrintHelp_UnknownCommand(t *testing.T) {\n    64→\t// printHelp with an unknown command should still return true (help was handled)\n    65→\tgot := printHelp([]string{\"nonexistent\"})\n    66→\tif !got {\n    67→\t\tt.Error(\"printHelp with unknown command should return true\")\n    68→\t}\n    69→}\n    70→\n    71→func TestPrintHelp_NoArgs(t *testing.T) {\n    72→\tgot := printHelp(nil)\n    73→\tif !got {\n    74→\t\tt.Error(\"printHelp with no args should return true\")\n    75→\t}\n    76→}\n    77→\n    78→func TestPrintHelp_ValidCommand(t *testing.T) {\n    79→\tgot := printHelp([]string{\"run\"})\n    80→\tif !got {\n    81→\t\tt.Error(\"printHelp with valid command should return true\")\n    82→\t}\n    83→}\n    84→\n    85→func TestRunHelpIncludesIssueFlag(t *testing.T) {\n    86→\ttext := subcommandHelp[\"run\"]\n    87→\tif !strings.Contains(text, \"--issue\") {\n    88→\t\tt.Error(\"run help text should document --issue flag\")\n    89→\t}\n    90→\tif !strings.Contains(text, \"-i\") {\n    91→\t\tt.Error(\"run help text should document -i shorthand\")\n    92→\t}\n    93→}\n    94→\n    95→func TestListHelpIncludesTaskIdColumn(t *testing.T) {\n    96→\ttext := subcommandHelp[\"list\"]\n    97→\tif !strings.Contains(text, \"task ID\") {\n    98→\t\tt.Error(\"list help text should mention task ID column\")\n    99→\t}\n   100→}\n   101→"}]},"parent_tool_use_id":"toolu_01PMzXEFt6XKjsQHNS83B3Mt","session_id":"a1496100-58bb-4933-86a8-269a722f19f5","uuid":"9921f934-ae41-4bb6-ad52-1d218e37af4c"}
