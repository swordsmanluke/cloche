{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0171X8MQYeVh5Thsjo3cDPRk","type":"tool_result","content":"     1→package engine\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"sync\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11→)\n    12→\n    13→const DefaultStepTimeout = 30 * time.Minute\n    14→\n    15→// StepExecutor executes a single step and returns the result name.\n    16→type StepExecutor interface {\n    17→\tExecute(ctx context.Context, step *domain.Step) (string, error)\n    18→}\n    19→\n    20→// StepExecutorFunc adapts a function to the StepExecutor interface.\n    21→type StepExecutorFunc func(ctx context.Context, step *domain.Step) (string, error)\n    22→\n    23→func (f StepExecutorFunc) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    24→\treturn f(ctx, step)\n    25→}\n    26→\n    27→// StatusHandler receives notifications about workflow execution progress.\n    28→type StatusHandler interface {\n    29→\tOnStepStart(run *domain.Run, step *domain.Step)\n    30→\tOnStepComplete(run *domain.Run, step *domain.Step, result string)\n    31→\tOnRunComplete(run *domain.Run)\n    32→}\n    33→\n    34→type noopStatus struct{}\n    35→\n    36→func (noopStatus) OnStepStart(*domain.Run, *domain.Step)            {}\n    37→func (noopStatus) OnStepComplete(*domain.Run, *domain.Step, string) {}\n    38→func (noopStatus) OnRunComplete(*domain.Run)                        {}\n    39→\n    40→type Engine struct {\n    41→\texecutor         StepExecutor\n    42→\tstatus           StatusHandler\n    43→\tmaxSteps         int\n    44→\tdefaultTimeout   time.Duration\n    45→\tpreloadedResults map[string]string // step_name -> result for resume mode\n    46→}\n    47→\n    48→func New(executor StepExecutor) *Engine {\n    49→\treturn &Engine{\n    50→\t\texecutor:       executor,\n    51→\t\tstatus:         noopStatus{},\n    52→\t\tmaxSteps:       1000,\n    53→\t\tdefaultTimeout: DefaultStepTimeout,\n    54→\t}\n    55→}\n    56→\n    57→func (e *Engine) SetStatusHandler(h StatusHandler) {\n    58→\te.status = h\n    59→}\n    60→\n    61→func (e *Engine) SetMaxSteps(n int) {\n    62→\te.maxSteps = n\n    63→}\n    64→\n    65→// SetDefaultTimeout sets the default timeout for steps that don't specify one.\n    66→func (e *Engine) SetDefaultTimeout(d time.Duration) {\n    67→\te.defaultTimeout = d\n    68→}\n    69→\n    70→// SetPreloadedResults configures the engine to skip execution of steps whose\n    71→// results are already known. When a step in this map is launched, the engine\n    72→// immediately produces the stored result without calling the executor. This is\n    73→// used for resume mode: completed steps before the resume point are replayed.\n    74→func (e *Engine) SetPreloadedResults(results map[string]string) {\n    75→\te.preloadedResults = results\n    76→}\n    77→\n    78→// stepResult is sent from worker goroutines back to the main event loop.\n    79→type stepResult struct {\n    80→\tstepName string\n    81→\tresult   string\n    82→\terr      error\n    83→}\n    84→\n    85→// collectState tracks the satisfaction state of a single Collect clause.\n    86→type collectState struct {\n    87→\tcollect   *domain.Collect\n    88→\tsatisfied map[int]bool\n    89→\tfired     bool\n    90→}\n    91→\n    92→func (e *Engine) Run(ctx context.Context, wf *domain.Workflow) (*domain.Run, error) {\n    93→\tif err := wf.Validate(); err != nil {\n    94→\t\treturn nil, fmt.Errorf(\"invalid workflow: %w\", err)\n    95→\t}\n    96→\tfor _, w := range wf.ValidateConfig() {\n    97→\t\tlog.Printf(\"WARNING: %s\", w)\n    98→\t}\n    99→\n   100→\trun := domain.NewRun(generateRunID(), wf.Name)\n   101→\trun.Start()\n   102→\n   103→\t// Check context cancellation before starting.\n   104→\tif err := ctx.Err(); err != nil {\n   105→\t\trun.Complete(domain.RunStateCancelled)\n   106→\t\treturn run, fmt.Errorf(\"workflow cancelled: %w\", err)\n   107→\t}\n   108→\n   109→\t// Build a set of (step, result) pairs that are handled by collects,\n   110→\t// so we know when a missing wire is acceptable.\n   111→\tcollectHandled := make(map[string]map[string]bool)\n   112→\tfor _, c := range wf.Collects {\n   113→\t\tfor _, cond := range c.Conditions {\n   114→\t\t\tif collectHandled[cond.Step] == nil {\n   115→\t\t\t\tcollectHandled[cond.Step] = make(map[string]bool)\n   116→\t\t\t}\n   117→\t\t\tcollectHandled[cond.Step][cond.Result] = true\n   118→\t\t}\n   119→\t}\n   120→\n   121→\t// Initialize collect states.\n   122→\tcStates := make([]*collectState, len(wf.Collects))\n   123→\tfor i := range wf.Collects {\n   124→\t\tcStates[i] = &collectState{\n   125→\t\t\tcollect:   &wf.Collects[i],\n   126→\t\t\tsatisfied: make(map[int]bool),\n   127→\t\t}\n   128→\t}\n   129→\n   130→\tresults := make(chan stepResult, e.maxSteps)\n   131→\tactiveCount := 0\n   132→\tstepCount := 0\n   133→\tdoneCount := 0\n   134→\taborted := false\n   135→\tvar runErr error\n   136→\n   137→\t// Use a mutex to protect run state from concurrent goroutine access.\n   138→\t// Only the main loop should touch the Run, but we record step start before\n   139→\t// launching the goroutine, so this is safe without a mutex for now.\n   140→\t// The goroutines only read the step and send on the channel.\n   141→\n   142→\tlaunchStep := func(stepName string) error {\n   143→\t\tstepCount++\n   144→\t\tif stepCount > e.maxSteps {\n   145→\t\t\treturn fmt.Errorf(\"workflow exceeded maximum step count (%d)\", e.maxSteps)\n   146→\t\t}\n   147→\n   148→\t\tstep, ok := wf.Steps[stepName]\n   149→\t\tif !ok {\n   150→\t\t\treturn fmt.Errorf(\"step %q not found in workflow\", stepName)\n   151→\t\t}\n   152→\n   153→\t\tactiveCount++\n   154→\t\trun.RecordStepStart(step.Name)\n   155→\t\te.status.OnStepStart(run, step)\n   156→\n   157→\t\t// Resume mode: if this step has a preloaded result, replay it\n   158→\t\t// instead of executing. This allows completed steps to be\n   159→\t\t// skipped while preserving the wiring logic.\n   160→\t\tif preloadedResult, ok := e.preloadedResults[stepName]; ok {\n   161→\t\t\tgo func(name, result string) {\n   162→\t\t\t\tresults <- stepResult{stepName: name, result: result}\n   163→\t\t\t}(step.Name, preloadedResult)\n   164→\t\t\treturn nil\n   165→\t\t}\n   166→\n   167→\t\tgo func(s *domain.Step) {\n   168→\t\t\tstepCtx := ctx\n   169→\t\t\tif d := stepTimeout(s, e.defaultTimeout); d > 0 {\n   170→\t\t\t\tvar cancel context.CancelFunc\n   171→\t\t\t\tstepCtx, cancel = context.WithTimeout(ctx, d)\n   172→\t\t\t\tdefer cancel()\n   173→\t\t\t}\n   174→\t\t\tresult, err := e.executor.Execute(stepCtx, s)\n   175→\t\t\tresults <- stepResult{stepName: s.Name, result: result, err: err}\n   176→\t\t}(step)\n   177→\n   178→\t\treturn nil\n   179→\t}\n   180→\n   181→\t// Launch entry step.\n   182→\tif err := launchStep(wf.EntryStep); err != nil {\n   183→\t\trun.Complete(domain.RunStateFailed)\n   184→\t\treturn run, err\n   185→\t}\n   186→\n   187→\t// Main event loop.\n   188→\tfor activeCount > 0 {\n   189→\t\tselect {\n   190→\t\tcase <-ctx.Done():\n   191→\t\t\trun.Complete(domain.RunStateCancelled)\n   192→\t\t\treturn run, fmt.Errorf(\"workflow cancelled: %w\", ctx.Err())\n   193→\n   194→\t\tcase sr := <-results:\n   195→\t\t\tactiveCount--\n   196→\n   197→\t\t\t// Step execution error.\n   198→\t\t\tif sr.err != nil {\n   199→\t\t\t\trun.RecordStepComplete(sr.stepName, \"error\")\n   200→\t\t\t\trun.Complete(domain.RunStateFailed)\n   201→\t\t\t\te.status.OnRunComplete(run)\n   202→\t\t\t\treturn run, fmt.Errorf(\"step %q execution failed: %w\", sr.stepName, sr.err)\n   203→\t\t\t}\n   204→\n   205→\t\t\t// Validate result is declared in the step's Results list.\n   206→\t\t\tstep := wf.Steps[sr.stepName]\n   207→\t\t\tif !isResultDeclared(step, sr.result) {\n   208→\t\t\t\trun.RecordStepComplete(sr.stepName, sr.result)\n   209→\t\t\t\trun.Complete(domain.RunStateFailed)\n   210→\t\t\t\te.status.OnRunComplete(run)\n   211→\t\t\t\treturn run, fmt.Errorf(\"step %q returned undeclared result %q\", sr.stepName, sr.result)\n   212→\t\t\t}\n   213→\n   214→\t\t\trun.RecordStepComplete(sr.stepName, sr.result)\n   215→\t\t\te.status.OnStepComplete(run, step, sr.result)\n   216→\n   217→\t\t\t// Process wiring: get next steps for this (step, result) pair.\n   218→\t\t\tnextSteps, wireErr := wf.NextSteps(sr.stepName, sr.result)\n   219→\t\t\tif wireErr != nil {\n   220→\t\t\t\t// No wire found. Check if any collect handles this (step, result).\n   221→\t\t\t\tif !collectHandled[sr.stepName][sr.result] {\n   222→\t\t\t\t\t// Neither wires nor collects handle this result.\n   223→\t\t\t\t\trun.Complete(domain.RunStateFailed)\n   224→\t\t\t\t\te.status.OnRunComplete(run)\n   225→\t\t\t\t\treturn run, wireErr\n   226→\t\t\t\t}\n   227→\t\t\t\t// Collect handles it; no wire targets to launch.\n   228→\t\t\t} else {\n   229→\t\t\t\t// Process wire targets.\n   230→\t\t\t\tfor _, target := range nextSteps {\n   231→\t\t\t\t\tswitch target {\n   232→\t\t\t\t\tcase domain.StepDone:\n   233→\t\t\t\t\t\tdoneCount++\n   234→\t\t\t\t\tcase domain.StepAbort:\n   235→\t\t\t\t\t\taborted = true\n   236→\t\t\t\t\tdefault:\n   237→\t\t\t\t\t\tif err := launchStep(target); err != nil {\n   238→\t\t\t\t\t\t\trun.Complete(domain.RunStateFailed)\n   239→\t\t\t\t\t\t\te.status.OnRunComplete(run)\n   240→\t\t\t\t\t\t\treturn run, err\n   241→\t\t\t\t\t\t}\n   242→\t\t\t\t\t}\n   243→\t\t\t\t}\n   244→\t\t\t}\n   245→\n   246→\t\t\t// Check and fire collect conditions.\n   247→\t\t\tfor _, cs := range cStates {\n   248→\t\t\t\tif cs.fired {\n   249→\t\t\t\t\tcontinue\n   250→\t\t\t\t}\n   251→\t\t\t\tfor i, cond := range cs.collect.Conditions {\n   252→\t\t\t\t\tif cond.Step == sr.stepName && cond.Result == sr.result {\n   253→\t\t\t\t\t\tcs.satisfied[i] = true\n   254→\t\t\t\t\t}\n   255→\t\t\t\t}\n   256→\n   257→\t\t\t\tshouldFire := false\n   258→\t\t\t\tswitch cs.collect.Mode {\n   259→\t\t\t\tcase domain.CollectAll:\n   260→\t\t\t\t\tshouldFire = len(cs.satisfied) == len(cs.collect.Conditions)\n   261→\t\t\t\tcase domain.CollectAny:\n   262→\t\t\t\t\tshouldFire = len(cs.satisfied) > 0\n   263→\t\t\t\t}\n   264→\n   265→\t\t\t\tif shouldFire {\n   266→\t\t\t\t\tcs.fired = true\n   267→\t\t\t\t\ttarget := cs.collect.To\n   268→\t\t\t\t\tswitch target {\n   269→\t\t\t\t\tcase domain.StepDone:\n   270→\t\t\t\t\t\tdoneCount++\n   271→\t\t\t\t\tcase domain.StepAbort:\n   272→\t\t\t\t\t\taborted = true\n   273→\t\t\t\t\tdefault:\n   274→\t\t\t\t\t\tif err := launchStep(target); err != nil {\n   275→\t\t\t\t\t\t\trun.Complete(domain.RunStateFailed)\n   276→\t\t\t\t\t\t\te.status.OnRunComplete(run)\n   277→\t\t\t\t\t\t\treturn run, err\n   278→\t\t\t\t\t\t}\n   279→\t\t\t\t\t}\n   280→\t\t\t\t}\n   281→\t\t\t}\n   282→\t\t}\n   283→\t}\n   284→\n   285→\t// Determine final state.\n   286→\tif aborted || runErr != nil {\n   287→\t\trun.Complete(domain.RunStateFailed)\n   288→\t} else if doneCount > 0 {\n   289→\t\trun.Complete(domain.RunStateSucceeded)\n   290→\t} else {\n   291→\t\trun.Complete(domain.RunStateFailed)\n   292→\t\trunErr = fmt.Errorf(\"workflow %q: no branches reached done\", wf.Name)\n   293→\t}\n   294→\n   295→\te.status.OnRunComplete(run)\n   296→\treturn run, runErr\n   297→}\n   298→\n   299→// isResultDeclared checks whether the given result is in the step's declared Results list.\n   300→func isResultDeclared(step *domain.Step, result string) bool {\n   301→\tfor _, r := range step.Results {\n   302→\t\tif r == result {\n   303→\t\t\treturn true\n   304→\t\t}\n   305→\t}\n   306→\treturn false\n   307→}\n   308→\n   309→var (\n   310→\trunCounter int\n   311→\trunMu      sync.Mutex\n   312→)\n   313→\n   314→func generateRunID() string {\n   315→\trunMu.Lock()\n   316→\tdefer runMu.Unlock()\n   317→\trunCounter++\n   318→\treturn fmt.Sprintf(\"run-%d\", runCounter)\n   319→}\n   320→\n   321→// stepTimeout returns the timeout for a step. It checks step.Config[\"timeout\"]\n   322→// first, falling back to the provided default.\n   323→func stepTimeout(step *domain.Step, defaultTimeout time.Duration) time.Duration {\n   324→\tif raw, ok := step.Config[\"timeout\"]; ok {\n   325→\t\tif d, err := time.ParseDuration(raw); err == nil {\n   326→\t\t\treturn d\n   327→\t\t}\n   328→\t}\n   329→\treturn defaultTimeout\n   330→}\n   331→"}]},"parent_tool_use_id":"toolu_01JBcSznxqHEKxbG5yXzGdkP","session_id":"a1496100-58bb-4933-86a8-269a722f19f5","uuid":"a83bb4ce-90d4-481c-b396-762f9b74e7af"}
