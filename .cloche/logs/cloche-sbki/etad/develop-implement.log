{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BbG1gzgz8XS87Pu96K8Whr","type":"tool_result","content":"   200→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   201→\t\t}\n   202→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   203→\t\treturn\n   204→\t}\n   205→\n   206→\ts.mu.Lock()\n   207→\ts.runIDs[runID] = containerID\n   208→\ts.mu.Unlock()\n   209→\n   210→\trun, _ := s.store.GetRun(ctx, runID)\n   211→\tif run != nil {\n   212→\t\trun.Start()\n   213→\t\trun.ContainerID = containerID\n   214→\t\trun.BaseSHA = baseSHA\n   215→\t\t_ = s.store.UpdateRun(ctx, run)\n   216→\t}\n   217→\n   218→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   219→}\n   220→\n   221→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   222→\tctx := context.Background()\n   223→\n   224→\t// Attach to agent output\n   225→\treader, err := s.container.AttachOutput(ctx, containerID)\n   226→\tif err != nil {\n   227→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   228→\t\t\treturn\n   229→\t}\n   230→\n   231→\t// Parse JSON-lines status messages\n   232→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   233→\tvar reportedError string  // captured from MsgError, used to set ErrorMessage on failed runs\n   234→\tscanner := bufio.NewScanner(reader)\n   235→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   236→\tfor scanner.Scan() {\n   237→\t\tvar msg protocol.StatusMessage\n   238→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   239→\t\t\tcontinue\n   240→\t\t}\n   241→\n   242→\t\t// Fast path: log messages don't need store interaction.\n   243→\t\tif msg.Type == protocol.MsgLog {\n   244→\t\t\tif s.logBroadcast != nil {\n   245→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   246→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   247→\t\t\t\t\tType:      \"llm\",\n   248→\t\t\t\t\tContent:   msg.Message,\n   249→\t\t\t\t\tStepName:  msg.StepName,\n   250→\t\t\t\t})\n   251→\t\t\t}\n   252→\t\t\tcontinue\n   253→\t\t}\n   254→\n   255→\t\trun, err := s.store.GetRun(ctx, runID)\n   256→\t\tif err != nil {\n   257→\t\t\tcontinue\n   258→\t\t}\n   259→\n   260→\t\tswitch msg.Type {\n   261→\t\tcase protocol.MsgStepStarted:\n   262→\t\t\trun.RecordStepStart(msg.StepName)\n   263→\t\t\tif s.captures != nil {\n   264→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   265→\t\t\t\t\tStepName:  msg.StepName,\n   266→\t\t\t\t\tStartedAt: msg.Timestamp,\n   267→\t\t\t\t})\n   268→\t\t\t}\n   269→\t\t\tif s.logBroadcast != nil {\n   270→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   271→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   272→\t\t\t\t\tType:      \"status\",\n   273→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   274→\t\t\t\t\tStepName:  msg.StepName,\n   275→\t\t\t\t})\n   276→\t\t\t}\n   277→\t\tcase protocol.MsgStepCompleted:\n   278→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   279→\t\t\tif s.captures != nil {\n   280→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   281→\t\t\t\t\tStepName:    msg.StepName,\n   282→\t\t\t\t\tResult:      msg.Result,\n   283→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   284→\t\t\t\t})\n   285→\t\t\t}\n   286→\t\t\tif s.logBroadcast != nil {\n   287→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   288→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   289→\t\t\t\t\tType:      \"status\",\n   290→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   291→\t\t\t\t\tStepName:  msg.StepName,\n   292→\t\t\t\t})\n   293→\t\t\t}\n   294→\t\tcase protocol.MsgRunTitle:\n   295→\t\t\tif run.Title == \"\" {\n   296→\t\t\t\trun.Title = msg.Message\n   297→\t\t\t}\n   298→\t\tcase protocol.MsgError:\n   299→\t\t\treportedError = msg.Message\n   300→\t\t\tcontinue // Don't persist; used during finalization\n   301→\t\tcase protocol.MsgRunCompleted:\n   302→\t\t\treportedResult = msg.Result\n   303→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   304→\t\t}\n   305→\n   306→\t\t_ = s.store.UpdateRun(ctx, run)\n   307→\t}\n   308→\treader.Close()\n   309→\n   310→\t// Signal live-stream subscribers that this run is done.\n   311→\tif s.logBroadcast != nil {\n   312→\t\ts.logBroadcast.Finish(runID)\n   313→\t}\n   314→\n   315→\t// Wait for process exit\n   316→\texitCode, err := s.container.Wait(ctx, containerID)\n   317→\tif err != nil {\n   318→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   319→\t}\n   320→\n   321→\t// Extract step output files from container before it's removed\n   322→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   323→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   324→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   325→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   326→\t\t}\n   327→\t}\n   328→\n   329→\t// Capture full container stdout/stderr before the container is removed\n   330→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   331→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   332→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   333→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   334→\t\t}\n   335→\t}\n   336→\n   337→\t// Index extracted log files in the log store\n   338→\tif s.logStore != nil {\n   339→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   340→\t}\n   341→\n   342→\t// Extract results to git branch BEFORE finalizing state, so that\n   343→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   344→\t// before the run is marked complete.\n   345→\tresultLabel := reportedResult\n   346→\tif resultLabel == \"\" {\n   347→\t\tif exitCode == 0 {\n   348→\t\t\tresultLabel = \"succeeded\"\n   349→\t\t} else {\n   350→\t\t\tresultLabel = \"failed\"\n   351→\t\t}\n   352→\t}\n   353→\t{\n   354→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   355→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   356→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   357→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   358→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   359→\t\t\t} else {\n   360→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   361→\t\t\t}\n   362→\t\t} else {\n   363→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   364→\t\t}\n   365→\t}\n   366→\n   367→\t// Now finalize run state\n   368→\trun, err := s.store.GetRun(ctx, runID)\n   369→\tif err != nil {\n   370→\t\treturn\n   371→\t}\n   372→\tif run.State == domain.RunStateRunning {\n   373→\t\tif reportedResult == \"succeeded\" {\n   374→\t\t\trun.Complete(domain.RunStateSucceeded)\n   375→\t\t} else if reportedResult != \"\" {\n   376→\t\t\tif reportedError != \"\" {\n   377→\t\t\t\trun.Fail(reportedError)\n   378→\t\t\t} else {\n   379→\t\t\t\trun.Complete(domain.RunStateFailed)\n   380→\t\t\t}\n   381→\t\t} else if exitCode == 0 {\n   382→\t\t\trun.Complete(domain.RunStateSucceeded)\n   383→\t\t} else {\n   384→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   385→\t\t}\n   386→\t\t_ = s.store.UpdateRun(ctx, run)\n   387→\t}\n   388→\n   389→\t// Fire evolution trigger if configured\n   390→\tif s.evolution != nil {\n   391→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   392→\t}\n   393→\n   394→\t// Merge is handled as a workflow step in host.cloche, not here.\n   395→\n   396→\t// Container retention policy:\n   397→\t// - Failed runs: always keep the container for debugging\n   398→\t// - Successful runs + --keep-container: keep the container\n   399→\t// - Successful runs without --keep-container: remove the container"}]},"parent_tool_use_id":"toolu_01LUR8zLT62d8pbFKzq3zGR4","session_id":"a767d320-7441-4cfb-80d2-26edf647ec06","uuid":"5790e4db-3adb-414e-80ff-f8d26bc43195"}
