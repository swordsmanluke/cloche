{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VvVxoywBTSekdjU4C9XeXX","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"strings\"\n    11→\t\"time\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    17→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    19→\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    20→)\n    21→\n    22→// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    23→// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    24→// strings suitable for adding to a command's environment.\n    25→func (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    26→\tvar env []string\n    27→\tfor _, w := range wires {\n    28→\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    29→\t\t\tcontinue\n    30→\t\t}\n    31→\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    32→\t\tif err != nil {\n    33→\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    34→\t\t}\n    35→\t\tfor _, m := range w.OutputMap {\n    36→\t\t\tval, err := m.Path.Evaluate(data)\n    37→\t\t\tif err != nil {\n    38→\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    39→\t\t\t}\n    40→\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    41→\t\t}\n    42→\t}\n    43→\treturn env, nil\n    44→}\n    45→\n    46→// RunDispatcher dispatches a container workflow run and returns the run ID.\n    47→type RunDispatcher interface {\n    48→\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    49→}\n    50→\n    51→// Executor implements engine.StepExecutor for host workflow steps.\n    52→type Executor struct {\n    53→\tProjectDir    string\n    54→\tMainDir       string         // main branch worktree dir; scripts execute from here\n    55→\tDispatcher    RunDispatcher\n    56→\tStore         ports.RunStore\n    57→\tOutputDir     string         // directory for step output files\n    58→\tWires         []domain.Wire  // workflow wiring (for output mappings)\n    59→\tHostRunID     string         // ID of the parent host run (set on child runs)\n    60→\tAgentCommands []string       // workflow-level agent command fallback chain\n    61→\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n    62→\tTaskID        string         // optional task ID assigned by the daemon loop\n    63→\tExtraEnv      []string       // additional KEY=VALUE env vars for all steps\n    64→}\n    65→\n    66→// scriptDir returns the directory from which scripts should execute.\n    67→// Uses MainDir if set, otherwise falls back to ProjectDir.\n    68→func (e *Executor) scriptDir() string {\n    69→\tif e.MainDir != \"\" {\n    70→\t\treturn e.MainDir\n    71→\t}\n    72→\treturn e.ProjectDir\n    73→}\n    74→\n    75→var _ engine.StepExecutor = (*Executor)(nil)\n    76→\n    77→// Execute runs a single host workflow step.\n    78→func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    79→\tswitch step.Type {\n    80→\tcase domain.StepTypeScript:\n    81→\t\treturn e.executeScript(ctx, step)\n    82→\tcase domain.StepTypeWorkflow:\n    83→\t\treturn e.executeWorkflow(ctx, step)\n    84→\tcase domain.StepTypeAgent:\n    85→\t\treturn e.executeAgent(ctx, step)\n    86→\tdefault:\n    87→\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    88→\t}\n    89→}\n    90→\n    91→// executeScript runs a shell command on the host.\n    92→func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    93→\tcmdStr := step.Config[\"run\"]\n    94→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    95→\tcmd.Dir = e.scriptDir()\n    96→\tcmd.Env = append(os.Environ(),\n    97→\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    98→\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    99→\t)\n   100→\n   101→\t// Pass run ID so steps can access .cloche/<run-id>/ and context.json\n   102→\tif e.HostRunID != \"\" {\n   103→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_RUN_ID=\"+e.HostRunID)\n   104→\t}\n   105→\n   106→\t// Pass daemon-assigned task ID if available\n   107→\tif e.TaskID != \"\" {\n   108→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_TASK_ID=\"+e.TaskID)\n   109→\t}\n   110→\n   111→\t// Pass extra env vars (e.g. finalize phase outcome vars)\n   112→\tif len(e.ExtraEnv) > 0 {\n   113→\t\tcmd.Env = append(cmd.Env, e.ExtraEnv...)\n   114→\t}\n   115→\n   116→\t// Pass previous step output if available\n   117→\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n   118→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n   119→\t}\n   120→\n   121→\t// Resolve output mappings from wires and add as env vars\n   122→\tif len(e.Wires) > 0 {\n   123→\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n   124→\t\tif err != nil {\n   125→\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n   126→\t\t}\n   127→\t\tcmd.Env = append(cmd.Env, mapped...)\n   128→\t}\n   129→\n   130→\toutput, err := cmd.CombinedOutput()\n   131→\n   132→\t// Extract result marker\n   133→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n   134→\n   135→\t// Write output to file\n   136→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   137→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   138→\t}\n   139→\n   140→\tif err != nil {\n   141→\t\tif _, ok := err.(*exec.ExitError); ok {\n   142→\t\t\tresult := \"fail\"\n   143→\t\t\tif found {\n   144→\t\t\t\tresult = markerResult\n   145→\t\t\t}\n   146→\t\t\treturn result, nil\n   147→\t\t}\n   148→\t\treturn \"\", err\n   149→\t}\n   150→\n   151→\tresult := \"success\"\n   152→\tif found {\n   153→\t\tresult = markerResult\n   154→\t}\n   155→\treturn result, nil\n   156→}\n   157→\n   158→// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   159→func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   160→\tworkflowName := step.Config[\"workflow_name\"]\n   161→\tif workflowName == \"\" {\n   162→\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   163→\t}\n   164→\n   165→\t// Read prompt from previous step output or prompt_step override\n   166→\tvar promptContent string\n   167→\tpromptSource := step.Config[\"prompt_step\"]\n   168→\tif promptSource != \"\" {\n   169→\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   170→\t\tif err == nil {\n   171→\t\t\tpromptContent = string(data)\n   172→\t\t}\n   173→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   174→\t\tdata, err := os.ReadFile(prev)\n   175→\t\tif err == nil {\n   176→\t\t\tpromptContent = string(data)\n   177→\t\t}\n   178→\t}\n   179→\n   180→\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   181→\t\tWorkflowName: workflowName,\n   182→\t\tProjectDir:   e.ProjectDir,\n   183→\t\tPrompt:       promptContent,\n   184→\t})\n   185→\tif err != nil {\n   186→\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   187→\t}\n   188→\n   189→\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   190→\n   191→\t// Link child run to parent host run and store in run context\n   192→\tif e.HostRunID != \"\" {\n   193→\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n   194→\t\t\tchildRun.ParentRunID = e.HostRunID\n   195→\t\t\tchildRun.TaskID = e.TaskID\n   196→\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n   197→\t\t}\n   198→\t\t// Store child run ID in context so downstream steps can retrieve it\n   199→\t\t// via \"cloche get child_run_id\"\n   200→\t\t_ = runcontext.Set(e.ProjectDir, e.HostRunID, \"child_run_id\", resp.RunId)\n   201→\t}\n   202→\n   203→\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n   204→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   205→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n   206→\t}\n   207→\n   208→\t// Poll until the run reaches a terminal state\n   209→\tstate, err := e.waitForRun(ctx, resp.RunId)\n   210→\tif err != nil {\n   211→\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   212→\t}\n   213→\n   214→\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   215→\n   216→\t// Map run state to step result\n   217→\tif state == domain.RunStateSucceeded {\n   218→\t\treturn \"success\", nil\n   219→\t}\n   220→\treturn \"fail\", nil\n   221→}\n   222→\n   223→// executeAgent runs an agent command on the host using the prompt adapter.\n   224→func (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n   225→\tadapter := prompt.New()\n   226→\n   227→\t// Apply workflow-level agent config\n   228→\tif len(e.AgentCommands) > 0 {\n   229→\t\tadapter.Commands = e.AgentCommands\n   230→\t}\n   231→\tif len(e.AgentArgs) > 0 {\n   232→\t\tadapter.ExplicitArgs = e.AgentArgs\n   233→\t}\n   234→\n   235→\t// Step-level overrides\n   236→\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   237→\t\tadapter.Commands = prompt.ParseCommands(cmd)\n   238→\t}\n   239→\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   240→\t\tadapter.ExplicitArgs = strings.Fields(args)\n   241→\t}\n   242→\n   243→\tadapter.RunID = e.HostRunID\n   244→\n   245→\t// Write previous step output as user prompt so the adapter can pick it up.\n   246→\tvar promptContent string\n   247→\tpromptSource := step.Config[\"prompt_step\"]\n   248→\tif promptSource != \"\" {\n   249→\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n   250→\t\t\tpromptContent = string(data)\n   251→\t\t}\n   252→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   253→\t\tif data, err := os.ReadFile(prev); err == nil {\n   254→\t\t\tpromptContent = string(data)\n   255→\t\t}\n   256→\t}\n   257→\n   258→\tif promptContent != \"\" {\n   259→\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n   260→\t\t_ = os.MkdirAll(promptDir, 0755)\n   261→\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n   262→\t}\n   263→\n   264→\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n   265→\tif err != nil {\n   266→\t\treturn \"\", err\n   267→\t}\n   268→\n   269→\t// Copy output from adapter's output location to executor's output path\n   270→\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n   271→\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n   272→\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   273→\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n   274→\t\t}\n   275→\t}\n   276→\n   277→\treturn result, nil\n   278→}\n   279→\n   280→// waitForRun polls the store until the run reaches a terminal state.\n   281→func (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   282→\tticker := time.NewTicker(2 * time.Second)\n   283→\tdefer ticker.Stop()\n   284→\n   285→\tfor {\n   286→\t\tselect {\n   287→\t\tcase <-ctx.Done():\n   288→\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   289→\t\tcase <-ticker.C:\n   290→\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   291→\t\t\tif err != nil {\n   292→\t\t\t\tcontinue // transient error, retry\n   293→\t\t\t}\n   294→\t\t\tswitch run.State {\n   295→\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   296→\t\t\t\treturn run.State, nil\n   297→\t\t\t}\n   298→\t\t\t// Still pending or running, continue polling\n   299→\t\t}\n   300→\t}\n   301→}\n   302→\n   303→// stepOutputPath returns the path for a step's output file.\n   304→func (e *Executor) stepOutputPath(stepName string) string {\n   305→\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   306→}\n   307→\n   308→// findPrevOutput finds the output file from the step that wires into this one.\n   309→// It checks prompt_step config first, then walks the wiring graph to find the\n   310→// source step.\n   311→func (e *Executor) findPrevOutput(step *domain.Step) string {\n   312→\t// Explicit prompt_step config takes priority\n   313→\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   314→\t\tpath := e.stepOutputPath(ps)\n   315→\t\tif _, err := os.Stat(path); err == nil {\n   316→\t\t\treturn path\n   317→\t\t}\n   318→\t}\n   319→\n   320→\t// Walk wiring to find the step that feeds into this one\n   321→\tfor _, w := range e.Wires {\n   322→\t\tif w.To == step.Name {\n   323→\t\t\tpath := e.stepOutputPath(w.From)\n   324→\t\t\tif _, err := os.Stat(path); err == nil {\n   325→\t\t\t\treturn path\n   326→\t\t\t}\n   327→\t\t}\n   328→\t}\n   329→\treturn \"\"\n   330→}\n   331→\n   332→// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n   333→// the repository containing projectDir. If projectDir is already the main\n   334→// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n   335→// error (e.g. not a git repo).\n   336→func MainWorktreeDir(projectDir string) string {\n   337→\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n   338→\tout, err := cmd.Output()\n   339→\tif err != nil {\n   340→\t\treturn projectDir\n   341→\t}\n   342→\t// The first \"worktree <path>\" line is always the main worktree.\n   343→\tfor _, line := range strings.Split(string(out), \"\\n\") {\n   344→\t\tif strings.HasPrefix(line, \"worktree \") {\n   345→\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n   346→\t\t}\n   347→\t}\n   348→\treturn projectDir\n   349→}\n   350→"}]},"parent_tool_use_id":null,"session_id":"a767d320-7441-4cfb-80d2-26edf647ec06","uuid":"fbbc8fae-8d70-4657-be6e-50f5a88d86c1","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n)\n\n// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n// reads the source step's output, evaluates each mapping path, and returns KEY=value\n// strings suitable for adding to a command's environment.\nfunc (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n\tvar env []string\n\tfor _, w := range wires {\n\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n\t\t}\n\t\tfor _, m := range w.OutputMap {\n\t\t\tval, err := m.Path.Evaluate(data)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n\t\t\t}\n\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n\t\t}\n\t}\n\treturn env, nil\n}\n\n// RunDispatcher dispatches a container workflow run and returns the run ID.\ntype RunDispatcher interface {\n\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n}\n\n// Executor implements engine.StepExecutor for host workflow steps.\ntype Executor struct {\n\tProjectDir    string\n\tMainDir       string         // main branch worktree dir; scripts execute from here\n\tDispatcher    RunDispatcher\n\tStore         ports.RunStore\n\tOutputDir     string         // directory for step output files\n\tWires         []domain.Wire  // workflow wiring (for output mappings)\n\tHostRunID     string         // ID of the parent host run (set on child runs)\n\tAgentCommands []string       // workflow-level agent command fallback chain\n\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n\tTaskID        string         // optional task ID assigned by the daemon loop\n\tExtraEnv      []string       // additional KEY=VALUE env vars for all steps\n}\n\n// scriptDir returns the directory from which scripts should execute.\n// Uses MainDir if set, otherwise falls back to ProjectDir.\nfunc (e *Executor) scriptDir() string {\n\tif e.MainDir != \"\" {\n\t\treturn e.MainDir\n\t}\n\treturn e.ProjectDir\n}\n\nvar _ engine.StepExecutor = (*Executor)(nil)\n\n// Execute runs a single host workflow step.\nfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\treturn e.executeScript(ctx, step)\n\tcase domain.StepTypeWorkflow:\n\t\treturn e.executeWorkflow(ctx, step)\n\tcase domain.StepTypeAgent:\n\t\treturn e.executeAgent(ctx, step)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n\t}\n}\n\n// executeScript runs a shell command on the host.\nfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n\tcmdStr := step.Config[\"run\"]\n\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n\tcmd.Dir = e.scriptDir()\n\tcmd.Env = append(os.Environ(),\n\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n\t)\n\n\t// Pass run ID so steps can access .cloche/<run-id>/ and context.json\n\tif e.HostRunID != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_RUN_ID=\"+e.HostRunID)\n\t}\n\n\t// Pass daemon-assigned task ID if available\n\tif e.TaskID != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_TASK_ID=\"+e.TaskID)\n\t}\n\n\t// Pass extra env vars (e.g. finalize phase outcome vars)\n\tif len(e.ExtraEnv) > 0 {\n\t\tcmd.Env = append(cmd.Env, e.ExtraEnv...)\n\t}\n\n\t// Pass previous step output if available\n\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n\t}\n\n\t// Resolve output mappings from wires and add as env vars\n\tif len(e.Wires) > 0 {\n\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n\t\t}\n\t\tcmd.Env = append(cmd.Env, mapped...)\n\t}\n\n\toutput, err := cmd.CombinedOutput()\n\n\t// Extract result marker\n\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n\n\t// Write output to file\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n\t}\n\n\tif err != nil {\n\t\tif _, ok := err.(*exec.ExitError); ok {\n\t\t\tresult := \"fail\"\n\t\t\tif found {\n\t\t\t\tresult = markerResult\n\t\t\t}\n\t\t\treturn result, nil\n\t\t}\n\t\treturn \"\", err\n\t}\n\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, nil\n}\n\n// executeWorkflow dispatches a container workflow run and blocks until it completes.\nfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n\tworkflowName := step.Config[\"workflow_name\"]\n\tif workflowName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n\t}\n\n\t// Read prompt from previous step output or prompt_step override\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tdata, err := os.ReadFile(prev)\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName: workflowName,\n\t\tProjectDir:   e.ProjectDir,\n\t\tPrompt:       promptContent,\n\t})\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n\t}\n\n\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n\n\t// Link child run to parent host run and store in run context\n\tif e.HostRunID != \"\" {\n\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n\t\t\tchildRun.ParentRunID = e.HostRunID\n\t\t\tchildRun.TaskID = e.TaskID\n\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n\t\t}\n\t\t// Store child run ID in context so downstream steps can retrieve it\n\t\t// via \"cloche get child_run_id\"\n\t\t_ = runcontext.Set(e.ProjectDir, e.HostRunID, \"child_run_id\", resp.RunId)\n\t}\n\n\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n\t}\n\n\t// Poll until the run reaches a terminal state\n\tstate, err := e.waitForRun(ctx, resp.RunId)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n\t}\n\n\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n\n\t// Map run state to step result\n\tif state == domain.RunStateSucceeded {\n\t\treturn \"success\", nil\n\t}\n\treturn \"fail\", nil\n}\n\n// executeAgent runs an agent command on the host using the prompt adapter.\nfunc (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n\tadapter := prompt.New()\n\n\t// Apply workflow-level agent config\n\tif len(e.AgentCommands) > 0 {\n\t\tadapter.Commands = e.AgentCommands\n\t}\n\tif len(e.AgentArgs) > 0 {\n\t\tadapter.ExplicitArgs = e.AgentArgs\n\t}\n\n\t// Step-level overrides\n\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n\t\tadapter.Commands = prompt.ParseCommands(cmd)\n\t}\n\tif args := step.Config[\"agent_args\"]; args != \"\" {\n\t\tadapter.ExplicitArgs = strings.Fields(args)\n\t}\n\n\tadapter.RunID = e.HostRunID\n\n\t// Write previous step output as user prompt so the adapter can pick it up.\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tif data, err := os.ReadFile(prev); err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tif promptContent != \"\" {\n\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n\t\t_ = os.MkdirAll(promptDir, 0755)\n\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n\t}\n\n\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\t// Copy output from adapter's output location to executor's output path\n\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\n// waitForRun polls the store until the run reaches a terminal state.\nfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n\tticker := time.NewTicker(2 * time.Second)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n\t\tcase <-ticker.C:\n\t\t\trun, err := e.Store.GetRun(ctx, runID)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // transient error, retry\n\t\t\t}\n\t\t\tswitch run.State {\n\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n\t\t\t\treturn run.State, nil\n\t\t\t}\n\t\t\t// Still pending or running, continue polling\n\t\t}\n\t}\n}\n\n// stepOutputPath returns the path for a step's output file.\nfunc (e *Executor) stepOutputPath(stepName string) string {\n\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n}\n\n// findPrevOutput finds the output file from the step that wires into this one.\n// It checks prompt_step config first, then walks the wiring graph to find the\n// source step.\nfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n\t// Explicit prompt_step config takes priority\n\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n\t\tpath := e.stepOutputPath(ps)\n\t\tif _, err := os.Stat(path); err == nil {\n\t\t\treturn path\n\t\t}\n\t}\n\n\t// Walk wiring to find the step that feeds into this one\n\tfor _, w := range e.Wires {\n\t\tif w.To == step.Name {\n\t\t\tpath := e.stepOutputPath(w.From)\n\t\t\tif _, err := os.Stat(path); err == nil {\n\t\t\t\treturn path\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n// the repository containing projectDir. If projectDir is already the main\n// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n// error (e.g. not a git repo).\nfunc MainWorktreeDir(projectDir string) string {\n\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn projectDir\n\t}\n\t// The first \"worktree <path>\" line is always the main worktree.\n\tfor _, line := range strings.Split(string(out), \"\\n\") {\n\t\tif strings.HasPrefix(line, \"worktree \") {\n\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n\t\t}\n\t}\n\treturn projectDir\n}\n","numLines":350,"startLine":1,"totalLines":350}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01LeK2p4Luo8Rn23sUuxkHU3","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GVzDwPnsbXDDztVo4jfei1","name":"Read","input":{"file_path":"/workspace/internal/adapters/agents/prompt/prompt.go"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":32745,"cache_read_input_tokens":23834,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":32745},"output_tokens":9,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a767d320-7441-4cfb-80d2-26edf647ec06","uuid":"46bd1061-5161-4002-9bd6-70924dc2c7a8"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GVzDwPnsbXDDztVo4jfei1","type":"tool_result","content":"     1→package prompt\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"bytes\"\n     6→\t\"context\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strconv\"\n    13→\t\"strings\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17→)\n    18→\n    19→// defaultAgentArgs maps known agent commands to their default arguments.\n    20→// Commands not in this map receive no default arguments (prompt on stdin only).\n    21→var defaultAgentArgs = map[string][]string{\n    22→\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n    23→}\n    24→\n    25→type Adapter struct {\n    26→\tCommands     []string // ordered fallback chain of agent commands\n    27→\tExplicitArgs []string // if non-nil, overrides default args for all commands\n    28→\tRunID        string\n    29→\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n    30→}\n    31→\n    32→func New() *Adapter {\n    33→\treturn &Adapter{\n    34→\t\tCommands: []string{\"claude\"},\n    35→\t}\n    36→}\n    37→\n    38→func (a *Adapter) Name() string {\n    39→\treturn \"prompt\"\n    40→}\n    41→\n    42→// argsFor returns the arguments for the given command. If ExplicitArgs is set,\n    43→// it is used for all commands. Otherwise, known agents get their default args.\n    44→func (a *Adapter) argsFor(command string) []string {\n    45→\tif a.ExplicitArgs != nil {\n    46→\t\treturn a.ExplicitArgs\n    47→\t}\n    48→\tif args, ok := defaultAgentArgs[command]; ok {\n    49→\t\treturn args\n    50→\t}\n    51→\treturn nil\n    52→}\n    53→\n    54→// ParseCommands splits a comma-separated agent_command string into individual\n    55→// command names, trimming whitespace from each entry.\n    56→func ParseCommands(s string) []string {\n    57→\tparts := strings.Split(s, \",\")\n    58→\tvar cmds []string\n    59→\tfor _, p := range parts {\n    60→\t\tp = strings.TrimSpace(p)\n    61→\t\tif p != \"\" {\n    62→\t\t\tcmds = append(cmds, p)\n    63→\t\t}\n    64→\t}\n    65→\treturn cmds\n    66→}\n    67→\n    68→func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    69→\t// Check attempt count for retry limiting\n    70→\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n    71→\t\tmax, err := strconv.Atoi(maxStr)\n    72→\t\tif err == nil {\n    73→\t\t\tcount := readAttemptCount(workDir, step.Name)\n    74→\t\t\tif count >= max {\n    75→\t\t\t\treturn \"give-up\", nil\n    76→\t\t\t}\n    77→\t\t}\n    78→\t}\n    79→\tincrementAttemptCount(workDir, step.Name)\n    80→\n    81→\t// Build the full prompt\n    82→\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n    83→\tif err != nil {\n    84→\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n    85→\t}\n    86→\n    87→\t// Try each command in the fallback chain\n    88→\tvar lastResult string\n    89→\tvar lastStdout []byte\n    90→\tvar lastErr error\n    91→\tran := false\n    92→\n    93→\tfor _, command := range a.Commands {\n    94→\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n    95→\t\tlastResult = result\n    96→\t\tlastStdout = stdout\n    97→\t\tlastErr = fallbackErr\n    98→\n    99→\t\tif fallbackErr == nil {\n   100→\t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n   101→\t\t\tbreak\n   102→\t\t}\n   103→\t\tif stdout != nil {\n   104→\t\t\tran = true\n   105→\t\t}\n   106→\t\t// Fallback-eligible — try next command\n   107→\t}\n   108→\n   109→\tif lastErr != nil && !ran && lastStdout == nil {\n   110→\t\t// All commands failed to produce any output (e.g., all not found)\n   111→\t\treturn \"\", lastErr\n   112→\t}\n   113→\n   114→\tresult := lastResult\n   115→\tif lastErr != nil {\n   116→\t\t// Last command in chain crashed without a result marker\n   117→\t\tresult = \"fail\"\n   118→\t}\n   119→\n   120→\t// Reset attempt counter on success so give-up only triggers after\n   121→\t// consecutive failures, not after successful fixes whose downstream\n   122→\t// tests fail for unrelated reasons.\n   123→\tif result == \"success\" {\n   124→\t\tresetAttemptCount(workDir, step.Name)\n   125→\t}\n   126→\n   127→\t// Write output file\n   128→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   129→\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n   130→\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n   131→\t}\n   132→\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n   133→\treturn result, nil\n   134→}\n   135→\n   136→// tryCommand executes a single agent command and returns:\n   137→//   - result: the step result name (e.g. \"success\", \"fail\")\n   138→//   - stdout: captured stdout bytes\n   139→//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n   140→//\n   141→// Fallback-eligible conditions:\n   142→//   - Command not found or failed to start (stdout will be nil)\n   143→//   - Command exited non-zero without a CLOCHE_RESULT marker\n   144→//\n   145→// Definitive (non-fallback) conditions:\n   146→//   - Command exited 0\n   147→//   - Command exited non-zero but produced a CLOCHE_RESULT marker\n   148→func (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n   149→\targs := a.argsFor(command)\n   150→\tcmd := exec.CommandContext(ctx, command, args...)\n   151→\tcmd.Dir = workDir\n   152→\tcmd.Stdin = strings.NewReader(prompt)\n   153→\n   154→\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n   155→\tif a.StatusWriter == nil {\n   156→\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n   157→\t\tcmd.Stdout = &stdoutBuf\n   158→\t\tcmd.Stderr = &stderrBuf\n   159→\n   160→\t\trunErr := cmd.Run()\n   161→\t\tstdoutBytes := stdoutBuf.Bytes()\n   162→\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n   163→\t}\n   164→\n   165→\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n   166→\tpipe, err := cmd.StdoutPipe()\n   167→\tif err != nil {\n   168→\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n   169→\t}\n   170→\tcmd.Stderr = nil // discard stderr\n   171→\n   172→\tif err := cmd.Start(); err != nil {\n   173→\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n   174→\t}\n   175→\n   176→\t// textBuf accumulates extracted text content for result extraction.\n   177→\t// rawBuf accumulates raw stdout for the output log file.\n   178→\tvar textBuf, rawBuf bytes.Buffer\n   179→\t// lineBuf accumulates text deltas into lines for streaming.\n   180→\tvar lineBuf strings.Builder\n   181→\n   182→\tscanner := bufio.NewScanner(pipe)\n   183→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n   184→\tfor scanner.Scan() {\n   185→\t\traw := scanner.Bytes()\n   186→\t\trawBuf.Write(raw)\n   187→\t\trawBuf.WriteByte('\\n')\n   188→\n   189→\t\ttext := extractStreamText(raw)\n   190→\t\tif text == \"\" {\n   191→\t\t\tcontinue\n   192→\t\t}\n   193→\t\ttextBuf.WriteString(text)\n   194→\n   195→\t\t// Stream complete lines to StatusWriter as they form.\n   196→\t\tlineBuf.WriteString(text)\n   197→\t\tfor {\n   198→\t\t\ts := lineBuf.String()\n   199→\t\t\tidx := strings.IndexByte(s, '\\n')\n   200→\t\t\tif idx < 0 {\n   201→\t\t\t\tbreak\n   202→\t\t\t}\n   203→\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n   204→\t\t\tlineBuf.Reset()\n   205→\t\t\tlineBuf.WriteString(s[idx+1:])\n   206→\t\t}\n   207→\t}\n   208→\t// Flush any remaining partial line.\n   209→\tif lineBuf.Len() > 0 {\n   210→\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n   211→\t}\n   212→\tif scanErr := scanner.Err(); scanErr != nil {\n   213→\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n   214→\t}\n   215→\n   216→\twaitErr := cmd.Wait()\n   217→\t// Prefer extracted text (stream-json) for result classification; fall back\n   218→\t// to raw output for non-JSON commands (scripts, non-claude agents).\n   219→\tclassifyBuf := textBuf.Bytes()\n   220→\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n   221→\t\tclassifyBuf = rawBuf.Bytes()\n   222→\t}\n   223→\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n   224→\treturn result, rawBuf.Bytes(), fallbackErr\n   225→}\n   226→\n   227→// classifyResult interprets the command's exit status and stdout to determine\n   228→// the step result.\n   229→func (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n   230→\tif runErr != nil {\n   231→\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n   232→\t\t\t// Command failed to start (not found, permission denied, etc.)\n   233→\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n   234→\t\t}\n   235→\t\t// Command ran but exited non-zero\n   236→\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   237→\t\tif found {\n   238→\t\t\treturn markerResult, stdoutBytes, nil\n   239→\t\t}\n   240→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n   241→\t}\n   242→\n   243→\t// Command succeeded (exit 0)\n   244→\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n   245→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n   246→\t}\n   247→\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   248→\tresult := \"success\"\n   249→\tif found {\n   250→\t\tresult = markerResult\n   251→\t}\n   252→\treturn result, stdoutBytes, nil\n   253→}\n   254→\n   255→// extractStreamText parses a Claude Code stream-json line and returns text content.\n   256→//\n   257→// Claude Code's stream-json emits these event types:\n   258→//   - \"assistant\": one per turn, contains message.content[] with text and tool_use blocks\n   259→//   - \"result\": final event with the full result text (contains CLOCHE_RESULT marker)\n   260→//\n   261→// For assistant events, we extract text blocks and summarize tool_use blocks\n   262→// (e.g. \"--- Tool: Read('path') ---\"). Each assistant event has a unique uuid\n   263→// for dedup by the caller.\n   264→func extractStreamText(line []byte) string {\n   265→\t// Fast path: skip lines that can't contain content we care about.\n   266→\tif !bytes.Contains(line, []byte(`\"type\"`)) {\n   267→\t\treturn \"\"\n   268→\t}\n   269→\n   270→\tvar envelope struct {\n   271→\t\tType string `json:\"type\"`\n   272→\t}\n   273→\tif json.Unmarshal(line, &envelope) != nil {\n   274→\t\treturn \"\"\n   275→\t}\n   276→\n   277→\tswitch envelope.Type {\n   278→\tcase \"assistant\":\n   279→\t\treturn extractAssistantText(line)\n   280→\tcase \"result\":\n   281→\t\treturn extractResultText(line)\n   282→\t}\n   283→\treturn \"\"\n   284→}\n   285→\n   286→// extractAssistantText extracts text and tool-use summaries from an assistant event.\n   287→func extractAssistantText(line []byte) string {\n   288→\tvar event struct {\n   289→\t\tMessage struct {\n   290→\t\t\tContent []struct {\n   291→\t\t\t\tType  string          `json:\"type\"`\n   292→\t\t\t\tText  string          `json:\"text\"`\n   293→\t\t\t\tName  string          `json:\"name\"`\n   294→\t\t\t\tInput json.RawMessage `json:\"input\"`\n   295→\t\t\t} `json:\"content\"`\n   296→\t\t} `json:\"message\"`\n   297→\t}\n   298→\tif json.Unmarshal(line, &event) != nil {\n   299→\t\treturn \"\"\n   300→\t}\n   301→\n   302→\tvar b strings.Builder\n   303→\tfor _, c := range event.Message.Content {\n   304→\t\tswitch c.Type {\n   305→\t\tcase \"text\":\n   306→\t\t\tif c.Text != \"\" {\n   307→\t\t\t\tb.WriteString(c.Text)\n   308→\t\t\t\tif !strings.HasSuffix(c.Text, \"\\n\") {\n   309→\t\t\t\t\tb.WriteByte('\\n')\n   310→\t\t\t\t}\n   311→\t\t\t}\n   312→\t\tcase \"tool_use\":\n   313→\t\t\tb.WriteString(\"--- Tool: \")\n   314→\t\t\tb.WriteString(c.Name)\n   315→\t\t\tb.WriteString(toolInputSummary(c.Input))\n   316→\t\t\tb.WriteString(\" ---\\n\")\n   317→\t\t}\n   318→\t}\n   319→\treturn b.String()\n   320→}\n   321→\n   322→// extractResultText extracts the final result text (contains CLOCHE_RESULT marker).\n   323→func extractResultText(line []byte) string {\n   324→\tif !bytes.Contains(line, []byte(`\"subtype\"`)) {\n   325→\t\treturn \"\"\n   326→\t}\n   327→\tvar event struct {\n   328→\t\tType   string `json:\"type\"`\n   329→\t\tResult string `json:\"result\"`\n   330→\t}\n   331→\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n   332→\t\treturn event.Result\n   333→\t}\n   334→\treturn \"\"\n   335→}\n   336→\n   337→// toolInputSummary returns a short parenthesized summary of a tool's input.\n   338→func toolInputSummary(input json.RawMessage) string {\n   339→\tif len(input) == 0 {\n   340→\t\treturn \"\"\n   341→\t}\n   342→\tvar m map[string]json.RawMessage\n   343→\tif json.Unmarshal(input, &m) != nil {\n   344→\t\treturn \"\"\n   345→\t}\n   346→\t// Pick the most informative single argument to show.\n   347→\tfor _, key := range []string{\"file_path\", \"command\", \"pattern\", \"prompt\", \"skill\"} {\n   348→\t\tif v, ok := m[key]; ok {\n   349→\t\t\tvar s string\n   350→\t\t\tif json.Unmarshal(v, &s) == nil {\n   351→\t\t\t\tif len(s) > 60 {\n   352→\t\t\t\t\ts = s[:57] + \"...\"\n   353→\t\t\t\t}\n   354→\t\t\t\treturn \"('\" + s + \"')\"\n   355→\t\t\t}\n   356→\t\t}\n   357→\t}\n   358→\treturn \"\"\n   359→}\n   360→\n   361→func assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n   362→\tvar parts []string\n   363→\n   364→\t// 1. Read system template from step config\n   365→\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n   366→\t\tcontent, err := resolveContent(tmpl, workDir)\n   367→\t\tif err != nil {\n   368→\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n   369→\t\t}\n   370→\t\tparts = append(parts, content)\n   371→\t}\n   372→\n   373→\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n   374→\tuserPrompt := readUserPrompt(workDir, runID)\n   375→\tif userPrompt != \"\" {\n   376→\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n   377→\t}\n   378→\n   379→\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n   380→\tif step.Config[\"feedback\"] == \"true\" {\n   381→\t\tfeedback := readFeedback(workDir)\n   382→\t\tif feedback != \"\" {\n   383→\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n   384→\t\t}\n   385→\t}\n   386→\n   387→\t// 4. Result selection instructions\n   388→\tif len(step.Results) > 0 {\n   389→\t\tvar resultLines []string\n   390→\t\tresultLines = append(resultLines, \"## Result Selection\")\n   391→\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n   392→\t\tfor _, r := range step.Results {\n   393→\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n   394→\t\t}\n   395→\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n   396→\t}\n   397→\n   398→\treturn strings.Join(parts, \"\\n\\n\"), nil\n   399→}\n   400→\n   401→// resolveContent handles file(\"path\") syntax or returns the string directly.\n   402→func resolveContent(value string, workDir string) (string, error) {\n   403→\t// Check for file(\"path\") syntax from DSL parser\n   404→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n   405→\t\tpath := value[6 : len(value)-2]\n   406→\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n   407→\t\tif err != nil {\n   408→\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n   409→\t\t}\n   410→\t\treturn string(data), nil\n   411→\t}\n   412→\treturn value, nil\n   413→}\n   414→\n   415→func readFeedback(workDir string) string {\n   416→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   417→\tentries, err := os.ReadDir(outputDir)\n   418→\tif err != nil {\n   419→\t\treturn \"\"\n   420→\t}\n   421→\n   422→\tvar parts []string\n   423→\tfor _, entry := range entries {\n   424→\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n   425→\t\t\tcontinue\n   426→\t\t}\n   427→\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n   428→\t\tif err != nil {\n   429→\t\t\tcontinue\n   430→\t\t}\n   431→\t\tcontent := strings.TrimSpace(string(data))\n   432→\t\tif content != \"\" {\n   433→\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n   434→\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n   435→\t\t}\n   436→\t}\n   437→\n   438→\treturn strings.Join(parts, \"\\n\\n\")\n   439→}\n   440→\n   441→func readAttemptCount(workDir, stepName string) int {\n   442→\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n   443→\tdata, err := os.ReadFile(path)\n   444→\tif err != nil {\n   445→\t\treturn 0\n   446→\t}\n   447→\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n   448→\treturn n\n   449→}\n   450→\n   451→// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\n   452→func readUserPrompt(workDir, runID string) string {\n   453→\tif runID == \"\" {\n   454→\t\treturn \"\"\n   455→\t}\n   456→\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   457→\tif data, err := os.ReadFile(path); err == nil {\n   458→\t\treturn string(data)\n   459→\t}\n   460→\treturn \"\"\n   461→}\n   462→\n   463→func resetAttemptCount(workDir, stepName string) {\n   464→\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n   465→\t_ = os.Remove(path)\n   466→}\n   467→\n   468→func incrementAttemptCount(workDir, stepName string) {\n   469→\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n   470→\t_ = os.MkdirAll(dir, 0755)\n   471→\tcount := readAttemptCount(workDir, stepName) + 1\n   472→\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n   473→}\n   474→"}]},"parent_tool_use_id":null,"session_id":"a767d320-7441-4cfb-80d2-26edf647ec06","uuid":"d8c0e90f-58a9-4f24-9667-e901eb17aafd","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/agents/prompt/prompt.go","content":"package prompt\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\n// defaultAgentArgs maps known agent commands to their default arguments.\n// Commands not in this map receive no default arguments (prompt on stdin only).\nvar defaultAgentArgs = map[string][]string{\n\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n}\n\ntype Adapter struct {\n\tCommands     []string // ordered fallback chain of agent commands\n\tExplicitArgs []string // if non-nil, overrides default args for all commands\n\tRunID        string\n\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n}\n\nfunc New() *Adapter {\n\treturn &Adapter{\n\t\tCommands: []string{\"claude\"},\n\t}\n}\n\nfunc (a *Adapter) Name() string {\n\treturn \"prompt\"\n}\n\n// argsFor returns the arguments for the given command. If ExplicitArgs is set,\n// it is used for all commands. Otherwise, known agents get their default args.\nfunc (a *Adapter) argsFor(command string) []string {\n\tif a.ExplicitArgs != nil {\n\t\treturn a.ExplicitArgs\n\t}\n\tif args, ok := defaultAgentArgs[command]; ok {\n\t\treturn args\n\t}\n\treturn nil\n}\n\n// ParseCommands splits a comma-separated agent_command string into individual\n// command names, trimming whitespace from each entry.\nfunc ParseCommands(s string) []string {\n\tparts := strings.Split(s, \",\")\n\tvar cmds []string\n\tfor _, p := range parts {\n\t\tp = strings.TrimSpace(p)\n\t\tif p != \"\" {\n\t\t\tcmds = append(cmds, p)\n\t\t}\n\t}\n\treturn cmds\n}\n\nfunc (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n\t// Check attempt count for retry limiting\n\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n\t\tmax, err := strconv.Atoi(maxStr)\n\t\tif err == nil {\n\t\t\tcount := readAttemptCount(workDir, step.Name)\n\t\t\tif count >= max {\n\t\t\t\treturn \"give-up\", nil\n\t\t\t}\n\t\t}\n\t}\n\tincrementAttemptCount(workDir, step.Name)\n\n\t// Build the full prompt\n\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n\t}\n\n\t// Try each command in the fallback chain\n\tvar lastResult string\n\tvar lastStdout []byte\n\tvar lastErr error\n\tran := false\n\n\tfor _, command := range a.Commands {\n\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n\t\tlastResult = result\n\t\tlastStdout = stdout\n\t\tlastErr = fallbackErr\n\n\t\tif fallbackErr == nil {\n\t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n\t\t\tbreak\n\t\t}\n\t\tif stdout != nil {\n\t\t\tran = true\n\t\t}\n\t\t// Fallback-eligible — try next command\n\t}\n\n\tif lastErr != nil && !ran && lastStdout == nil {\n\t\t// All commands failed to produce any output (e.g., all not found)\n\t\treturn \"\", lastErr\n\t}\n\n\tresult := lastResult\n\tif lastErr != nil {\n\t\t// Last command in chain crashed without a result marker\n\t\tresult = \"fail\"\n\t}\n\n\t// Reset attempt counter on success so give-up only triggers after\n\t// consecutive failures, not after successful fixes whose downstream\n\t// tests fail for unrelated reasons.\n\tif result == \"success\" {\n\t\tresetAttemptCount(workDir, step.Name)\n\t}\n\n\t// Write output file\n\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n\t}\n\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n\treturn result, nil\n}\n\n// tryCommand executes a single agent command and returns:\n//   - result: the step result name (e.g. \"success\", \"fail\")\n//   - stdout: captured stdout bytes\n//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n//\n// Fallback-eligible conditions:\n//   - Command not found or failed to start (stdout will be nil)\n//   - Command exited non-zero without a CLOCHE_RESULT marker\n//\n// Definitive (non-fallback) conditions:\n//   - Command exited 0\n//   - Command exited non-zero but produced a CLOCHE_RESULT marker\nfunc (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n\targs := a.argsFor(command)\n\tcmd := exec.CommandContext(ctx, command, args...)\n\tcmd.Dir = workDir\n\tcmd.Stdin = strings.NewReader(prompt)\n\n\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n\tif a.StatusWriter == nil {\n\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n\t\tcmd.Stdout = &stdoutBuf\n\t\tcmd.Stderr = &stderrBuf\n\n\t\trunErr := cmd.Run()\n\t\tstdoutBytes := stdoutBuf.Bytes()\n\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n\t}\n\n\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n\tpipe, err := cmd.StdoutPipe()\n\tif err != nil {\n\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n\t}\n\tcmd.Stderr = nil // discard stderr\n\n\tif err := cmd.Start(); err != nil {\n\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n\t}\n\n\t// textBuf accumulates extracted text content for result extraction.\n\t// rawBuf accumulates raw stdout for the output log file.\n\tvar textBuf, rawBuf bytes.Buffer\n\t// lineBuf accumulates text deltas into lines for streaming.\n\tvar lineBuf strings.Builder\n\n\tscanner := bufio.NewScanner(pipe)\n\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n\tfor scanner.Scan() {\n\t\traw := scanner.Bytes()\n\t\trawBuf.Write(raw)\n\t\trawBuf.WriteByte('\\n')\n\n\t\ttext := extractStreamText(raw)\n\t\tif text == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\ttextBuf.WriteString(text)\n\n\t\t// Stream complete lines to StatusWriter as they form.\n\t\tlineBuf.WriteString(text)\n\t\tfor {\n\t\t\ts := lineBuf.String()\n\t\t\tidx := strings.IndexByte(s, '\\n')\n\t\t\tif idx < 0 {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n\t\t\tlineBuf.Reset()\n\t\t\tlineBuf.WriteString(s[idx+1:])\n\t\t}\n\t}\n\t// Flush any remaining partial line.\n\tif lineBuf.Len() > 0 {\n\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n\t}\n\tif scanErr := scanner.Err(); scanErr != nil {\n\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n\t}\n\n\twaitErr := cmd.Wait()\n\t// Prefer extracted text (stream-json) for result classification; fall back\n\t// to raw output for non-JSON commands (scripts, non-claude agents).\n\tclassifyBuf := textBuf.Bytes()\n\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n\t\tclassifyBuf = rawBuf.Bytes()\n\t}\n\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n\treturn result, rawBuf.Bytes(), fallbackErr\n}\n\n// classifyResult interprets the command's exit status and stdout to determine\n// the step result.\nfunc (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n\tif runErr != nil {\n\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n\t\t\t// Command failed to start (not found, permission denied, etc.)\n\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n\t\t}\n\t\t// Command ran but exited non-zero\n\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n\t\tif found {\n\t\t\treturn markerResult, stdoutBytes, nil\n\t\t}\n\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n\t}\n\n\t// Command succeeded (exit 0)\n\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n\t}\n\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, stdoutBytes, nil\n}\n\n// extractStreamText parses a Claude Code stream-json line and returns text content.\n//\n// Claude Code's stream-json emits these event types:\n//   - \"assistant\": one per turn, contains message.content[] with text and tool_use blocks\n//   - \"result\": final event with the full result text (contains CLOCHE_RESULT marker)\n//\n// For assistant events, we extract text blocks and summarize tool_use blocks\n// (e.g. \"--- Tool: Read('path') ---\"). Each assistant event has a unique uuid\n// for dedup by the caller.\nfunc extractStreamText(line []byte) string {\n\t// Fast path: skip lines that can't contain content we care about.\n\tif !bytes.Contains(line, []byte(`\"type\"`)) {\n\t\treturn \"\"\n\t}\n\n\tvar envelope struct {\n\t\tType string `json:\"type\"`\n\t}\n\tif json.Unmarshal(line, &envelope) != nil {\n\t\treturn \"\"\n\t}\n\n\tswitch envelope.Type {\n\tcase \"assistant\":\n\t\treturn extractAssistantText(line)\n\tcase \"result\":\n\t\treturn extractResultText(line)\n\t}\n\treturn \"\"\n}\n\n// extractAssistantText extracts text and tool-use summaries from an assistant event.\nfunc extractAssistantText(line []byte) string {\n\tvar event struct {\n\t\tMessage struct {\n\t\t\tContent []struct {\n\t\t\t\tType  string          `json:\"type\"`\n\t\t\t\tText  string          `json:\"text\"`\n\t\t\t\tName  string          `json:\"name\"`\n\t\t\t\tInput json.RawMessage `json:\"input\"`\n\t\t\t} `json:\"content\"`\n\t\t} `json:\"message\"`\n\t}\n\tif json.Unmarshal(line, &event) != nil {\n\t\treturn \"\"\n\t}\n\n\tvar b strings.Builder\n\tfor _, c := range event.Message.Content {\n\t\tswitch c.Type {\n\t\tcase \"text\":\n\t\t\tif c.Text != \"\" {\n\t\t\t\tb.WriteString(c.Text)\n\t\t\t\tif !strings.HasSuffix(c.Text, \"\\n\") {\n\t\t\t\t\tb.WriteByte('\\n')\n\t\t\t\t}\n\t\t\t}\n\t\tcase \"tool_use\":\n\t\t\tb.WriteString(\"--- Tool: \")\n\t\t\tb.WriteString(c.Name)\n\t\t\tb.WriteString(toolInputSummary(c.Input))\n\t\t\tb.WriteString(\" ---\\n\")\n\t\t}\n\t}\n\treturn b.String()\n}\n\n// extractResultText extracts the final result text (contains CLOCHE_RESULT marker).\nfunc extractResultText(line []byte) string {\n\tif !bytes.Contains(line, []byte(`\"subtype\"`)) {\n\t\treturn \"\"\n\t}\n\tvar event struct {\n\t\tType   string `json:\"type\"`\n\t\tResult string `json:\"result\"`\n\t}\n\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n\t\treturn event.Result\n\t}\n\treturn \"\"\n}\n\n// toolInputSummary returns a short parenthesized summary of a tool's input.\nfunc toolInputSummary(input json.RawMessage) string {\n\tif len(input) == 0 {\n\t\treturn \"\"\n\t}\n\tvar m map[string]json.RawMessage\n\tif json.Unmarshal(input, &m) != nil {\n\t\treturn \"\"\n\t}\n\t// Pick the most informative single argument to show.\n\tfor _, key := range []string{\"file_path\", \"command\", \"pattern\", \"prompt\", \"skill\"} {\n\t\tif v, ok := m[key]; ok {\n\t\t\tvar s string\n\t\t\tif json.Unmarshal(v, &s) == nil {\n\t\t\t\tif len(s) > 60 {\n\t\t\t\t\ts = s[:57] + \"...\"\n\t\t\t\t}\n\t\t\t\treturn \"('\" + s + \"')\"\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n\nfunc assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n\tvar parts []string\n\n\t// 1. Read system template from step config\n\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n\t\tcontent, err := resolveContent(tmpl, workDir)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n\t\t}\n\t\tparts = append(parts, content)\n\t}\n\n\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n\tuserPrompt := readUserPrompt(workDir, runID)\n\tif userPrompt != \"\" {\n\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n\t}\n\n\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n\tif step.Config[\"feedback\"] == \"true\" {\n\t\tfeedback := readFeedback(workDir)\n\t\tif feedback != \"\" {\n\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n\t\t}\n\t}\n\n\t// 4. Result selection instructions\n\tif len(step.Results) > 0 {\n\t\tvar resultLines []string\n\t\tresultLines = append(resultLines, \"## Result Selection\")\n\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n\t\tfor _, r := range step.Results {\n\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n\t\t}\n\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n\t}\n\n\treturn strings.Join(parts, \"\\n\\n\"), nil\n}\n\n// resolveContent handles file(\"path\") syntax or returns the string directly.\nfunc resolveContent(value string, workDir string) (string, error) {\n\t// Check for file(\"path\") syntax from DSL parser\n\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n\t\tpath := value[6 : len(value)-2]\n\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n\t\t}\n\t\treturn string(data), nil\n\t}\n\treturn value, nil\n}\n\nfunc readFeedback(workDir string) string {\n\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\n\tvar parts []string\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tcontent := strings.TrimSpace(string(data))\n\t\tif content != \"\" {\n\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n\t\t}\n\t}\n\n\treturn strings.Join(parts, \"\\n\\n\")\n}\n\nfunc readAttemptCount(workDir, stepName string) int {\n\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n\tdata, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn 0\n\t}\n\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n\treturn n\n}\n\n// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\nfunc readUserPrompt(workDir, runID string) string {\n\tif runID == \"\" {\n\t\treturn \"\"\n\t}\n\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n\tif data, err := os.ReadFile(path); err == nil {\n\t\treturn string(data)\n\t}\n\treturn \"\"\n}\n\nfunc resetAttemptCount(workDir, stepName string) {\n\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n\t_ = os.Remove(path)\n}\n\nfunc incrementAttemptCount(workDir, stepName string) {\n\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n\t_ = os.MkdirAll(dir, 0755)\n\tcount := readAttemptCount(workDir, stepName) + 1\n\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n}\n","numLines":474,"startLine":1,"totalLines":474}}}
