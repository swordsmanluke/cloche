{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FmE72apepa1hyfa5ntY4B3","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"sort\"\n    13→\t\"strconv\"\n    14→\t\"strings\"\n    15→\t\"sync\"\n    16→\t\"time\"\n    17→\n    18→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    20→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    21→\t\"github.com/cloche-dev/cloche/internal/config\"\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    24→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    25→\t\"github.com/cloche-dev/cloche/internal/host\"\n    26→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    27→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    28→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    29→\t\"github.com/cloche-dev/cloche/internal/version\"\n    30→\trpcgrpc \"google.golang.org/grpc\"\n    31→\t\"google.golang.org/grpc/metadata\"\n    32→)\n    33→\n    34→type ClocheServer struct {\n    35→\tpb.UnimplementedClocheServiceServer\n    36→\tstore        ports.RunStore\n    37→\tcaptures     ports.CaptureStore\n    38→\tlogStore     ports.LogStore\n    39→\tcontainer    ports.ContainerRuntime\n    40→\tdefaultImage string\n    41→\tevolution    *evolution.Trigger\n    42→\tlogBroadcast *logstream.Broadcaster\n    43→\tshutdownFn   func()\n    44→\tmu           sync.Mutex\n    45→\trunIDs       map[string]string      // run_id -> container_id\n    46→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    47→}\n    48→\n    49→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    50→\treturn &ClocheServer{\n    51→\t\tstore:     store,\n    52→\t\tcontainer: container,\n    53→\t\trunIDs:    make(map[string]string),\n    54→\t\tloops:     make(map[string]*host.Loop),\n    55→\t}\n    56→}\n    57→\n    58→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    59→\treturn &ClocheServer{\n    60→\t\tstore:        store,\n    61→\t\tcaptures:     captures,\n    62→\t\tcontainer:    container,\n    63→\t\tdefaultImage: defaultImage,\n    64→\t\trunIDs:       make(map[string]string),\n    65→\t\tloops:        make(map[string]*host.Loop),\n    66→\t}\n    67→}\n    68→\n    69→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    70→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    71→\ts.logStore = ls\n    72→}\n    73→\n    74→\n    75→// SetEvolution attaches an evolution trigger to the server.\n    76→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    77→\ts.evolution = trigger\n    78→}\n    79→\n    80→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    81→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    82→\ts.logBroadcast = b\n    83→}\n    84→\n    85→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    86→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    87→\ts.shutdownFn = fn\n    88→}\n    89→\n    90→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    91→\t// Check if this is a host workflow (has host {} block).\n    92→\tif hostWFs, err := host.FindHostWorkflows(req.ProjectDir); err == nil {\n    93→\t\tif _, isHost := hostWFs[req.WorkflowName]; isHost {\n    94→\t\t\treturn s.runHostWorkflow(ctx, req)\n    95→\t\t}\n    96→\t}\n    97→\n    98→\tif s.container == nil {\n    99→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   100→\t}\n   101→\n   102→\t// Generate a unique run ID, retrying on collision\n   103→\tvar runID string\n   104→\tfor attempts := 0; attempts < 10; attempts++ {\n   105→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n   106→\t\texisting, err := s.store.GetRun(ctx, runID)\n   107→\t\tif err != nil {\n   108→\t\t\tbreak // ID is free\n   109→\t\t}\n   110→\t\t// Reuse if completed more than 1 hour ago\n   111→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   112→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   113→\t\t\tbreak\n   114→\t\t}\n   115→\t}\n   116→\n   117→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   118→\tif req.Prompt != \"\" {\n   119→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   120→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   121→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   122→\t\t}\n   123→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   124→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   125→\t\t}\n   126→\t}\n   127→\trun := domain.NewRun(runID, req.WorkflowName)\n   128→\trun.ProjectDir = req.ProjectDir\n   129→\trun.Title = req.Title\n   130→\trun.TaskID = req.IssueId\n   131→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   132→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   133→\t}\n   134→\n   135→\t// Resolve image: request-level override, then server default\n   136→\timage := req.Image\n   137→\tif image == \"\" {\n   138→\t\timage = s.defaultImage\n   139→\t}\n   140→\n   141→\t// Launch container start + tracking in background so the RPC returns immediately.\n   142→\t// The run stays in \"pending\" state until the container is up.\n   143→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   144→\n   145→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   146→}\n   147→\n   148→// runHostWorkflow dispatches a host workflow via the host runner, returning\n   149→// immediately while the workflow runs in a background goroutine.\n   150→func (s *ClocheServer) runHostWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n   151→\trunID := domain.GenerateRunID(req.WorkflowName)\n   152→\n   153→\trunner := &host.Runner{\n   154→\t\tDispatcher:   s,\n   155→\t\tStore:        s.store,\n   156→\t\tCaptures:     s.captures,\n   157→\t\tLogBroadcast: s.logBroadcast,\n   158→\t\tTaskID:       req.IssueId,\n   159→\t}\n   160→\n   161→\tgo func() {\n   162→\t\trunner.RunNamedWithID(context.Background(), req.ProjectDir, req.WorkflowName, runID)\n   163→\t}()\n   164→\n   165→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   166→}\n   167→\n   168→// launchAndTrack starts the container and then tracks it to completion.\n   169→// It runs in a background goroutine with its own context, independent of the\n   170→// RPC context which may be cancelled after RunWorkflow returns.\n   171→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   172→\tctx := context.Background()\n   173→\n   174→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   175→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   176→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   177→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   178→\t\t\tif run != nil {\n   179→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   180→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   181→\t\t\t}\n   182→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   183→\t\t\t\treturn\n   184→\t\t}\n   185→\t}\n   186→\n   187→\tbaseSHA := gitHEAD(req.ProjectDir)\n   188→\n   189→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   190→\t\tImage:        image,\n   191→\t\tWorkflowName: req.WorkflowName,\n   192→\t\tProjectDir:   req.ProjectDir,\n   193→\t\tRunID:        runID,\n   194→\t\tNetworkAllow: []string{\"*\"},\n   195→\t})\n   196→\tif err != nil {\n   197→\t\trun, _ := s.store.GetRun(ctx, runID)\n   198→\t\tif run != nil {\n   199→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   200→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   201→\t\t}\n   202→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   203→\t\treturn\n   204→\t}\n   205→\n   206→\ts.mu.Lock()\n   207→\ts.runIDs[runID] = containerID\n   208→\ts.mu.Unlock()\n   209→\n   210→\trun, _ := s.store.GetRun(ctx, runID)\n   211→\tif run != nil {\n   212→\t\trun.Start()\n   213→\t\trun.ContainerID = containerID\n   214→\t\trun.BaseSHA = baseSHA\n   215→\t\t_ = s.store.UpdateRun(ctx, run)\n   216→\t}\n   217→\n   218→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   219→}\n   220→\n   221→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   222→\tctx := context.Background()\n   223→\n   224→\t// Attach to agent output\n   225→\treader, err := s.container.AttachOutput(ctx, containerID)\n   226→\tif err != nil {\n   227→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   228→\t\t\treturn\n   229→\t}\n   230→\n   231→\t// Parse JSON-lines status messages\n   232→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   233→\tvar reportedError string  // captured from MsgError, used to set ErrorMessage on failed runs\n   234→\tscanner := bufio.NewScanner(reader)\n   235→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   236→\tfor scanner.Scan() {\n   237→\t\tvar msg protocol.StatusMessage\n   238→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   239→\t\t\tcontinue\n   240→\t\t}\n   241→\n   242→\t\t// Fast path: log messages don't need store interaction.\n   243→\t\tif msg.Type == protocol.MsgLog {\n   244→\t\t\tif s.logBroadcast != nil {\n   245→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   246→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   247→\t\t\t\t\tType:      \"llm\",\n   248→\t\t\t\t\tContent:   msg.Message,\n   249→\t\t\t\t\tStepName:  msg.StepName,\n   250→\t\t\t\t})\n   251→\t\t\t}\n   252→\t\t\tcontinue\n   253→\t\t}\n   254→\n   255→\t\trun, err := s.store.GetRun(ctx, runID)\n   256→\t\tif err != nil {\n   257→\t\t\tcontinue\n   258→\t\t}\n   259→\n   260→\t\tswitch msg.Type {\n   261→\t\tcase protocol.MsgStepStarted:\n   262→\t\t\trun.RecordStepStart(msg.StepName)\n   263→\t\t\tif s.captures != nil {\n   264→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   265→\t\t\t\t\tStepName:  msg.StepName,\n   266→\t\t\t\t\tStartedAt: msg.Timestamp,\n   267→\t\t\t\t})\n   268→\t\t\t}\n   269→\t\t\tif s.logBroadcast != nil {\n   270→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   271→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   272→\t\t\t\t\tType:      \"status\",\n   273→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   274→\t\t\t\t\tStepName:  msg.StepName,\n   275→\t\t\t\t})\n   276→\t\t\t}\n   277→\t\tcase protocol.MsgStepCompleted:\n   278→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   279→\t\t\tif s.captures != nil {\n   280→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   281→\t\t\t\t\tStepName:    msg.StepName,\n   282→\t\t\t\t\tResult:      msg.Result,\n   283→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   284→\t\t\t\t})\n   285→\t\t\t}\n   286→\t\t\tif s.logBroadcast != nil {\n   287→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   288→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   289→\t\t\t\t\tType:      \"status\",\n   290→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   291→\t\t\t\t\tStepName:  msg.StepName,\n   292→\t\t\t\t})\n   293→\t\t\t}\n   294→\t\tcase protocol.MsgRunTitle:\n   295→\t\t\tif run.Title == \"\" {\n   296→\t\t\t\trun.Title = msg.Message\n   297→\t\t\t}\n   298→\t\tcase protocol.MsgError:\n   299→\t\t\treportedError = msg.Message\n   300→\t\t\tcontinue // Don't persist; used during finalization\n   301→\t\tcase protocol.MsgRunCompleted:\n   302→\t\t\treportedResult = msg.Result\n   303→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   304→\t\t}\n   305→\n   306→\t\t_ = s.store.UpdateRun(ctx, run)\n   307→\t}\n   308→\treader.Close()\n   309→\n   310→\t// Signal live-stream subscribers that this run is done.\n   311→\tif s.logBroadcast != nil {\n   312→\t\ts.logBroadcast.Finish(runID)\n   313→\t}\n   314→\n   315→\t// Wait for process exit\n   316→\texitCode, err := s.container.Wait(ctx, containerID)\n   317→\tif err != nil {\n   318→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   319→\t}\n   320→\n   321→\t// Extract step output files from container before it's removed\n   322→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   323→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   324→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   325→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   326→\t\t}\n   327→\t}\n   328→\n   329→\t// Capture full container stdout/stderr before the container is removed\n   330→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   331→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   332→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   333→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   334→\t\t}\n   335→\t}\n   336→\n   337→\t// Index extracted log files in the log store\n   338→\tif s.logStore != nil {\n   339→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   340→\t}\n   341→\n   342→\t// Extract results to git branch BEFORE finalizing state, so that\n   343→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   344→\t// before the run is marked complete.\n   345→\tresultLabel := reportedResult\n   346→\tif resultLabel == \"\" {\n   347→\t\tif exitCode == 0 {\n   348→\t\t\tresultLabel = \"succeeded\"\n   349→\t\t} else {\n   350→\t\t\tresultLabel = \"failed\"\n   351→\t\t}\n   352→\t}\n   353→\t{\n   354→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   355→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   356→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   357→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   358→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   359→\t\t\t} else {\n   360→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   361→\t\t\t}\n   362→\t\t} else {\n   363→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   364→\t\t}\n   365→\t}\n   366→\n   367→\t// Now finalize run state\n   368→\trun, err := s.store.GetRun(ctx, runID)\n   369→\tif err != nil {\n   370→\t\treturn\n   371→\t}\n   372→\tif run.State == domain.RunStateRunning {\n   373→\t\tif reportedResult == \"succeeded\" {\n   374→\t\t\trun.Complete(domain.RunStateSucceeded)\n   375→\t\t} else if reportedResult != \"\" {\n   376→\t\t\tif reportedError != \"\" {\n   377→\t\t\t\trun.Fail(reportedError)\n   378→\t\t\t} else {\n   379→\t\t\t\trun.Complete(domain.RunStateFailed)\n   380→\t\t\t}\n   381→\t\t} else if exitCode == 0 {\n   382→\t\t\trun.Complete(domain.RunStateSucceeded)\n   383→\t\t} else {\n   384→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   385→\t\t}\n   386→\t\t_ = s.store.UpdateRun(ctx, run)\n   387→\t}\n   388→\n   389→\t// Fire evolution trigger if configured\n   390→\tif s.evolution != nil {\n   391→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   392→\t}\n   393→\n   394→\t// Merge is handled as a workflow step in host.cloche, not here.\n   395→\n   396→\t// Container retention policy:\n   397→\t// - Failed runs: always keep the container for debugging\n   398→\t// - Successful runs + --keep-container: keep the container\n   399→\t// - Successful runs without --keep-container: remove the container\n   400→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   401→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   402→\n   403→\tif keepContainer || runFailed {\n   404→\t\treason := \"--keep-container\"\n   405→\t\tif runFailed {\n   406→\t\t\treason = \"run failed\"\n   407→\t\t}\n   408→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   409→\t\tif runFinal != nil {\n   410→\t\t\trunFinal.ContainerKept = true\n   411→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   412→\t\t}\n   413→\t} else {\n   414→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   415→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   416→\t\t} else {\n   417→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   418→\t\t}\n   419→\t}\n   420→\n   421→\t// Cleanup mapping\n   422→\ts.mu.Lock()\n   423→\tdelete(s.runIDs, runID)\n   424→\ts.mu.Unlock()\n   425→}\n   426→\n   427→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   428→\tfilter := domain.RunListFilter{\n   429→\t\tProjectDir: req.ProjectDir,\n   430→\t\tState:      domain.RunState(req.State),\n   431→\t\tTaskID:     req.TaskId,\n   432→\t\tLimit:      int(req.Limit),\n   433→\t}\n   434→\n   435→\t// When no project filter and not --all, default to last hour\n   436→\tif filter.ProjectDir == \"\" && !req.All {\n   437→\t\tfilter.Since = time.Now().Add(-1 * time.Hour)\n   438→\t}\n   439→\n   440→\truns, err := s.store.ListRunsFiltered(ctx, filter)\n   441→\tif err != nil {\n   442→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   443→\t}\n   444→\n   445→\tresp := &pb.ListRunsResponse{}\n   446→\tfor _, run := range runs {\n   447→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   448→\t\t\tRunId:        run.ID,\n   449→\t\t\tWorkflowName: run.WorkflowName,\n   450→\t\t\tState:        string(run.State),\n   451→\t\t\tStartedAt:    run.StartedAt.String(),\n   452→\t\t\tErrorMessage: run.ErrorMessage,\n   453→\t\t\tContainerId:  run.ContainerID,\n   454→\t\t\tTitle:        run.Title,\n   455→\t\t\tIsHost:       run.IsHost,\n   456→\t\t\tProjectDir:   run.ProjectDir,\n   457→\t\t\tTaskId:       run.TaskID,\n   458→\t\t})\n   459→\t}\n   460→\treturn resp, nil\n   461→}\n   462→\n   463→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   464→\trun, err := s.store.GetRun(ctx, req.RunId)\n   465→\tif err != nil {\n   466→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   467→\t}\n   468→\n   469→\tresp := &pb.GetStatusResponse{\n   470→\t\tRunId:        run.ID,\n   471→\t\tWorkflowName: run.WorkflowName,\n   472→\t\tState:        string(run.State),\n   473→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   474→\t\tErrorMessage: run.ErrorMessage,\n   475→\t\tContainerId:  run.ContainerID,\n   476→\t\tTitle:        run.Title,\n   477→\t\tIsHost:       run.IsHost,\n   478→\t}\n   479→\n   480→\t// Check container liveness\n   481→\tif run.ContainerID != \"\" && s.container != nil {\n   482→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   483→\t\t\tresp.ContainerAlive = cs.Running\n   484→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   485→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   486→\t\t\t}\n   487→\t\t}\n   488→\t}\n   489→\n   490→\t// Load step executions from captures store if available\n   491→\tif s.captures != nil {\n   492→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   493→\t\tif err == nil {\n   494→\t\t\tfor _, exec := range captures {\n   495→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   496→\t\t\t\t\tStepName:    exec.StepName,\n   497→\t\t\t\t\tResult:      exec.Result,\n   498→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   499→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   500→\t\t\t\t})\n   501→\t\t\t}\n   502→\t\t}\n   503→\t} else {\n   504→\t\tfor _, exec := range run.StepExecutions {\n   505→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   506→\t\t\t\tStepName:    exec.StepName,\n   507→\t\t\t\tResult:      exec.Result,\n   508→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   509→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   510→\t\t\t})\n   511→\t\t}\n   512→\t}\n   513→\n   514→\treturn resp, nil\n   515→}\n   516→\n   517→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   518→\tctx := stream.Context()\n   519→\n   520→\t_ = followFromContext(ctx) // follow is implicit for active runs\n   521→\tlimit := limitFromContext(ctx)\n   522→\n   523→\t// Verify run exists\n   524→\trun, err := s.store.GetRun(ctx, req.RunId)\n   525→\tif err != nil {\n   526→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   527→\t}\n   528→\n   529→\t// If step_name or log_type filter is set, serve content directly from the log index\n   530→\tif req.StepName != \"\" || req.LogType != \"\" {\n   531→\t\treturn s.streamFilteredLogs(ctx, req, run, stream, limit)\n   532→\t}\n   533→\n   534→\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n   535→\n   536→\t// Active runs always stream live output (follow mode is implicit).\n   537→\t// The -f flag is accepted but redundant for active runs.\n   538→\tif isActive && s.logBroadcast != nil {\n   539→\t\treturn s.streamFollowLogs(req.RunId, run, stream, limit)\n   540→\t}\n   541→\n   542→\t// Check for full.log first — if it exists, serve it as the unified log\n   543→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   544→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   545→\t\tmsg := applyLimit(string(data), limit)\n   546→\t\tif err := stream.Send(&pb.LogEntry{\n   547→\t\t\tType:    \"full_log\",\n   548→\t\t\tMessage: msg,\n   549→\t\t}); err != nil {\n   550→\t\t\treturn err\n   551→\t\t}\n   552→\t\tif !isActive {\n   553→\t\t\tif err := stream.Send(&pb.LogEntry{\n   554→\t\t\t\tType:      \"run_completed\",\n   555→\t\t\t\tResult:    string(run.State),\n   556→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   557→\t\t\t\tMessage:   run.ErrorMessage,\n   558→\t\t\t}); err != nil {\n   559→\t\t\t\treturn err\n   560→\t\t\t}\n   561→\t\t}\n   562→\t\treturn nil\n   563→\t}\n   564→\n   565→\tif s.captures == nil {\n   566→\t\treturn fmt.Errorf(\"captures store not configured\")\n   567→\t}\n   568→\n   569→\t// Fall back to capture-based streaming\n   570→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   571→\tif err != nil {\n   572→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   573→\t}\n   574→\n   575→\tfor _, exec := range captures {\n   576→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   577→\t\t// and one for step_completed (has Result).\n   578→\t\tif exec.Result == \"\" {\n   579→\t\t\tentry := &pb.LogEntry{\n   580→\t\t\t\tType:      \"step_started\",\n   581→\t\t\t\tStepName:  exec.StepName,\n   582→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   583→\t\t\t}\n   584→\t\t\tif err := stream.Send(entry); err != nil {\n   585→\t\t\t\treturn err\n   586→\t\t\t}\n   587→\t\t} else {\n   588→\t\t\t// Read step output from per-step output file.\n   589→\t\t\t// Container runs write .log, host runs write .out — try both.\n   590→\t\t\tvar output string\n   591→\t\t\tfor _, ext := range []string{\".log\", \".out\"} {\n   592→\t\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+ext)\n   593→\t\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   594→\t\t\t\t\toutput = string(data)\n   595→\t\t\t\t\tbreak\n   596→\t\t\t\t}\n   597→\t\t\t}\n   598→\t\t\tentry := &pb.LogEntry{\n   599→\t\t\t\tType:      \"step_completed\",\n   600→\t\t\t\tStepName:  exec.StepName,\n   601→\t\t\t\tResult:    exec.Result,\n   602→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   603→\t\t\t\tMessage:   applyLimit(output, limit),\n   604→\t\t\t}\n   605→\t\t\tif err := stream.Send(entry); err != nil {\n   606→\t\t\t\treturn err\n   607→\t\t\t}\n   608→\t\t}\n   609→\t}\n   610→\n   611→\t// Send run completion entry\n   612→\tif !isActive {\n   613→\t\tif err := stream.Send(&pb.LogEntry{\n   614→\t\t\tType:      \"run_completed\",\n   615→\t\t\tResult:    string(run.State),\n   616→\t\t\tTimestamp: run.CompletedAt.String(),\n   617→\t\t\tMessage:   run.ErrorMessage,\n   618→\t\t}); err != nil {\n   619→\t\t\treturn err\n   620→\t\t}\n   621→\t}\n   622→\n   623→\treturn nil\n   624→}\n   625→\n   626→// followFromContext checks for the follow flag in gRPC metadata.\n   627→func followFromContext(ctx context.Context) bool {\n   628→\tmd, ok := metadata.FromIncomingContext(ctx)\n   629→\tif !ok {\n   630→\t\treturn false\n   631→\t}\n   632→\tvals := md.Get(\"x-cloche-follow\")\n   633→\treturn len(vals) > 0 && vals[0] == \"true\"\n   634→}\n   635→\n   636→// limitFromContext reads the line limit from gRPC metadata.\n   637→// Returns 0 when no limit is set.\n   638→func limitFromContext(ctx context.Context) int {\n   639→\tmd, ok := metadata.FromIncomingContext(ctx)\n   640→\tif !ok {\n   641→\t\treturn 0\n   642→\t}\n   643→\tvals := md.Get(\"x-cloche-limit\")\n   644→\tif len(vals) == 0 {\n   645→\t\treturn 0\n   646→\t}\n   647→\tn, err := strconv.Atoi(vals[0])\n   648→\tif err != nil || n <= 0 {\n   649→\t\treturn 0\n   650→\t}\n   651→\treturn n\n   652→}\n   653→\n   654→// applyLimit returns the last n lines of content. If n <= 0, returns content unchanged.\n   655→func applyLimit(content string, n int) string {\n   656→\tif n <= 0 {\n   657→\t\treturn content\n   658→\t}\n   659→\tlines := strings.Split(content, \"\\n\")\n   660→\t// Remove trailing empty line from final newline\n   661→\tif len(lines) > 0 && lines[len(lines)-1] == \"\" {\n   662→\t\tlines = lines[:len(lines)-1]\n   663→\t}\n   664→\tif len(lines) <= n {\n   665→\t\treturn content\n   666→\t}\n   667→\treturn strings.Join(lines[len(lines)-n:], \"\\n\") + \"\\n\"\n   668→}\n   669→\n   670→// streamFollowLogs sends existing log content then tails live output from the\n   671→// broadcaster. It combines snapshot + live streaming (like tail -f).\n   672→func (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry], limit int) error {\n   673→\t// Subscribe first so we don't miss lines written between read and subscribe.\n   674→\tsub := s.logBroadcast.Subscribe(runID)\n   675→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   676→\n   677→\t// Send existing full.log content if available.\n   678→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n   679→\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n   680→\t\tmsg := applyLimit(string(data), limit)\n   681→\t\tif err := stream.Send(&pb.LogEntry{\n   682→\t\t\tType:    \"full_log\",\n   683→\t\t\tMessage: msg,\n   684→\t\t}); err != nil {\n   685→\t\t\treturn err\n   686→\t\t}\n   687→\t}\n   688→\n   689→\t// Now tail live output from the broadcaster.\n   690→\tctx := stream.Context()\n   691→\tfor {\n   692→\t\tselect {\n   693→\t\tcase <-ctx.Done():\n   694→\t\t\treturn ctx.Err()\n   695→\t\tcase line, ok := <-sub.C:\n   696→\t\t\tif !ok {\n   697→\t\t\t\t// Run completed — send terminal entry.\n   698→\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n   699→\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n   700→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   701→\t\t\t\t\t\tType:      \"run_completed\",\n   702→\t\t\t\t\t\tResult:    string(r.State),\n   703→\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n   704→\t\t\t\t\t\tMessage:   r.ErrorMessage,\n   705→\t\t\t\t\t})\n   706→\t\t\t\t}\n   707→\t\t\t\treturn nil\n   708→\t\t\t}\n   709→\t\t\tif err := stream.Send(&pb.LogEntry{\n   710→\t\t\t\tType:      \"log\",\n   711→\t\t\t\tStepName:  line.StepName,\n   712→\t\t\t\tMessage:   line.Content,\n   713→\t\t\t\tTimestamp: line.Timestamp,\n   714→\t\t\t}); err != nil {\n   715→\t\t\t\treturn err\n   716→\t\t\t}\n   717→\t\t}\n   718→\t}\n   719→}\n   720→\n   721→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   722→// It uses the log index when available, falling back to file path conventions.\n   723→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry], limit int) error {\n   724→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   725→\n   726→\t// Try log index first\n   727→\tif s.logStore != nil {\n   728→\t\tvar logFiles []*ports.LogFileEntry\n   729→\t\tvar err error\n   730→\n   731→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   732→\t\t\t// Filter by both step and type\n   733→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   734→\t\t\tif err == nil {\n   735→\t\t\t\tfiltered := logFiles[:0]\n   736→\t\t\t\tfor _, lf := range logFiles {\n   737→\t\t\t\t\tif lf.FileType == req.LogType {\n   738→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   739→\t\t\t\t\t}\n   740→\t\t\t\t}\n   741→\t\t\t\tlogFiles = filtered\n   742→\t\t\t}\n   743→\t\t} else if req.StepName != \"\" {\n   744→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   745→\t\t} else {\n   746→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   747→\t\t}\n   748→\n   749→\t\tif err == nil && len(logFiles) > 0 {\n   750→\t\t\tfor _, lf := range logFiles {\n   751→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   752→\t\t\t\tif readErr != nil {\n   753→\t\t\t\t\tcontinue\n   754→\t\t\t\t}\n   755→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   756→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   757→\t\t\t\t\tStepName: lf.StepName,\n   758→\t\t\t\t\tMessage:  applyLimit(string(data), limit),\n   759→\t\t\t\t}); err != nil {\n   760→\t\t\t\t\treturn err\n   761→\t\t\t\t}\n   762→\t\t\t}\n   763→\t\t\treturn nil\n   764→\t\t}\n   765→\t}\n   766→\n   767→\t// Fall back to file path conventions\n   768→\tif req.StepName != \"\" {\n   769→\t\tvar logPath string\n   770→\t\tswitch req.LogType {\n   771→\t\tcase \"llm\":\n   772→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   773→\t\tdefault:\n   774→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   775→\t\t}\n   776→\n   777→\t\tdata, err := os.ReadFile(logPath)\n   778→\t\tif err != nil {\n   779→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   780→\t\t}\n   781→\t\treturn stream.Send(&pb.LogEntry{\n   782→\t\t\tType:     \"step_log\",\n   783→\t\t\tStepName: req.StepName,\n   784→\t\t\tMessage:  applyLimit(string(data), limit),\n   785→\t\t})\n   786→\t}\n   787→\n   788→\treturn fmt.Errorf(\"no log files found matching filter\")\n   789→}\n   790→\n   791→// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n   792→// time for an active run. The stream closes when the run completes or the\n   793→// client disconnects.\n   794→func (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   795→\tsub := s.logBroadcast.Subscribe(runID)\n   796→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   797→\n   798→\tctx := stream.Context()\n   799→\tfor {\n   800→\t\tselect {\n   801→\t\tcase <-ctx.Done():\n   802→\t\t\treturn ctx.Err()\n   803→\t\tcase line, ok := <-sub.C:\n   804→\t\t\tif !ok {\n   805→\t\t\t\t// Run completed — send terminal entry.\n   806→\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   807→\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   808→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   809→\t\t\t\t\t\tType:      \"run_completed\",\n   810→\t\t\t\t\t\tResult:    string(run.State),\n   811→\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   812→\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   813→\t\t\t\t\t})\n   814→\t\t\t\t}\n   815→\t\t\t\treturn nil\n   816→\t\t\t}\n   817→\t\t\tif err := stream.Send(&pb.LogEntry{\n   818→\t\t\t\tType:      \"log\",\n   819→\t\t\t\tStepName:  line.StepName,\n   820→\t\t\t\tMessage:   line.Content,\n   821→\t\t\t\tTimestamp: line.Timestamp,\n   822→\t\t\t}); err != nil {\n   823→\t\t\t\treturn err\n   824→\t\t\t}\n   825→\t\t}\n   826→\t}\n   827→}\n   828→\n   829→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   830→\ts.mu.Lock()\n   831→\tcontainerID, ok := s.runIDs[req.RunId]\n   832→\ts.mu.Unlock()\n   833→\n   834→\tif !ok {\n   835→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   836→\t}\n   837→\n   838→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   839→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   840→\t}\n   841→\n   842→\t// Mark as cancelled in store\n   843→\trun, err := s.store.GetRun(ctx, req.RunId)\n   844→\tif err == nil {\n   845→\t\trun.Complete(domain.RunStateCancelled)\n   846→\t\t_ = s.store.UpdateRun(ctx, run)\n   847→\t}\n   848→\n   849→\treturn &pb.StopRunResponse{}, nil\n   850→}\n   851→\n   852→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   853→\tif s.container == nil {\n   854→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   855→\t}\n   856→\n   857→\tid := req.Id\n   858→\tif id == \"\" {\n   859→\t\treturn nil, fmt.Errorf(\"id is required\")\n   860→\t}\n   861→\n   862→\t// Try to resolve as a run ID first\n   863→\tcontainerID := id\n   864→\trun, err := s.store.GetRun(ctx, id)\n   865→\tif err == nil {\n   866→\t\t// It's a run ID — use the container ID from the run record\n   867→\t\tif run.ContainerID == \"\" {\n   868→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   869→\t\t}\n   870→\t\tcontainerID = run.ContainerID\n   871→\t}\n   872→\n   873→\t// Remove the container\n   874→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   875→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   876→\t}\n   877→\n   878→\t// If we resolved a run, clear the container_kept flag\n   879→\tif run != nil {\n   880→\t\trun.ContainerKept = false\n   881→\t\t_ = s.store.UpdateRun(ctx, run)\n   882→\t}\n   883→\n   884→\treturn &pb.DeleteContainerResponse{}, nil\n   885→}\n   886→\n   887→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   888→\tprojectDir := req.ProjectDir\n   889→\tif projectDir == \"\" {\n   890→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   891→\t}\n   892→\n   893→\t// Verify at least one host workflow exists in the project.\n   894→\thostWorkflows, err := host.FindHostWorkflows(projectDir)\n   895→\tif err != nil || len(hostWorkflows) == 0 {\n   896→\t\treturn nil, fmt.Errorf(\"no host workflows found in %s/.cloche/\", projectDir)\n   897→\t}\n   898→\n   899→\t// Load project config for defaults.\n   900→\tprojCfg, _ := config.Load(projectDir)\n   901→\n   902→\tmaxConc := int(req.MaxConcurrent)\n   903→\tif maxConc <= 0 {\n   904→\t\tmaxConc = projCfg.Orchestration.Concurrency\n   905→\t}\n   906→\tif maxConc <= 0 {\n   907→\t\tmaxConc = 1\n   908→\t}\n   909→\n   910→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   911→\n   912→\t// Compute dedup timeout from config (default 5 minutes).\n   913→\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n   914→\n   915→\tloopCfg := host.LoopConfig{\n   916→\t\tProjectDir:    projectDir,\n   917→\t\tMaxConcurrent: maxConc,\n   918→\t\tStaggerDelay:  stagger,\n   919→\t\tDedupTimeout:  dedupTimeout,\n   920→\t\tStopOnError:   projCfg.Orchestration.StopOnError,\n   921→\t}\n   922→\n   923→\ts.mu.Lock()\n   924→\tdefer s.mu.Unlock()\n   925→\n   926→\t// Stop existing loop if running.\n   927→\tif existing, ok := s.loops[projectDir]; ok {\n   928→\t\texisting.Stop()\n   929→\t}\n   930→\n   931→\t// Check if project defines a list-tasks workflow for three-phase mode.\n   932→\tvar loop *host.Loop\n   933→\tif _, hasListTasks := hostWorkflows[\"list-tasks\"]; hasListTasks {\n   934→\t\tloop = s.createPhaseLoop(loopCfg, projectDir, dedupTimeout)\n   935→\t} else {\n   936→\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n   937→\t}\n   938→\n   939→\ts.loops[projectDir] = loop\n   940→\tloop.Start()\n   941→\n   942→\treturn &pb.EnableLoopResponse{}, nil\n   943→}\n   944→\n   945→// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n   946→// main, and finalize host workflows from any .cloche file.\n   947→func (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir string, dedupTimeout time.Duration) *host.Loop {\n   948→\t// Phase 1: list-tasks function\n   949→\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n   950→\t\trunner := &host.Runner{\n   951→\t\t\tDispatcher: s,\n   952→\t\t\tStore:      s.store,\n   953→\t\t}\n   954→\t\ttasks, _, err := host.RunListTasksWorkflow(ctx, runner, projDir)\n   955→\t\treturn tasks, err\n   956→\t}\n   957→\n   958→\t// Phase 2: main function\n   959→\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   960→\t\trunner := &host.Runner{\n   961→\t\t\tDispatcher:   s,\n   962→\t\t\tStore:        s.store,\n   963→\t\t\tCaptures:     s.captures,\n   964→\t\t\tLogBroadcast: s.logBroadcast,\n   965→\t\t\tTaskID:       taskID,\n   966→\t\t}\n   967→\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n   968→\t}\n   969→\n   970→\t// Phase 3: finalize function (optional — only if a finalize host workflow exists)\n   971→\tvar finalizeFn host.FinalizeFunc\n   972→\tif hostWFs, err := host.FindHostWorkflows(projectDir); err == nil {\n   973→\t\tif _, hasFinalize := hostWFs[\"finalize\"]; hasFinalize {\n   974→\t\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n   975→\t\t\t\tmainRunID := \"\"\n   976→\t\t\t\tmainOutcome := \"failed\"\n   977→\t\t\t\tif mainResult != nil {\n   978→\t\t\t\t\tmainRunID = mainResult.RunID\n   979→\t\t\t\t\tmainOutcome = string(mainResult.State)\n   980→\t\t\t\t}\n   981→\t\t\t\trunner := &host.Runner{\n   982→\t\t\t\t\tDispatcher:   s,\n   983→\t\t\t\t\tStore:        s.store,\n   984→\t\t\t\t\tCaptures:     s.captures,\n   985→\t\t\t\t\tLogBroadcast: s.logBroadcast,\n   986→\t\t\t\t\tTaskID:       taskID,\n   987→\t\t\t\t\tExtraEnv: []string{\n   988→\t\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n   989→\t\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n   990→\t\t\t\t\t},\n   991→\t\t\t\t}\n   992→\t\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n   993→\t\t\t}\n   994→\t\t}\n   995→\t}\n   996→\n   997→\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n   998→\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n   999→}\n  1000→\n  1001→// createLegacyLoop creates a legacy single-function orchestration loop.\n  1002→func (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n  1003→\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n  1004→\t\trunner := &host.Runner{\n  1005→\t\t\tDispatcher:   s,\n  1006→\t\t\tStore:        s.store,\n  1007→\t\t\tCaptures:     s.captures,\n  1008→\t\t\tLogBroadcast: s.logBroadcast,\n  1009→\t\t\tTaskID:       taskID,\n  1010→\t\t}\n  1011→\t\treturn runner.Run(ctx, projDir)\n  1012→\t}\n  1013→\n  1014→\tloop := host.NewLoop(loopCfg, s.store, runFn)\n  1015→\n  1016→\t// Configure daemon-managed task assignment if a list-tasks command is set.\n  1017→\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n  1018→\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n  1019→\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n  1020→\t}\n  1021→\n  1022→\treturn loop\n  1023→}\n  1024→\n  1025→// GetLoopTasks returns the current task pipeline state for a project's\n  1026→// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n  1027→// loop is active for the project.\n  1028→func (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n  1029→\ts.mu.Lock()\n  1030→\tloop, ok := s.loops[projectDir]\n  1031→\ts.mu.Unlock()\n  1032→\tif !ok {\n  1033→\t\treturn nil\n  1034→\t}\n  1035→\tsnapshot := loop.GetTaskSnapshot()\n  1036→\n  1037→\t// Build a set of task IDs that have active (pending/running) runs.\n  1038→\tactiveTaskIDs := make(map[string]bool)\n  1039→\tctx := context.Background()\n  1040→\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n  1041→\tfor _, r := range allRuns {\n  1042→\t\tif r.TaskID != \"\" && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n  1043→\t\t\tactiveTaskIDs[r.TaskID] = true\n  1044→\t\t}\n  1045→\t}\n  1046→\n  1047→\tentries := make([]web.TaskEntry, len(snapshot))\n  1048→\tfor i, e := range snapshot {\n  1049→\t\tentry := web.TaskEntry{\n  1050→\t\t\tID:          e.Task.ID,\n  1051→\t\t\tStatus:      e.Task.Status,\n  1052→\t\t\tTitle:       e.Task.Title,\n  1053→\t\t\tDescription: e.Task.Description,\n  1054→\t\t\tMetadata:    e.Task.Metadata,\n  1055→\t\t\tAssigned:    e.Assigned,\n  1056→\t\t\tRunID:       e.RunID,\n  1057→\t\t}\n  1058→\t\tif !e.AssignedAt.IsZero() {\n  1059→\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n  1060→\t\t}\n  1061→\t\t// Stale: task is in_progress but has no active worker.\n  1062→\t\tif host.TaskStatus(e.Task.Status) == host.TaskStatusInProgress && !activeTaskIDs[e.Task.ID] {\n  1063→\t\t\tentry.Stale = true\n  1064→\t\t}\n  1065→\t\tentries[i] = entry\n  1066→\t}\n  1067→\treturn entries\n  1068→}\n  1069→\n  1070→// ReleaseTask runs the release-task host workflow for a specific task,\n  1071→// returning it to open status.\n  1072→func (s *ClocheServer) ReleaseTask(ctx context.Context, projectDir string, taskID string) error {\n  1073→\trunner := &host.Runner{\n  1074→\t\tDispatcher:   s,\n  1075→\t\tStore:        s.store,\n  1076→\t\tCaptures:     s.captures,\n  1077→\t\tLogBroadcast: s.logBroadcast,\n  1078→\t\tTaskID:       taskID,\n  1079→\t}\n  1080→\tresult, err := runner.RunNamed(ctx, projectDir, \"release-task\")\n  1081→\tif err != nil {\n  1082→\t\treturn fmt.Errorf(\"release-task workflow failed: %w\", err)\n  1083→\t}\n  1084→\tif result.State != domain.RunStateSucceeded {\n  1085→\t\treturn fmt.Errorf(\"release-task workflow finished with state %s\", result.State)\n  1086→\t}\n  1087→\treturn nil\n  1088→}\n  1089→\n  1090→func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n  1091→\tprojectDir := req.ProjectDir\n  1092→\tif projectDir == \"\" {\n  1093→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n  1094→\t}\n  1095→\n  1096→\ts.mu.Lock()\n  1097→\tdefer s.mu.Unlock()\n  1098→\n  1099→\tif loop, ok := s.loops[projectDir]; ok {\n  1100→\t\tloop.Stop()\n  1101→\t\tdelete(s.loops, projectDir)\n  1102→\t}\n  1103→\n  1104→\treturn &pb.DisableLoopResponse{}, nil\n  1105→}\n  1106→\n  1107→func (s *ClocheServer) ResumeLoop(ctx context.Context, req *pb.ResumeLoopRequest) (*pb.ResumeLoopResponse, error) {\n  1108→\tprojectDir := req.ProjectDir\n  1109→\tif projectDir == \"\" {\n  1110→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n  1111→\t}\n  1112→\n  1113→\ts.mu.Lock()\n  1114→\tloop, ok := s.loops[projectDir]\n  1115→\ts.mu.Unlock()\n  1116→\n  1117→\tif !ok || loop == nil {\n  1118→\t\treturn nil, fmt.Errorf(\"no orchestration loop for %s\", projectDir)\n  1119→\t}\n  1120→\n  1121→\tloop.Resume()\n  1122→\treturn &pb.ResumeLoopResponse{}, nil\n  1123→}\n  1124→\n  1125→func (s *ClocheServer) GetProjectInfo(ctx context.Context, req *pb.GetProjectInfoRequest) (*pb.GetProjectInfoResponse, error) {\n  1126→\tprojectDir := req.ProjectDir\n  1127→\n  1128→\t// Resolve by name if provided.\n  1129→\tif req.Name != \"\" && projectDir == \"\" {\n  1130→\t\tprojects, err := s.store.ListProjects(ctx)\n  1131→\t\tif err != nil {\n  1132→\t\t\treturn nil, fmt.Errorf(\"listing projects: %w\", err)\n  1133→\t\t}\n  1134→\t\tlabels := projectLabels(projects)\n  1135→\t\tfound := false\n  1136→\t\tfor dir, label := range labels {\n  1137→\t\t\tif label == req.Name {\n  1138→\t\t\t\tprojectDir = dir\n  1139→\t\t\t\tfound = true\n  1140→\t\t\t\tbreak\n  1141→\t\t\t}\n  1142→\t\t}\n  1143→\t\tif !found {\n  1144→\t\t\treturn nil, fmt.Errorf(\"project %q not found\", req.Name)\n  1145→\t\t}\n  1146→\t}\n  1147→\n  1148→\tif projectDir == \"\" {\n  1149→\t\treturn nil, fmt.Errorf(\"project_dir or name is required\")\n  1150→\t}\n  1151→\n  1152→\t// Derive project label.\n  1153→\tprojects, _ := s.store.ListProjects(ctx)\n  1154→\tlabels := projectLabels(projects)\n  1155→\tlabel := labels[projectDir]\n  1156→\tif label == \"\" {\n  1157→\t\tlabel = filepath.Base(projectDir)\n  1158→\t}\n  1159→\n  1160→\t// Load config.\n  1161→\tcfg, _ := config.Load(projectDir)\n  1162→\n  1163→\t// Check loop state.\n  1164→\ts.mu.Lock()\n  1165→\tloop, loopExists := s.loops[projectDir]\n  1166→\ts.mu.Unlock()\n  1167→\tloopRunning := loopExists && loop != nil && loop.Running()\n  1168→\n  1169→\t// Get active runs.\n  1170→\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n  1171→\tvar activeRuns []*pb.RunSummary\n  1172→\tfor _, run := range allRuns {\n  1173→\t\tif run.State == domain.RunStatePending || run.State == domain.RunStateRunning {\n  1174→\t\t\tactiveRuns = append(activeRuns, &pb.RunSummary{\n  1175→\t\t\t\tRunId:        run.ID,\n  1176→\t\t\t\tWorkflowName: run.WorkflowName,\n  1177→\t\t\t\tState:        string(run.State),\n  1178→\t\t\t\tStartedAt:    run.StartedAt.String(),\n  1179→\t\t\t\tTitle:        run.Title,\n  1180→\t\t\t\tIsHost:       run.IsHost,\n  1181→\t\t\t\tContainerId:  run.ContainerID,\n  1182→\t\t\t})\n  1183→\t\t}\n  1184→\t}\n  1185→\n  1186→\t// Discover workflows.\n  1187→\tvar containerWorkflows, hostWorkflows []string\n  1188→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n  1189→\tentries, _ := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n  1190→\tfor _, path := range entries {\n  1191→\t\tbase := filepath.Base(path)\n  1192→\t\tdata, err := os.ReadFile(path)\n  1193→\t\tif err != nil {\n  1194→\t\t\tcontinue\n  1195→\t\t}\n  1196→\t\tif base == \"host.cloche\" {\n  1197→\t\t\twfs, err := dsl.ParseAllForHost(string(data))\n  1198→\t\t\tif err != nil {\n  1199→\t\t\t\tcontinue\n  1200→\t\t\t}\n  1201→\t\t\tfor name := range wfs {\n  1202→\t\t\t\thostWorkflows = append(hostWorkflows, name)\n  1203→\t\t\t}\n  1204→\t\t} else {\n  1205→\t\t\twf, err := dsl.ParseForContainer(string(data))\n  1206→\t\t\tif err != nil {\n  1207→\t\t\t\tcontinue\n  1208→\t\t\t}\n  1209→\t\t\tcontainerWorkflows = append(containerWorkflows, wf.Name)\n  1210→\t\t}\n  1211→\t}\n  1212→\n  1213→\tsort.Strings(containerWorkflows)\n  1214→\tsort.Strings(hostWorkflows)\n  1215→\n  1216→\t// Check if loop is halted due to an error.\n  1217→\tvar errorHalted bool\n  1218→\tvar haltError string\n  1219→\tif loopExists && loop != nil {\n  1220→\t\terrorHalted, haltError = loop.Halted()\n  1221→\t}\n  1222→\n  1223→\treturn &pb.GetProjectInfoResponse{\n  1224→\t\tProjectDir:         projectDir,\n  1225→\t\tName:               label,\n  1226→\t\tActive:             cfg.Active,\n  1227→\t\tConcurrency:        int32(cfg.Orchestration.Concurrency),\n  1228→\t\tStaggerSeconds:     cfg.Orchestration.StaggerSeconds,\n  1229→\t\tDedupSeconds:       cfg.Orchestration.DedupSeconds,\n  1230→\t\tEvolutionEnabled:   cfg.Evolution.Enabled,\n  1231→\t\tLoopRunning:        loopRunning,\n  1232→\t\tActiveRuns:         activeRuns,\n  1233→\t\tContainerWorkflows: containerWorkflows,\n  1234→\t\tHostWorkflows:      hostWorkflows,\n  1235→\t\tStopOnError:        cfg.Orchestration.StopOnError,\n  1236→\t\tErrorHalted:        errorHalted,\n  1237→\t\tHaltError:          haltError,\n  1238→\t}, nil\n  1239→}\n  1240→\n  1241→// projectLabels maps each project directory to a short display label.\n  1242→// Uses basename unless there are conflicts, in which case parent/basename is used.\n  1243→func projectLabels(dirs []string) map[string]string {\n  1244→\tlabels := make(map[string]string, len(dirs))\n  1245→\tbyBase := map[string][]string{}\n  1246→\tfor _, d := range dirs {\n  1247→\t\tbase := filepath.Base(d)\n  1248→\t\tbyBase[base] = append(byBase[base], d)\n  1249→\t}\n  1250→\tfor base, paths := range byBase {\n  1251→\t\tif len(paths) == 1 {\n  1252→\t\t\tlabels[paths[0]] = base\n  1253→\t\t} else {\n  1254→\t\t\tfor _, p := range paths {\n  1255→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1256→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1257→\t\t\t}\n  1258→\t\t}\n  1259→\t}\n  1260→\treturn labels\n  1261→}\n  1262→\n  1263→func (s *ClocheServer) GetVersion(ctx context.Context, req *pb.GetVersionRequest) (*pb.GetVersionResponse, error) {\n  1264→\treturn &pb.GetVersionResponse{Version: version.Version()}, nil\n  1265→}\n  1266→\n  1267→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n  1268→\tif !req.Force {\n  1269→\t\t// Check for active container runs.\n  1270→\t\ts.mu.Lock()\n  1271→\t\tactiveRuns := len(s.runIDs)\n  1272→\t\ts.mu.Unlock()\n  1273→\t\tif activeRuns > 0 {\n  1274→\t\t\treturn nil, fmt.Errorf(\"cannot shutdown: %d run(s) still active (use --force to override)\", activeRuns)\n  1275→\t\t}\n  1276→\t}\n  1277→\n  1278→\t// Stop all orchestration loops.\n  1279→\ts.mu.Lock()\n  1280→\tfor _, loop := range s.loops {\n  1281→\t\tloop.Stop()\n  1282→\t}\n  1283→\ts.loops = make(map[string]*host.Loop)\n  1284→\ts.mu.Unlock()\n  1285→\n  1286→\tif s.shutdownFn == nil {\n  1287→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n  1288→\t}\n  1289→\tgo s.shutdownFn()\n  1290→\treturn &pb.ShutdownResponse{}, nil\n  1291→}\n  1292→\n  1293→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n  1294→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n  1295→\tentries, err := os.ReadDir(outputDir)\n  1296→\tif err != nil {\n  1297→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n  1298→\t\treturn\n  1299→\t}\n  1300→\n  1301→\tnow := time.Now()\n  1302→\tfor _, entry := range entries {\n  1303→\t\tif entry.IsDir() {\n  1304→\t\t\tcontinue\n  1305→\t\t}\n  1306→\t\tname := entry.Name()\n  1307→\t\tif !strings.HasSuffix(name, \".log\") {\n  1308→\t\t\tcontinue\n  1309→\t\t}\n  1310→\n  1311→\t\tvar fileType, stepName string\n  1312→\t\tbase := strings.TrimSuffix(name, \".log\")\n  1313→\n  1314→\t\tswitch {\n  1315→\t\tcase name == \"full.log\":\n  1316→\t\t\tfileType = \"full\"\n  1317→\t\tcase name == \"container.log\":\n  1318→\t\t\t// container.log is internal, not indexed as a user-facing log type\n  1319→\t\t\tcontinue\n  1320→\t\tcase strings.HasPrefix(name, \"llm-\"):\n  1321→\t\t\tfileType = \"llm\"\n  1322→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n  1323→\t\tdefault:\n  1324→\t\t\tfileType = \"script\"\n  1325→\t\t\tstepName = base\n  1326→\t\t}\n  1327→\n  1328→\t\tinfo, _ := entry.Info()\n  1329→\t\tvar fileSize int64\n  1330→\t\tif info != nil {\n  1331→\t\t\tfileSize = info.Size()\n  1332→\t\t}\n  1333→\n  1334→\t\tlogEntry := &ports.LogFileEntry{\n  1335→\t\t\tRunID:     runID,\n  1336→\t\t\tStepName:  stepName,\n  1337→\t\t\tFileType:  fileType,\n  1338→\t\t\tFilePath:  filepath.Join(outputDir, name),\n  1339→\t\t\tFileSize:  fileSize,\n  1340→\t\t\tCreatedAt: now,\n  1341→\t\t}\n  1342→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n  1343→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n  1344→\t\t}\n  1345→\t}\n  1346→}\n  1347→\n  1348→func gitHEAD(dir string) string {\n  1349→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n  1350→\tcmd.Dir = dir\n  1351→\tout, err := cmd.Output()\n  1352→\tif err != nil {\n  1353→\t\treturn \"\"\n  1354→\t}\n  1355→\treturn strings.TrimSpace(string(out))\n  1356→}\n  1357→"}]},"parent_tool_use_id":null,"session_id":"a767d320-7441-4cfb-80d2-26edf647ec06","uuid":"0c49c3ed-21e7-4495-9e20-f4e8f8286828","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server.go","content":"package grpc\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\t\"github.com/cloche-dev/cloche/internal/host\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\t\"github.com/cloche-dev/cloche/internal/version\"\n\trpcgrpc \"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\ntype ClocheServer struct {\n\tpb.UnimplementedClocheServiceServer\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogStore     ports.LogStore\n\tcontainer    ports.ContainerRuntime\n\tdefaultImage string\n\tevolution    *evolution.Trigger\n\tlogBroadcast *logstream.Broadcaster\n\tshutdownFn   func()\n\tmu           sync.Mutex\n\trunIDs       map[string]string      // run_id -> container_id\n\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n}\n\nfunc NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:     store,\n\t\tcontainer: container,\n\t\trunIDs:    make(map[string]string),\n\t\tloops:     make(map[string]*host.Loop),\n\t}\n}\n\nfunc NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:        store,\n\t\tcaptures:     captures,\n\t\tcontainer:    container,\n\t\tdefaultImage: defaultImage,\n\t\trunIDs:       make(map[string]string),\n\t\tloops:        make(map[string]*host.Loop),\n\t}\n}\n\n// SetLogStore attaches a log store to the server for indexing extracted log files.\nfunc (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n\ts.logStore = ls\n}\n\n\n// SetEvolution attaches an evolution trigger to the server.\nfunc (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n\ts.evolution = trigger\n}\n\n// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\nfunc (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n\ts.logBroadcast = b\n}\n\n// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\nfunc (s *ClocheServer) SetShutdownFunc(fn func()) {\n\ts.shutdownFn = fn\n}\n\nfunc (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\t// Check if this is a host workflow (has host {} block).\n\tif hostWFs, err := host.FindHostWorkflows(req.ProjectDir); err == nil {\n\t\tif _, isHost := hostWFs[req.WorkflowName]; isHost {\n\t\t\treturn s.runHostWorkflow(ctx, req)\n\t\t}\n\t}\n\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\t// Generate a unique run ID, retrying on collision\n\tvar runID string\n\tfor attempts := 0; attempts < 10; attempts++ {\n\t\trunID = domain.GenerateRunID(req.WorkflowName)\n\t\texisting, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tbreak // ID is free\n\t\t}\n\t\t// Reuse if completed more than 1 hour ago\n\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n\t\t\t_ = s.store.DeleteRun(ctx, runID)\n\t\t\tbreak\n\t\t}\n\t}\n\n\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n\tif req.Prompt != \"\" {\n\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n\t\t}\n\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n\t\t}\n\t}\n\trun := domain.NewRun(runID, req.WorkflowName)\n\trun.ProjectDir = req.ProjectDir\n\trun.Title = req.Title\n\trun.TaskID = req.IssueId\n\tif err := s.store.CreateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n\t}\n\n\t// Resolve image: request-level override, then server default\n\timage := req.Image\n\tif image == \"\" {\n\t\timage = s.defaultImage\n\t}\n\n\t// Launch container start + tracking in background so the RPC returns immediately.\n\t// The run stays in \"pending\" state until the container is up.\n\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n\n\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n}\n\n// runHostWorkflow dispatches a host workflow via the host runner, returning\n// immediately while the workflow runs in a background goroutine.\nfunc (s *ClocheServer) runHostWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\trunID := domain.GenerateRunID(req.WorkflowName)\n\n\trunner := &host.Runner{\n\t\tDispatcher:   s,\n\t\tStore:        s.store,\n\t\tCaptures:     s.captures,\n\t\tLogBroadcast: s.logBroadcast,\n\t\tTaskID:       req.IssueId,\n\t}\n\n\tgo func() {\n\t\trunner.RunNamedWithID(context.Background(), req.ProjectDir, req.WorkflowName, runID)\n\t}()\n\n\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n}\n\n// launchAndTrack starts the container and then tracks it to completion.\n// It runs in a background goroutine with its own context, independent of the\n// RPC context which may be cancelled after RunWorkflow returns.\nfunc (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n\tctx := context.Background()\n\n\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n\t\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\t\tif run != nil {\n\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t\t}\n\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n\t\t\t\treturn\n\t\t}\n\t}\n\n\tbaseSHA := gitHEAD(req.ProjectDir)\n\n\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n\t\tImage:        image,\n\t\tWorkflowName: req.WorkflowName,\n\t\tProjectDir:   req.ProjectDir,\n\t\tRunID:        runID,\n\t\tNetworkAllow: []string{\"*\"},\n\t})\n\tif err != nil {\n\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\tif run != nil {\n\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t}\n\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n\t\treturn\n\t}\n\n\ts.mu.Lock()\n\ts.runIDs[runID] = containerID\n\ts.mu.Unlock()\n\n\trun, _ := s.store.GetRun(ctx, runID)\n\tif run != nil {\n\t\trun.Start()\n\t\trun.ContainerID = containerID\n\t\trun.BaseSHA = baseSHA\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n}\n\nfunc (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n\tctx := context.Background()\n\n\t// Attach to agent output\n\treader, err := s.container.AttachOutput(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n\t\t\treturn\n\t}\n\n\t// Parse JSON-lines status messages\n\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n\tvar reportedError string  // captured from MsgError, used to set ErrorMessage on failed runs\n\tscanner := bufio.NewScanner(reader)\n\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n\tfor scanner.Scan() {\n\t\tvar msg protocol.StatusMessage\n\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Fast path: log messages don't need store interaction.\n\t\tif msg.Type == protocol.MsgLog {\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"llm\",\n\t\t\t\t\tContent:   msg.Message,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\trun, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch msg.Type {\n\t\tcase protocol.MsgStepStarted:\n\t\t\trun.RecordStepStart(msg.StepName)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t\tStartedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"status\",\n\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgStepCompleted:\n\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:    msg.StepName,\n\t\t\t\t\tResult:      msg.Result,\n\t\t\t\t\tCompletedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"status\",\n\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgRunTitle:\n\t\t\tif run.Title == \"\" {\n\t\t\t\trun.Title = msg.Message\n\t\t\t}\n\t\tcase protocol.MsgError:\n\t\t\treportedError = msg.Message\n\t\t\tcontinue // Don't persist; used during finalization\n\t\tcase protocol.MsgRunCompleted:\n\t\t\treportedResult = msg.Result\n\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n\t\t}\n\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\treader.Close()\n\n\t// Signal live-stream subscribers that this run is done.\n\tif s.logBroadcast != nil {\n\t\ts.logBroadcast.Finish(runID)\n\t}\n\n\t// Wait for process exit\n\texitCode, err := s.container.Wait(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n\t}\n\n\t// Extract step output files from container before it's removed\n\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n\t\t}\n\t}\n\n\t// Capture full container stdout/stderr before the container is removed\n\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n\t\t}\n\t}\n\n\t// Index extracted log files in the log store\n\tif s.logStore != nil {\n\t\ts.indexLogFiles(ctx, runID, outputDst)\n\t}\n\n\t// Extract results to git branch BEFORE finalizing state, so that\n\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n\t// before the run is marked complete.\n\tresultLabel := reportedResult\n\tif resultLabel == \"\" {\n\t\tif exitCode == 0 {\n\t\t\tresultLabel = \"succeeded\"\n\t\t} else {\n\t\t\tresultLabel = \"failed\"\n\t\t}\n\t}\n\t{\n\t\textractRun, _ := s.store.GetRun(ctx, runID)\n\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n\t\t\t} else {\n\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n\t\t\t}\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n\t\t}\n\t}\n\n\t// Now finalize run state\n\trun, err := s.store.GetRun(ctx, runID)\n\tif err != nil {\n\t\treturn\n\t}\n\tif run.State == domain.RunStateRunning {\n\t\tif reportedResult == \"succeeded\" {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else if reportedResult != \"\" {\n\t\t\tif reportedError != \"\" {\n\t\t\t\trun.Fail(reportedError)\n\t\t\t} else {\n\t\t\t\trun.Complete(domain.RunStateFailed)\n\t\t\t}\n\t\t} else if exitCode == 0 {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else {\n\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n\t\t}\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\t// Fire evolution trigger if configured\n\tif s.evolution != nil {\n\t\ts.evolution.Fire(projectDir, workflowName, runID)\n\t}\n\n\t// Merge is handled as a workflow step in host.cloche, not here.\n\n\t// Container retention policy:\n\t// - Failed runs: always keep the container for debugging\n\t// - Successful runs + --keep-container: keep the container\n\t// - Successful runs without --keep-container: remove the container\n\trunFinal, _ := s.store.GetRun(ctx, runID)\n\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n\n\tif keepContainer || runFailed {\n\t\treason := \"--keep-container\"\n\t\tif runFailed {\n\t\t\treason = \"run failed\"\n\t\t}\n\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n\t\tif runFinal != nil {\n\t\t\trunFinal.ContainerKept = true\n\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n\t\t}\n\t} else {\n\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n\t\t}\n\t}\n\n\t// Cleanup mapping\n\ts.mu.Lock()\n\tdelete(s.runIDs, runID)\n\ts.mu.Unlock()\n}\n\nfunc (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n\tfilter := domain.RunListFilter{\n\t\tProjectDir: req.ProjectDir,\n\t\tState:      domain.RunState(req.State),\n\t\tTaskID:     req.TaskId,\n\t\tLimit:      int(req.Limit),\n\t}\n\n\t// When no project filter and not --all, default to last hour\n\tif filter.ProjectDir == \"\" && !req.All {\n\t\tfilter.Since = time.Now().Add(-1 * time.Hour)\n\t}\n\n\truns, err := s.store.ListRunsFiltered(ctx, filter)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n\t}\n\n\tresp := &pb.ListRunsResponse{}\n\tfor _, run := range runs {\n\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n\t\t\tRunId:        run.ID,\n\t\t\tWorkflowName: run.WorkflowName,\n\t\t\tState:        string(run.State),\n\t\t\tStartedAt:    run.StartedAt.String(),\n\t\t\tErrorMessage: run.ErrorMessage,\n\t\t\tContainerId:  run.ContainerID,\n\t\t\tTitle:        run.Title,\n\t\t\tIsHost:       run.IsHost,\n\t\t\tProjectDir:   run.ProjectDir,\n\t\t\tTaskId:       run.TaskID,\n\t\t})\n\t}\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n\t}\n\n\tresp := &pb.GetStatusResponse{\n\t\tRunId:        run.ID,\n\t\tWorkflowName: run.WorkflowName,\n\t\tState:        string(run.State),\n\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n\t\tErrorMessage: run.ErrorMessage,\n\t\tContainerId:  run.ContainerID,\n\t\tTitle:        run.Title,\n\t\tIsHost:       run.IsHost,\n\t}\n\n\t// Check container liveness\n\tif run.ContainerID != \"\" && s.container != nil {\n\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n\t\t\tresp.ContainerAlive = cs.Running\n\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n\t\t\t}\n\t\t}\n\t}\n\n\t// Load step executions from captures store if available\n\tif s.captures != nil {\n\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\t\tif err == nil {\n\t\t\tfor _, exec := range captures {\n\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\t\tStepName:    exec.StepName,\n\t\t\t\t\tResult:      exec.Result,\n\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, exec := range run.StepExecutions {\n\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\tStepName:    exec.StepName,\n\t\t\t\tResult:      exec.Result,\n\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t})\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tctx := stream.Context()\n\n\t_ = followFromContext(ctx) // follow is implicit for active runs\n\tlimit := limitFromContext(ctx)\n\n\t// Verify run exists\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n\t}\n\n\t// If step_name or log_type filter is set, serve content directly from the log index\n\tif req.StepName != \"\" || req.LogType != \"\" {\n\t\treturn s.streamFilteredLogs(ctx, req, run, stream, limit)\n\t}\n\n\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n\n\t// Active runs always stream live output (follow mode is implicit).\n\t// The -f flag is accepted but redundant for active runs.\n\tif isActive && s.logBroadcast != nil {\n\t\treturn s.streamFollowLogs(req.RunId, run, stream, limit)\n\t}\n\n\t// Check for full.log first — if it exists, serve it as the unified log\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n\t\tmsg := applyLimit(string(data), limit)\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: msg,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif !isActive {\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"run_completed\",\n\t\t\t\tResult:    string(run.State),\n\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}\n\n\tif s.captures == nil {\n\t\treturn fmt.Errorf(\"captures store not configured\")\n\t}\n\n\t// Fall back to capture-based streaming\n\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n\t}\n\n\tfor _, exec := range captures {\n\t\t// Captures are stored as separate rows: one for step_started (no Result)\n\t\t// and one for step_completed (has Result).\n\t\tif exec.Result == \"\" {\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_started\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tTimestamp: exec.StartedAt.String(),\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t} else {\n\t\t\t// Read step output from per-step output file.\n\t\t\t// Container runs write .log, host runs write .out — try both.\n\t\t\tvar output string\n\t\t\tfor _, ext := range []string{\".log\", \".out\"} {\n\t\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+ext)\n\t\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\t\t\t\toutput = string(data)\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_completed\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tResult:    exec.Result,\n\t\t\t\tTimestamp: exec.CompletedAt.String(),\n\t\t\t\tMessage:   applyLimit(output, limit),\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\t// Send run completion entry\n\tif !isActive {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:      \"run_completed\",\n\t\t\tResult:    string(run.State),\n\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\tMessage:   run.ErrorMessage,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// followFromContext checks for the follow flag in gRPC metadata.\nfunc followFromContext(ctx context.Context) bool {\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif !ok {\n\t\treturn false\n\t}\n\tvals := md.Get(\"x-cloche-follow\")\n\treturn len(vals) > 0 && vals[0] == \"true\"\n}\n\n// limitFromContext reads the line limit from gRPC metadata.\n// Returns 0 when no limit is set.\nfunc limitFromContext(ctx context.Context) int {\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif !ok {\n\t\treturn 0\n\t}\n\tvals := md.Get(\"x-cloche-limit\")\n\tif len(vals) == 0 {\n\t\treturn 0\n\t}\n\tn, err := strconv.Atoi(vals[0])\n\tif err != nil || n <= 0 {\n\t\treturn 0\n\t}\n\treturn n\n}\n\n// applyLimit returns the last n lines of content. If n <= 0, returns content unchanged.\nfunc applyLimit(content string, n int) string {\n\tif n <= 0 {\n\t\treturn content\n\t}\n\tlines := strings.Split(content, \"\\n\")\n\t// Remove trailing empty line from final newline\n\tif len(lines) > 0 && lines[len(lines)-1] == \"\" {\n\t\tlines = lines[:len(lines)-1]\n\t}\n\tif len(lines) <= n {\n\t\treturn content\n\t}\n\treturn strings.Join(lines[len(lines)-n:], \"\\n\") + \"\\n\"\n}\n\n// streamFollowLogs sends existing log content then tails live output from the\n// broadcaster. It combines snapshot + live streaming (like tail -f).\nfunc (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry], limit int) error {\n\t// Subscribe first so we don't miss lines written between read and subscribe.\n\tsub := s.logBroadcast.Subscribe(runID)\n\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n\n\t// Send existing full.log content if available.\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n\t\tmsg := applyLimit(string(data), limit)\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: msg,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\t// Now tail live output from the broadcaster.\n\tctx := stream.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Run completed — send terminal entry.\n\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n\t\t\t\t\t\tType:      \"run_completed\",\n\t\t\t\t\t\tResult:    string(r.State),\n\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n\t\t\t\t\t\tMessage:   r.ErrorMessage,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"log\",\n\t\t\t\tStepName:  line.StepName,\n\t\t\t\tMessage:   line.Content,\n\t\t\t\tTimestamp: line.Timestamp,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n}\n\n// streamFilteredLogs serves log content filtered by step name and/or log type.\n// It uses the log index when available, falling back to file path conventions.\nfunc (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry], limit int) error {\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n\n\t// Try log index first\n\tif s.logStore != nil {\n\t\tvar logFiles []*ports.LogFileEntry\n\t\tvar err error\n\n\t\tif req.StepName != \"\" && req.LogType != \"\" {\n\t\t\t// Filter by both step and type\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t\tif err == nil {\n\t\t\t\tfiltered := logFiles[:0]\n\t\t\t\tfor _, lf := range logFiles {\n\t\t\t\t\tif lf.FileType == req.LogType {\n\t\t\t\t\t\tfiltered = append(filtered, lf)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tlogFiles = filtered\n\t\t\t}\n\t\t} else if req.StepName != \"\" {\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t} else {\n\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n\t\t}\n\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr != nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\t\tType:     lf.FileType + \"_log\",\n\t\t\t\t\tStepName: lf.StepName,\n\t\t\t\t\tMessage:  applyLimit(string(data), limit),\n\t\t\t\t}); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Fall back to file path conventions\n\tif req.StepName != \"\" {\n\t\tvar logPath string\n\t\tswitch req.LogType {\n\t\tcase \"llm\":\n\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n\t\tdefault:\n\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n\t\t}\n\n\t\tdata, err := os.ReadFile(logPath)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n\t\t}\n\t\treturn stream.Send(&pb.LogEntry{\n\t\t\tType:     \"step_log\",\n\t\t\tStepName: req.StepName,\n\t\t\tMessage:  applyLimit(string(data), limit),\n\t\t})\n\t}\n\n\treturn fmt.Errorf(\"no log files found matching filter\")\n}\n\n// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n// time for an active run. The stream closes when the run completes or the\n// client disconnects.\nfunc (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tsub := s.logBroadcast.Subscribe(runID)\n\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n\n\tctx := stream.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Run completed — send terminal entry.\n\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n\t\t\t\t\t\tType:      \"run_completed\",\n\t\t\t\t\t\tResult:    string(run.State),\n\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"log\",\n\t\t\t\tStepName:  line.StepName,\n\t\t\t\tMessage:   line.Content,\n\t\t\t\tTimestamp: line.Timestamp,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n\ts.mu.Lock()\n\tcontainerID, ok := s.runIDs[req.RunId]\n\ts.mu.Unlock()\n\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n\t}\n\n\tif err := s.container.Stop(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n\t}\n\n\t// Mark as cancelled in store\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err == nil {\n\t\trun.Complete(domain.RunStateCancelled)\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.StopRunResponse{}, nil\n}\n\nfunc (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\tid := req.Id\n\tif id == \"\" {\n\t\treturn nil, fmt.Errorf(\"id is required\")\n\t}\n\n\t// Try to resolve as a run ID first\n\tcontainerID := id\n\trun, err := s.store.GetRun(ctx, id)\n\tif err == nil {\n\t\t// It's a run ID — use the container ID from the run record\n\t\tif run.ContainerID == \"\" {\n\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n\t\t}\n\t\tcontainerID = run.ContainerID\n\t}\n\n\t// Remove the container\n\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n\t}\n\n\t// If we resolved a run, clear the container_kept flag\n\tif run != nil {\n\t\trun.ContainerKept = false\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.DeleteContainerResponse{}, nil\n}\n\nfunc (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n\tprojectDir := req.ProjectDir\n\tif projectDir == \"\" {\n\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n\t}\n\n\t// Verify at least one host workflow exists in the project.\n\thostWorkflows, err := host.FindHostWorkflows(projectDir)\n\tif err != nil || len(hostWorkflows) == 0 {\n\t\treturn nil, fmt.Errorf(\"no host workflows found in %s/.cloche/\", projectDir)\n\t}\n\n\t// Load project config for defaults.\n\tprojCfg, _ := config.Load(projectDir)\n\n\tmaxConc := int(req.MaxConcurrent)\n\tif maxConc <= 0 {\n\t\tmaxConc = projCfg.Orchestration.Concurrency\n\t}\n\tif maxConc <= 0 {\n\t\tmaxConc = 1\n\t}\n\n\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n\n\t// Compute dedup timeout from config (default 5 minutes).\n\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n\n\tloopCfg := host.LoopConfig{\n\t\tProjectDir:    projectDir,\n\t\tMaxConcurrent: maxConc,\n\t\tStaggerDelay:  stagger,\n\t\tDedupTimeout:  dedupTimeout,\n\t\tStopOnError:   projCfg.Orchestration.StopOnError,\n\t}\n\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\t// Stop existing loop if running.\n\tif existing, ok := s.loops[projectDir]; ok {\n\t\texisting.Stop()\n\t}\n\n\t// Check if project defines a list-tasks workflow for three-phase mode.\n\tvar loop *host.Loop\n\tif _, hasListTasks := hostWorkflows[\"list-tasks\"]; hasListTasks {\n\t\tloop = s.createPhaseLoop(loopCfg, projectDir, dedupTimeout)\n\t} else {\n\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n\t}\n\n\ts.loops[projectDir] = loop\n\tloop.Start()\n\n\treturn &pb.EnableLoopResponse{}, nil\n}\n\n// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n// main, and finalize host workflows from any .cloche file.\nfunc (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir string, dedupTimeout time.Duration) *host.Loop {\n\t// Phase 1: list-tasks function\n\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n\t\trunner := &host.Runner{\n\t\t\tDispatcher: s,\n\t\t\tStore:      s.store,\n\t\t}\n\t\ttasks, _, err := host.RunListTasksWorkflow(ctx, runner, projDir)\n\t\treturn tasks, err\n\t}\n\n\t// Phase 2: main function\n\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n\t\trunner := &host.Runner{\n\t\t\tDispatcher:   s,\n\t\t\tStore:        s.store,\n\t\t\tCaptures:     s.captures,\n\t\t\tLogBroadcast: s.logBroadcast,\n\t\t\tTaskID:       taskID,\n\t\t}\n\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n\t}\n\n\t// Phase 3: finalize function (optional — only if a finalize host workflow exists)\n\tvar finalizeFn host.FinalizeFunc\n\tif hostWFs, err := host.FindHostWorkflows(projectDir); err == nil {\n\t\tif _, hasFinalize := hostWFs[\"finalize\"]; hasFinalize {\n\t\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n\t\t\t\tmainRunID := \"\"\n\t\t\t\tmainOutcome := \"failed\"\n\t\t\t\tif mainResult != nil {\n\t\t\t\t\tmainRunID = mainResult.RunID\n\t\t\t\t\tmainOutcome = string(mainResult.State)\n\t\t\t\t}\n\t\t\t\trunner := &host.Runner{\n\t\t\t\t\tDispatcher:   s,\n\t\t\t\t\tStore:        s.store,\n\t\t\t\t\tCaptures:     s.captures,\n\t\t\t\t\tLogBroadcast: s.logBroadcast,\n\t\t\t\t\tTaskID:       taskID,\n\t\t\t\t\tExtraEnv: []string{\n\t\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n\t\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n\t\t\t}\n\t\t}\n\t}\n\n\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n}\n\n// createLegacyLoop creates a legacy single-function orchestration loop.\nfunc (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n\t\trunner := &host.Runner{\n\t\t\tDispatcher:   s,\n\t\t\tStore:        s.store,\n\t\t\tCaptures:     s.captures,\n\t\t\tLogBroadcast: s.logBroadcast,\n\t\t\tTaskID:       taskID,\n\t\t}\n\t\treturn runner.Run(ctx, projDir)\n\t}\n\n\tloop := host.NewLoop(loopCfg, s.store, runFn)\n\n\t// Configure daemon-managed task assignment if a list-tasks command is set.\n\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n\t}\n\n\treturn loop\n}\n\n// GetLoopTasks returns the current task pipeline state for a project's\n// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n// loop is active for the project.\nfunc (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n\ts.mu.Lock()\n\tloop, ok := s.loops[projectDir]\n\ts.mu.Unlock()\n\tif !ok {\n\t\treturn nil\n\t}\n\tsnapshot := loop.GetTaskSnapshot()\n\n\t// Build a set of task IDs that have active (pending/running) runs.\n\tactiveTaskIDs := make(map[string]bool)\n\tctx := context.Background()\n\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n\tfor _, r := range allRuns {\n\t\tif r.TaskID != \"\" && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n\t\t\tactiveTaskIDs[r.TaskID] = true\n\t\t}\n\t}\n\n\tentries := make([]web.TaskEntry, len(snapshot))\n\tfor i, e := range snapshot {\n\t\tentry := web.TaskEntry{\n\t\t\tID:          e.Task.ID,\n\t\t\tStatus:      e.Task.Status,\n\t\t\tTitle:       e.Task.Title,\n\t\t\tDescription: e.Task.Description,\n\t\t\tMetadata:    e.Task.Metadata,\n\t\t\tAssigned:    e.Assigned,\n\t\t\tRunID:       e.RunID,\n\t\t}\n\t\tif !e.AssignedAt.IsZero() {\n\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n\t\t}\n\t\t// Stale: task is in_progress but has no active worker.\n\t\tif host.TaskStatus(e.Task.Status) == host.TaskStatusInProgress && !activeTaskIDs[e.Task.ID] {\n\t\t\tentry.Stale = true\n\t\t}\n\t\tentries[i] = entry\n\t}\n\treturn entries\n}\n\n// ReleaseTask runs the release-task host workflow for a specific task,\n// returning it to open status.\nfunc (s *ClocheServer) ReleaseTask(ctx context.Context, projectDir string, taskID string) error {\n\trunner := &host.Runner{\n\t\tDispatcher:   s,\n\t\tStore:        s.store,\n\t\tCaptures:     s.captures,\n\t\tLogBroadcast: s.logBroadcast,\n\t\tTaskID:       taskID,\n\t}\n\tresult, err := runner.RunNamed(ctx, projectDir, \"release-task\")\n\tif err != nil {\n\t\treturn fmt.Errorf(\"release-task workflow failed: %w\", err)\n\t}\n\tif result.State != domain.RunStateSucceeded {\n\t\treturn fmt.Errorf(\"release-task workflow finished with state %s\", result.State)\n\t}\n\treturn nil\n}\n\nfunc (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n\tprojectDir := req.ProjectDir\n\tif projectDir == \"\" {\n\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n\t}\n\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\tif loop, ok := s.loops[projectDir]; ok {\n\t\tloop.Stop()\n\t\tdelete(s.loops, projectDir)\n\t}\n\n\treturn &pb.DisableLoopResponse{}, nil\n}\n\nfunc (s *ClocheServer) ResumeLoop(ctx context.Context, req *pb.ResumeLoopRequest) (*pb.ResumeLoopResponse, error) {\n\tprojectDir := req.ProjectDir\n\tif projectDir == \"\" {\n\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n\t}\n\n\ts.mu.Lock()\n\tloop, ok := s.loops[projectDir]\n\ts.mu.Unlock()\n\n\tif !ok || loop == nil {\n\t\treturn nil, fmt.Errorf(\"no orchestration loop for %s\", projectDir)\n\t}\n\n\tloop.Resume()\n\treturn &pb.ResumeLoopResponse{}, nil\n}\n\nfunc (s *ClocheServer) GetProjectInfo(ctx context.Context, req *pb.GetProjectInfoRequest) (*pb.GetProjectInfoResponse, error) {\n\tprojectDir := req.ProjectDir\n\n\t// Resolve by name if provided.\n\tif req.Name != \"\" && projectDir == \"\" {\n\t\tprojects, err := s.store.ListProjects(ctx)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"listing projects: %w\", err)\n\t\t}\n\t\tlabels := projectLabels(projects)\n\t\tfound := false\n\t\tfor dir, label := range labels {\n\t\t\tif label == req.Name {\n\t\t\t\tprojectDir = dir\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\treturn nil, fmt.Errorf(\"project %q not found\", req.Name)\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\treturn nil, fmt.Errorf(\"project_dir or name is required\")\n\t}\n\n\t// Derive project label.\n\tprojects, _ := s.store.ListProjects(ctx)\n\tlabels := projectLabels(projects)\n\tlabel := labels[projectDir]\n\tif label == \"\" {\n\t\tlabel = filepath.Base(projectDir)\n\t}\n\n\t// Load config.\n\tcfg, _ := config.Load(projectDir)\n\n\t// Check loop state.\n\ts.mu.Lock()\n\tloop, loopExists := s.loops[projectDir]\n\ts.mu.Unlock()\n\tloopRunning := loopExists && loop != nil && loop.Running()\n\n\t// Get active runs.\n\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n\tvar activeRuns []*pb.RunSummary\n\tfor _, run := range allRuns {\n\t\tif run.State == domain.RunStatePending || run.State == domain.RunStateRunning {\n\t\t\tactiveRuns = append(activeRuns, &pb.RunSummary{\n\t\t\t\tRunId:        run.ID,\n\t\t\t\tWorkflowName: run.WorkflowName,\n\t\t\t\tState:        string(run.State),\n\t\t\t\tStartedAt:    run.StartedAt.String(),\n\t\t\t\tTitle:        run.Title,\n\t\t\t\tIsHost:       run.IsHost,\n\t\t\t\tContainerId:  run.ContainerID,\n\t\t\t})\n\t\t}\n\t}\n\n\t// Discover workflows.\n\tvar containerWorkflows, hostWorkflows []string\n\tclocheDir := filepath.Join(projectDir, \".cloche\")\n\tentries, _ := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n\tfor _, path := range entries {\n\t\tbase := filepath.Base(path)\n\t\tdata, err := os.ReadFile(path)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif base == \"host.cloche\" {\n\t\t\twfs, err := dsl.ParseAllForHost(string(data))\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor name := range wfs {\n\t\t\t\thostWorkflows = append(hostWorkflows, name)\n\t\t\t}\n\t\t} else {\n\t\t\twf, err := dsl.ParseForContainer(string(data))\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tcontainerWorkflows = append(containerWorkflows, wf.Name)\n\t\t}\n\t}\n\n\tsort.Strings(containerWorkflows)\n\tsort.Strings(hostWorkflows)\n\n\t// Check if loop is halted due to an error.\n\tvar errorHalted bool\n\tvar haltError string\n\tif loopExists && loop != nil {\n\t\terrorHalted, haltError = loop.Halted()\n\t}\n\n\treturn &pb.GetProjectInfoResponse{\n\t\tProjectDir:         projectDir,\n\t\tName:               label,\n\t\tActive:             cfg.Active,\n\t\tConcurrency:        int32(cfg.Orchestration.Concurrency),\n\t\tStaggerSeconds:     cfg.Orchestration.StaggerSeconds,\n\t\tDedupSeconds:       cfg.Orchestration.DedupSeconds,\n\t\tEvolutionEnabled:   cfg.Evolution.Enabled,\n\t\tLoopRunning:        loopRunning,\n\t\tActiveRuns:         activeRuns,\n\t\tContainerWorkflows: containerWorkflows,\n\t\tHostWorkflows:      hostWorkflows,\n\t\tStopOnError:        cfg.Orchestration.StopOnError,\n\t\tErrorHalted:        errorHalted,\n\t\tHaltError:          haltError,\n\t}, nil\n}\n\n// projectLabels maps each project directory to a short display label.\n// Uses basename unless there are conflicts, in which case parent/basename is used.\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\nfunc (s *ClocheServer) GetVersion(ctx context.Context, req *pb.GetVersionRequest) (*pb.GetVersionResponse, error) {\n\treturn &pb.GetVersionResponse{Version: version.Version()}, nil\n}\n\nfunc (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n\tif !req.Force {\n\t\t// Check for active container runs.\n\t\ts.mu.Lock()\n\t\tactiveRuns := len(s.runIDs)\n\t\ts.mu.Unlock()\n\t\tif activeRuns > 0 {\n\t\t\treturn nil, fmt.Errorf(\"cannot shutdown: %d run(s) still active (use --force to override)\", activeRuns)\n\t\t}\n\t}\n\n\t// Stop all orchestration loops.\n\ts.mu.Lock()\n\tfor _, loop := range s.loops {\n\t\tloop.Stop()\n\t}\n\ts.loops = make(map[string]*host.Loop)\n\ts.mu.Unlock()\n\n\tif s.shutdownFn == nil {\n\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n\t}\n\tgo s.shutdownFn()\n\treturn &pb.ShutdownResponse{}, nil\n}\n\n// indexLogFiles scans the extracted output directory and creates log_files index entries.\nfunc (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tname := entry.Name()\n\t\tif !strings.HasSuffix(name, \".log\") {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar fileType, stepName string\n\t\tbase := strings.TrimSuffix(name, \".log\")\n\n\t\tswitch {\n\t\tcase name == \"full.log\":\n\t\t\tfileType = \"full\"\n\t\tcase name == \"container.log\":\n\t\t\t// container.log is internal, not indexed as a user-facing log type\n\t\t\tcontinue\n\t\tcase strings.HasPrefix(name, \"llm-\"):\n\t\t\tfileType = \"llm\"\n\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n\t\tdefault:\n\t\t\tfileType = \"script\"\n\t\t\tstepName = base\n\t\t}\n\n\t\tinfo, _ := entry.Info()\n\t\tvar fileSize int64\n\t\tif info != nil {\n\t\t\tfileSize = info.Size()\n\t\t}\n\n\t\tlogEntry := &ports.LogFileEntry{\n\t\t\tRunID:     runID,\n\t\t\tStepName:  stepName,\n\t\t\tFileType:  fileType,\n\t\t\tFilePath:  filepath.Join(outputDir, name),\n\t\t\tFileSize:  fileSize,\n\t\t\tCreatedAt: now,\n\t\t}\n\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n\t\t}\n\t}\n}\n\nfunc gitHEAD(dir string) string {\n\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\treturn strings.TrimSpace(string(out))\n}\n","numLines":1357,"startLine":1,"totalLines":1357}}}
