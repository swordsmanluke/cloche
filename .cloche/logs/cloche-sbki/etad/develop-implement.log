{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RXBCqAqUDdcc33xkQgzxQX","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"sort\"\n    13→\t\"strconv\"\n    14→\t\"strings\"\n    15→\t\"sync\"\n    16→\t\"time\"\n    17→\n    18→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    20→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    21→\t\"github.com/cloche-dev/cloche/internal/config\"\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    24→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    25→\t\"github.com/cloche-dev/cloche/internal/host\"\n    26→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    27→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    28→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    29→\t\"github.com/cloche-dev/cloche/internal/version\"\n    30→\trpcgrpc \"google.golang.org/grpc\"\n    31→\t\"google.golang.org/grpc/metadata\"\n    32→)\n    33→\n    34→type ClocheServer struct {\n    35→\tpb.UnimplementedClocheServiceServer\n    36→\tstore        ports.RunStore\n    37→\tcaptures     ports.CaptureStore\n    38→\tlogStore     ports.LogStore\n    39→\tcontainer    ports.ContainerRuntime\n    40→\tdefaultImage string\n    41→\tevolution    *evolution.Trigger\n    42→\tlogBroadcast *logstream.Broadcaster\n    43→\tshutdownFn   func()\n    44→\tmu           sync.Mutex\n    45→\trunIDs       map[string]string      // run_id -> container_id\n    46→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    47→}\n    48→\n    49→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    50→\treturn &ClocheServer{\n    51→\t\tstore:     store,\n    52→\t\tcontainer: container,\n    53→\t\trunIDs:    make(map[string]string),\n    54→\t\tloops:     make(map[string]*host.Loop),\n    55→\t}\n    56→}\n    57→\n    58→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    59→\treturn &ClocheServer{\n    60→\t\tstore:        store,\n    61→\t\tcaptures:     captures,\n    62→\t\tcontainer:    container,\n    63→\t\tdefaultImage: defaultImage,\n    64→\t\trunIDs:       make(map[string]string),\n    65→\t\tloops:        make(map[string]*host.Loop),\n    66→\t}\n    67→}\n    68→\n    69→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    70→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    71→\ts.logStore = ls\n    72→}\n    73→\n    74→\n    75→// SetEvolution attaches an evolution trigger to the server.\n    76→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    77→\ts.evolution = trigger\n    78→}\n    79→\n    80→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    81→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    82→\ts.logBroadcast = b\n    83→}\n    84→\n    85→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    86→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    87→\ts.shutdownFn = fn\n    88→}\n    89→\n    90→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    91→\t// Check if this is a host workflow (has host {} block).\n    92→\tif hostWFs, err := host.FindHostWorkflows(req.ProjectDir); err == nil {\n    93→\t\tif _, isHost := hostWFs[req.WorkflowName]; isHost {\n    94→\t\t\treturn s.runHostWorkflow(ctx, req)\n    95→\t\t}\n    96→\t}\n    97→\n    98→\tif s.container == nil {\n    99→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   100→\t}\n   101→\n   102→\t// Generate a unique run ID, retrying on collision\n   103→\tvar runID string\n   104→\tfor attempts := 0; attempts < 10; attempts++ {\n   105→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n   106→\t\texisting, err := s.store.GetRun(ctx, runID)\n   107→\t\tif err != nil {\n   108→\t\t\tbreak // ID is free\n   109→\t\t}\n   110→\t\t// Reuse if completed more than 1 hour ago\n   111→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   112→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   113→\t\t\tbreak\n   114→\t\t}\n   115→\t}\n   116→\n   117→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   118→\tif req.Prompt != \"\" {\n   119→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   120→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   121→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   122→\t\t}\n   123→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   124→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   125→\t\t}\n   126→\t}\n   127→\trun := domain.NewRun(runID, req.WorkflowName)\n   128→\trun.ProjectDir = req.ProjectDir\n   129→\trun.Title = req.Title\n   130→\trun.TaskID = req.IssueId\n   131→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   132→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   133→\t}\n   134→\n   135→\t// Resolve image: request-level override, then server default\n   136→\timage := req.Image\n   137→\tif image == \"\" {\n   138→\t\timage = s.defaultImage\n   139→\t}\n   140→\n   141→\t// Launch container start + tracking in background so the RPC returns immediately.\n   142→\t// The run stays in \"pending\" state until the container is up.\n   143→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   144→\n   145→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   146→}\n   147→\n   148→// runHostWorkflow dispatches a host workflow via the host runner, returning\n   149→// immediately while the workflow runs in a background goroutine.\n   150→func (s *ClocheServer) runHostWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n   151→\trunID := domain.GenerateRunID(req.WorkflowName)\n   152→\n   153→\trunner := &host.Runner{\n   154→\t\tDispatcher:   s,\n   155→\t\tStore:        s.store,\n   156→\t\tCaptures:     s.captures,\n   157→\t\tLogBroadcast: s.logBroadcast,\n   158→\t\tTaskID:       req.IssueId,\n   159→\t}\n   160→\n   161→\tgo func() {\n   162→\t\trunner.RunNamedWithID(context.Background(), req.ProjectDir, req.WorkflowName, runID)\n   163→\t}()\n   164→\n   165→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   166→}\n   167→\n   168→// launchAndTrack starts the container and then tracks it to completion.\n   169→// It runs in a background goroutine with its own context, independent of the\n   170→// RPC context which may be cancelled after RunWorkflow returns.\n   171→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   172→\tctx := context.Background()\n   173→\n   174→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   175→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   176→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   177→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   178→\t\t\tif run != nil {\n   179→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   180→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   181→\t\t\t}\n   182→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   183→\t\t\t\treturn\n   184→\t\t}\n   185→\t}\n   186→\n   187→\tbaseSHA := gitHEAD(req.ProjectDir)\n   188→\n   189→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   190→\t\tImage:        image,\n   191→\t\tWorkflowName: req.WorkflowName,\n   192→\t\tProjectDir:   req.ProjectDir,\n   193→\t\tRunID:        runID,\n   194→\t\tNetworkAllow: []string{\"*\"},\n   195→\t})\n   196→\tif err != nil {\n   197→\t\trun, _ := s.store.GetRun(ctx, runID)\n   198→\t\tif run != nil {\n   199→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   200→\t\t\t_ = s.store.UpdateRun(ctx, run)"}]},"parent_tool_use_id":"toolu_01LUR8zLT62d8pbFKzq3zGR4","session_id":"a767d320-7441-4cfb-80d2-26edf647ec06","uuid":"ee38557c-4344-45a0-8dfd-8efb5ba709f7"}
