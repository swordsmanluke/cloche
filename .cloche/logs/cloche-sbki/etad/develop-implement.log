elp(\"health\")\n    63→\t\t\treturn\n    64→\t\t}\n    65→\t\tcmdHealth(os.Args[2:])\n    66→\t\treturn\n    67→\tcase \"get\":\n    68→\t\tif hasHelpFlag(os.Args[2:]) {\n    69→\t\t\tprintSubcommandHelp(\"get\")\n    70→\t\t\treturn\n    71→\t\t}\n    72→\t\tcmdGet(os.Args[2:])\n    73→\t\treturn\n    74→\tcase \"set\":\n    75→\t\tif hasHelpFlag(os.Args[2:]) {\n    76→\t\t\tprintSubcommandHelp(\"set\")\n    77→\t\t\treturn\n    78→\t\t}\n    79→\t\tcmdSet(os.Args[2:])\n    80→\t\treturn\n    81→\tcase \"tasks\":\n    82→\t\tif hasHelpFlag(os.Args[2:]) {\n    83→\t\t\tprintSubcommandHelp(\"tasks\")\n    84→\t\t\treturn\n    85→\t\t}\n    86→\t\tcmdTasks(os.Args[2:])\n    87→\t\treturn\n    88→\tcase \"workflow\":\n    89→\t\tif hasHelpFlag(os.Args[2:]) {\n    90→\t\t\tprintSubcommandHelp(\"workflow\")\n    91→\t\t\treturn\n    92→\t\t}\n    93→\t\tcmdWorkflow(os.Args[2:])\n    94→\t\treturn\n    95→\tcase \"project\":\n    96→\t\tif hasHelpFlag(os.Args[2:]) {\n    97→\t\t\tprintSubcommandHelp(\"project\")\n    98→\t\t\treturn\n    99→\t\t}\n   100→\t\tcmdProject(os.Args[2:])\n   101→\t\treturn\n   102→\tcase \"validate\":\n   103→\t\tif hasHelpFlag(os.Args[2:]) {\n   104→\t\t\tprintSubcommandHelp(\"validate\")\n   105→\t\t\treturn\n   106→\t\t}\n   107→\t\tcmdValidate(os.Args[2:])\n   108→\t\treturn\n   109→\t}\n   110→\n   111→\t// Handle --help for daemon commands before connecting\n   112→\tdaemonCmds := map[string]bool{\n   113→\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n   114→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n   115→\t}\n   116→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n   117→\t\tprintSubcommandHelp(os.Args[1])\n   118→\t\treturn\n   119→\t}\n   120→\n   121→\t// Commands that need a daemon connection\n   122→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   123→\tif addr == \"\" {\n   124→\t\taddr = config.DefaultSocketAddr()\n   125→\t}\n   126→\n   127→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   128→\tif err != nil {\n   129→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   130→\t\tos.Exit(1)\n   131→\t}\n   132→\tdefer conn.Close()\n   133→\n   134→\tclient := pb.NewClocheServiceClient(conn)\n   135→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   136→\tdefer cancel()\n   137→\n   138→\tswitch os.Args[1] {\n   139→\tcase \"run\":\n   140→\t\tcmdRun(ctx, client, os.Args[2:])\n   141→\tcase \"status\":\n   142→\t\tcmdStatus(ctx, client, os.Args[2:])\n   143→\tcase \"logs\":\n   144→\t\tcmdLogs(client, os.Args[2:])\n   145→\tcase \"poll\":\n   146→\t\tcmdPoll(client, os.Args[2:])\n   147→\tcase \"list\":\n   148→\t\tcmdList(ctx, client, os.Args[2:])\n   149→\tcase \"stop\":\n   150→\t\tcmdStop(ctx, client, os.Args[2:])\n   151→\tcase \"delete\":\n   152→\t\tcmdDelete(ctx, client, os.Args[2:])\n   153→\tcase \"loop\":\n   154→\t\tcmdLoop(ctx, client, os.Args[2:])\n   155→\tcase \"shutdown\":\n   156→\t\tcmdShutdown(ctx, client, os.Args[2:])\n   157→\tdefault:\n   158→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   159→\t\tprintTopLevelHelp()\n   160→\t\tos.Exit(1)\n   161→\t}\n   162→}\n   163→\n   164→\n   165→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   166→\tvar workflow, prompt, title, issueID string\n   167→\tvar keepContainer bool\n   168→\n   169→\tfor i := 0; i < len(args); i++ {\n   170→\t\tswitch args[i] {\n   171→\t\tcase \"--workflow\":\n   172→\t\t\tif i+1 < len(args) {\n   173→\t\t\t\ti++\n   174→\t\t\t\tworkflow = args[i]\n   175→\t\t\t}\n   176→\t\tcase \"--prompt\", \"-p\":\n   177→\t\t\tif i+1 < len(args) {\n   178→\t\t\t\ti++\n   179→\t\t\t\tprompt = args[i]\n   180→\t\t\t}\n   181→\t\tcase \"--title\":\n   182→\t\t\tif i+1 < len(args) {\n   183→\t\t\t\ti++\n   184→\t\t\t\ttitle = args[i]\n   185→\t\t\t}\n   186→\t\tcase \"--issue\", \"-i\":\n   187→\t\t\tif i+1 < len(args) {\n   188→\t\t\t\ti++\n   189→\t\t\t\tissueID = args[i]\n   190→\t\t\t}\n   191→\t\tcase \"--keep-container\":\n   192→\t\t\tkeepContainer = true\n   193→\t\tdefault:\n   194→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   195→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   196→\t\t\t\tworkflow = args[i]\n   197→\t\t\t}\n   198→\t\t}\n   199→\t}\n   200→\n   201→\tif workflow == \"\" {\n   202→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"] [--issue ID]\\n\")\n   203→\t\tos.Exit(1)\n   204→\t}\n   205→\n   206→\tcwd, _ := os.Getwd()\n   207→\n   208→\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n   209→\t// Try loading from any .cloche file; only extract image for container workflows.\n   210→\tvar image string\n   211→\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n   212→\t\timage = wf.Config[\"container.image\"]\n   213→\t}\n   214→\n   215→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   216→\t\tWorkflowName:  workflow,\n   217→\t\tProjectDir:    cwd,\n   218→\t\tImage:         image,\n   219→\t\tPrompt:        prompt,\n   220→\t\tKeepContainer: keepContainer,\n   221→\t\tTitle:         title,\n   222→\t\tIssueId:       issueID,\n   223→\t})\n   224→\tif err != nil {\n   225→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   226→\t\tos.Exit(1)\n   227→\t}\n   228→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   229→}\n   230→\n   231→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   232→\t// Parse flags to detect --all before checking positional args.\n   233→\tvar all bool\n   234→\tvar positional []string\n   235→\tfor _, arg := range args {\n   236→\t\tif arg == \"--all\" {\n   237→\t\t\tall = true\n   238→\t\t} else {\n   239→\t\t\tpositional = append(positional, arg)\n   240→\t\t}\n   241→\t}\n   242→\n   243→\t// If a run ID is provided, show single-run status.\n   244→\tif len(positional) > 0 {\n   245→\t\tcmdStatusRun(ctx, client, positional[0])\n   246→\t\treturn\n   247→\t}\n   248→\n   249→\t// No run ID: show daemon status overview.\n   250→\tcmdStatusOverview(ctx, client, os.Stdout, all)\n   251→}\n   252→\n   253→func cmdStatusRun(ctx context.Context, client pb.ClocheServiceClient, runID string) {\n   254→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: runID})\n   255→\tif err != nil {\n   256→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   257→\t\tos.Exit(1)\n   258→\t}\n   259→\n   260→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   261→\tif resp.Title != \"\" {\n   262→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   263→\t}\n   264→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   265→\tif resp.IsHost {\n   266→\t\tfmt.Printf(\"Type:      host\\n\")\n   267→\t} else {\n   268→\t\tfmt.Printf(\"Type:      container\\n\")\n   269→\t}\n   270→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   271→\tif resp.ContainerId != \"\" {\n   272→\t\tcid := resp.ContainerId\n   273→\t\tif len(cid) > 12 {\n   274→\t\t\tcid = cid[:12]\n   275→\t\t}\n   276→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   277→\t}\n   278→\tif resp.ErrorMessage != \"\" {\n   279→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   280→\t}\n   281→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   282→\tfor _, exec := range resp.StepExecutions {\n   283→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   284→\t}\n   285→}\n   286→\n   287→func cmdStatusOverview(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, all bool) {\n   288→\t// Get daemon version.\n   289→\tverResp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   290→\tif err != nil {\n   291→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   292→\t\tos.Exit(1)\n   293→\t}\n   294→\tfmt.Fprintf(w, \"Daemon version: %s\\n\", verResp.Version)\n   295→\n   296→\tcwd, _ := os.Getwd()\n   297→\t_, hasClocheDir := os.Stat(filepath.Join(cwd, \".cloche\"))\n   298→\n   299→\tif !all && hasClocheDir == nil {\n   300→\t\t// In a project directory: show project-specific info.\n   301→\t\tcmdStatusProject(ctx, client, w, cwd)\n   302→\t} else {\n   303→\t\t// Not in a project directory or --all: show global overview.\n   304→\t\tcmdStatusGlobal(ctx, client, w)\n   305→\t}\n   306→}\n   307→\n   308→func cmdStatusProject(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, projectDir string) {\n   309→\tinfo, err := client.GetProjectInfo(ctx, &pb.GetProjectInfoRequest{ProjectDir: projectDir})\n   310→\tif err != nil {\n   311→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   312→\t\tos.Exit(1)\n   313→\t}\n   314→\n   315→\tfmt.Fprintf(w, \"Project: %s\\n\", info.Name)\n   316→\tfmt.Fprintf(w, \"Concurrency: %d\\n\", info.Concurrency)\n   317→\n   318→\tloopStatus := \"stopped\"\n   319→\tif info.LoopRunning {\n   320→\t\tif info.ErrorHalted {\n   321→\t\t\tloopStatus = \"halted\"\n   322→\t\t} else {\n   323→\t\t\tloopStatus = \"running\"\n   324→\t\t}\n   325→\t}\n   326→\tfmt.Fprintf(w, \"Orchestration loop: %s\\n\", loopStatus)\n   327→\n   328→\t// Fetch runs for the past hour to compute success rate.\n   329→\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: projectDir})\n   330→\tif err != nil {\n   331→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   332→\t\tos.Exit(1)\n   333→\t}\n   334→\n   335→\tvar succeeded int\n   336→\tfor _, run := range listResp.Runs {\n   337→\t\tif run.State == \"succeeded\" {\n   338→\t\t\tsucceeded++\n   339→\t\t}\n   340→\t}\n   341→\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n   342→\n   343→\t// Active runs from project info.\n   344→\tfmt.Fprintf(w, \"Active runs: %d\\n\", len(info.ActiveRuns))\n   345→\tfor _, run := range info.ActiveRuns {\n   346→\t\tdur := formatDuration(run.StartedAt)\n   347→\t\tfmt.Fprintf(w, \"  %s: %s\\n\", run.RunId, dur)\n   348→\t}\n   349→}\n   350→\n   351→func cmdStatusGlobal(ctx context.Context, client pb.ClocheServiceClient, w io.Writer) {\n   352→\t// Fetch all runs (server defaults to past hour when no project filter and not --all).\n   353→\t// We pass All=true but the server returns everything; we filter client-side to past hour.\n   354→\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: true})\n   355→\tif err != nil {\n   356→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   357→\t\tos.Exit(1)\n   358→\t}\n   359→\n   360→\tvar succeeded, total, activeCount int\n   361→\ttype activeRun struct {\n   362→\t\tid        string\n   363→\t\tstartedAt string\n   364→\t}\n   365→\tvar actives []activeRun\n   366→\n   367→\toneHourAgo := time.Now().Add(-1 * time.Hour)\n   368→\tfor _, run := range listResp.Runs {\n   369→\t\tparsed, parseErr := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", run.StartedAt)\n   370→\t\tif parseErr != nil {\n   371→\t\t\t// Fall back: count all runs returned.\n   372→\t\t\tparsed = time.Time{}\n   373→\t\t}\n   374→\t\tif !parsed.IsZero() && parsed.Before(oneHourAgo) {\n   375→\t\t\tcontinue\n   376→\t\t}\n   377→\t\ttotal++\n   378→\t\tif run.State == \"succeeded\" {\n   379→\t\t\tsucceeded++\n   380→\t\t}\n   381→\t\tif run.State == \"running\" || run.State == \"pending\" {\n   382→\t\t\tactiveCount++\n   383→\t\t\tactives = append(actives, activeRun{id: run.RunId, startedAt: run.StartedAt})\n   384→\t\t}\n   385→\t}\n   386→\n   387→\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, total)\n   388→\tfmt.Fprintf(w, \"Active runs: %d\\n\", activeCount)\n   389→\tfor _, a := range actives {\n   390→\t\tdur := formatDuration(a.startedAt)\n   391→\t\tfmt.Fprintf(w, \"  %s: %s\\n\", a.id, dur)\n   392→\t}\n   393→}\n   394→\n   395→// formatDuration parses a Go time string and returns a human-readable duration since then.\n   396→func formatDuration(startedAt string) string {\n   397→\tparsed, err := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", startedAt)\n   398→\tif err != nil {\n   399→\t\treturn startedAt\n   400→\t}\n   401→\td := time.Since(parsed)\n   402→\tif d < time.Minute {\n   403→\t\treturn fmt.Sprintf(\"%ds\", int(d.Seconds()))\n   404→\t}\n   405→\tif d < time.Hour {\n   406→\t\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n   407→\t}\n   408→\treturn fmt.Sprintf(\"%dh%dm\", int(d.Hours()), int(d.Minutes())%60)\n   409→}\n   410→\n   411→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   412→\tvar all bool\n   413→\tvar projectDir, stateFilter, issueFilter string\n   414→\tvar limit int32\n   415→\n   416→\tfor i := 0; i < len(args); i++ {\n   417→\t\tswitch args[i] {\n   418→\t\tcase \"--all\":\n   419→\t\t\tall = true\n   420→\t\tcase \"--project\", \"-p\":\n   421→\t\t\tif i+1 < len(args) {\n   422→\t\t\t\ti++\n   423→\t\t\t\tprojectDir = args[i]\n   424→\t\t\t}\n   425→\t\tcase \"--state\", \"-s\":\n   426→\t\t\tif i+1 < len(args) {\n   427→\t\t\t\ti++\n   428→\t\t\t\tstateFilter = args[i]\n   429→\t\t\t}\n   430→\t\tcase \"--limit\", \"-n\":\n   431→\t\t\tif i+1 < len(args) {\n   432→\t\t\t\ti++\n   433→\t\t\t\tn, err := strconv.Atoi(args[i])\n   434→\t\t\t\tif err != nil {\n   435→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   436→\t\t\t\t\tos.Exit(1)\n   437→\t\t\t\t}\n   438→\t\t\t\tlimit = int32(n)\n   439→\t\t\t}\n   440→\t\tcase \"--issue\", \"-i\":\n   441→\t\t\tif i+1 < len(args) {\n   442→\t\t\t\ti++\n   443→\t\t\t\tissueFilter = args[i]\n   444→\t\t\t}\n   445→\t\t}\n   446→\t}\n   447→\n   448→\treq := &pb.ListRunsRequest{\n   449→\t\tState:  stateFilter,\n   450→\t\tLimit:  limit,\n   451→\t\tTaskId: issueFilter,\n   452→\t}\n   453→\tif projectDir != \"\" {\n   454→\t\treq.ProjectDir = projectDir\n   455→\t} else if all {\n   456→\t\treq.All = true\n   457→\t} else {\n   458→\t\t// Default: filter to current project\n   459→\t\tcwd, _ := os.Getwd()\n   460→\t\treq.ProjectDir = cwd\n   461→\t}\n   462→\n   463→\tresp, err := client.ListRuns(ctx, req)\n   464→\tif err != nil {\n   465→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   466→\t\tos.Exit(1)\n   467→\t}\n   468→\n   469→\tif len(resp.Runs) == 0 {\n   470→\t\tfmt.Println(\"No runs found.\")\n   471→\t\treturn\n   472→\t}\n   473→\n   474→\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n   475→\tfmt.Fprintln(w, \"RUN ID\\tWORKFLOW\\tSTATE\\tTYPE\\tTASK ID\\tTITLE\\tCONTAINER\\tERROR\")\n   476→\tfor _, run := range resp.Runs {\n   477→\t\trunType := \"container\"\n   478→\t\tif run.IsHost {\n   479→\t\t\trunType = \"host\"\n   480→\t\t}\n   481→\t\ttitle := run.Title\n   482→\t\tif len(title) > 40 {\n   483→\t\t\ttitle = title[:37] + \"...\"\n   484→\t\t}\n   485→\t\terrMsg := run.ErrorMessage\n   486→\t\tif len(errMsg) > 60 {\n   487→\t\t\terrMsg = errMsg[:57] + \"...\"\n   488→\t\t}\n   489→\t\tfmt.Fprintf(w, \"%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\n\",\n   490→\t\t\trun.RunId, run.WorkflowName, run.State, runType,\n   491→\t\t\trun.TaskId, title, run.ContainerId, errMsg)\n   492→\t}\n   493→\tw.Flush()\n   494→}\n   495→\n   496→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   497→\tif len(args) < 1 {\n   498→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n   499→\t\tos.Exit(1)\n   500→\t}\n   501→\n   502→\tvar stepFilter, typeFilter string\n   503→\tvar follow bool\n   504→\tvar limit int\n   505→\trunID := args[0]\n   506→\n   507→\tfor i := 1; i < len(args); i++ {\n   508→\t\tswitch args[i] {\n   509→\t\tcase \"--step\", \"-s\":\n   510→\t\t\tif i+1 < len(args) {\n   511→\t\t\t\ti++\n   512→\t\t\t\tstepFilter = args[i]\n   513→\t\t\t}\n   514→\t\tcase \"--type\":\n   515→\t\t\tif i+1 < len(args) {\n   516→\t\t\t\ti++\n   517→\t\t\t\ttypeFilter = args[i]\n   518→\t\t\t}\n   519→\t\tcase \"--follow\", \"-f\":\n   520→\t\t\tfollow = true\n   521→\t\tcase \"--limit\", \"-l\":\n   522→\t\t\tif i+1 < len(args) {\n   523→\t\t\t\ti++\n   524→\t\t\t\tn, err := strconv.Atoi(args[i])\n   525→\t\t\t\tif err != nil || n < 0 {\n   526→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n   527→\t\t\t\t\tos.Exit(1)\n   528→\t\t\t\t}\n   529→\t\t\t\tlimit = n\n   530→\t\t\t}\n   531→\t\t}\n   532→\t}\n   533→\n   534→\t// Use background context — log output can be large and follow mode blocks.\n   535→\tctx := context.Background()\n   536→\tvar mdPairs []string\n   537→\tif follow {\n   538→\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n   539→\t}\n   540→\tif limit > 0 {\n   541→\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n   542→\t}\n   543→\tif len(mdPairs) > 0 {\n   544→\t\tmd := metadata.Pairs(mdPairs...)\n   545→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   546→\t}\n   547→\n   548→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   549→\t\tRunId:    runID,\n   550→\t\tStepName: stepFilter,\n   551→\t\tLogType:  typeFilter,\n   552→\t})\n   553→\tif err != nil {\n   554→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   555→\t\tos.Exit(1)\n   556→\t}\n   557→\n   558→\tfor {\n   559→\t\tentry, err := stream.Recv()\n   560→\t\tif err != nil {\n   561→\t\t\tif errors.Is(err, io.EOF) {\n   562→\t\t\t\tbreak\n   563→\t\t\t}\n   564→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   565→\t\t\tos.Exit(1)\n   566→\t\t}\n   567→\n   568→\t\tswitch entry.Type {\n   569→\t\tcase \"step_started\":\n   570→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   571→\t\t\tif entry.Message != \"\" {\n   572→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   573→\t\t\t}\n   574→\t\tcase \"step_completed\":\n   575→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   576→\t\t\tif entry.Message != \"\" {\n   577→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   578→\t\t\t}\n   579→\t\tcase \"run_completed\":\n   580→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   581→\t\t\tif entry.Message != \"\" {\n   582→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   583→\t\t\t}\n   584→\t\tcase \"full_log\":\n   585→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   586→\t\tcase \"log\":\n   587→\t\t\t// Live-streamed log line from an active run.\n   588→\t\t\tfmt.Println(entry.Message)\n   589→\t\tdefault:\n   590→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   591→\t\t\tif entry.StepName != \"\" {\n   592→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   593→\t\t\t}\n   594→\t\t\tif entry.Message != \"\" {\n   595→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   596→\t\t\t}\n   597→\t\t}\n   598→\t}\n   599→}\n   600→\n   601→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   602→\tif len(args) < 1 {\n   603→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   604→\t\tos.Exit(1)\n   605→\t}\n   606→\n   607→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   608→\tif err != nil {\n   609→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   610→\t\tos.Exit(1)\n   611→\t}\n   612→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   613→}\n   614→\n   615→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   616→\tif len(args) < 1 {\n   617→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   618→\t\tos.Exit(1)\n   619→\t}\n   620→\n   621→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   622→\tif err != nil {\n   623→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   624→\t\tos.Exit(1)\n   625→\t}\n   626→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   627→}\n   628→\n   629→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   630→\tcwd, _ := os.Getwd()\n   631→\n   632→\t// Check for \"stop\" subcommand\n   633→\tif len(args) > 0 && args[0] == \"stop\" {\n   634→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   635→\t\tif err != nil {\n   636→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   637→\t\t\tos.Exit(1)\n   638→\t\t}\n   639→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   640→\t\treturn\n   641→\t}\n   642→\n   643→\t// Check for \"resume\" subcommand\n   644→\tif len(args) > 0 && args[0] == \"resume\" {\n   645→\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n   646→\t\tif err != nil {\n   647→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   648→\t\t\tos.Exit(1)\n   649→\t\t}\n   650→\t\tfmt.Println(\"Orchestration loop resumed.\")\n   651→\t\treturn\n   652→\t}\n   653→\n   654→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   655→\tvar maxConcurrent int32\n   656→\tfor i := 0; i < len(args); i++ {\n   657→\t\tswitch args[i] {\n   658→\t\tcase \"--max\":\n   659→\t\t\tif i+1 < len(args) {\n   660→\t\t\t\ti++\n   661→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   662→\t\t\t\tif n != 1 || err != nil {\n   663→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   664→\t\t\t\t\tos.Exit(1)\n   665→\t\t\t\t}\n   666→\t\t\t}\n   667→\t\t}\n   668→\t}\n   669→\n   670→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   671→\t\tProjectDir:    cwd,\n   672→\t\tMaxConcurrent: maxConcurrent,\n   673→\t})\n   674→\tif err != nil {\n   675→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   676→\t\tos.Exit(1)\n   677→\t}\n   678→\tif maxConcurrent > 0 {\n   679→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   680→\t} else {\n   681→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   682→\t}\n   683→}\n   684→\n   685→func cmdTasks(args []string) {\n   686→\t// Determine HTTP address from env\n   687→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   688→\tif httpAddr == \"\" {\n   689→\t\thttpAddr = \"localhost:8080\"\n   690→\t}\n   691→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   692→\n   693→\t// Determine project label from --project flag or current directory\n   694→\tprojectDir := \"\"\n   695→\tfor i := 0; i < len(args); i++ {\n   696→\t\tswitch args[i] {\n   697→\t\tcase \"--project\":\n   698→\t\t\tif i+1 < len(args) {\n   699→\t\t\t\ti++\n   700→\t\t\t\tprojectDir = args[i]\n   701→\t\t\t}\n   702→\t\t}\n   703→\t}\n   704→\n   705→\tif projectDir == \"\" {\n   706→\t\tcwd, _ := os.Getwd()\n   707→\t\tprojectDir = filepath.Base(cwd)\n   708→\t}\n   709→\n   710→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   711→\tresp, err := http.Get(tasksURL)\n   712→\tif err != nil {\n   713→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   714→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   715→\t\tos.Exit(1)\n   716→\t}\n   717→\tdefer resp.Body.Close()\n   718→\n   719→\tif resp.StatusCode != 200 {\n   720→\t\tbody, _ := io.ReadAll(resp.Body)\n   721→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   722→\t\tos.Exit(1)\n   723→\t}\n   724→\n   725→\ttype taskEntry struct {\n   726→\t\tID          string `json:\"id\"`\n   727→\t\tStatus      string `json:\"status\"`\n   728→\t\tTitle       string `json:\"title\"`\n   729→\t\tDescription string `json:\"description\"`\n   730→\t\tAssigned    bool   `json:\"assigned\"`\n   731→\t\tAssignedAt  string `json:\"assigned_at\"`\n   732→\t\tRunID       string `json:\"run_id\"`\n   733→\t}\n   734→\n   735→\tvar tasks []taskEntry\n   736→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   737→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   738→\t\tos.Exit(1)\n   739→\t}\n   740→\n   741→\tif len(tasks) == 0 {\n   742→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   743→\t\treturn\n   744→\t}\n   745→\n   746→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   747→\tfor _, t := range tasks {\n   748→\t\tstatus := t.Status\n   749→\t\tif status == \"\" {\n   750→\t\t\tstatus = \"open\"\n   751→\t\t}\n   752→\t\tassigned := \"-\"\n   753→\t\tif t.Assigned {\n   754→\t\t\tassigned = \"yes\"\n   755→\t\t}\n   756→\t\trunID := \"\"\n   757→\t\tif t.RunID != \"\" {\n   758→\t\t\trunID = t.RunID\n   759→\t\t\tif len(runID) > 30 {\n   760→\t\t\t\trunID = runID[:27] + \"...\"\n   761→\t\t\t}\n   762→\t\t}\n   763→\t\ttitle := t.Title\n   764→\t\tif len(title) > 40 {\n   765→\t\t\ttitle = title[:37] + \"...\"\n   766→\t\t}\n   767→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   768→\t}\n   769→}\n   770→\n   771→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   772→\tvar force bool\n   773→\tfor _, a := range args {\n   774→\t\tif a == \"-f\" || a == \"--force\" {\n   775→\t\t\tforce = true\n   776→\t\t}\n   777→\t}\n   778→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n   779→\tif err != nil {\n   780→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   781→\t\tos.Exit(1)\n   782→\t}\n   783→\tfmt.Println(\"Daemon shutting down.\")\n   784→}\n   785→\n   786→// resolveRunContext returns the project directory and run ID for context\n   787→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   788→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   789→func resolveRunContext() (projectDir, runID string, err error) {\n   790→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   791→\tif runID == \"\" {\n   792→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   793→\t}\n   794→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   795→\tif projectDir == \"\" {\n   796→\t\tprojectDir, err = os.Getwd()\n   797→\t\tif err != nil {\n   798→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   799→\t\t}\n   800→\t}\n   801→\treturn projectDir, runID, nil\n   802→}\n   803→\n   804→func cmdGet(args []string) {\n   805→\tif len(args) < 1 {\n   806→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   807→\t\tos.Exit(1)\n   808→\t}\n   809→\n   810→\tprojectDir, runID, err := resolveRunContext()\n   811→\tif err != nil {\n   812→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   813→\t\tos.Exit(1)\n   814→\t}\n   815→\n   816→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   817→\tif err != nil {\n   818→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   819→\t\tos.Exit(1)\n   820→\t}\n   821→\tif !ok {\n   822→\t\tos.Exit(1)\n   823→\t}\n   824→\tfmt.Println(val)\n   825→}\n   826→\n   827→func cmdSet(args []string) {\n   828→\tif len(args) < 2 {\n   829→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   830→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   831→\t\tos.Exit(1)\n   832→\t}\n   833→\n   834→\tprojectDir, runID, err := resolveRunContext()\n   835→\tif err != nil {\n   836→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   837→\t\tos.Exit(1)\n   838→\t}\n   839→\n   840→\tvalue := args[1]\n   841→\tif value == \"-\" {\n   842→\t\tdata, err := io.ReadAll(os.Stdin)\n   843→\t\tif err != nil {\n   844→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   845→\t\t\tos.Exit(1)\n   846→\t\t}\n   847→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   848→\t}\n   849→\n   850→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   851→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   852→\t\tos.Exit(1)\n   853→\t}\n   854→}\n   855→\n   856→func cmdVersion() {\n   857→\tcliVersion := version.Version()\n   858→\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   859→\n   860→\t// Try to get daemon version via gRPC\n   861→\tdaemonVersion := \"<unavailable>\"\n   862→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   863→\tif addr == \"\" {\n   864→\t\taddr = config.DefaultSocketAddr()\n   865→\t}\n   866→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   867→\tif err == nil {\n   868→\t\tdefer conn.Close()\n   869→\t\tclient := pb.NewClocheServiceClient(conn)\n   870→\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   871→\t\tdefer cancel()\n   872→\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   873→\t\tif err == nil {\n   874→\t\t\tdaemonVersion = resp.Version\n   875→\t\t}\n   876→\t}\n   877→\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   878→\n   879→\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   880→\tagentVersion := \"<unavailable>\"\n   881→\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   882→\tif image == \"\" {\n   883→\t\timage = \"cloche-agent:latest\"\n   884→\t}\n   885→\tout, err := exec.CommandContext(\n   886→\t\tcontext.Background(),\n   887→\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   888→\t).Output()\n   889→\tif err == nil {\n   890→\t\tagentVersion = strings.TrimSpace(string(out))\n   891→\t\t// Strip \"cloche-agent \" prefix if present\n   892→\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n   893→\t}\n   894→\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n   895→\n   896→\t// Warn about version mismatches\n   897→\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n   898→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n   899→\t}\n   900→\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n   901→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n   902→\t}\n   903→}\n   904→"}]},"parent_tool_use_id":null,"session_id":"a767d320-7441-4cfb-80d2-26edf647ec06","uuid":"38c2abbc-9a65-4993-b5f5-602559b21e68","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\t\"text/tabwriter\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n\t\"github.com/cloche-dev/cloche/internal/version\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n\n\t// Handle version flags before anything else\n\tif os.Args[1] == \"-v\" || os.Args[1] == \"--version\" {\n\t\tcmdVersion()\n\t\treturn\n\t}\n\n\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n\tswitch os.Args[1] {\n\tcase \"help\":\n\t\tprintHelp(os.Args[2:])\n\t\treturn\n\tcase \"--help\", \"-h\":\n\t\tprintTopLevelHelp()\n\t\treturn\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"init\")\n\t\t\treturn\n\t\t}\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"health\")\n\t\t\treturn\n\t\t}\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\tcase \"get\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"get\")\n\t\t\treturn\n\t\t}\n\t\tcmdGet(os.Args[2:])\n\t\treturn\n\tcase \"set\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"set\")\n\t\t\treturn\n\t\t}\n\t\tcmdSet(os.Args[2:])\n\t\treturn\n\tcase \"tasks\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"tasks\")\n\t\t\treturn\n\t\t}\n\t\tcmdTasks(os.Args[2:])\n\t\treturn\n\tcase \"workflow\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"workflow\")\n\t\t\treturn\n\t\t}\n\t\tcmdWorkflow(os.Args[2:])\n\t\treturn\n\tcase \"project\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"project\")\n\t\t\treturn\n\t\t}\n\t\tcmdProject(os.Args[2:])\n\t\treturn\n\tcase \"validate\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"validate\")\n\t\t\treturn\n\t\t}\n\t\tcmdValidate(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Handle --help for daemon commands before connecting\n\tdaemonCmds := map[string]bool{\n\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n\t}\n\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n\t\tprintSubcommandHelp(os.Args[1])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = config.DefaultSocketAddr()\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client, os.Args[2:])\n\tdefault:\n\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n}\n\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title, issueID string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--issue\", \"-i\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tissueID = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"] [--issue ID]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n\t// Try loading from any .cloche file; only extract image for container workflows.\n\tvar image string\n\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n\t\timage = wf.Config[\"container.image\"]\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t\tIssueId:       issueID,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\t// Parse flags to detect --all before checking positional args.\n\tvar all bool\n\tvar positional []string\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t} else {\n\t\t\tpositional = append(positional, arg)\n\t\t}\n\t}\n\n\t// If a run ID is provided, show single-run status.\n\tif len(positional) > 0 {\n\t\tcmdStatusRun(ctx, client, positional[0])\n\t\treturn\n\t}\n\n\t// No run ID: show daemon status overview.\n\tcmdStatusOverview(ctx, client, os.Stdout, all)\n}\n\nfunc cmdStatusRun(ctx context.Context, client pb.ClocheServiceClient, runID string) {\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: runID})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdStatusOverview(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, all bool) {\n\t// Get daemon version.\n\tverResp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Fprintf(w, \"Daemon version: %s\\n\", verResp.Version)\n\n\tcwd, _ := os.Getwd()\n\t_, hasClocheDir := os.Stat(filepath.Join(cwd, \".cloche\"))\n\n\tif !all && hasClocheDir == nil {\n\t\t// In a project directory: show project-specific info.\n\t\tcmdStatusProject(ctx, client, w, cwd)\n\t} else {\n\t\t// Not in a project directory or --all: show global overview.\n\t\tcmdStatusGlobal(ctx, client, w)\n\t}\n}\n\nfunc cmdStatusProject(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, projectDir string) {\n\tinfo, err := client.GetProjectInfo(ctx, &pb.GetProjectInfoRequest{ProjectDir: projectDir})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Fprintf(w, \"Project: %s\\n\", info.Name)\n\tfmt.Fprintf(w, \"Concurrency: %d\\n\", info.Concurrency)\n\n\tloopStatus := \"stopped\"\n\tif info.LoopRunning {\n\t\tif info.ErrorHalted {\n\t\t\tloopStatus = \"halted\"\n\t\t} else {\n\t\t\tloopStatus = \"running\"\n\t\t}\n\t}\n\tfmt.Fprintf(w, \"Orchestration loop: %s\\n\", loopStatus)\n\n\t// Fetch runs for the past hour to compute success rate.\n\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: projectDir})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvar succeeded int\n\tfor _, run := range listResp.Runs {\n\t\tif run.State == \"succeeded\" {\n\t\t\tsucceeded++\n\t\t}\n\t}\n\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n\n\t// Active runs from project info.\n\tfmt.Fprintf(w, \"Active runs: %d\\n\", len(info.ActiveRuns))\n\tfor _, run := range info.ActiveRuns {\n\t\tdur := formatDuration(run.StartedAt)\n\t\tfmt.Fprintf(w, \"  %s: %s\\n\", run.RunId, dur)\n\t}\n}\n\nfunc cmdStatusGlobal(ctx context.Context, client pb.ClocheServiceClient, w io.Writer) {\n\t// Fetch all runs (server defaults to past hour when no project filter and not --all).\n\t// We pass All=true but the server returns everything; we filter client-side to past hour.\n\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: true})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvar succeeded, total, activeCount int\n\ttype activeRun struct {\n\t\tid        string\n\t\tstartedAt string\n\t}\n\tvar actives []activeRun\n\n\toneHourAgo := time.Now().Add(-1 * time.Hour)\n\tfor _, run := range listResp.Runs {\n\t\tparsed, parseErr := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", run.StartedAt)\n\t\tif parseErr != nil {\n\t\t\t// Fall back: count all runs returned.\n\t\t\tparsed = time.Time{}\n\t\t}\n\t\tif !parsed.IsZero() && parsed.Before(oneHourAgo) {\n\t\t\tcontinue\n\t\t}\n\t\ttotal++\n\t\tif run.State == \"succeeded\" {\n\t\t\tsucceeded++\n\t\t}\n\t\tif run.State == \"running\" || run.State == \"pending\" {\n\t\t\tactiveCount++\n\t\t\tactives = append(actives, activeRun{id: run.RunId, startedAt: run.StartedAt})\n\t\t}\n\t}\n\n\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, total)\n\tfmt.Fprintf(w, \"Active runs: %d\\n\", activeCount)\n\tfor _, a := range actives {\n\t\tdur := formatDuration(a.startedAt)\n\t\tfmt.Fprintf(w, \"  %s: %s\\n\", a.id, dur)\n\t}\n}\n\n// formatDuration parses a Go time string and returns a human-readable duration since then.\nfunc formatDuration(startedAt string) string {\n\tparsed, err := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", startedAt)\n\tif err != nil {\n\t\treturn startedAt\n\t}\n\td := time.Since(parsed)\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%ds\", int(d.Seconds()))\n\t}\n\tif d < time.Hour {\n\t\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n\t}\n\treturn fmt.Sprintf(\"%dh%dm\", int(d.Hours()), int(d.Minutes())%60)\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tvar projectDir, stateFilter, issueFilter string\n\tvar limit int32\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--all\":\n\t\t\tall = true\n\t\tcase \"--project\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\tcase \"--state\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstateFilter = args[i]\n\t\t\t}\n\t\tcase \"--limit\", \"-n\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = int32(n)\n\t\t\t}\n\t\tcase \"--issue\", \"-i\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tissueFilter = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\treq := &pb.ListRunsRequest{\n\t\tState:  stateFilter,\n\t\tLimit:  limit,\n\t\tTaskId: issueFilter,\n\t}\n\tif projectDir != \"\" {\n\t\treq.ProjectDir = projectDir\n\t} else if all {\n\t\treq.All = true\n\t} else {\n\t\t// Default: filter to current project\n\t\tcwd, _ := os.Getwd()\n\t\treq.ProjectDir = cwd\n\t}\n\n\tresp, err := client.ListRuns(ctx, req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n\tfmt.Fprintln(w, \"RUN ID\\tWORKFLOW\\tSTATE\\tTYPE\\tTASK ID\\tTITLE\\tCONTAINER\\tERROR\")\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\ttitle := run.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\terrMsg := run.ErrorMessage\n\t\tif len(errMsg) > 60 {\n\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t}\n\t\tfmt.Fprintf(w, \"%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\n\",\n\t\t\trun.RunId, run.WorkflowName, run.State, runType,\n\t\t\trun.TaskId, title, run.ContainerId, errMsg)\n\t}\n\tw.Flush()\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\tvar limit int\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\tcase \"--limit\", \"-l\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil || n < 0 {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = n\n\t\t\t}\n\t\t}\n\t}\n\n\t// Use background context — log output can be large and follow mode blocks.\n\tctx := context.Background()\n\tvar mdPairs []string\n\tif follow {\n\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n\t}\n\tif limit > 0 {\n\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n\t}\n\tif len(mdPairs) > 0 {\n\t\tmd := metadata.Pairs(mdPairs...)\n\t\tctx = metadata.NewOutgoingContext(ctx, md)\n\t}\n\n\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Check for \"resume\" subcommand\n\tif len(args) > 0 && args[0] == \"resume\" {\n\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop resumed.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdTasks(args []string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\t// Determine project label from --project flag or current directory\n\tprojectDir := \"\"\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tcwd, _ := os.Getwd()\n\t\tprojectDir = filepath.Base(cwd)\n\t}\n\n\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n\tresp, err := http.Get(tasksURL)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\ttype taskEntry struct {\n\t\tID          string `json:\"id\"`\n\t\tStatus      string `json:\"status\"`\n\t\tTitle       string `json:\"title\"`\n\t\tDescription string `json:\"description\"`\n\t\tAssigned    bool   `json:\"assigned\"`\n\t\tAssignedAt  string `json:\"assigned_at\"`\n\t\tRunID       string `json:\"run_id\"`\n\t}\n\n\tvar tasks []taskEntry\n\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(tasks) == 0 {\n\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n\t\treturn\n\t}\n\n\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n\tfor _, t := range tasks {\n\t\tstatus := t.Status\n\t\tif status == \"\" {\n\t\t\tstatus = \"open\"\n\t\t}\n\t\tassigned := \"-\"\n\t\tif t.Assigned {\n\t\t\tassigned = \"yes\"\n\t\t}\n\t\trunID := \"\"\n\t\tif t.RunID != \"\" {\n\t\t\trunID = t.RunID\n\t\t\tif len(runID) > 30 {\n\t\t\t\trunID = runID[:27] + \"...\"\n\t\t\t}\n\t\t}\n\t\ttitle := t.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar force bool\n\tfor _, a := range args {\n\t\tif a == \"-f\" || a == \"--force\" {\n\t\t\tforce = true\n\t\t}\n\t}\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n\n// resolveRunContext returns the project directory and run ID for context\n// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n// from CLOCHE_PROJECT_DIR (falling back to cwd).\nfunc resolveRunContext() (projectDir, runID string, err error) {\n\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n\tif runID == \"\" {\n\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n\t}\n\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n\tif projectDir == \"\" {\n\t\tprojectDir, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n\t\t}\n\t}\n\treturn projectDir, runID, nil\n}\n\nfunc cmdGet(args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif !ok {\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(val)\n}\n\nfunc cmdSet(args []string) {\n\tif len(args) < 2 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvalue := args[1]\n\tif value == \"-\" {\n\t\tdata, err := io.ReadAll(os.Stdin)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n\t}\n\n\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n\nfunc cmdVersion() {\n\tcliVersion := version.Version()\n\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n\n\t// Try to get daemon version via gRPC\n\tdaemonVersion := \"<unavailable>\"\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = config.DefaultSocketAddr()\n\t}\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err == nil {\n\t\tdefer conn.Close()\n\t\tclient := pb.NewClocheServiceClient(conn)\n\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n\t\tdefer cancel()\n\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n\t\tif err == nil {\n\t\t\tdaemonVersion = resp.Version\n\t\t}\n\t}\n\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n\n\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n\tagentVersion := \"<unavailable>\"\n\timage := os.Getenv(\"CLOCHE_IMAGE\")\n\tif image == \"\" {\n\t\timage = \"cloche-agent:latest\"\n\t}\n\tout, err := exec.CommandContext(\n\t\tcontext.Background(),\n\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n\t).Output()\n\tif err == nil {\n\t\tagentVersion = strings.TrimSpace(string(out))\n\t\t// Strip \"cloche-agent \" prefix if present\n\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n\t}\n\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n\n\t// Warn about version mismatches\n\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n\t}\n\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n\t}\n}\n","numLines":904,"startLine":1,"totalLines":904}}}
