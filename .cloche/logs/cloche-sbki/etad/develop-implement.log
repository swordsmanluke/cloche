= grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   128→\tif err != nil {\n   129→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   130→\t\tos.Exit(1)\n   131→\t}\n   132→\tdefer conn.Close()\n   133→\n   134→\tclient := pb.NewClocheServiceClient(conn)\n   135→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   136→\tdefer cancel()\n   137→\n   138→\tswitch os.Args[1] {\n   139→\tcase \"run\":\n   140→\t\tcmdRun(ctx, client, os.Args[2:])\n   141→\tcase \"status\":\n   142→\t\tcmdStatus(ctx, client, os.Args[2:])\n   143→\tcase \"logs\":\n   144→\t\tcmdLogs(client, os.Args[2:])\n   145→\tcase \"poll\":\n   146→\t\tcmdPoll(client, os.Args[2:])\n   147→\tcase \"list\":\n   148→\t\tcmdList(ctx, client, os.Args[2:])\n   149→\tcase \"stop\":\n   150→\t\tcmdStop(ctx, client, os.Args[2:])"}]},"parent_tool_use_id":"toolu_01LUR8zLT62d8pbFKzq3zGR4","session_id":"a767d320-7441-4cfb-80d2-26edf647ec06","uuid":"49278427-8a6b-401f-aafa-a348bfa058ae"}
