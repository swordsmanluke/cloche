 which includes the agent)\n\tcmd := exec.CommandContext(ctx, \"docker\", \"start\", containerID)\n\tif out, err := cmd.CombinedOutput(); err != nil {\n\t\tlog.Printf(\"resume run %s: failed to restart container: %s: %v\", runID, string(out), err)\n\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\tif run != nil {\n\t\t\trun.Fail(fmt.Sprintf(\"failed to restart container: %v\", err))\n\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t}\n\t\ts.mu.Lock()\n\t\tdelete(s.runIDs, runID)\n\t\ts.mu.Unlock()\n\t\treturn\n\t}\n\n\trun, _ := s.store.GetRun(ctx, runID)\n\tif run != nil {\n\t\trun.Start()\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\t// Reuse trackRun — keepContainer=true so the container is preserved\n\ts.trackRun(runID, containerID, projectDir, workflowName, true)\n}\n\n// firstFailedStepFromCaptures finds the first step that failed or was not completed.\nfunc firstFailedStepFromCaptures(captures []*domain.StepExecution) string {\n\tcompleted := make(map[string]string)\n\tfor _, c := range captures {\n\t\tif c.Result != \"\" {\n\t\t\tcompleted[c.StepName] = c.Result\n\t\t}\n\t}\n\n\tfor _, c := range captures {\n\t\tresult, hasResult := completed[c.StepName]\n\t\tif !hasResult {\n\t\t\treturn c.StepName\n\t\t}\n\t\tif result == \"fail\" || result == \"error\" {\n\t\t\treturn c.StepName\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// succeededStepsBefore returns step results for all steps that completed\n// successfully before the target step in execution order.\nfunc succeededStepsBefore(captures []*domain.StepExecution, targetStep string) map[string]string {\n\tresults := make(map[string]string)\n\tfor _, c := range captures {\n\t\tif c.StepName == targetStep {\n\t\t\tbreak\n\t\t}\n\t\tif c.Result != \"\" && c.Result != \"fail\" && c.Result != \"error\" {\n\t\t\tresults[c.StepName] = c.Result\n\t\t}\n\t}\n\treturn results\n}\n\n// dockerCp wraps docker cp for copying files into a container.\nfunc dockerCp(ctx context.Context, src, dst string) error {\n\tcmd := exec.CommandContext(c