{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Boqoet6hHgwEJ6cc8wBvXG","type":"tool_result","content":"     1→package agent\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"io\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n    12→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    15→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    17→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    18→)\n    19→\n    20→type RunnerConfig struct {\n    21→\tWorkflowPath string\n    22→\tWorkDir      string\n    23→\tStatusOutput io.Writer\n    24→\tRunID        string\n    25→}\n    26→\n    27→type Runner struct {\n    28→\tcfg RunnerConfig\n    29→}\n    30→\n    31→func NewRunner(cfg RunnerConfig) *Runner {\n    32→\treturn &Runner{\n    33→\t\tcfg: cfg,\n    34→\t}\n    35→}\n    36→\n    37→func (r *Runner) Run(ctx context.Context) error {\n    38→\tdata, err := os.ReadFile(r.cfg.WorkflowPath)\n    39→\tif err != nil {\n    40→\t\treturn fmt.Errorf(\"reading workflow file: %w\", err)\n    41→\t}\n    42→\n    43→\twf, err := dsl.ParseForContainer(string(data))\n    44→\tif err != nil {\n    45→\t\treturn fmt.Errorf(\"parsing workflow: %w\", err)\n    46→\t}\n    47→\n    48→\tstatusWriter := protocol.NewStatusWriter(r.cfg.StatusOutput)\n    49→\tgenericAdapter := generic.New()\n    50→\tgenericAdapter.RunID = r.cfg.RunID\n    51→\tpromptAdapter := prompt.New()\n    52→\tpromptAdapter.RunID = r.cfg.RunID\n    53→\tpromptAdapter.StatusWriter = statusWriter\n    54→\tif cmd, ok := os.LookupEnv(\"CLOCHE_AGENT_COMMAND\"); ok {\n    55→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    56→\t}\n    57→\tif cmd := wf.Config[\"container.agent_command\"]; cmd != \"\" {\n    58→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    59→\t}\n    60→\tif args := wf.Config[\"container.agent_args\"]; args != \"\" {\n    61→\t\tpromptAdapter.ExplicitArgs = strings.Fields(args)\n    62→\t}\n    63→\n    64→\t// Reset per-run state from any previous run\n    65→\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"attempt_count\"))\n    66→\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"output\"))\n    67→\n    68→\t// Create unified log writer\n    69→\tulog, err := logstream.New(r.cfg.WorkDir)\n    70→\tif err != nil {\n    71→\t\treturn fmt.Errorf(\"creating unified log: %w\", err)\n    72→\t}\n    73→\tdefer ulog.Close()\n    74→\n    75→\tgenericAdapter.StatusWriter = statusWriter\n    76→\n    77→\texecutor := &stepExecutor{\n    78→\t\tworkDir:      r.cfg.WorkDir,\n    79→\t\tgeneric:      genericAdapter,\n    80→\t\tprompt:       promptAdapter,\n    81→\t\tlogStream:    ulog,\n    82→\t\tstatusWriter: statusWriter,\n    83→\t}\n    84→\n    85→\teng := engine.New(executor)\n    86→\teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n    87→\n    88→\t// Generate a run title from the prompt if one was not provided by the caller.\n    89→\t// The daemon sets title from --title; if empty, the agent extracts from prompt.\n    90→\tif title := extractTitle(r.cfg.WorkDir, r.cfg.RunID); title != \"\" {\n    91→\t\tstatusWriter.RunTitle(title)\n    92→\t}\n    93→\n    94→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n    95→\n    96→\trun, runErr := eng.Run(ctx, wf)\n    97→\tif runErr != nil {\n    98→\t\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:failed\")\n    99→\t\tulog.Log(logstream.TypeStatus, \"error: \"+runErr.Error())\n   100→\t\tulog.Log(logstream.TypeStatus, \"run_completed: failed\")\n   101→\t\t// Extract the failed step name from step executions so the daemon\n   102→\t\t// can display which step caused the failure.\n   103→\t\tfailedStep := \"\"\n   104→\t\tif run != nil {\n   105→\t\t\tfor _, se := range run.StepExecutions {\n   106→\t\t\t\tif se.Result == \"error\" || se.Result == \"fail\" {\n   107→\t\t\t\t\tfailedStep = se.StepName\n   108→\t\t\t\t}\n   109→\t\t\t}\n   110→\t\t}\n   111→\t\tstatusWriter.Error(failedStep, runErr.Error())\n   112→\t\tstatusWriter.RunCompleted(\"failed\")\n   113→\t\treturn runErr\n   114→\t}\n   115→\n   116→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:\"+string(run.State))\n   117→\n   118→\tulog.Log(logstream.TypeStatus, \"run_completed: \"+string(run.State))\n   119→\tstatusWriter.RunCompleted(string(run.State))\n   120→\treturn nil\n   121→}\n   122→\n   123→type stepExecutor struct {\n   124→\tworkDir      string\n   125→\tgeneric      *generic.Adapter\n   126→\tprompt       *prompt.Adapter\n   127→\tlogStream    *logstream.Writer\n   128→\tstatusWriter *protocol.StatusWriter\n   129→}\n   130→\n   131→func (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n   132→\tswitch step.Type {\n   133→\tcase domain.StepTypeScript:\n   134→\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   135→\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   136→\t\treturn result, err\n   137→\tcase domain.StepTypeAgent:\n   138→\t\tif _, ok := step.Config[\"run\"]; ok {\n   139→\t\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   140→\t\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   141→\t\t\treturn result, err\n   142→\t\t}\n   143→\t\tif _, ok := step.Config[\"prompt\"]; ok {\n   144→\t\t\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   145→\t\t\t\te.prompt.Commands = prompt.ParseCommands(cmd)\n   146→\t\t\t}\n   147→\t\t\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   148→\t\t\t\te.prompt.ExplicitArgs = strings.Fields(args)\n   149→\t\t\t}\n   150→\t\t\tresult, err := e.prompt.Execute(ctx, step, e.workDir)\n   151→\t\t\te.copyToLLMLog(step.Name)\n   152→\t\t\te.logStepOutput(step.Name, logstream.TypeLLM)\n   153→\t\t\treturn result, err\n   154→\t\t}\n   155→\t\treturn \"\", fmt.Errorf(\"agent step %q requires either 'run' or 'prompt' config\", step.Name)\n   156→\tdefault:\n   157→\t\treturn \"\", fmt.Errorf(\"unknown step type: %s\", step.Type)\n   158→\t}\n   159→}\n   160→\n   161→// logStepOutput reads the per-step log file and writes its contents to the unified log.\n   162→func (e *stepExecutor) logStepOutput(stepName string, typ logstream.EntryType) {\n   163→\tpath := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   164→\tdata, err := os.ReadFile(path)\n   165→\tif err != nil || len(data) == 0 {\n   166→\t\treturn\n   167→\t}\n   168→\te.logStream.Log(typ, string(data))\n   169→}\n   170→\n   171→// copyToLLMLog copies <step>.log to llm-<step>.log for agent prompt steps.\n   172→func (e *stepExecutor) copyToLLMLog(stepName string) {\n   173→\tsrc := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   174→\tdst := filepath.Join(e.workDir, \".cloche\", \"output\", \"llm-\"+stepName+\".log\")\n   175→\tdata, err := os.ReadFile(src)\n   176→\tif err != nil {\n   177→\t\treturn\n   178→\t}\n   179→\t_ = os.WriteFile(dst, data, 0644)\n   180→}\n   181→\n   182→type statusReporter struct {\n   183→\twriter    *protocol.StatusWriter\n   184→\tlogStream *logstream.Writer\n   185→}\n   186→\n   187→func (s *statusReporter) OnStepStart(_ *domain.Run, step *domain.Step) {\n   188→\ts.writer.StepStarted(step.Name)\n   189→\ts.logStream.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n   190→}\n   191→\n   192→func (s *statusReporter) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   193→\ts.writer.StepCompleted(step.Name, result)\n   194→\ts.logStream.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n   195→}\n   196→\n   197→func (s *statusReporter) OnRunComplete(_ *domain.Run) {}\n   198→\n   199→// extractTitle tries to derive a one-line summary from the run's prompt content.\n   200→// It reads the per-run prompt.txt file (written by the daemon before container start),\n   201→// then returns the first non-empty line, truncated to 100 characters.\n   202→func extractTitle(workDir string, runID string) string {\n   203→\t// Try the per-run prompt file\n   204→\tpromptPath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   205→\tif _, err := os.Stat(promptPath); err != nil {\n   206→\t\t// Fall back to legacy path\n   207→\t\tpromptPath = filepath.Join(workDir, \".cloche\", \"prompt.txt\")\n   208→\t}\n   209→\tdata, err := os.ReadFile(promptPath)\n   210→\tif err != nil || len(data) == 0 {\n   211→\t\treturn \"\"\n   212→\t}\n   213→\n   214→\ttext := strings.TrimSpace(string(data))\n   215→\tif text == \"\" {\n   216→\t\treturn \"\"\n   217→\t}\n   218→\n   219→\t// Take first non-empty line as the title\n   220→\tfor _, line := range strings.Split(text, \"\\n\") {\n   221→\t\tline = strings.TrimSpace(line)\n   222→\t\t// Skip markdown headers, comment markers, and blank lines\n   223→\t\tif line == \"\" || line == \"---\" || line == \"```\" {\n   224→\t\t\tcontinue\n   225→\t\t}\n   226→\t\t// Strip leading markdown header markers\n   227→\t\tline = strings.TrimLeft(line, \"# \")\n   228→\t\tline = strings.TrimSpace(line)\n   229→\t\tif line == \"\" {\n   230→\t\t\tcontinue\n   231→\t\t}\n   232→\t\tif len(line) > 100 {\n   233→\t\t\tline = line[:97] + \"...\"\n   234→\t\t}\n   235→\t\treturn line\n   236→\t}\n   237→\treturn \"\"\n   238→}\n   239→"}]},"parent_tool_use_id":"toolu_01BzjcVAg47gGUAAG5dSfXCB","session_id":"46588779-0c89-4fa7-bd14-27979381b9bd","uuid":"89865550-7d17-4586-b2df-73d44fef70ba"}
