images when the project Dockerfile has\n// changed since the last build.\ntype ImageEnsurer interface {\n\tEnsureImage(ctx context.Context, projectDir, image string) error\n}\n","structuredPatch":[{"oldStart":30,"oldLines":6,"newStart":30,"newLines":9,"lines":["   Logs(ctx context.Context, containerID string) (string, error)","   Remove(ctx context.Context, containerID string) error","   Inspect(ctx context.Context, containerID string) (*ContainerStatus, error)","+  // Exec runs a command inside a running container and returns a reader for","+  // the combined stdout/stderr output. Used for resume operations.","+  Exec(ctx context.Context, containerID string, cmd []string) (io.ReadCloser, error)"," }"," "," // ImageEnsurer is an optional interface that a ContainerRuntime may implement"]}],"userModified":false,"replaceAll":false}}
