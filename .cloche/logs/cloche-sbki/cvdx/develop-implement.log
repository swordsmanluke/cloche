{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_013CcbGhPVEdAryqBtvshQzS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LLnUErCifhDiRXvCfDHH86","name":"Write","input":{"file_path":"/workspace/internal/engine/resume.go","content":"package engine\n\nimport (\n\t\"context\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n)\n\n// ResumeExecutor wraps a StepExecutor to support resume behavior.\n// Steps listed in PriorResults are skipped (their cached result is returned).\n// The ResumeStep gets executed with IsResume=true set in the step's Config.\ntype ResumeExecutor struct {\n\tInner        StepExecutor\n\tPriorResults map[string]string // step name → result to replay\n\tResumeStep   string            // the step being resumed\n}\n\nfunc (r *ResumeExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\t// If this step has a prior result, return it immediately (skip execution)\n\tif result, ok := r.PriorResults[step.Name]; ok {\n\t\treturn result, nil\n\t}\n\n\t// If this is the resume step, mark it in the step config so adapters\n\t// can handle it specially (e.g. prompt adapter uses -c for conversation resume)\n\tif step.Name == r.ResumeStep {\n\t\tif step.Config == nil {\n\t\t\tstep.Config = make(map[string]string)\n\t\t}\n\t\tstep.Config[\"_resume\"] = \"true\"\n\t}\n\n\treturn r.Inner.Execute(ctx, step)\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":749,"cache_read_input_tokens":143037,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":749},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"46588779-0c89-4fa7-bd14-27979381b9bd","uuid":"50232d53-a1e2-41b0-89f8-3f0ced25f91f"}
