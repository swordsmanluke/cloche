th.Join(projectDir, \".cloche\", \"overrides\"), \"/workspace/\"},","+  } {","+    if _, err := os.Stat(sub.hostDir); err == nil {","+      dockerCp(ctx, sub.hostDir+\"/.\", containerID+\":\"+sub.containerDir)","+    }","   }","-","-  // Copy updated .cloche/prompts/ if it exists","-  promptsDir := filepath.Join(projectDir, \".cloche\", \"prompts\")","-  if _, err := os.Stat(promptsDir); err == nil {","-    cmd := execCommand(ctx, \"docker\", \"cp\", promptsDir+\"/.\", containerID+\":/workspace/.cloche/prompts/\")","-    cmd.CombinedOutput()","-  }","-","-  // Copy updated .cloche/overrides/ if it exists","-  overridesDir := filepath.Join(projectDir, \".cloche\", \"overrides\")","-  if _, err := os.Stat(overridesDir); err == nil {","-    cmd := execCommand(ctx, \"docker\", \"cp\", overridesDir+\"/.\", containerID+\":/workspace/\")","-    cmd.CombinedOutput()","-  }"," }","-","-// execCommand wraps exec.CommandContext for testing.","-var execCommand = execCommandReal","-","-func execCommandReal(ctx context.Context, name string, args ...string) *execCmd {","-  cmd := execCmdWrapper(ctx, name, args...)","-  return cmd","-}","-","-type execCmd = execCmdType"]}],"originalFile":"package grpc\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/host\"\n)\n\n// ResumeRun re-attempts a failed workflow run from a specified step (or the\n// first failed step if step_name is empty).\nfunc (s *ClocheServer) ResumeRun(ctx context.Context, req *pb.ResumeRunRequest) (*pb.ResumeRunResponse, error) {\n\t// 1. Load the run\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n\t}\n\n\t// 2. Verify the run is in a failed state\n\tif run.State != domain.RunStateFailed {\n\t\treturn nil, fmt.Errorf(\"run %q is in state %q, not failed\", req.RunId, run.State)\n\t}\n\n\t// 3. Load step executions from captures store\n\tvar stepExecutions []*domain.StepExecution\n\tif s.captures != nil {\n\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\t\tif err == nil {\n\t\t\tstepExecutions = captures\n\t\t}\n\t}\n\tif stepExecutions == nil {\n\t\tstepExecutions = run.StepExecutions\n\t}\n\n\t// 4. Determine the resume step\n\tresumeStep := req.StepName\n\tif resumeStep == \"\" {\n\t\t// Find the first failed step from captures\n\t\tresumeStep = firstFailedStepFromCaptures(stepExecutions)\n\t\tif resumeStep == \"\" {\n\t\t\treturn nil, fmt.Errorf(\"run %q has no failed step to resume from\", req.RunId)\n\t\t}\n\t}\n\n\t// 5. Build prior results map (all steps that succeeded before the resume step)\n\tpriorResults := succeededStepsBefore(stepExecutions, resumeStep)\n\n\tresumeCfg := &domain.ResumeConfig{\n\t\tFromStep:     resumeStep,\n\t\tPriorResults: priorResults,\n\t}\n\n\t// 6. Dispatch based on run type\n\tif run.IsHost {\n\t\treturn s.resumeHostRun(ctx, run, resumeCfg)\n\t}\n\treturn s.resumeContainerRun(ctx, run, resumeCfg)\n}\n\n// resumeContainerRun resumes a failed container workflow run.\nfunc (s *ClocheServer) resumeContainerRun(ctx context.Context, run *domain.Run, resumeCfg *domain.ResumeConfig) (*pb.ResumeRunResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\tcontainerID := run.ContainerID\n\tif containerID == \"\" {\n\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", run.ID)\n\t}\n\n\t// Verify the container still exists\n\tcs, err := s.container.Inspect(ctx, containerID)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"container %s not found (may have been cleaned up): %w\", containerID, err)\n\t}\n\t_ = cs // container exists, may be stopped\n\n\t// Write the resume config into the stopped container\n\tresumeJSON, err := json.Marshal(resumeCfg)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"marshaling resume config: %w\", err)\n\t}\n\n\t// Write resume.json to a temp file, then docker cp into the container\n\ttmpFile, err := os.CreateTemp(\"\", \"cloche-resume-*.json\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating temp file: %w\", err)\n\t}\n\ttmpPath := tmpFile.Name()\n\tdefer os.Remove(tmpPath)\n\n\tif _, err := tmpFile.Write(resumeJSON); err != nil {\n\t\ttmpFile.Close()\n\t\treturn nil, fmt.Errorf(\"writing resume config: %w\", err)\n\t}\n\ttmpFile.Close()\n\n\t// Copy resume.json into the container's workspace\n\tif err := copyToContainer(ctx, containerID, tmpPath, \"/workspace/.cloche/resume.json\"); err != nil {\n\t\treturn nil, fmt.Errorf(\"copying resume config to container: %w\", err)\n\t}\n\n\t// Also copy updated project files (scripts may have been modified)\n\tif run.ProjectDir != \"\" {\n\t\tcopyProjectUpdates(ctx, containerID, run.ProjectDir)\n\t}\n\n\t// Reset run state to pending\n\trun.State = domain.RunStatePending\n\trun.ErrorMessage = \"\"\n\trun.CompletedAt = run.CompletedAt // preserve original\n\trun.ActiveSteps = nil\n\tif err := s.store.UpdateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"updating run state: %w\", err)\n\t}\n\n\t// Restart the container and track it\n\ts.mu.Lock()\n\ts.runIDs[run.ID] = containerID\n\ts.mu.Unlock()\n\n\tgo s.restartAndTrack(run.ID, containerID, run.ProjectDir, run.WorkflowName)\n\n\treturn &pb.ResumeRunResponse{RunId: run.ID}, nil\n}\n\n// resumeHostRun resumes a failed host workflow run.\nfunc (s *ClocheServer) resumeHostRun(ctx context.Context, run *domain.Run, resumeCfg *domain.ResumeConfig) (*pb.ResumeRunResponse, error) {\n\t// Write resume config for the host runner\n\tresumeJSON, err := json.Marshal(resumeCfg)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"marshaling resume config: %w\", err)\n\t}\n\n\tresumeDir := filepath.Join(run.ProjectDir, \".cloche\", run.ID)\n\tif err := os.MkdirAll(resumeDir, 0755); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating resume dir: %w\", err)\n\t}\n\tif err := os.WriteFile(filepath.Join(resumeDir, \"resume.json\"), resumeJSON, 0644); err != nil {\n\t\treturn nil, fmt.Errorf(\"writing resume config: %w\", err)\n\t}\n\n\t// Reset run state\n\trun.State = domain.RunStatePending\n\trun.ErrorMessage = \"\"\n\trun.ActiveSteps = nil\n\tif err := s.store.UpdateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"updating run state: %w\", err)\n\t}\n\n\trunner := &host.Runner{\n\t\tDispatcher:   s,\n\t\tStore:        s.store,\n\t\tCaptures:     s.captures,\n\t\tLogBroadcast: s.logBroadcast,\n\t\tTaskID:       run.TaskID,\n\t}\n\n\tgo func() {\n\t\trunner.RunNamedWithID(context.Background(), run.ProjectDir, run.WorkflowName, run.ID)\n\t}()\n\n\treturn &pb.ResumeRunResponse{RunId: run.ID}, nil\n}\n\n// restartAndTrack restarts a stopped container and tracks it to completion.\nfunc (s *ClocheServer) restartAndTrack(runID, containerID, projectDir, workflowName string) {\n\tctx := context.Background()\n\n\t// Start the stopped container (re-runs original CMD which includes the agent)\n\tif err := startContainer(ctx, containerID); err != nil {\n\t\tlog.Printf(\"resume run %s: failed to restart container: %v\", runID, err)\n\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\tif run != nil {\n\t\t\trun.Fail(fmt.Sprintf(\"failed to restart container: %v\", err))\n\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t}\n\t\ts.mu.Lock()\n\t\tdelete(s.runIDs, runID)\n\t\ts.mu.Unlock()\n\t\treturn\n\t}\n\n\trun, _ := s.store.GetRun(ctx, runID)\n\tif run != nil {\n\t\trun.Start()\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\t// Reuse trackRun for the rest of the lifecycle\n\ts.trackRun(runID, containerID, projectDir, workflowName, true) // keepContainer=true for resumed runs\n}\n\n// firstFailedStepFromCaptures finds the first step that failed or has no result\n// (indicating it was interrupted) from the step execution captures.\nfunc firstFailedStepFromCaptures(captures []*domain.StepExecution) string {\n\t// Build a map of completed steps\n\tcompleted := make(map[string]string)\n\tfor _, c := range captures {\n\t\tif c.Result != \"\" {\n\t\t\tcompleted[c.StepName] = c.Result\n\t\t}\n\t}\n\n\t// Find the first step that started but either failed or has no completion\n\tfor _, c := range captures {\n\t\tresult, hasResult := completed[c.StepName]\n\t\tif !hasResult {\n\t\t\t// Step started but never completed\n\t\t\treturn c.StepName\n\t\t}\n\t\tif result == \"fail\" || result == \"error\" {\n\t\t\treturn c.StepName\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// succeededStepsBefore returns step results for all steps that completed\n// successfully before the target step in execution order.\nfunc succeededStepsBefore(captures []*domain.StepExecution, targetStep string) map[string]string {\n\tresults := make(map[string]string)\n\tfor _, c := range captures {\n\t\tif c.StepName == targetStep {\n\t\t\tbreak\n\t\t}\n\t\tif c.Result != \"\" && c.Result != \"fail\" && c.Result != \"error\" {\n\t\t\tresults[c.StepName] = c.Result\n\t\t}\n\t}\n\treturn results\n}\n\n// copyToContainer copies a local file to a path inside a Docker container.\nfunc copyToContainer(ctx context.Context, containerID, localPath, containerPath string) error {\n\tcmd := execCommand(ctx, \"docker\", \"cp\", localPath, containerID+\":\"+containerPath)\n\tif out, err := cmd.CombinedOutput(); err != nil {\n\t\treturn fmt.Errorf(\"%s: %w\", string(out), err)\n\t}\n\treturn nil\n}\n\n// startContainer starts a stopped Docker container.\nfunc startContainer(ctx context.Context, containerID string) error {\n\tcmd := execCommand(ctx, \"docker\", \"start\", containerID)\n\tif out, err := cmd.CombinedOutput(); err != nil {\n\t\treturn fmt.Errorf(\"%s: %w\", string(out), err)\n\t}\n\treturn nil\n}\n\n// copyProjectUpdates copies updated scripts, overrides, and prompt files\n// from the project directory into the container.\nfunc copyProjectUpdates(ctx context.Context, containerID, projectDir string) {\n\t// Copy updated .cloche/scripts/ if it exists\n\tscriptsDir := filepath.Join(projectDir, \".cloche\", \"scripts\")\n\tif _, err := os.Stat(scriptsDir); err == nil {\n\t\tcmd := execCommand(ctx, \"docker\", \"cp\", scriptsDir+\"/.\", containerID+\":/workspace/.cloche/scripts/\")\n\t\tcmd.CombinedOutput()\n\t}\n\n\t// Copy updated .cloche/prompts/ if it exists\n\tpromptsDir := filepath.Join(projectDir, \".cloche\", \"prompts\")\n\tif _, err := os.Stat(promptsDir); err == nil {\n\t\tcmd := execCommand(ctx, \"docker\", \"cp\", promptsDir+\"/.\", containerID+\":/workspace/.cloche/prompts/\")\n\t\tcmd.CombinedOutput()\n\t}\n\n\t// Copy updated .cloche/overrides/ if it exists\n\toverridesDir := filepath.Join(projectDir, \".cloche\", \"overrides\")\n\tif _, err := os.Stat(overridesDir); err == nil {\n\t\tcmd := execCommand(ctx, \"docker\", \"cp\", overridesDir+\"/.\", containerID+\":/workspace/\")\n\t\tcmd.CombinedOutput()\n\t}\n}\n\n// execCommand wraps exec.CommandContext for testing.\nvar execCommand = execCommandReal\n\nfunc execCommandReal(ctx context.Context, name string, args ...string) *execCmd {\n\tcmd := execCmdWrapper(ctx, name, args...)\n\treturn cmd\n}\n\ntype execCmd = execCmdType\n"}}
