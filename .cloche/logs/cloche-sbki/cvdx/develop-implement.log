{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MXwhDynw5gmgqJMhvrML4T","type":"tool_result","content":"     1→package generic_test\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"context\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"testing\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n    11→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    12→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    13→\t\"github.com/stretchr/testify/assert\"\n    14→\t\"github.com/stretchr/testify/require\"\n    15→)\n    16→\n    17→func TestGenericAdapter_ScriptSuccess(t *testing.T) {\n    18→\tadapter := generic.New()\n    19→\tstep := &domain.Step{\n    20→\t\tName:    \"build\",\n    21→\t\tType:    domain.StepTypeScript,\n    22→\t\tResults: []string{\"success\", \"fail\"},\n    23→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n    24→\t}\n    25→\n    26→\tresult, err := adapter.Execute(context.Background(), step, t.TempDir())\n    27→\trequire.NoError(t, err)\n    28→\tassert.Equal(t, \"success\", result)\n    29→}\n    30→\n    31→func TestGenericAdapter_ScriptFailure(t *testing.T) {\n    32→\tadapter := generic.New()\n    33→\tstep := &domain.Step{\n    34→\t\tName:    \"build\",\n    35→\t\tType:    domain.StepTypeScript,\n    36→\t\tResults: []string{\"success\", \"fail\"},\n    37→\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n    38→\t}\n    39→\n    40→\tresult, err := adapter.Execute(context.Background(), step, t.TempDir())\n    41→\trequire.NoError(t, err)\n    42→\tassert.Equal(t, \"fail\", result)\n    43→}\n    44→\n    45→func TestGenericAdapter_ScriptModifiesFiles(t *testing.T) {\n    46→\tdir := t.TempDir()\n    47→\tadapter := generic.New()\n    48→\tstep := &domain.Step{\n    49→\t\tName:    \"generate\",\n    50→\t\tType:    domain.StepTypeScript,"}]},"parent_tool_use_id":"toolu_01BzjcVAg47gGUAAG5dSfXCB","session_id":"46588779-0c89-4fa7-bd