{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DtR3SHG6RuGrWEk8CJAqKF","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"net\"\n     7→\t\"net/http\"\n     8→\t\"os\"\n     9→\t\"os/signal\"\n    10→\t\"path/filepath\"\n    11→\t\"syscall\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    15→\t\"github.com/cloche-dev/cloche/internal/version\"\n    16→\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    20→\t\"github.com/cloche-dev/cloche/internal/config\"\n    21→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    22→\thostpkg \"github.com/cloche-dev/cloche/internal/host\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→\t\"google.golang.org/grpc\"\n    26→)\n    27→\n    28→func main() {\n    29→\tif len(os.Args) >= 2 && (os.Args[1] == \"-v\" || os.Args[1] == \"--version\") {\n    30→\t\tfmt.Printf(\"cloched %s\\n\", version.Version())\n    31→\t\treturn\n    32→\t}\n    33→\n    34→\t// Load global config file (~/.config/cloche/config)\n    35→\tglobalCfg, err := config.LoadGlobal()\n    36→\tif err != nil {\n    37→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n    38→\t\tdefaults := config.Config{}\n    39→\t\tglobalCfg = &defaults\n    40→\t}\n    41→\n    42→\t// Ensure state directory exists (~/.config/cloche/)\n    43→\tif _, err := config.EnsureStateDir(); err != nil {\n    44→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to create state dir: %v\\n\", err)\n    45→\t}\n    46→\n    47→\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, config.DefaultDBPath())\n    48→\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, config.DefaultSocketAddr())\n    49→\n    50→\tstore, err := sqlite.NewStore(dbPath)\n    51→\tif err != nil {\n    52→\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    53→\t\tos.Exit(1)\n    54→\t}\n    55→\tdefer store.Close()\n    56→\n    57→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    58→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    59→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    60→\t} else if n > 0 {\n    61→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    62→\t}\n    63→\n    64→\truntime, err := initRuntime(globalCfg)\n    65→\tif err != nil {\n    66→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    67→\t\tos.Exit(1)\n    68→\t}\n    69→\n    70→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    71→\n    72→\tbroadcaster := logstream.NewBroadcaster()\n    73→\n    74→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    75→\tsrv.SetLogStore(store)\n    76→\tsrv.SetLogBroadcaster(broadcaster)\n    77→\n    78→\t// Set up evolution trigger\n    79→\tevoTrigger := initEvolution(globalCfg, store, store)\n    80→\tif evoTrigger != nil {\n    81→\t\tsrv.SetEvolution(evoTrigger)\n    82→\t}\n    83→\n    84→\tgrpcServer := grpc.NewServer()\n    85→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    86→\n    87→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    88→\n    89→\tlis, err := listen(listenAddr)\n    90→\tif err != nil {\n    91→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    92→\t\tos.Exit(1)\n    93→\t}\n    94→\n    95→\tvar httpServer *http.Server\n    96→\tif httpAddr := envOrConfig(\"CLOCHE_