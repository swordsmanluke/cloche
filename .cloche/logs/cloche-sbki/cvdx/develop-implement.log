)\n\t}\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":985,"cache_read_input_tokens":145787,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":985},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"46588779-0c89-4fa7-bd14-27979381b9bd","uuid":"e881ae7f-4cd1-4194-b2c5-6270583e98cf"}
