\t\tPriorResults: priorResults,\n\t}\n\n\t// 6. Dispatch based on run type\n\tif run.IsHost {\n\t\treturn s.resumeHostRun(ctx, run, resumeCfg)\n\t}\n\treturn s.resumeContainerRun(ctx, run, resumeCfg)\n}\n\n// resumeContainerRun resumes a failed container workflow run.\nfunc (s *ClocheServer) resumeContainerRun(ctx context.Context, run *domain.Run, resumeCfg *domain.ResumeConfig) (*pb.ResumeRunResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\tcontainerID := run.ContainerID\n\tif containerID == \"\" {\n\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", run.ID)\n\t}\n\n\t// Verify the container still exists\n\tif _, err := s.container.Inspect(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"container %s not found (may have been cleaned up): %w\", containerID, err)\n\t}\n\n\t// Write the resume config into the stopped container\n\tresumeJSON, err := json.Marshal(resumeCfg)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"marshaling resume config: %w\", err)\n\t}\n\n\ttmpFile, err := os.CreateTemp(\"\", \"cloche-resume-*.json\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating temp file: %w\", err)\n\t}\n\ttmpPath := tmpFile.Name()\n\tdefer os.Remove(tmpPath)\n\n\tif _, err := tmpFile.Write(resumeJSON); err != nil {\n\t\ttmpFile.Close()\n\t\treturn nil, fmt.Errorf(\"writing resume config: %w\", err)\n\t}\n\ttmpFile.Close()\n\n\t// Copy resume.json into the container's workspace\n\tif err := dockerCp(ctx, tmpPath, containerID+\":/workspace/.cloche/resume.json\"); err != nil {\n\t\treturn nil, fmt.Errorf(\"copying resume config to container: %w\", err)\n\t}\n\n\t// Copy updated project files (scripts, prompts, overrides)\n\tif run.ProjectDir != \"\" {\n\t\tcopyProjectUpdates(ctx, containerID, run.ProjectDir)\n\t}\n\n\t// Reset run state to pending\n\trun.State = domain.RunStatePending\n\trun.ErrorMessage = \"\"\n\trun.ActiveSteps = nil\n\tif err := s.store.UpdateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"updating run state: %w\", err)\n\t}\n\n\ts.mu.Lock()\n\ts.runIDs[run.ID] = containerID\n\ts.mu.Unlock()\n\n\tgo s.restartAndTrack(run.ID, containerID, run.ProjectDir, run.WorkflowName)\n\n\treturn &pb.ResumeRunResponse{RunId: run.ID}, nil\n}\n\n// resumeHostRun resumes a failed host workflow run.\nfunc (s *ClocheServer) resumeHostRun(ctx context.Context, run *domain.Run, resumeCfg *domain.ResumeConfig) (*pb.ResumeRunResponse, error) {\n\tresumeJSON, err := json.Marshal(resumeCfg)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"marshaling resume config: %w\", err)\n\t}\n\n\tresumeDir := filepath.Join(run.ProjectDir, \".cloche\", run.ID)\n\tif err := os.MkdirAll(resumeDir, 0755); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating resume dir: %w\", err)\n\t}\n\tif err := os.WriteFile(filepath.Join(resumeDir, \"resume.json\"), resumeJSON, 0644); err != nil {\n\t\treturn nil, fmt.Errorf(\"writing resume config: %w\", err)\n\t}\n\n\t// Reset run state\n\trun.State = domain.RunStatePending\n\trun.ErrorMessage = \"\"\n\trun.ActiveSteps = nil\n\tif err := s.store.UpdateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"updating run state: %w\", err)\n\t}\n\n\trunner := &host.Runner{\n\t\tDispatcher:   s,\n\t\tStore:        s.store,\n\t\tCaptures:     s.captures,\n\t\tLogBroadcast: s.logBroadcast,\n\t\tTaskID:       run.TaskID,\n\t}\n\n\tgo func() {\n\t\trunner.RunNamedWithID(context.Background(), run.ProjectDir, run.WorkflowName, run.ID)\n\t}()\n\n\treturn &pb.ResumeRunResponse{RunId: run.ID}, nil\n}\n\n// restartAndTrack restarts a stopped container and tracks it to completion.\nfunc (s *ClocheServer) restartAndTrack(runID, containerID, projectDir, workflowName string) {\n\tctx := context.Background()\n\n\t// Start the stopped container (re-runs original CMD which includes the agent)\n\tcmd := exec.CommandContext(ctx, \"docker\", \"start\", containerID)\n\tif out, err := cmd.CombinedOutput(); err != nil {\n\t\tlog.Printf(\"resume run %s: failed to restart container: %s: %v\", runID, string(out), err)\n\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\tif run != nil {\n\t\t\trun.Fail(fmt.Sprintf(\"failed to restart container: %v\", err))\n\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t}\n\t\ts.mu.Lock()\n\t\tdelete(s.runIDs, runID)\n\t\ts.mu.Unlock()\n\t\treturn\n\t}\n\n\trun, _ := s.store.GetRun(ctx, runID)\n\tif run != nil {\n\t\trun.Start()\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\t// Reuse trackRun — keepContainer=true so the container is preserved\n\ts.trackRun(runID, containerID, projectDir, workflowName, true)\n}\n\n// firstFailedStepFromCaptures finds the first step that failed or was not completed.\nfunc firstFailedStepFromCaptures(captures []*domain.StepExecution) string {\n\tcompleted := make(map[string]string)\n\tfor _, c := range captures {\n\t\tif c.Result != \"\" {\n\t\t\tcompleted[c.StepName] = c.Result\n\t\t}\n\t}\n\n\tfor _, c := range captures {\n\t\tresult, hasResult := completed[c.StepName]\n\t\tif !hasResult {\n\t\t\treturn c.StepName\n\t\t}\n\t\tif result == \"fail\" || result == \"error\" {\n\t\t\treturn c.StepName\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// succeededStepsBefore returns step results for all steps that completed\n// successfully before the target step in execution order.\nfunc succeededStepsBefore(captures []*domain.StepExecution, targetStep string) map[string]string {\n\tresults := make(map[string]string)\n\tfor _, c := range captures {\n\t\tif c.StepName == targetStep {\n\t\t\tbreak\n\t\t}\n\t\tif c.Result != \"\" && c.Result != \"fail\" && c.Result != \"error\" {\n\t\t\tresults[c.StepName] = c.Result\n\t\t}\n\t}\n\treturn results\n}\n\n// dockerCp wraps docker cp for copying files into a container.\nfunc dockerCp(ctx context.Context, src, dst string) error {\n\tcmd := exec.CommandContext(ctx, \"docker\", \"cp\", src, dst)\n\tif out, err := cmd.CombinedOutput(); err != nil {\n\t\treturn fmt.Errorf(\"%s: %w\", string(out), err)\n\t}\n\treturn nil\n}\n\n// copyProjectUpdates copies updated scripts, prompts, and overrides into the container.\nfunc copyProjectUpdates(ctx context.Context, containerID, projectDir string) {\n\tfor _, sub := range []struct {\n\t\thostDir      string\n\t\tcontainerDir string\n\t}{\n\t\t{filepath.Join(projectDir, \".cloche\", \"scripts\"), \"/workspace/.cloche/scripts/\"},\n\t\t{filepath.Join(projectDir, \".cloche\", \"prompts\"), \"/workspace/.cloche/prompts/\"},\n\t\t{filepath.Join(projectDir, \".cloche\", \"overrides\"), \"/workspace/\"},\n\t} {\n\t\tif _, err := os.Stat(sub.hostDir); err == nil {\n\t\t\tdockerCp(ctx, sub.hostDir+\"/.\", containerID+\":\"+sub.containerDir)\n\t\t}\n\t}\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3274,"cache_read_input_tokens":147919,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3274},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"46588779-0c89-4fa7-bd14-27979381b9bd","uuid":"cafdc0a3-fa00-4ae1-9c15-025e4a472f11"}
