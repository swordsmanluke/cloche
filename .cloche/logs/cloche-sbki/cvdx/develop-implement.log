{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TpnNy2oyVDNEboQAM7ZWdp","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"net\"\n     7→\t\"net/http\"\n     8→\t\"os\"\n     9→\t\"os/signal\"\n    10→\t\"path/filepath\"\n    11→\t\"syscall\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    15→\t\"github.com/cloche-dev/cloche/internal/version\"\n    16→\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    20→\t\"github.com/cloche-dev/cloche/internal/config\"\n    21→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    22→\thostpkg \"github.com/cloche-dev/cloche/internal/host\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→\t\"google.golang.org/grpc\"\n    26→)\n    27→\n    28→func main() {\n    29→\tif len(os.Args) >= 2 && (os.Args[1] == \"-v\" || os.Args[1] == \"--version\") {\n    30→\t\tfmt.Printf(\"cloched %s\\n\", version.Version())\n    31→\t\treturn\n    32→\t}\n    33→\n    34→\t// Load global config file (~/.config/cloche/config)\n    35→\tglobalCfg, err := config.LoadGlobal()\n    36→\tif err != nil {\n    37→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n    38→\t\tdefaults := config.Config{}\n    39→\t\tglobalCfg = &defaults\n    40→\t}\n    41→\n    42→\t// Ensure state directory exists (~/.config/cloche/)\n    43→\tif _, err := config.EnsureStateDir(); err != nil {\n    44→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to create state dir: %v\\n\", err)\n    45→\t}\n    46→\n    47→\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, config.DefaultDBPath())\n    48→\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, config.DefaultSocketAddr())\n    49→\n    50→\tstore, err := sqlite.NewStore(dbPath)\n    51→\tif err != nil {\n    52→\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    53→\t\tos.Exit(1)\n    54→\t}\n    55→\tdefer store.Close()\n    56→\n    57→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    58→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    59→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    60→\t} else if n > 0 {\n    61→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    62→\t}\n    63→\n    64→\truntime, err := initRuntime(globalCfg)\n    65→\tif err != nil {\n    66→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    67→\t\tos.Exit(1)\n    68→\t}\n    69→\n    70→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    71→\n    72→\tbroadcaster := logstream.NewBroadcaster()\n    73→\n    74→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    75→\tsrv.SetLogStore(store)\n    76→\tsrv.SetLogBroadcaster(broadcaster)\n    77→\n    78→\t// Set up evolution trigger\n    79→\tevoTrigger := initEvolution(globalCfg, store, store)\n    80→\tif evoTrigger != nil {\n    81→\t\tsrv.SetEvolution(evoTrigger)\n    82→\t}\n    83→\n    84→\tgrpcServer := grpc.NewServer()\n    85→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    86→\n    87→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    88→\n    89→\tlis, err := listen(listenAddr)\n    90→\tif err != nil {\n    91→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    92→\t\tos.Exit(1)\n    93→\t}\n    94→\n    95→\tvar httpServer *http.Server\n    96→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n    97→\t\twebOpts := []web.HandlerOption{\n    98→\t\t\tweb.WithContainerLogger(runtime),\n    99→\t\t\tweb.WithLogStore(store),\n   100→\t\t\tweb.WithLogBroadcaster(broadcaster),\n   101→\t\t\tweb.WithTaskProvider(srv),\n   102→\t\t}\n   103→\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n   104→\t\tif err != nil {\n   105→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n   106→\t\t\tos.Exit(1)\n   107→\t\t}\n   108→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n   109→\t\tgo func() {\n   110→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   111→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   112→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   113→\t\t\t}\n   114→\t\t}()\n   115→\t}\n   116→\n   117→\t// Auto-execute main workflow for active projects\n   118→\tautoRunActiveProjects(store, srv)\n   119→\n   120→\tsigCh := make(chan os.Signal, 1)\n   121→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   122→\tgo func() {\n   123→\t\t<-sigCh\n   124→\t\tif httpServer != nil {\n   125→\t\t\thttpServer.Close()\n   126→\t\t}\n   127→\t\tgrpcServer.GracefulStop()\n   128→\t}()\n   129→\n   130→\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   131→\tif err := grpcServer.Serve(lis); err != nil {\n   132→\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   133→\t\tos.Exit(1)\n   134→\t}\n   135→}\n   136→\n   137→func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   138→\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   139→\n   140→\tswitch runtimeType {\n   141→\tcase \"local\":\n   142→\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   143→\t\tif agentPath == \"\" {\n   144→\t\t\t// Look for cloche-agent next to this binary\n   145→\t\t\texe, err := os.Executable()\n   146→\t\t\tif err == nil {\n   147→\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   148→\t\t\t} else {\n   149→\t\t\t\tagentPath = \"cloche-agent\"\n   150→\t\t\t}\n   151→\t\t}\n   152→\t\treturn local.NewRuntime(agentPath), nil\n   153→\tcase \"docker\":\n   154→\t\treturn docker.NewRuntime()\n   155→\tdefault:\n   156→\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   157→\t}\n   158→}\n   159→\n   160→func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   161→\t// Load config from working directory (daemon-level defaults)\n   162→\tcfg, err := config.Load(\".\")\n   163→\tif err != nil || !cfg.Evolution.Enabled {\n   164→\t\treturn nil\n   165→\t}\n   166→\n   167→\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   168→\tif llmCmd == \"\" {\n   169→\t\treturn nil\n   170→\t}\n   171→\n   172→\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   173→\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   174→\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   175→\t\t\t// Load per-project config for confidence threshold\n   176→\t\t\tprojCfg, err := config.Load(projectDir)\n   177→\t\t\tif err != nil {\n   178→\t\t\t\tprojCfg = cfg // fall back to daemon config\n   179→\t\t\t}\n   180→\n   181→\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   182→\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   183→\t\t\t\tProjectDir:    projectDir,\n   184→\t\t\t\tWorkflowName:  workflowName,\n   185→\t\t\t\tLLM:           llm,\n   186→\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   187→\t\t\t})\n   188→\n   189→\t\t\tctx := context.Background()\n   190→\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   191→\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   192→\t\t\t}\n   193→\t\t},\n   194→\t})\n   195→\n   196→\treturn trigger\n   197→}\n   198→\n   199→func listen(addr string) (net.Listener, error) {\n   200→\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   201→\t\tsockPath := addr[7:]\n   202→\t\tos.Remove(sockPath)\n   203→\t\treturn net.Listen(\"unix\", sockPath)\n   204→\t}\n   205→\treturn net.Listen(\"tcp\", addr)\n   206→}\n   207→\n   208→// autoRunActiveProjects scans known projects for active = true in their config,\n   209→// parses .cloche/host.cloche and executes the full host workflow step by step.\n   210→func autoRunActiveProjects(store ports.RunStore, srv *adaptgrpc.ClocheServer) {\n   211→\tctx := context.Background()\n   212→\tprojects, err := store.ListProjects(ctx)\n   213→\tif err != nil {\n   214→\t\tfmt.Fprintf(os.Stderr, \"startup: failed to list projects: %v\\n\", err)\n   215→\t\treturn\n   216→\t}\n   217→\n   218→\tfor _, projectDir := range projects {\n   219→\t\tcfg, err := config.Load(projectDir)\n   220→\t\tif err != nil || !cfg.Active {\n   221→\t\t\tcontinue\n   222→\t\t}\n   223→\n   224→\t\t// Verify host.cloche exists before launching\n   225→\t\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   226→\t\tif _, err := os.Stat(hostPath); err != nil {\n   227→\t\t\tfmt.Fprintf(os.Stderr, \"startup: skipping active project %s: %v\\n\", projectDir, err)\n   228→\t\t\tcontinue\n   229→\t\t}\n   230→\n   231→\t\tfmt.Fprintf(os.Stderr, \"startup: auto-running host workflow for active project %s\\n\", projectDir)\n   232→\t\tgo func(projDir string) {\n   233→\t\t\trunner := &hostpkg.Runner{\n   234→\t\t\t\tDispatcher: srv,\n   235→\t\t\t\tStore:      store,\n   236→\t\t\t}\n   237→\t\t\tresult, err := runner.Run(context.Background(), projDir)\n   238→\t\t\tif err != nil {\n   239→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow failed for %s: %v\\n\", projDir, err)\n   240→\t\t\t} else {\n   241→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow completed for %s: %s (run %s)\\n\", projDir, result.State, result.RunID)\n   242→\t\t\t}\n   243→\t\t}(projectDir)\n   244→\t}\n   245→}\n   246→\n   247→// envOrConfig returns the env var value if set, otherwise the config file\n   248→// value if non-empty, otherwise the fallback default.\n   249→func envOrConfig(envKey, configVal, fallback string) string {\n   250→\tif v := os.Getenv(envKey); v != \"\" {\n   251→\t\treturn v\n   252→\t}\n   253→\tif configVal != \"\" {\n   254→\t\treturn configVal\n   255→\t}\n   256→\treturn fallback\n   257→}\n   258→"}]},"parent_tool_use_id":"toolu_01BzjcVAg47gGUAAG5dSfXCB","session_id":"46588779-0c89-4fa7-bd14-27979381b9bd","uuid":"d24ff292-a5f4-44a5-8958-01f930ca9808"}
