{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NWU2ffC7RPaTanFCrPSawY","type":"tool_result","content":"     1→package domain\n     2→\n     3→import (\n     4→\t\"encoding/json\"\n     5→\t\"fmt\"\n     6→\t\"strings\"\n     7→)\n     8→\n     9→const (\n    10→\tStepDone  = \"done\"\n    11→\tStepAbort = \"abort\"\n    12→)\n    13→\n    14→type StepType string\n    15→\n    16→const (\n    17→\tStepTypeAgent    StepType = \"agent\"\n    18→\tStepTypeScript   StepType = \"script\"\n    19→\tStepTypeWorkflow StepType = \"workflow\"\n    20→)\n    21→\n    22→// WorkflowLocation indicates where a workflow is intended to run.\n    23→type WorkflowLocation string\n    24→\n    25→const (\n    26→\t// LocationContainer is for workflows that run inside a Docker container.\n    27→\t// This is the default for workflows without a \"host { }\" block.\n    28→\tLocationContainer WorkflowLocation = \"container\"\n    29→\n    30→\t// LocationHost is for workflows that run on the host machine.\n    31→\t// A workflow declares itself as host by including a \"host { }\" block.\n    32→\tLocationHost WorkflowLocation = \"host\"\n    33→)\n    34→\n    35→type Step struct {\n    36→\tName    string\n    37→\tType    StepType\n    38→\tResults []string\n    39→\tConfig  map[string]string\n    40→}\n    41→\n    42→type Wire struct {\n    43→\tFrom      string\n    44→\tResult    string\n    45→\tTo        string\n    46→\tOutputMap []OutputMapping\n    47→}\n    48→\n    49→type SegmentKind int\n    50→\n    51→const (\n    52→\tSegmentField SegmentKind = iota\n    53→\tSegmentIndex\n    54→)\n    55→\n    56→type PathSegment struct {\n    57→\tKind  SegmentKind\n    58→\tField string // for SegmentField\n    59→\tIndex int    // for SegmentIndex\n    60→}\n    61→\n    62→type OutputPath struct {\n    63→\tSegments []PathSegment\n    64→}\n    65→\n    66→type OutputMapping struct {\n    67→\tEnvVar string\n    68→\tPath   OutputPath\n    69→}\n    70→\n    71→// Evaluate navigates the raw output bytes using the path segments.\n    72→// With no segments, it returns the raw output as a string.\n    73→// With segments, it parses the raw bytes as JSON and navigates using\n    74→// field access (SegmentField) and array indexing (SegmentIndex).\n    75→func (p OutputPath) Evaluate(raw []byte) (string, error) {\n    76→\tif len(p.Segments) == 0 {\n    77→\t\treturn string(raw), nil\n    78→\t}\n    79→\n    80→\tvar val any\n    81→\tif err := json.Unmarshal(raw, &val); err != nil {\n    82→\t\treturn \"\", fmt.Errorf(\"output is not valid JSON\")\n    83→\t}\n    84→\n    85→\tfor _, seg := range p.Segments {\n    86→\t\tswitch seg.Kind {\n    87→\t\tcase SegmentField:\n    88→\t\t\tm, ok := val.(map[string]any)\n    89→\t\t\tif !ok {\n    90→\t\t\t\treturn \"\", fmt.Errorf(\"expected object for .%s\", seg.Field)\n    91→\t\t\t}\n    92→\t\t\tval, ok = m[seg.Field]\n    93→\t\t\tif !ok {\n    94→\t\t\t\treturn \"\", fmt.Errorf(\"field %q not found\", seg.Field)\n    95→\t\t\t}\n    96→\t\tcase SegmentIndex:\n    97→\t\t\tarr, ok := val.([]any)\n    98→\t\t\tif !ok {\n    99→\t\t\t\treturn \"\", fmt.Errorf(\"expected array for [%d]\", seg.Index)\n   100→\t\t\t}\n   101→\t\t\tif seg.Index < 0 || seg.Index >= len(arr) {\n   102→\t\t\t\treturn \"\", fmt.Errorf(\"index %d out of range (len %d)\", seg.Index, len(arr))\n   103→\t\t\t}\n   104→\t\t\tval = arr[seg.Index]\n   105→\t\t}\n   106→\t}\n   107→\n   108→\tswitch v := val.(type) {\n   109→\tcase string:\n   110→\t\treturn v, nil\n   111→\tdefault:\n   112→\t\tb, _ := json.Marshal(v)\n   113→\t\treturn string(b), nil\n   114→\t}\n   115→}\n   116→\n   117→type CollectMode string\n   118→\n   119→const (\n   120→\tCollectAll CollectMode = \"all\"\n   121→\tCollectAny CollectMode = \"any\"\n   122→)\n   123→\n   124→type WireCondition struct {\n   125→\tStep   string\n   126→\tResult string\n   127→}\n   128→\n   129→type Collect struct {\n   130→\tMode       CollectMode\n   131→\tConditions []WireCondition\n   132→\tTo         string\n   133→}\n   134→\n   135→type Workflow struct {\n   136→\tName      string\n   137→\tLocation  WorkflowLocation  // host or container\n   138→\tSteps     map[string]*Step\n   139→\tWiring    []Wire\n   140→\tCollects  []Collect\n   141→\tEntryStep string\n   142→\tConfig    map[string]string // workflow-level config (e.g. \"container.image\")\n   143→}\n   144→\n   145→func (w *Workflow) Validate() error {\n   146→\tif w.EntryStep == \"\" {\n   147→\t\treturn fmt.Errorf(\"workflow %q: no entry step defined\", w.Name)\n   148→\t}\n   149→\tif _, ok := w.Steps[w.EntryStep]; !ok {\n   150→\t\treturn fmt.Errorf(\"workflow %q: entry step %q not found\", w.Name, w.EntryStep)\n   151→\t}\n   152→\n   153→\twired := make(map[string]map[string]bool)\n   154→\treachable := map[string]bool{w.EntryStep: true}\n   155→\tfor _, wire := range w.Wiring {\n   156→\t\tif wired[wire.From] == nil {\n   157→\t\t\twired[wire.From] = make(map[string]bool)\n   158→\t\t}\n   159→\t\twired[wire.From][wire.Result] = true\n   160→\t\tif wire.To != StepDone && wire.To != StepAbort {\n   161→\t\t\treachable[wire.To] = true\n   162→\t\t}\n   163→\t}\n   164→\n   165→\t// Validate collects and count their results as wired\n   166→\tfor _, c := range w.Collects {\n   167→\t\t// Validate target step exists\n   168→\t\tif c.To != StepDone && c.To != StepAbort {\n   169→\t\t\tif _, ok := w.Steps[c.To]; !ok {\n   170→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect target step %q not found\", w.Name, c.To)\n   171→\t\t\t}\n   172→\t\t\treachable[c.To] = true\n   173→\t\t}\n   174→\n   175→\t\tfor _, cond := range c.Conditions {\n   176→\t\t\t// Validate condition step exists\n   177→\t\t\tstep, ok := w.Steps[cond.Step]\n   178→\t\t\tif !ok {\n   179→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references unknown step %q\", w.Name, cond.Step)\n   180→\t\t\t}\n   181→\t\t\t// Validate condition result is declared\n   182→\t\t\tfoun