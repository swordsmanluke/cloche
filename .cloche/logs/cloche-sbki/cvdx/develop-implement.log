he resume step)\n\tpriorResults := succeededStepsBefore(stepExecutions, resumeStep)\n\n\tresumeCfg := &domain.ResumeConfig{\n\t\tFromStep:     resumeStep,\n\t\tPriorResults: priorResults,\n\t}\n\n\t// 6. Dispatch based on run type\n\tif run.IsHost {\n\t\treturn s.resumeHostRun(ctx, run, resumeCfg)\n\t}\n\treturn s.resumeContainerRun(ctx, run, resumeCfg)\n}\n\n// resumeContainerRun resumes a failed container workflow run.\nfunc (s *ClocheServer) resumeContainerRun(ctx context.Context, run *domain.Run, resumeCfg *domain.ResumeConfig) (*pb.ResumeRunResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\tcontainerID := run.ContainerID\n\tif containerID == \"\" {\n\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", run.ID)\n\t}\n\n\t// Verify the container still exists\n\tif _, err := s.container.Inspect(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"container %s not found (may have been cleaned up): %w\", containerID, err)\n\t}\n\n\t// Write the resume config into the stopped container\n\tresumeJSON, err := json.Marshal(resumeCfg)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"marshaling resume config: %w\", err)\n\t}\n\n\ttmpFile, err := os.CreateTemp(\"\", \"cloche-resume-*.json\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating temp file: %w\", err)\n\t}\n\ttmpPath := tmpFile.Name()\n\tdefer os.Remove(tmpPath)\n\n\tif _, err := tmpFile.Write(resumeJSON); err != nil {\n\t\ttmpFile.Close()\n\t\treturn nil, fmt.Errorf(\"writing resume config: %w\", err)\n\t}\n\ttmpFile.Close()\n\n\t// Copy resume.json into the container's workspace\n\tif err := dockerCp(ctx, tmpPath, containerID+\":/workspace/.cloche/resume.json\"); err != nil {\n\t\treturn nil, fmt.Errorf(\"copying resume config to container: %w\", err)\n\t}\n\n\t// Copy updated project files (scripts, prompts, overrides)\n\tif run.ProjectDir != \"\" {\n\t\tcopyProjectUpdates(ctx, containerID, run.ProjectDir)\n\t}