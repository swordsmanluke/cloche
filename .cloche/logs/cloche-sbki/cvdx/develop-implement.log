ool error_halted = 13;       // true when loop is halted due to an unrecovered error\n  string halt_error = 14;       // the error that caused the halt\n}\n\nmessage GetVersionRequest {}\n\nmessage GetVersionResponse {\n  string version = 1;\n}\n","numLines":171,"startLine":1,"totalLines":171}}}
