{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019swBUDLsrJrZvkV4Ys3g9F","type":"tool_result","content":"     1→package protocol\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"io\"\n     8→\t\"time\"\n     9→)\n    10→\n    11→type MessageType string\n    12→\n    13→const (\n    14→\tMsgStepStarted  MessageType = \"step_started\"\n    15→\tMsgStepCompleted MessageType = \"step_completed\"\n    16→\tMsgRunCompleted  MessageType = \"run_completed\"\n    17→\tMsgRunTitle      MessageType = \"run_title\"\n    18→\tMsgLog           MessageType = \"log\"\n    19→\tMsgError         MessageType = \"error\"\n    20→)\n    21→\n    22→type StatusMessage struct {\n    23→\tType      MessageType `json:\"type\"`\n    24→\tStepName  string      `json:\"step_name,omitempty\"`\n    25→\tResult    string      `json:\"result,omitempty\"`\n    26→\tMessage   string      `json:\"message,omitempty\"`\n    27→\tTimestamp time.Time   `json:\"timestamp\"`\n    28→}\n    29→\n    30→// flusher is an optional interface for writers that support explicit flushing.\n    31→type flusher interface {\n    32→\tFlush() error\n    33→}\n    34→\n    35→type StatusWriter struct {\n    36→\tw   io.Writer\n    37→\tenc *json.Encoder\n    38→}\n    39→\n    40→func NewStatusWriter(w io.Writer) *StatusWriter {\n    41→\treturn &StatusWriter{w: w, enc: json.NewEncoder(w)}\n    42→}\n    43→\n    44→func (s *StatusWriter) StepStarted(stepName string) {\n    45→\ts.write(StatusMessage{Type: MsgStepStarted, StepName: stepName})\n    46→}\n    47→\n    48→func (s *StatusWriter) StepCompleted(stepName, result string) {\n    49→\ts.write(StatusMessage{Type: MsgStepCompleted, StepName: stepName, Result: result})\n    50→}\n    51→\n    52→func (s *StatusWriter) RunCompleted(result string) {\n    53→\ts.write(StatusMessage{Type: MsgRunCompleted, Result: result})\n    54→}\n    55→\n    56→func (s *StatusWriter) RunTitle(title string) {\n    57→\ts.write(StatusMessage{Type: MsgRunTitle, Message: title})\n    58→}\n    59→\n    60→func (s *StatusWriter) Log(stepName, message string) {\n    61→\ts.write(StatusMessage{Type: MsgLog, StepName: stepName, Message: message})\n    62→}\n    63→\n    64→func (s *StatusWriter) Error(stepName, message string) {\n    65→\ts.write(StatusMessage{Type: MsgError, StepName: stepName, Message: message})\n    66→}\n    67→\n    68→func (s *StatusWriter) write(msg StatusMessage) {\n    69→\tmsg.Timestamp = time.Now()\n    70→\t_ = s.enc.Encode(msg)\n    71→\t// Flush the underlying writer if it supports it, to ensure real-time delivery.\n    72→\tif f, ok := s.w.(flusher); ok {\n    73→\t\t_ = f.Flush()\n    74→\t}\n    75→}\n    76→\n    77→func ParseStatusStream(data []byte) ([]StatusMessage, error) {\n    78→\tvar msgs []StatusMessage\n    79→\tdec := json.NewDecoder(bytes.NewReader(data))\n    80→\tfor dec.More() {\n    81→\t\tvar msg StatusMessage\n    82→\t\tif err := dec.Decode(&msg); err != nil {\n    83→\t\t\treturn msgs, fmt.Errorf(\"failed to decode status message: %w\", err)\n    84→\t\t}\n    85→\t\tmsgs = append(msgs, msg)\n    86→\t}\n    87→\treturn msgs, nil\n    88→}\n    89→"}]},"parent_tool_use_id":"toolu_01BzjcVAg47gGUAAG5dSfXCB","session_id":"46588779-0c89-4fa7-bd14-27979381b9bd","uuid":"910841d3-b472-4759-bb0e-f4f1ae205830"}
