{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W5AQSkpW3DepoMH6647QsU","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"os\"\n     8→\t\"os/signal\"\n     9→\t\"syscall\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/agent\"\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/version\"\n    14→)\n    15→\n    16→func main() {\n    17→\tif len(os.Args) >= 2 && (os.Args[1] == \"-v\" || os.Args[1] == \"--version\") {\n    18→\t\tfmt.Printf(\"cloche-agent %s\\n\", version.Version())\n    19→\t\treturn\n    20→\t}\n    21→\n    22→\tif len(os.Args) < 2 {\n    23→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche-agent <workflow-file>\\n\")\n    24→\t\tos.Exit(1)\n    25→\t}\n    26→\n    27→\tworkflowPath := os.Args[1]\n    28→\tworkDir, _ := os.Getwd()\n    29→\n    30→\tctx, cancel := context.WithCancel(context.Background())\n    31→\tdefer cancel()\n    32→\n    33→\tsigCh := make(chan os.Signal, 1)\n    34→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n    35→\tgo func() {\n    36→\t\t<-sigCh\n    37→\t\tcancel()\n    38→\t}()\n    39→\n    40→\trunID := os.Getenv(\"CLOCHE_RUN_ID\")\n    41→\tos.Unsetenv(\"CLOCHE_RUN_ID\")\n    42→\n    43→\t// Check for resume config file\n    44→\tvar resumeCfg *domain.ResumeConfig\n    45→\tresumePath := \".cloche/resume.json\"\n    46→\tif data, err := os.ReadFile(resumePath); err == nil {\n    47→\t\tvar rc domain.ResumeConfig\n    48→\t\tif err := json.Unmarshal(data, &rc); err != nil {\n    49→\t\t\tfmt.Fprintf(os.Stderr, \"error parsing resume config: %v\\n\", err)\n    50→\t\t\tos.Exit(1)\n    51→\t\t}\n    52→\t\tresumeCfg = &rc\n    53→\t\t// Remove the resume file so the next run starts fresh\n    54→\t\tos.Remove(resumePath)\n    55→\t}\n    56→\n    57→\trunner := agent.NewRunner(agent.RunnerConfig{\n    58→\t\tWorkflowPath: workflowPath,\n    59→\t\tWorkDir:      workDir,\n    60→\t\tStatusOutput: os.Stdout,\n    61→\t\tRunID:        runID,\n    62→\t\tResumeConfig: resumeCfg,\n    63→\t})\n    64→\n    65→\tif err := runner.Run(ctx); err != nil {\n    66→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    67→\t\tos.Exit(1)\n    68→\t}\n    69→}\n    70→"}]},"parent_tool_use_id":"toolu_01Y1PzzwgtqcjET4zTfJf9wf","session_id":"499cc276-44bb-4bfe-9549-2f88e2009a57","uuid":"774214b0-ed81-4956-9c01-72d470513daf"}
