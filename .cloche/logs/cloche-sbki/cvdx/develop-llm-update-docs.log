{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01547FJ8CaNsQ2Rrem1Pn2oj","type":"tool_result","content":"     1→package agent\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"io\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n    12→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    15→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    17→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    18→)\n    19→\n    20→type RunnerConfig struct {\n    21→\tWorkflowPath string\n    22→\tWorkDir      string\n    23→\tStatusOutput io.Writer\n    24→\tRunID        string\n    25→\tResumeConfig *domain.ResumeConfig // if non-nil, resume from the specified step\n    26→}\n    27→\n    28→type Runner struct {\n    29→\tcfg RunnerConfig\n    30→}\n    31→\n    32→func NewRunner(cfg RunnerConfig) *Runner {\n    33→\treturn &Runner{\n    34→\t\tcfg: cfg,\n    35→\t}\n    36→}\n    37→\n    38→func (r *Runner) Run(ctx context.Context) error {\n    39→\tdata, err := os.ReadFile(r.cfg.WorkflowPath)\n    40→\tif err != nil {\n    41→\t\treturn fmt.Errorf(\"reading workflow file: %w\", err)\n    42→\t}\n    43→\n    44→\twf, err := dsl.ParseForContainer(string(data))\n    45→\tif err != nil {\n    46→\t\treturn fmt.Errorf(\"parsing workflow: %w\", err)\n    47→\t}\n    48→\n    49→\tstatusWriter := protocol.NewStatusWriter(r.cfg.StatusOutput)\n    50→\tgenericAdapter := generic.New()\n    51→\tgenericAdapter.RunID = r.cfg.RunID\n    52→\tpromptAdapter := prompt.New()\n    53→\tpromptAdapter.RunID = r.cfg.RunID\n    54→\tpromptAdapter.StatusWriter = statusWriter\n    55→\tif cmd, ok := os.LookupEnv(\"CLOCHE_AGENT_COMMAND\"); ok {\n    56→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    57→\t}\n    58→\tif cmd := wf.Config[\"container.agent_command\"]; cmd != \"\" {\n    59→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    60→\t}\n    61→\tif args := wf.Config[\"container.agent_args\"]; args != \"\" {\n    62→\t\tpromptAdapter.ExplicitArgs = strings.Fields(args)\n    63→\t}\n    64→\n    65→\t// When resuming, keep prior state (attempt_count, output files).\n    66→\t// On fresh runs, reset per-run state from any previous run.\n    67→\tif r.cfg.ResumeConfig == nil {\n    68→\t\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"attempt_count\"))\n    69→\t\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"output\"))\n    70→\t}\n    71→\n    72→\t// Create unified log writer\n    73→\tulog, err := logstream.New(r.cfg.WorkDir)\n    74→\tif err != nil {\n    75→\t\treturn fmt.Errorf(\"creating unified log: %w\", err)\n    76→\t}\n    77→\tdefer ulog.Close()\n    78→\n    79→\tgenericAdapter.StatusWriter = statusWriter\n    80→\n    81→\texecutor := &stepExecutor{\n    82→\t\tworkDir:      r.cfg.WorkDir,\n    83→\t\tgeneric:      genericAdapter,\n    84→\t\tprompt:       promptAdapter,\n    85→\t\tlogStream:    ulog,\n    86→\t\tstatusWriter: statusWriter,\n    87→\t}\n    88→\n    89→\t// Wrap executor for resume mode if configured\n    90→\tvar stepExec engine.StepExecutor = executor\n    91→\tif r.cfg.ResumeConfig != nil {\n    92→\t\tstepExec = &engine.ResumeExecutor{\n    93→\t\t\tInner:        executor,\n    94→\t\t\tPriorResults: r.cfg.ResumeConfig.PriorResults,\n    95→\t\t\tResumeStep:   r.cfg.ResumeConfig.FromStep,\n    96→\t\t}\n    97→\t}\n    98→\n    99→\teng := engine.New(stepExec)\n   100→\teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n   101→\n   102→\t// Generate a run title from the prompt if one was not provided by the caller.\n   103→\t// The daemon sets title from --title; if empty, the agent extracts from prompt.\n   104→\tif title := extractTitle(r.cfg.WorkDir, r.cfg.RunID); title != \"\" {\n   105→\t\tstatusWriter.RunTitle(title)\n   106→\t}\n   107→\n   108→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n   109→\n   110→\trun, runErr := eng.Run(ctx, wf)\n   111→\tif runErr != nil {\n   112→\t\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:failed\")\n   113→\t\tulog.Log(logstream.TypeStatus, \"error: \"+runErr.Error())\n   114→\t\tulog.Log(logstream.TypeStatus, \"run_completed: failed\")\n   115→\t\t// Extract the failed step name from step executions so the daemon\n   116→\t\t// can display which step caused the failure.\n   117→\t\tfailedStep := \"\"\n   118→\t\tif run != nil {\n   119→\t\t\tfor _, se := range run.StepExecutions {\n   120→\t\t\t\tif se.Result == \"error\" || se.Result == \"fail\" {\n   121→\t\t\t\t\tfailedStep = se.StepName\n   122→\t\t\t\t}\n   123→\t\t\t}\n   124→\t\t}\n   125→\t\tstatusWriter.Error(failedStep, runErr.Error())\n   126→\t\tstatusWriter.RunCompleted(\"failed\")\n   127→\t\treturn runErr\n   128→\t}\n   129→\n   130→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:\"+string(run.State))\n   131→\n   132→\tulog.Log(logstream.TypeStatus, \"run_completed: \"+string(run.State))\n   133→\tstatusWriter.RunCompleted(string(run.State))\n   134→\treturn nil\n   135→}\n   136→\n   137→type stepExecutor struct {\n   138→\tworkDir      string\n   139→\tgeneric      *generic.Adapter\n   140→\tprompt       *prompt.Adapter\n   141→\tlogStream    *logstream.Writer\n   142→\tstatusWriter *protocol.StatusWriter\n   143→}\n   144→\n   145→func (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n   146→\tswitch step.Type {\n   147→\tcase domain.StepTypeScript:\n   148→\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   149→\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   150→\t\treturn result, err"}]},"parent_tool_use_id":"toolu_01Y1PzzwgtqcjET4zTfJf9wf","session_id":"499cc276-44bb-4bfe-9549-2f88e2009a57","uuid":"871f1276-3517-460e-8fa3-9c67a6f2f229"}
