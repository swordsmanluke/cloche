{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ugp42tHB9CAUf1xwjo571Z","type":"tool_result","content":"     1→package grpc_test\n     2→\n     3→import (\n     4→\t\"testing\"\n     5→\n     6→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     7→\tgrpcadapter \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n     8→\t\"github.com/stretchr/testify/assert\"\n     9→)\n    10→\n    11→func TestFirstFailedStepFromCaptures(t *testing.T) {\n    12→\tcaptures := []*domain.StepExecution{\n    13→\t\t{StepName: \"build\", Result: \"success\"},\n    14→\t\t{StepName: \"implement\", Result: \"fail\"},\n    15→\t}\n    16→\n    17→\tresult := grpcadapter.FirstFailedStepFromCaptures(captures)\n    18→\tassert.Equal(t, \"implement\", result)\n    19→}\n    20→\n    21→func TestFirstFailedStepFromCaptures_NoCompletion(t *testing.T) {\n    22→\tcaptures := []*domain.StepExecution{\n    23→\t\t{StepName: \"build\", Result: \"success\"},\n    24→\t\t{StepName: \"implement\"}, // started but no result\n    25→\t}\n    26→\n    27→\tresult := grpcadapter.FirstFailedStepFromCaptures(captures)\n    28→\tassert.Equal(t, \"implement\", result)\n    29→}\n    30→\n    31→func TestFirstFailedStepFromCaptures_AllSucceeded(t *testing.T) {\n    32→\tcaptures := []*domain.StepExecution{\n    33→\t\t{StepName: \"build\", Result: \"success\"},\n    34→\t\t{StepName: \"test\", Result: \"pass\"},\n    35→\t}\n    36→\n    37→\tresult := grpcadapter.FirstFailedStepFromCaptures(captures)\n    38→\tassert.Empty(t, result)\n    39→}\n    40→\n    41→func TestSucceededStepsBefore(t *testing.T) {\n    42→\tcaptures := []*domain.StepExecution{\n    43→\t\t{StepName: \"setup\", Result: \"success\"},\n    44→\t\t{StepName: \"build\", Result: \"success\"},\n    45→\t\t{StepName: \"implement\", Result: \"fail\"},\n    46→\t}\n    47→\n    48→\tprior := grpcadapter.SucceededStepsBefore(captures, \"implement\")\n    49→\tassert.Equal(t, map[string]string{\n    50→\t\t\"setup\": \"success\",\n    51→\t\t\"build\": \"success\",\n    52→\t}, prior)\n    53→}\n    54→\n    55→func TestSucceededStepsBefore_FirstStep(t *testing.T) {\n    56→\tcaptures := []*domain.StepExecution{\n    57→\t\t{StepName: \"implement\", Result: \"fail\"},\n    58→\t}\n    59→\n    60→\tprior := grpcadapter.SucceededStepsBefore(captures, \"implement\")\n    61→\tassert.Empty(t, prior)\n    62→}\n    63→"}]},"parent_tool_use_id":"toolu_01Y1PzzwgtqcjET4zTfJf9wf","session_id":"499cc276-44bb-4bfe-9549-2f88e2009a57","uuid":"298d3097-f8c7-4676-ba7a-870633a46072"}
