{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TVjq5aKWehhrnBYC8HZKh3","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import \"github.com/cloche-dev/cloche/internal/domain\"\n     4→\n     5→// AddActiveRun registers a fake active run for testing.\n     6→func (s *ClocheServer) AddActiveRun(runID, containerID string) {\n     7→\ts.mu.Lock()\n     8→\ts.runIDs[runID] = containerID\n     9→\ts.mu.Unlock()\n    10→}\n    11→\n    12→// FirstFailedStepFromCaptures is exported for testing.\n    13→var FirstFailedStepFromCaptures = firstFailedStepFromCaptures\n    14→\n    15→// SucceededStepsBefore is exported for testing.\n    16→var SucceededStepsBefore = func(captures []*domain.StepExecution, targetStep string) map[string]string {\n    17→\treturn succeededStepsBefore(captures, targetStep)\n    18→}\n    19→"}]},"parent_tool_use_id":"toolu_01Y1PzzwgtqcjET4zTfJf9wf","session_id":"499cc276-44bb-4bfe-9549-2f88e2009a57","uuid":"b9b43739-0d1a-4a5f-821f-953c7f680df8"}
