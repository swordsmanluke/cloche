{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ALveJJ7qwcLJg8PgMGLXTs","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"net\"\n     7→\t\"net/http\"\n     8→\t\"os\"\n     9→\t\"os/signal\"\n    10→\t\"path/filepath\"\n    11→\t\"syscall\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    15→\t\"github.com/cloche-dev/cloche/internal/version\"\n    16→\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    20→\t\"github.com/cloche-dev/cloche/internal/config\"\n    21→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    22→\thostpkg \"github.com/cloche-dev/cloche/internal/host\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→\t\"google.golang.org/grpc\"\n    26→)\n    27→\n    28→func main() {\n    29→\tif len(os.Args) >= 2 && (os.Args[1] == \"-v\" || os.Args[1] == \"--version\") {\n    30→\t\tfmt.Printf(\"cloched %s\\n\", version.Version())\n    31→\t\treturn\n    32→\t}\n    33→\n    34→\t// Load global config file (~/.config/cloche/config)\n    35→\tglobalCfg, err := config.LoadGlobal()\n    36→\tif err != nil {\n    37→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n    38→\t\tdefaults := config.Config{}\n    39→\t\tglobalCfg = &defaults\n    40→\t}\n    41→\n    42→\t// Ensure state directory exists (~/.config/cloche/)\n    43→\tif _, err := config.EnsureStateDir(); err != nil {\n    44→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to create state dir: %v\\n\", err)\n    45→\t}\n    46→\n    47→\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, config.DefaultDBPath())\n    48→\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, config.DefaultSocketAddr())\n    49→\n    50→\tstore, err := sqlite.NewStore(dbPath)\n    51→\tif err != nil {\n    52→\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    53→\t\tos.Exit(1)\n    54→\t}\n    55→\tdefer store.Close()\n    56→\n    57→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    58→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    59→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    60→\t} else if n > 0 {\n    61→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    62→\t}\n    63→\n    64→\truntime, err := initRuntime(globalCfg)\n    65→\tif err != nil {\n    66→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    67→\t\tos.Exit(1)\n    68→\t}\n    69→\n    70→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    71→\n    72→\tbroadcaster := logstream.NewBroadcaster()\n    73→\n    74→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    75→\tsrv.SetLogStore(store)\n    76→\tsrv.SetLogBroadcaster(broadcaster)\n    77→\n    78→\t// Set up evolution trigger\n    79→\tevoTrigger := initEvolution(globalCfg, store, store)\n    80→\tif evoTrigger != nil {\n    81→\t\tsrv.SetEvolution(evoTrigger)\n    82→\t}\n    83→\n    84→\tgrpcServer := grpc.NewServer()\n    85→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    86→\tpb.RegisterResumeRunHandler(grpcServer, srv)\n    87→\n    88→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    89→\n    90→\tlis, err := listen(listenAddr)\n    91→\tif err != nil {\n    92→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    93→\t\tos.Exit(1)\n    94→\t}\n    95→\n    96→\tvar httpServer *http.Server\n    97→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n    98→\t\twebOpts := []web.HandlerOption{\n    99→\t\t\tweb.WithContainerLogger(runtime),\n   100→\t\t\tweb.WithLogStore(store),\n   101→\t\t\tweb.WithLogBroadcaster(broadcaster),\n   102→\t\t\tweb.WithTaskProvider(srv),\n   103→\t\t}\n   104→\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n   105→\t\tif err != nil {\n   106→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n   107→\t\t\tos.Exit(1)\n   108→\t\t}\n   109→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n   110→\t\tgo func() {\n   111→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   112→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   113→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   114→\t\t\t}\n   115→\t\t}()\n   116→\t}\n   117→\n   118→\t// Auto-execute main workflow for active projects\n   119→\tautoRunActiveProjects(store, srv)\n   120→\n   121→\tsigCh := make(chan os.Signal, 1)\n   122→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   123→\tgo func() {\n   124→\t\t<-sigCh\n   125→\t\tif httpServer != nil {\n   126→\t\t\thttpServer.Close()\n   127→\t\t}\n   128→\t\tgrpcServer.GracefulStop()\n   129→\t}()\n   130→\n   131→\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   132→\tif err := grpcServer.Serve(lis); err != nil {\n   133→\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   134→\t\tos.Exit(1)\n   135→\t}\n   136→}\n   137→\n   138→func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   139→\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   140→\n   141→\tswitch runtimeType {\n   142→\tcase \"local\":\n   143→\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   144→\t\tif agentPath == \"\" {\n   145→\t\t\t// Look for cloche-agent next to this binary\n   146→\t\t\texe, err := os.Executable()\n   147→\t\t\tif err == nil {\n   148→\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   149→\t\t\t} else {\n   150→\t\t\t\tagentPath = \"cloche-agent\"\n   151→\t\t\t}\n   152→\t\t}\n   153→\t\treturn local.NewRuntime(agentPath), nil\n   154→\tcase \"docker\":\n   155→\t\treturn docker.NewRuntime()\n   156→\tdefault:\n   157→\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   158→\t}\n   159→}\n   160→\n   161→func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   162→\t// Load config from working directory (daemon-level defaults)\n   163→\tcfg, err := config.Load(\".\")\n   164→\tif err != nil || !cfg.Evolution.Enabled {\n   165→\t\treturn nil\n   166→\t}\n   167→\n   168→\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   169→\tif llmCmd == \"\" {\n   170→\t\treturn nil\n   171→\t}\n   172→\n   173→\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   174→\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   175→\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   176→\t\t\t// Load per-project config for confidence threshold\n   177→\t\t\tprojCfg, err := config.Load(projectDir)\n   178→\t\t\tif err != nil {\n   179→\t\t\t\tprojCfg = cfg // fall back to daemon config\n   180→\t\t\t}\n   181→\n   182→\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   183→\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   184→\t\t\t\tProjectDir:    projectDir,\n   185→\t\t\t\tWorkflowName:  workflowName,\n   186→\t\t\t\tLLM:           llm,\n   187→\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   188→\t\t\t})\n   189→\n   190→\t\t\tctx := context.Background()\n   191→\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   192→\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   193→\t\t\t}\n   194→\t\t},\n   195→\t})\n   196→\n   197→\treturn trigger\n   198→}\n   199→\n   200→func listen(addr string) (net.Listener, error) {\n   201→\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   202→\t\tsockPath := addr[7:]\n   203→\t\tos.Remove(sockPath)\n   204→\t\treturn net.Listen(\"unix\", sockPath)\n   205→\t}\n   206→\treturn net.Listen(\"tcp\", addr)\n   207→}\n   208→\n   209→// autoRunActiveProjects scans known projects for active = true in their config,\n   210→// parses .cloche/host.cloche and executes the full host workflow step by step.\n   211→func autoRunActiveProjects(store ports.RunStore, srv *adaptgrpc.ClocheServer) {\n   212→\tctx := context.Background()\n   213→\tprojects, err := store.ListProjects(ctx)\n   214→\tif err != nil {\n   215→\t\tfmt.Fprintf(os.Stderr, \"startup: failed to list projects: %v\\n\", err)\n   216→\t\treturn\n   217→\t}\n   218→\n   219→\tfor _, projectDir := range projects {\n   220→\t\tcfg, err := config.Load(projectDir)\n   221→\t\tif err != nil || !cfg.Active {\n   222→\t\t\tcontinue\n   223→\t\t}\n   224→\n   225→\t\t// Verify host.cloche exists before launching\n   226→\t\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   227→\t\tif _, err := os.Stat(hostPath); err != nil {\n   228→\t\t\tfmt.Fprintf(os.Stderr, \"startup: skipping active project %s: %v\\n\", projectDir, err)\n   229→\t\t\tcontinue\n   230→\t\t}\n   231→\n   232→\t\tfmt.Fprintf(os.Stderr, \"startup: auto-running host workflow for active project %s\\n\", projectDir)\n   233→\t\tgo func(projDir string) {\n   234→\t\t\trunner := &hostpkg.Runner{\n   235→\t\t\t\tDispatcher: srv,\n   236→\t\t\t\tStore:      store,\n   237→\t\t\t}\n   238→\t\t\tresult, err := runner.Run(context.Background(), projDir)\n   239→\t\t\tif err != nil {\n   240→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow failed for %s: %v\\n\", projDir, err)\n   241→\t\t\t} else {\n   242→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow completed for %s: %s (run %s)\\n\", projDir, result.State, result.RunID)\n   243→\t\t\t}\n   244→\t\t}(projectDir)\n   245→\t}\n   246→}\n   247→\n   248→// envOrConfig returns the env var value if set, otherwise the config file\n   249→// value if non-empty, otherwise the fallback default.\n   250→func envOrConfig(envKey, configVal, fallback string) string {\n   251→\tif v := os.Getenv(envKey); v != \"\" {\n   252→\t\treturn v\n   253→\t}\n   254→\tif configVal != \"\" {\n   255→\t\treturn configVal\n   256→\t}\n   257→\treturn fallback\n   258→}\n   259→"}]},"parent_tool_use_id":"toolu_01Y1PzzwgtqcjET4zTfJf9wf","session_id":"499cc276-44bb-4bfe-9549-2f88e2009a57","uuid":"81bd8fa2-4de9-4f7e-a2bc-2e6f815b6b24"}
