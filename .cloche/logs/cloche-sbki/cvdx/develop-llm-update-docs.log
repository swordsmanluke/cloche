{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WMWYLBLcdTDZVJuMmEk42S","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"errors\"\n     7→\t\"fmt\"\n     8→\t\"io\"\n     9→\t\"net/http\"\n    10→\t\"os\"\n    11→\t\"os/exec\"\n    12→\t\"path/filepath\"\n    13→\t\"strconv\"\n    14→\t\"strings\"\n    15→\t\"text/tabwriter\"\n    16→\t\"time\"\n    17→\n    18→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    19→\t\"github.com/cloche-dev/cloche/internal/config\"\n    20→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    21→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    22→\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    23→\t\"github.com/cloche-dev/cloche/internal/version\"\n    24→\t\"google.golang.org/grpc\"\n    25→\t\"google.golang.org/grpc/credentials/insecure\"\n    26→\t\"google.golang.org/grpc/metadata\"\n    27→)\n    28→\n    29→func main() {\n    30→\tif len(os.Args) < 2 {\n    31→\t\tprintTopLevelHelp()\n    32→\t\tos.Exit(1)\n    33→\t}\n    34→\n    35→\t// Handle version flags before anything else\n    36→\tif os.Args[1] == \"-v\" || os.Args[1] == \"--version\" {\n    37→\t\tcmdVersion()\n    38→\t\treturn\n    39→\t}\n    40→\n    41→\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n    42→\tswitch os.Args[1] {\n    43→\tcase \"help\":\n    44→\t\tprintHelp(os.Args[2:])\n    45→\t\treturn\n    46→\tcase \"--help\", \"-h\":\n    47→\t\tprintTopLevelHelp()\n    48→\t\treturn\n    49→\t}\n    50→\n    51→\t// Commands that don't need a daemon connection\n    52→\tswitch os.Args[1] {\n    53→\tcase \"init\":\n    54→\t\tif hasHelpFlag(os.Args[2:]) {\n    55→\t\t\tprintSubcommandHelp(\"init\")\n    56→\t\t\treturn\n    57→\t\t}\n    58→\t\tcmdInit(os.Args[2:])\n    59→\t\treturn\n    60→\tcase \"health\":\n    61→\t\tif hasHelpFlag(os.Args[2:]) {\n    62→\t\t\tprintSubcommandHelp(\"health\")\n    63→\t\t\treturn\n    64→\t\t}\n    65→\t\tcmdHealth(os.Args[2:])\n    66→\t\treturn\n    67→\tcase \"get\":\n    68→\t\tif hasHelpFlag(os.Args[2:]) {\n    69→\t\t\tprintSubcommandHelp(\"get\")\n    70→\t\t\treturn\n    71→\t\t}\n    72→\t\tcmdGet(os.Args[2:])\n    73→\t\treturn\n    74→\tcase \"set\":\n    75→\t\tif hasHelpFlag(os.Args[2:]) {\n    76→\t\t\tprintSubcommandHelp(\"set\")\n    77→\t\t\treturn\n    78→\t\t}\n    79→\t\tcmdSet(os.Args[2:])\n    80→\t\treturn\n    81→\tcase \"tasks\":\n    82→\t\tif hasHelpFlag(os.Args[2:]) {\n    83→\t\t\tprintSubcommandHelp(\"tasks\")\n    84→\t\t\treturn\n    85→\t\t}\n    86→\t\tcmdTasks(os.Args[2:])\n    87→\t\treturn\n    88→\tcase \"workflow\":\n    89→\t\tif hasHelpFlag(os.Args[2:]) {\n    90→\t\t\tprintSubcommandHelp(\"workflow\")\n    91→\t\t\treturn\n    92→\t\t}\n    93→\t\tcmdWorkflow(os.Args[2:])\n    94→\t\treturn\n    95→\tcase \"project\":\n    96→\t\tif hasHelpFlag(os.Args[2:]) {\n    97→\t\t\tprintSubcommandHelp(\"project\")\n    98→\t\t\treturn\n    99→\t\t}\n   100→\t\tcmdProject(os.Args[2:])\n   101→\t\treturn\n   102→\tcase \"validate\":\n   103→\t\tif hasHelpFlag(os.Args[2:]) {\n   104→\t\t\tprintSubcommandHelp(\"validate\")\n   105→\t\t\treturn\n   106→\t\t}\n   107→\t\tcmdValidate(os.Args[2:])\n   108→\t\treturn\n   109→\t}\n   110→\n   111→\t// Handle --help for daemon commands before connecting\n   112→\tdaemonCmds := map[string]bool{\n   113→\t\t\"run\": true, \"resume\": true, \"status\": true, \"logs\": true, \"poll\": true,\n   114→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n   115→\t}\n   116→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n   117→\t\tprintSubcommandHelp(os.Args[1])\n   118→\t\treturn\n   119→\t}\n   120→\n   121→\t// Commands that need a daemon connection\n   122→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   123→\tif addr == \"\" {\n   124→\t\taddr = config.DefaultSocketAddr()\n   125→\t}\n   126→\n   127→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   128→\tif err != nil {\n   129→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   130→\t\tos.Exit(1)\n   131→\t}\n   132→\tdefer conn.Close()\n   133→\n   134→\tclient := pb.NewClocheServiceClient(conn)\n   135→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   136→\tdefer cancel()\n   137→\n   138→\tswitch os.Args[1] {\n   139→\tcase \"run\":\n   140→\t\tcmdRun(ctx, client, os.Args[2:])\n   141→\tcase \"resume\":\n   142→\t\tcmdResume(ctx, conn, os.Args[2:])\n   143→\tcase \"status\":\n   144→\t\tcmdStatus(ctx, client, os.Args[2:])\n   145→\tcase \"logs\":\n   146→\t\tcmdLogs(client, os.Args[2:])\n   147→\tcase \"poll\":\n   148→\t\tcmdPoll(client, os.Args[2:])\n   149→\tcase \"list\":\n   150→\t\tcmdList(ctx, client, os.Args[2:])\n   151→\tcase \"stop\":\n   152→\t\tcmdStop(ctx, client, os.Args[2:])\n   153→\tcase \"delete\":\n   154→\t\tcmdDelete(ctx, client, os.Args[2:])\n   155→\tcase \"loop\":\n   156→\t\tcmdLoop(ctx, client, os.Args[2:])\n   157→\tcase \"shutdown\":\n   158→\t\tcmdShutdown(ctx, client, os.Args[2:])\n   159→\tdefault:\n   160→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   161→\t\tprintTopLevelHelp()\n   162→\t\tos.Exit(1)\n   163→\t}\n   164→}\n   165→\n   166→\n   167→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   168→\tvar workflow, prompt, title, issueID string\n   169→\tvar keepContainer bool\n   170→\n   171→\tfor i := 0; i < len(args); i++ {\n   172→\t\tswitch args[i] {\n   173→\t\tcase \"--workflow\":\n   174→\t\t\tif i+1 < len(args) {\n   175→\t\t\t\ti++\n   176→\t\t\t\tworkflow = args[i]\n   177→\t\t\t}\n   178→\t\tcase \"--prompt\", \"-p\":\n   179→\t\t\tif i+1 < len(args) {\n   180→\t\t\t\ti++\n   181→\t\t\t\tprompt = args[i]\n   182→\t\t\t}\n   183→\t\tcase \"--title\":\n   184→\t\t\tif i+1 < len(args) {\n   185→\t\t\t\ti++\n   186→\t\t\t\ttitle = args[i]\n   187→\t\t\t}\n   188→\t\tcase \"--issue\", \"-i\":\n   189→\t\t\tif i+1 < len(args) {\n   190→\t\t\t\ti++\n   191→\t\t\t\tissueID = args[i]\n   192→\t\t\t}\n   193→\t\tcase \"--keep-container\":\n   194→\t\t\tkeepContainer = true\n   195→\t\tdefault:\n   196→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   197→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   198→\t\t\t\tworkflow = args[i]\n   199→\t\t\t}\n   200→\t\t}\n   201→\t}\n   202→\n   203→\tif workflow == \"\" {\n   204→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"] [--issue ID]\\n\")\n   205→\t\tos.Exit(1)\n   206→\t}\n   207→\n   208→\tcwd, _ := os.Getwd()\n   209→\n   210→\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n   211→\t// Try loading from any .cloche file; only extract image for container workflows.\n   212→\tvar image string\n   213→\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n   214→\t\timage = wf.Config[\"container.image\"]\n   215→\t}\n   216→\n   217→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   218→\t\tWorkflowName:  workflow,\n   219→\t\tProjectDir:    cwd,\n   220→\t\tImage:         image,\n   221→\t\tPrompt:        prompt,\n   222→\t\tKeepContainer: keepContainer,\n   223→\t\tTitle:         title,\n   224→\t\tIssueId:       issueID,\n   225→\t})\n   226→\tif err != nil {\n   227→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   228→\t\tos.Exit(1)\n   229→\t}\n   230→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   231→}\n   232→\n   233→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   234→\tif len(args) < 1 {\n   235→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   236→\t\tos.Exit(1)\n   237→\t}\n   238→\n   239→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   240→\tif err != nil {\n   241→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   242→\t\tos.Exit(1)\n   243→\t}\n   244→\n   245→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   246→\tif resp.Title != \"\" {\n   247→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   248→\t}\n   249→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   250→\tif resp.IsHost {\n   251→\t\tfmt.Printf(\"Type:      host\\n\")\n   252→\t} else {\n   253→\t\tfmt.Printf(\"Type:      container\\n\")\n   254→\t}\n   255→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   256→\tif resp.ContainerId != \"\" {\n   257→\t\tcid := resp.ContainerId\n   258→\t\tif len(cid) > 12 {\n   259→\t\t\tcid = cid[:12]\n   260→\t\t}\n   261→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   262→\t}\n   263→\tif resp.ErrorMessage != \"\" {\n   264→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   265→\t}\n   266→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   267→\tfor _, exec := range resp.StepExecutions {\n   268→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   269→\t}\n   270→}\n   271→\n   272→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   273→\tvar all bool\n   274→\tvar projectDir, stateFilter, issueFilter string\n   275→\tvar limit int32\n   276→\n   277→\tfor i := 0; i < len(args); i++ {\n   278→\t\tswitch args[i] {\n   279→\t\tcase \"--all\":\n   280→\t\t\tall = true\n   281→\t\tcase \"--project\", \"-p\":\n   282→\t\t\tif i+1 < len(args) {\n   283→\t\t\t\ti++\n   284→\t\t\t\tprojectDir = args[i]\n   285→\t\t\t}\n   286→\t\tcase \"--state\", \"-s\":\n   287→\t\t\tif i+1 < len(args) {\n   288→\t\t\t\ti++\n   289→\t\t\t\tstateFilter = args[i]\n   290→\t\t\t}\n   291→\t\tcase \"--limit\", \"-n\":\n   292→\t\t\tif i+1 < len(args) {\n   293→\t\t\t\ti++\n   294→\t\t\t\tn, err := strconv.Atoi(args[i])\n   295→\t\t\t\tif err != nil {\n   296→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   297→\t\t\t\t\tos.Exit(1)\n   298→\t\t\t\t}\n   299→\t\t\t\tlimit = int32(n)\n   300→\t\t\t}\n   301→\t\tcase \"--issue\", \"-i\":\n   302→\t\t\tif i+1 < len(args) {\n   303→\t\t\t\ti++\n   304→\t\t\t\tissueFilter = args[i]\n   305→\t\t\t}\n   306→\t\t}\n   307→\t}\n   308→\n   309→\treq := &pb.ListRunsRequest{\n   310→\t\tState:  stateFilter,\n   311→\t\tLimit:  limit,\n   312→\t\tTaskId: issueFilter,\n   313→\t}\n   314→\tif projectDir != \"\" {\n   315→\t\treq.ProjectDir = projectDir\n   316→\t} else if all {\n   317→\t\treq.All = true\n   318→\t} else {\n   319→\t\t// Default: filter to current project\n   320→\t\tcwd, _ := os.Getwd()\n   321→\t\treq.ProjectDir = cwd\n   322→\t}\n   323→\n   324→\tresp, err := client.ListRuns(ctx, req)\n   325→\tif err != nil {\n   326→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   327→\t\tos.Exit(1)\n   328→\t}\n   329→\n   330→\tif len(resp.Runs) == 0 {\n   331→\t\tfmt.Println(\"No runs found.\")\n   332→\t\treturn\n   333→\t}\n   334→\n   335→\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n   336→\tfmt.Fprintln(w, \"RUN ID\\tWORKFLOW\\tSTATE\\tTYPE\\tTASK ID\\tTITLE\\tCONTAINER\\tERROR\")\n   337→\tfor _, run := range resp.Runs {\n   338→\t\trunType := \"container\"\n   339→\t\tif run.IsHost {\n   340→\t\t\trunType = \"host\"\n   341→\t\t}\n   342→\t\ttitle := run.Title\n   343→\t\tif len(title) > 40 {\n   344→\t\t\ttitle = title[:37] + \"...\"\n   345→\t\t}\n   346→\t\terrMsg := run.ErrorMessage\n   347→\t\tif len(errMsg) > 60 {\n   348→\t\t\terrMsg = errMsg[:57] + \"...\"\n   349→\t\t}\n   350→\t\tfmt.Fprintf(w, \"%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\n\",\n   351→\t\t\trun.RunId, run.WorkflowName, run.State, runType,\n   352→\t\t\trun.TaskId, title, run.ContainerId, errMsg)\n   353→\t}\n   354→\tw.Flush()\n   355→}\n   356→\n   357→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   358→\tif len(args) < 1 {\n   359→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n   360→\t\tos.Exit(1)\n   361→\t}\n   362→\n   363→\tvar stepFilter, typeFilter string\n   364→\tvar follow bool\n   365→\tvar limit int\n   366→\trunID := args[0]\n   367→\n   368→\tfor i := 1; i < len(args); i++ {\n   369→\t\tswitch args[i] {\n   370→\t\tcase \"--step\", \"-s\":\n   371→\t\t\tif i+1 < len(args) {\n   372→\t\t\t\ti++\n   373→\t\t\t\tstepFilter = args[i]\n   374→\t\t\t}\n   375→\t\tcase \"--type\":\n   376→\t\t\tif i+1 < len(args) {\n   377→\t\t\t\ti++\n   378→\t\t\t\ttypeFilter = args[i]\n   379→\t\t\t}\n   380→\t\tcase \"--follow\", \"-f\":\n   381→\t\t\tfollow = true\n   382→\t\tcase \"--limit\", \"-l\":\n   383→\t\t\tif i+1 < len(args) {\n   384→\t\t\t\ti++\n   385→\t\t\t\tn, err := strconv.Atoi(args[i])\n   386→\t\t\t\tif err != nil || n < 0 {\n   387→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n   388→\t\t\t\t\tos.Exit(1)\n   389→\t\t\t\t}\n   390→\t\t\t\tlimit = n\n   391→\t\t\t}\n   392→\t\t}\n   393→\t}\n   394→\n   395→\t// Use background context — log output can be large and follow mode blocks.\n   396→\tctx := context.Background()\n   397→\tvar mdPairs []string\n   398→\tif follow {\n   399→\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n   400→\t}\n   401→\tif limit > 0 {\n   402→\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n   403→\t}\n   404→\tif len(mdPairs) > 0 {\n   405→\t\tmd := metadata.Pairs(mdPairs...)\n   406→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   407→\t}\n   408→\n   409→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   410→\t\tRunId:    runID,\n   411→\t\tStepName: stepFilter,\n   412→\t\tLogType:  typeFilter,\n   413→\t})\n   414→\tif err != nil {\n   415→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   416→\t\tos.Exit(1)\n   417→\t}\n   418→\n   419→\tfor {\n   420→\t\tentry, err := stream.Recv()\n   421→\t\tif err != nil {\n   422→\t\t\tif errors.Is(err, io.EOF) {\n   423→\t\t\t\tbreak\n   424→\t\t\t}\n   425→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   426→\t\t\tos.Exit(1)\n   427→\t\t}\n   428→\n   429→\t\tswitch entry.Type {\n   430→\t\tcase \"step_started\":\n   431→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   432→\t\t\tif entry.Message != \"\" {\n   433→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   434→\t\t\t}\n   435→\t\tcase \"step_completed\":\n   436→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   437→\t\t\tif entry.Message != \"\" {\n   438→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   439→\t\t\t}\n   440→\t\tcase \"run_completed\":\n   441→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   442→\t\t\tif entry.Message != \"\" {\n   443→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   444→\t\t\t}\n   445→\t\tcase \"full_log\":\n   446→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   447→\t\tcase \"log\":\n   448→\t\t\t// Live-streamed log line from an active run.\n   449→\t\t\tfmt.Println(entry.Message)\n   450→\t\tdefault:\n   451→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   452→\t\t\tif entry.StepName != \"\" {\n   453→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   454→\t\t\t}\n   455→\t\t\tif entry.Message != \"\" {\n   456→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   457→\t\t\t}\n   458→\t\t}\n   459→\t}\n   460→}\n   461→\n   462→func cmdResume(ctx context.Context, conn *grpc.ClientConn, args []string) {\n   463→\tif len(args) < 1 {\n   464→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche resume <run-id> [step-name]\\n\")\n   465→\t\tos.Exit(1)\n   466→\t}\n   467→\n   468→\treq := &pb.ResumeRunRequest{RunId: args[0]}\n   469→\tif len(args) >= 2 {\n   470→\t\treq.StepName = args[1]\n   471→\t}\n   472→\n   473→\tresp, err := pb.InvokeResumeRun(conn, ctx, req)\n   474→\tif err != nil {\n   475→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   476→\t\tos.Exit(1)\n   477→\t}\n   478→\tfmt.Printf(\"Resumed run: %s\\n\", resp.RunId)\n   479→}\n   480→\n   481→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   482→\tif len(args) < 1 {\n   483→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   484→\t\tos.Exit(1)\n   485→\t}\n   486→\n   487→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   488→\tif err != nil {\n   489→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   490→\t\tos.Exit(1)\n   491→\t}\n   492→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   493→}\n   494→\n   495→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   496→\tif len(args) < 1 {\n   497→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   498→\t\tos.Exit(1)\n   499→\t}\n   500→\n   501→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   502→\tif err != nil {\n   503→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   504→\t\tos.Exit(1)\n   505→\t}\n   506→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   507→}\n   508→\n   509→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   510→\tcwd, _ := os.Getwd()\n   511→\n   512→\t// Check for \"stop\" subcommand\n   513→\tif len(args) > 0 && args[0] == \"stop\" {\n   514→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   515→\t\tif err != nil {\n   516→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   517→\t\t\tos.Exit(1)\n   518→\t\t}\n   519→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   520→\t\treturn\n   521→\t}\n   522→\n   523→\t// Check for \"resume\" subcommand\n   524→\tif len(args) > 0 && args[0] == \"resume\" {\n   525→\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n   526→\t\tif err != nil {\n   527→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   528→\t\t\tos.Exit(1)\n   529→\t\t}\n   530→\t\tfmt.Println(\"Orchestration loop resumed.\")\n   531→\t\treturn\n   532→\t}\n   533→\n   534→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   535→\tvar maxConcurrent int32\n   536→\tfor i := 0; i < len(args); i++ {\n   537→\t\tswitch args[i] {\n   538→\t\tcase \"--max\":\n   539→\t\t\tif i+1 < len(args) {\n   540→\t\t\t\ti++\n   541→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   542→\t\t\t\tif n != 1 || err != nil {\n   543→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   544→\t\t\t\t\tos.Exit(1)\n   545→\t\t\t\t}\n   546→\t\t\t}\n   547→\t\t}\n   548→\t}\n   549→\n   550→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   551→\t\tProjectDir:    cwd,\n   552→\t\tMaxConcurrent: maxConcurrent,\n   553→\t})\n   554→\tif err != nil {\n   555→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   556→\t\tos.Exit(1)\n   557→\t}\n   558→\tif maxConcurrent > 0 {\n   559→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   560→\t} else {\n   561→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   562→\t}\n   563→}\n   564→\n   565→func cmdTasks(args []string) {\n   566→\t// Determine HTTP address from env\n   567→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   568→\tif httpAddr == \"\" {\n   569→\t\thttpAddr = \"localhost:8080\"\n   570→\t}\n   571→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   572→\n   573→\t// Determine project label from --project flag or current directory\n   574→\tprojectDir := \"\"\n   575→\tfor i := 0; i < len(args); i++ {\n   576→\t\tswitch args[i] {\n   577→\t\tcase \"--project\":\n   578→\t\t\tif i+1 < len(args) {\n   579→\t\t\t\ti++\n   580→\t\t\t\tprojectDir = args[i]\n   581→\t\t\t}\n   582→\t\t}\n   583→\t}\n   584→\n   585→\tif projectDir == \"\" {\n   586→\t\tcwd, _ := os.Getwd()\n   587→\t\tprojectDir = filepath.Base(cwd)\n   588→\t}\n   589→\n   590→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   591→\tresp, err := http.Get(tasksURL)\n   592→\tif err != nil {\n   593→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   594→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   595→\t\tos.Exit(1)\n   596→\t}\n   597→\tdefer resp.Body.Close()\n   598→\n   599→\tif resp.StatusCode != 200 {\n   600→\t\tbody, _ := io.ReadAll(resp.Body)\n   601→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   602→\t\tos.Exit(1)\n   603→\t}\n   604→\n   605→\ttype taskEntry struct {\n   606→\t\tID          string `json:\"id\"`\n   607→\t\tStatus      string `json:\"status\"`\n   608→\t\tTitle       string `json:\"title\"`\n   609→\t\tDescription string `json:\"description\"`\n   610→\t\tAssigned    bool   `json:\"assigned\"`\n   611→\t\tAssignedAt  string `json:\"assigned_at\"`\n   612→\t\tRunID       string `json:\"run_id\"`\n   613→\t}\n   614→\n   615→\tvar tasks []taskEntry\n   616→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   617→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   618→\t\tos.Exit(1)\n   619→\t}\n   620→\n   621→\tif len(tasks) == 0 {\n   622→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   623→\t\treturn\n   624→\t}\n   625→\n   626→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   627→\tfor _, t := range tasks {\n   628→\t\tstatus := t.Status\n   629→\t\tif status == \"\" {\n   630→\t\t\tstatus = \"open\"\n   631→\t\t}\n   632→\t\tassigned := \"-\"\n   633→\t\tif t.Assigned {\n   634→\t\t\tassigned = \"yes\"\n   635→\t\t}\n   636→\t\trunID := \"\"\n   637→\t\tif t.RunID != \"\" {\n   638→\t\t\trunID = t.RunID\n   639→\t\t\tif len(runID) > 30 {\n   640→\t\t\t\trunID = runID[:27] + \"...\"\n   641→\t\t\t}\n   642→\t\t}\n   643→\t\ttitle := t.Title\n   644→\t\tif len(title) > 40 {\n   645→\t\t\ttitle = title[:37] + \"...\"\n   646→\t\t}\n   647→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   648→\t}\n   649→}\n   650→\n   651→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   652→\tvar force bool\n   653→\tfor _, a := range args {\n   654→\t\tif a == \"-f\" || a == \"--force\" {\n   655→\t\t\tforce = true\n   656→\t\t}\n   657→\t}\n   658→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n   659→\tif err != nil {\n   660→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   661→\t\tos.Exit(1)\n   662→\t}\n   663→\tfmt.Println(\"Daemon shutting down.\")\n   664→}\n   665→\n   666→// resolveRunContext returns the project directory and run ID for context\n   667→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   668→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   669→func resolveRunContext() (projectDir, runID string, err error) {\n   670→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   671→\tif runID == \"\" {\n   672→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   673→\t}\n   674→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   675→\tif projectDir == \"\" {\n   676→\t\tprojectDir, err = os.Getwd()\n   677→\t\tif err != nil {\n   678→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   679→\t\t}\n   680→\t}\n   681→\treturn projectDir, runID, nil\n   682→}\n   683→\n   684→func cmdGet(args []string) {\n   685→\tif len(args) < 1 {\n   686→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   687→\t\tos.Exit(1)\n   688→\t}\n   689→\n   690→\tprojectDir, runID, err := resolveRunContext()\n   691→\tif err != nil {\n   692→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   693→\t\tos.Exit(1)\n   694→\t}\n   695→\n   696→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   697→\tif err != nil {\n   698→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   699→\t\tos.Exit(1)\n   700→\t}\n   701→\tif !ok {\n   702→\t\tos.Exit(1)\n   703→\t}\n   704→\tfmt.Println(val)\n   705→}\n   706→\n   707→func cmdSet(args []string) {\n   708→\tif len(args) < 2 {\n   709→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   710→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   711→\t\tos.Exit(1)\n   712→\t}\n   713→\n   714→\tprojectDir, runID, err := resolveRunContext()\n   715→\tif err != nil {\n   716→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   717→\t\tos.Exit(1)\n   718→\t}\n   719→\n   720→\tvalue := args[1]\n   721→\tif value == \"-\" {\n   722→\t\tdata, err := io.ReadAll(os.Stdin)\n   723→\t\tif err != nil {\n   724→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   725→\t\t\tos.Exit(1)\n   726→\t\t}\n   727→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   728→\t}\n   729→\n   730→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   731→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   732→\t\tos.Exit(1)\n   733→\t}\n   734→}\n   735→\n   736→func cmdVersion() {\n   737→\tcliVersion := version.Version()\n   738→\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   739→\n   740→\t// Try to get daemon version via gRPC\n   741→\tdaemonVersion := \"<unavailable>\"\n   742→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   743→\tif addr == \"\" {\n   744→\t\taddr = config.DefaultSocketAddr()\n   745→\t}\n   746→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   747→\tif err == nil {\n   748→\t\tdefer conn.Close()\n   749→\t\tclient := pb.NewClocheServiceClient(conn)\n   750→\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   751→\t\tdefer cancel()\n   752→\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   753→\t\tif err == nil {\n   754→\t\t\tdaemonVersion = resp.Version\n   755→\t\t}\n   756→\t}\n   757→\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   758→\n   759→\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   760→\tagentVersion := \"<unavailable>\"\n   761→\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   762→\tif image == \"\" {\n   763→\t\timage = \"cloche-agent:latest\"\n   764→\t}\n   765→\tout, err := exec.CommandContext(\n   766→\t\tcontext.Background(),\n   767→\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   768→\t).Output()\n   769→\tif err == nil {\n   770→\t\tagentVersion = strings.TrimSpace(string(out))\n   771→\t\t// Strip \"cloche-agent \" prefix if present\n   772→\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n   773→\t}\n   774→\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n   775→\n   776→\t// Warn about version mismatches\n   777→\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n   778→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n   779→\t}\n   780→\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n   781→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n   782→\t}\n   783→}\n   784→"}]},"parent_tool_use_id":"toolu_01Y1PzzwgtqcjET4zTfJf9wf","session_id":"499cc276-44bb-4bfe-9549-2f88e2009a57","uuid":"cb5e8304-e7b6-4232-a946-458ea9f82e86"}
