{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017aYMRAe35VnMJP6xETv64X","type":"tool_result","content":"     1→package domain\n     2→\n     3→// ResumeConfig describes how to resume a failed workflow run.\n     4→type ResumeConfig struct {\n     5→\t// FromStep is the step to resume from. If empty, resume from the first failed step.\n     6→\tFromStep string `json:\"from_step,omitempty\"`\n     7→\n     8→\t// PriorResults maps step names to their results from the previous run.\n     9→\t// Steps in this map are skipped (their result is replayed) instead of re-executed.\n    10→\tPriorResults map[string]string `json:\"prior_results\"`\n    11→}\n    12→\n    13→// FirstFailedStep returns the name of the first step that failed or errored\n    14→// in the run's step executions. Returns empty string if no failed step is found.\n    15→func (r *Run) FirstFailedStep() string {\n    16→\tfor _, se := range r.StepExecutions {\n    17→\t\tif se.Result == \"fail\" || se.Result == \"error\" || se.Result == \"\" {\n    18→\t\t\treturn se.StepName\n    19→\t\t}\n    20→\t}\n    21→\treturn \"\"\n    22→}\n    23→\n    24→// SucceededStepsBefore returns a map of step name → result for all steps that\n    25→// completed successfully before the given step in the execution order.\n    26→func (r *Run) SucceededStepsBefore(targetStep string) map[string]string {\n    27→\tresults := make(map[string]string)\n    28→\tfor _, se := range r.StepExecutions {\n    29→\t\tif se.StepName == targetStep {\n    30→\t\t\tbreak\n    31→\t\t}\n    32→\t\tif se.Result != \"\" && se.Result != \"fail\" && se.Result != \"error\" {\n    33→\t\t\tresults[se.StepName] = se.Result\n    34→\t\t}\n    35→\t}\n    36→\treturn results\n    37→}\n    38→"}]},"parent_tool_use_id":"toolu_01Y1PzzwgtqcjET4zTfJf9wf","session_id":"499cc276-44bb-4bfe-9549-2f88e2009a57","uuid":"1d99cc92-9982-4ac4-a4af-c263de7c2402"}
