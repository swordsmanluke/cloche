{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XTke3oFZ3FRVSnRxf63AyT","type":"tool_result","content":"     1→package engine\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\n     6→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     7→)\n     8→\n     9→// ResumeExecutor wraps a StepExecutor to support resume behavior.\n    10→// Steps listed in PriorResults are skipped (their cached result is returned).\n    11→// The ResumeStep gets executed with IsResume=true set in the step's Config.\n    12→type ResumeExecutor struct {\n    13→\tInner        StepExecutor\n    14→\tPriorResults map[string]string // step name → result to replay\n    15→\tResumeStep   string            // the step being resumed\n    16→}\n    17→\n    18→func (r *ResumeExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    19→\t// If this step has a prior result, return it immediately (skip execution)\n    20→\tif result, ok := r.PriorResults[step.Name]; ok {\n    21→\t\treturn result, nil\n    22→\t}\n    23→\n    24→\t// If this is the resume step, mark it in the step config so adapters\n    25→\t// can handle it specially (e.g. prompt adapter uses -c for conversation resume)\n    26→\tif step.Name == r.ResumeStep {\n    27→\t\tif step.Config == nil {\n    28→\t\t\tstep.Config = make(map[string]string)\n    29→\t\t}\n    30→\t\tstep.Config[\"_resume\"] = \"true\"\n    31→\t}\n    32→\n    33→\treturn r.Inner.Execute(ctx, step)\n    34→}\n    35→"}]},"parent_tool_use_id":"toolu_01Y1PzzwgtqcjET4zTfJf9wf","session_id":"499cc276-44bb-4bfe-9549-2f88e2009a57","uuid":"ea035fe6-8a85-4482-83c7-09b644326be0"}
