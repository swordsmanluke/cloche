7→\tStreams:  []grpc.StreamDesc{},\n    88→\tMetadata: \"resume.proto\",\n    89→}\n    90→"}]},"parent_tool_use_id":"toolu_01Y1PzzwgtqcjET4zTfJf9wf","session_id":"499cc276-44bb-4bfe-9549-2f88e2009a57","uuid":"6942976f-b573-4fe6-bbf2-bb8b14aad338"}
