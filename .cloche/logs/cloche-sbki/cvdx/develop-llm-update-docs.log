{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GfVBJHJf7vqsiyUmfM3xhw","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"log\"\n     8→\t\"os\"\n     9→\t\"os/exec\"\n    10→\t\"path/filepath\"\n    11→\n    12→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/host\"\n    15→)\n    16→\n    17→// ResumeRun re-attempts a failed workflow run from a specified step (or the\n    18→// first failed step if step_name is empty).\n    19→func (s *ClocheServer) ResumeRun(ctx context.Context, req *pb.ResumeRunRequest) (*pb.ResumeRunResponse, error) {\n    20→\t// 1. Load the run\n    21→\trun, err := s.store.GetRun(ctx, req.RunId)\n    22→\tif err != nil {\n    23→\t\treturn nil, fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n    24→\t}\n    25→\n    26→\t// 2. Verify the run is in a failed state\n    27→\tif run.State != domain.RunStateFailed {\n    28→\t\treturn nil, fmt.Errorf(\"run %q is in state %q, not failed\", req.RunId, run.State)\n    29→\t}\n    30→\n    31→\t// 3. Load step executions from captures store\n    32→\tvar stepExecutions []*domain.StepExecution\n    33→\tif s.captures != nil {\n    34→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n    35→\t\tif err == nil {\n    36→\t\t\tstepExecutions = captures\n    37→\t\t}\n    38→\t}\n    39→\tif stepExecutions == nil {\n    40→\t\tstepExecutions = run.StepExecutions\n    41→\t}\n    42→\n    43→\t// 4. Determine the resume step\n    44→\tresumeStep := req.StepName\n    45→\tif resumeStep == \"\" {\n    46→\t\tresumeStep = firstFailedStepFromCaptures(stepExecutions)\n    47→\t\tif resumeStep == \"\" {\n    48→\t\t\treturn nil, fmt.Errorf(\"run %q has no failed step to resume from\", req.RunId)\n    49→\t\t}\n    50→\t}\n    51→\n    52→\t// 5. Build prior results map (all steps that succeeded before the resume step)\n    53→\tpriorResults := succeededStepsBefore(stepExecutions, resumeStep)\n    54→\n    55→\tresumeCfg := &domain.ResumeConfig{\n    56→\t\tFromStep:     resumeStep,\n    57→\t\tPriorResults: priorResults,\n    58→\t}\n    59→\n    60→\t// 6. Dispatch based on run type\n    61→\tif run.IsHost {\n    62→\t\treturn s.resumeHostRun(ctx, run, resumeCfg)\n    63→\t}\n    64→\treturn s.resumeContainerRun(ctx, run, resumeCfg)\n    65→}\n    66→\n    67→// resumeContainerRun resumes a failed container workflow run.\n    68→func (s *ClocheServer) resumeContainerRun(ctx context.Context, run *domain.Run, resumeCfg *domain.ResumeConfig) (*pb.ResumeRunResponse, error) {\n    69→\tif s.container == nil {\n    70→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    71→\t}\n    72→\n    73→\tcontainerID := run.ContainerID\n    74→\tif containerID == \"\" {\n    75→\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", run.ID)\n    76→\t}\n    77→\n    78→\t// Verify the container still exists\n    79→\tif _, err := s.container.Inspect(ctx, containerID); err != nil {\n    80→\t\treturn nil, fmt.Errorf(\"container %s not found (may have been cleaned up): %w\", containerID, err)\n    81→\t}\n    82→\n    83→\t// Write the resume config into the stopped container\n    84→\tresumeJSON, err := json.Marshal(resumeCfg)\n    85→\tif err != nil {\n    86→\t\treturn nil, fmt.Errorf(\"marshaling resume config: %w\", err)\n    87→\t}\n    88→\n    89→\ttmpFile, err := os.CreateTemp(\"\", \"cloche-resume-*.json\")\n    90→\tif err != nil {\n    91→\t\treturn nil, fmt.Errorf(\"creating temp file: %w\", err)\n    92→\t}\n    93→\ttmpPath := tmpFile.Name()\n    94→\tdefer os.Remove(tmpPath)\n    95→\n    96→\tif _, err := tmpFile.Write(resumeJSON); err != nil {\n    97→\t\ttmpFile.Close()\n    98→\t\treturn nil, fmt.Errorf(\"writing resume config: %w\", err)\n    99→\t}\n   100→\ttmpFile.Close()\n   101→\n   102→\t// Copy resume.json into the container's workspace\n   103→\tif err := dockerCp(ctx, tmpPath, containerID+\":/workspace/.cloche/resume.json\"); err != nil {\n   104→\t\treturn nil, fmt.Errorf(\"copying resume config to container: %w\", err)\n   105→\t}\n   106→\n   107→\t// Copy updated project files (scripts, prompts, overrides)\n   108→\tif run.ProjectDir != \"\" {\n   109→\t\tcopyProjectUpdates(ctx, containerID, run.ProjectDir)\n   110→\t}\n   111→\n   112→\t// Reset run state to pending\n   113→\trun.State = domain.RunStatePending\n   114→\trun.ErrorMessage = \"\"\n   115→\trun.ActiveSteps = nil\n   116→\tif err := s.store.UpdateRun(ctx, run); err != nil {\n   117→\t\treturn nil, fmt.Errorf(\"updating run state: %w\", err)\n   118→\t}\n   119→\n   120→\ts.mu.Lock()\n   121→\ts.runIDs[run.ID] = containerID\n   122→\ts.mu.Unlock()\n   123→\n   124→\tgo s.restartAndTrack(run.ID, containerID, run.ProjectDir, run.WorkflowName)\n   125→\n   126→\treturn &pb.ResumeRunResponse{RunId: run.ID}, nil\n   127→}\n   128→\n   129→// resumeHostRun resumes a failed host workflow run.\n   130→func (s *ClocheServer) resumeHostRun(ctx context.Context, run *domain.Run, resumeCfg *domain.ResumeConfig) (*pb.ResumeRunResponse, error) {\n   131→\tresumeJSON, err := json.Marshal(resumeCfg)\n   132→\tif err != nil {\n   133→\t\treturn nil, fmt.Errorf(\"marshaling resume config: %w\", err)\n   134→\t}\n   135→\n   136→\tresumeDir := filepath.Join(run.ProjectDir, \".cloche\", run.ID)\n   137→\tif err := os.MkdirAll(resumeDir, 0755); err != nil {\n   138→\t\treturn nil, fmt.Errorf(\"creating resume dir: %w\", err)\n   139→\t}\n   140→\tif err := os.WriteFile(filepath.Join(resumeDir, \"resume.json\"), resumeJSON, 0644); err != nil {\n   141→\t\treturn nil, fmt.Errorf(\"writing resume config: %w\", err)\n   142→\t}\n   143→\n   144→\t// Reset run state\n   145→\trun.State = domain.RunStatePending\n   146→\trun.ErrorMessage = \"\"\n   147→\trun.ActiveSteps = nil\n   148→\tif err := s.store.UpdateRun(ctx, run); err != nil {\n   149→\t\treturn nil, fmt.Errorf(\"updating run state: %w\", err)\n   150→\t}\n   151→\n   152→\trunner := &host.Runner{\n   153→\t\tDispatcher:   s,\n   154→\t\tStore:        s.store,\n   155→\t\tCaptures:     s.captures,\n   156→\t\tLogBroadcast: s.logBroadcast,\n   157→\t\tTaskID:       run.TaskID,\n   158→\t}\n   159→\n   160→\tgo func() {\n   161→\t\trunner.RunNamedWithID(context.Background(), run.ProjectDir, run.WorkflowName, run.ID)\n   162→\t}()\n   163→\n   164→\treturn &pb.ResumeRunResponse{RunId: run.ID}, nil\n   165→}\n   166→\n   167→// restartAndTrack restarts a stopped container and tracks it to completion.\n   168→func (s *ClocheServer) restartAndTrack(runID, containerID, projectDir, workflowName string) {\n   169→\tctx := context.Background()\n   170→\n   171→\t// Start the stopped container (re-runs original CMD which includes the agent)\n   172→\tcmd := exec.CommandContext(ctx, \"docker\", \"start\", containerID)\n   173→\tif out, err := cmd.CombinedOutput(); err != nil {\n   174→\t\tlog.Printf(\"resume run %s: failed to restart container: %s: %v\", runID, string(out), err)\n   175→\t\trun, _ := s.store.GetRun(ctx, runID)\n   176→\t\tif run != nil {\n   177→\t\t\trun.Fail(fmt.Sprintf(\"failed to restart container: %v\", err))\n   178→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   179→\t\t}\n   180→\t\ts.mu.Lock()\n   181→\t\tdelete(s.runIDs, runID)\n   182→\t\ts.mu.Unlock()\n   183→\t\treturn\n   184→\t}\n   185→\n   186→\trun, _ := s.store.GetRun(ctx, runID)\n   187→\tif run != nil {\n   188→\t\trun.Start()\n   189→\t\t_ = s.store.UpdateRun(ctx, run)\n   190→\t}\n   191→\n   192→\t// Reuse trackRun — keepContainer=true so the container is preserved\n   193→\ts.trackRun(runID, containerID, projectDir, workflowName, true)\n   194→}\n   195→\n   196→// firstFailedStepFromCaptures finds the first step that failed or was not completed.\n   197→func firstFailedStepFromCaptures(captures []*domain.StepExecution) string {\n   198→\tcompleted := make(map[string]string)\n   199→\tfor _, c := range captures {\n   200→\t\tif c.Result != \"\" {\n   201→\t\t\tcompleted[c.StepName] = c.Result\n   202→\t\t}\n   203→\t}\n   204→\n   205→\tfor _, c := range captures {\n   206→\t\tresult, hasResult := completed[c.StepName]\n   207→\t\tif !hasResult {\n   208→\t\t\treturn c.StepName\n   209→\t\t}\n   210→\t\tif result == \"fail\" || result == \"error\" {\n   211→\t\t\treturn c.StepName\n   212→\t\t}\n   213→\t}\n   214→\treturn \"\"\n   215→}\n   216→\n   217→// succeededStepsBefore returns step results for all steps that completed\n   218→// successfully before the target step in execution order.\n   219→func succeededStepsBefore(captures []*domain.StepExecution, targetStep string) map[string]string {\n   220→\tresults := make(map[string]string)\n   221→\tfor _, c := range captures {\n   222→\t\tif c.StepName == targetStep {\n   223→\t\t\tbreak\n   224→\t\t}\n   225→\t\tif c.Result != \"\" && c.Result != \"fail\" && c.Result != \"error\" {\n   226→\t\t\tresults[c.StepName] = c.Result\n   227→\t\t}\n   228→\t}\n   229→\treturn results\n   230→}\n   231→\n   232→// dockerCp wraps docker cp for copying files into a container.\n   233→func dockerCp(ctx context.Context, src, dst string) error {\n   234→\tcmd := exec.CommandContext(ctx, \"docker\", \"cp\", src, dst)\n   235→\tif out, err := cmd.CombinedOutput(); err != nil {\n   236→\t\treturn fmt.Errorf(\"%s: %w\", string(out), err)\n   237→\t}\n   238→\treturn nil\n   239→}\n   240→\n   241→// copyProjectUpdates copies updated scripts, prompts, and overrides into the container.\n   242→func copyProjectUpdates(ctx context.Context, containerID, projectDir string) {\n   243→\tfor _, sub := range []struct {\n   244→\t\thostDir      string\n   245→\t\tcontainerDir string\n   246→\t}{\n   247→\t\t{filepath.Join(projectDir, \".cloche\", \"scripts\"), \"/workspace/.cloche/scripts/\"},\n   248→\t\t{filepath.Join(projectDir, \".cloche\", \"prompts\"), \"/workspace/.cloche/prompts/\"},\n   249→\t\t{filepath.Join(projectDir, \".cloche\", \"overrides\"), \"/workspace/\"},\n   250→\t} {\n   251→\t\tif _, err := os.Stat(sub.hostDir); err == nil {\n   252→\t\t\tdockerCp(ctx, sub.hostDir+\"/.\", containerID+\":\"+sub.containerDir)\n   253→\t\t}\n   254→\t}\n   255→}\n   256→"}]},"parent_tool_use_id":"toolu_01Y1PzzwgtqcjET4zTfJf9wf","session_id":"499cc276-44bb-4bfe-9549-2f88e2009a57","uuid":"2315b412-541d-47df-b186-d307bfc0321f"}
