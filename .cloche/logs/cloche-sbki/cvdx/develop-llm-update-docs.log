{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GSGoqwWkFf3LJiGQ9ETj67","type":"tool_result","content":"     1→package domain_test\n     2→\n     3→import (\n     4→\t\"testing\"\n     5→\n     6→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     7→\t\"github.com/stretchr/testify/assert\"\n     8→)\n     9→\n    10→func TestRun_FirstFailedStep(t *testing.T) {\n    11→\trun := domain.NewRun(\"run-1\", \"develop\")\n    12→\trun.StepExecutions = []*domain.StepExecution{\n    13→\t\t{StepName: \"build\", Result: \"success\"},\n    14→\t\t{StepName: \"test\", Result: \"success\"},\n    15→\t\t{StepName: \"implement\", Result: \"fail\"},\n    16→\t}\n    17→\n    18→\tassert.Equal(t, \"implement\", run.FirstFailedStep())\n    19→}\n    20→\n    21→func TestRun_FirstFailedStep_Error(t *testing.T) {\n    22→\trun := domain.NewRun(\"run-1\", \"develop\")\n    23→\trun.StepExecutions = []*domain.StepExecution{\n    24→\t\t{StepName: \"build\", Result: \"success\"},\n    25→\t\t{StepName: \"implement\", Result: \"error\"},\n    26→\t}\n    27→\n    28→\tassert.Equal(t, \"implement\", run.FirstFailedStep())\n    29→}\n    30→\n    31→func TestRun_FirstFailedStep_NoCompletion(t *testing.T) {\n    32→\trun := domain.NewRun(\"run-1\", \"develop\")\n    33→\trun.StepExecutions = []*domain.StepExecution{\n    34→\t\t{StepName: \"build\", Result: \"success\"},\n    35→\t\t{StepName: \"implement\", Result: \"\"}, // started but never completed\n    36→\t}\n    37→\n    38→\tassert.Equal(t, \"implement\", run.FirstFailedStep())\n    39→}\n    40→\n    41→func TestRun_FirstFailedStep_AllSucceeded(t *testing.T) {\n    42→\trun := domain.NewRun(\"run-1\", \"develop\")\n    43→\trun.StepExecutions = []*domain.StepExecution{\n    44→\t\t{StepName: \"build\", Result: \"success\"},\n    45→\t\t{StepName: \"test\", Result: \"pass\"},\n    46→\t}\n    47→\n    48→\tassert.Empty(t, run.FirstFailedStep())\n    49→}\n    50→\n    51→func TestRun_SucceededStepsBefore(t *testing.T) {\n    52→\trun := domain.NewRun(\"run-1\", \"develop\")\n    53→\trun.StepExecutions = []*domain.StepExecution{\n    54→\t\t{StepName: \"setup\", Result: \"success\"},\n    55→\t\t{StepName: \"build\", Result: \"success\"},\n    56→\t\t{StepName: \"implement\", Result: \"fail\"},\n    57→\t\t{StepName: \"test\", Result: \"pass\"},\n    58→\t}\n    59→\n    60→\tprior := run.SucceededStepsBefore(\"implement\")\n    61→\tassert.Equal(t, map[string]string{\n    62→\t\t\"setup\": \"success\",\n    63→\t\t\"build\": \"success\",\n    64→\t}, prior)\n    65→}\n    66→\n    67→func TestRun_SucceededStepsBefore_FirstStep(t *testing.T) {\n    68→\trun := domain.NewRun(\"run-1\", \"develop\")\n    69→\trun.StepExecutions = []*domain.StepExecution{\n    70→\t\t{StepName: \"implement\", Result: \"fail\"},\n    71→\t}\n    72→\n    73→\tprior := run.SucceededStepsBefore(\"implement\")\n    74→\tassert.Empty(t, prior)\n    75→}\n    76→\n    77→func TestRun_SucceededStepsBefore_SkipsFailed(t *testing.T) {\n    78→\trun := domain.NewRun(\"run-1\", \"develop\")\n    79→\trun.StepExecutions = []*domain.StepExecution{\n    80→\t\t{StepName: \"setup\", Result: \"success\"},\n    81→\t\t{StepName: \"lint\", Result: \"fail\"},\n    82→\t\t{StepName: \"implement\", Result: \"fail\"},\n    83→\t}\n    84→\n    85→\tprior := run.SucceededStepsBefore(\"implement\")\n    86→\tassert.Equal(t, map[string]string{\n    87→\t\t\"setup\": \"success\",\n    88→\t}, prior)\n    89→}\n    90→"}]},"parent_tool_use_id":"toolu_01Y1PzzwgtqcjET4zTfJf9wf","session_id":"499cc276-44bb-4bfe-9549-2f88e2009a57","uuid":"bda1dbda-ae1d-4953-92ab-eeb54e34cff6"}
