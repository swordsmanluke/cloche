{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R5c7srPMdSAozF6KFjbMC4","type":"tool_result","content":"     1→package engine_test\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"testing\"\n     6→\n     7→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     8→\t\"github.com/cloche-dev/cloche/internal/engine\"\n     9→\t\"github.com/stretchr/testify/assert\"\n    10→\t\"github.com/stretchr/testify/require\"\n    11→)\n    12→\n    13→func TestResumeExecutor_SkipsPriorSteps(t *testing.T) {\n    14→\twf := &domain.Workflow{\n    15→\t\tName: \"resume-test\",\n    16→\t\tSteps: map[string]*domain.Step{\n    17→\t\t\t\"build\":     {Name: \"build\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n    18→\t\t\t\"implement\": {Name: \"implement\", Type: domain.StepTypeAgent, Results: []string{\"success\"}, Config: map[string]string{}},\n    19→\t\t\t\"test\":      {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n    20→\t\t},\n    21→\t\tWiring: []domain.Wire{\n    22→\t\t\t{From: \"build\", Result: \"success\", To: \"implement\"},\n    23→\t\t\t{From: \"implement\", Result: \"success\", To: \"test\"},\n    24→\t\t\t{From: \"test\", Result: \"pass\", To: domain.StepDone},\n    25→\t\t},\n    26→\t\tEntryStep: \"build\",\n    27→\t}\n    28→\n    29→\texec := &fakeExecutor{results: map[string]string{\n    30→\t\t\"build\":     \"success\",\n    31→\t\t\"implement\": \"success\",\n    32→\t\t\"test\":      \"pass\",\n    33→\t}}\n    34→\n    35→\tresumeExec := &engine.ResumeExecutor{\n    36→\t\tInner: exec,\n    37→\t\tPriorResults: map[string]string{\n    38→\t\t\t\"build\": \"success\",\n    39→\t\t},\n    40→\t\tResumeStep: \"implement\",\n    41→\t}\n    42→\n    43→\teng := engine.New(resumeExec)\n    44→\trun, err := eng.Run(context.Background(), wf)\n    45→\trequire.NoError(t, err)\n    46→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n    47→\n    48→\t// \"build\" should NOT have been called (skipped via PriorResults)\n    49→\tassert.NotContains(t, exec.called, \"build\")\n    50→\t// \"implement\" and \"test\" should have been called\n    51→\tassert.Contains(t, exec.called, \"implement\")\n    52→\tassert.Contains(t, exec.called, \"test\")\n    53→}\n    54→\n    55→func TestResumeExecutor_SetsResumeFlag(t *testing.T) {\n    56→\tstep := &domain.Step{\n    57→\t\tName:    \"implement\",\n    58→\t\tType:    domain.StepTypeAgent,\n    59→\t\tResults: []string{\"success\"},\n    60→\t\tConfig:  map[string]string{},\n    61→\t}\n    62→\n    63→\tvar capturedConfig map[string]string\n    64→\tinner := engine.StepExecutorFunc(func(_ context.Context, s *domain.Step) (string, error) {\n    65→\t\tcapturedConfig = s.Config\n    66→\t\treturn \"success\", nil\n    67→\t})\n    68→\n    69→\tresumeExec := &engine.ResumeExecutor{\n    70→\t\tInner:        inner,\n    71→\t\tPriorResults: map[string]string{},\n    72→\t\tResumeStep:   \"implement\",\n    73→\t}\n    74→\n    75→\tresult, err := resumeExec.Execute(context.Background(), step)\n    76→\trequire.NoError(t, err)\n    77→\tassert.Equal(t, \"success\", result)\n    78→\tassert.Equal(t, \"true\", capturedConfig[\"_resume\"])\n    79→}\n    80→\n    81→func TestResumeExecutor_NoResumeFlagForNonResumeStep(t *testing.T) {\n    82→\tstep := &domain.Step{\n    83→\t\tName:    \"test\",\n    84→\t\tType:    domain.StepTypeScript,\n    85→\t\tResults: []string{\"pass\"},\n    86→\t\tConfig:  map[string]string{},\n    87→\t}\n    88→\n    89→\tvar capturedConfig map[string]string\n    90→\tinner := engine.StepExecutorFunc(func(_ context.Context, s *domain.Step) (string, error) {\n    91→\t\tcapturedConfig = s.Config\n    92→\t\treturn \"pass\", nil\n    93→\t})\n    94→\n    95→\tresumeExec := &engine.ResumeExecutor{\n    96→\t\tInner:        inner,\n    97→\t\tPriorResults: map[string]string{},\n    98→\t\tResumeStep:   \"implement\", // different step\n    99→\t}\n   100→\n   101→\tresult, err := resumeExec.Execute(context.Background(), step)\n   102→\trequire.NoError(t, err)\n   103→\tassert.Equal(t, \"pass\", result)\n   104→\tassert.Empty(t, capturedConfig[\"_resume\"])\n   105→}\n   106→"}]},"parent_tool_use_id":"toolu_01Y1PzzwgtqcjET4zTfJf9wf","session_id":"499cc276-44bb-4bfe-9549-2f88e2009a57","uuid":"23a89727-018b-4049-aed9-269fff3bd268"}
