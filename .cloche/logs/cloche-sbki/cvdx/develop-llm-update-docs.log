{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JgzbxDeeFAVJfQfDAabFNk","type":"tool_result","content":"diff --git a/cmd/cloche/main.go b/cmd/cloche/main.go\nindex f5eec12..80f9a71 100644\n--- a/cmd/cloche/main.go\n+++ b/cmd/cloche/main.go\n@@ -110,7 +110,7 @@ func main() {\n \n \t// Handle --help for daemon commands before connecting\n \tdaemonCmds := map[string]bool{\n-\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n+\t\t\"run\": true, \"resume\": true, \"status\": true, \"logs\": true, \"poll\": true,\n \t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n \t}\n \tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n@@ -138,6 +138,8 @@ func main() {\n \tswitch os.Args[1] {\n \tcase \"run\":\n \t\tcmdRun(ctx, client, os.Args[2:])\n+\tcase \"resume\":\n+\t\tcmdResume(ctx, conn, os.Args[2:])\n \tcase \"status\":\n \t\tcmdStatus(ctx, client, os.Args[2:])\n \tcase \"logs\":\n@@ -457,6 +459,25 @@ func cmdLogs(client pb.ClocheServiceClient, args []string) {\n \t}\n }\n \n+func cmdResume(ctx context.Context, conn *grpc.ClientConn, args []string) {\n+\tif len(args) < 1 {\n+\t\tfmt.Fprintf(os.Stderr, \"usage: cloche resume <run-id> [step-name]\\n\")\n+\t\tos.Exit(1)\n+\t}\n+\n+\treq := &pb.ResumeRunRequest{RunId: args[0]}\n+\tif len(args) >= 2 {\n+\t\treq.StepName = args[1]\n+\t}\n+\n+\tresp, err := pb.InvokeResumeRun(conn, ctx, req)\n+\tif err != nil {\n+\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n+\t\tos.Exit(1)\n+\t}\n+\tfmt.Printf(\"Resumed run: %s\\n\", resp.RunId)\n+}\n+\n func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n \tif len(args) < 1 {\n \t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")","is_error":false}]},"parent_tool_use_id":"toolu_01Y1PzzwgtqcjET4zTfJf9wf","session_id":"499cc276-44bb-4bfe-9549-2f88e2009a57","uuid":"b3764eb5-85ca-4596-a281-d1ab73589c43"}
