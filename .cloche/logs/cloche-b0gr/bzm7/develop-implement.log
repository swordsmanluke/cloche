{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RnFBZt3uRLwTcrSsiNTyUz","type":"tool_result","content":"     1→package evolution_test\n     2→\n     3→import (\n     4→\t\"path/filepath\"\n     5→\t\"sort\"\n     6→\t\"testing\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    11→\t\"github.com/stretchr/testify/assert\"\n    12→\t\"github.com/stretchr/testify/require\"\n    13→)\n    14→\n    15→func TestEvaluateRun(t *testing.T) {\n    16→\ttests := []struct {\n    17→\t\tname       string\n    18→\t\trun        *domain.Run\n    19→\t\tcandidate  string\n    20→\t\twantSucc   bool\n    21→\t\twantRetry  int\n    22→\t\twantDurPos bool\n    23→\t}{\n    24→\t\t{\n    25→\t\t\tname: \"succeeded run no retries\",\n    26→\t\t\trun: &domain.Run{\n    27→\t\t\t\tID:           \"r1\",\n    28→\t\t\t\tWorkflowName: \"develop\",\n    29→\t\t\t\tState:        domain.RunStateSucceeded,\n    30→\t\t\t\tStartedAt:    time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n    31→\t\t\t\tCompletedAt:  time.Date(2026, 1, 1, 0, 5, 0, 0, time.UTC),\n    32→\t\t\t\tStepExecutions: []*domain.StepExecution{\n    33→\t\t\t\t\t{StepName: \"code\"},\n    34→\t\t\t\t\t{StepName: \"test\"},\n    35→\t\t\t\t},\n    36→\t\t\t},\n    37→\t\t\tcandidate:  \"v1\",\n    38→\t\t\twantSucc:   true,\n    39→\t\t\twantRetry:  0,\n    40→\t\t\twantDurPos: true,\n    41→\t\t},\n    42→\t\t{\n    43→\t\t\tname: \"failed run with retries\",\n    44→\t\t\trun: &domain.Run{\n    45→\t\t\t\tID:           \"r2\",\n    46→\t\t\t\tWorkflowName: \"develop\",\n    47→\t\t\t\tState:        domain.RunStateFailed,\n    48→\t\t\t\tStartedAt:    time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n    49→\t\t\t\tCompletedAt:  time.Date(2026, 1, 1, 0, 10, 0, 0, time.UTC),\n    50→\t\t\t\tStepExecutions: []*domain.StepExecution{\n    51→\t\t\t\t\t{StepName: \"code\"},\n    52→\t\t\t\t\t{StepName: \"test\"},\n    53→\t\t\t\t\t{StepName: \"code\"}, // retry\n    54→\t\t\t\t\t{StepName: \"test\"}, // retry\n    55→\t\t\t\t},\n    56→\t\t\t},\n    57→\t\t\tcandidate:  \"v1\",\n    58→\t\t\twantSucc:   false,\n    59→\t\t\twantRetry:  2,\n    60→\t\t\twantDurPos: true,\n    61→\t\t},\n    62→\t\t{\n    63→\t\t\tname: \"cancelled run zero duration\",\n    64→\t\t\trun: &domain.Run{\n    65→\t\t\t\tID:           \"r3\",\n    66→\t\t\t\tWorkflowName: \"develop\",\n    67→\t\t\t\tState:        domain.RunStateCancelled,\n    68→\t\t\t\tStartedAt:    time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n    69→\t\t\t\tCompletedAt:  time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n    70→\t\t\t},\n    71→\t\t\tcandidate:  \"v2\",\n    72→\t\t\twantSucc:   false,\n    73→\t\t\twantRetry:  0,\n    74→\t\t\twantDurPos: false,\n    75→\t\t},\n    76→\t}\n    77→\n    78→\tfor _, tt := range tests {\n    79→\t\tt.Run(tt.name, func(t *testing.T) {\n    80→\t\t\trec := evolution.EvaluateRun(tt.run, tt.candidate)\n    81→\t\t\tassert.Equal(t, tt.run.ID, rec.RunID)\n    82→\t\t\tassert.Equal(t, tt.candidate, rec.Candidate)\n    83→\t\t\tassert.Equal(t, tt.wantSucc, rec.Success)\n    84→\t\t\tassert.Equal(t, tt.wantRetry, rec.RetryCount)\n    85→\t\t\tif tt.wantDurPos {\n    86→\t\t\t\tassert.Greater(t, rec.Duration, time.Duration(0))\n    87→\t\t\t}\n    88→\t\t})\n    89→\t}\n    90→}\n    91→\n    92→func TestRecordAndLoadFitness(t *testing.T) {\n    93→\tdir := t.TempDir()\n    94→\tpath := filepath.Join(dir, \"fitness.jsonl\")\n    95→\n    96→\t// Load from nonexistent file returns nil\n    97→\trecords, err := evolution.LoadFitness(path)\n    98→\trequire.NoError(t, err)\n    99→\tassert.Nil(t, records)\n   100→\n   101→\t// Write two records\n   102→\tr1 := evolution.FitnessRecord{\n   103→\t\tRunID:     \"r1\",\n   104→\t\tCandidate: \"v1\",\n   105→\t\tSuccess:   true,\n   106→\t\tDuration:  5 * time.Minute,\n   107→\t}\n   108→\tr2 := evolution.FitnessRecord{\n   109→\t\tRunID:      \"r2\",\n   110→\t\tCandidate:  \"v1\",\n   111→\t\tSuccess:    false,\n   112→\t\tRetryCount: 2,\n   113→\t\tDuration:   10 * time.Minute,\n   114→\t}\n   115→\n   116→\trequire.NoError(t, evolution.RecordFitness(path, r1))\n   117→\trequire.NoError(t, evolution.RecordFitness(path, r2))\n   118→\n   119→\trecords, err = evolution.LoadFitness(path)\n   120→\trequire.NoError(t, err)\n   121→\trequire.Len(t, records, 2)\n   122→\tassert.Equal(t, \"r1\", records[0].RunID)\n   123→\tassert.True(t, records[0].Success)\n   124→\tassert.Equal(t, \"r2\", records[1].RunID)\n   125→\tassert.Equal(t, 2, records[1].RetryCount)\n   126→}\n   127→\n   128→func TestAggregateFitness(t *testing.T) {\n   129→\trecords := []evolution.FitnessRecord{\n   130→\t\t{Candidate: \"a\", Success: true, RetryCount: 0, Duration: 60 * time.Second},\n   131→\t\t{Candidate: \"a\", Success: true, RetryCount: 0, Duration: 60 * time.Second},\n   132→\t\t{Candidate: \"b\", Success: true, RetryCount: 0, Duration: 60 * time.Second},\n   133→\t\t{Candidate: \"b\", Success: false, RetryCount: 2, Duration: 120 * time.Second},\n   134→\t}\n   135→\n   136→\tagg := evolution.AggregateFitness(records)\n   137→\tsort.Slice(agg, func(i, j int) bool { return agg[i].Candidate < agg[j].Candidate })\n   138→\n   139→\trequire.Len(t, agg, 2)\n   140→\n   141→\t// Candidate \"a\": 2/2 success, 0 retries, 60s avg → efficiency = 1/(1+0+1) = 0.5\n   142→\tassert.Equal(t, \"a\", agg[0].Candidate)\n   143→\tassert.Equal(t, 1.0, agg[0].SuccessRate)\n   144→\tassert.InDelta(t, 0.5, agg[0].Efficiency, 0.001)\n   145→\tassert.Equal(t, 2, agg[0].RunCount)\n   146→\n   147→\t// Candidate \"b\": 1/2 success, avg retries=1, avg dur=90s → efficiency = 1/(1+1+1.5) = 1/3.5\n   148→\tassert.Equal(t, \"b\", agg[1].Candidate)\n   149→\tassert.Equal(t, 0.5, agg[1].SuccessRate)\n   150→\tassert.InDelta(t, 1.0/3.5, agg[1].Efficiency, 0.001)\n   151→\tassert.Equal(t, 2, agg[1].RunCount)\n   152→}\n   153→\n   154→func TestDominates(t *testing.T) {\n   155→\ttests := []struct {\n   156→\t\tname string\n   157→\t\ta, b evolution.CandidateFitness\n   158→\t\twant bool\n   159→\t}{\n   160→\t\t{\n   161→\t\t\tname: \"a dominates b both better\",\n   162→\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n   163→\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.7, Efficiency: 0.5},\n   164→\t\t\twant: true,\n   165→\t\t},\n   166→\t\t{\n   167→\t\t\tname: \"a dominates b equal success better efficiency\",\n   168→\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n   169→\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.5},\n   170→\t\t\twant: true,\n   171→\t\t},\n   172→\t\t{\n   173→\t\t\tname: \"no domination equal\",\n   174→\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n   175→\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n   176→\t\t\twant: false,\n   177→\t\t},\n   178→\t\t{\n   179→\t\t\tname: \"no domination tradeoff\",\n   180→\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.3},\n   181→\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.7, Efficiency: 0.8},\n   182→\t\t\twant: false,\n   183→\t\t},\n   184→\t\t{\n   185→\t\t\tname: \"b dominates a\",\n   186→\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.5, Efficiency: 0.3},\n   187→\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n   188→\t\t\twant: false,\n   189→\t\t},\n   190→\t}\n   191→\n   192→\tfor _, tt := range tests {\n   193→\t\tt.Run(tt.name, func(t *testing.T) {\n   194→\t\t\tassert.Equal(t, tt.want, evolution.Dominates(tt.a, tt.b))\n   195→\t\t})\n   196→\t}\n   197→}\n   198→\n   199→func TestComputeParetoFront(t *testing.T) {\n   200→\ttests := []struct {\n   201→\t\tname       string\n   202→\t\tcandidates []evolution.CandidateFitness\n   203→\t\twantFront  []string // expected candidate names in front\n   204→\t}{\n   205→\t\t{\n   206→\t\t\tname: \"single candidate is front\",\n   207→\t\t\tcandidates: []evolution.CandidateFitness{\n   208→\t\t\t\t{Candidate: \"a\", SuccessRate: 0.8, Efficiency: 0.5},\n   209→\t\t\t},\n   210→\t\t\twantFront: []string{\"a\"},\n   211→\t\t},\n   212→\t\t{\n   213→\t\t\tname: \"one dominates the other\",\n   214→\t\t\tcandidates: []evolution.CandidateFitness{\n   215→\t\t\t\t{Candidate: \"a\", SuccessRate: 0.9, Efficiency: 0.8},\n   216→\t\t\t\t{Candidate: \"b\", SuccessRate: 0.7, Efficiency: 0.5},\n   217→\t\t\t},\n   218→\t\t\twantFront: []string{\"a\"},\n   219→\t\t},\n   220→\t\t{\n   221→\t\t\tname: \"tradeoff front\",\n   222→\t\t\tcandidates: []evolution.CandidateFitness{\n   223→\t\t\t\t{Candidate: \"fast\", SuccessRate: 0.6, Efficiency: 0.9},\n   224→\t\t\t\t{Candidate: \"reliable\", SuccessRate: 0.95, Efficiency: 0.3},\n   225→\t\t\t\t{Candidate: \"dominated\", SuccessRate: 0.5, Efficiency: 0.2},\n   226→\t\t\t},\n   227→\t\t\twantFront: []string{\"fast\", \"reliable\"},\n   228→\t\t},\n   229→\t\t{\n   230→\t\t\tname: \"all on front\",\n   231→\t\t\tcandidates: []evolution.CandidateFitness{\n   232→\t\t\t\t{Candidate: \"a\", SuccessRate: 1.0, Efficiency: 0.1},\n   233→\t\t\t\t{Candidate: \"b\", SuccessRate: 0.5, Efficiency: 0.5},\n   234→\t\t\t\t{Candidate: \"c\", SuccessRate: 0.1, Efficiency: 1.0},\n   235→\t\t\t},\n   236→\t\t\twantFront: []string{\"a\", \"b\", \"c\"},\n   237→\t\t},\n   238→\t\t{\n   239→\t\t\tname: \"complex front with interior points\",\n   240→\t\t\tcandidates: []evolution.CandidateFitness{\n   241→\t\t\t\t{Candidate: \"p1\", SuccessRate: 1.0, Efficiency: 0.2},\n   242→\t\t\t\t{Candidate: \"p2\", SuccessRate: 0.8, Efficiency: 0.7},\n   243→\t\t\t\t{Candidate: \"p3\", SuccessRate: 0.5, Efficiency: 0.9},\n   244→\t\t\t\t{Candidate: \"d1\", SuccessRate: 0.7, Efficiency: 0.3}, // dominated by p2\n   245→\t\t\t\t{Candidate: \"d2\", SuccessRate: 0.4, Efficiency: 0.5}, // dominated by p2\n   246→\t\t\t\t{Candidate: \"d3\", SuccessRate: 0.3, Efficiency: 0.8}, // dominated by p3\n   247→\t\t\t},\n   248→\t\t\twantFront: []string{\"p1\", \"p2\", \"p3\"},\n   249→\t\t},\n   250→\t\t{\n   251→\t\t\tname:       \"empty input\",\n   252→\t\t\tcandidates: nil,\n   253→\t\t\twantFront:  nil,\n   254→\t\t},\n   255→\t}\n   256→\n   257→\tfor _, tt := range tests {\n   258→\t\tt.Run(tt.name, func(t *testing.T) {\n   259→\t\t\tfront := evolution.ComputeParetoFront(tt.candidates)\n   260→\n   261→\t\t\tvar names []string\n   262→\t\t\tfor _, c := range front {\n   263→\t\t\t\tnames = append(names, c.Candidate)\n   264→\t\t\t}\n   265→\t\t\tsort.Strings(names)\n   266→\n   267→\t\t\tvar expected []string\n   268→\t\t\tif tt.wantFront != nil {\n   269→\t\t\t\texpected = make([]string, len(tt.wantFront))\n   270→\t\t\t\tcopy(expected, tt.wantFront)\n   271→\t\t\t\tsort.Strings(expected)\n   272→\t\t\t}\n   273→\n   274→\t\t\tassert.Equal(t, expected, names)\n   275→\t\t})\n   276→\t}\n   277→}\n   278→\n   279→func TestFitnessPath(t *testing.T) {\n   280→\tgot := evolution.FitnessPath(\"/home/user/project\", \"develop\")\n   281→\tassert.Equal(t, \"/home/user/project/.cloche/evolution/fitness/develop.jsonl\", got)\n   282→}\n   283→"}]},"parent_tool_use_id":null,"session_id":"be77d2fd-89b7-4848-a0a1-80420fb9ccaa","uuid":"395c95cb-6bac-4408-9839-62390960c3f3","timestamp":"2026-03-17T14:54:49.186Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/fitness_test.go","content":"package evolution_test\n\nimport (\n\t\"path/filepath\"\n\t\"sort\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestEvaluateRun(t *testing.T) {\n\ttests := []struct {\n\t\tname       string\n\t\trun        *domain.Run\n\t\tcandidate  string\n\t\twantSucc   bool\n\t\twantRetry  int\n\t\twantDurPos bool\n\t}{\n\t\t{\n\t\t\tname: \"succeeded run no retries\",\n\t\t\trun: &domain.Run{\n\t\t\t\tID:           \"r1\",\n\t\t\t\tWorkflowName: \"develop\",\n\t\t\t\tState:        domain.RunStateSucceeded,\n\t\t\t\tStartedAt:    time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n\t\t\t\tCompletedAt:  time.Date(2026, 1, 1, 0, 5, 0, 0, time.UTC),\n\t\t\t\tStepExecutions: []*domain.StepExecution{\n\t\t\t\t\t{StepName: \"code\"},\n\t\t\t\t\t{StepName: \"test\"},\n\t\t\t\t},\n\t\t\t},\n\t\t\tcandidate:  \"v1\",\n\t\t\twantSucc:   true,\n\t\t\twantRetry:  0,\n\t\t\twantDurPos: true,\n\t\t},\n\t\t{\n\t\t\tname: \"failed run with retries\",\n\t\t\trun: &domain.Run{\n\t\t\t\tID:           \"r2\",\n\t\t\t\tWorkflowName: \"develop\",\n\t\t\t\tState:        domain.RunStateFailed,\n\t\t\t\tStartedAt:    time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n\t\t\t\tCompletedAt:  time.Date(2026, 1, 1, 0, 10, 0, 0, time.UTC),\n\t\t\t\tStepExecutions: []*domain.StepExecution{\n\t\t\t\t\t{StepName: \"code\"},\n\t\t\t\t\t{StepName: \"test\"},\n\t\t\t\t\t{StepName: \"code\"}, // retry\n\t\t\t\t\t{StepName: \"test\"}, // retry\n\t\t\t\t},\n\t\t\t},\n\t\t\tcandidate:  \"v1\",\n\t\t\twantSucc:   false,\n\t\t\twantRetry:  2,\n\t\t\twantDurPos: true,\n\t\t},\n\t\t{\n\t\t\tname: \"cancelled run zero duration\",\n\t\t\trun: &domain.Run{\n\t\t\t\tID:           \"r3\",\n\t\t\t\tWorkflowName: \"develop\",\n\t\t\t\tState:        domain.RunStateCancelled,\n\t\t\t\tStartedAt:    time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n\t\t\t\tCompletedAt:  time.Date(2026, 1, 1, 0, 0, 0, 0, time.UTC),\n\t\t\t},\n\t\t\tcandidate:  \"v2\",\n\t\t\twantSucc:   false,\n\t\t\twantRetry:  0,\n\t\t\twantDurPos: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\trec := evolution.EvaluateRun(tt.run, tt.candidate)\n\t\t\tassert.Equal(t, tt.run.ID, rec.RunID)\n\t\t\tassert.Equal(t, tt.candidate, rec.Candidate)\n\t\t\tassert.Equal(t, tt.wantSucc, rec.Success)\n\t\t\tassert.Equal(t, tt.wantRetry, rec.RetryCount)\n\t\t\tif tt.wantDurPos {\n\t\t\t\tassert.Greater(t, rec.Duration, time.Duration(0))\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestRecordAndLoadFitness(t *testing.T) {\n\tdir := t.TempDir()\n\tpath := filepath.Join(dir, \"fitness.jsonl\")\n\n\t// Load from nonexistent file returns nil\n\trecords, err := evolution.LoadFitness(path)\n\trequire.NoError(t, err)\n\tassert.Nil(t, records)\n\n\t// Write two records\n\tr1 := evolution.FitnessRecord{\n\t\tRunID:     \"r1\",\n\t\tCandidate: \"v1\",\n\t\tSuccess:   true,\n\t\tDuration:  5 * time.Minute,\n\t}\n\tr2 := evolution.FitnessRecord{\n\t\tRunID:      \"r2\",\n\t\tCandidate:  \"v1\",\n\t\tSuccess:    false,\n\t\tRetryCount: 2,\n\t\tDuration:   10 * time.Minute,\n\t}\n\n\trequire.NoError(t, evolution.RecordFitness(path, r1))\n\trequire.NoError(t, evolution.RecordFitness(path, r2))\n\n\trecords, err = evolution.LoadFitness(path)\n\trequire.NoError(t, err)\n\trequire.Len(t, records, 2)\n\tassert.Equal(t, \"r1\", records[0].RunID)\n\tassert.True(t, records[0].Success)\n\tassert.Equal(t, \"r2\", records[1].RunID)\n\tassert.Equal(t, 2, records[1].RetryCount)\n}\n\nfunc TestAggregateFitness(t *testing.T) {\n\trecords := []evolution.FitnessRecord{\n\t\t{Candidate: \"a\", Success: true, RetryCount: 0, Duration: 60 * time.Second},\n\t\t{Candidate: \"a\", Success: true, RetryCount: 0, Duration: 60 * time.Second},\n\t\t{Candidate: \"b\", Success: true, RetryCount: 0, Duration: 60 * time.Second},\n\t\t{Candidate: \"b\", Success: false, RetryCount: 2, Duration: 120 * time.Second},\n\t}\n\n\tagg := evolution.AggregateFitness(records)\n\tsort.Slice(agg, func(i, j int) bool { return agg[i].Candidate < agg[j].Candidate })\n\n\trequire.Len(t, agg, 2)\n\n\t// Candidate \"a\": 2/2 success, 0 retries, 60s avg → efficiency = 1/(1+0+1) = 0.5\n\tassert.Equal(t, \"a\", agg[0].Candidate)\n\tassert.Equal(t, 1.0, agg[0].SuccessRate)\n\tassert.InDelta(t, 0.5, agg[0].Efficiency, 0.001)\n\tassert.Equal(t, 2, agg[0].RunCount)\n\n\t// Candidate \"b\": 1/2 success, avg retries=1, avg dur=90s → efficiency = 1/(1+1+1.5) = 1/3.5\n\tassert.Equal(t, \"b\", agg[1].Candidate)\n\tassert.Equal(t, 0.5, agg[1].SuccessRate)\n\tassert.InDelta(t, 1.0/3.5, agg[1].Efficiency, 0.001)\n\tassert.Equal(t, 2, agg[1].RunCount)\n}\n\nfunc TestDominates(t *testing.T) {\n\ttests := []struct {\n\t\tname string\n\t\ta, b evolution.CandidateFitness\n\t\twant bool\n\t}{\n\t\t{\n\t\t\tname: \"a dominates b both better\",\n\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.7, Efficiency: 0.5},\n\t\t\twant: true,\n\t\t},\n\t\t{\n\t\t\tname: \"a dominates b equal success better efficiency\",\n\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.5},\n\t\t\twant: true,\n\t\t},\n\t\t{\n\t\t\tname: \"no domination equal\",\n\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n\t\t\twant: false,\n\t\t},\n\t\t{\n\t\t\tname: \"no domination tradeoff\",\n\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.3},\n\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.7, Efficiency: 0.8},\n\t\t\twant: false,\n\t\t},\n\t\t{\n\t\t\tname: \"b dominates a\",\n\t\t\ta:    evolution.CandidateFitness{SuccessRate: 0.5, Efficiency: 0.3},\n\t\t\tb:    evolution.CandidateFitness{SuccessRate: 0.9, Efficiency: 0.8},\n\t\t\twant: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, tt.want, evolution.Dominates(tt.a, tt.b))\n\t\t})\n\t}\n}\n\nfunc TestComputeParetoFront(t *testing.T) {\n\ttests := []struct {\n\t\tname       string\n\t\tcandidates []evolution.CandidateFitness\n\t\twantFront  []string // expected candidate names in front\n\t}{\n\t\t{\n\t\t\tname: \"single candidate is front\",\n\t\t\tcandidates: []evolution.CandidateFitness{\n\t\t\t\t{Candidate: \"a\", SuccessRate: 0.8, Efficiency: 0.5},\n\t\t\t},\n\t\t\twantFront: []string{\"a\"},\n\t\t},\n\t\t{\n\t\t\tname: \"one dominates the other\",\n\t\t\tcandidates: []evolution.CandidateFitness{\n\t\t\t\t{Candidate: \"a\", SuccessRate: 0.9, Efficiency: 0.8},\n\t\t\t\t{Candidate: \"b\", SuccessRate: 0.7, Efficiency: 0.5},\n\t\t\t},\n\t\t\twantFront: []string{\"a\"},\n\t\t},\n\t\t{\n\t\t\tname: \"tradeoff front\",\n\t\t\tcandidates: []evolution.CandidateFitness{\n\t\t\t\t{Candidate: \"fast\", SuccessRate: 0.6, Efficiency: 0.9},\n\t\t\t\t{Candidate: \"reliable\", SuccessRate: 0.95, Efficiency: 0.3},\n\t\t\t\t{Candidate: \"dominated\", SuccessRate: 0.5, Efficiency: 0.2},\n\t\t\t},\n\t\t\twantFront: []string{\"fast\", \"reliable\"},\n\t\t},\n\t\t{\n\t\t\tname: \"all on front\",\n\t\t\tcandidates: []evolution.CandidateFitness{\n\t\t\t\t{Candidate: \"a\", SuccessRate: 1.0, Efficiency: 0.1},\n\t\t\t\t{Candidate: \"b\", SuccessRate: 0.5, Efficiency: 0.5},\n\t\t\t\t{Candidate: \"c\", SuccessRate: 0.1, Efficiency: 1.0},\n\t\t\t},\n\t\t\twantFront: []string{\"a\", \"b\", \"c\"},\n\t\t},\n\t\t{\n\t\t\tname: \"complex front with interior points\",\n\t\t\tcandidates: []evolution.CandidateFitness{\n\t\t\t\t{Candidate: \"p1\", SuccessRate: 1.0, Efficiency: 0.2},\n\t\t\t\t{Candidate: \"p2\", SuccessRate: 0.8, Efficiency: 0.7},\n\t\t\t\t{Candidate: \"p3\", SuccessRate: 0.5, Efficiency: 0.9},\n\t\t\t\t{Candidate: \"d1\", SuccessRate: 0.7, Efficiency: 0.3}, // dominated by p2\n\t\t\t\t{Candidate: \"d2\", SuccessRate: 0.4, Efficiency: 0.5}, // dominated by p2\n\t\t\t\t{Candidate: \"d3\", SuccessRate: 0.3, Efficiency: 0.8}, // dominated by p3\n\t\t\t},\n\t\t\twantFront: []string{\"p1\", \"p2\", \"p3\"},\n\t\t},\n\t\t{\n\t\t\tname:       \"empty input\",\n\t\t\tcandidates: nil,\n\t\t\twantFront:  nil,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tfront := evolution.ComputeParetoFront(tt.candidates)\n\n\t\t\tvar names []string\n\t\t\tfor _, c := range front {\n\t\t\t\tnames = append(names, c.Candidate)\n\t\t\t}\n\t\t\tsort.Strings(names)\n\n\t\t\tvar expected []string\n\t\t\tif tt.wantFront != nil {\n\t\t\t\texpected = make([]string, len(tt.wantFront))\n\t\t\t\tcopy(expected, tt.wantFront)\n\t\t\t\tsort.Strings(expected)\n\t\t\t}\n\n\t\t\tassert.Equal(t, expected, names)\n\t\t})\n\t}\n}\n\nfunc TestFitnessPath(t *testing.T) {\n\tgot := evolution.FitnessPath(\"/home/user/project\", \"develop\")\n\tassert.Equal(t, \"/home/user/project/.cloche/evolution/fitness/develop.jsonl\", got)\n}\n","numLines":283,"startLine":1,"totalLines":283}}}
