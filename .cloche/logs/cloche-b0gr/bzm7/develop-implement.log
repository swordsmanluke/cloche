; err != nil {\n\t\treturn fmt.Errorf(\"creating fitness dir: %w\", err)\n\t}\n\n\tf, err := os.OpenFile(path, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"opening fitness file: %w\", err)\n\t}\n\tdefer f.Close()\n\n\tdata, err := json.Marshal(record)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"marshaling fitness record: %w\", err)\n\t}\n\n\tif _, err := f.Write(append(data, '\\n')); err != nil {\n\t\treturn fmt.Errorf(\"writing fitness record: %w\", err)\n\t}\n\n\treturn nil\n}\n```\n\n**Pattern 2: Loading JSONL Files** (`/workspace/internal/evolution/fitness.go`, lines 85-108)\n```go\nfunc LoadFitness(path string) ([]FitnessRecord, error) {\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn nil, nil\n\t}\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading fitness file: %w\", err)\n\t}\n\n\tvar records []FitnessRecord\n\tfor _, line := range strings.Split(strings.TrimSpace(string(data)), \"\\n\") {\n\t\tline = strings.TrimSpace(line)\n\t\tif line == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tvar rec FitnessRecord\n\t\tif err := json.Unmarshal([]byte(line), &rec); err != nil {\n\t\t\tcontinue\n\t\t}\n\t\trecords = append(records, rec)\n\t}\n\treturn records, nil\n}\n```\n\n**Pattern 3: Audit Logging** (`/workspace/internal/evolution/audit.go`, lines 19-42)\n```go\nfunc (a *AuditLogger) Log(result *EvolutionResult) error {\n\tlogPath := filepath.Join(a.ProjectDir, \".cloche\", \"evolution\", \"log.jsonl\")\n\tif err := os.MkdirAll(filepath.Dir(logPath), 0755); err != nil {\n\t\treturn fmt.Errorf(\"creating evolution log dir: %w\", err)\n\t}\n\n\tf, err := os.OpenFile(logPath, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"opening evolution log: %w\", err)\n\t}\n\tdefer f.Close()\n\n\tdata, err := json.Marshal(result)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"marshaling evolution result: %w\", err)\n\t}\n\n\tif _, err := f.Write(append(data, '\\n')); err != nil {\n\t\treturn fmt.Errorf(\"writing evolution log: %w\", err)\n\t}\n\n\treturn nil\n}\n```\n\n**Key JSONL Files in the Project:**\n- `.cloche/evolution/fitness/<workflow-name>.jsonl` (via `FitnessPath()`)\n- `.cloche/evolution/log.jsonl` (evolution audit trail)\n- `.cloche/evolution/knowledge/<workflow-name>.jsonl` (lessons learned)\n- `.cloche/evolution/population/<step-name>/meta.jsonl` (candidate metadata)\n- `.cloche/evolution/population/<step-name>/assignments.jsonl` (run→candidate mapping)\n\n---\n\n### 5. **Test File Conventions**\n\n**Pattern: Using testify for assertions**\n- File: `/workspace/internal/domain/run_test.go`\n- Pattern: Package named `domain_test`, imports `testing`, `github.com/stretchr/testify/assert`, `github.com/stretchr/testify/require`\n- Use `assert.*` for non-fatal checks, `require.*` for fatal checks\n- Table-driven tests are common (see `TestTaskAggregateStatus` in run_test.go)\n\n**Example Test Structure** (from `/workspace/internal/evolution/fitness_test.go`):\n```go\npackage evolution_test\n\nimport (\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestEvaluateRun(t *testing.T) {\n\ttests := []struct {\n\t\tname string\n\t\t// ... fields\n\t}{\n\t\t// ... test cases\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\t// test body\n\t\t})\n\t}\n}\n```\n\n**Test File Usage Patterns:**\n- Use `t.TempDir()` for temporary test directories\n- Use `require.NoError()` for setup, `assert.Equal()` for verification\n- Test both happy path and error cases\n\n---\n\n### 6. **Existing Fitness Functions** (from `/workspace/internal/evolution/fitness.go`)\n\nThe codebase already has:\n\n**FitnessRecord struct** (lines 15-23):\n```go\ntype FitnessRecord struct {\n\tRunID        string        `json:\"run_id\"`\n\tWorkflowName string        `json:\"workflow_name\"`\n\tCandidate    string        `json:\"candidate\"`\n\tSuccess      bool          `json:\"success\"`\n\tRetryCount   int           `json:\"retry_count\"`\n\tDuration     time.Duration `json:\"duration\"`\n\tTimestamp    time.Time     `json:\"timestamp\"`\n}\n```\n\n**CandidateFitness struct** (lines 26-31):\n```go\ntype CandidateFitness struct {\n\tCandidate   string  `json:\"candidate\"`\n\tSuccessRate float64 `json:\"success_rate\"`\n\tEfficiency  float64 `json:\"efficiency\"`\n\tRunCount    int     `json:\"run_count\"`\n}\n```\n\n**Core Functions:**\n- `EvaluateRun(r *domain.Run, candidate string) FitnessRecord` - Extract metrics from a single run\n- `RecordFitness(path string, record FitnessRecord) error` - Append to JSONL file\n- `LoadFitness(path string) ([]FitnessRecord, error)` - Read JSONL file\n- `AggregateFitness(records []FitnessRecord) []CandidateFitness` - Compute success rate and efficiency\n- `Dominates(a, b CandidateFitness) bool` - Multi-objective comparison\n- `ComputeParetoFront(candidates []CandidateFitness) []CandidateFitness` - Non-dominated set\n- `FitnessPath(projectDir, workflowName string) string` - Standard path resolution\n\n---\n\n### Summary for Implementation\n\nYou have a solid foundation for fitness evaluation:\n- **Module:** `github.com/cloche-dev/cloche`\n- **Domain entity:** `*domain.Run` with full execution history\n- **Evolution package:** `/workspace/internal/evolution/` with existing fitness infrastructure\n- **JSONL patterns:** Established and consistent (append-only with `os.O_APPEND|os.O_CREATE|os.O_WRONLY`, line-by-line JSON unmarshaling)\n- **Testing:** Use `testify`, table-driven tests, `t.TempDir()` for fixtures\n- **Standard paths:** `.cloche/evolution/<category>/<workflow>.jsonl` structure\n- **Already implemented:** `EvaluateRun()`, `RecordFitness()`, `LoadFitness()`, aggregation, Pareto front computation"}],"totalDurationMs":31518,"totalTokens":39753,"totalToolUseCount":1