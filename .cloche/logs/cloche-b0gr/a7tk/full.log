    55→\terr := wf.Validate()\n    56→\trequire.Error(t, err)\n    57→\tassert.Contains(t, err.Error(), \"fail\")\n    58→}\n    59→\n    60→func TestWorkflow_Validate_OrphanStep(t *testing.T) {\n    61→\twf := &domain.Workflow{\n    62→\t\tName: \"test-workflow\",\n    63→\t\tSteps: map[string]*domain.Step{\n    64→\t\t\t\"code\": {\n    65→\t\t\t\tName:    \"code\",\n    66→\t\t\t\tType:    domain.StepTypeAgent,\n    67→\t\t\t\tResults: []string{\"success\"},\n    68→\t\t\t},\n    69→\t\t\t\"orphan\": {\n    70→\t\t\t\tName:    \"orphan\",\n    71→\t\t\t\tType:    domain.StepTypeScript,\n    72→\t\t\t\tResults: []string{\"done\"},\n    73→\t\t\t},\n    74→\t\t},\n    75→\t\tWiring: []domain.Wire{\n    76→\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n    77→\t\t\t{From: \"orphan\", Result: \"done\", To: domain.StepDone},\n    78→\t\t},\n    79→\t\tEntryStep: \"code\",\n    80→\t}\n    81→\n    82→\terr := wf.Validate()\n    83→\trequire.Error(t, err)\n    84→\tassert.Contains(t, err.Error(), \"orphan\")\n    85→}\n    86→\n    87→func TestWorkflow_Validate_NoEntryStep(t *testing.T) {\n    88→\twf := &domain.Workflow{\n    89→\t\tName:      \"test-workflow\",\n    90→\t\tSteps:     map[string]*domain.Step{},\n    91→\t\tWiring:    []domain.Wire{},\n    92→\t\tEntryStep: \"\",\n    93→\t}\n    94→\n    95→\terr := wf.Validate()\n    96→\trequire.Error(t, err)\n    97→\tassert.Contains(t, err.Error(), \"entry\")\n    98→}\n    99→\n   100→func TestWorkflow_NextSteps(t *testing.T) {"}]},"parent_tool_use_id":"toolu_01DimqXp4JMZuAnP1BLHUN3i","session_id":"2c9bf61f-09a1-44ad-b826-f3dc460a4b97","uuid":"66f98802-0c23-4521-a72c-38ce51914aab","timestamp":"2026-03-17T14:07:56.249Z"}
