[2026-03-17T14:10:43Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019WQR4rjZhMGYyKJfHvfGJH","type":"tool_result","content":"     1→package domain_test\n     2→\n     3→import (\n     4→\t\"testing\"\n     5→\t\"time\"\n     6→\n     7→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     8→\t\"github.com/stretchr/testify/assert\"\n     9→)\n    10→\n    11→func TestRun_Lifecycle(t *testing.T) {\n    12→\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n    13→\tassert.Equal(t, domain.RunStatePending, run.State)\n    14→\n    15→\trun.Start()\n    16→\tassert.Equal(t, domain.RunStateRunning, run.State)\n    17→\tassert.False(t, run.StartedAt.IsZero())\n    18→\n    19→\trun.RecordStepStart(\"code\")\n    20→\tassert.Equal(t, []string{\"code\"}, run.ActiveSteps)\n    21→\tassert.Len(t, run.StepExecutions, 1)\n    22→\n    23→\trun.RecordStepComplete(\"code\", \"success\")\n    24→\tassert.Empty(t, run.ActiveSteps)\n    25→\tassert.Equal(t, \"success\", run.StepExecutions[0].Result)\n    26→\tassert.False(t, run.StepExecutions[0].CompletedAt.IsZero())\n    27→\n    28→\trun.Complete(domain.RunStateSucceeded)\n    29→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n    30→\tassert.False(t, run.CompletedAt.IsZero())\n    31→}\n    32→\n    33→func TestRunProjectDir(t *testing.T) {\n    34→\tr := domain.NewRun(\"test-1\", \"develop\")\n    35→\tr.ProjectDir = \"/home/user/project\"\n    36→\tassert.Equal(t, \"/home/user/project\", r.ProjectDir)\n    37→}\n    38→\n    39→func TestRunTitle(t *testing.T) {\n    40→\tr := domain.NewRun(\"test-1\", \"develop\")\n    41→\tr.Title = \"Add dark mode toggle\"\n    42→\tassert.Equal(t, \"Add dark mode toggle\", r.Title)\n    43→}\n    44→\n    45→func TestStepExecutionFields(t *testing.T) {\n    46→\texec := &domain.StepExecution{\n    47→\t\tStepName: \"implement\",\n    48→\t\tResult:   \"success\",\n    49→\t}\n    50→\tassert.Equal(t, \"implement\", exec.StepName)\n    51→\tassert.Equal(t, \"success\", exec.Result)\n    52→}\n    53→\n    54→func TestRun_Fail(t *testing.T) {\n    55→\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n    56→\trun.Start()\n    57→\trun.Fail(\"container exploded\")\n    58→\tassert.Equal(t, domain.RunStateFailed, run.State)\n    59→\tassert.False(t, run.CompletedAt.IsZero())\n    60→\tassert.Equal(t, \"container exploded\", run.ErrorMessage)\n    61→}\n    62→\n    63→func TestRunIsHost(t *testing.T) {\n    64→\tr := domain.NewRun(\"host-1\", \"main\")\n    65→\tassert.False(t, r.IsHost)\n    66→\tr.IsHost = true\n    67→\tassert.True(t, r.IsHost)\n    68→}\n    69→\n    70→func TestRun_StepExecution_Duration(t *testing.T) {\n    71→\texec := &domain.StepExecution{\n    72→\t\tStepName:    \"code\",\n    73→\t\tStartedAt:   time.Now().Add(-5 * time.Second),\n    74→\t\tCompletedAt: time.Now(),\n    75→\t}\n    76→\tassert.InDelta(t, 5.0, exec.Duration().Seconds(), 0.1)\n    77→}\n    78→\n    79→func TestWorseState(t *testing.T) {\n    80→\ttests := []struct {\n    81→\t\tname string\n    82→\t\ta, b domain.RunState\n    83→\t\twant domain.RunState\n    84→\t}{\n    85→\t\t{\"succeeded vs succeeded\", domain.RunStateSucceeded, domain.RunStateSucceeded, domain.RunStateSucceeded},\n    86→\t\t{\"succeeded vs failed\", domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateFailed},\n    87→\t\t{\"failed vs succeeded\", domain.RunStateFailed, domain.RunStateSucceeded, domain.RunStateFailed},\n    88→\t\t{\"succeeded vs cancelled\", domain.RunStateSucceeded, domain.RunStateCancelled, domain.RunStateCancelled},\n    89→\t\t{\"cancelled vs failed\", domain.RunStateCancelled, domain.RunStateFailed, domain.RunStateFailed},\n    90→\t\t{\"failed vs failed\", domain.RunStateFailed, domain.RunStateFailed, domain.RunStateFailed},\n    91→\t}\n    92→\n    93→\tfor _, tt := range tests {\n    94→\t\tt.Run(tt.name, func(t *testing.T) {\n    95→\t\t\tgot := domain.WorseState(tt.a, tt.b)\n    96→\t\t\tassert.Equal(t, tt.want, got)\n    97→\t\t})\n    98→\t}\n    99→}\n   100→\n   101→func TestTaskAggregateStatus(t *testing.T) {\n   102→\tnow := time.Now()\n   103→\tmkRun := func(state domain.RunState, startedAt time.Time) *domain.Run {\n   104→\t\tr := domain.NewRun(\"r\", \"wf\")\n   105→\t\tr.State = state\n   106→\t\tr.StartedAt = startedAt\n   107→\t\treturn r\n   108→\t}\n   109→\tmkHostRun := func(state domain.RunState, startedAt time.Time) *domain.Run {\n   110→\t\tr := mkRun(state, startedAt)\n   111→\t\tr.IsHost = true\n   112→\t\treturn r\n   113→\t}\n   114→\n   115→\ttests := []struct {\n   116→\t\tname string\n   117→\t\truns []*domain.Run\n   118→\t\twant domain.RunState\n   119→\t}{\n   120→\t\t{\n   121→\t\t\tname: \"empty returns pending\",\n   122→\t\t\truns: nil,\n   123→\t\t\twant: domain.RunStatePending,\n   124→\t\t},\n   125→\t\t{\n   126→\t\t\tname: \"single succeeded\",\n   127→\t\t\truns: []*domain.Run{mkRun(domain.RunStateSucceeded, now)},\n   128→\t\t\twant: domain.RunStateSucceeded,\n   129→\t\t},\n   130→\t\t{\n   131→\t\t\tname: \"single failed\",\n   132→\t\t\truns: []*domain.Run{mkRun(domain.RunStateFailed, now)},\n   133→\t\t\twant: domain.RunStateFailed,\n   134→\t\t},\n   135→\t\t{\n   136→\t\t\tname: \"running outweighs succeeded\",\n   137→\t\t\truns: []*domain.Run{\n   138→\t\t\t\tmkRun(domain.RunStateSucceeded, now.Add(-1*time.Minute)),\n   139→\t\t\t\tmkRun(domain.RunStateRunning, now),\n   140→\t\t\t},\n   141→\t\t\twant: domain.RunStateRunning,\n   142→\t\t},\n   143→\t\t{\n   144→\t\t\tname: \"running outweighs failed\",\n   145→\t\t\truns: []*domain.Run{\n   146→\t\t\t\tmkRun(domain.RunStateFailed, now.Add(-1*time.Minute)),\n   147→\t\t\t\tmkRun(domain.RunStateRunning, now),\n   148→\t\t\t},\n   149→\t\t\twant: domain.RunStateRunning,\n   150→\t\t},\n   151→\t\t{\n   152→\t\t\tname: \"pending outweighs terminal\",\n   153→\t\t\truns: []*domain.Run{\n   154→\t\t\t\tmkRun(domain.RunStateFailed, now.Add(-1*time.Minute)),\n   155→\t\t\t\tmkRun(domain.RunStatePending, now),\n   156→\t\t\t},\n   157→\t\t\twant: domain.RunStatePending,\n   158→\t\t},\n   159→\t\t{\n   160→\t\t\tname: \"running outweighs pending\",\n   161→\t\t\truns: []*domain.Run{\n   162→\t\t\t\tmkRun(domain.RunStatePending, now.Add(-1*time.Minute)),\n   163→\t\t\t\tmkRun(domain.RunStateRunning, now),\n   164→\t\t\t},\n   165→\t\t\twant: domain.RunStateRunning,\n   166→\t\t},\n   167→\t\t{\n   168→\t\t\tname: \"most recent attempt wins - success after failure\",\n   169→\t\t\truns: []*domain.Run{\n   170→\t\t\t\tmkRun(domain.RunStateFailed, now.Add(-2*time.Minute)),\n   171→\t\t\t\tmkRun(domain.RunStateSucceeded, now),\n   172→\t\t\t},\n   173→\t\t\twant: domain.RunStateSucceeded,\n   174→\t\t},\n   175→\t\t{\n   176→\t\t\tname: \"most recent attempt wins - failure after success\",\n   177→\t\t\truns: []*domain.Run{\n   178→\t\t\t\tmkRun(domain.RunStateSucceeded, now.Add(-2*time.Minute)),\n   179→\t\t\t\tmkRun(domain.RunStateFailed, now),\n   180→\t\t\t},\n   181→\t\t\twant: domain.RunStateFailed,\n   182→\t\t},\n   183→\t\t{\n   184→\t\t\tname: \"cancelled is terminal - most recent wins\",\n   185→\t\t\truns: []*domain.Run{\n   186→\t\t\t\tmkRun(domain.RunStateCancelled, now.Add(-2*time.Minute)),\n   187→\t\t\t\tmkRun(domain.RunStateSucceeded, now),\n   188→\t\t\t},\n   189→\t\t\twant: domain.RunStateSucceeded,\n   190→\t\t},\n   191→\t\t{\n   192→\t\t\tname: \"active outweighs even most recent terminal\",\n   193→\t\t\truns: []*domain.Run{\n   194→\t\t\t\tmkRun(domain.RunStateRunning, now.Add(-5*time.Minute)),\n   195→\t\t\t\tmkRun(domain.RunStateFailed, now),\n   196→\t\t\t},\n   197→\t\t\twant: domain.RunStateRunning,\n   198→\t\t},\n   199→\t\t{\n   200→\t\t\tname: \"host run failed with succeeded child - host wins\",\n   201→\t\t\truns: []*domain.Run{\n   202→\t\t\t\tmkHostRun(domain.RunStateFailed, now.Add(-1*time.Minute)),\n   203→\t\t\t\tmkRun(domain.RunStateSucceeded, now),\n   204→\t\t\t},\n   205→\t\t\twant: domain.RunStateFailed,\n   206→\t\t},\n   207→\t\t{\n   208→\t\t\tname: \"host run succeeded with succeeded child\",\n   209→\t\t\truns: []*domain.Run{\n   210→\t\t\t\tmkHostRun(domain.RunStateSucceeded, now.Add(-1*time.Minute)),\n   211→\t\t\t\tmkRun(domain.RunStateSucceeded, now),\n   212→\t\t\t},\n   213→\t\t\twant: domain.RunStateSucceeded,\n   214→\t\t},\n   215→\t\t{\n   216→\t\t\tname: \"most recent host run wins over older host\",\n   217→\t\t\truns: []*domain.Run{\n   218→\t\t\t\tmkHostRun(domain.RunStateSucceeded, now.Add(-5*time.Minute)),\n   219→\t\t\t\tmkRun(domain.RunStateSucceeded, now.Add(-4*time.Minute)),\n   220→\t\t\t\tmkHostRun(domain.RunStateFailed, now.Add(-2*time.Minute)),\n   221→\t\t\t\tmkRun(domain.RunStateSucceeded, now),\n   222→\t\t\t},\n   223→\t\t\twant: domain.RunStateFailed,\n   224→\t\t},\n   225→\t\t{\n   226→\t\t\tname: \"active outweighs failed host\",\n   227→\t\t\truns: []*domain.Run{\n   228→\t\t\t\tmkHostRun(domain.RunStateFailed, now.Add(-2*time.Minute)),\n   229→\t\t\t\tmkRun(domain.RunStateRunning, now),\n   230→\t\t\t},\n   231→\t\t\twant: domain.RunStateRunning,\n   232→\t\t},\n   233→\t}\n   234→\n   235→\tfor _, tt := range tests {\n   236→\t\tt.Run(tt.name, func(t *testing.T) {\n   237→\t\t\tgot := domain.TaskAggregateStatus(tt.runs)\n   238→\t\t\tassert.Equal(t, tt.want, got)\n   239→\t\t})\n   240→\t}\n   241→}\n   242→"}]},"parent_tool_use_id":"toolu_01DimqXp4JMZuAnP1BLHUN3i","session_id":"2c9bf61f-09a1-44ad-b826-f3dc460a4b97","uuid":"03136c3e-7e48-433c-aab3-9d3cb116c3d0","timestamp":"2026-03-17T14:07:50.258Z"}
