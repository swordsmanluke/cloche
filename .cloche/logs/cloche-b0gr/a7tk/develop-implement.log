{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D5WzX2VWsMja3Cd6qEyRAM","type":"tool_result","content":"     1â†’package evolution\n     2â†’\n     3â†’import (\n     4â†’\t\"encoding/json\"\n     5â†’\t\"fmt\"\n     6â†’\t\"io\"\n     7â†’\t\"os\"\n     8â†’\t\"path/filepath\"\n     9â†’\t\"strings\"\n    10â†’\t\"time\"\n    11â†’)\n    12â†’\n    13â†’// AuditLogger records evolution actions and manages snapshots.\n    14â†’type AuditLogger struct {\n    15â†’\tProjectDir       string\n    16â†’\tMaxPromptBullets int // 0 means unlimited\n    17â†’}\n    18â†’\n    19â†’// Log appends an EvolutionResult as a JSONL entry.\n    20â†’func (a *AuditLogger) Log(result *EvolutionResult) error {\n    21â†’\tlogPath := filepath.Join(a.ProjectDir, \".cloche\", \"evolution\", \"log.jsonl\")\n    22â†’\tif err := os.MkdirAll(filepath.Dir(logPath), 0755); err != nil {\n    23â†’\t\treturn fmt.Errorf(\"creating evolution log dir: %w\", err)\n    24â†’\t}\n    25â†’\n    26â†’\tf, err := os.OpenFile(logPath, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644)\n    27â†’\tif err != nil {\n    28â†’\t\treturn fmt.Errorf(\"opening evolution log: %w\", err)\n    29â†’\t}\n    30â†’\tdefer f.Close()\n    31â†’\n    32â†’\tdata, err := json.Marshal(result)\n    33â†’\tif err != nil {\n    34â†’\t\treturn fmt.Errorf(\"marshaling evolution result: %w\", err)\n    35â†’\t}\n    36â†’\n    37â†’\tif _, err := f.Write(append(data, '\\n')); err != nil {\n    38â†’\t\treturn fmt.Errorf(\"writing evolution log: %w\", err)\n    39â†’\t}\n    40â†’\n    41â†’\treturn nil\n    42â†’}\n    43â†’\n    44â†’// Snapshot copies a file to the snapshots directory and returns the snapshot filename.\n    45â†’func (a *AuditLogger) Snapshot(relativePath string) (string, error) {\n    46â†’\tsrcPath := filepath.Join(a.ProjectDir, relativePath)\n    47â†’\tsnapDir := filepath.Join(a.ProjectDir, \".cloche\", \"evolution\", \"snapshots\")\n    48â†’\tif err := os.MkdirAll(snapDir, 0755); err != nil {\n    49â†’\t\treturn \"\", fmt.Errorf(\"creating snapshots dir: %w\", err)\n    50â†’\t}\n    51â†’\n    52â†’\tbasename := filepath.Base(relativePath)\n    53â†’\tsnapName := fmt.Sprintf(\"%s-%s\", time.Now().Format(\"20060102T150405\"), basename)\n    54â†’\tdstPath := filepath.Join(snapDir, snapName)\n    55â†’\n    56â†’\tsrc, err := os.Open(srcPath)\n    57â†’\tif err != nil {\n    58â†’\t\treturn \"\", fmt.Errorf(\"opening source for snapshot: %w\", err)\n    59â†’\t}\n    60â†’\tdefer src.Close()\n    61â†’\n    62â†’\tdst, err := os.Create(dstPath)\n    63â†’\tif err != nil {\n    64â†’\t\treturn \"\", fmt.Errorf(\"creating snapshot file: %w\", err)\n    65â†’\t}\n    66â†’\tdefer dst.Close()\n    67â†’\n    68â†’\tif _, err := io.Copy(dst, src); err != nil {\n    69â†’\t\treturn \"\", fmt.Errorf(\"copying to snapshot: %w\", err)\n    70â†’\t}\n    71â†’\n    72â†’\treturn snapName, nil\n    73â†’}\n    74â†’\n    75â†’// Restore copies a snapshot back to the original file location.\n    76â†’func (a *AuditLogger) Restore(relativePath, snapName string) error {\n    77â†’\tsnapDir := filepath.Join(a.ProjectDir, \".cloche\", \"evolution\", \"snapshots\")\n    78â†’\tsrcPath := filepath.Join(snapDir, snapName)\n    79â†’\tdstPath := filepath.Join(a.ProjectDir, relativePath)\n    80â†’\n    81â†’\tdata, err := os.ReadFile(srcPath)\n    82â†’\tif err != nil {\n    83â†’\t\treturn fmt.Errorf(\"reading snapshot %s: %w\", snapName, err)\n    84â†’\t}\n    85â†’\n    86â†’\tif err := os.WriteFile(dstPath, data, 0644); err != nil {\n    87â†’\t\treturn fmt.Errorf(\"restoring snapshot to %s: %w\", relativePath, err)\n    88â†’\t}\n    89â†’\n    90â†’\treturn nil\n    91â†’}\n    92â†’\n    93â†’// KnowledgePath returns the JSONL knowledge base path for a workflow.\n    94â†’func (a *AuditLogger) KnowledgePath(workflowName string) string {\n    95â†’\treturn filepath.Join(a.ProjectDir, \".cloche\", \"evolution\", \"knowledge\", workflowName+\".jsonl\")\n    96â†’}\n    97â†’\n    98â†’// readKnowledge reads existing lessons from the JSONL knowledge base.\n    99â†’func readKnowledge(path string) ([]Lesson, error) {\n   100â†’\tdata, err := os.ReadFile(path)\n   101â†’\tif os.IsNotExist(err) {\n   102â†’\t\treturn nil, nil\n   103â†’\t}\n   104â†’\tif err != nil {\n   105â†’\t\treturn nil, err\n   106â†’\t}\n   107â†’\n   108â†’\tvar lessons []Lesson\n   109â†’\tfor _, line := range strings.Split(strings.TrimSpace(string(data)), \"\\n\") {\n   110â†’\t\tline = strings.TrimSpace(line)\n   111â†’\t\tif line == \"\" {\n   112â†’\t\t\tcontinue\n   113â†’\t\t}\n   114â†’\t\tvar l Lesson\n   115â†’\t\tif err := json.Unmarshal([]byte(line), &l); err != nil {\n   116â†’\t\t\tcontinue // skip malformed lines\n   117â†’\t\t}\n   118â†’\t\tlessons = append(lessons, l)\n   119â†’\t}\n   120â†’\treturn lessons, nil\n   121â†’}\n   122â†’\n   123â†’// writeKnowledge writes lessons as JSONL, one per line.\n   124â†’func writeKnowledge(path string, lessons []Lesson) error {\n   125â†’\tif err := os.MkdirAll(filepath.Dir(path), 0755); err != nil {\n   126â†’\t\treturn fmt.Errorf(\"creating knowledge dir: %w\", err)\n   127â†’\t}\n   128â†’\n   129â†’\tvar sb strings.Builder\n   130â†’\tfor _, l := range lessons {\n   131â†’\t\tdata, err := json.Marshal(l)\n   132â†’\t\tif err != nil {\n   133â†’\t\t\tcontinue\n   134â†’\t\t}\n   135â†’\t\tsb.Write(data)\n   136â†’\t\tsb.WriteByte('\\n')\n   137â†’\t}\n   138â†’\treturn os.WriteFile(path, []byte(sb.String()), 0644)\n   139â†’}\n   140â†’\n   141â†’// UpdateKnowledge merges lessons into the knowledge base with deduplication\n   142â†’// and optional pruning when MaxPromptBullets is exceeded.\n   143â†’func (a *AuditLogger) UpdateKnowledge(workflowName string, lessons []Lesson) error {\n   144â†’\tkbPath := a.KnowledgePath(workflowName)\n   145â†’\n   146â†’\texisting, err := readKnowledge(kbPath)\n   147â†’\tif err != nil {\n   148â†’\t\treturn fmt.Errorf(\"reading knowledge base: %w\", err)\n   149â†’\t}\n   150â†’\n   151â†’\t// Build index of existing lesson IDs\n   152â†’\tidIndex := make(map[string]int, len(existing))\n   153â†’\tfor i, l := range existing {\n   154â†’\t\tidIndex[l.ID] = i\n   155â†’\t}\n   156â†’\n   157â†’\t// Merge: update in place if ID exists, append if new\n   158â†’\tfor _, l := range lessons {\n   159â†’\t\tif idx, ok := idIndex[l.ID]; ok {\n   160â†’\t\t\texisting[idx] = l // update existing entry\n   161â†’\t\t} else {\n   162â†’\t\t\texisting = append(existing, l)\n   163â†’\t\t\tidIndex[l.ID] = len(existing) - 1\n   164â†’\t\t}\n   165â†’\t}\n   166â†’\n   167â†’\t// Prune oldest entries if MaxPromptBullets is set and exceeded\n   168â†’\tif a.MaxPromptBullets > 0 && len(existing) > a.MaxPromptBullets {\n   169â†’\t\texisting = existing[len(existing)-a.MaxPromptBullets:]\n   170â†’\t}\n   171â†’\n   172â†’\treturn writeKnowledge(kbPath, existing)\n   173â†’}\n   174â†’"}]},"parent_tool_use_id":"toolu_01DimqXp4JMZuAnP1BLHUN3i","session_id":"2c9bf61f-09a1-44ad-b826-f3dc460a4b97","uuid":"51b26384-6571-4405-9131-0cb1eec40368","timestamp":"2026-03-17T14:07:54.139Z"}
