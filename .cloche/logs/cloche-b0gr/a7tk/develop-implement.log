{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0196QzXDELoAiL3B53qqkmnT","type":"tool_result","content":"     1â†’package domain\n     2â†’\n     3â†’import (\n     4â†’\t\"strings\"\n     5â†’\t\"time\"\n     6â†’)\n     7â†’\n     8â†’type RunState string\n     9â†’\n    10â†’const (\n    11â†’\tRunStatePending   RunState = \"pending\"\n    12â†’\tRunStateRunning   RunState = \"running\"\n    13â†’\tRunStateSucceeded RunState = \"succeeded\"\n    14â†’\tRunStateFailed    RunState = \"failed\"\n    15â†’\tRunStateCancelled RunState = \"cancelled\"\n    16â†’)\n    17â†’\n    18â†’// RunListFilter holds optional filters for listing runs.\n    19â†’type RunListFilter struct {\n    20â†’\tProjectDir string\n    21â†’\tState      RunState\n    22â†’\tTaskID     string\n    23â†’\tLimit      int\n    24â†’\tSince      time.Time\n    25â†’}\n    26â†’\n    27â†’type StepExecution struct {\n    28â†’\tStepName    string\n    29â†’\tResult      string\n    30â†’\tStartedAt   time.Time\n    31â†’\tCompletedAt time.Time\n    32â†’\tLogs        string\n    33â†’\tGitRef      string // output state\n    34â†’}\n    35â†’\n    36â†’func (e *StepExecution) Duration() time.Duration {\n    37â†’\treturn e.CompletedAt.Sub(e.StartedAt)\n    38â†’}\n    39â†’\n    40â†’type Run struct {\n    41â†’\tID             string\n    42â†’\tWorkflowName   string\n    43â†’\tState          RunState\n    44â†’\tActiveSteps    []string\n    45â†’\tStepExecutions []*StepExecution\n    46â†’\tStartedAt      time.Time\n    47â†’\tCompletedAt    time.Time\n    48â†’\tProjectDir     string\n    49â†’\tErrorMessage   string\n    50â†’\tContainerID    string\n    51â†’\tBaseSHA        string // Git HEAD at run start, for result branch creation\n    52â†’\tContainerKept  bool   // true when the container was retained after run completion\n    53â†’\tTitle          string // One-line summary of the work being done\n    54â†’\tIsHost         bool   // true for host workflow runs (vs container runs)\n    55â†’\tParentRunID    string // ID of the parent (host) run, empty for top-level runs\n    56â†’\tTaskID         string // optional task ID this run is associated with\n    57â†’}\n    58â†’\n    59â†’func NewRun(id, workflowName string) *Run {\n    60â†’\treturn &Run{\n    61â†’\t\tID:           id,\n    62â†’\t\tWorkflowName: workflowName,\n    63â†’\t\tState:        RunStatePending,\n    64â†’\t}\n    65â†’}\n    66â†’\n    67â†’func (r *Run) Start() {\n    68â†’\tr.State = RunStateRunning\n    69â†’\tr.StartedAt = time.Now()\n    70â†’}\n    71â†’\n    72â†’func (r *Run) RecordStepStart(stepName string) {\n    73â†’\tr.ActiveSteps = append(r.ActiveSteps, stepName)\n    74â†’\tr.StepExecutions = append(r.StepExecutions, &StepExecution{\n    75â†’\t\tStepName:  stepName,\n    76â†’\t\tStartedAt: time.Now(),\n    77â†’\t})\n    78â†’}\n    79â†’\n    80â†’func (r *Run) RecordStepComplete(stepName, result string) {\n    81â†’\t// Remove from active steps\n    82â†’\tfor i, name := range r.ActiveSteps {\n    83â†’\t\tif name == stepName {\n    84â†’\t\t\tr.ActiveSteps = append(r.ActiveSteps[:i], r.ActiveSteps[i+1:]...)\n    85â†’\t\t\tbreak\n    86â†’\t\t}\n    87â†’\t}\n    88â†’\t// Mark execution complete\n    89â†’\tfor i := len(r.StepExecutions) - 1; i >= 0; i-- {\n    90â†’\t\tif r.StepExecutions[i].StepName == stepName && r.StepExecutions[i].CompletedAt.IsZero() {\n    91â†’\t\t\tr.StepExecutions[i].Result = result\n    92â†’\t\t\tr.StepExecutions[i].CompletedAt = time.Now()\n    93â†’\t\t\treturn\n    94â†’\t\t}\n    95â†’\t}\n    96â†’}\n    97â†’\n    98â†’// ActiveStepsString returns a comma-separated representation of active steps\n    99â†’// for backward-compatible serialization.\n   100â†’func (r *Run) ActiveStepsString() string {\n   101â†’\treturn strings.Join(r.ActiveSteps, \",\")\n   102â†’}\n   103â†’\n   104â†’// SetActiveStepsFromString parses a comma-separated string into ActiveSteps.\n   105â†’func (r *Run) SetActiveStepsFromString(s string) {\n   106â†’\tif s == \"\" {\n   107â†’\t\tr.ActiveSteps = nil\n   108â†’\t\treturn\n   109â†’\t}\n   110â†’\tr.ActiveSteps = strings.Split(s, \",\")\n   111â†’}\n   112â†’\n   113â†’func (r *Run) Complete(state RunState) {\n   114â†’\tr.State = state\n   115â†’\tr.CompletedAt = time.Now()\n   116â†’}\n   117â†’\n   118â†’func (r *Run) Fail(msg string) {\n   119â†’\tr.State = RunStateFailed\n   120â†’\tr.CompletedAt = time.Now()\n   121â†’\tr.ErrorMessage = msg\n   122â†’}\n   123â†’\n   124â†’// FindFirstFailedStep returns the name of the first step that produced a\n   125â†’// failure result (fail/error) in the run's step executions.\n   126â†’// Returns empty string if no failed step is found.\n   127â†’func (r *Run) FindFirstFailedStep() string {\n   128â†’\tfor _, exec := range r.StepExecutions {\n   129â†’\t\tif exec.Result == \"fail\" || exec.Result == \"error\" {\n   130â†’\t\t\treturn exec.StepName\n   131â†’\t\t}\n   132â†’\t}\n   133â†’\treturn \"\"\n   134â†’}\n   135â†’\n   136â†’// stateSeverity returns a severity score for terminal RunStates.\n   137â†’// Higher values indicate worse outcomes.\n   138â†’func stateSeverity(s RunState) int {\n   139â†’\tswitch s {\n   140â†’\tcase RunStateSucceeded:\n   141â†’\t\treturn 0\n   142â†’\tcase RunStateCancelled:\n   143â†’\t\treturn 1\n   144â†’\tcase RunStateFailed:\n   145â†’\t\treturn 2\n   146â†’\tdefault:\n   147â†’\t\treturn -1\n   148â†’\t}\n   149â†’}\n   150â†’\n   151â†’// WorseState returns the more severe of two terminal RunStates.\n   152â†’// Failed is worse than cancelled, which is worse than succeeded.\n   153â†’func WorseState(a, b RunState) RunState {\n   154â†’\tif stateSeverity(b) > stateSeverity(a) {\n   155â†’\t\treturn b\n   156â†’\t}\n   157â†’\treturn a\n   158â†’}\n   159â†’\n   160â†’// TaskAggregateStatus computes the aggregate status for a group of runs\n   161â†’// representing attempts at a task. Active statuses (running, pending) outweigh\n   162â†’// terminal ones. Among terminal runs, host runs (which represent the full\n   163â†’// attempt including finalize) take precedence over child container runs.\n   164â†’// If no host runs exist, the most recently started run determines the result.\n   165â†’func TaskAggregateStatus(runs []*Run) RunState {\n   166â†’\tif len(runs) == 0 {\n   167â†’\t\treturn RunStatePending\n   168â†’\t}\n   169â†’\n   170â†’\t// Active statuses outweigh terminal ones. Prefer running over pending.\n   171â†’\thasRunning := false\n   172â†’\thasPending := false\n   173â†’\tfor _, r := range runs {\n   174â†’\t\tswitch r.State {\n   175â†’\t\tcase RunStateRunning:\n   176â†’\t\t\thasRunning = true\n   177â†’\t\tcase RunStatePending:\n   178â†’\t\t\thasPending = true\n   179â†’\t\t}\n   180â†’\t}\n   181â†’\tif hasRunning {\n   182â†’\t\treturn RunStateRunning\n   183â†’\t}\n   184â†’\tif hasPending {\n   185â†’\t\treturn RunStatePending\n   186â†’\t}\n   187â†’\n   188â†’\t// All runs are terminal. Prefer the most recently started host run,\n   189â†’\t// since it reflects the full attempt outcome (including finalize).\n   190â†’\t// Child container runs start after their parent, so naive most-recent\n   191â†’\t// selection would incorrectly pick a succeeded child over a failed host.\n   192â†’\tvar latestHost *Run\n   193â†’\tvar latest *Run\n   194â†’\tfor _, r := range runs {\n   195â†’\t\tif r.IsHost && (latestHost == nil || r.StartedAt.After(latestHost.StartedAt)) {\n   196â†’\t\t\tlatestHost = r\n   197â†’\t\t}\n   198â†’\t\tif latest == nil || r.StartedAt.After(latest.StartedAt) {\n   199â†’\t\t\tlatest = r\n   200â†’\t\t}\n   201â†’\t}\n   202â†’\tif latestHost != nil {\n   203â†’\t\treturn latestHost.State\n   204â†’\t}\n   205â†’\treturn latest.State\n   206â†’}\n   207â†’"}]},"parent_tool_use_id":"toolu_01DimqXp4JMZuAnP1BLHUN3i","session_id":"2c9bf61f-09a1-44ad-b826-f3dc460a4b97","uuid":"8f98f1d9-9d2a-4082-a262-ae94b4865b7c","timestamp":"2026-03-17T14:07:49.769Z"}
