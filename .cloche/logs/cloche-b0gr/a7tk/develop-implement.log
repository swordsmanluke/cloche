3â†’\t\tMinConfidence: \"medium\",\n   944â†’\t})\n   945â†’\n   946â†’\tresult, err := orch.Run(context.Background(), \"run-5\", nil, nil)\n   947â†’\trequire.NoError(t, err)\n   948â†’\n   949â†’\t// Read and fully validate the workflow\n   950â†’\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   951â†’\trequire.NoError(t, err)\n   952â†’\twf, err := dsl.Parse(string(wfContent))\n   953â†’\trequire.NoError(t, err)\n   954â†’\trequire.NoError(t, wf.Validate())\n   955â†’\n   956â†’\t// Verify we got 3 steps now\n   957â†’\tassert.Equal(t, 3, len(wf.Steps))\n   958â†’\n   959â†’\t// Verify we got the add_step change\n   960â†’\thasAddStep := false\n   961â†’\tfor _, c := range result.Changes {\n   962â†’\t\tif c.Type == \"add_step\" {\n   963â†’\t\t\thasAddStep = true\n   964â†’\t\t}\n   965â†’\t}\n   966â†’\tassert.True(t, hasAddStep)\n   967â†’}\n   968â†’\n   969â†’func TestOrchestratorNoLessons(t *testing.T) {\n   970â†’\tdir := t.TempDir()\n   971â†’\n   972â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   973â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   974â†’\t\t[]byte(`workflow \"develop\" {\n   975â†’  step s {\n   976â†’    run = \"echo hi\"\n   977â†’    results = [success]\n   978â†’  }\n   979â†’  s:success -> done\n   980â†’}`), 0644)\n   981â†’\n   982â†’\tllm := &scriptedLLM{\n   983â†’\t\tresponses: []string{\n   984â†’\t\t\t// Classifier\n   985â†’\t\t\t`{\"classification\": \"feature\"}`,\n   986â†’\t\t\t// Reflector â€” no lessons\n   987â†’\t\t\t`{\"lessons\": []}`,\n   988â†’\t\t},\n   989â†’\t}\n   990â†’\n   991â†’\torch := NewOrchestrator(OrchestratorConfig{\n   992â†’\t\tProjectDir:    dir,\n   993â†’\t\tWorkflowName:  \"develop\",\n   994â†’\t\tLLM:           llm,\n   995â†’\t\tMinConfidence: \"medium\",\n   996â†’\t})\n   997â†’\n   998â†’\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   999â†’\trequire.NoError(t, err)\n  1000â†’\tassert.Equal(t, \"feature\", result.Classification)\n  1001â†’\tassert.Empty(t, result.Changes)\n  1002â†’}\n  1003â†’\n  1004â†’// --- Content-change guard tests ---\n  1005â†’\n  1006â†’func TestLessonAlreadyPresent(t *testing.T) {\n  1007â†’\ttests := []struct {\n  1008â†’\t\tname    string\n  1009â†’\t\tprompt  string\n  1010â†’\t\tlesson  *Lesson\n  1011â†’\t\tpresent bool\n  1012â†’\t}{\n  1013â†’\t\t{\n  1014â†’\t\t\tname:    \"insight present\",\n  1015â†’\t\t\tprompt:  \"# Prompt\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n  1016â†’\t\t\tlesson:  &Lesson{Insight: \"Always sanitize user inputs\", SuggestedAction: \"Add rule\"},\n  1017â†’\t\t\tpresent: true,\n  1018â†’\t\t},\n  1019â†’\t\t{\n  1020â†’\t\t\tname:    \"action present\",\n  1021â†’\t\t\tprompt:  \"# Prompt\\n\\n## Learned Rules\\n\\n- Add input validation for all forms\\n\",\n  1022â†’\t\t\tlesson:  &Lesson{Insight: \"Forms lack validation\", SuggestedAction: \"Add input validation for all forms\"},\n  1023â†’\t\t\tpresent: true,\n  1024â†’\t\t},\n  1025â†’\t\t{\n  1026â†’\t\t\tname:    \"case insensitive match\",\n  1027â†’\t\t\tprompt:  \"# Prompt\\n\\n## Learned Rules\\n\\n- always sanitize user inputs\\n\",\n  1028â†’\t\t\tlesson:  &Lesson{Insight: \"Always Sanitize User Inputs\", SuggestedAction: \"Do it\"},\n  1029â†’\t\t\tpresent: true,\n  1030â†’\t\t},\n  1031â†’\t\t{\n  1032â†’\t\t\tname:    \"not present\",\n  1033â†’\t\t\tprompt:  \"# Prompt\\n\\nWrite good code.\\n\",\n  1034â†’\t\t\tlesson:  &Lesson{Insight: \"Always sanitize user inputs\", SuggestedAction: \"Add sanitization\"},\n  1035â†’\t\t\tpresent: false,\n  1036â†’\t\t},\n  1037â†’\t\t{\n  1038â†’\t\t\tname:    \"empty insight and action\",\n  1039â†’\t\t\tprompt:  \"# Prompt\\n\\nWrite good code.\\n\",\n  1040â†’\t\t\tlesson:  &Lesson{Insight: \"\", SuggestedAction: \"\"},\n  1041â†’\t\t\tpresent: false,\n  1042â†’\t\t},\n  1043â†’\t}\n  1044â†’\n  1045â†’\tfor _, tt := range tests {\n  1046â†’\t\tt.Run(tt.name, func(t *testing.T) {\n  1047â†’\t\t\tassert.Equal(t, tt.present, lessonAlreadyPresent(tt.prompt, tt.lesson))\n  1048â†’\t\t})\n  1049â†’\t}\n  1050â†’}\n  1051â†’\n  1052â†’func TestCuratorSkipsWhenLessonAlreadyPresent(t *testing.T) {\n  1053â†’\tdir := t.TempDir()\n  1054â†’\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n  1055â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n  1056â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n  1057â†’\n  1058â†’\t// Prompt already contains the lesson insight\n  1059â†’\tos.WriteFile(promptPath, []byte(\"# Prompt\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"), 0644)\n  1060â†’\n  1061â†’\t// LLM should NOT be called â€” use a response that would change the file\n  1062â†’\tllm := &fakeLLM{response: \"THIS SHOULD NOT APPEAR\"}\n  1063â†’\taudit := &AuditLogger{ProjectDir: dir}\n  1064â†’\tc := &Curator{LLM: llm, Audit: audit}\n  1065â†’\tlesson := &Lesson{\n  1066â†’\t\tTarget:          \".cloche/prompts/implement.md\",\n  1067â†’\t\tInsight:         \"Always sanitize user inputs\",\n  1068â†’\t\tSuggestedAction: \"Add sanitization rule\",\n  1069â†’\t}\n  1070â†’\n  1071â†’\tchange, err := c.Apply(context.Background(), dir, lesson)\n  1072â†’\trequire.NoError(t, err)\n  1073â†’\tassert.Nil(t, change, \"should return nil change when lesson already present\")\n  1074â†’\n  1075â†’\t// File should be unchanged\n  1076â†’\tcontent, _ := os.ReadFile(promptPath)\n  1077â†’\tassert.NotContains(t, string(content), \"THIS SHOULD NOT APPEAR\")\n  1078â†’}\n  1079â†’\n  1080â†’func TestReflectorFiltersAlreadyAppliedLessons(t *testing.T) {\n  1081â†’\tlessonsJSON, _ := json.Marshal(map[string]any{\n  1082â†’\t\t\"lessons\": []map[string]any{\n  1083â†’\t\t\t{\"id\": \"lesson-001\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n  1084â†’\t\t\t{\"id\": \"lesson-002\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n  1085â†’\t\t},\n  1086â†’\t})\n  1087â†’\n  1088â†’\tllm := &fakeLLM{response: string(lessonsJSON)}\n  1089â†’\tr := &Reflector{LLM: llm, MinConfidence: \"low\"}\n  1090â†’\n  1091â†’\t// Knowledge base already contains lesson-001\n  1092â†’\tdata := &CollectedData{\n  1093â†’\t\tKnowledgeBase: \"# Knowledge Base\\n\\n- **[lesson-001]** (prompt_improvement, confidence: high) Old insight\\n\",\n  1094â†’\t}\n  1095â†’\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n  1096â†’\trequire.NoError(t, err)\n  1097â†’\trequire.Len(t, lessons, 1)\n  1098â†’\tassert.Equal(t, \"lesson-002\", lessons[0].ID)\n  1099â†’}\n  1100â†’\n  1101â†’func TestOrchestratorSkipsAlreadyAppliedLessons(t *testing.T) {\n  1102â†’\tdir := t.TempDir()\n  1103â†’\n  1104â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n  1105â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n  1106â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.jsonl\"),\n  1107â†’\t\t[]byte(`{\"id\":\"L001\",\"category\":\"prompt_improvement\",\"insight\":\"XSS pattern\",\"suggested_action\":\"Add sanitization\",\"confidence\":\"high\"}`+\"\\n\"), 0644)\n  1108â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n  1109â†’\t\t[]byte(\"Write good code.\\n\"), 0644)\n  1110â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n  1111â†’\t\t[]byte(`workflow \"develop\" {\n  1112â†’  step s {\n  1113â†’    run = \"echo hi\"\n  1114â†’    results = [success]\n  1115â†’  }\n  1116â†’  s:success -> done\n  1117â†’}`), 0644)\n  1118â†’\n  1119â†’\t// Reflector returns a lesson that's already in the knowledge base\n  1120â†’\tllm := &scriptedLLM{\n  1121â†’\t\tresponses: []string{\n  1122â†’\t\t\t`{\"classification\": \"bug\"}`,\n  1123â†’\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n  1124â†’\t\t},\n  1125â†’\t}\n  1126â†’\n  1127â†’\torch := NewOrchestrator(OrchestratorConfig{\n  1128â†’\t\tProjectDir:    dir,\n  1129â†’\t\tWorkflowName:  \"develop\",\n  1130â†’\t\tLLM:           llm,\n  1131â†’\t\tMinConfidence: \"low\",\n  1132â†’\t})\n  1133â†’\n  1134â†’\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n  1135â†’\trequire.NoError(t, err)\n  1136â†’\tassert.Empty(t, result.Changes, \"should produce zero changes for already-applied lesson\")\n  1137â†’}\n  1138â†’\n  1139â†’func TestOrchestratorSecondRunProducesNoChanges(t *testing.T) {\n  1140â†’\tdir := t.TempDir()\n  1141â†’\n  1142â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n  1143â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n  1144â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n  1145â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n  1146â†’\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n  1147â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n  1148â†’\t\t[]byte(\"Write good code.\\n\"), 0644)\n  1149â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n  1150â†’\t\t[]byte(`workflow \"develop\" {\n  1151â†’  step implement {\n  1152â†’    prompt = file(\".cloche/prompts/implement.md\")\n  1153â†’    results = [success, fail]\n  1154â†’  }\n  1155â†’  implement:success -> done\n  1156â†’  implement:fail -> abort\n  1157â†’}`), 0644)\n  1158â†’\n  1159â†’\t// First run: lesson gets applied\n  1160â†’\tllm1 := &scriptedLLM{\n  1161â†’\t\tresponses: []string{\n  1162â†’\t\t\t`{\"classification\": \"bug\"}`,\n  1163â†’\t\t\t`{\"lessons\": [{\"id\": \"L010\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Always sanitize user inputs\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n  1164â†’\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n  1165â†’\t\t},\n  1166â†’\t}\n  1167â†’\n  1168â†’\torch1 := NewOrchestrator(OrchestratorConfig{\n  1169â†’\t\tProjectDir:    dir,\n  1170â†’\t\tWorkflowName:  \"develop\",\n  1171â†’\t\tLLM:           llm1,\n  1172â†’\t\tMinConfidence: \"low\",\n  1173â†’\t})\n  1174â†’\n  1175â†’\tresult1, err := orch1.Run(context.Background(), \"run-1\", nil, nil)\n  1176â†’\trequire.NoError(t, err)\n  1177â†’\trequire.Len(t, result1.Changes, 1, \"first run should produce one change\")\n  1178â†’\n  1179â†’\t// Second run: same lesson ID â€” the knowledge base now contains L010,\n  1180â†’\t// and the prompt contains the insight text.\n  1181â†’\tllm2 := &scriptedLLM{\n  1182â†’\t\tresponses: []string{\n  1183â†’\t\t\t`{\"classification\": \"bug\"}`,\n  1184â†’\t\t\t`{\"lessons\": [{\"id\": \"L010\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Always sanitize user inputs\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n  1185â†’\t\t},\n  1186â†’\t}\n  1187â†’\n  1188â†’\torch2 := NewOrchestrator(OrchestratorConfig{\n  1189â†’\t\tProjectDir:    dir,\n  1190â†’\t\tWorkflowName:  \"develop\",\n  1191â†’\t\tLLM:           llm2,\n  1192â†’\t\tMinConfidence: \"low\",\n  1193â†’\t})\n  1194â†’\n  1195â†’\tresult2, err := orch2.Run(context.Background(), \"run-2\", nil, nil)\n  1196â†’\trequire.NoError(t, err)\n  1197â†’\tassert.Empty(t, result2.Changes, \"second run should produce zero changes\")\n  1198â†’}\n  1199â†’"}]},"parent_tool_use_id":"toolu_01DimqXp4JMZuAnP1BLHUN3i","session_id":"2c9bf61f-09a1-44ad-b826-f3dc460a4b97","uuid":"652db7e1-22ec-4ebe-88be-60be8e86f5f7","timestamp":"2026-03-17T