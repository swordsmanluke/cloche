{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FN7Xpcp4k6e3Z51fpyFsgG","type":"tool_result","content":"     1â†’package evolution\n     2â†’\n     3â†’import (\n     4â†’\t\"context\"\n     5â†’\t\"encoding/json\"\n     6â†’\t\"fmt\"\n     7â†’\t\"os\"\n     8â†’\t\"path/filepath\"\n     9â†’\t\"strings\"\n    10â†’\t\"testing\"\n    11â†’\n    12â†’\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    13â†’\t\"github.com/stretchr/testify/assert\"\n    14â†’\t\"github.com/stretchr/testify/require\"\n    15â†’)\n    16â†’\n    17â†’// fakeLLM returns a fixed response for testing.\n    18â†’type fakeLLM struct {\n    19â†’\tresponse string\n    20â†’}\n    21â†’\n    22â†’func (f *fakeLLM) Complete(ctx context.Context, system, user string) (string, error) {\n    23â†’\treturn f.response, nil\n    24â†’}\n    25â†’\n    26â†’// --- Collector tests ---\n    27â†’\n    28â†’func TestCollectorGathersData(t *testing.T) {\n    29â†’\tdir := t.TempDir()\n    30â†’\n    31â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n    32â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n    33â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.jsonl\"),\n    34â†’\t\t[]byte(`{\"id\":\"L000\",\"insight\":\"existing lesson\"}`+\"\\n\"), 0644)\n    35â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n    36â†’\t\t[]byte(\"Write good code\"), 0644)\n    37â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n    38â†’\t\t[]byte(`workflow \"develop\" {\n    39â†’  step impl {\n    40â†’    prompt = file(\".cloche/prompts/implement.md\")\n    41â†’    results = [success]\n    42â†’  }\n    43â†’  impl:success -> done\n    44â†’}`), 0644)\n    45â†’\n    46â†’\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n    47â†’\tdata, err := c.Collect(context.Background(), nil, nil)\n    48â†’\trequire.NoError(t, err)\n    49â†’\n    50â†’\tassert.Contains(t, data.KnowledgeBase, \"existing lesson\")\n    51â†’\tassert.Contains(t, data.CurrentPrompts, \".cloche/prompts/implement.md\")\n    52â†’\tassert.Equal(t, \"Write good code\", data.CurrentPrompts[\".cloche/prompts/implement.md\"])\n    53â†’\tassert.NotEmpty(t, data.CurrentWorkflow)\n    54â†’\tassert.Equal(t, dir, data.ProjectDir)\n    55â†’\tassert.Equal(t, \"develop\", data.WorkflowName)\n    56â†’}\n    57â†’\n    58â†’func TestCollectorNoKnowledgeBase(t *testing.T) {\n    59â†’\tdir := t.TempDir()\n    60â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n    61â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n    62â†’\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n    63â†’\n    64â†’\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n    65â†’\tdata, err := c.Collect(context.Background(), nil, nil)\n    66â†’\trequire.NoError(t, err)\n    67â†’\tassert.Empty(t, data.KnowledgeBase)\n    68â†’}\n    69â†’\n    70â†’func TestExtractPromptFiles(t *testing.T) {\n    71â†’\tworkflow := `step impl { prompt = file(\".cloche/prompts/implement.md\") }\n    72â†’step fix { prompt = file(\".cloche/prompts/fix.md\") }\n    73â†’step test { run = \"make test\" }`\n    74â†’\n    75â†’\tfiles := extractPromptFiles(workflow)\n    76â†’\tassert.Len(t, files, 2)\n    77â†’\tassert.Contains(t, files, \".cloche/prompts/implement.md\")\n    78â†’\tassert.Contains(t, files, \".cloche/prompts/fix.md\")\n    79â†’}\n    80â†’\n    81â†’// --- Classifier tests ---\n    82â†’\n    83â†’func TestClassifierCategorizesRun(t *testing.T) {\n    84â†’\ttests := []struct {\n    85â†’\t\tname     string\n    86â†’\t\tresponse string\n    87â†’\t\texpected string\n    88â†’\t}{\n    89â†’\t\t{\"bug\", `{\"classification\": \"bug\"}`, \"bug\"},\n    90â†’\t\t{\"feature\", `{\"classification\": \"feature\"}`, \"feature\"},\n    91â†’\t\t{\"feedback\", `{\"classification\": \"feedback\"}`, \"feedback\"},\n    92â†’\t\t{\"enhancement\", `{\"classification\": \"enhancement\"}`, \"enhancement\"},\n    93â†’\t\t{\"chore\", `{\"classification\": \"chore\"}`, \"chore\"},\n    94â†’\t\t{\"invalid defaults to feature\", `{\"classification\": \"unknown\"}`, \"feature\"},\n    95â†’\t\t{\"malformed JSON defaults to feature\", `not json`, \"feature\"},\n    96â†’\t}\n    97â†’\n    98â†’\tfor _, tt := range tests {\n    99â†’\t\tt.Run(tt.name, func(t *testing.T) {\n   100â†’\t\t\tllm := &fakeLLM{response: tt.response}\n   101â†’\t\t\tc := &Classifier{LLM: llm}\n   102â†’\t\t\tresult, err := c.Classify(context.Background(), \"some prompt\")\n   103â†’\t\t\trequire.NoError(t, err)\n   104â†’\t\t\tassert.Equal(t, tt.expected, result)\n   105â†’\t\t})\n   106â†’\t}\n   107â†’}\n   108â†’\n   109â†’// --- Reflector tests ---\n   110â†’\n   111â†’func TestReflectorExtractsLessons(t *testing.T) {\n   112â†’\tlessonsJSON, _ := json.Marshal(map[string]any{\n   113â†’\t\t\"lessons\": []map[string]any{\n   114â†’\t\t\t{\n   115â†’\t\t\t\t\"id\":               \"lesson-001\",\n   116â†’\t\t\t\t\"category\":         \"prompt_improvement\",\n   117â†’\t\t\t\t\"target\":           \".cloche/prompts/implement.md\",\n   118â†’\t\t\t\t\"insight\":          \"Agent produces unsanitized HTML\",\n   119â†’\t\t\t\t\"suggested_action\": \"Add sanitization rule\",\n   120â†’\t\t\t\t\"evidence\":         []string{\"run-1\", \"run-2\"},\n   121â†’\t\t\t\t\"confidence\":       \"high\",\n   122â†’\t\t\t},\n   123â†’\t\t},\n   124â†’\t})\n   125â†’\n   126â†’\tllm := &fakeLLM{response: string(lessonsJSON)}\n   127â†’\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n   128â†’\n   129â†’\tdata := &CollectedData{WorkflowName: \"develop\", KnowledgeBase: \"# KB\\n\"}\n   130â†’\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n   131â†’\trequire.NoError(t, err)\n   132â†’\trequire.Len(t, lessons, 1)\n   133â†’\tassert.Equal(t, \"prompt_improvement\", lessons[0].Category)\n   134â†’\tassert.Equal(t, \"high\", lessons[0].Confidence)\n   135â†’}\n   136â†’\n   137â†’func TestReflectorFiltersLowConfidence(t *testing.T) {\n   138â†’\tlessonsJSON, _ := json.Marshal(map[string]any{\n   139â†’\t\t\"lessons\": []map[string]any{\n   140â†’\t\t\t{\"id\": \"L1\", \"category\": \"new_step\", \"confidence\": \"low\"},\n   141â†’\t\t\t{\"id\": \"L2\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n   142â†’\t\t},\n   143â†’\t})\n   144â†’\n   145â†’\tllm := &fakeLLM{response: string(lessonsJSON)}\n   146â†’\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n   147â†’\n   148â†’\tlessons, err := r.Reflect(context.Background(), &CollectedData{}, \"bug\")\n   149â†’\trequire.NoError(t, err)\n   150â†’\tassert.Len(t, lessons, 1)\n   151â†’\tassert.Equal(t, \"L2\", lessons[0].ID)\n   152â†’}\n   153â†’\n   154â†’func TestConfidenceLevel(t *testing.T) {\n   155â†’\tassert.Equal(t, 3, confidenceLevel(\"high\"))\n   156â†’\tassert.Equal(t, 2, confidenceLevel(\"medium\"))\n   157â†’\tassert.Equal(t, 1, confidenceLevel(\"low\"))\n   158â†’\tassert.Equal(t, 0, confidenceLevel(\"\"))\n   159â†’}\n   160â†’\n   161â†’// --- Audit Logger tests ---\n   162â†’\n   163â†’func TestAuditLoggerAppendsJSONL(t *testing.T) {\n   164â†’\tdir := t.TempDir()\n   165â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\"), 0755)\n   166â†’\n   167â†’\tlogger := &AuditLogger{ProjectDir: dir}\n   168â†’\n   169â†’\tresult1 := &EvolutionResult{\n   170â†’\t\tID:           \"evo-1\",\n   171â†’\t\tWorkflowName: \"develop\",\n   172â†’\t\tChanges:      []Change{{Type: \"prompt_update\", File: \".cloche/prompts/impl.md\"}},\n   173â†’\t}\n   174â†’\trequire.NoError(t, logger.Log(result1))\n   175â†’\n   176â†’\tresult2 := &EvolutionResult{\n   177â†’\t\tID:           \"evo-2\",\n   178â†’\t\tWorkflowName: \"develop\",\n   179â†’\t\tChanges:      []Change{{Type: \"add_step\", File: \".cloche/develop.cloche\"}},\n   180â†’\t}\n   181â†’\trequire.NoError(t, logger.Log(result2))\n   182â†’\n   183â†’\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n   184â†’\trequire.NoError(t, err)\n   185â†’\n   186â†’\tlines := strings.Split(strings.TrimSpace(string(content)), \"\\n\")\n   187â†’\tassert.Len(t, lines, 2)\n   188â†’\n   189â†’\tvar entry1 EvolutionResult\n   190â†’\trequire.NoError(t, json.Unmarshal([]byte(lines[0]), &entry1))\n   191â†’\tassert.Equal(t, \"evo-1\", entry1.ID)\n   192â†’}\n   193â†’\n   194â†’func TestAuditLoggerSnapshot(t *testing.T) {\n   195â†’\tdir := t.TempDir()\n   196â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   197â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   198â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"original content\"), 0644)\n   199â†’\n   200â†’\tlogger := &AuditLogger{ProjectDir: dir}\n   201â†’\tsnapName, err := logger.Snapshot(\".cloche/prompts/implement.md\")\n   202â†’\trequire.NoError(t, err)\n   203â†’\tassert.NotEmpty(t, snapName)\n   204â†’\n   205â†’\tsnapPath := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\", snapName)\n   206â†’\tcontent, err := os.ReadFile(snapPath)\n   207â†’\trequire.NoError(t, err)\n   208â†’\tassert.Equal(t, \"original content\", string(content))\n   209â†’}\n   210â†’\n   211â†’func TestAuditLoggerUpdatesKnowledge(t *testing.T) {\n   212â†’\tdir := t.TempDir()\n   213â†’\tkbDir := filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\")\n   214â†’\tos.MkdirAll(kbDir, 0755)\n   215â†’\n   216â†’\tlogger := &AuditLogger{ProjectDir: dir}\n   217â†’\tlessons := []Lesson{\n   218â†’\t\t{\n   219â†’\t\t\tID:              \"P001\",\n   220â†’\t\t\tCategory:        \"prompt_improvement\",\n   221â†’\t\t\tConfidence:      \"high\",\n   222â†’\t\t\tInsight:         \"Always sanitize HTML inputs\",\n   223â†’\t\t\tSuggestedAction: \"Add rule to implement prompt\",\n   224â†’\t\t\tEvidence:        []string{\"run-1\", \"run-2\"},\n   225â†’\t\t},\n   226â†’\t}\n   227â†’\n   228â†’\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", lessons))\n   229â†’\n   230â†’\tcontent, err := os.ReadFile(filepath.Join(kbDir, \"develop.jsonl\"))\n   231â†’\trequire.NoError(t, err)\n   232â†’\tassert.Contains(t, string(content), \"P001\")\n   233â†’\tassert.Contains(t, string(content), \"sanitize HTML\")\n   234â†’\tassert.Contains(t, string(content), \"run-1\")\n   235â†’}\n   236â†’\n   237â†’func TestAuditLoggerDeduplicatesLessons(t *testing.T) {\n   238â†’\tdir := t.TempDir()\n   239â†’\tlogger := &AuditLogger{ProjectDir: dir}\n   240â†’\n   241â†’\tlesson := Lesson{\n   242â†’\t\tID:       \"L001\",\n   243â†’\t\tCategory: \"prompt_improvement\",\n   244â†’\t\tInsight:  \"Original insight\",\n   245â†’\t}\n   246â†’\n   247â†’\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{lesson}))\n   248â†’\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{lesson}))\n   249â†’\n   250â†’\t// Read back and verify only one entry\n   251â†’\tlessons, err := readKnowledge(logger.KnowledgePath(\"develop\"))\n   252â†’\trequire.NoError(t, err)\n   253â†’\tassert.Len(t, lessons, 1)\n   254â†’\tassert.Equal(t, \"L001\", lessons[0].ID)\n   255â†’}\n   256â†’\n   257â†’func TestAuditLoggerUpdatesExistingLesson(t *testing.T) {\n   258â†’\tdir := t.TempDir()\n   259â†’\tlogger := &AuditLogger{ProjectDir: dir}\n   260â†’\n   261â†’\toriginal := Lesson{ID: \"L001\", Insight: \"Original insight\"}\n   262â†’\tupdated := Lesson{ID: \"L001\", Insight: \"Updated insight\"}\n   263â†’\n   264â†’\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{original}))\n   265â†’\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{updated}))\n   266â†’\n   267â†’\tlessons, err := readKnowledge(logger.KnowledgePath(\"develop\"))\n   268â†’\trequire.NoError(t, err)\n   269â†’\tassert.Len(t, lessons, 1)\n   270â†’\tassert.Equal(t, \"Updated insight\", lessons[0].Insight)\n   271â†’}\n   272â†’\n   273â†’func TestAuditLoggerPrunesWithMaxPromptBullets(t *testing.T) {\n   274â†’\tdir := t.TempDir()\n   275â†’\tlogger := &AuditLogger{ProjectDir: dir, MaxPromptBullets: 5}\n   276â†’\n   277â†’\t// Add 10 lessons\n   278â†’\tfor i := 0; i < 10; i++ {\n   279â†’\t\tlesson := Lesson{\n   280â†’\t\t\tID:      fmt.Sprintf(\"L%03d\", i),\n   281â†’\t\t\tInsight: fmt.Sprintf(\"Insight %d\", i),\n   282â†’\t\t}\n   283â†’\t\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{lesson}))\n   284â†’\t}\n   285â†’\n   286â†’\tlessons, err := readKnowledge(logger.KnowledgePath(\"develop\"))\n   287â†’\trequire.NoError(t, err)\n   288â†’\tassert.Len(t, lessons, 5)\n   289â†’\t// Should keep the most recent 5 (L005-L009)\n   290â†’\tassert.Equal(t, \"L005\", lessons[0].ID)\n   291â†’\tassert.Equal(t, \"L009\", lessons[4].ID)\n   292â†’}\n   293â†’\n   294â†’// --- LLM Client tests ---\n   295â†’\n   296â†’// --- Curator tests ---\n   297â†’\n   298â†’func TestCuratorUpdatesPrompt(t *testing.T) {\n   299â†’\tdir := t.TempDir()\n   300â†’\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   301â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   302â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   303â†’\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   304â†’\n   305â†’\tupdatedContent := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"\n   306â†’\tllm := &fakeLLM{response: updatedContent}\n   307â†’\n   308â†’\taudit := &AuditLogger{ProjectDir: dir}\n   309â†’\tc := &Curator{LLM: llm, Audit: audit}\n   310â†’\tlesson := &Lesson{\n   311â†’\t\tID:              \"lesson-001\",\n   312â†’\t\tCategory:        \"prompt_improvement\",\n   313â†’\t\tTarget:          \".cloche/prompts/implement.md\",\n   314â†’\t\tInsight:         \"XSS vulnerabilities in form handlers\",\n   315â†’\t\tSuggestedAction: \"Add sanitization rule\",\n   316â†’\t}\n   317â†’\n   318â†’\tchange, err := c.Apply(context.Background(), dir, lesson)\n   319â†’\trequire.NoError(t, err)\n   320â†’\tassert.Equal(t, \"prompt_update\", change.Type)\n   321â†’\tassert.Equal(t, \".cloche/prompts/implement.md\", change.File)\n   322â†’\tassert.NotEmpty(t, change.Snapshot)\n   323â†’\n   324â†’\tcontent, err := os.ReadFile(promptPath)\n   325â†’\trequire.NoError(t, err)\n   326â†’\tassert.Contains(t, string(content), \"sanitize user inputs\")\n   327â†’}\n   328â†’\n   329â†’// --- stripCodeFences tests ---\n   330â†’\n   331â†’func TestStripCodeFences(t *testing.T) {\n   332â†’\ttests := []struct {\n   333â†’\t\tname     string\n   334â†’\t\tinput    string\n   335â†’\t\texpected string\n   336â†’\t}{\n   337â†’\t\t{\n   338â†’\t\t\tname:     \"no fences returns as-is\",\n   339â†’\t\t\tinput:    \"# Prompt\\n\\nDo good work.\\n\",\n   340â†’\t\t\texpected: \"# Prompt\\n\\nDo good work.\",\n   341â†’\t\t},\n   342â†’\t\t{\n   343â†’\t\t\tname:     \"plain code fence\",\n   344â†’\t\t\tinput:    \"```\\n# Prompt\\n\\nDo good work.\\n```\",\n   345â†’\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   346â†’\t\t},\n   347â†’\t\t{\n   348â†’\t\t\tname:     \"code fence with language hint\",\n   349â†’\t\t\tinput:    \"```markdown\\n# Prompt\\n\\nDo good work.\\n```\",\n   350â†’\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   351â†’\t\t},\n   352â†’\t\t{\n   353â†’\t\t\tname:     \"commentary before and after fence\",\n   354â†’\t\t\tinput:    \"Here's the updated prompt:\\n\\n```markdown\\n# Prompt\\n\\nDo good work.\\n```\\n\\nI've added the rule as requested.\",\n   355â†’\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   356â†’\t\t},\n   357â†’\t\t{\n   358â†’\t\t\tname:     \"no closing fence returns as-is\",\n   359â†’\t\t\tinput:    \"```markdown\\n# Prompt\\n\",\n   360â†’\t\t\texpected: \"```markdown\\n# Prompt\",\n   361â†’\t\t},\n   362â†’\t}\n   363â†’\n   364â†’\tfor _, tt := range tests {\n   365â†’\t\tt.Run(tt.name, func(t *testing.T) {\n   366â†’\t\t\tassert.Equal(t, tt.expected, stripCodeFences(tt.input))\n   367â†’\t\t})\n   368â†’\t}\n   369â†’}\n   370â†’\n   371â†’func TestCuratorStripsCodeFencesFromResponse(t *testing.T) {\n   372â†’\tdir := t.TempDir()\n   373â†’\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   374â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   375â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   376â†’\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   377â†’\n   378â†’\t// LLM returns content wrapped in code fences with commentary\n   379â†’\tfencedResponse := \"Here is the updated prompt:\\n\\n```markdown\\n# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n```\\n\\nI added the validation rule.\"\n   380â†’\tllm := &fakeLLM{response: fencedResponse}\n   381â†’\n   382â†’\taudit := &AuditLogger{ProjectDir: dir}\n   383â†’\tc := &Curator{LLM: llm, Audit: audit}\n   384â†’\tlesson := &Lesson{\n   385â†’\t\tTarget:          \".cloche/prompts/implement.md\",\n   386â†’\t\tInsight:         \"Missing input validation\",\n   387â†’\t\tSuggestedAction: \"Add validation rule\",\n   388â†’\t}\n   389â†’\n   390â†’\t_, err := c.Apply(context.Background(), dir, lesson)\n   391â†’\trequire.NoError(t, err)\n   392â†’\n   393â†’\tcontent, err := os.ReadFile(promptPath)\n   394â†’\trequire.NoError(t, err)\n   395â†’\n   396â†’\t// Should contain the actual prompt content, not the commentary\n   397â†’\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   398â†’\tassert.Contains(t, string(content), \"Always validate inputs\")\n   399â†’\tassert.NotContains(t, string(content), \"Here is the updated prompt\")\n   400â†’\tassert.NotContains(t, string(content), \"I added the validation rule\")\n   401â†’\tassert.NotContains(t, string(content), \"```\")\n   402â†’}\n   403â†’\n   404â†’func TestCuratorRejectsConversationalMetaText(t *testing.T) {\n   405â†’\tdir := t.TempDir()\n   406â†’\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"fix.md\")\n   407â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   408â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   409â†’\toriginal := \"# Fix Prompt\\n\\nFix bugs carefully.\\n\"\n   410â†’\tos.WriteFile(promptPath, []byte(original), 0644)\n   411â†’\n   412â†’\t// LLM returns conversational meta-text\n   413â†’\tllm := &fakeLLM{response: \"I need write permission to update the file. Could you grant access to .cloche/prompts/fix.md?\"}\n   414â†’\taudit := &AuditLogger{ProjectDir: dir}\n   415â†’\tc := &Curator{LLM: llm, Audit: audit}\n   416â†’\tlesson := &Lesson{\n   417â†’\t\tTarget:          \".cloche/prompts/fix.md\",\n   418â†’\t\tInsight:         \"Missing error context\",\n   419â†’\t\tSuggestedAction: \"Wrap errors with context\",\n   420â†’\t}\n   421â†’\n   422â†’\t_, err := c.Apply(context.Background(), dir, lesson)\n   423â†’\trequire.NoError(t, err)\n   424â†’\n   425â†’\tcontent, err := os.ReadFile(promptPath)\n   426â†’\trequire.NoError(t, err)\n   427â†’\t// Must NOT contain the conversational text\n   428â†’\tassert.NotContains(t, string(content), \"I need write permission\")\n   429â†’\tassert.NotContains(t, string(content), \"Could you grant access\")\n   430â†’\t// Should contain the original content and the lesson appended directly\n   431â†’\tassert.Contains(t, string(content), \"# Fix Prompt\")\n   432â†’\tassert.Contains(t, string(content), \"Missing error context\")\n   433â†’}\n   434â†’\n   435â†’func TestCuratorRejectsUnfencedConversationalPrefix(t *testing.T) {\n   436â†’\tdir := t.TempDir()\n   437â†’\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   438â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   439â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   440â†’\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n   441â†’\tos.WriteFile(promptPath, []byte(original), 0644)\n   442â†’\n   443â†’\t// LLM returns \"Here is the updated prompt:\" with NO code fences\n   444â†’\tllm := &fakeLLM{response: \"Here is the updated prompt:\\n\\n# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Validate inputs\\n\"}\n   445â†’\taudit := &AuditLogger{ProjectDir: dir}\n   446â†’\tc := &Curator{LLM: llm, Audit: audit}\n   447â†’\tlesson := &Lesson{\n   448â†’\t\tTarget:          \".cloche/prompts/implement.md\",\n   449â†’\t\tInsight:         \"Missing validation\",\n   450â†’\t\tSuggestedAction: \"Add input validation\",\n   451â†’\t}\n   452â†’\n   453â†’\t_, err := c.Apply(context.Background(), dir, lesson)\n   454â†’\trequire.NoError(t, err)\n   455â†’\n   456â†’\tcontent, err := os.ReadFile(promptPath)\n   457â†’\trequire.NoError(t, err)\n   458â†’\t// The conversational prefix must not appear\n   459â†’\tassert.NotContains(t, string(content), \"Here is the updated prompt\")\n   460â†’\t// Original content preserved, lesson appended via fallback\n   461â†’\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   462â†’\tassert.Contains(t, string(content), \"Missing validation\")\n   463â†’}\n   464â†’\n   465â†’func TestCuratorAcceptsValidPromptWithoutFences(t *testing.T) {\n   466â†’\tdir := t.TempDir()\n   467â†’\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   468â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   469â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   470â†’\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   471â†’\n   472â†’\t// LLM returns valid prompt content without code fences\n   473â†’\tvalidResponse := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n\"\n   474â†’\tllm := &fakeLLM{response: validResponse}\n   475â†’\taudit := &AuditLogger{ProjectDir: dir}\n   476â†’\tc := &Curator{LLM: llm, Audit: audit}\n   477â†’\tlesson := &Lesson{\n   478â†’\t\tTarget:          \".cloche/prompts/implement.md\",\n   479â†’\t\tInsight:         \"Missing validation\",\n   480â†’\t\tSuggestedAction: \"Add validation rule\",\n   481â†’\t}\n   482â†’\n   483â†’\t_, err := c.Apply(context.Background(), dir, lesson)\n   484â†’\trequire.NoError(t, err)\n   485â†’\n   486â†’\tcontent, err := os.ReadFile(promptPath)\n   487â†’\trequire.NoError(t, err)\n   488â†’\t// Should write the LLM response (after stripCodeFences trimming) since it's valid prompt content\n   489â†’\tassert.Contains(t, string(content), \"Always validate inputs\")\n   490â†’\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   491â†’\tassert.NotContains(t, string(content), \"Missing validation\")\n   492â†’}\n   493â†’\n   494â†’func TestIsConversationalResponse(t *testing.T) {\n   495â†’\ttests := []struct {\n   496â†’\t\tname     string\n   497â†’\t\tinput    string\n   498â†’\t\texpected bool\n   499â†’\t}{\n   500â†’\t\t{\"permission request\", \"I need write permission to update the file\", true},\n   501â†’\t\t{\"grant request\", \"Could you grant access to the file?\", true},\n   502â†’\t\t{\"blocked message\", \"Permission blocked by sandbox\", true},\n   503â†’\t\t{\"here is updated\", \"Here is the updated prompt:\\n\\n# Prompt\", true},\n   504â†’\t\t{\"heres updated\", \"Here's the updated prompt:\\n\\n# Prompt\", true},\n   505â†’\t\t{\"ive updated\", \"I've updated the prompt with the new rule\", true},\n   506â†’\t\t{\"let me\", \"Let me update the file for you\", true},\n   507â†’\t\t{\"valid markdown heading\", \"# Prompt\\n\\nDo good work.\", false},\n   508â†’\t\t{\"valid bullet list\", \"- Rule one\\n- Rule two\", false},\n   509â†’\t\t{\"empty string\", \"\", true},\n   510â†’\t\t{\"valid content no heading\", \"Write good code and test everything.\", false},\n   511â†’\t}\n   512â†’\n   513â†’\tfor _, tt := range tests {\n   514â†’\t\tt.Run(tt.name, func(t *testing.T) {\n   515â†’\t\t\tassert.Equal(t, tt.expected, isConversationalResponse(tt.input))\n   516â†’\t\t})\n   517â†’\t}\n   518â†’}\n   519â†’\n   520â†’func TestAppendLessonDirectly(t *testing.T) {\n   521â†’\tt.Run(\"creates learned rules section\", func(t *testing.T) {\n   522â†’\t\tresult := appendLessonDirectly(\"# Prompt\\n\\nDo good work.\\n\", &Lesson{\n   523â†’\t\t\tInsight:         \"Missing validation\",\n   524â†’\t\t\tSuggestedAction: \"Add validation\",\n   525â†’\t\t})\n   526â†’\t\tassert.Contains(t, result, \"## Learned Rules\")\n   527â†’\t\tassert.Contains(t, result, \"Missing validation: Add validation\")\n   528â†’\t})\n   529â†’\n   530â†’\tt.Run(\"appends to existing learned rules\", func(t *testing.T) {\n   531â†’\t\texisting := \"# Prompt\\n\\n## Learned Rules\\n\\n- Existing rule\\n\"\n   532â†’\t\tresult := appendLessonDirectly(existing, &Lesson{\n   533â†’\t\t\tInsight:         \"New insight\",\n   534â†’\t\t\tSuggestedAction: \"New action\",\n   535â†’\t\t})\n   536â†’\t\tassert.Contains(t, result, \"- Existing rule\")\n   537â†’\t\tassert.Contains(t, result, \"- New insight: New action\")\n   538â†’\t\t// Should not create a duplicate section\n   539â†’\t\tassert.Equal(t, 1, strings.Count(result, \"## Learned Rules\"))\n   540â†’\t})\n   541â†’}\n   542â†’\n   543â†’// --- Script Generator tests ---\n   544â†’\n   545â†’func TestScriptGeneratorCreatesScript(t *testing.T) {\n   546â†’\tdir := t.TempDir()\n   547â†’\n   548â†’\tllm := &fakeLLM{response: `{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`}\n   549â†’\tg := &ScriptGenerator{LLM: llm}\n   550â†’\n   551â†’\tlesson := &Lesson{\n   552â†’\t\tID:              \"lesson-001\",\n   553â†’\t\tCategory:        \"new_step\",\n   554â†’\t\tStepType:        \"script\",\n   555â†’\t\tInsight:         \"No security scanning\",\n   556â†’\t\tSuggestedAction: \"Add gosec security scan\",\n   557â†’\t}\n   558â†’\n   559â†’\tresult, err := g.Generate(context.Background(), dir, lesson)\n   560â†’\trequire.NoError(t, err)\n   561â†’\tassert.Equal(t, \"scripts/security-scan.sh\", result.Path)\n   562â†’\n   563â†’\tcontent, err := os.ReadFile(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n   564â†’\trequire.NoError(t, err)\n   565â†’\tassert.Contains(t, string(content), \"gosec\")\n   566â†’\n   567â†’\tinfo, err := os.Stat(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n   568â†’\trequire.NoError(t, err)\n   569â†’\tassert.Zero(t, info.Mode()&0111) // non-executable; workflow engine handles execution\n   570â†’}\n   571â†’\n   572â†’// --- LLM Client tests ---\n   573â†’\n   574â†’func TestCommandLLMClientPrintMode(t *testing.T) {\n   575â†’\t// Use a shell script that dumps its args and stdin so we can verify\n   576â†’\t// that the client passes the right flags and prompt separation.\n   577â†’\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   578â†’\tos.WriteFile(script, []byte(`#!/bin/sh\n   579â†’echo \"ARGS:$*\"\n   580â†’echo \"STDIN:$(cat)\"\n   581â†’`), 0755)\n   582â†’\n   583â†’\tc := &CommandLLMClient{Command: script, Args: []string{}}\n   584â†’\tresult, err := c.Complete(context.Background(), \"You are a helpful assistant.\", \"Summarize this text\")\n   585â†’\trequire.NoError(t, err)\n   586â†’\n   587â†’\t// Should include -p flag for print/non-interactive mode\n   588â†’\tassert.Contains(t, result, \"-p\")\n   589â†’\n   590â†’\t// Should pass system prompt via --system-prompt flag\n   591â†’\tassert.Contains(t, result, \"--system-prompt\")\n   592â†’\tassert.Contains(t, result, \"You are a helpful assistant.\")\n   593â†’\n   594â†’\t// Should pass --output-format text\n   595â†’\tassert.Contains(t, result, \"--output-format text\")\n   596â†’\n   597â†’\t// Stdin should contain only the user prompt, not the system prompt\n   598â†’\tassert.Contains(t, result, \"STDIN:Summarize this text\")\n   599â†’\tassert.NotContains(t, result, \"STDIN:You are a helpful assistant\")\n   600â†’}\n   601â†’\n   602â†’func TestCommandLLMClientEmptySystemPrompt(t *testing.T) {\n   603â†’\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   604â†’\tos.WriteFile(script, []byte(`#!/bin/sh\n   605â†’echo \"ARGS:$*\"\n   606â†’echo \"STDIN:$(cat)\"\n   607â†’`), 0755)\n   608â†’\n   609â†’\tc := &CommandLLMClient{Command: script, Args: []string{}}\n   610â†’\tresult, err := c.Complete(context.Background(), \"\", \"just user prompt\")\n   611â†’\trequire.NoError(t, err)\n   612â†’\n   613â†’\t// Should NOT include --system-prompt when system prompt is empty\n   614â†’\tassert.NotContains(t, result, \"--system-prompt\")\n   615â†’\t// Should still have -p and --output-format\n   616â†’\tassert.Contains(t, result, \"-p\")\n   617â†’\tassert.Contains(t, result, \"--output-format text\")\n   618â†’\tassert.Contains(t, result, \"STDIN:just user prompt\")\n   619â†’}\n   620â†’\n   621â†’func TestCommandLLMClientExtraArgs(t *testing.T) {\n   622â†’\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   623â†’\tos.WriteFile(script, []byte(`#!/bin/sh\n   624â†’echo \"ARGS:$*\"\n   625â†’echo \"STDIN:$(cat)\"\n   626â†’`), 0755)\n   627â†’\n   628â†’\tc := &CommandLLMClient{Command: script, Args: []string{\"--model\", \"sonnet\"}}\n   629â†’\tresult, err := c.Complete(context.Background(), \"sys\", \"usr\")\n   630â†’\trequire.NoError(t, err)\n   631â†’\n   632â†’\t// Extra args should appear before the appended flags\n   633â†’\tassert.Contains(t, result, \"--model sonnet\")\n   634â†’\tassert.Contains(t, result, \"-p\")\n   635â†’}\n   636â†’\n   637â†’func TestCommandLLMClientDoesNotMutateArgs(t *testing.T) {\n   638â†’\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   639â†’\tos.WriteFile(script, []byte(\"#!/bin/sh\\ncat\\n\"), 0755)\n   640â†’\n   641â†’\toriginal := []string{\"--verbose\"}\n   642â†’\tc := &CommandLLMClient{Command: script, Args: original}\n   643â†’\t_, err := c.Complete(context.Background(), \"sys\", \"usr\")\n   644â†’\trequire.NoError(t, err)\n   645â†’\n   646â†’\t// The original Args slice should not be modified between calls.\n   647â†’\tassert.Equal(t, []string{\"--verbose\"}, original)\n   648â†’}\n   649â†’\n   650â†’// --- Orchestrator tests ---\n   651â†’\n   652â†’// scriptedLLM returns responses in order.\n   653â†’type scriptedLLM struct {\n   654â†’\tresponses []string\n   655â†’\tidx       int\n   656â†’}\n   657â†’\n   658â†’func (s *scriptedLLM) Complete(ctx context.Context, system, user string) (string, error) {\n   659â†’\tresp := s.responses[s.idx]\n   660â†’\ts.idx++\n   661â†’\treturn resp, nil\n   662â†’}\n   663â†’\n   664â†’func TestOrchestratorEndToEnd(t *testing.T) {\n   665â†’\tdir := t.TempDir()\n   666â†’\n   667â†’\t// Set up project structure\n   668â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   669â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   670â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   671â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n   672â†’\t\t[]byte(\"Write good code.\\n\"), 0644)\n   673â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   674â†’\t\t[]byte(`workflow \"develop\" {\n   675â†’  step implement {\n   676â†’    prompt = file(\".cloche/prompts/implement.md\")\n   677â†’    results = [success, fail]\n   678â†’  }\n   679â†’  step test {\n   680â†’    run = \"make test\"\n   681â†’    results = [success, fail]\n   682â†’  }\n   683â†’  implement:success -> test\n   684â†’  test:success -> done\n   685â†’  test:fail -> abort\n   686â†’}`), 0644)\n   687â†’\n   688â†’\t// Fake LLM that returns appropriate responses per stage\n   689â†’\tllm := &scriptedLLM{\n   690â†’\t\tresponses: []string{\n   691â†’\t\t\t// Classifier\n   692â†’\t\t\t`{\"classification\": \"bug\"}`,\n   693â†’\t\t\t// Reflector\n   694â†’\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n   695â†’\t\t\t// Curator\n   696â†’\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n   697â†’\t\t},\n   698â†’\t}\n   699â†’\n   700â†’\torch := NewOrchestrator(OrchestratorConfig{\n   701â†’\t\tProjectDir:    dir,\n   702â†’\t\tWorkflowName:  \"develop\",\n   703â†’\t\tLLM:           llm,\n   704â†’\t\tMinConfidence: \"medium\",\n   705â†’\t})\n   706â†’\n   707â†’\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   708â†’\trequire.NoError(t, err)\n   709â†’\tassert.Equal(t, \"bug\", result.Classification)\n   710â†’\trequire.Len(t, result.Changes, 1)\n   711â†’\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n   712â†’\n   713â†’\t// Verify prompt was actually updated\n   714â†’\tcontent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n   715â†’\tassert.Contains(t, string(content), \"sanitize user inputs\")\n   716â†’\n   717â†’\t// Verify audit log was written\n   718â†’\tlogContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n   719â†’\tassert.Contains(t, string(logContent), \"prompt_update\")\n   720â†’\tassert.Contains(t, string(logContent), \"XSS pattern\")\n   721â†’\n   722â†’\t// Verify knowledge base was updated (JSONL format)\n   723â†’\tkbContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.jsonl\"))\n   724â†’\tassert.Contains(t, string(kbContent), \"L001\")\n   725â†’}\n   726â†’\n   727â†’func TestOrchestratorNewStepWiredIntoGraph(t *testing.T) {\n   728â†’\tdir := t.TempDir()\n   729â†’\n   730â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   731â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   732â†’\t// Knowledge base uses JSONL format (created automatically by UpdateKnowledge)\n   733â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   734â†’\t\t[]byte(`workflow \"develop\" {\n   735â†’  step implement {\n   736â†’    prompt = file(\".cloche/prompts/implement.md\")\n   737â†’    results = [success, fail]\n   738â†’  }\n   739â†’  step test {\n   740â†’    run = \"make test\"\n   741â†’    results = [success, fail]\n   742â†’  }\n   743â†’  implement:success -> test\n   744â†’  implement:fail -> abort\n   745â†’  test:success -> done\n   746â†’  test:fail -> abort\n   747â†’}`), 0644)\n   748â†’\n   749â†’\tllm := &scriptedLLM{\n   750â†’\t\tresponses: []string{\n   751â†’\t\t\t// Classifier\n   752â†’\t\t\t`{\"classification\": \"enhancement\"}`,\n   753â†’\t\t\t// Reflector\n   754â†’\t\t\t`{\"lessons\": [{\"id\": \"L002\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"No security scanning\", \"suggested_action\": \"Add gosec scan\", \"evidence\": [\"run-2\"], \"confidence\": \"high\"}]}`,\n   755â†’\t\t\t// ScriptGenerator\n   756â†’\t\t\t`{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`,\n   757â†’\t\t},\n   758â†’\t}\n   759â†’\n   760â†’\torch := NewOrchestrator(OrchestratorConfig{\n   761â†’\t\tProjectDir:    dir,\n   762â†’\t\tWorkflowName:  \"develop\",\n   763â†’\t\tLLM:           llm,\n   764â†’\t\tMinConfidence: \"medium\",\n   765â†’\t})\n   766â†’\n   767â†’\tresult, err := orch.Run(context.Background(), \"run-2\", nil, nil)\n   768â†’\trequire.NoError(t, err)\n   769â†’\trequire.Len(t, result.Changes, 2) // add_script + add_step\n   770â†’\tassert.Equal(t, \"add_script\", result.Changes[0].Type)\n   771â†’\tassert.Equal(t, \"add_step\", result.Changes[1].Type)\n   772â†’\n   773â†’\t// Read the updated workflow and verify the new step is reachable\n   774â†’\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   775â†’\trequire.NoError(t, err)\n   776â†’\n   777â†’\twfStr := string(wfContent)\n   778â†’\t// The new step should be wired into the graph\n   779â†’\tassert.Contains(t, wfStr, \"step security-scan\")\n   780â†’\t// An existing step should wire to the new step (rewired from -> done)\n   781â†’\tassert.Contains(t, wfStr, \"test:success -> security-scan\")\n   782â†’\t// The new step should wire its results to terminals\n   783â†’\tassert.Contains(t, wfStr, \"security-scan:success -> done\")\n   784â†’\tassert.Contains(t, wfStr, \"security-scan:fail -> abort\")\n   785â†’\n   786â†’\t// Verify the workflow parses and validates\n   787â†’\twf, err := dsl.Parse(wfStr)\n   788â†’\trequire.NoError(t, err)\n   789â†’\trequire.NoError(t, wf.Validate())\n   790â†’}\n   791â†’\n   792â†’func TestHandleNewStepSkipsDuplicate(t *testing.T) {\n   793â†’\tdir := t.TempDir()\n   794â†’\n   795â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   796â†’\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   797â†’\n   798â†’\t// Workflow already contains a step named \"security-scan\"\n   799â†’\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   800â†’\t\t[]byte(`workflow \"develop\" {\n   801â†’  step implement {\n   802â†’    prompt = file(\".cloche/prompts/implement.md\")\n   803â†’    results = [success, fail]\n   804â†’  }\n   805â†’  step security-scan {\n   806â†’    run = \"scripts/security-scan.sh\"\n   807â†’    results = [success, fail]\n   808â†’  }\n   809â†’  implement:success -> security-scan\n   810â†’  implement:fail -> abort\n   811â†’  security-scan:success -> done\n   812â†’  security-scan:fail -> abort\n   813â†’}`), 0644)\n   814â†’\n   815â†’\tllm := &scriptedLLM{\n   816â†’\t\tresponses: []string{\n   817â†’\t\t\t// Classifier\n   818â†’\t\t\t`{\"classification\": \"enhancement\"}`,\n   819â†’\t\t\t// Reflector â€” lesson wants to add \"security-scan\" again\n   820â†’\t\t\t`{\"lessons\": [{\"id\": \"L003\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add security scanning\", \"suggested_action\": \"Add gosec scan\", \"evidence\": [\"run-3\"], \"confidence\": \"high\"}]}`,\n   821â†’\t\t\t// ScriptGenerator\n   822â†’\t\t\t`{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`,\n   823â†’\t\t},\n   824â†’\t}\n   825â†’\n   826â†’\torch := NewOrchestrator(OrchestratorConfig{\n   827â†’\t\tProjectDir:    dir,\n   828â†’\t\tWorkflowName:  \"develop\",\n   829â†’\t\tLLM:           llm,\n   830â†’\t\tMinConfidence: \"medium\",\n   831â†’\t})\n   832â†’\n   833â†’\tresult, err := orch.Run(context.Background(), \"run-3\", nil, nil)\n   834â†’\trequire.NoError(t, err)\n   835â†’\n   836â†’\t// Should have add_script change but NOT add_step (skipped as duplicate)\n   837â†’\tstepChanges := 0\n   838â†’\tfor _, c := range result.Changes {\n   839â†’\t\tif c.Type == \"add_step\" {\n   840â†’\t\t\tstepChanges++\n   841â†’\t\t}\n   842â†’\t}\n   843â†’\tassert.Equal(t, 0, stepChanges, \"should not add a duplicate step\")\n   844â†’\n   845â†’\t// Workflow should be unchanged â€” still valid, no duplicates\n   846â†’\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   847â†’\trequire.NoError(t, err)\n   848â†’\twf, err := dsl.Parse(string(wfContent))\n   849â†’\trequire.NoError(t, err)\n   850â†’\trequire.NoError(t, wf.Validate())\n   851â†’\tassert.Equal(t, 2, len(wf.Steps), \"should still have exactly 2 steps\")\n   852â†’}\n   853â†’\n   854â†’func TestHandleNewStepNoDoneEdge(t *testing.T) {