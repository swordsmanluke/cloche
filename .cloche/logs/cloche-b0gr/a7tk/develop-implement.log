\n    51â†’\t\t},\n    52â†’\t\tEntryStep: \"code\",\n    53â†’\t}\n    54â†’\n    55â†’\terr := wf.Validate()\n    56â†’\trequire.Error(t, err)\n    57â†’\tassert.Contains(t, err.Error(), \"fail\")\n    58â†’}\n    59â†’\n    60â†’func TestWorkflow_Validate_OrphanStep(t *testing.T) {\n    61â†’\twf := &domain.Workflow{\n    62â†’\t\tName: \"test-workflow\",\n    63â†’\t\tSteps: map[string]*domain.Step{\n    64â†’\t\t\t\"code\": {\n    65â†’\t\t\t\tName:    \"code\",\n    66â†’\t\t\t\tType:    domain.StepTypeAgent,\n    67â†’\t\t\t\tResults: []string{\"success\"},\n    68â†’\t\t\t},\n    69â†’\t\t\t\"orphan\": {\n    70â†’\t\t\t\tName:    \"orphan\",\n    71â†’\t\t\t\tType:    domain.StepTypeScript,\n    72â†’\t\t\t\tResults: []string{\"done\"},\n    73â†’\t\t\t},\n    74â†’\t\t},\n    75â†’\t\tWiring: []domain.Wire{\n    76â†’\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n    77â†’\t\t\t{From: \"orphan\", Result: \"done\", To: domain.StepDone},\n    78â†’\t\t},\n    79â†’\t\tEntryStep: \"code\",\n    80â†’\t}\n    81â†’\n    82â†’\terr := wf.Validate()\n    83â†’\trequire.Error(t, err)\n    84â†’\tassert.Contains(t, err.Error(), \"orphan\")\n    85â†’}\n    86â†’\n    87â†’func TestWorkflow_Validate_NoEntryStep(t *testing.T) {\n    88â†’\twf := &domain.Workflow{\n    89â†’\t\tName:      \"test-workflow\",\n    90â†’\t\tSteps:     map[string]*domain.Step{},\n    91â†’\t\tWiring:    []domain.Wire{},\n    92â†’\t\tEntryStep: \"\",\n    93â†’\t}\n    94â†’\n    95â†’\terr := wf.Validate()\n    96â†’\trequire.Error(t, err)\n    97â†’\tassert.Contains(t, err.Error(), \"entry\")\n    98â†’}\n    99â†’\n   100â†’func TestWorkflow_NextSteps(t *testing.T) {"}]},"parent_tool_use_id":"toolu_01DimqXp4JMZuAnP1BLHUN3i","session_id":"2c9bf61f-09a1-44ad-b826-f3dc460a4b97","uuid":"66f98802-0c23-4521-a72c-38ce51914aab","timestamp":"2026-03-17T14:07:56.249Z"}
