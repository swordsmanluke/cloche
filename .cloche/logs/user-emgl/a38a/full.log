n    63→\t\tcmd:        cmd,\n    64→\t\tstdout:     stdout,\n    65→\t\tdone:       make(chan struct{}),\n    66→\t\tprojectDir: cfg.ProjectDir,\n    67→\t}\n    68→\tr.processes[id] = mp\n    69→\tr.mu.Unlock()\n    70→\n    71→\treturn id, nil\n    72→}\n    73→\n    74→func (r *Runtime) Stop(ctx context.Context, containerID string) error {\n    75→\tr.mu.Lock()\n    76→\tmp, ok := r.processes[containerID]\n    77→\tr.mu.Unlock()\n    78→\n    79→\tif !ok {\n    80→\t\treturn fmt.Errorf(\"process %q not found\", containerID)\n    81→\t}\n    82→\n    83→\tif mp.cmd.Process != nil {\n    84→\t\treturn mp.cmd.Process.Kill()\n    85→\t}\n    86→\treturn nil\n    87→}\n    88→\n    89→func (r *Runtime) AttachOutput(ctx context.Context, containerID string) (io.ReadCloser, error) {\n    90→\tr.mu.Lock()\n    91→\tmp, ok := r.processes[containerID]\n    92→\tr.mu.Unlock()\n    93→\n    94→\tif !ok {\n    95→\t\treturn nil, fmt.Errorf(\"process %q not found\", containerID)\n    96→\t}\n    97→\n    98→\treturn mp.stdout, nil\n    99→}\n   100→\n   101→func (r *Runtime) Wait(ctx context.Context, containerID string) (int, error) {\n   102→\tr.mu.Lock()\n   103→\tmp, ok := r.processes[containerID]\n   104→\tr.mu.Unlock()\n   105→\n   106→\tif !ok {\n   107→\t\treturn -1, fmt.Errorf(\"process %q not found\", containerID)\n   108→\t}\n   109→\n   110→\t// Call cmd.Wait() in a goroutine so we can respect context cancellation.\n   111→\t// cmd.Wait() must be called AFTER all reads from StdoutPipe are complete,\n   112→\t// which is guaranteed since trackRun drains the pipe before calling Wait().\n   113→\ttype waitResult struct {\n   114→\t\texit int\n   115→\t\terr  error\n   116→\t}\n   117→\tch := make(chan waitResult, 1)\n   118→\tgo func() {\n   119→\t\terr := mp.cmd.Wait()\n   120→\t\tif err != nil {\n   121→\t\t\tif exitErr, ok := err.(*exec.ExitError); ok {\n   122→\t\t\t\tch <- waitResult{exit: exitErr.ExitCode()}\n   123→\t\t\t} else {\n   124→\t\t\t\tch <- waitResult{exit: -1, err: err}\n   125→\t\t\t}\n   126→\t\t} else {\n   127→\t\t\tch <- waitResult{exit: 0}\n   128→\t\t}\n   129→\t\tclose(mp.done)\n   130→\t}()\n   131→\n   132→\tselect {\n   133→\tcase res := <-ch:\n   134→\t\treturn res.exit, res.err\n   135→\tcase <-ctx.Done():\n   136→\t\treturn -1, ctx.Err()\n   137→\t}\n   138→}\n   139→\n   140→func (r *Runtime) Logs(ctx context.Context, containerID string) (string, error) {\n   141→\treturn \"\", nil\n   142→}\n   143→\n   144→func (r *Runtime) Remove(ctx context.Context, containerID string) error {\n   145→\treturn nil\n   146→}\n   147→\n   148→func (r *Runtime) Inspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error) {\n   149→\treturn &ports.ContainerStatus{Running: false}, nil\n   150→}\n   151→\n   152→func (r *Runtime) CopyFrom(ctx context.Context, containerID string, srcPath, dstPath string) error {\n   153→\tr.mu.Lock()\n   154→\tmp, ok := r.processes[containerID]\n   155→\tr.mu.Unlock()\n   156→\n   157→\tif !ok {\n   158→\t\treturn fmt.Errorf(\"process %q not found\", containerID)\n   159→\t}\n   160→\n   161→\t// In local mode the workspace IS the project dir. Container-internal\n   162→\t// absolute paths (e.g. /workspace/.cloche/output/) are mapped to the\n   163→\t// project directory, matching what Docker does via volume mounts.\n   164→\tsrc := srcPath\n   165→\tif strings.HasPrefix(srcPath, \"/workspace/\") || srcPath == \"/workspace\" {\n   166→\t\tsrc = filepath.Join(mp.projectDir, strings.TrimPrefix(srcPath, \"/workspace\"))\n   167→\t} else if !filepath.IsAbs(srcPath) {\n   168→\t\tsrc = filepath.Join(mp.projectDir, srcPath)\n   169→\t}\n   170→\n   171→\tif err := os.MkdirAll(dstPath, 0o755); err != nil {\n   172→\t\treturn fmt.Errorf(\"creating destination dir: %w\", err)\n   173→\t}\n   174→\n   175→\tcmd := exec.CommandContext(ctx, \"cp\", \"-r\", src+\"/.\", dstPath)\n   176→\tif out, err := cmd.CombinedOutput(); err != nil {\n   177→\t\treturn fmt.Errorf(\"copying files: %s: %w\", string(out), err)\n   178→\t}\n   179→\treturn nil\n   180→}\n   181→"}]},"parent_tool_use_id":null,"session_id":"be03ba05-685d-4063-a5b5-3cada1f11f8c","uuid":"ade89fe1-7a37-48d4-90f2-176dc89a5b7e","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/local/runtime.go","content":"package local\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"sync\"\n\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\ntype managedProcess struct {\n\tcmd        *exec.Cmd\n\tstdout     io.ReadCloser\n\tdone       chan struct{}\n\texit       int\n\tprojectDir string\n}\n\ntype Runtime struct {\n\tagentBinary string\n\tmu          sync.Mutex\n\tprocesses   map[string]*managedProcess\n\tnextID      int\n}\n\nfunc NewRuntime(agentBinary string) *Runtime {\n\treturn &Runtime{\n\t\tagentBinary: agentBinary,\n\t\tprocesses:   make(map[string]*managedProcess),\n\t}\n}\n\nfunc (r *Runtime) Start(ctx context.Context, cfg ports.ContainerConfig) (string, error) {\n\t// Resolve workflow file path\n\tworkflowPath := filepath.Join(cfg.ProjectDir, \".cloche\", cfg.WorkflowName+\".cloche\")\n\n\tagentCmd := cfg.Cmd\n\tif len(agentCmd) == 0 {\n\t\tagentCmd = []string{r.agentBinary, workflowPath}\n\t}\n\n\tcmd := exec.CommandContext(ctx, agentCmd[0], agentCmd[1:]...)\n\tcmd.Dir = cfg.ProjectDir\n\n\tstdout, err := cmd.StdoutPipe()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"creating stdout pipe: %w\", err)\n\t}\n\n\tif err := cmd.Start(); err != nil {\n\t\treturn \"\", fmt.Errorf(\"starting agent process: %w\", err)\n\t}\n\n\tr.mu.Lock()\n\tr.nextID++\n\tid := fmt.Sprintf(\"local-%d\", r.nextID)\n\tmp := &managedProcess{\n\t\tcmd:        cmd,\n\t\tstdout:     stdout,\n\t\tdone:       make(chan struct{}),\n\t\tprojectDir: cfg.ProjectDir,\n\t}\n\tr.processes[id] = mp\n\tr.mu.Unlock()\n\n\treturn id, nil\n}\n\nfunc (r *Runtime) Stop(ctx context.Context, containerID string) error {\n\tr.mu.Lock()\n\tmp, ok := r.processes[containerID]\n\tr.mu.Unlock()\n\n\tif !ok {\n\t\treturn fmt.Errorf(\"process %q not found\", containerID)\n\t}\n\n\tif mp.cmd.Process != nil {\n\t\treturn mp.cmd.Process.Kill()\n\t}\n\treturn nil\n}\n\nfunc (r *Runtime) AttachOutput(ctx context.Context, containerID string) (io.ReadCloser, error) {\n\tr.mu.Lock()\n\tmp, ok := r.processes[containerID]\n\tr.mu.Unlock()\n\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"process %q not found\", containerID)\n\t}\n\n\treturn mp.stdout, nil\n}\n\nfunc (r *Runtime) Wait(ctx context.Context, containerID string) (int, error) {\n\tr.mu.Lock()\n\tmp, ok := r.processes[containerID]\n\tr.mu.Unlock()\n\n\tif !ok {\n\t\treturn -1, fmt.Errorf(\"process %q not found\", containerID)\n\t}\n\n\t// Call cmd.Wait() in a goroutine so we can respect context cancellation.\n\t// cmd.Wait() must be called AFTER all reads from StdoutPipe are complete,\n\t// which is guaranteed since trackRun drains the pipe before calling Wait().\n\ttype waitResult struct {\n\t\texit int\n\t\terr  error\n\t}\n\tch := make(chan waitResult, 1)\n\tgo func() {\n\t\terr := mp.cmd.Wait()\n\t\tif err != nil {\n\t\t\tif exitErr, ok := err.(*exec.ExitError); ok {\n\t\t\t\tch <- waitResult{exit: exitErr.ExitCode()}\n\t\t\t} else {\n\t\t\t\tch <- waitResult{exit: -1, err: err}\n\t\t\t}\n\t\t} else {\n\t\t\tch <- waitResult{exit: 0}\n\t\t}\n\t\tclose(mp.done)\n\t}()\n\n\tselect {\n\tcase res := <-ch:\n\t\treturn res.exit, res.err\n\tcase <-ctx.Done():\n\t\treturn -1, ctx.Err()\n\t}\n}\n\nfunc (r *Runtime) Logs(ctx context.Context, containerID string) (string, error) {\n\treturn \"\", nil\n}\n\nfunc (r *Runtime) Remove(ctx context.Context, containerID string) error {\n\treturn nil\n}\n\nfunc (r *Runtime) Inspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error) {\n\treturn &ports.ContainerStatus{Running: false}, nil\n}\n\nfunc (r *Runtime) CopyFrom(ctx context.Context, containerID string, srcPath, dstPath string) error {\n\tr.mu.Lock()\n\tmp, ok := r.processes[containerID]\n\tr.mu.Unlock()\n\n\tif !ok {\n\t\treturn fmt.Errorf(\"process %q not found\", containerID)\n\t}\n\n\t// In local mode the workspace IS the project dir. Container-internal\n\t// absolute paths (e.g. /workspace/.cloche/output/) are mapped to the\n\t// project directory, matching what Docker does via volume mounts.\n\tsrc := srcPath\n\tif strings.HasPrefix(srcPath, \"/workspace/\") || srcPath == \"/workspace\" {\n\t\tsrc = filepath.Join(mp.projectDir, strings.TrimPrefix(srcPath, \"/workspace\"))\n\t} else if !filepath.IsAbs(srcPath) {\n\t\tsrc = filepath.Join(mp.projectDir, srcPath)\n\t}\n\n\tif err := os.MkdirAll(dstPath, 0o755); err != nil {\n\t\treturn fmt.Errorf(\"creating destination dir: %w\", err)\n\t}\n\n\tcmd := exec.CommandContext(ctx, \"cp\", \"-r\", src+\"/.\", dstPath)\n\tif out, err := cmd.CombinedOutput(); err != nil {\n\t\treturn fmt.Errorf(\"copying files: %s: %w\", string(out), err)\n\t}\n\treturn nil\n}\n","numLines":181,"startLine":1,"totalLines":181}}}
[2026-03-10T21:50:57Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_0136GmnzFRKBxBofS79wHf3T","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"OK, now I have the full picture. Let me look at the existing tests to understand the test patterns.\n\nThe core issue is:\n1. **`StreamLogs` gRPC** doesn't support live streaming for active runs. It only reads from disk files (which aren't available until after the run completes).\n2. **`--follow` SSE path** should work for live streaming, but it requires the HTTP server.\n\nThe fix should make `StreamLogs` gRPC work for active runs by subscribing to the broadcaster. This way `cloche logs <run-id>` works for both active and completed runs.\n\nBut also, I now realize there might be an additional issue: even the SSE/follow path and the broadcaster-based streaming might not get the full picture of what Claude is doing. \n\nThe `StatusWriter.Log()` in `prompt.go` only streams extracted text lines, not tool calls or tool results, so users won't see the full context of what's happening in the live stream. That's a separate concern though—the immediate priority is getting log streaming to work at all. Let me examine the test patterns and then plan the implementation: I need to modify `StreamLogs` in the gRPC server to subscribe to the broadcaster for active runs, streaming live log lines until the run completes.\n\nThen I'll update the `cmdLogs` function to handle the new \"log\" entry type from live streaming, and add tests for this functionality. I'm also wondering whether the gRPC path should support live streaming independently of the `--follow` flag, since currently `cloche logs` uses gRPC while `cloche logs --follow` uses SSE.\n\nActually, the cleaner approach is to have `StreamLogs` automatically detect whether a run is active and stream live log entries as they happen through the broadcaster, then serve any remaining entries once the run completes. The tricky part is that the broadcaster only contains log lines, not step events, so I need to handle both paths—streaming log entries directly from the broadcaster while also capturing step state changes from the store. For completed runs, I'll fall back to serving from the archived files. The CLI already handles arbitrary entry types in its default case, parsing the message content appropriately. For \"log\" type entries specifically, I should add a dedicated handler that prints the message cleanly without any prefix, since the content is already plain text extracted by the prompt adapter. Now I need to write the code and handle the edge case where...\n\nWriting CLI handler...\n\nI also need to think about whether the log broadcaster should publish step events like MsgStepStarted and MsgStepCompleted in addition to just log lines, so the gRPC live stream has better context about what's happening in the run.\n\nMy plan is to update trackRun to publish step events to the broadcaster using the LogLine type with a \"status\" type field, then have StreamLogs subscribe to the broadcaster for active runs while serving completed runs from files. I'll also need to handle these new event types in the CLI and write tests for the whole flow.\n\nLet me start implementing this, but first I should double-check the LogLine struct definition...\n\nLooking at the LogLine type, it has Type as \"status\", \"script\", or \"llm\", and Content for the message. So I'll publish step_started and step_completed events as LogLine entries with Type \"status\", and when converting to the gRPC LogEntry for streaming, I'll map \"status\" type entries appropriately while keeping \"llm\" entries as regular logs.\n\nFor the actual implementation, I need to modify trackRun to publish these step events to the broadcaster after they're recorded, so step transitions show up in the live stream alongside the log output.\n\nAdding step event publishing... Still writing server logic...\n\nNow I'm realizing the LogLine structure needs a StepName field to properly populate the log entries being sent to the client, since the current broadcaster only has the content and timestamp but not which step the log came from. I see the issue now—the StatusMessage struct has the StepName field available, but when publishing to the broadcaster, that field isn't being passed along to the LogLine. Since LogLine only accepts Timestamp, Type, and Content, I'd need to either add a StepName field to LogLine itself or embed the step name in the Content somehow.\n\nAdding a StepName field to LogLine is the cleaner approach. The SSE handler will include it in the output, and existing clients will simply ignore the new field, so there's no breaking change. My plan is to update the LogLine struct to include StepName, then modify the broadcaster publish call in the message handling to pass that field along, and also handle step_started and step_completed events through the broadcaster as well.\n\nNow I'm thinking through the StreamLogs implementation for active runs. The broadcaster doesn't maintain history, so if a client connects mid-step they'll miss earlier events. I could send any existing step captures from the store first before subscribing to live updates, which would give a more complete picture. But that introduces a race condition—events might be published to the broadcaster between when I finish replaying history and when I subscribe to live events, causing duplicates or missed messages. I need to handle this carefully.\n\nThe simplest solution is to subscribe first, then send any existing captures from the store, then start draining the subscriber. This avoids the race condition entirely. Deduplication would be complex, so I'll skip it for now. The priority is giving the user a live tail of what's happening right now—historical context is secondary. So I'll go with subscribing to the broadcaster, streaming live log lines, and sending a run_completed entry when the channel closes.\n\nBut I need to check whether the broadcaster will even be active if the run just started and hasn't produced output yet. Looking at how `IsActive` works, it checks if the run has an entry in the runs map and isn't marked done. If neither Subscribe nor Publish has been called yet, the entry won't exist, so `IsActive` returns false. That means for a freshly started run with no output yet, `StreamLogs` would fall back to reading from the existing file instead of waiting for live events.\n\nI should change the approach—instead of checking `IsActive`, I'll check the run's state directly from the store. If the run is in a running or pending state, I'll subscribe to the broadcaster regardless, and the subscriber will just wait for events to arrive. I'm going to start implementing this now.","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2345,"cache_read_input_tokens":72119,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2345},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"be03ba05-685d-4063-a5b5-3cada1f11f8c","uuid":"8b95f511-be4f-40de-b622-a94bbc7aca56"}
[2026-03-10T21:50:57Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_0136GmnzFRKBxBofS79wHf3T","type":"message","role":"assistant","content":[{"type":"text","text":"Now I have a complete understanding of the issue. The problem is:\n\n1. **`StreamLogs` gRPC** (used by `cloche logs <run-id>`) only reads from disk files, which aren't available until after the container run completes and files are extracted. For active runs, it shows almost nothing.\n2. The broadcaster infrastructure exists and the SSE/`--follow` path uses it, but the primary gRPC path does not.\n3. The `LogLine` struct doesn't carry the step name, losing context.\n\nLet me implement the fix."}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2345,"cache_read_input_tokens":72119,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2345},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"be03ba05-685d-4063-a5b5-3cada1f11f8c","uuid":"535d235d-fa83-473b-bd1f-2df803927702"}
