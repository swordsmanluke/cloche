[2026-03-10T21:50:57Z] [llm] {"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01Hoz5Zq6faZGqtHc9gfp7kq","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Sh4zUxMcfA66NAYNdAgS4Y","name":"Read","input":{"file_path":"/workspace/internal/logstream/parse.go"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":7,"cache_creation_input_tokens":3736,"cache_read_input_tokens":47764,"cache_creation":{"ephemeral_5m_input_tokens":3736,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_016scsk6C1cFooJapGWBZudk","session_id":"be03ba05-685d-4063-a5b5-3cada1f11f8c","uuid":"dd0c617d-afcf-4156-b533-e4bf2cbfe019"}
[2026-03-10T21:50:57Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Sh4zUxMcfA66NAYNdAgS4Y","type":"tool_result","content":"     1→package logstream\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"strings\"\n     8→)\n     9→\n    10→// ParseClaudeLine parses a single Claude Code stream-json line and returns\n    11→// the human-readable text it represents. If the line is a protocol event\n    12→// with no user-visible content, ok is false. Non-JSON input is returned as-is.\n    13→func ParseClaudeLine(line []byte) (text string, ok bool) {\n    14→\tline = bytes.TrimSpace(line)\n    15→\tif len(line) == 0 {\n    16→\t\treturn \"\", false\n    17→\t}\n    18→\tif line[0] != '{' {\n    19→\t\treturn string(line), true\n    20→\t}\n    21→\n    22→\tvar base struct {\n    23→\t\tType string `json:\"type\"`\n    24→\t}\n    25→\tif json.Unmarshal(line, &base) != nil {\n    26→\t\treturn string(line), true\n    27→\t}\n    28→\n    29→\tswitch base.Type {\n    30→\tcase \"assistant\":\n    31→\t\tt := extractAssistantText(line)\n    32→\t\treturn t, t != \"\"\n    33→\tcase \"result\":\n    34→\t\tt := extractResultText(line)\n    35→\t\treturn t, t != \"\"\n    36→\tcase \"content_block_delta\":\n    37→\t\tt := extractDeltaText(line)\n    38→\t\treturn t, t != \"\"\n    39→\tcase \"content_block_start\":\n    40→\t\tt := extractBlockStart(line)\n    41→\t\treturn t, t != \"\"\n    42→\tdefault:\n    43→\t\t// Skip system, user (tool results), and other protocol events\n    44→\t\treturn \"\", false\n    45→\t}\n    46→}\n    47→\n    48→// ParseClaudeStream converts raw Claude Code stream-json output into\n    49→// human-readable text. It extracts assistant text, tool call summaries,\n    50→// and error messages, discarding protocol-level events.\n    51→//\n    52→// If the input does not appear to be stream-json (no valid JSON lines\n    53→// detected), it is returned unchanged.\n    54→func ParseClaudeStream(raw []byte) []byte {\n    55→\tlines := bytes.Split(raw, []byte(\"\\n\"))\n    56→\tvar out strings.Builder\n    57→\tjsonLines := 0\n    58→\n    59→\tfor _, line := range lines {\n    60→\t\tline = bytes.TrimSpace(line)\n    61→\t\tif len(line) == 0 {\n    62→\t\t\tcontinue\n    63→\t\t}\n    64→\n    65→\t\tif line[0] != '{' {\n    66→\t\t\tout.Write(line)\n    67→\t\t\tout.WriteByte('\\n')\n    68→\t\t\tcontinue\n    69→\t\t}\n    70→\n    71→\t\tvar base struct {\n    72→\t\t\tType string `json:\"type\"`\n    73→\t\t}\n    74→\t\tif json.Unmarshal(line, &base) != nil {\n    75→\t\t\tout.Write(line)\n    76→\t\t\tout.WriteByte('\\n')\n    77→\t\t\tcontinue\n    78→\t\t}\n    79→\t\tjsonLines++\n    80→\n    81→\t\tif text, ok := ParseClaudeLine(line); ok {\n    82→\t\t\tout.WriteString(text)\n    83→\t\t}\n    84→\t}\n    85→\n    86→\tif jsonLines == 0 {\n    87→\t\treturn raw\n    88→\t}\n    89→\n    90→\treturn []byte(out.String())\n    91→}\n    92→\n    93→// extractAssistantText handles Claude Code \"assistant\" events.\n    94→// Extracts text content from message.content blocks.\n    95→func extractAssistantText(line []byte) string {\n    96→\tvar event struct {\n    97→\t\tMessage struct {\n    98→\t\t\tContent []struct {\n    99→\t\t\t\tType  string          `json:\"type\"`\n   100→\t\t\t\tText  string          `json:\"text\"`\n   101→\t\t\t\tName  string          `json:\"name\"`  // for tool_use blocks\n   102→\t\t\t\tInput json.RawMessage `json:\"input\"` // for tool_use blocks\n   103→\t\t\t} `json:\"content\"`\n   104→\t\t} `json:\"message\"`\n   105→\t}\n   106→\tif json.Unmarshal(line, &event) != nil {\n   107→\t\treturn \"\"\n   108→\t}\n   109→\n   110→\tvar parts []string\n   111→\tfor _, block := range event.Message.Content {\n   112→\t\tswitch block.Type {\n   113→\t\tcase \"text\":\n   114→\t\t\tif t := strings.TrimSpace(block.Text); t != \"\" {\n   115→\t\t\t\tparts = append(parts, t)\n   116→\t\t\t}\n   117→\t\tcase \"tool_use\":\n   118→\t\t\tparts = append(parts, \"\\n--- Tool: \"+formatToolCall(block.Name, block.Input)+\" ---\")\n   119→\t\t}\n   120→\t}\n   121→\tif len(parts) == 0 {\n   122→\t\treturn \"\"\n   123→\t}\n   124→\treturn strings.Join(parts, \"\\n\") + \"\\n\"\n   125→}\n   126→\n   127→// extractDeltaText handles content_block_delta events (streaming API format).\n   128→func extractDeltaText(line []byte) string {\n   129→\tif bytes.Contains(line, []byte(`\"text_delta\"`)) {\n   130→\t\tvar event struct {\n   131→\t\t\tDelta struct {\n   132→\t\t\t\tType string `json:\"type\"`\n   133→\t\t\t\tText string `json:\"text\"`\n   134→\t\t\t} `json:\"delta\"`\n   135→\t\t}\n   136→\t\tif json.Unmarshal(line, &event) == nil && event.Delta.Type == \"text_delta\" {\n   137→\t\t\treturn event.Delta.Text\n   138→\t\t}\n   139→\t}\n   140→\treturn \"\"\n   141→}\n   142→\n   143→// extractBlockStart handles content_block_start events (streaming API format).\n   144→func extractBlockStart(line []byte) string {\n   145→\tif !bytes.Contains(line, []byte(`\"tool_use\"`)) {\n   146→\t\treturn \"\"\n   147→\t}\n   148→\tvar event struct {\n   149→\t\tContentBlock struct {\n   150→\t\t\tType  string          `json:\"type\"`\n   151→\t\t\tName  string          `json:\"name\"`\n   152→\t\t\tInput json.RawMessage `json:\"input\"`\n   153→\t\t} `json:\"content_block\"`\n   154→\t}\n   155→\tif json.Unmarshal(line, &event) == nil && event.ContentBlock.Type == \"tool_use\" {\n   156→\t\treturn \"\\n--- Tool: \" + formatToolCall(event.ContentBlock.Name, event.ContentBlock.Input) + \" ---\\n\"\n   157→\t}\n   158→\treturn \"\"\n   159→}\n   160→\n   161→// formatToolCall formats a tool name and its input into a human-readable\n   162→// summary like Bash('ls -al') or Read('path/to/file'). If the input is empty\n   163→// or cannot be parsed, just the tool name is returned.\n   164→func formatToolCall(name string, input json.RawMessage) string {\n   165→\tif len(input) == 0 {\n   166→\t\treturn name\n   167→\t}\n   168→\tvar params map[string]json.RawMessage\n   169→\tif json.Unmarshal(input, &params) != nil || len(params) == 0 {\n   170→\t\treturn name\n   171→\t}\n   172→\n   173→\t// Pick the most informative parameter for each known tool.\n   174→\ttype paramSpec struct {\n   175→\t\tkey      string\n   176→\t\tmaxLen   int\n   177→\t}\n   178→\ttoolParams := map[string]paramSpec{\n   179→\t\t\"Bash\":    {\"command\", 80},\n   180→\t\t\"Read\":    {\"file_path\", 0},\n   181→\t\t\"Edit\":    {\"file_path\", 0},\n   182→\t\t\"Write\":   {\"file_path\", 0},\n   183→\t\t\"Glob\":    {\"pattern\", 0},\n   184→\t\t\"Grep\":    {\"pattern\", 80},\n   185→\t\t\"Agent\":   {\"description\", 80},\n   186→\t\t\"WebFetch\": {\"url\", 0},\n   187→\t\t\"WebSearch\": {\"query\", 80},\n   188→\t}\n   189→\n   190→\tspec, known := toolParams[name]\n   191→\tif !known {\n   192→\t\t// For unknown tools, try common parameter names.\n   193→\t\tfor _, fallback := range []string{\"command\", \"file_path\", \"pattern\", \"query\", \"description\"} {\n   194→\t\t\tif _, exists := params[fallback]; exists {\n   195→\t\t\t\tspec = paramSpec{fallback, 80}\n   196→\t\t\t\tknown = true\n   197→\t\t\t\tbreak\n   198→\t\t\t}\n   199→\t\t}\n   200→\t}\n   201→\tif !known {\n   202→\t\treturn name\n   203→\t}\n   204→\n   205→\traw, exists := params[spec.key]\n   206→\tif !exists {\n   207→\t\treturn name\n   208→\t}\n   209→\n   210→\tvar value string\n   211→\tif json.Unmarshal(raw, &value) != nil {\n   212→\t\treturn name\n   213→\t}\n   214→\n   215→\tif spec.maxLen > 0 && len(value) > spec.maxLen {\n   216→\t\tvalue = value[:spec.maxLen] + \"...\"\n   217→\t}\n   218→\n   219→\treturn fmt.Sprintf(\"%s('%s')\", name, value)\n   220→}\n   221→\n   222→// extractResultText handles result events (final output).\n   223→func extractResultText(line []byte) string {\n   224→\tvar event struct {\n   225→\t\tType   string `json:\"type\"`\n   226→\t\tResult string `json:\"result\"`\n   227→\t}\n   228→\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n   229→\t\treturn event.Result\n   230→\t}\n   231→\treturn \"\"\n   232→}\n   233→"}]},"parent_tool_use_id":"toolu_016scsk6C1cFooJapGWBZudk","session_id":"be03ba05-685d-4063-a5b5-3cada1f11f8c","uuid":"c6e0cb84-d7ba-4be1-bb88-e14f11c69be6"}
