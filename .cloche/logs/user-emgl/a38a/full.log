usWriter) RunTitle(title string) {\n    57→\ts.write(StatusMessage{Type: MsgRunTitle, Message: title})\n    58→}\n    59→\n    60→func (s *StatusWriter) Log(stepName, message string) {\n    61→\ts.write(StatusMessage{Type: MsgLog, StepName: stepName, Message: message})\n    62→}\n    63→\n    64→func (s *StatusWriter) Error(stepName, message string) {\n    65→\ts.write(StatusMessage{Type: MsgError, StepName: stepName, Message: message})\n    66→}\n    67→\n    68→func (s *StatusWriter) write(msg StatusMessage) {\n    69→\tmsg.Timestamp = time.Now()\n    70→\t_ = s.enc.Encode(msg)\n    71→\t// Flush the underlying writer if it supports it, to ensure real-time delivery.\n    72→\tif f, ok := s.w.(flusher); ok {\n    73→\t\t_ = f.Flush()\n    74→\t}\n    75→}\n    76→\n    77→func ParseStatusStream(data []byte) ([]StatusMessage, error) {\n    78→\tvar msgs []StatusMessage\n    79→\tdec := json.NewDecoder(bytes.NewReader(data))\n    80→\tfor dec.More() {\n    81→\t\tvar msg StatusMessage\n    82→\t\tif err := dec.Decode(&msg); err != nil {\n    83→\t\t\treturn msgs, fmt.Errorf(\"failed to decode status message: %w\", err)\n    84→\t\t}\n    85→\t\tmsgs = append(msgs, msg)\n    86→\t}\n    87→\treturn msgs, nil\n    88→}\n    89→"}]},"parent_tool_use_id":null,"session_id":"be03ba05-685d-4063-a5b5-3cada1f11f8c","uuid":"18ffbb59-4305-4eac-9c2b-626fc4eb7431","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/protocol/status.go","content":"package protocol\n\nimport (\n\t\"bytes\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"time\"\n)\n\ntype MessageType string\n\nconst (\n\tMsgStepStarted  MessageType = \"step_started\"\n\tMsgStepCompleted MessageType = \"step_completed\"\n\tMsgRunCompleted  MessageType = \"run_completed\"\n\tMsgRunTitle      MessageType = \"run_title\"\n\tMsgLog           MessageType = \"log\"\n\tMsgError         MessageType = \"error\"\n)\n\ntype StatusMessage struct {\n\tType      MessageType `json:\"type\"`\n\tStepName  string      `json:\"step_name,omitempty\"`\n\tResult    string      `json:\"result,omitempty\"`\n\tMessage   string      `json:\"message,omitempty\"`\n\tTimestamp time.Time   `json:\"timestamp\"`\n}\n\n// flusher is an optional interface for writers that support explicit flushing.\ntype flusher interface {\n\tFlush() error\n}\n\ntype StatusWriter struct {\n\tw   io.Writer\n\tenc *json.Encoder\n}\n\nfunc NewStatusWriter(w io.Writer) *StatusWriter {\n\treturn &StatusWriter{w: w, enc: json.NewEncoder(w)}\n}\n\nfunc (s *StatusWriter) StepStarted(stepName string) {\n\ts.write(StatusMessage{Type: MsgStepStarted, StepName: stepName})\n}\n\nfunc (s *StatusWriter) StepCompleted(stepName, result string) {\n\ts.write(StatusMessage{Type: MsgStepCompleted, StepName: stepName, Result: result})\n}\n\nfunc (s *StatusWriter) RunCompleted(result string) {\n\ts.write(StatusMessage{Type: MsgRunCompleted, Result: result})\n}\n\nfunc (s *StatusWriter) RunTitle(title string) {\n\ts.write(StatusMessage{Type: MsgRunTitle, Message: title})\n}\n\nfunc (s *StatusWriter) Log(stepName, message string) {\n\ts.write(StatusMessage{Type: MsgLog, StepName: stepName, Message: message})\n}\n\nfunc (s *StatusWriter) Error(stepName, message string) {\n\ts.write(StatusMessage{Type: MsgError, StepName: stepName, Message: message})\n}\n\nfunc (s *StatusWriter) write(msg StatusMessage) {\n\tmsg.Timestamp = time.Now()\n\t_ = s.enc.Encode(msg)\n\t// Flush the underlying writer if it supports it, to ensure real-time delivery.\n\tif f, ok := s.w.(flusher); ok {\n\t\t_ = f.Flush()\n\t}\n}\n\nfunc ParseStatusStream(data []byte) ([]StatusMessage, error) {\n\tvar msgs []StatusMessage\n\tdec := json.NewDecoder(bytes.NewReader(data))\n\tfor dec.More() {\n\t\tvar msg StatusMessage\n\t\tif err := dec.Decode(&msg); err != nil {\n\t\t\treturn msgs, fmt.Errorf(\"failed to decode status message: %w\", err)\n\t\t}\n\t\tmsgs = append(msgs, msg)\n\t}\n\treturn msgs, nil\n}\n","numLines":89,"startLine":1,"totalLines":89}}}
