[2026-03-10T21:52:20Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013wi6Y7FZBX3RKsGM2dYMtZ","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"errors\"\n     8→\t\"fmt\"\n     9→\t\"io\"\n    10→\t\"net/http\"\n    11→\t\"os\"\n    12→\t\"path/filepath\"\n    13→\t\"strings\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    18→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    19→\t\"google.golang.org/grpc\"\n    20→\t\"google.golang.org/grpc/credentials/insecure\"\n    21→)\n    22→\n    23→func main() {\n    24→\tif len(os.Args) < 2 {\n    25→\t\tusage()\n    26→\t\tos.Exit(1)\n    27→\t}\n    28→\n    29→\t// Commands that don't need a daemon connection\n    30→\tswitch os.Args[1] {\n    31→\tcase \"init\":\n    32→\t\tcmdInit(os.Args[2:])\n    33→\t\treturn\n    34→\tcase \"health\":\n    35→\t\tcmdHealth(os.Args[2:])\n    36→\t\treturn\n    37→\t}\n    38→\n    39→\t// Commands that need a daemon connection\n    40→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    41→\tif addr == \"\" {\n    42→\t\taddr = \"unix:///tmp/cloche.sock\"\n    43→\t}\n    44→\n    45→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n    46→\tif err != nil {\n    47→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n    48→\t\tos.Exit(1)\n    49→\t}\n    50→\tdefer conn.Close()\n    51→\n    52→\tclient := pb.NewClocheServiceClient(conn)\n    53→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n    54→\tdefer cancel()\n    55→\n    56→\tswitch os.Args[1] {\n    57→\tcase \"run\":\n    58→\t\tcmdRun(ctx, client, os.Args[2:])\n    59→\tcase \"status\":\n    60→\t\tcmdStatus(ctx, client, os.Args[2:])\n    61→\tcase \"logs\":\n    62→\t\tcmdLogs(client, os.Args[2:])\n    63→\tcase \"poll\":\n    64→\t\tcmdPoll(client, os.Args[2:])\n    65→\tcase \"list\":\n    66→\t\tcmdList(ctx, client, os.Args[2:])\n    67→\tcase \"stop\":\n    68→\t\tcmdStop(ctx, client, os.Args[2:])\n    69→\tcase \"delete\":\n    70→\t\tcmdDelete(ctx, client, os.Args[2:])\n    71→\tcase \"loop\":\n    72→\t\tcmdLoop(ctx, client, os.Args[2:])\n    73→\tcase \"shutdown\":\n    74→\t\tcmdShutdown(ctx, client)\n    75→\tdefault:\n    76→\t\tusage()\n    77→\t\tos.Exit(1)\n    78→\t}\n    79→}\n    80→\n    81→func usage() {\n    82→\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n    83→\n    84→Commands:\n    85→  init [--workflow <name>] [--base-image <image>]\n    86→                                             Initialize a Cloche project\n    87→  health                                   Show project health summary\n    88→  run --workflow <name> [--prompt \"...\"] [--title \"...\"] [--keep-container]\n    89→                                             Launch a workflow run\n    90→  status <run-id>                            Check run status\n    91→  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n    92→                                             Show logs for a run\n    93→  poll <run-id>                              Wait for a run to finish\n    94→  list [--all]                                List runs (last hour by default)\n    95→  stop <run-id>                              Stop a running workflow\n    96→  delete <container-or-run-id>               Delete a retained container\n    97→  loop [--max <n>]                            Start orchestration loop (default max=1)\n    98→  loop stop                                  Stop orchestration loop\n    99→  shutdown                                   Shut down the daemon\n   100→`)\n   101→}\n   102→\n   103→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   104→\tvar workflow, prompt, title string\n   105→\tvar keepContainer bool\n   106→\n   107→\tfor i := 0; i < len(args); i++ {\n   108→\t\tswitch args[i] {\n   109→\t\tcase \"--workflow\":\n   110→\t\t\tif i+1 < len(args) {\n   111→\t\t\t\ti++\n   112→\t\t\t\tworkflow = args[i]\n   113→\t\t\t}\n   114→\t\tcase \"--prompt\", \"-p\":\n   115→\t\t\tif i+1 < len(args) {\n   116→\t\t\t\ti++\n   117→\t\t\t\tprompt = args[i]\n   118→\t\t\t}\n   119→\t\tcase \"--title\":\n   120→\t\t\tif i+1 < len(args) {\n   121→\t\t\t\ti++\n   122→\t\t\t\ttitle = args[i]\n   123→\t\t\t}\n   124→\t\tcase \"--keep-container\":\n   125→\t\t\tkeepContainer = true\n   126→\t\tdefault:\n   127→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   128→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   129→\t\t\t\tworkflow = args[i]\n   130→\t\t\t}\n   131→\t\t}\n   132→\t}\n   133→\n   134→\tif workflow == \"\" {\n   135→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   136→\t\tos.Exit(1)\n   137→\t}\n   138→\n   139→\tcwd, _ := os.Getwd()\n   140→\n   141→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   142→\tvar image string\n   143→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   144→\tif data, err := os.ReadFile(wfPath); err == nil {\n   145→\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   146→\t\t\timage = wf.Config[\"container.image\"]\n   147→\t\t}\n   148→\t}\n   149→\n   150→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   151→\t\tWorkflowName:  workflow,\n   152→\t\tProjectDir:    cwd,\n   153→\t\tImage:         image,\n   154→\t\tPrompt:        prompt,\n   155→\t\tKeepContainer: keepContainer,\n   156→\t\tTitle:         title,\n   157→\t})\n   158→\tif err != nil {\n   159→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   160→\t\tos.Exit(1)\n   161→\t}\n   162→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   163→}\n   164→\n   165→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   166→\tif len(args) < 1 {\n   167→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   168→\t\tos.Exit(1)\n   169→\t}\n   170→\n   171→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   172→\tif err != nil {\n   173→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   174→\t\tos.Exit(1)\n   175→\t}\n   176→\n   177→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   178→\tif resp.Title != \"\" {\n   179→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   180→\t}\n   181→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   182→\tif resp.IsHost {\n   183→\t\tfmt.Printf(\"Type:      host\\n\")\n   184→\t} else {\n   185→\t\tfmt.Printf(\"Type:      container\\n\")\n   186→\t}\n   187→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   188→\tif resp.ContainerId != \"\" {\n   189→\t\tcid := resp.ContainerId\n   190→\t\tif len(cid) > 12 {\n   191→\t\t\tcid = cid[:12]\n   192→\t\t}\n   193→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   194→\t}\n   195→\tif resp.ErrorMessage != \"\" {\n   196→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   197→\t}\n   198→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   199→\tfor _, exec := range resp.StepExecutions {\n   200→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   201→\t}\n   202→}\n   203→\n   204→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   205→\tvar all bool\n   206→\tfor _, arg := range args {\n   207→\t\tif arg == \"--all\" {\n   208→\t\t\tall = true\n   209→\t\t}\n   210→\t}\n   211→\n   212→\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n   213→\tif err != nil {\n   214→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   215→\t\tos.Exit(1)\n   216→\t}\n   217→\n   218→\tif len(resp.Runs) == 0 {\n   219→\t\tfmt.Println(\"No runs found.\")\n   220→\t\treturn\n   221→\t}\n   222→\n   223→\tfor _, run := range resp.Runs {\n   224→\t\trunType := \"container\"\n   225→\t\tif run.IsHost {\n   226→\t\t\trunType = \"host\"\n   227→\t\t}\n   228→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   229→\t\tif run.Title != \"\" {\n   230→\t\t\tt := run.Title\n   231→\t\t\tif len(t) > 40 {\n   232→\t\t\t\tt = t[:37] + \"...\"\n   233→\t\t\t}\n   234→\t\t\tline += \"  \" + t\n   235→\t\t}\n   236→\t\tif run.ContainerId != \"\" {\n   237→\t\t\tline += \"  \" + run.ContainerId\n   238→\t\t}\n   239→\t\tif run.ErrorMessage != \"\" {\n   240→\t\t\terrMsg := run.ErrorMessage\n   241→\t\t\tif len(errMsg) > 60 {\n   242→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   243→\t\t\t}\n   244→\t\t\tline += \"  \" + errMsg\n   245→\t\t}\n   246→\t\tfmt.Println(line)\n   247→\t}\n   248→}\n   249→\n   250→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   251→\tif len(args) < 1 {\n   252→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n   253→\t\tos.Exit(1)\n   254→\t}\n   255→\n   256→\tvar stepFilter, typeFilter string\n   257→\tvar follow bool\n   258→\trunID := args[0]\n   259→\n   260→\tfor i := 1; i < len(args); i++ {\n   261→\t\tswitch args[i] {\n   262→\t\tcase \"--step\":\n   263→\t\t\tif i+1 < len(args) {\n   264→\t\t\t\ti++\n   265→\t\t\t\tstepFilter = args[i]\n   266→\t\t\t}\n   267→\t\tcase \"--type\":\n   268→\t\t\tif i+1 < len(args) {\n   269→\t\t\t\ti++\n   270→\t\t\t\ttypeFilter = args[i]\n   271→\t\t\t}\n   272→\t\tcase \"--follow\", \"-f\":\n   273→\t\t\tfollow = true\n   274→\t\t}\n   275→\t}\n   276→\n   277→\tif follow {\n   278→\t\tcmdLogsFollow(runID)\n   279→\t\treturn\n   280→\t}\n   281→\n   282→\t// Use background context — log output can be large\n   283→\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n   284→\t\tRunId:    runID,\n   285→\t\tStepName: stepFilter,\n   286→\t\tLogType:  typeFilter,\n   287→\t})\n   288→\tif err != nil {\n   289→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   290→\t\tos.Exit(1)\n   291→\t}\n   292→\n   293→\tfor {\n   294→\t\tentry, err := stream.Recv()\n   295→\t\tif err != nil {\n   296→\t\t\tif errors.Is(err, io.EOF) {\n   297→\t\t\t\tbreak\n   298→\t\t\t}\n   299→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   300→\t\t\tos.Exit(1)\n   301→\t\t}\n   302→\n   303→\t\tswitch entry.Type {\n   304→\t\tcase \"step_started\":\n   305→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   306→\t\t\tif entry.Message != \"\" {\n   307→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   308→\t\t\t}\n   309→\t\tcase \"step_completed\":\n   310→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   311→\t\t\tif entry.Message != \"\" {\n   312→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   313→\t\t\t}\n   314→\t\tcase \"run_completed\":\n   315→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   316→\t\t\tif entry.Message != \"\" {\n   317→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   318→\t\t\t}\n   319→\t\tcase \"full_log\":\n   320→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   321→\t\tcase \"log\":\n   322→\t\t\t// Live-streamed log line from an active run.\n   323→\t\t\tfmt.Println(entry.Message)\n   324→\t\tdefault:\n   325→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   326→\t\t\tif entry.StepName != \"\" {\n   327→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   328→\t\t\t}\n   329→\t\t\tif entry.Message != \"\" {\n   330→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   331→\t\t\t}\n   332→\t\t}\n   333→\t}\n   334→}\n   335→\n   336→func cmdLogsFollow(runID string) {\n   337→\t// Determine HTTP address from env\n   338→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   339→\tif httpAddr == \"\" {\n   340→\t\thttpAddr = \"localhost:8080\"\n   341→\t}\n   342→\t// Strip protocol prefix if present\n   343→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   344→\n   345→\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n   346→\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n   347→\tif err != nil {\n   348→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   349→\t\tos.Exit(1)\n   350→\t}\n   351→\treq.Header.Set(\"Accept\", \"text/event-stream\")\n   352→\n   353→\tresp, err := http.DefaultClient.Do(req)\n   354→\tif err != nil {\n   355→\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n   356→\t\tos.Exit(1)\n   357→\t}\n   358→\tdefer resp.Body.Close()\n   359→\n   360→\tif resp.StatusCode != 200 {\n   361→\t\tbody, _ := io.ReadAll(resp.Body)\n   362→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   363→\t\tos.Exit(1)\n   364→\t}\n   365→\n   366→\tscanner := bufio.NewScanner(resp.Body)\n   367→\tfor scanner.Scan() {\n   368→\t\tline := scanner.Text()\n   369→\t\tif strings.HasPrefix(line, \"event: done\") {\n   370→\t\t\tbreak\n   371→\t\t}\n   372→\t\tif !strings.HasPrefix(line, \"data: \") {\n   373→\t\t\tcontinue\n   374→\t\t}\n   375→\t\tdata := strings.TrimPrefix(line, \"data: \")\n   376→\n   377→\t\tvar entry struct {\n   378→\t\t\tTimestamp string `json:\"timestamp\"`\n   379→\t\t\tType      string `json:\"type\"`\n   380→\t\t\tContent   string `json:\"content\"`\n   381→\t\t}\n   382→\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n   383→\t\t\tcontinue\n   384→\t\t}\n   385→\n   386→\t\t// Color-code by type\n   387→\t\tswitch entry.Type {\n   388→\t\tcase \"status\":\n   389→\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   390→\t\tcase \"llm\":\n   391→\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   392→\t\tdefault:\n   393→\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n   394→\t\t}\n   395→\t}\n   396→}\n   397→\n   398→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   399→\tif len(args) < 1 {\n   400→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   401→\t\tos.Exit(1)\n   402→\t}\n   403→\n   404→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   405→\tif err != nil {\n   406→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   407→\t\tos.Exit(1)\n   408→\t}\n   409→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   410→}\n   411→\n   412→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   413→\tif len(args) < 1 {\n   414→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   415→\t\tos.Exit(1)\n   416→\t}\n   417→\n   418→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   419→\tif err != nil {\n   420→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   421→\t\tos.Exit(1)\n   422→\t}\n   423→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   424→}\n   425→\n   426→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   427→\tcwd, _ := os.Getwd()\n   428→\n   429→\t// Check for \"stop\" subcommand\n   430→\tif len(args) > 0 && args[0] == \"stop\" {\n   431→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   432→\t\tif err != nil {\n   433→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   434→\t\t\tos.Exit(1)\n   435→\t\t}\n   436→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   437→\t\treturn\n   438→\t}\n   439→\n   440→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   441→\tvar maxConcurrent int32\n   442→\tfor i := 0; i < len(args); i++ {\n   443→\t\tswitch args[i] {\n   444→\t\tcase \"--max\":\n   445→\t\t\tif i+1 < len(args) {\n   446→\t\t\t\ti++\n   447→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   448→\t\t\t\tif n != 1 || err != nil {\n   449→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   450→\t\t\t\t\tos.Exit(1)\n   451→\t\t\t\t}\n   452→\t\t\t}\n   453→\t\t}\n   454→\t}\n   455→\n   456→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   457→\t\tProjectDir:    cwd,\n   458→\t\tMaxConcurrent: maxConcurrent,\n   459→\t})\n   460→\tif err != nil {\n   461→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   462→\t\tos.Exit(1)\n   463→\t}\n   464→\tif maxConcurrent > 0 {\n   465→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   466→\t} else {\n   467→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   468→\t}\n   469→}\n   470→\n   471→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   472→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   473→\tif err != nil {\n   474→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   475→\t\tos.Exit(1)\n   476→\t}\n   477→\tfmt.Println(\"Daemon shutting down.\")\n   478→}\n   479→"}]},"parent_tool_use_id":null,"session_id":"7e3762fb-e565-4c0e-b9b1-9371ff7bfffd","uuid":"2ae5f060-ca8e-4308-bd4b-2dfe0d9456b8","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client)\n\tdefault:\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n}\n\nfunc usage() {\n\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n\nCommands:\n  init [--workflow <name>] [--base-image <image>]\n                                             Initialize a Cloche project\n  health                                   Show project health summary\n  run --workflow <name> [--prompt \"...\"] [--title \"...\"] [--keep-container]\n                                             Launch a workflow run\n  status <run-id>                            Check run status\n  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n                                             Show logs for a run\n  poll <run-id>                              Wait for a run to finish\n  list [--all]                                List runs (last hour by default)\n  stop <run-id>                              Stop a running workflow\n  delete <container-or-run-id>               Delete a retained container\n  loop [--max <n>]                            Start orchestration loop (default max=1)\n  loop stop                                  Stop orchestration loop\n  shutdown                                   Shut down the daemon\n`)\n}\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n\tvar image string\n\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n\tif data, err := os.ReadFile(wfPath); err == nil {\n\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n\t\t\timage = wf.Config[\"container.image\"]\n\t\t}\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t}\n\t}\n\n\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n\t\tif run.Title != \"\" {\n\t\t\tt := run.Title\n\t\t\tif len(t) > 40 {\n\t\t\t\tt = t[:37] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + t\n\t\t}\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\t}\n\t}\n\n\tif follow {\n\t\tcmdLogsFollow(runID)\n\t\treturn\n\t}\n\n\t// Use background context — log output can be large\n\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdLogsFollow(runID string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\t// Strip protocol prefix if present\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\treq.Header.Set(\"Accept\", \"text/event-stream\")\n\n\tresp, err := http.DefaultClient.Do(req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\tscanner := bufio.NewScanner(resp.Body)\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"event: done\") {\n\t\t\tbreak\n\t\t}\n\t\tif !strings.HasPrefix(line, \"data: \") {\n\t\t\tcontinue\n\t\t}\n\t\tdata := strings.TrimPrefix(line, \"data: \")\n\n\t\tvar entry struct {\n\t\t\tTimestamp string `json:\"timestamp\"`\n\t\t\tType      string `json:\"type\"`\n\t\t\tContent   string `json:\"content\"`\n\t\t}\n\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Color-code by type\n\t\tswitch entry.Type {\n\t\tcase \"status\":\n\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tcase \"llm\":\n\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tdefault:\n\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n","numLines":479,"startLine":1,"totalLines":479}}}
