\n   493→\t\t\tif err := stream.Send(&pb.LogEntry{\n   494→\t\t\t\tType:      \"run_completed\",\n   495→\t\t\t\tResult:    string(run.State),\n   496→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   497→\t\t\t\tMessage:   run.ErrorMessage,\n   498→\t\t\t}); err != nil {\n   499→\t\t\t\treturn err\n   500→\t\t\t}\n   501→\t\t}\n   502→\t\treturn nil\n   503→\t}\n   504→\n   505→\t// Fall back to capture-based streaming\n   506→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   507→\tif err != nil {\n   508→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   509→\t}\n   510→\n   511→\tfor _, exec := range captures {\n   512→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   513→\t\t// and one for step_completed (has Result).\n   514→\t\tif exec.Result == \"\" {\n   515→\t\t\tentry := &pb.LogEntry{\n   516→\t\t\t\tType:      \"step_started\",\n   517→\t\t\t\tStepName:  exec.StepName,\n   518→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   519→\t\t\t}\n   520→\t\t\tif err := stream.Send(entry); err != nil {\n   521→\t\t\t\treturn err\n   522→\t\t\t}\n   523→\t\t} else {\n   524→\t\t\t// Read step output from file, falling back to container.log\n   525→\t\t\tvar output string\n   526→\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   527→\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   528→\t\t\t\toutput = string(data)\n   529→\t\t\t} else {\n   530→\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n   531→\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n   532→\t\t\t\t\toutput = string(data)\n   533→\t\t\t\t}\n   534→\t\t\t}\n   535→\t\t\tentry := &pb.LogEntry{\n   536→\t\t\t\tType:      \"step_completed\",\n   537→\t\t\t\tStepName:  exec.StepName,\n   538→\t\t\t\tResult:    exec.Result,\n   539→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   540