bscribe(id, sub)\n   849→\n   850→\tctx := r.Context()\n   851→\tfor {\n   852→\t\tselect {\n   853→\t\tcase <-ctx.Done():\n   854→\t\t\treturn\n   855→\t\tcase line, ok := <-sub.C:\n   856→\t\t\tif !ok {\n   857→\t\t\t\t// Stream finished (run completed)\n   858→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   859→\t\t\t\tflusher.Flush()\n   860→\t\t\t\treturn\n   861→\t\t\t}\n   862→\t\t\tline = parseLLMLogLine(line)\n   863→\t\t\tif line.Type == \"\" {\n   864→\t\t\t\tcontinue // skip protocol-only llm lines\n   865→\t\t\t}\n   866→\t\t\tdata, _ := json.Marshal(line)\n   867→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   868→\t\t\tflusher.Flush()\n   869→\t\t}\n   870→\t}\n   871→}\n   872→\n   873→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   874→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   875→\n   876→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   877→// LLM-type lines are parsed from raw Claude JSON into human-readable text.\n   878→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   879→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   880→\tf, err := os.Open(logPath)\n   881→\tif err != nil {\n   882→\t\treturn\n   883→\t}\n   884→\tdefer f.Close()\n   885→\n   886→\tscanner := bufio.NewScanner(f)\n   887→\tfor scanner.Scan() {\n   888→\t\ttext := scanner.Text()\n   889→\t\tline := parseFullLogLine(text)\n   890→\t\tline = parseLLMLogLine(line)\n   891→\t\tif line.Type == \"\" {\n   892→\t\t\tcontinue // skip protocol-only llm lines\n   893→\t\t}\n   894→\t\tdata, _ := json.Marshal(line)\n   895→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   896→\t\tflusher.Flush()\n   897→\t}\n   898→}\n   899→"}]},"parent_tool_use_id":null,"session_id":"be03ba05-685d-4063-a5b5-3cada1f11f8c","uuid":"6890e0fd-3136-4bbb-87dc-6b9e61768955","tool_