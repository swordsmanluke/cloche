[2026-03-10T21:50:57Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0129R4yv4X9npM5bUSoMuKYv","type":"tool_result","content":"     1→package generic\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"bytes\"\n     6→\t\"context\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    12→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    13→)\n    14→\n    15→type Adapter struct {\n    16→\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n    17→}\n    18→\n    19→func New() *Adapter {\n    20→\treturn &Adapter{}\n    21→}\n    22→\n    23→func (a *Adapter) Name() string {\n    24→\treturn \"generic\"\n    25→}\n    26→\n    27→func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    28→\tcmdStr := step.Config[\"run\"]\n    29→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    30→\tcmd.Dir = workDir\n    31→\n    32→\tvar output []byte\n    33→\tvar err error\n    34→\n    35→\tif a.StatusWriter != nil {\n    36→\t\toutput, err = a.executeStreaming(cmd, step.Name)\n    37→\t} else {\n    38→\t\toutput, err = cmd.CombinedOutput()\n    39→\t}\n    40→\n    41→\t// Extract result marker before writing logs\n    42→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n    43→\n    44→\t// Write cleaned output to log file\n    45→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n    46→\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n    47→\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), cleanOutput, 0644)\n    48→\t}\n    49→\n    50→\tisAgent := step.Type == domain.StepTypeAgent\n    51→\n    52→\tif err != nil {\n    53→\t\tif _, ok := err.(*exec.ExitError); ok {\n    54→\t\t\tresult := \"fail\"\n    55→\t\t\tif found {\n    56→\t\t\t\tresult = markerResult\n    57→\t\t\t}\n    58→\t\t\tprotocol.AppendHistory(workDir, step.Name, result, isAgent, cleanOutput)\n    59→\t\t\treturn result, nil\n    60→\t\t}\n    61→\t\treturn \"\", err\n    62→\t}\n    63→\n    64→\tresult := \"success\"\n    65→\tif found {\n    66→\t\tresult = markerResult\n    67→\t}\n    68→\tprotocol.AppendHistory(workDir, step.Name, result, isAgent, cleanOutput)\n    69→\treturn result, nil\n    70→}\n    71→\n    72→// executeStreaming runs the command and streams output lines through StatusWriter\n    73→// in real-time. Returns the full accumulated output.\n    74→func (a *Adapter) executeStreaming(cmd *exec.Cmd, stepName string) ([]byte, error) {\n    75→\tpipe, err := cmd.StdoutPipe()\n    76→\tif err != nil {\n    77→\t\treturn nil, err\n    78→\t}\n    79→\tcmd.Stderr = cmd.Stdout // merge stderr into stdout pipe\n    80→\n    81→\tif err := cmd.Start(); err != nil {\n    82→\t\treturn nil, err\n    83→\t}\n    84→\n    85→\tvar buf bytes.Buffer\n    86→\tscanner := bufio.NewScanner(pipe)\n    87→\tfor scanner.Scan() {\n    88→\t\tline := scanner.Text()\n    89→\t\tbuf.WriteString(line)\n    90→\t\tbuf.WriteByte('\\n')\n    91→\t\ta.StatusWriter.Log(stepName, line)\n    92→\t}\n    93→\n    94→\twaitErr := cmd.Wait()\n    95→\treturn buf.Bytes(), waitErr\n    96→}\n    97→"}]},"parent_tool_use_id":null,"session_id":"be03ba05-685d-4063-a5b5-3cada1f11f8c","uuid":"93c6ae77-3da8-41ec-a1bf-157fceeb7844","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/agents/generic/generic.go","content":"package generic\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"context\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\ntype Adapter struct {\n\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n}\n\nfunc New() *Adapter {\n\treturn &Adapter{}\n}\n\nfunc (a *Adapter) Name() string {\n\treturn \"generic\"\n}\n\nfunc (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n\tcmdStr := step.Config[\"run\"]\n\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n\tcmd.Dir = workDir\n\n\tvar output []byte\n\tvar err error\n\n\tif a.StatusWriter != nil {\n\t\toutput, err = a.executeStreaming(cmd, step.Name)\n\t} else {\n\t\toutput, err = cmd.CombinedOutput()\n\t}\n\n\t// Extract result marker before writing logs\n\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n\n\t// Write cleaned output to log file\n\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), cleanOutput, 0644)\n\t}\n\n\tisAgent := step.Type == domain.StepTypeAgent\n\n\tif err != nil {\n\t\tif _, ok := err.(*exec.ExitError); ok {\n\t\t\tresult := \"fail\"\n\t\t\tif found {\n\t\t\t\tresult = markerResult\n\t\t\t}\n\t\t\tprotocol.AppendHistory(workDir, step.Name, result, isAgent, cleanOutput)\n\t\t\treturn result, nil\n\t\t}\n\t\treturn \"\", err\n\t}\n\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\tprotocol.AppendHistory(workDir, step.Name, result, isAgent, cleanOutput)\n\treturn result, nil\n}\n\n// executeStreaming runs the command and streams output lines through StatusWriter\n// in real-time. Returns the full accumulated output.\nfunc (a *Adapter) executeStreaming(cmd *exec.Cmd, stepName string) ([]byte, error) {\n\tpipe, err := cmd.StdoutPipe()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tcmd.Stderr = cmd.Stdout // merge stderr into stdout pipe\n\n\tif err := cmd.Start(); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar buf bytes.Buffer\n\tscanner := bufio.NewScanner(pipe)\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tbuf.WriteString(line)\n\t\tbuf.WriteByte('\\n')\n\t\ta.StatusWriter.Log(stepName, line)\n\t}\n\n\twaitErr := cmd.Wait()\n\treturn buf.Bytes(), waitErr\n}\n","numLines":97,"startLine":1,"totalLines":97}}}
