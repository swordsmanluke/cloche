{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MJeCdrkiKfQfqMBxm1eMkd","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/config\"\n    19→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    20→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    21→\t\"github.com/cloche-dev/cloche/internal/host\"\n    22→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    23→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    24→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    25→\trpcgrpc \"google.golang.org/grpc\"\n    26→)\n    27→\n    28→type ClocheServer struct {\n    29→\tpb.UnimplementedClocheServiceServer\n    30→\tstore        ports.RunStore\n    31→\tcaptures     ports.CaptureStore\n    32→\tlogStore     ports.LogStore\n    33→\tcontainer    ports.ContainerRuntime\n    34→\tdefaultImage string\n    35→\tevolution    *evolution.Trigger\n    36→\tlogBroadcast *logstream.Broadcaster\n    37→\tshutdownFn   func()\n    38→\tmu           sync.Mutex\n    39→\trunIDs       map[string]string      // run_id -> container_id\n    40→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    41→}\n    42→\n    43→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    44→\treturn &ClocheServer{\n    45→\t\tstore:     store,\n    46→\t\tcontainer: container,\n    47→\t\trunIDs:    make(map[string]string),\n    48→\t\tloops:     make(map[string]*host.Loop),\n    49→\t}\n    50→}\n    51→\n    52→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    53→\treturn &ClocheServer{\n    54→\t\tstore:        store,\n    55→\t\tcaptures:     captures,\n    56→\t\tcontainer:    container,\n    57→\t\tdefaultImage: defaultImage,\n    58→\t\trunIDs:       make(map[string]string),\n    59→\t\tloops:        make(map[string]*host.Loop),\n    60→\t}\n    61→}\n    62→\n    63→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    64→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    65→\ts.logStore = ls\n    66→}\n    67→\n    68→\n    69→// SetEvolution attaches an evolution trigger to the server.\n    70→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    71→\ts.evolution = trigger\n    72→}\n    73→\n    74→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    75→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    76→\ts.logBroadcast = b\n    77→}\n    78→\n    79→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    80→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    81→\ts.shutdownFn = fn\n    82→}\n    83→\n    84→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    85→\tif s.container == nil {\n    86→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    87→\t}\n    88→\n    89→\t// Generate a unique run ID, retrying on collision\n    90→\tvar runID string\n    91→\tfor attempts := 0; attempts < 10; attempts++ {\n    92→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    93→\t\texisting, err := s.store.GetRun(ctx, runID)\n    94→\t\tif err != nil {\n    95→\t\t\tbreak // ID is free\n    96→\t\t}\n    97→\t\t// Reuse if completed more than 1 hour ago\n    98→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n    99→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   100→\t\t\tbreak\n   101→\t\t}\n   102→\t}\n   103→\n   104→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   105→\tif req.Prompt != \"\" {\n   106→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   107→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   108→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   109→\t\t}\n   110→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   111→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   112→\t\t}\n   113→\t}\n   114→\trun := domain.NewRun(runID, req.WorkflowName)\n   115→\trun.ProjectDir = req.ProjectDir\n   116→\trun.Title = req.Title\n   117→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   118→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   119→\t}\n   120→\n   121→\t// Resolve image: request-level override, then server default\n   122→\timage := req.Image\n   123→\tif image == \"\" {\n   124→\t\timage = s.defaultImage\n   125→\t}\n   126→\n   127→\t// Launch container start + tracking in background so the RPC returns immediately.\n   128→\t// The run stays in \"pending\" state until the container is up.\n   129→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   130→\n   131→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   132→}\n   133→\n   134→// launchAndTrack starts the container and then tracks it to completion.\n   135→// It runs in a background goroutine with its own context, independent of the\n   136→// RPC context which may be cancelled after RunWorkflow returns.\n   137→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   138→\tctx := context.Background()\n   139→\n   140→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   141→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   142→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   143→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   144→\t\t\tif run != nil {\n   145→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   146→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   147→\t\t\t}\n   148→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   149→\t\t\t\treturn\n   150→\t\t}\n   151→\t}\n   152→\n   153→\tbaseSHA := gitHEAD(req.ProjectDir)\n   154→\n   155→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   156→\t\tImage:        image,\n   157→\t\tWorkflowName: req.WorkflowName,\n   158→\t\tProjectDir:   req.ProjectDir,\n   159→\t\tRunID:        runID,\n   160→\t\tNetworkAllow: []string{\"*\"},\n   161→\t})\n   162→\tif err != nil {\n   163→\t\trun, _ := s.store.GetRun(ctx, runID)\n   164→\t\tif run != nil {\n   165→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   166→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   167→\t\t}\n   168→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   169→\t\treturn\n   170→\t}\n   171→\n   172→\ts.mu.Lock()\n   173→\ts.runIDs[runID] = containerID\n   174→\ts.mu.Unlock()\n   175→\n   176→\trun, _ := s.store.GetRun(ctx, runID)\n   177→\tif run != nil {\n   178→\t\trun.Start()\n   179→\t\trun.ContainerID = containerID\n   180→\t\trun.BaseSHA = baseSHA\n   181→\t\t_ = s.store.UpdateRun(ctx, run)\n   182→\t}\n   183→\n   184→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   185→}\n   186→\n   187→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   188→\tctx := context.Background()\n   189→\n   190→\t// Attach to agent output\n   191→\treader, err := s.container.AttachOutput(ctx, containerID)\n   192→\tif err != nil {\n   193→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   194→\t\t\treturn\n   195→\t}\n   196→\n   197→\t// Parse JSON-lines status messages\n   198→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   199→\tscanner := bufio.NewScanner(reader)\n   200→\tfor scanner.Scan() {\n   201→\t\tvar msg protocol.StatusMessage\n   202→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   203→\t\t\tcontinue\n   204→\t\t}\n   205→\n   206→\t\t// Fast path: log messages don't need store interaction.\n   207→\t\tif msg.Type == protocol.MsgLog {\n   208→\t\t\tif s.logBroadcast != nil {\n   209→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   210→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   211→\t\t\t\t\tType:      \"llm\",\n   212→\t\t\t\t\tContent:   msg.Message,\n   213→\t\t\t\t\tStepName:  msg.StepName,\n   214→\t\t\t\t})\n   215→\t\t\t}\n   216→\t\t\tcontinue\n   217→\t\t}\n   218→\n   219→\t\trun, err := s.store.GetRun(ctx, runID)\n   220→\t\tif err != nil {\n   221→\t\t\tcontinue\n   222→\t\t}\n   223→\n   224→\t\tswitch msg.Type {\n   225→\t\tcase protocol.MsgStepStarted:\n   226→\t\t\trun.RecordStepStart(msg.StepName)\n   227→\t\t\tif s.captures != nil {\n   228→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   229→\t\t\t\t\tStepName:  msg.StepName,\n   230→\t\t\t\t\tStartedAt: msg.Timestamp,\n   231→\t\t\t\t})\n   232→\t\t\t}\n   233→\t\t\tif s.logBroadcast != nil {\n   234→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   235→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   236→\t\t\t\t\tType:      \"status\",\n   237→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   238→\t\t\t\t\tStepName:  msg.StepName,\n   239→\t\t\t\t})\n   240→\t\t\t}\n   241→\t\tcase protocol.MsgStepCompleted:\n   242→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   243→\t\t\tif s.captures != nil {\n   244→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   245→\t\t\t\t\tStepName:    msg.StepName,\n   246→\t\t\t\t\tResult:      msg.Result,\n   247→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   248→\t\t\t\t})\n   249→\t\t\t}\n   250→\t\t\tif s.logBroadcast != nil {\n   251→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   252→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   253→\t\t\t\t\tType:      \"status\",\n   254→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   255→\t\t\t\t\tStepName:  msg.StepName,\n   256→\t\t\t\t})\n   257→\t\t\t}\n   258→\t\tcase protocol.MsgRunTitle:\n   259→\t\t\tif run.Title == \"\" {\n   260→\t\t\t\trun.Title = msg.Message\n   261→\t\t\t}\n   262→\t\tcase protocol.MsgRunCompleted:\n   263→\t\t\treportedResult = msg.Result\n   264→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   265→\t\t}\n   266→\n   267→\t\t_ = s.store.UpdateRun(ctx, run)\n   268→\t}\n   269→\treader.Close()\n   270→\n   271→\t// Signal live-stream subscribers that this run is done.\n   272→\tif s.logBroadcast != nil {\n   273→\t\ts.logBroadcast.Finish(runID)\n   274→\t}\n   275→\n   276→\t// Wait for process exit\n   277→\texitCode, err := s.container.Wait(ctx, containerID)\n   278→\tif err != nil {\n   279→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   280→\t}\n   281→\n   282→\t// Extract step output files from container before it's removed\n   283→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   284→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   285→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   286→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   287→\t\t}\n   288→\t}\n   289→\n   290→\t// Capture full container stdout/stderr before the container is removed\n   291→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   292→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   293→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   294→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   295→\t\t}\n   296→\t}\n   297→\n   298→\t// Index extracted log files in the log store\n   299→\tif s.logStore != nil {\n   300→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   301→\t}\n   302→\n   303→\t// Extract results to git branch BEFORE finalizing state, so that\n   304→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   305→\t// before the run is marked complete.\n   306→\tresultLabel := reportedResult\n   307→\tif resultLabel == \"\" {\n   308→\t\tif exitCode == 0 {\n   309→\t\t\tresultLabel = \"succeeded\"\n   310→\t\t} else {\n   311→\t\t\tresultLabel = \"failed\"\n   312→\t\t}\n   313→\t}\n   314→\t{\n   315→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   316→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   317→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   318→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   319→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   320→\t\t\t} else {\n   321→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   322→\t\t\t}\n   323→\t\t} else {\n   324→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   325→\t\t}\n   326→\t}\n   327→\n   328→\t// Now finalize run state\n   329→\trun, err := s.store.GetRun(ctx, runID)\n   330→\tif err != nil {\n   331→\t\treturn\n   332→\t}\n   333→\tif run.State == domain.RunStateRunning {\n   334→\t\tif reportedResult == \"succeeded\" {\n   335→\t\t\trun.Complete(domain.RunStateSucceeded)\n   336→\t\t} else if reportedResult != \"\" {\n   337→\t\t\trun.Complete(domain.RunStateFailed)\n   338→\t\t} else if exitCode == 0 {\n   339→\t\t\trun.Complete(domain.RunStateSucceeded)\n   340→\t\t} else {\n   341→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   342→\t\t}\n   343→\t\t_ = s.store.UpdateRun(ctx, run)\n   344→\t}\n   345→\n   346→\t// Fire evolution trigger if configured\n   347→\tif s.evolution != nil {\n   348→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   349→\t}\n   350→\n   351→\t// Merge is handled as a workflow step in host.cloche, not here.\n   352→\n   353→\t// Container retention policy:\n   354→\t// - Failed runs: always keep the container for debugging\n   355→\t// - Successful runs + --keep-container: keep the container\n   356→\t// - Successful runs without --keep-container: remove the container\n   357→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   358→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   359→\n   360→\tif keepContainer || runFailed {\n   361→\t\treason := \"--keep-container\"\n   362→\t\tif runFailed {\n   363→\t\t\treason = \"run failed\"\n   364→\t\t}\n   365→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   366→\t\tif runFinal != nil {\n   367→\t\t\trunFinal.ContainerKept = true\n   368→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   369→\t\t}\n   370→\t} else {\n   371→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   372→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   373→\t\t} else {\n   374→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   375→\t\t}\n   376→\t}\n   377→\n   378→\t// Cleanup mapping\n   379→\ts.mu.Lock()\n   380→\tdelete(s.runIDs, runID)\n   381→\ts.mu.Unlock()\n   382→}\n   383→\n   384→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   385→\tvar since time.Time\n   386→\tif !req.All {\n   387→\t\tsince = time.Now().Add(-1 * time.Hour)\n   388→\t}\n   389→\truns, err := s.store.ListRuns(ctx, since)\n   390→\tif err != nil {\n   391→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   392→\t}\n   393→\n   394→\tresp := &pb.ListRunsResponse{}\n   395→\tfor _, run := range runs {\n   396→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   397→\t\t\tRunId:        run.ID,\n   398→\t\t\tWorkflowName: run.WorkflowName,\n   399→\t\t\tState:        string(run.State),\n   400→\t\t\tStartedAt:    run.StartedAt.String(),\n   401→\t\t\tErrorMessage: run.ErrorMessage,\n   402→\t\t\tContainerId:  run.ContainerID,\n   403→\t\t\tTitle:        run.Title,\n   404→\t\t\tIsHost:       run.IsHost,\n   405→\t\t})\n   406→\t}\n   407→\treturn resp, nil\n   408→}\n   409→\n   410→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   411→\trun, err := s.store.GetRun(ctx, req.RunId)\n   412→\tif err != nil {\n   413→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   414→\t}\n   415→\n   416→\tresp := &pb.GetStatusResponse{\n   417→\t\tRunId:        run.ID,\n   418→\t\tWorkflowName: run.WorkflowName,\n   419→\t\tState:        string(run.State),\n   420→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   421→\t\tErrorMessage: run.ErrorMessage,\n   422→\t\tContainerId:  run.ContainerID,\n   423→\t\tTitle:        run.Title,\n   424→\t\tIsHost:       run.IsHost,\n   425→\t}\n   426→\n   427→\t// Check container liveness\n   428→\tif run.ContainerID != \"\" && s.container != nil {\n   429→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   430→\t\t\tresp.ContainerAlive = cs.Running\n   431→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   432→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   433→\t\t\t}\n   434→\t\t}\n   435→\t}\n   436→\n   437→\t// Load step executions from captures store if available\n   438→\tif s.captures != nil {\n   439→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   440→\t\tif err == nil {\n   441→\t\t\tfor _, exec := range captures {\n   442→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   443→\t\t\t\t\tStepName:    exec.StepName,\n   444→\t\t\t\t\tResult:      exec.Result,\n   445→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   446→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   447→\t\t\t\t})\n   448→\t\t\t}\n   449→\t\t}\n   450→\t} else {\n   451→\t\tfor _, exec := range run.StepExecutions {\n   452→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   453→\t\t\t\tStepName:    exec.StepName,\n   454→\t\t\t\tResult:      exec.Result,\n   455→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   456→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   457→\t\t\t})\n   458→\t\t}\n   459→\t}\n   460→\n   461→\treturn resp, nil\n   462→}\n   463→\n   464→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   465→\tctx := stream.Context()\n   466→\n   467→\t// Verify run exists\n   468→\trun, err := s.store.GetRun(ctx, req.RunId)\n   469→\tif err != nil {\n   470→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   471→\t}\n   472→\n   473→\t// If step_name or log_type filter is set, serve content directly from the log index\n   474→\tif req.StepName != \"\" || req.LogType != \"\" {\n   475→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   476→\t}\n   477→\n   478→\t// For active runs, stream live from the broadcaster so callers can tail output.\n   479→\tif (run.State == domain.RunStateRunning || run.State == domain.RunStatePending) && s.logBroadcast != nil {\n   480→\t\treturn s.streamLiveLogs(req.RunId, stream)\n   481→\t}\n   482→\n   483→\tif s.captures == nil {\n   484→\t\treturn fmt.Errorf(\"captures store not configured\")\n   485→\t}\n   486→\n   487→\t// Check for full.log first — if it exists, serve it as the unified log\n   488→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   489→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   490→\t\tif err := stream.Send(&pb.LogEntry{\n   491→\t\t\tType:    \"full_log\",\n   492→\t\t\tMessage: string(data),\n   493→\t\t}); err != nil {\n   494→\t\t\treturn err\n   495→\t\t}\n   496→\t\t// Still send run completion entry\n   497→\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   498→\t\t\tif err := stream.Send(&pb.LogEntry{\n   499→\t\t\t\tType:      \"run_completed\",\n   500→\t\t\t\tResult:    string(run.State),\n   501→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   502→\t\t\t\tMessage:   run.ErrorMessage,\n   503→\t\t\t}); err != nil {\n   504→\t\t\t\treturn err\n   505→\t\t\t}\n   506→\t\t}\n   507→\t\treturn nil\n   508→\t}\n   509→\n   510→\t// Fall back to capture-based streaming\n   511→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   512→\tif err != nil {\n   513→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   514→\t}\n   515→\n   516→\tfor _, exec := range captures {\n   517→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   518→\t\t// and one for step_completed (has Result).\n   519→\t\tif exec.Result == \"\" {\n   520→\t\t\tentry := &pb.LogEntry{\n   521→\t\t\t\tType:      \"step_started\",\n   522→\t\t\t\tStepName:  exec.StepName,\n   523→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   524→\t\t\t}\n   525→\t\t\tif err := stream.Send(entry); err != nil {\n   526→\t\t\t\treturn err\n   527→\t\t\t}\n   528→\t\t} else {\n   529→\t\t\t// Read step output from file, falling back to container.log\n   530→\t\t\tvar output string\n   531→\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   532→\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   533→\t\t\t\toutput = string(data)\n   534→\t\t\t} else {\n   535→\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n   536→\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n   537→\t\t\t\t\toutput = string(data)\n   538→\t\t\t\t}\n   539→\t\t\t}\n   540→\t\t\tentry := &pb.LogEntry{\n   541→\t\t\t\tType:      \"step_completed\",\n   542→\t\t\t\tStepName:  exec.StepName,\n   543→\t\t\t\tResult:    exec.Result,\n   544→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   545→\t\t\t\tMessage:   output,\n   546→\t\t\t}\n   547→\t\t\tif err := stream.Send(entry); err != nil {\n   548→\t\t\t\treturn err\n   549→\t\t\t}\n   550→\t\t}\n   551→\t}\n   552→\n   553→\t// Send run completion entry\n   554→\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   555→\t\tif err := stream.Send(&pb.LogEntry{\n   556→\t\t\tType:      \"run_completed\",\n   557→\t\t\tResult:    string(run.State),\n   558→\t\t\tTimestamp: run.CompletedAt.String(),\n   559→\t\t\tMessage:   run.ErrorMessage,\n   560→\t\t}); err != nil {\n   561→\t\t\treturn err\n   562→\t\t}\n   563→\t}\n   564→\n   565→\treturn nil\n   566→}\n   567→\n   568→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   569→// It uses the log index when available, falling back to file path conventions.\n   570→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   571→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   572→\n   573→\t// Try log index first\n   574→\tif s.logStore != nil {\n   575→\t\tvar logFiles []*ports.LogFileEntry\n   576→\t\tvar err error\n   577→\n   578→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   579→\t\t\t// Filter by both step and type\n   580→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   581→\t\t\tif err == nil {\n   582→\t\t\t\tfiltered := logFiles[:0]\n   583→\t\t\t\tfor _, lf := range logFiles {\n   584→\t\t\t\t\tif lf.FileType == req.LogType {\n   585→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   586→\t\t\t\t\t}\n   587→\t\t\t\t}\n   588→\t\t\t\tlogFiles = filtered\n   589→\t\t\t}\n   590→\t\t} else if req.StepName != \"\" {\n   591→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   592→\t\t} else {\n   593→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   594→\t\t}\n   595→\n   596→\t\tif err == nil && len(logFiles) > 0 {\n   597→\t\t\tfor _, lf := range logFiles {\n   598→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   599→\t\t\t\tif readErr != nil {\n   600→\t\t\t\t\tcontinue\n   601→\t\t\t\t}\n   602→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   603→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   604→\t\t\t\t\tStepName: lf.StepName,\n   605→\t\t\t\t\tMessage:  string(data),\n   606→\t\t\t\t}); err != nil {\n   607→\t\t\t\t\treturn err\n   608→\t\t\t\t}\n   609→\t\t\t}\n   610→\t\t\treturn nil\n   611→\t\t}\n   612→\t}\n   613→\n   614→\t// Fall back to file path conventions\n   615→\tif req.StepName != \"\" {\n   616→\t\tvar logPath string\n   617→\t\tswitch req.LogType {\n   618→\t\tcase \"llm\":\n   619→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   620→\t\tdefault:\n   621→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   622→\t\t}\n   623→\n   624→\t\tdata, err := os.ReadFile(logPath)\n   625→\t\tif err != nil {\n   626→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   627→\t\t}\n   628→\t\treturn stream.Send(&pb.LogEntry{\n   629→\t\t\tType:     \"step_log\",\n   630→\t\t\tStepName: req.StepName,\n   631→\t\t\tMessage:  string(data),\n   632→\t\t})\n   633→\t}\n   634→\n   635→\treturn fmt.Errorf(\"no log files found matching filter\")\n   636→}\n   637→\n   638→// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n   639→// time for an active run. The stream closes when the run completes or the\n   640→// client disconnects.\n   641→func (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   642→\tsub := s.logBroadcast.Subscribe(runID)\n   643→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   644→\n   645→\tctx := stream.Context()\n   646→\tfor {\n   647→\t\tselect {\n   648→\t\tcase <-ctx.Done():\n   649→\t\t\treturn ctx.Err()\n   650→\t\tcase line, ok := <-sub.C:\n   651→\t\t\tif !ok {\n   652→\t\t\t\t// Run completed — send terminal entry.\n   653→\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   654→\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   655→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   656→\t\t\t\t\t\tType:      \"run_completed\",\n   657→\t\t\t\t\t\tResult:    string(run.State),\n   658→\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   659→\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   660→\t\t\t\t\t})\n   661→\t\t\t\t}\n   662→\t\t\t\treturn nil\n   663→\t\t\t}\n   664→\t\t\tif err := stream.Send(&pb.LogEntry{\n   665→\t\t\t\tType:      \"log\",\n   666→\t\t\t\tStepName:  line.StepName,\n   667→\t\t\t\tMessage:   line.Content,\n   668→\t\t\t\tTimestamp: line.Timestamp,\n   669→\t\t\t}); err != nil {\n   670→\t\t\t\treturn err\n   671→\t\t\t}\n   672→\t\t}\n   673→\t}\n   674→}\n   675→\n   676→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   677→\ts.mu.Lock()\n   678→\tcontainerID, ok := s.runIDs[req.RunId]\n   679→\ts.mu.Unlock()\n   680→\n   681→\tif !ok {\n   682→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   683→\t}\n   684→\n   685→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   686→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   687→\t}\n   688→\n   689→\t// Mark as cancelled in store\n   690→\trun, err := s.store.GetRun(ctx, req.RunId)\n   691→\tif err == nil {\n   692→\t\trun.Complete(domain.RunStateCancelled)\n   693→\t\t_ = s.store.UpdateRun(ctx, run)\n   694→\t}\n   695→\n   696→\treturn &pb.StopRunResponse{}, nil\n   697→}\n   698→\n   699→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   700→\tif s.container == nil {\n   701→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   702→\t}\n   703→\n   704→\tid := req.Id\n   705→\tif id == \"\" {\n   706→\t\treturn nil, fmt.Errorf(\"id is required\")\n   707→\t}\n   708→\n   709→\t// Try to resolve as a run ID first\n   710→\tcontainerID := id\n   711→\trun, err := s.store.GetRun(ctx, id)\n   712→\tif err == nil {\n   713→\t\t// It's a run ID — use the container ID from the run record\n   714→\t\tif run.ContainerID == \"\" {\n   715→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   716→\t\t}\n   717→\t\tcontainerID = run.ContainerID\n   718→\t}\n   719→\n   720→\t// Remove the container\n   721→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   722→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   723→\t}\n   724→\n   725→\t// If we resolved a run, clear the container_kept flag\n   726→\tif run != nil {\n   727→\t\trun.ContainerKept = false\n   728→\t\t_ = s.store.UpdateRun(ctx, run)\n   729→\t}\n   730→\n   731→\treturn &pb.DeleteContainerResponse{}, nil\n   732→}\n   733→\n   734→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   735→\tprojectDir := req.ProjectDir\n   736→\tif projectDir == \"\" {\n   737→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   738→\t}\n   739→\n   740→\t// Verify host.cloche exists\n   741→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   742→\tif _, err := os.Stat(hostPath); err != nil {\n   743→\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n   744→\t}\n   745→\n   746→\t// Load project config for defaults.\n   747→\tprojCfg, _ := config.Load(projectDir)\n   748→\n   749→\tmaxConc := int(req.MaxConcurrent)\n   750→\tif maxConc <= 0 {\n   751→\t\tmaxConc = projCfg.Orchestration.Concurrency\n   752→\t}\n   753→\tif maxConc <= 0 {\n   754→\t\tmaxConc = 1\n   755→\t}\n   756→\n   757→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   758→\n   759→\ts.mu.Lock()\n   760→\tdefer s.mu.Unlock()\n   761→\n   762→\t// Stop existing loop if running.\n   763→\tif existing, ok := s.loops[projectDir]; ok {\n   764→\t\texisting.Stop()\n   765→\t}\n   766→\n   767→\trunFn := func(ctx context.Context, projDir string) (*host.RunResult, error) {\n   768→\t\trunner := &host.Runner{\n   769→\t\t\tDispatcher: s,\n   770→\t\t\tStore:      s.store,\n   771→\t\t}\n   772→\t\treturn runner.Run(ctx, projDir)\n   773→\t}\n   774→\n   775→\tloop := host.NewLoop(host.LoopConfig{\n   776→\t\tProjectDir:    projectDir,\n   777→\t\tMaxConcurrent: maxConc,\n   778→\t\tStaggerDelay:  stagger,\n   779→\t}, s.store, runFn)\n   780→\ts.loops[projectDir] = loop\n   781→\tloop.Start()\n   782→\n   783→\treturn &pb.EnableLoopResponse{}, nil\n   784→}\n   785→\n   786→func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n   787→\tprojectDir := req.ProjectDir\n   788→\tif projectDir == \"\" {\n   789→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   790→\t}\n   791→\n   792→\ts.mu.Lock()\n   793→\tdefer s.mu.Unlock()\n   794→\n   795→\tif loop, ok := s.loops[projectDir]; ok {\n   796→\t\tloop.Stop()\n   797→\t\tdelete(s.loops, projectDir)\n   798→\t}\n   799→\n   800→\treturn &pb.DisableLoopResponse{}, nil\n   801→}\n   802→\n   803→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n   804→\t// Stop all orchestration loops.\n   805→\ts.mu.Lock()\n   806→\tfor _, loop := range s.loops {\n   807→\t\tloop.Stop()\n   808→\t}\n   809→\ts.loops = make(map[string]*host.Loop)\n   810→\ts.mu.Unlock()\n   811→\n   812→\tif s.shutdownFn == nil {\n   813→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n   814→\t}\n   815→\tgo s.shutdownFn()\n   816→\treturn &pb.ShutdownResponse{}, nil\n   817→}\n   818→\n   819→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n   820→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n   821→\tentries, err := os.ReadDir(outputDir)\n   822→\tif err != nil {\n   823→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n   824→\t\treturn\n   825→\t}\n   826→\n   827→\tnow := time.Now()\n   828→\tfor _, entry := range entries {\n   829→\t\tif entry.IsDir() {\n   830→\t\t\tcontinue\n   831→\t\t}\n   832→\t\tname := entry.Name()\n   833→\t\tif !strings.HasSuffix(name, \".log\") {\n   834→\t\t\tcontinue\n   835→\t\t}\n   836→\n   837→\t\tvar fileType, stepName string\n   838→\t\tbase := strings.TrimSuffix(name, \".log\")\n   839→\n   840→\t\tswitch {\n   841→\t\tcase name == \"full.log\":\n   842→\t\t\tfileType = \"full\"\n   843→\t\tcase name == \"container.log\":\n   844→\t\t\t// container.log is internal, not indexed as a user-facing log type\n   845→\t\t\tcontinue\n   846→\t\tcase strings.HasPrefix(name, \"llm-\"):\n   847→\t\t\tfileType = \"llm\"\n   848→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n   849→\t\tdefault:\n   850→\t\t\tfileType = \"script\"\n   851→\t\t\tstepName = base\n   852→\t\t}\n   853→\n   854→\t\tinfo, _ := entry.Info()\n   855→\t\tvar fileSize int64\n   856→\t\tif info != nil {\n   857→\t\t\tfileSize = info.Size()\n   858→\t\t}\n   859→\n   860→\t\tlogEntry := &ports.LogFileEntry{\n   861→\t\t\tRunID:     runID,\n   862→\t\t\tStepName:  stepName,\n   863→\t\t\tFileType:  fileType,\n   864→\t\t\tFilePath:  filepath.Join(outputDir, name),\n   865→\t\t\tFileSize:  fileSize,\n   866→\t\t\tCreatedAt: now,\n   867→\t\t}\n   868→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n   869→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n   870→\t\t}\n   871→\t}\n   872→}\n   873→\n   874→func gitHEAD(dir string) string {\n   875→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n   876→\tcmd.Dir = dir\n   877→\tout, err := cmd.Output()\n   878→\tif err != nil {\n   879→\t\treturn \"\"\n   880→\t}\n   881→\treturn strings.TrimSpace(string(out))\n   882→}\n   883→"}]},"parent_tool_use_id":null,"session_id":"7e3762fb-e565-4c0e-b9b1-9371ff7bfffd","uuid":"4de9ee31-2305-477d-ace0-00c0e9252d96","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server.go","content":"package grpc\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\t\"github.com/cloche-dev/cloche/internal/host\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\trpcgrpc \"google.golang.org/grpc\"\n)\n\ntype ClocheServer struct {\n\tpb.UnimplementedClocheServiceServer\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogStore     ports.LogStore\n\tcontainer    ports.ContainerRuntime\n\tdefaultImage string\n\tevolution    *evolution.Trigger\n\tlogBroadcast *logstream.Broadcaster\n\tshutdownFn   func()\n\tmu           sync.Mutex\n\trunIDs       map[string]string      // run_id -> container_id\n\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n}\n\nfunc NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:     store,\n\t\tcontainer: container,\n\t\trunIDs:    make(map[string]string),\n\t\tloops:     make(map[string]*host.Loop),\n\t}\n}\n\nfunc NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:        store,\n\t\tcaptures:     captures,\n\t\tcontainer:    container,\n\t\tdefaultImage: defaultImage,\n\t\trunIDs:       make(map[string]string),\n\t\tloops:        make(map[string]*host.Loop),\n\t}\n}\n\n// SetLogStore attaches a log store to the server for indexing extracted log files.\nfunc (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n\ts.logStore = ls\n}\n\n\n// SetEvolution attaches an evolution trigger to the server.\nfunc (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n\ts.evolution = trigger\n}\n\n// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\nfunc (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n\ts.logBroadcast = b\n}\n\n// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\nfunc (s *ClocheServer) SetShutdownFunc(fn func()) {\n\ts.shutdownFn = fn\n}\n\nfunc (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\t// Generate a unique run ID, retrying on collision\n\tvar runID string\n\tfor attempts := 0; attempts < 10; attempts++ {\n\t\trunID = domain.GenerateRunID(req.WorkflowName)\n\t\texisting, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tbreak // ID is free\n\t\t}\n\t\t// Reuse if completed more than 1 hour ago\n\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n\t\t\t_ = s.store.DeleteRun(ctx, runID)\n\t\t\tbreak\n\t\t}\n\t}\n\n\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n\tif req.Prompt != \"\" {\n\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n\t\t}\n\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n\t\t}\n\t}\n\trun := domain.NewRun(runID, req.WorkflowName)\n\trun.ProjectDir = req.ProjectDir\n\trun.Title = req.Title\n\tif err := s.store.CreateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n\t}\n\n\t// Resolve image: request-level override, then server default\n\timage := req.Image\n\tif image == \"\" {\n\t\timage = s.defaultImage\n\t}\n\n\t// Launch container start + tracking in background so the RPC returns immediately.\n\t// The run stays in \"pending\" state until the container is up.\n\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n\n\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n}\n\n// launchAndTrack starts the container and then tracks it to completion.\n// It runs in a background goroutine with its own context, independent of the\n// RPC context which may be cancelled after RunWorkflow returns.\nfunc (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n\tctx := context.Background()\n\n\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n\t\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\t\tif run != nil {\n\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t\t}\n\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n\t\t\t\treturn\n\t\t}\n\t}\n\n\tbaseSHA := gitHEAD(req.ProjectDir)\n\n\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n\t\tImage:        image,\n\t\tWorkflowName: req.WorkflowName,\n\t\tProjectDir:   req.ProjectDir,\n\t\tRunID:        runID,\n\t\tNetworkAllow: []string{\"*\"},\n\t})\n\tif err != nil {\n\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\tif run != nil {\n\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t}\n\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n\t\treturn\n\t}\n\n\ts.mu.Lock()\n\ts.runIDs[runID] = containerID\n\ts.mu.Unlock()\n\n\trun, _ := s.store.GetRun(ctx, runID)\n\tif run != nil {\n\t\trun.Start()\n\t\trun.ContainerID = containerID\n\t\trun.BaseSHA = baseSHA\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n}\n\nfunc (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n\tctx := context.Background()\n\n\t// Attach to agent output\n\treader, err := s.container.AttachOutput(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n\t\t\treturn\n\t}\n\n\t// Parse JSON-lines status messages\n\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n\tscanner := bufio.NewScanner(reader)\n\tfor scanner.Scan() {\n\t\tvar msg protocol.StatusMessage\n\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Fast path: log messages don't need store interaction.\n\t\tif msg.Type == protocol.MsgLog {\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"llm\",\n\t\t\t\t\tContent:   msg.Message,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\trun, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch msg.Type {\n\t\tcase protocol.MsgStepStarted:\n\t\t\trun.RecordStepStart(msg.StepName)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t\tStartedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"status\",\n\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgStepCompleted:\n\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:    msg.StepName,\n\t\t\t\t\tResult:      msg.Result,\n\t\t\t\t\tCompletedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"status\",\n\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgRunTitle:\n\t\t\tif run.Title == \"\" {\n\t\t\t\trun.Title = msg.Message\n\t\t\t}\n\t\tcase protocol.MsgRunCompleted:\n\t\t\treportedResult = msg.Result\n\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n\t\t}\n\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\treader.Close()\n\n\t// Signal live-stream subscribers that this run is done.\n\tif s.logBroadcast != nil {\n\t\ts.logBroadcast.Finish(runID)\n\t}\n\n\t// Wait for process exit\n\texitCode, err := s.container.Wait(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n\t}\n\n\t// Extract step output files from container before it's removed\n\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n\t\t}\n\t}\n\n\t// Capture full container stdout/stderr before the container is removed\n\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n\t\t}\n\t}\n\n\t// Index extracted log files in the log store\n\tif s.logStore != nil {\n\t\ts.indexLogFiles(ctx, runID, outputDst)\n\t}\n\n\t// Extract results to git branch BEFORE finalizing state, so that\n\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n\t// before the run is marked complete.\n\tresultLabel := reportedResult\n\tif resultLabel == \"\" {\n\t\tif exitCode == 0 {\n\t\t\tresultLabel = \"succeeded\"\n\t\t} else {\n\t\t\tresultLabel = \"failed\"\n\t\t}\n\t}\n\t{\n\t\textractRun, _ := s.store.GetRun(ctx, runID)\n\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n\t\t\t} else {\n\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n\t\t\t}\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n\t\t}\n\t}\n\n\t// Now finalize run state\n\trun, err := s.store.GetRun(ctx, runID)\n\tif err != nil {\n\t\treturn\n\t}\n\tif run.State == domain.RunStateRunning {\n\t\tif reportedResult == \"succeeded\" {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else if reportedResult != \"\" {\n\t\t\trun.Complete(domain.RunStateFailed)\n\t\t} else if exitCode == 0 {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else {\n\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n\t\t}\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\t// Fire evolution trigger if configured\n\tif s.evolution != nil {\n\t\ts.evolution.Fire(projectDir, workflowName, runID)\n\t}\n\n\t// Merge is handled as a workflow step in host.cloche, not here.\n\n\t// Container retention policy:\n\t// - Failed runs: always keep the container for debugging\n\t// - Successful runs + --keep-container: keep the container\n\t// - Successful runs without --keep-container: remove the container\n\trunFinal, _ := s.store.GetRun(ctx, runID)\n\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n\n\tif keepContainer || runFailed {\n\t\treason := \"--keep-container\"\n\t\tif runFailed {\n\t\t\treason = \"run failed\"\n\t\t}\n\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n\t\tif runFinal != nil {\n\t\t\trunFinal.ContainerKept = true\n\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n\t\t}\n\t} else {\n\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n\t\t}\n\t}\n\n\t// Cleanup mapping\n\ts.mu.Lock()\n\tdelete(s.runIDs, runID)\n\ts.mu.Unlock()\n}\n\nfunc (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n\tvar since time.Time\n\tif !req.All {\n\t\tsince = time.Now().Add(-1 * time.Hour)\n\t}\n\truns, err := s.store.ListRuns(ctx, since)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n\t}\n\n\tresp := &pb.ListRunsResponse{}\n\tfor _, run := range runs {\n\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n\t\t\tRunId:        run.ID,\n\t\t\tWorkflowName: run.WorkflowName,\n\t\t\tState:        string(run.State),\n\t\t\tStartedAt:    run.StartedAt.String(),\n\t\t\tErrorMessage: run.ErrorMessage,\n\t\t\tContainerId:  run.ContainerID,\n\t\t\tTitle:        run.Title,\n\t\t\tIsHost:       run.IsHost,\n\t\t})\n\t}\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n\t}\n\n\tresp := &pb.GetStatusResponse{\n\t\tRunId:        run.ID,\n\t\tWorkflowName: run.WorkflowName,\n\t\tState:        string(run.State),\n\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n\t\tErrorMessage: run.ErrorMessage,\n\t\tContainerId:  run.ContainerID,\n\t\tTitle:        run.Title,\n\t\tIsHost:       run.IsHost,\n\t}\n\n\t// Check container liveness\n\tif run.ContainerID != \"\" && s.container != nil {\n\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n\t\t\tresp.ContainerAlive = cs.Running\n\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n\t\t\t}\n\t\t}\n\t}\n\n\t// Load step executions from captures store if available\n\tif s.captures != nil {\n\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\t\tif err == nil {\n\t\t\tfor _, exec := range captures {\n\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\t\tStepName:    exec.StepName,\n\t\t\t\t\tResult:      exec.Result,\n\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, exec := range run.StepExecutions {\n\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\tStepName:    exec.StepName,\n\t\t\t\tResult:      exec.Result,\n\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t})\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tctx := stream.Context()\n\n\t// Verify run exists\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n\t}\n\n\t// If step_name or log_type filter is set, serve content directly from the log index\n\tif req.StepName != \"\" || req.LogType != \"\" {\n\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n\t}\n\n\t// For active runs, stream live from the broadcaster so callers can tail output.\n\tif (run.State == domain.RunStateRunning || run.State == domain.RunStatePending) && s.logBroadcast != nil {\n\t\treturn s.streamLiveLogs(req.RunId, stream)\n\t}\n\n\tif s.captures == nil {\n\t\treturn fmt.Errorf(\"captures store not configured\")\n\t}\n\n\t// Check for full.log first — if it exists, serve it as the unified log\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: string(data),\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t\t// Still send run completion entry\n\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"run_completed\",\n\t\t\t\tResult:    string(run.State),\n\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}\n\n\t// Fall back to capture-based streaming\n\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n\t}\n\n\tfor _, exec := range captures {\n\t\t// Captures are stored as separate rows: one for step_started (no Result)\n\t\t// and one for step_completed (has Result).\n\t\tif exec.Result == \"\" {\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_started\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tTimestamp: exec.StartedAt.String(),\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t} else {\n\t\t\t// Read step output from file, falling back to container.log\n\t\t\tvar output string\n\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\t\t\toutput = string(data)\n\t\t\t} else {\n\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n\t\t\t\t\toutput = string(data)\n\t\t\t\t}\n\t\t\t}\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_completed\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tResult:    exec.Result,\n\t\t\t\tTimestamp: exec.CompletedAt.String(),\n\t\t\t\tMessage:   output,\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\t// Send run completion entry\n\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:      \"run_completed\",\n\t\t\tResult:    string(run.State),\n\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\tMessage:   run.ErrorMessage,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// streamFilteredLogs serves log content filtered by step name and/or log type.\n// It uses the log index when available, falling back to file path conventions.\nfunc (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n\n\t// Try log index first\n\tif s.logStore != nil {\n\t\tvar logFiles []*ports.LogFileEntry\n\t\tvar err error\n\n\t\tif req.StepName != \"\" && req.LogType != \"\" {\n\t\t\t// Filter by both step and type\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t\tif err == nil {\n\t\t\t\tfiltered := logFiles[:0]\n\t\t\t\tfor _, lf := range logFiles {\n\t\t\t\t\tif lf.FileType == req.LogType {\n\t\t\t\t\t\tfiltered = append(filtered, lf)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tlogFiles = filtered\n\t\t\t}\n\t\t} else if req.StepName != \"\" {\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t} else {\n\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n\t\t}\n\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr != nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\t\tType:     lf.FileType + \"_log\",\n\t\t\t\t\tStepName: lf.StepName,\n\t\t\t\t\tMessage:  string(data),\n\t\t\t\t}); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Fall back to file path conventions\n\tif req.StepName != \"\" {\n\t\tvar logPath string\n\t\tswitch req.LogType {\n\t\tcase \"llm\":\n\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n\t\tdefault:\n\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n\t\t}\n\n\t\tdata, err := os.ReadFile(logPath)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n\t\t}\n\t\treturn stream.Send(&pb.LogEntry{\n\t\t\tType:     \"step_log\",\n\t\t\tStepName: req.StepName,\n\t\t\tMessage:  string(data),\n\t\t})\n\t}\n\n\treturn fmt.Errorf(\"no log files found matching filter\")\n}\n\n// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n// time for an active run. The stream closes when the run completes or the\n// client disconnects.\nfunc (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tsub := s.logBroadcast.Subscribe(runID)\n\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n\n\tctx := stream.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Run completed — send terminal entry.\n\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n\t\t\t\t\t\tType:      \"run_completed\",\n\t\t\t\t\t\tResult:    string(run.State),\n\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"log\",\n\t\t\t\tStepName:  line.StepName,\n\t\t\t\tMessage:   line.Content,\n\t\t\t\tTimestamp: line.Timestamp,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n\ts.mu.Lock()\n\tcontainerID, ok := s.runIDs[req.RunId]\n\ts.mu.Unlock()\n\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n\t}\n\n\tif err := s.container.Stop(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n\t}\n\n\t// Mark as cancelled in store\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err == nil {\n\t\trun.Complete(domain.RunStateCancelled)\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.StopRunResponse{}, nil\n}\n\nfunc (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\tid := req.Id\n\tif id == \"\" {\n\t\treturn nil, fmt.Errorf(\"id is required\")\n\t}\n\n\t// Try to resolve as a run ID first\n\tcontainerID := id\n\trun, err := s.store.GetRun(ctx, id)\n\tif err == nil {\n\t\t// It's a run ID — use the container ID from the run record\n\t\tif run.ContainerID == \"\" {\n\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n\t\t}\n\t\tcontainerID = run.ContainerID\n\t}\n\n\t// Remove the container\n\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n\t}\n\n\t// If we resolved a run, clear the container_kept flag\n\tif run != nil {\n\t\trun.ContainerKept = false\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.DeleteContainerResponse{}, nil\n}\n\nfunc (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n\tprojectDir := req.ProjectDir\n\tif projectDir == \"\" {\n\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n\t}\n\n\t// Verify host.cloche exists\n\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n\tif _, err := os.Stat(hostPath); err != nil {\n\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n\t}\n\n\t// Load project config for defaults.\n\tprojCfg, _ := config.Load(projectDir)\n\n\tmaxConc := int(req.MaxConcurrent)\n\tif maxConc <= 0 {\n\t\tmaxConc = projCfg.Orchestration.Concurrency\n\t}\n\tif maxConc <= 0 {\n\t\tmaxConc = 1\n\t}\n\n\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\t// Stop existing loop if running.\n\tif existing, ok := s.loops[projectDir]; ok {\n\t\texisting.Stop()\n\t}\n\n\trunFn := func(ctx context.Context, projDir string) (*host.RunResult, error) {\n\t\trunner := &host.Runner{\n\t\t\tDispatcher: s,\n\t\t\tStore:      s.store,\n\t\t}\n\t\treturn runner.Run(ctx, projDir)\n\t}\n\n\tloop := host.NewLoop(host.LoopConfig{\n\t\tProjectDir:    projectDir,\n\t\tMaxConcurrent: maxConc,\n\t\tStaggerDelay:  stagger,\n\t}, s.store, runFn)\n\ts.loops[projectDir] = loop\n\tloop.Start()\n\n\treturn &pb.EnableLoopResponse{}, nil\n}\n\nfunc (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n\tprojectDir := req.ProjectDir\n\tif projectDir == \"\" {\n\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n\t}\n\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\tif loop, ok := s.loops[projectDir]; ok {\n\t\tloop.Stop()\n\t\tdelete(s.loops, projectDir)\n\t}\n\n\treturn &pb.DisableLoopResponse{}, nil\n}\n\nfunc (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n\t// Stop all orchestration loops.\n\ts.mu.Lock()\n\tfor _, loop := range s.loops {\n\t\tloop.Stop()\n\t}\n\ts.loops = make(map[string]*host.Loop)\n\ts.mu.Unlock()\n\n\tif s.shutdownFn == nil {\n\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n\t}\n\tgo s.shutdownFn()\n\treturn &pb.ShutdownResponse{}, nil\n}\n\n// indexLogFiles scans the extracted output directory and creates log_files index entries.\nfunc (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tname := entry.Name()\n\t\tif !strings.HasSuffix(name, \".log\") {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar fileType, stepName string\n\t\tbase := strings.TrimSuffix(name, \".log\")\n\n\t\tswitch {\n\t\tcase name == \"full.log\":\n\t\t\tfileType = \"full\"\n\t\tcase name == \"container.log\":\n\t\t\t// container.log is internal, not indexed as a user-facing log type\n\t\t\tcontinue\n\t\tcase strings.HasPrefix(name, \"llm-\"):\n\t\t\tfileType = \"llm\"\n\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n\t\tdefault:\n\t\t\tfileType = \"script\"\n\t\t\tstepName = base\n\t\t}\n\n\t\tinfo, _ := entry.Info()\n\t\tvar fileSize int64\n\t\tif info != nil {\n\t\t\tfileSize = info.Size()\n\t\t}\n\n\t\tlogEntry := &ports.LogFileEntry{\n\t\t\tRunID:     runID,\n\t\t\tStepName:  stepName,\n\t\t\tFileType:  fileType,\n\t\t\tFilePath:  filepath.Join(outputDir, name),\n\t\t\tFileSize:  fileSize,\n\t\t\tCreatedAt: now,\n\t\t}\n\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n\t\t}\n\t}\n}\n\nfunc gitHEAD(dir string) string {\n\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\treturn strings.TrimSpace(string(out))\n}\n","numLines":883,"startLine":1,"totalLines":883}}}
