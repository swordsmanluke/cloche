[2026-03-07T18:50:51Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UWUeXyiRMC9tTJpLmiH8w6","type":"tool_result","content":"     1→package orchestrator\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"sync\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/config\"\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14→)\n    15→\n    16→// RunDispatcher dispatches a workflow run and returns the run ID.\n    17→type RunDispatcher func(ctx context.Context, workflowName, projectDir, prompt string) (string, error)\n    18→\n    19→// ProjectConfig holds orchestration settings for a single project.\n    20→type ProjectConfig struct {\n    21→\tDir         string\n    22→\tWorkflow    string\n    23→\tConcurrency int\n    24→\tTracker     ports.TaskTracker\n    25→\tEnabled     bool\n    26→}\n    27→\n    28→// ParseHostWorkflowFunc parses a host.cloche file and returns the named workflow.\n    29→type ParseHostWorkflowFunc func(input string) (*domain.Workflow, error)\n    30→\n    31→// Orchestrator pulls ready tasks and dispatches workflow runs, respecting\n    32→// per-project concurrency limits.\n    33→type Orchestrator struct {\n    34→\tpromptGen          PromptGenerator\n    35→\tdispatch           RunDispatcher\n    36→\tmu                 sync.Mutex\n    37→\tprojects           map[string]*ProjectConfig // keyed by Dir\n    38→\tinFlight           map[string]int            // keyed by Dir\n    39→\tinFlightTasks      map[string]string         // runID -> taskID\n    40→\tinFlightTaskSet    map[string]map[string]bool // projectDir -> set of taskIDs in flight\n    41→\thostRunner         *HostRunner\n    42→\tparseHostWorkflow  ParseHostWorkflowFunc\n    43→}\n    44→\n    45→// New creates an Orchestrator.\n    46→func New(promptGen PromptGenerator, dispatch RunDispatcher, opts ...OrchestratorOption) *Orchestrator {\n    47→\to := &Orchestrator{\n    48→\t\tpromptGen:       promptGen,\n    49→\t\tdispatch:        dispatch,\n    50→\t\tprojects:        make(map[string]*ProjectConfig),\n    51→\t\tinFlight:        make(map[string]int),\n    52→\t\tinFlightTasks:   make(map[string]string),\n    53→\t\tinFlightTaskSet: make(map[string]map[string]bool),\n    54→\t}\n    55→\tfor _, opt := range opts {\n    56→\t\topt(o)\n    57→\t}\n    58→\treturn o\n    59→}\n    60→\n    61→// OrchestratorOption configures optional fields on the Orchestrator.\n    62→type OrchestratorOption func(*Orchestrator)\n    63→\n    64→// WithHostRunner sets the HostRunner for host.cloche support.\n    65→func WithHostRunner(hr *HostRunner) OrchestratorOption {\n    66→\treturn func(o *Orchestrator) {\n    67→\t\to.hostRunner = hr\n    68→\t}\n    69→}\n    70→\n    71→// WithParseHostWorkflow sets the parser function for host.cloche files.\n    72→func WithParseHostWorkflow(fn ParseHostWorkflowFunc) OrchestratorOption {\n    73→\treturn func(o *Orchestrator) {\n    74→\t\to.parseHostWorkflow = fn\n    75→\t}\n    76→}\n    77→\n    78→// Register adds a project to the orchestrator.\n    79→func (o *Orchestrator) Register(pc *ProjectConfig) {\n    80→\to.mu.Lock()\n    81→\tdefer o.mu.Unlock()\n    82→\tpc.Enabled = true\n    83→\to.projects[pc.Dir] = pc\n    84→}\n    85→\n    86→// Status returns the enabled flag, in-flight count, and concurrency for a project.\n    87→func (o *Orchestrator) Status(dir string) (enabled bool, inFlight int, concurrency int) {\n    88→\to.mu.Lock()\n    89→\tdefer o.mu.Unlock()\n    90→\tpc, ok := o.projects[dir]\n    91→\tif !ok {\n    92→\t\treturn false, 0, 0\n    93→\t}\n    94→\treturn pc.Enabled, o.inFlight[dir], pc.Concurrency\n    95→}\n    96→\n    97→// SetEnabled enables or disables orchestration for a project.\n    98→func (o *Orchestrator) SetEnabled(dir string, enabled bool) {\n    99→\to.mu.Lock()\n   100→\tdefer o.mu.Unlock()\n   101→\tif pc, ok := o.projects[dir]; ok {\n   102→\t\tpc.Enabled = enabled\n   103→\t}\n   104→}\n   105→\n   106→// SetConcurrency overrides the concurrency limit for a project (runtime only).\n   107→func (o *Orchestrator) SetConcurrency(dir string, concurrency int) {\n   108→\to.mu.Lock()\n   109→\tdefer o.mu.Unlock()\n   110→\tif pc, ok := o.projects[dir]; ok {\n   111→\t\tpc.Concurrency = concurrency\n   112→\t}\n   113→}\n   114→\n   115→// RegisterFromConfig registers a project using its config file.\n   116→// Returns false if orchestration is not enabled for the project.\n   117→func (o *Orchestrator) RegisterFromConfig(projectDir string, tracker ports.TaskTracker) bool {\n   118→\tcfg, err := config.Load(projectDir)\n   119→\tif err != nil || !cfg.Orchestration.Enabled {\n   120→\t\treturn false\n   121→\t}\n   122→\tworkflow := cfg.Orchestration.Workflow\n   123→\tif workflow == \"\" {\n   124→\t\tworkflow = \"develop\"\n   125→\t}\n   126→\tconcurrency := cfg.Orchestration.Concurrency\n   127→\tif concurrency < 1 {\n   128→\t\tconcurrency = 1\n   129→\t}\n   130→\to.Register(&ProjectConfig{\n   131→\t\tDir:         projectDir,\n   132→\t\tWorkflow:    workflow,\n   133→\t\tConcurrency: concurrency,\n   134→\t\tTracker:     tracker,\n   135→\t\tEnabled:     true,\n   136→\t})\n   137→\treturn true\n   138→}\n   139→\n   140→// trackTask records a run-to-task mapping for later completion/failure.\n   141→func (o *Orchestrator) trackTask(projectDir, runID, taskID string) {\n   142→\to.inFlightTasks[runID] = taskID\n   143→\tif o.inFlightTaskSet[projectDir] == nil {\n   144→\t\to.inFlightTaskSet[projectDir] = make(map[string]bool)\n   145→\t}\n   146→\to.inFlightTaskSet[projectDir][taskID] = true\n   147→}\n   148→\n   149→// untrackTask removes a run-to-task mapping. Returns the task ID.\n   150→func (o *Orchestrator) untrackTask(projectDir, runID string) string {\n   151→\ttaskID := o.inFlightTasks[runID]\n   152→\tdelete(o.inFlightTasks, runID)\n   153→\tif taskID != \"\" && o.inFlightTaskSet[projectDir] != nil {\n   154→\t\tdelete(o.inFlightTaskSet[projectDir], taskID)\n   155→\t}\n   156→\treturn taskID\n   157→}\n   158→\n   159→// isTaskInFlight checks if a task already has an active run.\n   160→func (o *Orchestrator) isTaskInFlight(projectDir, taskID string) bool {\n   161→\tif set := o.inFlightTaskSet[projectDir]; set != nil {\n   162→\t\treturn set[taskID]\n   163→\t}\n   164→\treturn false\n   165→}\n   166→\n   167→// RecoverStaleTasks resets in_progress tasks that have no corresponding\n   168→// in-flight run. This should be called on daemon startup to clean up after\n   169→// crashes where tasks were claimed but never completed or failed.\n   170→func (o *Orchestrator) RecoverStaleTasks(ctx context.Context) int {\n   171→\to.mu.Lock()\n   172→\tdirs := make([]string, 0, len(o.projects))\n   173→\tfor dir := range o.projects {\n   174→\t\tdirs = append(dirs, dir)\n   175→\t}\n   176→\to.mu.Unlock()\n   177→\n   178→\ttotal := 0\n   179→\tfor _, dir := range dirs {\n   180→\t\to.mu.Lock()\n   181→\t\tpc := o.projects[dir]\n   182→\t\tactiveIDs := make(map[string]bool)\n   183→\t\tif set := o.inFlightTaskSet[dir]; set != nil {\n   184→\t\t\tfor id := range set {\n   185→\t\t\t\tactiveIDs[id] = true\n   186→\t\t\t}\n   187→\t\t}\n   188→\t\to.mu.Unlock()\n   189→\n   190→\t\tn, err := pc.Tracker.RecoverStaleTasks(ctx, activeIDs)\n   191→\t\tif err != nil {\n   192→\t\t\tlog.Printf(\"orchestrator: failed to recover stale tasks for %s: %v\", dir, err)\n   193→\t\t\tcontinue\n   194→\t\t}\n   195→\t\tif n > 0 {\n   196→\t\t\tlog.Printf(\"orchestrator: recovered %d stale task(s) in %s\", n, dir)\n   197→\t\t}\n   198→\t\ttotal += n\n   199→\t}\n   200→\treturn total\n   201→}\n   202→\n   203→// Run performs one orchestration cycle for a single project. It returns the\n   204→// number of runs dispatched.\n   205→func (o *Orchestrator) Run(ctx context.Context, projectDir string) (int, error) {\n   206→\to.mu.Lock()\n   207→\tpc, ok := o.projects[projectDir]\n   208→\tif !ok {\n   209→\t\to.mu.Unlock()\n   210→\t\treturn 0, fmt.Errorf(\"project %q not registered\", projectDir)\n   211→\t}\n   212→\tif !pc.Enabled {\n   213→\t\to.mu.Unlock()\n   214→\t\treturn 0, nil\n   215→\t}\n   216→\tcurrent := o.inFlight[projectDir]\n   217→\tavailable := pc.Concurrency - current\n   218→\to.mu.Unlock()\n   219→\n   220→\tif available <= 0 {\n   221→\t\treturn 0, nil\n   222→\t}\n   223→\n   224→\ttasks, err := pc.Tracker.ListReady(ctx, projectDir)\n   225→\tif err != nil {\n   226→\t\treturn 0, fmt.Errorf(\"listing ready tasks: %w\", err)\n   227→\t}\n   228→\n   229→\t// Check if host.cloche exists for this project\n   230→\thostWorkflowPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   231→\tuseHostWorkflow := o.hostRunner != nil && o.parseHostWorkflow != nil\n   232→\tif useHostWorkflow {\n   233→\t\tif _, err := os.Stat(hostWorkflowPath); os.IsNotExist(err) {\n   234→\t\t\tuseHostWorkflow = false\n   235→\t\t}\n   236→\t}\n   237→\n   238→\tdispatched := 0\n   239→\tfor i := 0; i < len(tasks) && dispatched < available; i++ {\n   240→\t\ttask := tasks[i]\n   241→\n   242→\t\t// Skip tasks that already have an in-flight run (dedup)\n   243→\t\to.mu.Lock()\n   244→\t\talreadyRunning := o.isTaskInFlight(projectDir, task.ID)\n   245→\t\to.mu.Unlock()\n   246→\t\tif alreadyRunning {\n   247→\t\t\tlog.Printf(\"orchestrator: skipping task %s (already in flight)\", task.ID)\n   248→\t\t\tcontinue\n   249→\t\t}\n   250→\n   251→\t\tif err := pc.Tracker.Claim(ctx, task.ID); err != nil {\n   252→\t\t\tlog.Printf(\"orchestrator: failed to claim task %s: %v\", task.ID, err)\n   253→\t\t\tcontinue\n   254→\t\t}\n   255→\n   256→\t\tif useHostWorkflow {\n   257→\t\t\t// Host workflow path\n   258→\t\t\tdata, err := os.ReadFile(hostWorkflowPath)\n   259→\t\t\tif err != nil {\n   260→\t\t\t\tlog.Printf(\"orchestrator: failed to read host.cloche for task %s: %v\", task.ID, err)\n   261→\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   262→\t\t\t\tcontinue\n   263→\t\t\t}\n   264→\n   265→\t\t\twf, err := o.parseHostWorkflow(string(data))\n   266→\t\t\tif err != nil {\n   267→\t\t\t\tlog.Printf(\"orchestrator: failed to parse host.cloche for task %s: %v\", task.ID, err)\n   268→\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   269→\t\t\t\tcontinue\n   270→\t\t\t}\n   271→\n   272→\t\t\torchRunID := domain.GenerateRunID(\"orchestrate\")\n   273→\n   274→\t\t\to.mu.Lock()\n   275→\t\t\to.inFlight[projectDir]++\n   276→\t\t\to.trackTask(projectDir, orchRunID, task.ID)\n   277→\t\t\to.mu.Unlock()\n   278→\n   279→\t\t\thr := &HostRunner{\n   280→\t\t\t\tDispatch:   o.hostRunner.Dispatch,\n   281→\t\t\t\tWaitRun:    o.hostRunner.WaitRun,\n   282→\t\t\t\tProjectDir: projectDir,\n   283→\t\t\t}\n   284→\n   285→\t\t\tgo func(task ports.TrackerTask, runID string) {\n   286→\t\t\t\tresult, err := hr.RunWorkflow(ctx, wf, task, runID)\n   287→\n   288→\t\t\t\to.mu.Lock()\n   289→\t\t\t\to.untrackTask(projectDir, runID)\n   290→\t\t\t\tif o.inFlight[projectDir] > 0 {\n   291→\t\t\t\t\to.inFlight[projectDir]--\n   292→\t\t\t\t}\n   293→\t\t\t\to.mu.Unlock()\n   294→\n   295→\t\t\t\tif err != nil {\n   296→\t\t\t\t\tlog.Printf(\"orchestrator: host workflow error for task %s: %v\", task.ID, err)\n   297→\t\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   298→\t\t\t\t} else if result == domain.StepDone {\n   299→\t\t\t\t\tlog.Printf(\"orchestrator: task %s completed successfully\", task.ID)\n   300→\t\t\t\t\t_ = pc.Tracker.Complete(ctx, task.ID)\n   301→\t\t\t\t} else {\n   302→\t\t\t\t\tlog.Printf(\"orchestrator: task %s aborted\", task.ID)\n   303→\t\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   304→\t\t\t\t}\n   305→\t\t\t}(task, orchRunID)\n   306→\n   307→\t\t\tlog.Printf(\"orchestrator: started host workflow %s for task %s in %s\", orchRunID, task.ID, projectDir)\n   308→\t\t\tdispatched++\n   309→\t\t} else {\n   310→\t\t\t// Fallback: existing promptGen → dispatch path\n   311→\t\t\tprompt, err := o.promptGen.Generate(ctx, task, projectDir)\n   312→\t\t\tif err != nil {\n   313→\t\t\t\tlog.Printf(\"orchestrator: failed to generate prompt for task %s: %v\", task.ID, err)\n   314→\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   315→\t\t\t\tcontinue\n   316→\t\t\t}\n   317→\n   318→\t\t\trunID, err := o.dispatch(ctx, pc.Workflow, projectDir, prompt)\n   319→\t\t\tif err != nil {\n   320→\t\t\t\tlog.Printf(\"orchestrator: failed to dispatch run for task %s: %v\", task.ID, err)\n   321→\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   322→\t\t\t\tcontinue\n   323→\t\t\t}\n   324→\n   325→\t\t\to.mu.Lock()\n   326→\t\t\to.inFlight[projectDir]++\n   327→\t\t\to.trackTask(projectDir, runID, task.ID)\n   328→\t\t\to.mu.Unlock()\n   329→\n   330→\t\t\tlog.Printf(\"orchestrator: dispatched run %s for task %s in %s\", runID, task.ID, projectDir)\n   331→\t\t\tdispatched++\n   332→\t\t}\n   333→\t}\n   334→\n   335→\treturn dispatched, nil\n   336→}\n   337→\n   338→// TriggerAll runs orchestration for all registered projects. Returns total\n   339→// dispatched count.\n   340→func (o *Orchestrator) TriggerAll(ctx context.Context) int {\n   341→\to.mu.Lock()\n   342→\tdirs := make([]string, 0, len(o.projects))\n   343→\tfor dir := range o.projects {\n   344→\t\tdirs = append(dirs, dir)\n   345→\t}\n   346→\to.mu.Unlock()\n   347→\n   348→\ttotal := 0\n   349→\tfor _, dir := range dirs {\n   350→\t\tn, err := o.Run(ctx, dir)\n   351→\t\tif err != nil {\n   352→\t\t\tlog.Printf(\"orchestrator: error for project %s: %v\", dir, err)\n   353→\t\t\tcontinue\n   354→\t\t}\n   355→\t\ttotal += n\n   356→\t}\n   357→\treturn total\n   358→}\n   359→\n   360→// OnRunComplete should be called when a workflow run finishes. It looks up the\n   361→// associated task, completes or fails it in the tracker, decrements the\n   362→// in-flight counter, and triggers a new orchestration cycle.\n   363→func (o *Orchestrator) OnRunComplete(ctx context.Context, projectDir string, runID string, state domain.RunState) {\n   364→\to.mu.Lock()\n   365→\tpc := o.projects[projectDir]\n   366→\ttaskID := o.untrackTask(projectDir, runID)\n   367→\tif o.inFlight[projectDir] > 0 {\n   368→\t\to.inFlight[projectDir]--\n   369→\t}\n   370→\to.mu.Unlock()\n   371→\n   372→\t// Close/fail the associated task in the tracker\n   373→\tif taskID != \"\" && pc != nil {\n   374→\t\tif state == domain.RunStateSucceeded {\n   375→\t\t\tlog.Printf(\"orchestrator: completing task %s (run %s succeeded)\", taskID, runID)\n   376→\t\t\t_ = pc.Tracker.Complete(ctx, taskID)\n   377→\t\t} else {\n   378→\t\t\tlog.Printf(\"orchestrator: failing task %s (run %s state: %s)\", taskID, runID, state)\n   379→\t\t\t_ = pc.Tracker.Fail(ctx, taskID)\n   380→\t\t}\n   381→\t}\n   382→\n   383→\tif _, err := o.Run(ctx, projectDir); err != nil {\n   384→\t\tlog.Printf(\"orchestrator: post-completion trigger failed for %s: %v\", projectDir, err)\n   385→\t}\n   386→}\n   387→\n   388→// InFlight returns the current in-flight run count for a project.\n   389→func (o *Orchestrator) InFlight(projectDir string) int {\n   390→\to.mu.Lock()\n   391→\tdefer o.mu.Unlock()\n   392→\treturn o.inFlight[projectDir]\n   393→}\n   394→"}]},"parent_tool_use_id":null,"session_id":"92f06db3-be18-4832-ac12-993c8ca2e234","uuid":"1a41ee7d-0b00-4697-9dbf-238a4f6d1f11","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/orchestrator/orchestrator.go","content":"package orchestrator\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sync\"\n\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// RunDispatcher dispatches a workflow run and returns the run ID.\ntype RunDispatcher func(ctx context.Context, workflowName, projectDir, prompt string) (string, error)\n\n// ProjectConfig holds orchestration settings for a single project.\ntype ProjectConfig struct {\n\tDir         string\n\tWorkflow    string\n\tConcurrency int\n\tTracker     ports.TaskTracker\n\tEnabled     bool\n}\n\n// ParseHostWorkflowFunc parses a host.cloche file and returns the named workflow.\ntype ParseHostWorkflowFunc func(input string) (*domain.Workflow, error)\n\n// Orchestrator pulls ready tasks and dispatches workflow runs, respecting\n// per-project concurrency limits.\ntype Orchestrator struct {\n\tpromptGen          PromptGenerator\n\tdispatch           RunDispatcher\n\tmu                 sync.Mutex\n\tprojects           map[string]*ProjectConfig // keyed by Dir\n\tinFlight           map[string]int            // keyed by Dir\n\tinFlightTasks      map[string]string         // runID -> taskID\n\tinFlightTaskSet    map[string]map[string]bool // projectDir -> set of taskIDs in flight\n\thostRunner         *HostRunner\n\tparseHostWorkflow  ParseHostWorkflowFunc\n}\n\n// New creates an Orchestrator.\nfunc New(promptGen PromptGenerator, dispatch RunDispatcher, opts ...OrchestratorOption) *Orchestrator {\n\to := &Orchestrator{\n\t\tpromptGen:       promptGen,\n\t\tdispatch:        dispatch,\n\t\tprojects:        make(map[string]*ProjectConfig),\n\t\tinFlight:        make(map[string]int),\n\t\tinFlightTasks:   make(map[string]string),\n\t\tinFlightTaskSet: make(map[string]map[string]bool),\n\t}\n\tfor _, opt := range opts {\n\t\topt(o)\n\t}\n\treturn o\n}\n\n// OrchestratorOption configures optional fields on the Orchestrator.\ntype OrchestratorOption func(*Orchestrator)\n\n// WithHostRunner sets the HostRunner for host.cloche support.\nfunc WithHostRunner(hr *HostRunner) OrchestratorOption {\n\treturn func(o *Orchestrator) {\n\t\to.hostRunner = hr\n\t}\n}\n\n// WithParseHostWorkflow sets the parser function for host.cloche files.\nfunc WithParseHostWorkflow(fn ParseHostWorkflowFunc) OrchestratorOption {\n\treturn func(o *Orchestrator) {\n\t\to.parseHostWorkflow = fn\n\t}\n}\n\n// Register adds a project to the orchestrator.\nfunc (o *Orchestrator) Register(pc *ProjectConfig) {\n\to.mu.Lock()\n\tdefer o.mu.Unlock()\n\tpc.Enabled = true\n\to.projects[pc.Dir] = pc\n}\n\n// Status returns the enabled flag, in-flight count, and concurrency for a project.\nfunc (o *Orchestrator) Status(dir string) (enabled bool, inFlight int, concurrency int) {\n\to.mu.Lock()\n\tdefer o.mu.Unlock()\n\tpc, ok := o.projects[dir]\n\tif !ok {\n\t\treturn false, 0, 0\n\t}\n\treturn pc.Enabled, o.inFlight[dir], pc.Concurrency\n}\n\n// SetEnabled enables or disables orchestration for a project.\nfunc (o *Orchestrator) SetEnabled(dir string, enabled bool) {\n\to.mu.Lock()\n\tdefer o.mu.Unlock()\n\tif pc, ok := o.projects[dir]; ok {\n\t\tpc.Enabled = enabled\n\t}\n}\n\n// SetConcurrency overrides the concurrency limit for a project (runtime only).\nfunc (o *Orchestrator) SetConcurrency(dir string, concurrency int) {\n\to.mu.Lock()\n\tdefer o.mu.Unlock()\n\tif pc, ok := o.projects[dir]; ok {\n\t\tpc.Concurrency = concurrency\n\t}\n}\n\n// RegisterFromConfig registers a project using its config file.\n// Returns false if orchestration is not enabled for the project.\nfunc (o *Orchestrator) RegisterFromConfig(projectDir string, tracker ports.TaskTracker) bool {\n\tcfg, err := config.Load(projectDir)\n\tif err != nil || !cfg.Orchestration.Enabled {\n\t\treturn false\n\t}\n\tworkflow := cfg.Orchestration.Workflow\n\tif workflow == \"\" {\n\t\tworkflow = \"develop\"\n\t}\n\tconcurrency := cfg.Orchestration.Concurrency\n\tif concurrency < 1 {\n\t\tconcurrency = 1\n\t}\n\to.Register(&ProjectConfig{\n\t\tDir:         projectDir,\n\t\tWorkflow:    workflow,\n\t\tConcurrency: concurrency,\n\t\tTracker:     tracker,\n\t\tEnabled:     true,\n\t})\n\treturn true\n}\n\n// trackTask records a run-to-task mapping for later completion/failure.\nfunc (o *Orchestrator) trackTask(projectDir, runID, taskID string) {\n\to.inFlightTasks[runID] = taskID\n\tif o.inFlightTaskSet[projectDir] == nil {\n\t\to.inFlightTaskSet[projectDir] = make(map[string]bool)\n\t}\n\to.inFlightTaskSet[projectDir][taskID] = true\n}\n\n// untrackTask removes a run-to-task mapping. Returns the task ID.\nfunc (o *Orchestrator) untrackTask(projectDir, runID string) string {\n\ttaskID := o.inFlightTasks[runID]\n\tdelete(o.inFlightTasks, runID)\n\tif taskID != \"\" && o.inFlightTaskSet[projectDir] != nil {\n\t\tdelete(o.inFlightTaskSet[projectDir], taskID)\n\t}\n\treturn taskID\n}\n\n// isTaskInFlight checks if a task already has an active run.\nfunc (o *Orchestrator) isTaskInFlight(projectDir, taskID string) bool {\n\tif set := o.inFlightTaskSet[projectDir]; set != nil {\n\t\treturn set[taskID]\n\t}\n\treturn false\n}\n\n// RecoverStaleTasks resets in_progress tasks that have no corresponding\n// in-flight run. This should be called on daemon startup to clean up after\n// crashes where tasks were claimed but never completed or failed.\nfunc (o *Orchestrator) RecoverStaleTasks(ctx context.Context) int {\n\to.mu.Lock()\n\tdirs := make([]string, 0, len(o.projects))\n\tfor dir := range o.projects {\n\t\tdirs = append(dirs, dir)\n\t}\n\to.mu.Unlock()\n\n\ttotal := 0\n\tfor _, dir := range dirs {\n\t\to.mu.Lock()\n\t\tpc := o.projects[dir]\n\t\tactiveIDs := make(map[string]bool)\n\t\tif set := o.inFlightTaskSet[dir]; set != nil {\n\t\t\tfor id := range set {\n\t\t\t\tactiveIDs[id] = true\n\t\t\t}\n\t\t}\n\t\to.mu.Unlock()\n\n\t\tn, err := pc.Tracker.RecoverStaleTasks(ctx, activeIDs)\n\t\tif err != nil {\n\t\t\tlog.Printf(\"orchestrator: failed to recover stale tasks for %s: %v\", dir, err)\n\t\t\tcontinue\n\t\t}\n\t\tif n > 0 {\n\t\t\tlog.Printf(\"orchestrator: recovered %d stale task(s) in %s\", n, dir)\n\t\t}\n\t\ttotal += n\n\t}\n\treturn total\n}\n\n// Run performs one orchestration cycle for a single project. It returns the\n// number of runs dispatched.\nfunc (o *Orchestrator) Run(ctx context.Context, projectDir string) (int, error) {\n\to.mu.Lock()\n\tpc, ok := o.projects[projectDir]\n\tif !ok {\n\t\to.mu.Unlock()\n\t\treturn 0, fmt.Errorf(\"project %q not registered\", projectDir)\n\t}\n\tif !pc.Enabled {\n\t\to.mu.Unlock()\n\t\treturn 0, nil\n\t}\n\tcurrent := o.inFlight[projectDir]\n\tavailable := pc.Concurrency - current\n\to.mu.Unlock()\n\n\tif available <= 0 {\n\t\treturn 0, nil\n\t}\n\n\ttasks, err := pc.Tracker.ListReady(ctx, projectDir)\n\tif err != nil {\n\t\treturn 0, fmt.Errorf(\"listing ready tasks: %w\", err)\n\t}\n\n\t// Check if host.cloche exists for this project\n\thostWorkflowPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n\tuseHostWorkflow := o.hostRunner != nil && o.parseHostWorkflow != nil\n\tif useHostWorkflow {\n\t\tif _, err := os.Stat(hostWorkflowPath); os.IsNotExist(err) {\n\t\t\tuseHostWorkflow = false\n\t\t}\n\t}\n\n\tdispatched := 0\n\tfor i := 0; i < len(tasks) && dispatched < available; i++ {\n\t\ttask := tasks[i]\n\n\t\t// Skip tasks that already have an in-flight run (dedup)\n\t\to.mu.Lock()\n\t\talreadyRunning := o.isTaskInFlight(projectDir, task.ID)\n\t\to.mu.Unlock()\n\t\tif alreadyRunning {\n\t\t\tlog.Printf(\"orchestrator: skipping task %s (already in flight)\", task.ID)\n\t\t\tcontinue\n\t\t}\n\n\t\tif err := pc.Tracker.Claim(ctx, task.ID); err != nil {\n\t\t\tlog.Printf(\"orchestrator: failed to claim task %s: %v\", task.ID, err)\n\t\t\tcontinue\n\t\t}\n\n\t\tif useHostWorkflow {\n\t\t\t// Host workflow path\n\t\t\tdata, err := os.ReadFile(hostWorkflowPath)\n\t\t\tif err != nil {\n\t\t\t\tlog.Printf(\"orchestrator: failed to read host.cloche for task %s: %v\", task.ID, err)\n\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\twf, err := o.parseHostWorkflow(string(data))\n\t\t\tif err != nil {\n\t\t\t\tlog.Printf(\"orchestrator: failed to parse host.cloche for task %s: %v\", task.ID, err)\n\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\torchRunID := domain.GenerateRunID(\"orchestrate\")\n\n\t\t\to.mu.Lock()\n\t\t\to.inFlight[projectDir]++\n\t\t\to.trackTask(projectDir, orchRunID, task.ID)\n\t\t\to.mu.Unlock()\n\n\t\t\thr := &HostRunner{\n\t\t\t\tDispatch:   o.hostRunner.Dispatch,\n\t\t\t\tWaitRun:    o.hostRunner.WaitRun,\n\t\t\t\tProjectDir: projectDir,\n\t\t\t}\n\n\t\t\tgo func(task ports.TrackerTask, runID string) {\n\t\t\t\tresult, err := hr.RunWorkflow(ctx, wf, task, runID)\n\n\t\t\t\to.mu.Lock()\n\t\t\t\to.untrackTask(projectDir, runID)\n\t\t\t\tif o.inFlight[projectDir] > 0 {\n\t\t\t\t\to.inFlight[projectDir]--\n\t\t\t\t}\n\t\t\t\to.mu.Unlock()\n\n\t\t\t\tif err != nil {\n\t\t\t\t\tlog.Printf(\"orchestrator: host workflow error for task %s: %v\", task.ID, err)\n\t\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n\t\t\t\t} else if result == domain.StepDone {\n\t\t\t\t\tlog.Printf(\"orchestrator: task %s completed successfully\", task.ID)\n\t\t\t\t\t_ = pc.Tracker.Complete(ctx, task.ID)\n\t\t\t\t} else {\n\t\t\t\t\tlog.Printf(\"orchestrator: task %s aborted\", task.ID)\n\t\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n\t\t\t\t}\n\t\t\t}(task, orchRunID)\n\n\t\t\tlog.Printf(\"orchestrator: started host workflow %s for task %s in %s\", orchRunID, task.ID, projectDir)\n\t\t\tdispatched++\n\t\t} else {\n\t\t\t// Fallback: existing promptGen → dispatch path\n\t\t\tprompt, err := o.promptGen.Generate(ctx, task, projectDir)\n\t\t\tif err != nil {\n\t\t\t\tlog.Printf(\"orchestrator: failed to generate prompt for task %s: %v\", task.ID, err)\n\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\trunID, err := o.dispatch(ctx, pc.Workflow, projectDir, prompt)\n\t\t\tif err != nil {\n\t\t\t\tlog.Printf(\"orchestrator: failed to dispatch run for task %s: %v\", task.ID, err)\n\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\to.mu.Lock()\n\t\t\to.inFlight[projectDir]++\n\t\t\to.trackTask(projectDir, runID, task.ID)\n\t\t\to.mu.Unlock()\n\n\t\t\tlog.Printf(\"orchestrator: dispatched run %s for task %s in %s\", runID, task.ID, projectDir)\n\t\t\tdispatched++\n\t\t}\n\t}\n\n\treturn dispatched, nil\n}\n\n// TriggerAll runs orchestration for all registered projects. Returns total\n// dispatched count.\nfunc (o *Orchestrator) TriggerAll(ctx context.Context) int {\n\to.mu.Lock()\n\tdirs := make([]string, 0, len(o.projects))\n\tfor dir := range o.projects {\n\t\tdirs = append(dirs, dir)\n\t}\n\to.mu.Unlock()\n\n\ttotal := 0\n\tfor _, dir := range dirs {\n\t\tn, err := o.Run(ctx, dir)\n\t\tif err != nil {\n\t\t\tlog.Printf(\"orchestrator: error for project %s: %v\", dir, err)\n\t\t\tcontinue\n\t\t}\n\t\ttotal += n\n\t}\n\treturn total\n}\n\n// OnRunComplete should be called when a workflow run finishes. It looks up the\n// associated task, completes or fails it in the tracker, decrements the\n// in-flight counter, and triggers a new orchestration cycle.\nfunc (o *Orchestrator) OnRunComplete(ctx context.Context, projectDir string, runID string, state domain.RunState) {\n\to.mu.Lock()\n\tpc := o.projects[projectDir]\n\ttaskID := o.untrackTask(projectDir, runID)\n\tif o.inFlight[projectDir] > 0 {\n\t\to.inFlight[projectDir]--\n\t}\n\to.mu.Unlock()\n\n\t// Close/fail the associated task in the tracker\n\tif taskID != \"\" && pc != nil {\n\t\tif state == domain.RunStateSucceeded {\n\t\t\tlog.Printf(\"orchestrator: completing task %s (run %s succeeded)\", taskID, runID)\n\t\t\t_ = pc.Tracker.Complete(ctx, taskID)\n\t\t} else {\n\t\t\tlog.Printf(\"orchestrator: failing task %s (run %s state: %s)\", taskID, runID, state)\n\t\t\t_ = pc.Tracker.Fail(ctx, taskID)\n\t\t}\n\t}\n\n\tif _, err := o.Run(ctx, projectDir); err != nil {\n\t\tlog.Printf(\"orchestrator: post-completion trigger failed for %s: %v\", projectDir, err)\n\t}\n}\n\n// InFlight returns the current in-flight run count for a project.\nfunc (o *Orchestrator) InFlight(projectDir string) int {\n\to.mu.Lock()\n\tdefer o.mu.Unlock()\n\treturn o.inFlight[projectDir]\n}\n","numLines":394,"startLine":1,"totalLines":394}}}
