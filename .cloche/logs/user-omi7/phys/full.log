sks(ctx); n > 0 {\n   143→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: recovered %d stale task(s)\\n\", n)\n   144→\t\t\t}\n   145→\t\t\tif n := orch.TriggerAll(ctx); n > 0 {\n   146→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: orchestrator dispatched %d run(s)\\n\", n)\n   147→\t\t\t}\n   148→\t\t}()\n   149→\t}\n   150→\n   151→\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   152→\tif err := grpcServer.Serve(lis); err != nil {\n   153→\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   154→\t\tos.Exit(1)\n   155→\t}\n   156→}\n   157→\n   158→func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   159→\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   160→\n   161→\tswitch runtimeType {\n   162→\tcase \"local\":\n   163→\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   164→\t\tif agentPath == \"\" {\n   165→\t\t\t// Look for cloche-agent next to this binary\n   166→\t\t\texe, err := os.Executable()\n   167→\t\t\tif err == nil {\n   168→\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   169→\t\t\t} else {\n   170→\t\t\t\tagentPath = \"cloche-agent\"\n   171→\t\t\t}\n   172→\t\t}\n   173→\t\treturn local.NewRuntime(agentPath), nil\n   174→\tcase \"docker\":\n   175→\t\treturn docker.NewRuntime()\n   176→\tdefault:\n   177→\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   178→\t}\n   179→}\n   180→\n   181→func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   182→\t// Load config from working directory (daemon-level defaults)\n   183→\tcfg, err := config.Load(\".\")\n   184→\tif err != nil || !cfg.Evolution.Enabled {\n   185→\t\treturn nil\n   186→\t}\n   187→\n   188→\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   189→\tif llmCmd == \"\" {\n   190→\t\treturn nil\n   191→\t}\n   192→\n   193→\ttrigge