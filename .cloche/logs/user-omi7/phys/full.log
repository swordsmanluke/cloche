e":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":26598,"cache_read_input_tokens":14225,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":26598},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"92f06db3-be18-4832-ac12-993c8ca2e234","uuid":"84ff0033-a947-4f4c-bf49-6e7ada666b19"}
