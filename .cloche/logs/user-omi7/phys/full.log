e\", \"task-active\")\n\torch.mu.Unlock()\n\n\ttotal := orch.RecoverStaleTasks(context.Background())\n\tassert.Equal(t, 1, total)\n\t// The active task should be passed to the tracker\n\tassert.True(t, tracker.recoveredActiveIDs[\"task-active\"])\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":311,"cache_read_input_tokens":58726,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":311},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"36e135ce-10f3-4a37-be7d-4cf1fde5dba1","uuid":"ed63006d-c586-4218-9382-e1d6dc1be3da"}
