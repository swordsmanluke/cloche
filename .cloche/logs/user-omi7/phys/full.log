[2026-03-07T18:50:51Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W9QS335oHSZrbdruCTWmTG","type":"tool_result","content":"     1→package orchestrator\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"sync\"\n     9→\t\"testing\"\n    10→\t\"time\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    14→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    15→\t\"github.com/stretchr/testify/assert\"\n    16→\t\"github.com/stretchr/testify/require\"\n    17→)\n    18→\n    19→// mockTracker implements ports.TaskTracker for testing.\n    20→type mockTracker struct {\n    21→\tmu                sync.Mutex\n    22→\ttasks             []ports.TrackerTask\n    23→\tclaimed           []string\n    24→\tcompleted         []string\n    25→\tfailed            []string\n    26→\tclaimErr          error\n    27→\trecoverResult     int\n    28→\trecoveredActiveIDs map[string]bool\n    29→}\n    30→\n    31→func (m *mockTracker) ListReady(_ context.Context, project string) ([]ports.TrackerTask, error) {\n    32→\tm.mu.Lock()\n    33→\tdefer m.mu.Unlock()\n    34→\t// Return a copy\n    35→\tresult := make([]ports.TrackerTask, len(m.tasks))\n    36→\tcopy(result, m.tasks)\n    37→\treturn result, nil\n    38→}\n    39→\n    40→func (m *mockTracker) Claim(_ context.Context, taskID string) error {\n    41→\tm.mu.Lock()\n    42→\tdefer m.mu.Unlock()\n    43→\tif m.claimErr != nil {\n    44→\t\treturn m.claimErr\n    45→\t}\n    46→\tm.claimed = append(m.claimed, taskID)\n    47→\treturn nil\n    48→}\n    49→\n    50→func (m *mockTracker) Complete(_ context.Context, taskID string) error {\n    51→\tm.mu.Lock()\n    52→\tdefer m.mu.Unlock()\n    53→\tm.completed = append(m.completed, taskID)\n    54→\treturn nil\n    55→}\n    56→\n    57→func (m *mockTracker) Fail(_ context.Context, taskID string) error {\n    58→\tm.mu.Lock()\n    59→\tdefer m.mu.Unlock()\n    60→\tm.failed = append(m.failed, taskID)\n    61→\treturn nil\n    62→}\n    63→\n    64→func (m *mockTracker) RecoverStaleTasks(_ context.Context, activeTaskIDs map[string]bool) (int, error) {\n    65→\tm.mu.Lock()\n    66→\tdefer m.mu.Unlock()\n    67→\tm.recoveredActiveIDs = activeTaskIDs\n    68→\treturn m.recoverResult, nil\n    69→}\n    70→\n    71→// mockPromptGen implements PromptGenerator for testing.\n    72→type mockPromptGen struct {\n    73→\tresponse string\n    74→\terr      error\n    75→\tcalls    int\n    76→}\n    77→\n    78→func (m *mockPromptGen) Generate(_ context.Context, task ports.TrackerTask, projectDir string) (string, error) {\n    79→\tm.calls++\n    80→\treturn m.response, m.err\n    81→}\n    82→\n    83→func TestOrchestratorRun_DispatchesTasks(t *testing.T) {\n    84→\ttracker := &mockTracker{\n    85→\t\ttasks: []ports.TrackerTask{\n    86→\t\t\t{ID: \"task-1\", Title: \"First task\", Priority: 2},\n    87→\t\t\t{ID: \"task-2\", Title: \"Second task\", Priority: 1},\n    88→\t\t},\n    89→\t}\n    90→\tpromptGen := &mockPromptGen{response: \"generated prompt\"}\n    91→\n    92→\tvar dispatched []string\n    93→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n    94→\t\tdispatched = append(dispatched, prompt)\n    95→\t\treturn \"run-\" + fmt.Sprintf(\"%d\", len(dispatched)), nil\n    96→\t}\n    97→\n    98→\torch := New(promptGen, dispatch)\n    99→\torch.Register(&ProjectConfig{\n   100→\t\tDir:         \"/test/project\",\n   101→\t\tWorkflow:    \"develop\",\n   102→\t\tConcurrency: 2,\n   103→\t\tTracker:     tracker,\n   104→\t})\n   105→\n   106→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   107→\trequire.NoError(t, err)\n   108→\tassert.Equal(t, 2, n)\n   109→\tassert.Equal(t, 2, len(dispatched))\n   110→\tassert.Equal(t, []string{\"task-1\", \"task-2\"}, tracker.claimed)\n   111→\tassert.Equal(t, 2, promptGen.calls)\n   112→}\n   113→\n   114→func TestOrchestratorRun_RespectsConncurrencyLimit(t *testing.T) {\n   115→\ttracker := &mockTracker{\n   116→\t\ttasks: []ports.TrackerTask{\n   117→\t\t\t{ID: \"task-1\", Title: \"First\", Priority: 2},\n   118→\t\t\t{ID: \"task-2\", Title: \"Second\", Priority: 1},\n   119→\t\t},\n   120→\t}\n   121→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   122→\n   123→\tdispatchCount := 0\n   124→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   125→\t\tdispatchCount++\n   126→\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n   127→\t}\n   128→\n   129→\torch := New(promptGen, dispatch)\n   130→\torch.Register(&ProjectConfig{\n   131→\t\tDir:         \"/test/project\",\n   132→\t\tWorkflow:    \"develop\",\n   133→\t\tConcurrency: 1, // only 1 slot\n   134→\t\tTracker:     tracker,\n   135→\t})\n   136→\n   137→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   138→\trequire.NoError(t, err)\n   139→\tassert.Equal(t, 1, n)\n   140→\tassert.Equal(t, 1, dispatchCount)\n   141→\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed) // highest priority\n   142→}\n   143→\n   144→func TestOrchestratorRun_NoAvailableSlots(t *testing.T) {\n   145→\ttracker := &mockTracker{\n   146→\t\ttasks: []ports.TrackerTask{\n   147→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   148→\t\t},\n   149→\t}\n   150→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   151→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   152→\t\treturn \"run-1\", nil\n   153→\t}\n   154→\n   155→\torch := New(promptGen, dispatch)\n   156→\torch.Register(&ProjectConfig{\n   157→\t\tDir:         \"/test/project\",\n   158→\t\tWorkflow:    \"develop\",\n   159→\t\tConcurrency: 1,\n   160→\t\tTracker:     tracker,\n   161→\t})\n   162→\n   163→\t// Simulate an in-flight run\n   164→\torch.mu.Lock()\n   165→\torch.inFlight[\"/test/project\"] = 1\n   166→\torch.mu.Unlock()\n   167→\n   168→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   169→\trequire.NoError(t, err)\n   170→\tassert.Equal(t, 0, n)\n   171→}\n   172→\n   173→func TestOrchestratorRun_NoReadyTasks(t *testing.T) {\n   174→\ttracker := &mockTracker{tasks: nil}\n   175→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   176→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   177→\t\tt.Fatal(\"dispatch should not be called\")\n   178→\t\treturn \"\", nil\n   179→\t}\n   180→\n   181→\torch := New(promptGen, dispatch)\n   182→\torch.Register(&ProjectConfig{\n   183→\t\tDir:         \"/test/project\",\n   184→\t\tWorkflow:    \"develop\",\n   185→\t\tConcurrency: 1,\n   186→\t\tTracker:     tracker,\n   187→\t})\n   188→\n   189→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   190→\trequire.NoError(t, err)\n   191→\tassert.Equal(t, 0, n)\n   192→}\n   193→\n   194→func TestOrchestratorRun_UnregisteredProject(t *testing.T) {\n   195→\torch := New(nil, nil)\n   196→\t_, err := orch.Run(context.Background(), \"/unknown\")\n   197→\tassert.Error(t, err)\n   198→\tassert.Contains(t, err.Error(), \"not registered\")\n   199→}\n   200→\n   201→func TestOrchestratorRun_PromptGenerationFailure(t *testing.T) {\n   202→\ttracker := &mockTracker{\n   203→\t\ttasks: []ports.TrackerTask{\n   204→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   205→\t\t},\n   206→\t}\n   207→\tpromptGen := &mockPromptGen{err: fmt.Errorf(\"LLM unavailable\")}\n   208→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   209→\t\tt.Fatal(\"dispatch should not be called on prompt failure\")\n   210→\t\treturn \"\", nil\n   211→\t}\n   212→\n   213→\torch := New(promptGen, dispatch)\n   214→\torch.Register(&ProjectConfig{\n   215→\t\tDir:         \"/test/project\",\n   216→\t\tWorkflow:    \"develop\",\n   217→\t\tConcurrency: 1,\n   218→\t\tTracker:     tracker,\n   219→\t})\n   220→\n   221→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   222→\trequire.NoError(t, err) // errors are logged, not returned\n   223→\tassert.Equal(t, 0, n)\n   224→\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed)\n   225→\tassert.Equal(t, []string{\"task-1\"}, tracker.failed) // task should be failed back\n   226→}\n   227→\n   228→func TestOrchestratorRun_DispatchFailure(t *testing.T) {\n   229→\ttracker := &mockTracker{\n   230→\t\ttasks: []ports.TrackerTask{\n   231→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   232→\t\t},\n   233→\t}\n   234→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   235→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   236→\t\treturn \"\", fmt.Errorf(\"container start failed\")\n   237→\t}\n   238→\n   239→\torch := New(promptGen, dispatch)\n   240→\torch.Register(&ProjectConfig{\n   241→\t\tDir:         \"/test/project\",\n   242→\t\tWorkflow:    \"develop\",\n   243→\t\tConcurrency: 1,\n   244→\t\tTracker:     tracker,\n   245→\t})\n   246→\n   247→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   248→\trequire.NoError(t, err)\n   249→\tassert.Equal(t, 0, n)\n   250→\tassert.Equal(t, []string{\"task-1\"}, tracker.failed)\n   251→}\n   252→\n   253→func TestOrchestratorRun_ClaimFailure(t *testing.T) {\n   254→\ttracker := &mockTracker{\n   255→\t\ttasks: []ports.TrackerTask{\n   256→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   257→\t\t},\n   258→\t\tclaimErr: fmt.Errorf(\"already claimed\"),\n   259→\t}\n   260→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   261→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   262→\t\tt.Fatal(\"dispatch should not be called on claim failure\")\n   263→\t\treturn \"\", nil\n   264→\t}\n   265→\n   266→\torch := New(promptGen, dispatch)\n   267→\torch.Register(&ProjectConfig{\n   268→\t\tDir:         \"/test/project\",\n   269→\t\tWorkflow:    \"develop\",\n   270→\t\tConcurrency: 1,\n   271→\t\tTracker:     tracker,\n   272→\t})\n   273→\n   274→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   275→\trequire.NoError(t, err)\n   276→\tassert.Equal(t, 0, n)\n   277→}\n   278→\n   279→func TestOrchestratorTriggerAll(t *testing.T) {\n   280→\ttracker1 := &mockTracker{\n   281→\t\ttasks: []ports.TrackerTask{{ID: \"t1\", Title: \"T1\", Priority: 1}},\n   282→\t}\n   283→\ttracker2 := &mockTracker{\n   284→\t\ttasks: []ports.TrackerTask{{ID: \"t2\", Title: \"T2\", Priority: 1}},\n   285→\t}\n   286→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   287→\n   288→\tdispatchCount := 0\n   289→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   290→\t\tdispatchCount++\n   291→\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n   292→\t}\n   293→\n   294→\torch := New(promptGen, dispatch)\n   295→\torch.Register(&ProjectConfig{Dir: \"/proj1\", Workflow: \"dev\", Concurrency: 1, Tracker: tracker1})\n   296→\torch.Register(&ProjectConfig{Dir: \"/proj2\", Workflow: \"dev\", Concurrency: 1, Tracker: tracker2})\n   297→\n   298→\ttotal := orch.TriggerAll(context.Background())\n   299→\tassert.Equal(t, 2, total)\n   300→\tassert.Equal(t, 2, dispatchCount)\n   301→}\n   302→\n   303→func TestOrchestratorOnRunComplete(t *testing.T) {\n   304→\ttracker := &mockTracker{\n   305→\t\ttasks: []ports.TrackerTask{\n   306→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   307→\t\t},\n   308→\t}\n   309→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   310→\n   311→\tdispatchCount := 0\n   312→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   313→\t\tdispatchCount++\n   314→\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n   315→\t}\n   316→\n   317→\torch := New(promptGen, dispatch)\n   318→\torch.Register(&ProjectConfig{\n   319→\t\tDir:         \"/test/project\",\n   320→\t\tWorkflow:    \"develop\",\n   321→\t\tConcurrency: 1,\n   322→\t\tTracker:     tracker,\n   323→\t})\n   324→\n   325→\t// Simulate a run is in flight (fills the concurrency slot)\n   326→\torch.mu.Lock()\n   327→\torch.inFlight[\"/test/project\"] = 1\n   328→\torch.trackTask(\"/test/project\", \"existing-run\", \"existing-task\")\n   329→\torch.mu.Unlock()\n   330→\n   331→\t// OnRunComplete should decrement in-flight and trigger new dispatch\n   332→\torch.OnRunComplete(context.Background(), \"/test/project\", \"existing-run\", domain.RunStateSucceeded)\n   333→\n   334→\t// After OnRunComplete: 1 → 0 (decrement) → 1 (new run dispatched)\n   335→\tassert.Equal(t, 1, orch.InFlight(\"/test/project\"))\n   336→\tassert.Equal(t, 1, dispatchCount) // should have dispatched the waiting task\n   337→}\n   338→\n   339→func TestOrchestratorOnRunComplete_ClosesTask(t *testing.T) {\n   340→\ttracker := &mockTracker{tasks: nil} // no more ready tasks\n   341→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   342→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   343→\t\treturn \"run-1\", nil\n   344→\t}\n   345→\n   346→\torch := New(promptGen, dispatch)\n   347→\torch.Register(&ProjectConfig{\n   348→\t\tDir:         \"/test/project\",\n   349→\t\tWorkflow:    \"develop\",\n   350→\t\tConcurrency: 1,\n   351→\t\tTracker:     tracker,\n   352→\t})\n   353→\n   354→\t// Simulate a run for task-1 in flight\n   355→\torch.mu.Lock()\n   356→\torch.inFlight[\"/test/project\"] = 1\n   357→\torch.trackTask(\"/test/project\", \"run-1\", \"task-1\")\n   358→\torch.mu.Unlock()\n   359→\n   360→\t// Run succeeds → task should be completed\n   361→\torch.OnRunComplete(context.Background(), \"/test/project\", \"run-1\", domain.RunStateSucceeded)\n   362→\tassert.Equal(t, []string{\"task-1\"}, tracker.completed)\n   363→\tassert.Empty(t, tracker.failed)\n   364→}\n   365→\n   366→func TestOrchestratorOnRunComplete_FailsTask(t *testing.T) {\n   367→\ttracker := &mockTracker{tasks: nil}\n   368→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   369→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   370→\t\treturn \"run-1\", nil\n   371→\t}\n   372→\n   373→\torch := New(promptGen, dispatch)\n   374→\torch.Register(&ProjectConfig{\n   375→\t\tDir:         \"/test/project\",\n   376→\t\tWorkflow:    \"develop\",\n   377→\t\tConcurrency: 1,\n   378→\t\tTracker:     tracker,\n   379→\t})\n   380→\n   381→\t// Simulate a run for task-1 in flight\n   382→\torch.mu.Lock()\n   383→\torch.inFlight[\"/test/project\"] = 1\n   384→\torch.trackTask(\"/test/project\", \"run-1\", \"task-1\")\n   385→\torch.mu.Unlock()\n   386→\n   387→\t// Run fails → task should be failed\n   388→\torch.OnRunComplete(context.Background(), \"/test/project\", \"run-1\", domain.RunStateFailed)\n   389→\tassert.Equal(t, []string{\"task-1\"}, tracker.failed)\n   390→\tassert.Empty(t, tracker.completed)\n   391→}\n   392→\n   393→func TestOrchestratorRun_SkipsDuplicateTasks(t *testing.T) {\n   394→\ttracker := &mockTracker{\n   395→\t\ttasks: []ports.TrackerTask{\n   396→\t\t\t{ID: \"task-1\", Title: \"Already running\", Priority: 2},\n   397→\t\t\t{ID: \"task-2\", Title: \"New task\", Priority: 1},\n   398→\t\t},\n   399→\t}\n   400→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   401→\n   402→\tvar dispatched []string\n   403→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   404→\t\tdispatched = append(dispatched, fmt.Sprintf(\"run-%d\", len(dispatched)+1))\n   405→\t\treturn dispatched[len(dispatched)-1], nil\n   406→\t}\n   407→\n   408→\torch := New(promptGen, dispatch)\n   409→\torch.Register(&ProjectConfig{\n   410→\t\tDir:         \"/test/project\",\n   411→\t\tWorkflow:    \"develop\",\n   412→\t\tConcurrency: 2,\n   413→\t\tTracker:     tracker,\n   414→\t})\n   415→\n   416→\t// Simulate task-1 already in flight\n   417→\torch.mu.Lock()\n   418→\torch.inFlight[\"/test/project\"] = 1\n   419→\torch.trackTask(\"/test/project\", \"existing-run\", \"task-1\")\n   420→\torch.mu.Unlock()\n   421→\n   422→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   423→\trequire.NoError(t, err)\n   424→\tassert.Equal(t, 1, n) // only task-2 should be dispatched\n   425→\tassert.Equal(t, []string{\"task-2\"}, tracker.claimed) // task-1 skipped\n   426→}\n   427→\n   428→func TestOrchestratorInFlightTracking(t *testing.T) {\n   429→\ttracker := &mockTracker{\n   430→\t\ttasks: []ports.TrackerTask{\n   431→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   432→\t\t},\n   433→\t}\n   434→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   435→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   436→\t\treturn \"run-1\", nil\n   437→\t}\n   438→\n   439→\torch := New(promptGen, dispatch)\n   440→\torch.Register(&ProjectConfig{\n   441→\t\tDir:         \"/test/project\",\n   442→\t\tWorkflow:    \"develop\",\n   443→\t\tConcurrency: 2,\n   444→\t\tTracker:     tracker,\n   445→\t})\n   446→\n   447→\tassert.Equal(t, 0, orch.InFlight(\"/test/project\"))\n   448→\n   449→\t_, err := orch.Run(context.Background(), \"/test/project\")\n   450→\trequire.NoError(t, err)\n   451→\n   452→\tassert.Equal(t, 1, orch.InFlight(\"/test/project\"))\n   453→}\n   454→\n   455→func TestOrchestratorRun_HostWorkflowPath(t *testing.T) {\n   456→\ttmpDir := t.TempDir()\n   457→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   458→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   459→\n   460→\t// Write a host.cloche file\n   461→\thostCloche := `workflow \"orchestrate\" {\n   462→  step prep {\n   463→    run     = \"echo hello\"\n   464→    results = [success, fail]\n   465→  }\n   466→\n   467→  prep:success -> done\n   468→  prep:fail    -> abort\n   469→}\n   470→`\n   471→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   472→\n   473→\ttracker := &mockTracker{\n   474→\t\ttasks: []ports.TrackerTask{\n   475→\t\t\t{ID: \"task-1\", Title: \"Test Task\", Description: \"task body\"},\n   476→\t\t},\n   477→\t}\n   478→\tpromptGen := &mockPromptGen{response: \"should not be called\"}\n   479→\n   480→\tdispatchCalled := false\n   481→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   482→\t\tdispatchCalled = true\n   483→\t\treturn \"run-1\", nil\n   484→\t}\n   485→\n   486→\tparseFunc := func(input string) (*domain.Workflow, error) {\n   487→\t\treturn dsl.Parse(input)\n   488→\t}\n   489→\n   490→\twaiter := &mockRunWaiter{state: domain.RunStateSucceeded}\n   491→\thostRunner := &HostRunner{\n   492→\t\tDispatch: dispatch,\n   493→\t\tWaitRun:  waiter,\n   494→\t}\n   495→\n   496→\torch := New(promptGen, dispatch,\n   497→\t\tWithHostRunner(hostRunner),\n   498→\t\tWithParseHostWorkflow(parseFunc),\n   499→\t)\n   500→\torch.Register(&ProjectConfig{\n   501→\t\tDir:         tmpDir,\n   502→\t\tWorkflow:    \"develop\",\n   503→\t\tConcurrency: 1,\n   504→\t\tTracker:     tracker,\n   505→\t})\n   506→\n   507→\tn, err := orch.Run(context.Background(), tmpDir)\n   508→\trequire.NoError(t, err)\n   509→\tassert.Equal(t, 1, n)\n   510→\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed)\n   511→\t// promptGen should NOT have been called (host workflow path used instead)\n   512→\tassert.Equal(t, 0, promptGen.calls)\n   513→\t// dispatch should NOT have been called directly (host runner handles it)\n   514→\tassert.False(t, dispatchCalled)\n   515→\n   516→\t// Wait for the background goroutine to finish so TempDir cleanup succeeds.\n   517→\trequire.Eventually(t, func() bool {\n   518→\t\ttracker.mu.Lock()\n   519→\t\tdefer tracker.mu.Unlock()\n   520→\t\treturn len(tracker.completed) > 0\n   521→\t}, time.Second, 10*time.Millisecond)\n   522→}\n   523→\n   524→func TestOrchestratorRun_FallbackWithoutHostCloche(t *testing.T) {\n   525→\ttmpDir := t.TempDir()\n   526→\t// No host.cloche file — should fall back to promptGen → dispatch path\n   527→\n   528→\ttracker := &mockTracker{\n   529→\t\ttasks: []ports.TrackerTask{\n   530→\t\t\t{ID: \"task-1\", Title: \"Test Task\"},\n   531→\t\t},\n   532→\t}\n   533→\tpromptGen := &mockPromptGen{response: \"generated prompt\"}\n   534→\n   535→\tdispatched := false\n   536→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   537→\t\tdispatched = true\n   538→\t\treturn \"run-1\", nil\n   539→\t}\n   540→\n   541→\twaiter := &mockRunWaiter{state: domain.RunStateSucceeded}\n   542→\thostRunner := &HostRunner{\n   543→\t\tDispatch: dispatch,\n   544→\t\tWaitRun:  waiter,\n   545→\t}\n   546→\n   547→\tparseFunc := func(input string) (*domain.Workflow, error) {\n   548→\t\treturn dsl.Parse(input)\n   549→\t}\n   550→\n   551→\torch := New(promptGen, dispatch,\n   552→\t\tWithHostRunner(hostRunner),\n   553→\t\tWithParseHostWorkflow(parseFunc),\n   554→\t)\n   555→\torch.Register(&ProjectConfig{\n   556→\t\tDir:         tmpDir,\n   557→\t\tWorkflow:    \"develop\",\n   558→\t\tConcurrency: 1,\n   559→\t\tTracker:     tracker,\n   560→\t})\n   561→\n   562→\tn, err := orch.Run(context.Background(), tmpDir)\n   563→\trequire.NoError(t, err)\n   564→\tassert.Equal(t, 1, n)\n   565→\tassert.Equal(t, 1, promptGen.calls)\n   566→\tassert.True(t, dispatched)\n   567→}\n   568→\n   569→func TestOrchestratorRun_UsesCorrectWorkflow(t *testing.T) {\n   570→\ttracker := &mockTracker{\n   571→\t\ttasks: []ports.TrackerTask{\n   572→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   573→\t\t},\n   574→\t}\n   575→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   576→\n   577→\tvar capturedWorkflow string\n   578→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   579→\t\tcapturedWorkflow = workflow\n   580→\t\treturn \"run-1\", nil\n   581→\t}\n   582→\n   583→\torch := New(promptGen, dispatch)\n   584→\torch.Register(&ProjectConfig{\n   585→\t\tDir:         \"/test/project\",\n   586→\t\tWorkflow:    \"custom-workflow\",\n   587→\t\tConcurrency: 1,\n   588→\t\tTracker:     tracker,\n   589→\t})\n   590→\n   591→\t_, err := orch.Run(context.Background(), \"/test/project\")\n   592→\trequire.NoError(t, err)\n   593→\tassert.Equal(t, \"custom-workflow\", capturedWorkflow)\n   594→}\n   595→\n   596→func TestOrchestratorRecoverStaleTasks(t *testing.T) {\n   597→\ttracker := &mockTracker{\n   598→\t\trecoverResult: 3,\n   599→\t}\n   600→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   601→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   602→\t\treturn \"run-1\", nil\n   603→\t}\n   604→\n   605→\torch := New(promptGen, dispatch)\n   606→\torch.Register(&ProjectConfig{\n   607→\t\tDir:         \"/test/project\",\n   608→\t\tWorkflow:    \"develop\",\n   609→\t\tConcurrency: 1,\n   610→\t\tTracker:     tracker,\n   611→\t})\n   612→\n   613→\ttotal := orch.RecoverStaleTasks(context.Background())\n   614→\tassert.Equal(t, 3, total)\n   615→\t// With no in-flight tasks, the active set should be empty\n   616→\tassert.Empty(t, tracker.recoveredActiveIDs)\n   617→}\n   618→\n   619→func TestOrchestratorRecoverStaleTasks_ExcludesInFlight(t *testing.T) {\n   620→\ttracker := &mockTracker{\n   621→\t\trecoverResult: 1,\n   622→\t}\n   623→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   624→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   625→\t\treturn \"run-1\", nil\n   626→\t}\n   627→\n   628→\torch := New(promptGen, dispatch)\n   629→\torch.Register(&ProjectConfig{\n   630→\t\tDir:         \"/test/project\",\n   631→\t\tWorkflow:    \"develop\",\n   632→\t\tConcurrency: 2,\n   633→\t\tTracker:     tracker,\n   634→\t})\n   635→\n   636→\t// Simulate an in-flight task\n   637→\torch.mu.Lock()\n   638→\torch.inFlight[\"/test/project\"] = 1\n   639→\torch.trackTask(\"/test/project\", \"run-active\", \"task-active\")\n   640→\torch.mu.Unlock()\n   641→\n   642→\ttotal := orch.RecoverStaleTasks(context.Background())\n   643→\tassert.Equal(t, 1, total)\n   644→\t// The active task should be passed to the tracker\n   645→\tassert.True(t, tracker.recoveredActiveIDs[\"task-active\"])\n   646→}\n   647→"}]},"parent_tool_use_id":null,"session_id":"92f06db3-be18-4832-ac12-993c8ca2e234","uuid":"6d5ee0cb-b200-466d-bac1-8f61a6ff12a7","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/orchestrator/orchestrator_test.go","content":"package orchestrator\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// mockTracker implements ports.TaskTracker for testing.\ntype mockTracker struct {\n\tmu                sync.Mutex\n\ttasks             []ports.TrackerTask\n\tclaimed           []string\n\tcompleted         []string\n\tfailed            []string\n\tclaimErr          error\n\trecoverResult     int\n\trecoveredActiveIDs map[string]bool\n}\n\nfunc (m *mockTracker) ListReady(_ context.Context, project string) ([]ports.TrackerTask, error) {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\t// Return a copy\n\tresult := make([]ports.TrackerTask, len(m.tasks))\n\tcopy(result, m.tasks)\n\treturn result, nil\n}\n\nfunc (m *mockTracker) Claim(_ context.Context, taskID string) error {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tif m.claimErr != nil {\n\t\treturn m.claimErr\n\t}\n\tm.claimed = append(m.claimed, taskID)\n\treturn nil\n}\n\nfunc (m *mockTracker) Complete(_ context.Context, taskID string) error {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tm.completed = append(m.completed, taskID)\n\treturn nil\n}\n\nfunc (m *mockTracker) Fail(_ context.Context, taskID string) error {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tm.failed = append(m.failed, taskID)\n\treturn nil\n}\n\nfunc (m *mockTracker) RecoverStaleTasks(_ context.Context, activeTaskIDs map[string]bool) (int, error) {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tm.recoveredActiveIDs = activeTaskIDs\n\treturn m.recoverResult, nil\n}\n\n// mockPromptGen implements PromptGenerator for testing.\ntype mockPromptGen struct {\n\tresponse string\n\terr      error\n\tcalls    int\n}\n\nfunc (m *mockPromptGen) Generate(_ context.Context, task ports.TrackerTask, projectDir string) (string, error) {\n\tm.calls++\n\treturn m.response, m.err\n}\n\nfunc TestOrchestratorRun_DispatchesTasks(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"First task\", Priority: 2},\n\t\t\t{ID: \"task-2\", Title: \"Second task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"generated prompt\"}\n\n\tvar dispatched []string\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatched = append(dispatched, prompt)\n\t\treturn \"run-\" + fmt.Sprintf(\"%d\", len(dispatched)), nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 2,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 2, n)\n\tassert.Equal(t, 2, len(dispatched))\n\tassert.Equal(t, []string{\"task-1\", \"task-2\"}, tracker.claimed)\n\tassert.Equal(t, 2, promptGen.calls)\n}\n\nfunc TestOrchestratorRun_RespectsConncurrencyLimit(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"First\", Priority: 2},\n\t\t\t{ID: \"task-2\", Title: \"Second\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\n\tdispatchCount := 0\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatchCount++\n\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1, // only 1 slot\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 1, n)\n\tassert.Equal(t, 1, dispatchCount)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed) // highest priority\n}\n\nfunc TestOrchestratorRun_NoAvailableSlots(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\treturn \"run-1\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\t// Simulate an in-flight run\n\torch.mu.Lock()\n\torch.inFlight[\"/test/project\"] = 1\n\torch.mu.Unlock()\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 0, n)\n}\n\nfunc TestOrchestratorRun_NoReadyTasks(t *testing.T) {\n\ttracker := &mockTracker{tasks: nil}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tt.Fatal(\"dispatch should not be called\")\n\t\treturn \"\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 0, n)\n}\n\nfunc TestOrchestratorRun_UnregisteredProject(t *testing.T) {\n\torch := New(nil, nil)\n\t_, err := orch.Run(context.Background(), \"/unknown\")\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"not registered\")\n}\n\nfunc TestOrchestratorRun_PromptGenerationFailure(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{err: fmt.Errorf(\"LLM unavailable\")}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tt.Fatal(\"dispatch should not be called on prompt failure\")\n\t\treturn \"\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err) // errors are logged, not returned\n\tassert.Equal(t, 0, n)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.failed) // task should be failed back\n}\n\nfunc TestOrchestratorRun_DispatchFailure(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\treturn \"\", fmt.Errorf(\"container start failed\")\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 0, n)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.failed)\n}\n\nfunc TestOrchestratorRun_ClaimFailure(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t\tclaimErr: fmt.Errorf(\"already claimed\"),\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tt.Fatal(\"dispatch should not be called on claim failure\")\n\t\treturn \"\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 0, n)\n}\n\nfunc TestOrchestratorTriggerAll(t *testing.T) {\n\ttracker1 := &mockTracker{\n\t\ttasks: []ports.TrackerTask{{ID: \"t1\", Title: \"T1\", Priority: 1}},\n\t}\n\ttracker2 := &mockTracker{\n\t\ttasks: []ports.TrackerTask{{ID: \"t2\", Title: \"T2\", Priority: 1}},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\n\tdispatchCount := 0\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatchCount++\n\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{Dir: \"/proj1\", Workflow: \"dev\", Concurrency: 1, Tracker: tracker1})\n\torch.Register(&ProjectConfig{Dir: \"/proj2\", Workflow: \"dev\", Concurrency: 1, Tracker: tracker2})\n\n\ttotal := orch.TriggerAll(context.Background())\n\tassert.Equal(t, 2, total)\n\tassert.Equal(t, 2, dispatchCount)\n}\n\nfunc TestOrchestratorOnRunComplete(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\n\tdispatchCount := 0\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatchCount++\n\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\t// Simulate a run is in flight (fills the concurrency slot)\n\torch.mu.Lock()\n\torch.inFlight[\"/test/project\"] = 1\n\torch.trackTask(\"/test/project\", \"existing-run\", \"existing-task\")\n\torch.mu.Unlock()\n\n\t// OnRunComplete should decrement in-flight and trigger new dispatch\n\torch.OnRunComplete(context.Background(), \"/test/project\", \"existing-run\", domain.RunStateSucceeded)\n\n\t// After OnRunComplete: 1 → 0 (decrement) → 1 (new run dispatched)\n\tassert.Equal(t, 1, orch.InFlight(\"/test/project\"))\n\tassert.Equal(t, 1, dispatchCount) // should have dispatched the waiting task\n}\n\nfunc TestOrchestratorOnRunComplete_ClosesTask(t *testing.T) {\n\ttracker := &mockTracker{tasks: nil} // no more ready tasks\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\treturn \"run-1\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\t// Simulate a run for task-1 in flight\n\torch.mu.Lock()\n\torch.inFlight[\"/test/project\"] = 1\n\torch.trackTask(\"/test/project\", \"run-1\", \"task-1\")\n\torch.mu.Unlock()\n\n\t// Run succeeds → task should be completed\n\torch.OnRunComplete(context.Background(), \"/test/project\", \"run-1\", domain.RunStateSucceeded)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.completed)\n\tassert.Empty(t, tracker.failed)\n}\n\nfunc TestOrchestratorOnRunComplete_FailsTask(t *testing.T) {\n\ttracker := &mockTracker{tasks: nil}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\treturn \"run-1\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\t// Simulate a run for task-1 in flight\n\torch.mu.Lock()\n\torch.inFlight[\"/test/project\"] = 1\n\torch.trackTask(\"/test/project\", \"run-1\", \"task-1\")\n\torch.mu.Unlock()\n\n\t// Run fails → task should be failed\n\torch.OnRunComplete(context.Background(), \"/test/project\", \"run-1\", domain.RunStateFailed)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.failed)\n\tassert.Empty(t, tracker.completed)\n}\n\nfunc TestOrchestratorRun_SkipsDuplicateTasks(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Already running\", Priority: 2},\n\t\t\t{ID: \"task-2\", Title: \"New task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\n\tvar dispatched []string\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatched = append(dispatched, fmt.Sprintf(\"run-%d\", len(dispatched)+1))\n\t\treturn dispatched[len(dispatched)-1], nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 2,\n\t\tTracker:     tracker,\n\t})\n\n\t// Simulate task-1 already in flight\n\torch.mu.Lock()\n\torch.inFlight[\"/test/project\"] = 1\n\torch.trackTask(\"/test/project\", \"existing-run\", \"task-1\")\n\torch.mu.Unlock()\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 1, n) // only task-2 should be dispatched\n\tassert.Equal(t, []string{\"task-2\"}, tracker.claimed) // task-1 skipped\n}\n\nfunc TestOrchestratorInFlightTracking(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\treturn \"run-1\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 2,\n\t\tTracker:     tracker,\n\t})\n\n\tassert.Equal(t, 0, orch.InFlight(\"/test/project\"))\n\n\t_, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, 1, orch.InFlight(\"/test/project\"))\n}\n\nfunc TestOrchestratorRun_HostWorkflowPath(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\n\t// Write a host.cloche file\n\thostCloche := `workflow \"orchestrate\" {\n  step prep {\n    run     = \"echo hello\"\n    results = [success, fail]\n  }\n\n  prep:success -> done\n  prep:fail    -> abort\n}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Test Task\", Description: \"task body\"},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"should not be called\"}\n\n\tdispatchCalled := false\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatchCalled = true\n\t\treturn \"run-1\", nil\n\t}\n\n\tparseFunc := func(input string) (*domain.Workflow, error) {\n\t\treturn dsl.Parse(input)\n\t}\n\n\twaiter := &mockRunWaiter{state: domain.RunStateSucceeded}\n\thostRunner := &HostRunner{\n\t\tDispatch: dispatch,\n\t\tWaitRun:  waiter,\n\t}\n\n\torch := New(promptGen, dispatch,\n\t\tWithHostRunner(hostRunner),\n\t\tWithParseHostWorkflow(parseFunc),\n\t)\n\torch.Register(&ProjectConfig{\n\t\tDir:         tmpDir,\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, 1, n)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed)\n\t// promptGen should NOT have been called (host workflow path used instead)\n\tassert.Equal(t, 0, promptGen.calls)\n\t// dispatch should NOT have been called directly (host runner handles it)\n\tassert.False(t, dispatchCalled)\n\n\t// Wait for the background goroutine to finish so TempDir cleanup succeeds.\n\trequire.Eventually(t, func() bool {\n\t\ttracker.mu.Lock()\n\t\tdefer tracker.mu.Unlock()\n\t\treturn len(tracker.completed) > 0\n\t}, time.Second, 10*time.Millisecond)\n}\n\nfunc TestOrchestratorRun_FallbackWithoutHostCloche(t *testing.T) {\n\ttmpDir := t.TempDir()\n\t// No host.cloche file — should fall back to promptGen → dispatch path\n\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Test Task\"},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"generated prompt\"}\n\n\tdispatched := false\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatched = true\n\t\treturn \"run-1\", nil\n\t}\n\n\twaiter := &mockRunWaiter{state: domain.RunStateSucceeded}\n\thostRunner := &HostRunner{\n\t\tDispatch: dispatch,\n\t\tWaitRun:  waiter,\n\t}\n\n\tparseFunc := func(input string) (*domain.Workflow, error) {\n\t\treturn dsl.Parse(input)\n\t}\n\n\torch := New(promptGen, dispatch,\n\t\tWithHostRunner(hostRunner),\n\t\tWithParseHostWorkflow(parseFunc),\n\t)\n\torch.Register(&ProjectConfig{\n\t\tDir:         tmpDir,\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, 1, n)\n\tassert.Equal(t, 1, promptGen.calls)\n\tassert.True(t, dispatched)\n}\n\nfunc TestOrchestratorRun_UsesCorrectWorkflow(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\n\tvar capturedWorkflow string\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tcapturedWorkflow = workflow\n\t\treturn \"run-1\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"custom-workflow\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\t_, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"custom-workflow\", capturedWorkflow)\n}\n\nfunc TestOrchestratorRecoverStaleTasks(t *testing.T) {\n\ttracker := &mockTracker{\n\t\trecoverResult: 3,\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\treturn \"run-1\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\ttotal := orch.RecoverStaleTasks(context.Background())\n\tassert.Equal(t, 3, total)\n\t// With no in-flight tasks, the active set should be empty\n\tassert.Empty(t, tracker.recoveredActiveIDs)\n}\n\nfunc TestOrchestratorRecoverStaleTasks_ExcludesInFlight(t *testing.T) {\n\ttracker := &mockTracker{\n\t\trecoverResult: 1,\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\treturn \"run-1\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 2,\n\t\tTracker:     tracker,\n\t})\n\n\t// Simulate an in-flight task\n\torch.mu.Lock()\n\torch.inFlight[\"/test/project\"] = 1\n\torch.trackTask(\"/test/project\", \"run-active\", \"task-active\")\n\torch.mu.Unlock()\n\n\ttotal := orch.RecoverStaleTasks(context.Background())\n\tassert.Equal(t, 1, total)\n\t// The active task should be passed to the tracker\n\tassert.True(t, tracker.recoveredActiveIDs[\"task-active\"])\n}\n","numLines":647,"startLine":1,"totalLines":647}}}
