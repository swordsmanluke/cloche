d":null,"session_id":"36e135ce-10f3-4a37-be7d-4cf1fde5dba1","uuid":"dffc05e7-d419-42e1-bfb5-8d1dd55a5a8e","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/orchestrator/orchestrator_test.go","content":"// mockTracker implements ports.TaskTracker for testing.\ntype mockTracker struct {\n\tmu                sync.Mutex\n\ttasks             []ports.TrackerTask\n\tclaimed           []string\n\tcompleted         []string\n\tfailed            []string\n\tclaimErr          error\n\trecoverResult     int\n\trecoveredActiveIDs map[string]bool\n}\n\nfunc (m *mockTracker) ListReady(_ context.Context, project string) ([]ports.TrackerTask, error) {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\t// Return a copy\n\tresult := make([]ports.TrackerTask, len(m.tasks))\n\tcopy(result, m.tasks)\n\treturn result, nil\n}\n\nfunc (m *mockTracker) Claim(_ context.Context, taskID string) error {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tif m.claimErr != nil {\n\t\treturn m.claimErr\n\t}\n\tm.claimed = append(m.claimed, taskID)\n\treturn nil\n}\n\nfunc (m *mockTracker) Complete(_ context.Context, taskID string) error {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tm.completed = append(m.completed, taskID)\n\treturn nil\n}\n\nfunc (m *mockTracker) Fail(_ context.Context, taskID string) error {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tm.failed = append(m.failed, taskID)\n\treturn nil\n}\n\nfunc (m *mockTracker) RecoverStaleTasks(_ context.Context, activeTaskIDs map[string]bool) (int, error) {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tm.recoveredActiveIDs = activeTaskIDs\n\treturn m.recoverResult, nil\n}\n\n// mockPromptGen implements PromptGenerator for testing.","numLines":53,"startLine":19,"totalLines":647}}}
