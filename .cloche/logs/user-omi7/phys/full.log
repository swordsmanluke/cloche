open store: %v\\n\", err)\n    45→\t\tos.Exit(1)\n    46→\t}\n    47→\tdefer store.Close()\n    48→\n    49→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    50→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    51→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    52→\t} else if n > 0 {\n    53→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    54→\t}\n    55→\n    56→\truntime, err := initRuntime(globalCfg)\n    57→\tif err != nil {\n    58→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    59→\t\tos.Exit(1)\n    60→\t}\n    61→\n    62→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    63→\n    64→\tbroadcaster := logstream.NewBroadcaster()\n    65→\n    66→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    67→\tsrv.SetLogStore(store)\n    68→\tsrv.SetLogBroadcaster(broadcaster)\n    69→\n    70→\t// Set up evolution trigger\n    71→\tevoTrigger := initEvolution(globalCfg, store, store)\n    72→\tif evoTrigger != nil {\n    73→\t\tsrv.SetEvolution(evoTrigger)\n    74→\t}\n    75→\n    76→\t// Set up orchestrator\n    77→\torch := initOrchestrator(globalCfg, store, srv)\n    78→\tif orch != nil {\n    79→\t\tsrv.SetOnRunComplete(func(ctx context.Context, projectDir string, runID string, state domain.RunState) {\n    80→\t\t\torch.OnRunComplete(ctx, projectDir, runID, state)\n    81→\t\t})\n    82→\t\tsrv.SetOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n    83→\t\t\tif projectDir != \"\" {\n    84→\t\t\t\treturn orch.Run(ctx, projectDir)\n    85→\t\t\t}\n    86→\t\t\treturn orch.TriggerAll(ctx), nil\n    87→\t\t})\n    88→\t}\n    89→\n    90→\tgrpcServer := grpc.NewServer()\n    91→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    92→\n    93→\tsrv.SetShutdownFunc(func() { grpcSe