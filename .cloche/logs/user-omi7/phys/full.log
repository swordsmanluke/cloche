[2026-03-07T18:49:50Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CBF9fdWWKY2nGHg1kzP5TZ","type":"tool_result","content":"   400→\torch.Register(&ProjectConfig{\n   401→\t\tDir:         \"/test/project\",\n   402→\t\tWorkflow:    \"develop\",\n   403→\t\tConcurrency: 2,\n   404→\t\tTracker:     tracker,\n   405→\t})\n   406→\n   407→\t// Simulate task-1 already in flight\n   408→\torch.mu.Lock()\n   409→\torch.inFlight[\"/test/project\"] = 1\n   410→\torch.trackTask(\"/test/project\", \"existing-run\", \"task-1\")\n   411→\torch.mu.Unlock()\n   412→\n   413→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   414→\trequire.NoError(t, err)\n   415→\tassert.Equal(t, 1, n) // only task-2 should be dispatched\n   416→\tassert.Equal(t, []string{\"task-2\"}, tracker.claimed) // task-1 skipped\n   417→}\n   418→\n   419→func TestOrchestratorInFlightTracking(t *testing.T) {\n   420→\ttracker := &mockTracker{\n   421→\t\ttasks: []ports.TrackerTask{\n   422→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   423→\t\t},\n   424→\t}\n   425→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   426→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   427→\t\treturn \"run-1\", nil\n   428→\t}\n   429→\n   430→\torch := New(promptGen, dispatch)\n   431→\torch.Register(&ProjectConfig{\n   432→\t\tDir:         \"/test/project\",\n   433→\t\tWorkflow:    \"develop\",\n   434→\t\tConcurrency: 2,\n   435→\t\tTracker:     tracker,\n   436→\t})\n   437→\n   438→\tassert.Equal(t, 0, orch.InFlight(\"/test/project\"))\n   439→\n   440→\t_, err := orch.Run(context.Background(), \"/test/project\")\n   441→\trequire.NoError(t, err)\n   442→\n   443→\tassert.Equal(t, 1, orch.InFlight(\"/test/project\"))\n   444→}\n   445→\n   446→func TestOrchestratorRun_HostWorkflowPath(t *testing.T) {\n   447→\ttmpDir := t.TempDir()\n   448→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   449→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   450→\n   451→\t// Write a host.cloche file\n   452→\thostCloche := `workflow \"orchestrate\" {\n   453→  step prep {\n   454→    run     = \"echo hello\"\n   455→    results = [success, fail]\n   456→  }\n   457→\n   458→  prep:success -> done\n   459→  prep:fail    -> abort\n   460→}\n   461→`\n   462→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   463→\n   464→\ttracker := &mockTracker{\n   465→\t\ttasks: []ports.TrackerTask{\n   466→\t\t\t{ID: \"task-1\", Title: \"Test Task\", Description: \"task body\"},\n   467→\t\t},\n   468→\t}\n   469→\tpromptGen := &mockPromptGen{response: \"should not be called\"}\n   470→\n   471→\tdispatchCalled := false\n   472→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   473→\t\tdispatchCalled = true\n   474→\t\treturn \"run-1\", nil\n   475→\t}\n   476→\n   477→\tparseFunc := func(input string) (*domain.Workflow, error) {\n   478→\t\treturn dsl.Parse(input)\n   479→\t}\n   480→\n   481→\twaiter := &mockRunWaiter{state: domain.RunStateSucceeded}\n   482→\thostRunner := &HostRunner{\n   483→\t\tDispatch: dispatch,\n   484→\t\tWaitRun:  waiter,\n   485→\t}\n   486→\n   487→\torch := New(promptGen, dispatch,\n   488→\t\tWithHostRunner(hostRunner),\n   489→\t\tWithParseHostWorkflow(parseFunc),\n   490→\t)\n   491→\torch.Register(&ProjectConfig{\n   492→\t\tDir:         tmpDir,\n   493→\t\tWorkflow:    \"develop\",\n   494→\t\tConcurrency: 1,\n   495→\t\tTracker:     tracker,\n   496→\t})\n   497→\n   498→\tn, err := orch.Run(context.Background(), tmpDir)\n   499→\trequire.NoError(t, err)\n   500→\tassert.Equal(t, 1, n)\n   501→\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed)\n   502→\t// promptGen should NOT have been called (host workflow path used instead)\n   503→\tassert.Equal(t, 0, promptGen.calls)\n   504→\t// dispatch should NOT have been called directly (host runner handles it)\n   505→\tassert.False(t, dispatchCalled)\n   506→\n   507→\t// Wait for the background goroutine to finish so TempDir cleanup succeeds.\n   508→\trequire.Eventually(t, func() bool {\n   509→\t\ttracker.mu.Lock()\n   510→\t\tdefer tracker.mu.Unlock()\n   511→\t\treturn len(tracker.completed) > 0\n   512→\t}, time.Second, 10*time.Millisecond)\n   513→}\n   514→\n   515→func TestOrchestratorRun_FallbackWithoutHostCloche(t *testing.T) {\n   516→\ttmpDir := t.TempDir()\n   517→\t// No host.cloche file — should fall back to promptGen → dispatch path\n   518→\n   519→\ttracker := &mockTracker{\n   520→\t\ttasks: []ports.TrackerTask{\n   521→\t\t\t{ID: \"task-1\", Title: \"Test Task\"},\n   522→\t\t},\n   523→\t}\n   524→\tpromptGen := &mockPromptGen{response: \"generated prompt\"}\n   525→\n   526→\tdispatched := false\n   527→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   528→\t\tdispatched = true\n   529→\t\treturn \"run-1\", nil\n   530→\t}\n   531→\n   532→\twaiter := &mockRunWaiter{state: domain.RunStateSucceeded}\n   533→\thostRunner := &HostRunner{\n   534→\t\tDispatch: dispatch,\n   535→\t\tWaitRun:  waiter,\n   536→\t}\n   537→\n   538→\tparseFunc := func(input string) (*domain.Workflow, error) {\n   539→\t\treturn dsl.Parse(input)\n   540→\t}\n   541→\n   542→\torch := New(promptGen, dispatch,\n   543→\t\tWithHostRunner(hostRunner),\n   544→\t\tWithParseHostWorkflow(parseFunc),\n   545→\t)\n   546→\torch.Register(&ProjectConfig{\n   547→\t\tDir:         tmpDir,\n   548→\t\tWorkflow:    \"develop\",\n   549→\t\tConcurrency: 1,\n   550→\t\tTracker:     tracker,\n   551→\t})\n   552→\n   553→\tn, err := orch.Run(context.Background(), tmpDir)\n   554→\trequire.NoError(t, err)\n   555→\tassert.Equal(t, 1, n)\n   556→\tassert.Equal(t, 1, promptGen.calls)\n   557→\tassert.True(t, dispatched)\n   558→}\n   559→\n   560→func TestOrchestratorRun_UsesCorrectWorkflow(t *testing.T) {\n   561→\ttracker := &mockTracker{\n   562→\t\ttasks: []ports.TrackerTask{\n   563→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   564→\t\t},\n   565→\t}\n   566→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   567→\n   568→\tvar capturedWorkflow string\n   569→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   570→\t\tcapturedWorkflow = workflow\n   571→\t\treturn \"run-1\", nil\n   572→\t}\n   573→\n   574→\torch := New(promptGen, dispatch)\n   575→\torch.Register(&ProjectConfig{\n   576→\t\tDir:         \"/test/project\",\n   577→\t\tWorkflow:    \"custom-workflow\",\n   578→\t\tConcurrency: 1,\n   579→\t\tTracker:     tracker,\n   580→\t})\n   581→\n   582→\t_, err := orch.Run(context.Background(), \"/test/project\")\n   583→\trequire.NoError(t, err)\n   584→\tassert.Equal(t, \"custom-workflow\", capturedWorkflow)\n   585→}\n   586→"}]},"parent_tool_use_id":"toolu_012uHU5wr2SMuKTi5y43q4Vk","session_id":"36e135ce-10f3-4a37-be7d-4cf1fde5dba1","uuid":"2709f87f-699f-426f-841e-8b0060aceafe"}
