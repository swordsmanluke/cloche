{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xw28SvwtSAaGGRE2yReEfc","type":"tool_result","content":"     1→package beads\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"os\"\n     6→\t\"path/filepath\"\n     7→\t\"testing\"\n     8→\n     9→\t\"github.com/stretchr/testify/assert\"\n    10→\t\"github.com/stretchr/testify/require\"\n    11→)\n    12→\n    13→func TestTrackerListReady_Empty(t *testing.T) {\n    14→\tdir := t.TempDir()\n    15→\ttracker := NewTracker(dir)\n    16→\n    17→\ttasks, err := tracker.ListReady(context.Background(), dir)\n    18→\trequire.NoError(t, err)\n    19→\tassert.Empty(t, tasks)\n    20→}\n    21→\n    22→func TestTrackerListReady_FiltersByOpenStatus(t *testing.T) {\n    23→\tdir := t.TempDir()\n    24→\tbeadsDir := filepath.Join(dir, \".beads\")\n    25→\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n    26→\n    27→\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Open task\",\"status\":\"open\",\"priority\":1}\n    28→{\"id\":\"t2\",\"title\":\"Closed task\",\"status\":\"closed\",\"priority\":2}\n    29→{\"id\":\"t3\",\"title\":\"In progress\",\"status\":\"in_progress\",\"priority\":3}\n    30→{\"id\":\"t4\",\"title\":\"Another open\",\"status\":\"open\",\"priority\":5}\n    31→`\n    32→\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n    33→\n    34→\ttracker := NewTracker(dir)\n    35→\ttasks, err := tracker.ListReady(context.Background(), dir)\n    36→\trequire.NoError(t, err)\n    37→\trequire.Len(t, tasks, 2)\n    38→\n    39→\t// Should be ordered by priority descending\n    40→\tassert.Equal(t, \"t4\", tasks[0].ID)\n    41→\tassert.Equal(t, \"Another open\", tasks[0].Title)\n    42→\tassert.Equal(t, 5, tasks[0].Priority)\n    43→\n    44→\tassert.Equal(t, \"t1\", tasks[1].ID)\n    45→\tassert.Equal(t, 1, tasks[1].Priority)\n    46→}\n    47→\n    48→func TestTrackerListReady_LastOccurrenceWins(t *testing.T) {\n    49→\tdir := t.TempDir()\n    50→\tbeadsDir := filepath.Join(dir, \".beads\")\n    51→\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n    52→\n    53→\t// Same ID appears twice; second occurrence should win\n    54→\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Original\",\"status\":\"open\",\"priority\":1}\n    55→{\"id\":\"t1\",\"title\":\"Updated\",\"status\":\"closed\",\"priority\":1}\n    56→`\n    57→\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n    58→\n    59→\ttracker := NewTracker(dir)\n    60→\ttasks, err := tracker.ListReady(context.Background(), dir)\n    61→\trequire.NoError(t, err)\n    62→\tassert.Empty(t, tasks) // t1 is now closed\n    63→}\n    64→\n    65→func TestTrackerListReady_SkipsTombstones(t *testing.T) {\n    66→\tdir := t.TempDir()\n    67→\tbeadsDir := filepath.Join(dir, \".beads\")\n    68→\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n    69→\n    70→\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Active\",\"status\":\"open\",\"priority\":1}\n    71→{\"id\":\"t2\",\"title\":\"Deleted\",\"status\":\"tombstone\",\"priority\":2}\n    72→`\n    73→\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n    74→\n    75→\ttracker := NewTracker(dir)\n    76→\ttasks, err := tracker.ListReady(context.Background(), dir)\n    77→\trequire.NoError(t, err)\n    78→\trequire.Len(t, tasks, 1)\n    79→\tassert.Equal(t, \"t1\", tasks[0].ID)\n    80→}\n    81→\n    82→func TestTrackerClaim(t *testing.T) {\n    83→\tdir := t.TempDir()\n    84→\tbeadsDir := filepath.Join(dir, \".beads\")\n    85→\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n    86→\n    87→\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Task\",\"status\":\"open\",\"priority\":1}\n    88→`\n    89→\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n    90→\n    91→\ttracker := NewTracker(dir)\n    92→\terr := tracker.Claim(context.Background(), \"t1\")\n    93→\trequire.NoError(t, err)\n    94→\n    95→\t// Verify task is now in_progress\n    96→\ttasks, err := tracker.ListReady(context.Background(), dir)\n    97→\trequire.NoError(t, err)\n    98→\tassert.Empty(t, tasks) // no longer \"open\"\n    99→}\n   100→\n   101→func TestTrackerComplete(t *testing.T) {\n   102→\tdir := t.TempDir()\n   103→\tbeadsDir := filepath.Join(dir, \".beads\")\n   104→\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n   105→\n   106→\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Task\",\"status\":\"in_progress\",\"priority\":1}\n   107→`\n   108→\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n   109→\n   110→\ttracker := NewTracker(dir)\n   111→\terr := tracker.Complete(context.Background(), \"t1\")\n   112→\trequire.NoError(t, err)\n   113→\n   114→\t// Read raw file to verify\n   115→\tissues, err := readIssuesFromFile(filepath.Join(beadsDir, \"issues.jsonl\"))\n   116→\trequire.NoError(t, err)\n   117→\trequire.Len(t, issues, 1)\n   118→\tassert.Equal(t, \"closed\", issues[0].Status)\n   119→}\n   120→\n   121→func TestTrackerFail(t *testing.T) {\n   122→\tdir := t.TempDir()\n   123→\tbeadsDir := filepath.Join(dir, \".beads\")\n   124→\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n   125→\n   126→\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Task\",\"status\":\"in_progress\",\"priority\":1}\n   127→`\n   128→\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n   129→\n   130→\ttracker := NewTracker(dir)\n   131→\terr := tracker.Fail(context.Background(), \"t1\")\n   132→\trequire.NoError(t, err)\n   133→\n   134→\t// Should be back to open\n   135→\ttasks, err := tracker.ListReady(context.Background(), dir)\n   136→\trequire.NoError(t, err)\n   137→\trequire.Len(t, tasks, 1)\n   138→\tassert.Equal(t, \"t1\", tasks[0].ID)\n   139→}\n   140→\n   141→func TestTrackerClaim_NotFound(t *testing.T) {\n   142→\tdir := t.TempDir()\n   143→\tbeadsDir := filepath.Join(dir, \".beads\")\n   144→\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n   145→\n   146→\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Task\",\"status\":\"open\",\"priority\":1}\n   147→`\n   148→\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n   149→\n   150→\ttracker := NewTracker(dir)\n   151→\terr := tracker.Claim(context.Background(), \"nonexistent\")\n   152→\tassert.Error(t, err)\n   153→\tassert.Contains(t, err.Error(), \"not found\")\n   154→}\n   155→\n   156→func TestTrackerListReady_FiltersBlockedTasks(t *testing.T) {\n   157→\tdir := t.TempDir()\n   158→\tbeadsDir := filepath.Join(dir, \".beads\")\n   159→\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n   160→\n   161→\t// t2 depends on t1 (which is open), so t2 should be blocked.\n   162→\t// t3 depends on t4 (which is closed), so t3 should be ready.\n   163→\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Blocker\",\"status\":\"open\",\"priority\":1}\n   164→{\"id\":\"t2\",\"title\":\"Blocked by t1\",\"status\":\"open\",\"priority\":3,\"dependencies\":[{\"issue_id\":\"t2\",\"depends_on_id\":\"t1\",\"type\":\"blocks\"}]}\n   165→{\"id\":\"t3\",\"title\":\"Unblocked\",\"status\":\"open\",\"priority\":2,\"dependencies\":[{\"issue_id\":\"t3\",\"depends_on_id\":\"t4\",\"type\":\"blocks\"}]}\n   166→{\"id\":\"t4\",\"title\":\"Done dep\",\"status\":\"closed\",\"priority\":1}\n   167→`\n   168→\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n   169→\n   170→\ttracker := NewTracker(dir)\n   171→\ttasks, err := tracker.ListReady(context.Background(), dir)\n   172→\trequire.NoError(t, err)\n   173→\n   174→\t// t2 should be filtered out (blocked by t1 which is open).\n   175→\t// t1 and t3 should be returned.\n   176→\tids := make([]string, len(tasks))\n   177→\tfor i, task := range tasks {\n   178→\t\tids[i] = task.ID\n   179→\t}\n   180→\tassert.Contains(t, ids, \"t1\")\n   181→\tassert.Contains(t, ids, \"t3\")\n   182→\tassert.NotContains(t, ids, \"t2\")\n   183→\tassert.Len(t, tasks, 2)\n   184→}\n   185→\n   186→func TestTrackerListReady_BlockerClosedUnblocks(t *testing.T) {\n   187→\tdir := t.TempDir()\n   188→\tbeadsDir := filepath.Join(dir, \".beads\")\n   189→\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n   190→\n   191→\t// Initially t1 blocks t2\n   192→\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Blocker\",\"status\":\"open\",\"priority\":1}\n   193→{\"id\":\"t2\",\"title\":\"Blocked\",\"status\":\"open\",\"priority\":2,\"dependencies\":[{\"issue_id\":\"t2\",\"depends_on_id\":\"t1\",\"type\":\"blocks\"}]}\n   194→`\n   195→\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n   196→\n   197→\ttracker := NewTracker(dir)\n   198→\n   199→\t// Before closing t1: only t1 ready\n   200→\ttasks, err := tracker.ListReady(context.Background(), dir)\n   201→\trequire.NoError(t, err)\n   202→\trequire.Len(t, tasks, 1)\n   203→\tassert.Equal(t, \"t1\", tasks[0].ID)\n   204→\n   205→\t// Close t1\n   206→\terr = tracker.Complete(context.Background(), \"t1\")\n   207→\trequire.NoError(t, err)\n   208→\n   209→\t// After closing t1: t2 should now be ready\n   210→\ttasks, err = tracker.ListReady(context.Background(), dir)\n   211→\trequire.NoError(t, err)\n   212→\trequire.Len(t, tasks, 1)\n   213→\tassert.Equal(t, \"t2\", tasks[0].ID)\n   214→}\n   215→\n   216→func TestTrackerRecoverStaleTasks(t *testing.T) {\n   217→\tdir := t.TempDir()\n   218→\tbeadsDir := filepath.Join(dir, \".beads\")\n   219→\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n   220→\n   221→\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Stale task\",\"status\":\"in_progress\",\"priority\":2}\n   222→{\"id\":\"t2\",\"title\":\"Active task\",\"status\":\"in_progress\",\"priority\":1}\n   223→{\"id\":\"t3\",\"title\":\"Open task\",\"status\":\"open\",\"priority\":3}\n   224→{\"id\":\"t4\",\"title\":\"Closed task\",\"status\":\"closed\",\"priority\":1}\n   225→`\n   226→\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n   227→\n   228→\ttracker := NewTracker(dir)\n   229→\n   230→\t// t2 is actively in-flight, t1 is stale\n   231→\tactiveIDs := map[string]bool{\"t2\": true}\n   232→\tn, err := tracker.RecoverStaleTasks(context.Background(), activeIDs)\n   233→\trequire.NoError(t, err)\n   234→\tassert.Equal(t, 1, n) // only t1 recovered\n   235→\n   236→\t// After recovery, t1 should be open again\n   237→\ttasks, err := tracker.ListReady(context.Background(), dir)\n   238→\trequire.NoError(t, err)\n   239→\n   240→\tids := make([]string, len(tasks))\n   241→\tfor i, task := range tasks {\n   242→\t\tids[i] = task.ID\n   243→\t}\n   244→\tassert.Contains(t, ids, \"t1\") // recovered\n   245→\tassert.Contains(t, ids, \"t3\") // was already open\n   246→\tassert.NotContains(t, ids, \"t2\") // still in_progress (active)\n   247→}\n   248→\n   249→func TestTrackerRecoverStaleTasks_NoStale(t *testing.T) {\n   250→\tdir := t.TempDir()\n   251→\tbeadsDir := filepath.Join(dir, \".beads\")\n   252→\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n   253→\n   254→\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Open task\",\"status\":\"open\",\"priority\":1}\n   255→{\"id\":\"t2\",\"title\":\"Closed task\",\"status\":\"closed\",\"priority\":2}\n   256→`\n   257→\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n   258→\n   259→\ttracker := NewTracker(dir)\n   260→\tn, err := tracker.RecoverStaleTasks(context.Background(), nil)\n   261→\trequire.NoError(t, err)\n   262→\tassert.Equal(t, 0, n)\n   263→}\n   264→\n   265→func TestTrackerRecoverStaleTasks_AllStale(t *testing.T) {\n   266→\tdir := t.TempDir()\n   267→\tbeadsDir := filepath.Join(dir, \".beads\")\n   268→\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n   269→\n   270→\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Stale 1\",\"status\":\"in_progress\",\"priority\":2}\n   271→{\"id\":\"t2\",\"title\":\"Stale 2\",\"status\":\"in_progress\",\"priority\":1}\n   272→`\n   273→\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n   274→\n   275→\ttracker := NewTracker(dir)\n   276→\tn, err := tracker.RecoverStaleTasks(context.Background(), nil)\n   277→\trequire.NoError(t, err)\n   278→\tassert.Equal(t, 2, n)\n   279→\n   280→\t// Both should now be ready\n   281→\ttasks, err := tracker.ListReady(context.Background(), dir)\n   282→\trequire.NoError(t, err)\n   283→\tassert.Len(t, tasks, 2)\n   284→}\n   285→\n   286→func TestTrackerImplementsInterface(t *testing.T) {\n   287→\tvar _ interface {\n   288→\t\tListReady(context.Context, string) ([]interface{}, error)\n   289→\t}\n   290→\t// Compile-time check\n   291→\ttracker := NewTracker(\"\")\n   292→\t_ = tracker\n   293→}\n   294→"}]},"parent_tool_use_id":null,"session_id":"92f06db3-be18-4832-ac12-993c8ca2e234","uuid":"0122be02-9147-48ba-94c1-735d29390851","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/beads/tracker_test.go","content":"package beads\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestTrackerListReady_Empty(t *testing.T) {\n\tdir := t.TempDir()\n\ttracker := NewTracker(dir)\n\n\ttasks, err := tracker.ListReady(context.Background(), dir)\n\trequire.NoError(t, err)\n\tassert.Empty(t, tasks)\n}\n\nfunc TestTrackerListReady_FiltersByOpenStatus(t *testing.T) {\n\tdir := t.TempDir()\n\tbeadsDir := filepath.Join(dir, \".beads\")\n\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n\n\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Open task\",\"status\":\"open\",\"priority\":1}\n{\"id\":\"t2\",\"title\":\"Closed task\",\"status\":\"closed\",\"priority\":2}\n{\"id\":\"t3\",\"title\":\"In progress\",\"status\":\"in_progress\",\"priority\":3}\n{\"id\":\"t4\",\"title\":\"Another open\",\"status\":\"open\",\"priority\":5}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n\n\ttracker := NewTracker(dir)\n\ttasks, err := tracker.ListReady(context.Background(), dir)\n\trequire.NoError(t, err)\n\trequire.Len(t, tasks, 2)\n\n\t// Should be ordered by priority descending\n\tassert.Equal(t, \"t4\", tasks[0].ID)\n\tassert.Equal(t, \"Another open\", tasks[0].Title)\n\tassert.Equal(t, 5, tasks[0].Priority)\n\n\tassert.Equal(t, \"t1\", tasks[1].ID)\n\tassert.Equal(t, 1, tasks[1].Priority)\n}\n\nfunc TestTrackerListReady_LastOccurrenceWins(t *testing.T) {\n\tdir := t.TempDir()\n\tbeadsDir := filepath.Join(dir, \".beads\")\n\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n\n\t// Same ID appears twice; second occurrence should win\n\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Original\",\"status\":\"open\",\"priority\":1}\n{\"id\":\"t1\",\"title\":\"Updated\",\"status\":\"closed\",\"priority\":1}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n\n\ttracker := NewTracker(dir)\n\ttasks, err := tracker.ListReady(context.Background(), dir)\n\trequire.NoError(t, err)\n\tassert.Empty(t, tasks) // t1 is now closed\n}\n\nfunc TestTrackerListReady_SkipsTombstones(t *testing.T) {\n\tdir := t.TempDir()\n\tbeadsDir := filepath.Join(dir, \".beads\")\n\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n\n\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Active\",\"status\":\"open\",\"priority\":1}\n{\"id\":\"t2\",\"title\":\"Deleted\",\"status\":\"tombstone\",\"priority\":2}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n\n\ttracker := NewTracker(dir)\n\ttasks, err := tracker.ListReady(context.Background(), dir)\n\trequire.NoError(t, err)\n\trequire.Len(t, tasks, 1)\n\tassert.Equal(t, \"t1\", tasks[0].ID)\n}\n\nfunc TestTrackerClaim(t *testing.T) {\n\tdir := t.TempDir()\n\tbeadsDir := filepath.Join(dir, \".beads\")\n\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n\n\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Task\",\"status\":\"open\",\"priority\":1}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n\n\ttracker := NewTracker(dir)\n\terr := tracker.Claim(context.Background(), \"t1\")\n\trequire.NoError(t, err)\n\n\t// Verify task is now in_progress\n\ttasks, err := tracker.ListReady(context.Background(), dir)\n\trequire.NoError(t, err)\n\tassert.Empty(t, tasks) // no longer \"open\"\n}\n\nfunc TestTrackerComplete(t *testing.T) {\n\tdir := t.TempDir()\n\tbeadsDir := filepath.Join(dir, \".beads\")\n\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n\n\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Task\",\"status\":\"in_progress\",\"priority\":1}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n\n\ttracker := NewTracker(dir)\n\terr := tracker.Complete(context.Background(), \"t1\")\n\trequire.NoError(t, err)\n\n\t// Read raw file to verify\n\tissues, err := readIssuesFromFile(filepath.Join(beadsDir, \"issues.jsonl\"))\n\trequire.NoError(t, err)\n\trequire.Len(t, issues, 1)\n\tassert.Equal(t, \"closed\", issues[0].Status)\n}\n\nfunc TestTrackerFail(t *testing.T) {\n\tdir := t.TempDir()\n\tbeadsDir := filepath.Join(dir, \".beads\")\n\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n\n\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Task\",\"status\":\"in_progress\",\"priority\":1}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n\n\ttracker := NewTracker(dir)\n\terr := tracker.Fail(context.Background(), \"t1\")\n\trequire.NoError(t, err)\n\n\t// Should be back to open\n\ttasks, err := tracker.ListReady(context.Background(), dir)\n\trequire.NoError(t, err)\n\trequire.Len(t, tasks, 1)\n\tassert.Equal(t, \"t1\", tasks[0].ID)\n}\n\nfunc TestTrackerClaim_NotFound(t *testing.T) {\n\tdir := t.TempDir()\n\tbeadsDir := filepath.Join(dir, \".beads\")\n\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n\n\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Task\",\"status\":\"open\",\"priority\":1}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n\n\ttracker := NewTracker(dir)\n\terr := tracker.Claim(context.Background(), \"nonexistent\")\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"not found\")\n}\n\nfunc TestTrackerListReady_FiltersBlockedTasks(t *testing.T) {\n\tdir := t.TempDir()\n\tbeadsDir := filepath.Join(dir, \".beads\")\n\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n\n\t// t2 depends on t1 (which is open), so t2 should be blocked.\n\t// t3 depends on t4 (which is closed), so t3 should be ready.\n\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Blocker\",\"status\":\"open\",\"priority\":1}\n{\"id\":\"t2\",\"title\":\"Blocked by t1\",\"status\":\"open\",\"priority\":3,\"dependencies\":[{\"issue_id\":\"t2\",\"depends_on_id\":\"t1\",\"type\":\"blocks\"}]}\n{\"id\":\"t3\",\"title\":\"Unblocked\",\"status\":\"open\",\"priority\":2,\"dependencies\":[{\"issue_id\":\"t3\",\"depends_on_id\":\"t4\",\"type\":\"blocks\"}]}\n{\"id\":\"t4\",\"title\":\"Done dep\",\"status\":\"closed\",\"priority\":1}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n\n\ttracker := NewTracker(dir)\n\ttasks, err := tracker.ListReady(context.Background(), dir)\n\trequire.NoError(t, err)\n\n\t// t2 should be filtered out (blocked by t1 which is open).\n\t// t1 and t3 should be returned.\n\tids := make([]string, len(tasks))\n\tfor i, task := range tasks {\n\t\tids[i] = task.ID\n\t}\n\tassert.Contains(t, ids, \"t1\")\n\tassert.Contains(t, ids, \"t3\")\n\tassert.NotContains(t, ids, \"t2\")\n\tassert.Len(t, tasks, 2)\n}\n\nfunc TestTrackerListReady_BlockerClosedUnblocks(t *testing.T) {\n\tdir := t.TempDir()\n\tbeadsDir := filepath.Join(dir, \".beads\")\n\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n\n\t// Initially t1 blocks t2\n\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Blocker\",\"status\":\"open\",\"priority\":1}\n{\"id\":\"t2\",\"title\":\"Blocked\",\"status\":\"open\",\"priority\":2,\"dependencies\":[{\"issue_id\":\"t2\",\"depends_on_id\":\"t1\",\"type\":\"blocks\"}]}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n\n\ttracker := NewTracker(dir)\n\n\t// Before closing t1: only t1 ready\n\ttasks, err := tracker.ListReady(context.Background(), dir)\n\trequire.NoError(t, err)\n\trequire.Len(t, tasks, 1)\n\tassert.Equal(t, \"t1\", tasks[0].ID)\n\n\t// Close t1\n\terr = tracker.Complete(context.Background(), \"t1\")\n\trequire.NoError(t, err)\n\n\t// After closing t1: t2 should now be ready\n\ttasks, err = tracker.ListReady(context.Background(), dir)\n\trequire.NoError(t, err)\n\trequire.Len(t, tasks, 1)\n\tassert.Equal(t, \"t2\", tasks[0].ID)\n}\n\nfunc TestTrackerRecoverStaleTasks(t *testing.T) {\n\tdir := t.TempDir()\n\tbeadsDir := filepath.Join(dir, \".beads\")\n\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n\n\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Stale task\",\"status\":\"in_progress\",\"priority\":2}\n{\"id\":\"t2\",\"title\":\"Active task\",\"status\":\"in_progress\",\"priority\":1}\n{\"id\":\"t3\",\"title\":\"Open task\",\"status\":\"open\",\"priority\":3}\n{\"id\":\"t4\",\"title\":\"Closed task\",\"status\":\"closed\",\"priority\":1}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n\n\ttracker := NewTracker(dir)\n\n\t// t2 is actively in-flight, t1 is stale\n\tactiveIDs := map[string]bool{\"t2\": true}\n\tn, err := tracker.RecoverStaleTasks(context.Background(), activeIDs)\n\trequire.NoError(t, err)\n\tassert.Equal(t, 1, n) // only t1 recovered\n\n\t// After recovery, t1 should be open again\n\ttasks, err := tracker.ListReady(context.Background(), dir)\n\trequire.NoError(t, err)\n\n\tids := make([]string, len(tasks))\n\tfor i, task := range tasks {\n\t\tids[i] = task.ID\n\t}\n\tassert.Contains(t, ids, \"t1\") // recovered\n\tassert.Contains(t, ids, \"t3\") // was already open\n\tassert.NotContains(t, ids, \"t2\") // still in_progress (active)\n}\n\nfunc TestTrackerRecoverStaleTasks_NoStale(t *testing.T) {\n\tdir := t.TempDir()\n\tbeadsDir := filepath.Join(dir, \".beads\")\n\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n\n\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Open task\",\"status\":\"open\",\"priority\":1}\n{\"id\":\"t2\",\"title\":\"Closed task\",\"status\":\"closed\",\"priority\":2}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n\n\ttracker := NewTracker(dir)\n\tn, err := tracker.RecoverStaleTasks(context.Background(), nil)\n\trequire.NoError(t, err)\n\tassert.Equal(t, 0, n)\n}\n\nfunc TestTrackerRecoverStaleTasks_AllStale(t *testing.T) {\n\tdir := t.TempDir()\n\tbeadsDir := filepath.Join(dir, \".beads\")\n\trequire.NoError(t, os.MkdirAll(beadsDir, 0755))\n\n\tissuesJSONL := `{\"id\":\"t1\",\"title\":\"Stale 1\",\"status\":\"in_progress\",\"priority\":2}\n{\"id\":\"t2\",\"title\":\"Stale 2\",\"status\":\"in_progress\",\"priority\":1}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(beadsDir, \"issues.jsonl\"), []byte(issuesJSONL), 0644))\n\n\ttracker := NewTracker(dir)\n\tn, err := tracker.RecoverStaleTasks(context.Background(), nil)\n\trequire.NoError(t, err)\n\tassert.Equal(t, 2, n)\n\n\t// Both should now be ready\n\ttasks, err := tracker.ListReady(context.Background(), dir)\n\trequire.NoError(t, err)\n\tassert.Len(t, tasks, 2)\n}\n\nfunc TestTrackerImplementsInterface(t *testing.T) {\n\tvar _ interface {\n\t\tListReady(context.Context, string) ([]interface{}, error)\n\t}\n\t// Compile-time check\n\ttracker := NewTracker(\"\")\n\t_ = tracker\n}\n","numLines":294,"startLine":1,"totalLines":294}}}
