{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CRJoNuNXEP4WG49DyGxvEF","type":"tool_result","content":"     1→package beads\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"sort\"\n    10→\t\"strings\"\n    11→\t\"sync\"\n    12→\t\"time\"\n    13→\n    14→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    15→)\n    16→\n    17→// issue is the on-disk representation of a beads issue.\n    18→type issue struct {\n    19→\tID           string       `json:\"id\"`\n    20→\tTitle        string       `json:\"title\"`\n    21→\tDescription  string       `json:\"description\"`\n    22→\tStatus       string       `json:\"status\"`\n    23→\tPriority     int          `json:\"priority\"`\n    24→\tIssueType    string       `json:\"issue_type\"`\n    25→\tLabels       []string     `json:\"labels\"`\n    26→\tDependencies []dependency `json:\"dependencies,omitempty\"`\n    27→\tCreatedAt    time.Time    `json:\"created_at\"`\n    28→\tUpdatedAt    time.Time    `json:\"updated_at\"`\n    29→\tClosedAt     time.Time    `json:\"closed_at,omitempty\"`\n    30→\tCloseReason  string       `json:\"close_reason,omitempty\"`\n    31→\tCreatedBy    string       `json:\"created_by\"`\n    32→}\n    33→\n    34→type dependency struct {\n    35→\tIssueID     string `json:\"issue_id\"`\n    36→\tDependsOnID string `json:\"depends_on_id\"`\n    37→\tType        string `json:\"type\"`\n    38→}\n    39→\n    40→// Tracker implements ports.TaskTracker backed by .beads/issues.jsonl.\n    41→// Each Tracker is scoped to a single project directory.\n    42→type Tracker struct {\n    43→\tprojectDir string\n    44→\tmu         sync.Mutex\n    45→}\n    46→\n    47→// NewTracker creates a new Beads tracker for the given project directory.\n    48→func NewTracker(projectDir string) *Tracker {\n    49→\treturn &Tracker{projectDir: projectDir}\n    50→}\n    51→\n    52→// ListReady returns open tasks whose blocking dependencies are all closed,\n    53→// ordered by priority (highest first).\n    54→func (t *Tracker) ListReady(_ context.Context, project string) ([]ports.TrackerTask, error) {\n    55→\tt.mu.Lock()\n    56→\tdefer t.mu.Unlock()\n    57→\n    58→\tissues, err := readIssuesFromFile(t.beadsPath())\n    59→\tif err != nil {\n    60→\t\treturn nil, err\n    61→\t}\n    62→\n    63→\t// Build a status lookup for dependency checking.\n    64→\tstatusByID := make(map[string]string, len(issues))\n    65→\tfor _, iss := range issues {\n    66→\t\tstatusByID[iss.ID] = iss.Status\n    67→\t}\n    68→\n    69→\tvar tasks []ports.TrackerTask\n    70→\tfor _, iss := range issues {\n    71→\t\tif iss.Status != \"open\" {\n    72→\t\t\tcontinue\n    73→\t\t}\n    74→\t\tif hasOpenBlockers(iss, statusByID) {\n    75→\t\t\tcontinue\n    76→\t\t}\n    77→\t\ttasks = append(tasks, ports.TrackerTask{\n    78→\t\t\tID:          iss.ID,\n    79→\t\t\tTitle:       iss.Title,\n    80→\t\t\tDescription: iss.Description,\n    81→\t\t\tLabels:      iss.Labels,\n    82→\t\t\tPriority:    iss.Priority,\n    83→\t\t})\n    84→\t}\n    85→\n    86→\tsort.Slice(tasks, func(i, j int) bool {\n    87→\t\treturn tasks[i].Priority > tasks[j].Priority\n    88→\t})\n    89→\n    90→\treturn tasks, nil\n    91→}\n    92→\n    93→// hasOpenBlockers returns true if any of the issue's dependencies are not closed.\n    94→func hasOpenBlockers(iss issue, statusByID map[string]string) bool {\n    95→\tfor _, dep := range iss.Dependencies {\n    96→\t\tdepStatus := statusByID[dep.DependsOnID]\n    97→\t\tif depStatus != \"closed\" {\n    98→\t\t\treturn true\n    99→\t\t}\n   100→\t}\n   101→\treturn false\n   102→}\n   103→\n   104→// Claim marks a task as \"in_progress\" by appending an updated line to the JSONL file.\n   105→func (t *Tracker) Claim(_ context.Context, taskID string) error {\n   106→\treturn t.appendStatusUpdate(taskID, \"in_progress\")\n   107→}\n   108→\n   109→// Complete marks a task as \"closed\" by appending an updated line to the JSONL file.\n   110→func (t *Tracker) Complete(_ context.Context, taskID string) error {\n   111→\treturn t.appendStatusUpdate(taskID, \"closed\")\n   112→}\n   113→\n   114→// Fail marks a task back to \"open\" so it can be retried.\n   115→func (t *Tracker) Fail(_ context.Context, taskID string) error {\n   116→\treturn t.appendStatusUpdate(taskID, \"open\")\n   117→}\n   118→\n   119→// RecoverStaleTasks resets in_progress tasks back to open, except those in\n   120→// activeTaskIDs. Returns the number of tasks recovered.\n   121→func (t *Tracker) RecoverStaleTasks(_ context.Context, activeTaskIDs map[string]bool) (int, error) {\n   122→\tt.mu.Lock()\n   123→\tdefer t.mu.Unlock()\n   124→\n   125→\tpath := t.beadsPath()\n   126→\tissues, err := readIssuesFromFile(path)\n   127→\tif err != nil {\n   128→\t\treturn 0, err\n   129→\t}\n   130→\n   131→\tvar stale []string\n   132→\tfor _, iss := range issues {\n   133→\t\tif iss.Status == \"in_progress\" && !activeTaskIDs[iss.ID] {\n   134→\t\t\tstale = append(stale, iss.ID)\n   135→\t\t}\n   136→\t}\n   137→\n   138→\tif len(stale) == 0 {\n   139→\t\treturn 0, nil\n   140→\t}\n   141→\n   142→\tf, err := os.OpenFile(path, os.O_APPEND|os.O_WRONLY, 0644)\n   143→\tif err != nil {\n   144→\t\treturn 0, fmt.Errorf(\"opening beads file: %w\", err)\n   145→\t}\n   146→\tdefer f.Close()\n   147→\n   148→\t// Build lookup for efficient access\n   149→\tissueByID := make(map[string]*issue, len(issues))\n   150→\tfor i := range issues {\n   151→\t\tissueByID[issues[i].ID] = &issues[i]\n   152→\t}\n   153→\n   154→\tfor _, id := range stale {\n   155→\t\tiss := issueByID[id]\n   156→\t\tiss.Status = \"open\"\n   157→\t\tiss.UpdatedAt = time.Now()\n   158→\t\tdata, err := json.Marshal(iss)\n   159→\t\tif err != nil {\n   160→\t\t\treturn 0, fmt.Errorf(\"marshaling issue: %w\", err)\n   161→\t\t}\n   162→\t\tif _, err := f.WriteString(\"\\n\" + string(data)); err != nil {\n   163→\t\t\treturn 0, fmt.Errorf(\"appending to beads file: %w\", err)\n   164→\t\t}\n   165→\t}\n   166→\n   167→\treturn len(stale), nil\n   168→}\n   169→\n   170→// appendStatusUpdate reads the current issue, updates its status, and appends\n   171→// the updated version to the JSONL file.\n   172→func (t *Tracker) appendStatusUpdate(taskID, newStatus string) error {\n   173→\tt.mu.Lock()\n   174→\tdefer t.mu.Unlock()\n   175→\n   176→\tpath := t.beadsPath()\n   177→\tissues, err := readIssuesFromFile(path)\n   178→\tif err != nil {\n   179→\t\treturn err\n   180→\t}\n   181→\n   182→\tvar target *issue\n   183→\tfor i := range issues {\n   184→\t\tif issues[i].ID == taskID {\n   185→\t\t\ttarget = &issues[i]\n   186→\t\t\tbreak\n   187→\t\t}\n   188→\t}\n   189→\tif target == nil {\n   190→\t\treturn fmt.Errorf(\"task %q not found in %s\", taskID, path)\n   191→\t}\n   192→\n   193→\ttarget.Status = newStatus\n   194→\ttarget.UpdatedAt = time.Now()\n   195→\tif newStatus == \"closed\" {\n   196→\t\tnow := time.Now()\n   197→\t\ttarget.ClosedAt = now\n   198→\t}\n   199→\n   200→\tdata, err := json.Marshal(target)\n   201→\tif err != nil {\n   202→\t\treturn fmt.Errorf(\"marshaling issue: %w\", err)\n   203→\t}\n   204→\n   205→\tf, err := os.OpenFile(path, os.O_APPEND|os.O_WRONLY, 0644)\n   206→\tif err != nil {\n   207→\t\treturn fmt.Errorf(\"opening beads file: %w\", err)\n   208→\t}\n   209→\tdefer f.Close()\n   210→\n   211→\tif _, err := f.WriteString(\"\\n\" + string(data)); err != nil {\n   212→\t\treturn fmt.Errorf(\"appending to beads file: %w\", err)\n   213→\t}\n   214→\n   215→\treturn nil\n   216→}\n   217→\n   218→func (t *Tracker) beadsPath() string {\n   219→\treturn filepath.Join(t.projectDir, \".beads\", \"issues.jsonl\")\n   220→}\n   221→\n   222→func readIssuesFromFile(path string) ([]issue, error) {\n   223→\tdata, err := os.ReadFile(path)\n   224→\tif os.IsNotExist(err) {\n   225→\t\treturn nil, nil\n   226→\t}\n   227→\tif err != nil {\n   228→\t\treturn nil, fmt.Errorf(\"reading beads file: %w\", err)\n   229→\t}\n   230→\n   231→\t// JSONL: each issue can appear multiple times; last occurrence wins.\n   232→\tseen := make(map[string]*issue)\n   233→\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   234→\t\tline = strings.TrimSpace(line)\n   235→\t\tif line == \"\" {\n   236→\t\t\tcontinue\n   237→\t\t}\n   238→\t\tvar iss issue\n   239→\t\tif err := json.Unmarshal([]byte(line), &iss); err != nil {\n   240→\t\t\tcontinue // skip malformed lines\n   241→\t\t}\n   242→\t\tif iss.Status == \"tombstone\" {\n   243→\t\t\tdelete(seen, iss.ID)\n   244→\t\t\tcontinue\n   245→\t\t}\n   246→\t\tcp := iss\n   247→\t\tseen[iss.ID] = &cp\n   248→\t}\n   249→\n   250→\tresult := make([]issue, 0, len(seen))\n   251→\tfor _, iss := range seen {\n   252→\t\tresult = append(result, *iss)\n   253→\t}\n   254→\treturn result, nil\n   255→}\n   256→"}]},"parent_tool_use_id":null,"session_id":"92f06db3-be18-4832-ac12-993c8ca2e234","uuid":"acf5e09a-3ba9-4e72-b23c-76bd253bae9f","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/beads/tracker.go","content":"package beads\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// issue is the on-disk representation of a beads issue.\ntype issue struct {\n\tID           string       `json:\"id\"`\n\tTitle        string       `json:\"title\"`\n\tDescription  string       `json:\"description\"`\n\tStatus       string       `json:\"status\"`\n\tPriority     int          `json:\"priority\"`\n\tIssueType    string       `json:\"issue_type\"`\n\tLabels       []string     `json:\"labels\"`\n\tDependencies []dependency `json:\"dependencies,omitempty\"`\n\tCreatedAt    time.Time    `json:\"created_at\"`\n\tUpdatedAt    time.Time    `json:\"updated_at\"`\n\tClosedAt     time.Time    `json:\"closed_at,omitempty\"`\n\tCloseReason  string       `json:\"close_reason,omitempty\"`\n\tCreatedBy    string       `json:\"created_by\"`\n}\n\ntype dependency struct {\n\tIssueID     string `json:\"issue_id\"`\n\tDependsOnID string `json:\"depends_on_id\"`\n\tType        string `json:\"type\"`\n}\n\n// Tracker implements ports.TaskTracker backed by .beads/issues.jsonl.\n// Each Tracker is scoped to a single project directory.\ntype Tracker struct {\n\tprojectDir string\n\tmu         sync.Mutex\n}\n\n// NewTracker creates a new Beads tracker for the given project directory.\nfunc NewTracker(projectDir string) *Tracker {\n\treturn &Tracker{projectDir: projectDir}\n}\n\n// ListReady returns open tasks whose blocking dependencies are all closed,\n// ordered by priority (highest first).\nfunc (t *Tracker) ListReady(_ context.Context, project string) ([]ports.TrackerTask, error) {\n\tt.mu.Lock()\n\tdefer t.mu.Unlock()\n\n\tissues, err := readIssuesFromFile(t.beadsPath())\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Build a status lookup for dependency checking.\n\tstatusByID := make(map[string]string, len(issues))\n\tfor _, iss := range issues {\n\t\tstatusByID[iss.ID] = iss.Status\n\t}\n\n\tvar tasks []ports.TrackerTask\n\tfor _, iss := range issues {\n\t\tif iss.Status != \"open\" {\n\t\t\tcontinue\n\t\t}\n\t\tif hasOpenBlockers(iss, statusByID) {\n\t\t\tcontinue\n\t\t}\n\t\ttasks = append(tasks, ports.TrackerTask{\n\t\t\tID:          iss.ID,\n\t\t\tTitle:       iss.Title,\n\t\t\tDescription: iss.Description,\n\t\t\tLabels:      iss.Labels,\n\t\t\tPriority:    iss.Priority,\n\t\t})\n\t}\n\n\tsort.Slice(tasks, func(i, j int) bool {\n\t\treturn tasks[i].Priority > tasks[j].Priority\n\t})\n\n\treturn tasks, nil\n}\n\n// hasOpenBlockers returns true if any of the issue's dependencies are not closed.\nfunc hasOpenBlockers(iss issue, statusByID map[string]string) bool {\n\tfor _, dep := range iss.Dependencies {\n\t\tdepStatus := statusByID[dep.DependsOnID]\n\t\tif depStatus != \"closed\" {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\n// Claim marks a task as \"in_progress\" by appending an updated line to the JSONL file.\nfunc (t *Tracker) Claim(_ context.Context, taskID string) error {\n\treturn t.appendStatusUpdate(taskID, \"in_progress\")\n}\n\n// Complete marks a task as \"closed\" by appending an updated line to the JSONL file.\nfunc (t *Tracker) Complete(_ context.Context, taskID string) error {\n\treturn t.appendStatusUpdate(taskID, \"closed\")\n}\n\n// Fail marks a task back to \"open\" so it can be retried.\nfunc (t *Tracker) Fail(_ context.Context, taskID string) error {\n\treturn t.appendStatusUpdate(taskID, \"open\")\n}\n\n// RecoverStaleTasks resets in_progress tasks back to open, except those in\n// activeTaskIDs. Returns the number of tasks recovered.\nfunc (t *Tracker) RecoverStaleTasks(_ context.Context, activeTaskIDs map[string]bool) (int, error) {\n\tt.mu.Lock()\n\tdefer t.mu.Unlock()\n\n\tpath := t.beadsPath()\n\tissues, err := readIssuesFromFile(path)\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\n\tvar stale []string\n\tfor _, iss := range issues {\n\t\tif iss.Status == \"in_progress\" && !activeTaskIDs[iss.ID] {\n\t\t\tstale = append(stale, iss.ID)\n\t\t}\n\t}\n\n\tif len(stale) == 0 {\n\t\treturn 0, nil\n\t}\n\n\tf, err := os.OpenFile(path, os.O_APPEND|os.O_WRONLY, 0644)\n\tif err != nil {\n\t\treturn 0, fmt.Errorf(\"opening beads file: %w\", err)\n\t}\n\tdefer f.Close()\n\n\t// Build lookup for efficient access\n\tissueByID := make(map[string]*issue, len(issues))\n\tfor i := range issues {\n\t\tissueByID[issues[i].ID] = &issues[i]\n\t}\n\n\tfor _, id := range stale {\n\t\tiss := issueByID[id]\n\t\tiss.Status = \"open\"\n\t\tiss.UpdatedAt = time.Now()\n\t\tdata, err := json.Marshal(iss)\n\t\tif err != nil {\n\t\t\treturn 0, fmt.Errorf(\"marshaling issue: %w\", err)\n\t\t}\n\t\tif _, err := f.WriteString(\"\\n\" + string(data)); err != nil {\n\t\t\treturn 0, fmt.Errorf(\"appending to beads file: %w\", err)\n\t\t}\n\t}\n\n\treturn len(stale), nil\n}\n\n// appendStatusUpdate reads the current issue, updates its status, and appends\n// the updated version to the JSONL file.\nfunc (t *Tracker) appendStatusUpdate(taskID, newStatus string) error {\n\tt.mu.Lock()\n\tdefer t.mu.Unlock()\n\n\tpath := t.beadsPath()\n\tissues, err := readIssuesFromFile(path)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tvar target *issue\n\tfor i := range issues {\n\t\tif issues[i].ID == taskID {\n\t\t\ttarget = &issues[i]\n\t\t\tbreak\n\t\t}\n\t}\n\tif target == nil {\n\t\treturn fmt.Errorf(\"task %q not found in %s\", taskID, path)\n\t}\n\n\ttarget.Status = newStatus\n\ttarget.UpdatedAt = time.Now()\n\tif newStatus == \"closed\" {\n\t\tnow := time.Now()\n\t\ttarget.ClosedAt = now\n\t}\n\n\tdata, err := json.Marshal(target)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"marshaling issue: %w\", err)\n\t}\n\n\tf, err := os.OpenFile(path, os.O_APPEND|os.O_WRONLY, 0644)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"opening beads file: %w\", err)\n\t}\n\tdefer f.Close()\n\n\tif _, err := f.WriteString(\"\\n\" + string(data)); err != nil {\n\t\treturn fmt.Errorf(\"appending to beads file: %w\", err)\n\t}\n\n\treturn nil\n}\n\nfunc (t *Tracker) beadsPath() string {\n\treturn filepath.Join(t.projectDir, \".beads\", \"issues.jsonl\")\n}\n\nfunc readIssuesFromFile(path string) ([]issue, error) {\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn nil, nil\n\t}\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading beads file: %w\", err)\n\t}\n\n\t// JSONL: each issue can appear multiple times; last occurrence wins.\n\tseen := make(map[string]*issue)\n\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\tline = strings.TrimSpace(line)\n\t\tif line == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tvar iss issue\n\t\tif err := json.Unmarshal([]byte(line), &iss); err != nil {\n\t\t\tcontinue // skip malformed lines\n\t\t}\n\t\tif iss.Status == \"tombstone\" {\n\t\t\tdelete(seen, iss.ID)\n\t\t\tcontinue\n\t\t}\n\t\tcp := iss\n\t\tseen[iss.ID] = &cp\n\t}\n\n\tresult := make([]issue, 0, len(seen))\n\tfor _, iss := range seen {\n\t\tresult = append(result, *iss)\n\t}\n\treturn result, nil\n}\n","numLines":256,"startLine":1,"totalLines":256}}}
