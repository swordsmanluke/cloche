[2026-03-09T15:34:40Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q3Yu9hc2GTNkuimuwAy6Pq","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"os/exec\"\n    14→\t\"path/filepath\"\n    15→\t\"regexp\"\n    16→\t\"sort\"\n    17→\t\"strconv\"\n    18→\t\"strings\"\n    19→\t\"time\"\n    20→\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→)\n    26→\n    27→// HandlerOption configures optional Handler dependencies.\n    28→type HandlerOption func(*Handler)\n    29→\n    30→// WithContainerLogger sets the container runtime for fetching live logs.\n    31→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32→\treturn func(h *Handler) { h.container = c }\n    33→}\n    34→\n    35→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36→func WithContainerManager(c ContainerManager) HandlerOption {\n    37→\treturn func(h *Handler) { h.container = c }\n    38→}\n    39→\n    40→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42→\treturn func(h *Handler) { h.logBroadcast = b }\n    43→}\n    44→\n    45→// WithLogStore sets the log store for indexed log file lookups.\n    46→func WithLogStore(ls ports.LogStore) HandlerOption {\n    47→\treturn func(h *Handler) { h.logStore = ls }\n    48→}\n    49→\n    50→// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    51→func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    52→\treturn func(h *Handler) { h.orchestrateFn = fn }\n    53→}\n    54→\n    55→// OrchestratorController provides per-project orchestrator control.\n    56→type OrchestratorController interface {\n    57→\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    58→\tSetEnabled(dir string, enabled bool)\n    59→\tSetConcurrency(dir string, concurrency int)\n    60→}\n    61→\n    62→// WithOrchestrator sets the orchestrator controller for project-level control.\n    63→func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    64→\treturn func(h *Handler) { h.orchestrator = oc }\n    65→}\n    66→\n    67→//go:embed templates/*.html static/*\n    68→var content embed.FS\n    69→\n    70→// Handler serves the web dashboard.\n    71→// ContainerLogger can retrieve logs from a container by ID.\n    72→type ContainerLogger interface {\n    73→\tLogs(ctx context.Context, containerID string) (string, error)\n    74→}\n    75→\n    76→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    77→type ContainerManager interface {\n    78→\tContainerLogger\n    79→\tRemove(ctx context.Context, containerID string) error\n    80→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    81→}\n    82→\n    83→type Handler struct {\n    84→\tstore         ports.RunStore\n    85→\tcaptures      ports.CaptureStore\n    86→\tlogStore      ports.LogStore\n    87→\tcontainer     ContainerLogger\n    88→\tlogBroadcast  *logstream.Broadcaster\n    89→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    90→\torchestrator  OrchestratorController\n    91→\tpages         map[string]*template.Template\n    92→\tmux           *http.ServeMux\n    93→}\n    94→\n    95→// NewHandler creates a web dashboard handler.\n    96→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    97→\tfuncMap := template.FuncMap{\n    98→\t\t\"stateColor\":       stateColor,\n    99→\t\t\"healthColor\":      healthColor,\n   100→\t\t\"formatTime\":       formatTime,\n   101→\t\t\"formatDuration\":   formatDuration,\n   102→\t\t\"truncate\":         truncate,\n   103→\t\t\"shortContainerID\": shortContainerID,\n   104→\t}\n   105→\n   106→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   107→\tif err != nil {\n   108→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   109→\t}\n   110→\n   111→\tpages := map[string]*template.Template{}\n   112→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   113→\t\tclone, err := base.Clone()\n   114→\t\tif err != nil {\n   115→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   116→\t\t}\n   117→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   118→\t\tif err != nil {\n   119→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   120→\t\t}\n   121→\t\tpages[page] = clone\n   122→\t}\n   123→\n   124→\th := &Handler{\n   125→\t\tstore:    store,\n   126→\t\tcaptures: captures,\n   127→\t\tpages:    pages,\n   128→\t\tmux:      http.NewServeMux(),\n   129→\t}\n   130→\tfor _, opt := range opts {\n   131→\t\topt(h)\n   132→\t}\n   133→\n   134→\tstaticFS, err := fs.Sub(content, \"static\")\n   135→\tif err != nil {\n   136→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   137→\t}\n   138→\n   139→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   140→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   141→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   142→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   143→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   144→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   145→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   146→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   147→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   148→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   149→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   150→\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   151→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   152→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   153→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   154→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   155→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   156→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   157→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   158→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   159→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   160→\n   161→\treturn h, nil\n   162→}\n   163→\n   164→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   165→\th.mux.ServeHTTP(w, r)\n   166→}\n   167→\n   168→// --- HTML handlers ---\n   169→\n   170→// projectOverviewEntry holds data for a single project card on the landing page.\n   171→type projectOverviewEntry struct {\n   172→\tDir         string\n   173→\tLabel       string\n   174→\tHealth      domain.HealthResult\n   175→\tRecentRuns  []recentRunDot\n   176→\tActiveCount int\n   177→}\n   178→\n   179→// recentRunDot is a minimal representation of a run for the mini history display.\n   180→type recentRunDot struct {\n   181→\tID    string\n   182→\tState string\n   183→}\n   184→\n   185→const healthWindowSize = 10\n   186→\n   187→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   188→\tprojects, _ := h.store.ListProjects(r.Context())\n   189→\tlabels := projectLabels(projects)\n   190→\n   191→\tvar entries []projectOverviewEntry\n   192→\tfor _, dir := range projects {\n   193→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   194→\t\tif err != nil {\n   195→\t\t\tcontinue\n   196→\t\t}\n   197→\n   198→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   199→\t\trunValues := make([]domain.Run, len(runs))\n   200→\t\tfor i, rr := range runs {\n   201→\t\t\trunValues[i] = *rr\n   202→\t\t}\n   203→\n   204→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   205→\n   206→\t\t// Take the last N runs for the mini history (most recent first).\n   207→\t\tn := healthWindowSize\n   208→\t\tif n > len(runs) {\n   209→\t\t\tn = len(runs)\n   210→\t\t}\n   211→\t\tdots := make([]recentRunDot, n)\n   212→\t\tfor i := 0; i < n; i++ {\n   213→\t\t\tdots[i] = recentRunDot{\n   214→\t\t\t\tID:    runs[i].ID,\n   215→\t\t\t\tState: string(runs[i].State),\n   216→\t\t\t}\n   217→\t\t}\n   218→\n   219→\t\tvar activeCount int\n   220→\t\tfor _, rr := range runs {\n   221→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   222→\t\t\t\tactiveCount++\n   223→\t\t\t}\n   224→\t\t}\n   225→\n   226→\t\tentries = append(entries, projectOverviewEntry{\n   227→\t\t\tDir:         dir,\n   228→\t\t\tLabel:       labels[dir],\n   229→\t\t\tHealth:      health,\n   230→\t\t\tRecentRuns:  dots,\n   231→\t\t\tActiveCount: activeCount,\n   232→\t\t})\n   233→\t}\n   234→\n   235→\tsort.Slice(entries, func(i, j int) bool {\n   236→\t\treturn entries[i].Label < entries[j].Label\n   237→\t})\n   238→\n   239→\tdata := map[string]any{\n   240→\t\t\"Title\":    \"Projects\",\n   241→\t\t\"Projects\": entries,\n   242→\t}\n   243→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   244→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   245→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   246→\t}\n   247→}\n   248→\n   249→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   250→\th.renderRunsList(w, r, r.URL.Query().Get(\"project\"), \"\")\n   251→}\n   252→\n   253→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   254→\tlabel := r.PathValue(\"name\")\n   255→\tprojects, _ := h.store.ListProjects(r.Context())\n   256→\tlabels := projectLabels(projects)\n   257→\tfor dir, l := range labels {\n   258→\t\tif l == label {\n   259→\t\t\th.renderRunsList(w, r, dir, label)\n   260→\t\t\treturn\n   261→\t\t}\n   262→\t}\n   263→\thttp.Error(w, \"project not found\", http.StatusNotFound)\n   264→}\n   265→\n   266→func (h *Handler) renderRunsList(w http.ResponseWriter, r *http.Request, projectFilter, projectLabel string) {\n   267→\tvar runs []*domain.Run\n   268→\tvar err error\n   269→\tif projectFilter != \"\" {\n   270→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   271→\t} else {\n   272→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   273→\t}\n   274→\tif err != nil {\n   275→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   276→\t\treturn\n   277→\t}\n   278→\n   279→\tprojects, _ := h.store.ListProjects(r.Context())\n   280→\tlabels := projectLabels(projects)\n   281→\n   282→\t// Count retained containers per project\n   283→\tcontainerCounts := map[string]int{}\n   284→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   285→\tfor _, run := range allRuns {\n   286→\t\tif run.ContainerKept {\n   287→\t\t\tcontainerCounts[run.ProjectDir]++\n   288→\t\t}\n   289→\t}\n   290→\n   291→\tvar projectList []projectEntry\n   292→\tfor _, dir := range projects {\n   293→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   294→\t}\n   295→\tsort.Slice(projectList, func(i, j int) bool {\n   296→\t\treturn projectList[i].Label < projectList[j].Label\n   297→\t})\n   298→\n   299→\tdata := map[string]any{\n   300→\t\t\"Title\":         \"Runs\",\n   301→\t\t\"Runs\":          runs,\n   302→\t\t\"Projects\":      projectList,\n   303→\t\t\"ProjectFilter\": projectFilter,\n   304→\t\t\"ProjectLabels\": labels,\n   305→\t}\n   306→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   307→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   308→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   309→\t}\n   310→}\n   311→\n   312→// stepEntry is a merged view of a step execution for the template.\n   313→type stepEntry struct {\n   314→\tIndex     int\n   315→\tStepName  string\n   316→\tResult    string\n   317→\tStartedAt time.Time\n   318→\tDuration  string\n   319→}\n   320→\n   321→// mergeCaptures collapses started/completed capture pairs into single entries.\n   322→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   323→\tvar entries []stepEntry\n   324→\t// Track pending started rows by step name (LIFO for retries)\n   325→\tpending := map[string]*domain.StepExecution{}\n   326→\n   327→\tfor _, c := range caps {\n   328→\t\tif c.Result == \"\" {\n   329→\t\t\t// step_started row\n   330→\t\t\tpending[c.StepName] = c\n   331→\t\t\tcontinue\n   332→\t\t}\n   333→\t\t// step_completed row — merge with pending started if available\n   334→\t\tstartedAt := c.StartedAt\n   335→\t\tif started := pending[c.StepName]; started != nil {\n   336→\t\t\tstartedAt = started.StartedAt\n   337→\t\t\tdelete(pending, c.StepName)\n   338→\t\t}\n   339→\t\tentries = append(entries, stepEntry{\n   340→\t\t\tIndex:     len(entries),\n   341→\t\t\tStepName:  c.StepName,\n   342→\t\t\tResult:    c.Result,\n   343→\t\t\tStartedAt: startedAt,\n   344→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   345→\t\t})\n   346→\t}\n   347→\n   348→\t// Append any started-but-not-completed steps (still running)\n   349→\tfor _, c := range caps {\n   350→\t\tif c.Result == \"\" {\n   351→\t\t\tif _, used := pending[c.StepName]; !used {\n   352→\t\t\t\tcontinue\n   353→\t\t\t}\n   354→\t\t\tentries = append(entries, stepEntry{\n   355→\t\t\t\tIndex:     len(entries),\n   356→\t\t\t\tStepName:  c.StepName,\n   357→\t\t\t\tStartedAt: c.StartedAt,\n   358→\t\t\t})\n   359→\t\t\tdelete(pending, c.StepName)\n   360→\t\t}\n   361→\t}\n   362→\n   363→\treturn entries\n   364→}\n   365→\n   366→// containerState inspects the container for a run and returns one of:\n   367→//   - \"running\"   – container exists and is running\n   368→//   - \"stopped\"   – container exists, not running, not kept\n   369→//   - \"available\" – container exists, not running, kept (can be deleted)\n   370→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   371→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   372→\tif run.ContainerID == \"\" {\n   373→\t\treturn \"removed\"\n   374→\t}\n   375→\tmgr, ok := h.container.(ContainerManager)\n   376→\tif !ok {\n   377→\t\treturn \"removed\"\n   378→\t}\n   379→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   380→\tif err != nil {\n   381→\t\treturn \"removed\"\n   382→\t}\n   383→\tif status.Running {\n   384→\t\treturn \"running\"\n   385→\t}\n   386→\tif run.ContainerKept {\n   387→\t\treturn \"available\"\n   388→\t}\n   389→\treturn \"stopped\"\n   390→}\n   391→\n   392→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   393→\tid := r.PathValue(\"id\")\n   394→\n   395→\trun, err := h.store.GetRun(r.Context(), id)\n   396→\tif err != nil {\n   397→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   398→\t\treturn\n   399→\t}\n   400→\n   401→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   402→\tif err != nil {\n   403→\t\tcaps = nil // non-fatal\n   404→\t}\n   405→\n   406→\tsteps := mergeCaptures(caps)\n   407→\n   408→\tdata := map[string]any{\n   409→\t\t\"Title\":          \"Run \" + run.ID,\n   410→\t\t\"Run\":            run,\n   411→\t\t\"Steps\":          steps,\n   412→\t\t\"Page\":           \"detail\",\n   413→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   414→\t}\n   415→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   416→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   417→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   418→\t}\n   419→}\n   420→\n   421→// --- JSON API handlers ---\n   422→\n   423→type apiRun struct {\n   424→\tID           string `json:\"id\"`\n   425→\tWorkflowName string `json:\"workflow_name\"`\n   426→\tProjectDir   string `json:\"project_dir\"`\n   427→\tProjectLabel string `json:\"project_label\"`\n   428→\tState        string `json:\"state\"`\n   429→\tStartedAt    string `json:\"started_at\"`\n   430→\tCompletedAt  string `json:\"completed_at\"`\n   431→\tContainerID  string `json:\"container_id\"`\n   432→\tErrorMessage string `json:\"error_message\"`\n   433→}\n   434→\n   435→type apiStep struct {\n   436→\tStepName    string `json:\"step_name\"`\n   437→\tResult      string `json:\"result\"`\n   438→\tStartedAt   string `json:\"started_at\"`\n   439→\tCompletedAt string `json:\"completed_at\"`\n   440→\tDuration    string `json:\"duration\"`\n   441→}\n   442→\n   443→type apiRunDetail struct {\n   444→\tapiRun\n   445→\tContainerState string    `json:\"container_state\"`\n   446→\tSteps          []apiStep `json:\"steps\"`\n   447→}\n   448→\n   449→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   450→\treturn apiRun{\n   451→\t\tID:           r.ID,\n   452→\t\tWorkflowName: r.WorkflowName,\n   453→\t\tProjectDir:   r.ProjectDir,\n   454→\t\tProjectLabel: labels[r.ProjectDir],\n   455→\t\tState:        string(r.State),\n   456→\t\tStartedAt:    formatTime(r.StartedAt),\n   457→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   458→\t\tContainerID:  r.ContainerID,\n   459→\t\tErrorMessage: r.ErrorMessage,\n   460→\t}\n   461→}\n   462→\n   463→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   464→\tprojectFilter := r.URL.Query().Get(\"project\")\n   465→\n   466→\tvar runs []*domain.Run\n   467→\tvar err error\n   468→\tif projectFilter != \"\" {\n   469→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   470→\t} else {\n   471→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   472→\t}\n   473→\tif err != nil {\n   474→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   475→\t\treturn\n   476→\t}\n   477→\n   478→\tprojects, _ := h.store.ListProjects(r.Context())\n   479→\tlabels := projectLabels(projects)\n   480→\n   481→\tresult := make([]apiRun, len(runs))\n   482→\tfor i, run := range runs {\n   483→\t\tresult[i] = toAPIRun(run, labels)\n   484→\t}\n   485→\n   486→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   487→\tjson.NewEncoder(w).Encode(result)\n   488→}\n   489→\n   490→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   491→\tprojects, err := h.store.ListProjects(r.Context())\n   492→\tif err != nil {\n   493→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   494→\t\treturn\n   495→\t}\n   496→\tlabels := projectLabels(projects)\n   497→\n   498→\ttype apiHealth struct {\n   499→\t\tStatus string `json:\"status\"`\n   500→\t\tPassed int    `json:\"passed\"`\n   501→\t\tFailed int    `json:\"failed\"`\n   502→\t\tTotal  int    `json:\"total\"`\n   503→\t}\n   504→\ttype apiProject struct {\n   505→\t\tDir         string    `json:\"dir\"`\n   506→\t\tLabel       string    `json:\"label\"`\n   507→\t\tHealth      apiHealth `json:\"health\"`\n   508→\t\tActiveCount int       `json:\"active_count\"`\n   509→\t}\n   510→\tresult := make([]apiProject, len(projects))\n   511→\tfor i, dir := range projects {\n   512→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   513→\t\trunValues := make([]domain.Run, len(runs))\n   514→\t\tfor j, rr := range runs {\n   515→\t\t\trunValues[j] = *rr\n   516→\t\t}\n   517→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   518→\t\tvar activeCount int\n   519→\t\tfor _, rr := range runs {\n   520→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   521→\t\t\t\tactiveCount++\n   522→\t\t\t}\n   523→\t\t}\n   524→\t\tresult[i] = apiProject{\n   525→\t\t\tDir:   dir,\n   526→\t\t\tLabel: labels[dir],\n   527→\t\t\tHealth: apiHealth{\n   528→\t\t\t\tStatus: string(health.Status),\n   529→\t\t\t\tPassed: health.Passed,\n   530→\t\t\t\tFailed: health.Failed,\n   531→\t\t\t\tTotal:  health.Total,\n   532→\t\t\t},\n   533→\t\t\tActiveCount: activeCount,\n   534→\t\t}\n   535→\t}\n   536→\n   537→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   538→\tjson.NewEncoder(w).Encode(result)\n   539→}\n   540→\n   541→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   542→\tid := r.PathValue(\"id\")\n   543→\n   544→\trun, err := h.store.GetRun(r.Context(), id)\n   545→\tif err != nil {\n   546→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   547→\t\treturn\n   548→\t}\n   549→\n   550→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   551→\tif err != nil {\n   552→\t\tcaps = nil\n   553→\t}\n   554→\n   555→\tprojects, _ := h.store.ListProjects(r.Context())\n   556→\tlabels := projectLabels(projects)\n   557→\n   558→\tmerged := mergeCaptures(caps)\n   559→\tsteps := make([]apiStep, len(merged))\n   560→\tfor i, e := range merged {\n   561→\t\tsteps[i] = apiStep{\n   562→\t\t\tStepName:  e.StepName,\n   563→\t\t\tResult:    e.Result,\n   564→\t\t\tStartedAt: formatTime(e.StartedAt),\n   565→\t\t\tDuration:  e.Duration,\n   566→\t\t}\n   567→\t}\n   568→\n   569→\tdetail := apiRunDetail{\n   570→\t\tapiRun:         toAPIRun(run, labels),\n   571→\t\tContainerState: h.containerState(r.Context(), run),\n   572→\t\tSteps:          steps,\n   573→\t}\n   574→\n   575→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   576→\tjson.NewEncoder(w).Encode(detail)\n   577→}\n   578→\n   579→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   580→\tid := r.PathValue(\"id\")\n   581→\tstep := r.PathValue(\"step\")\n   582→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   583→\n   584→\trun, err := h.store.GetRun(r.Context(), id)\n   585→\tif err != nil {\n   586→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   587→\t\treturn\n   588→\t}\n   589→\n   590→\t// Try log index first for fast lookup\n   591→\tif h.logStore != nil {\n   592→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   593→\t\tif err == nil && len(logFiles) > 0 {\n   594→\t\t\t// If type filter specified, narrow results\n   595→\t\t\tfor _, lf := range logFiles {\n   596→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   597→\t\t\t\t\tcontinue\n   598→\t\t\t\t}\n   599→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   600→\t\t\t\tif readErr == nil && len(data) > 0 {\n   601→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   602→\t\t\t\t\tw.Write(data)\n   603→\t\t\t\t\treturn\n   604→\t\t\t\t}\n   605→\t\t\t}\n   606→\t\t}\n   607→\t}\n   608→\n   609→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   610→\n   611→\t// Fall back to file path conventions\n   612→\t// If type is \"llm\", try llm-<step>.log\n   613→\tif logType == \"llm\" {\n   614→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   615→\t\tdata, err := os.ReadFile(llmPath)\n   616→\t\tif err == nil && len(data) > 0 {\n   617→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   618→\t\t\tw.Write(data)\n   619→\t\t\treturn\n   620→\t\t}\n   621→\t}\n   622→\n   623→\t// Try per-step output first, fall back to container.log, then live docker logs\n   624→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   625→\tdata, err := os.ReadFile(outputPath)\n   626→\tif err == nil && len(data) > 0 {\n   627→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   628→\t\tw.Write(data)\n   629→\t\treturn\n   630→\t}\n   631→\n   632→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   633→\tdata, err = os.ReadFile(containerLog)\n   634→\tif err == nil && len(data) > 0 {\n   635→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   636→\t\tw.Write(data)\n   637→\t\treturn\n   638→\t}\n   639→\n   640→\t// Last resort: try live docker logs from still-existing container\n   641→\tif h.container != nil && run.ContainerID != \"\" {\n   642→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   643→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   644→\t\t\tw.Write([]byte(logs))\n   645→\t\t\treturn\n   646→\t\t}\n   647→\t}\n   648→\n   649→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   650→}\n   651→\n   652→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   653→\tid := r.PathValue(\"id\")\n   654→\n   655→\trun, err := h.store.GetRun(r.Context(), id)\n   656→\tif err != nil {\n   657→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   658→\t\tw.WriteHeader(http.StatusNotFound)\n   659→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   660→\t\treturn\n   661→\t}\n   662→\n   663→\tmgr, ok := h.container.(ContainerManager)\n   664→\tif !ok || run.ContainerID == \"\" {\n   665→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   666→\t\tw.WriteHeader(http.StatusBadRequest)\n   667→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   668→\t\treturn\n   669→\t}\n   670→\n   671→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   672→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   673→\t\tw.WriteHeader(http.StatusInternalServerError)\n   674→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   675→\t\treturn\n   676→\t}\n   677→\n   678→\trun.ContainerKept = false\n   679→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   680→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   681→\t\tw.WriteHeader(http.StatusInternalServerError)\n   682→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   683→\t\treturn\n   684→\t}\n   685→\n   686→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   687→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   688→}\n   689→\n   690→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   691→\tlabel := r.PathValue(\"name\")\n   692→\n   693→\t// Resolve label back to project directory via the store.\n   694→\tprojects, _ := h.store.ListProjects(r.Context())\n   695→\tlabels := projectLabels(projects)\n   696→\tvar projectDir string\n   697→\tfor dir, l := range labels {\n   698→\t\tif l == label {\n   699→\t\t\tprojectDir = dir\n   700→\t\t\tbreak\n   701→\t\t}\n   702→\t}\n   703→\tif projectDir == \"\" {\n   704→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   705→\t\tw.WriteHeader(http.StatusNotFound)\n   706→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   707→\t\treturn\n   708→\t}\n   709→\n   710→\tif h.orchestrateFn == nil {\n   711→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   712→\t\tw.WriteHeader(http.StatusNotImplemented)\n   713→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   714→\t\treturn\n   715→\t}\n   716→\n   717→\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   718→\tif err != nil {\n   719→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   720→\t\tw.WriteHeader(http.StatusInternalServerError)\n   721→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   722→\t\treturn\n   723→\t}\n   724→\n   725→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   726→\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   727→}\n   728→\n   729→// handleAPIStream serves an SSE stream of log lines for a run.\n   730→// For active runs, it subscribes to the live broadcaster.\n   731→// For completed runs, it serves the archived full.log then closes.\n   732→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   733→\tid := r.PathValue(\"id\")\n   734→\n   735→\trun, err := h.store.GetRun(r.Context(), id)\n   736→\tif err != nil {\n   737→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   738→\t\treturn\n   739→\t}\n   740→\n   741→\tflusher, ok := w.(http.Flusher)\n   742→\tif !ok {\n   743→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   744→\t\treturn\n   745→\t}\n   746→\n   747→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   748→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   749→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   750→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   751→\n   752→\tisComplete := run.State == domain.RunStateSucceeded ||\n   753→\t\trun.State == domain.RunStateFailed ||\n   754→\t\trun.State == domain.RunStateCancelled\n   755→\n   756→\tif isComplete {\n   757→\t\t// Serve archived full.log\n   758→\t\th.streamFullLog(w, flusher, run)\n   759→\t\t// Send done event\n   760→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   761→\t\tflusher.Flush()\n   762→\t\treturn\n   763→\t}\n   764→\n   765→\t// Active run: subscribe to live broadcaster\n   766→\tif h.logBroadcast == nil {\n   767→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   768→\t\treturn\n   769→\t}\n   770→\n   771→\tsub := h.logBroadcast.Subscribe(id)\n   772→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   773→\n   774→\tctx := r.Context()\n   775→\tfor {\n   776→\t\tselect {\n   777→\t\tcase <-ctx.Done():\n   778→\t\t\treturn\n   779→\t\tcase line, ok := <-sub.C:\n   780→\t\t\tif !ok {\n   781→\t\t\t\t// Stream finished (run completed)\n   782→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   783→\t\t\t\tflusher.Flush()\n   784→\t\t\t\treturn\n   785→\t\t\t}\n   786→\t\t\tdata, _ := json.Marshal(line)\n   787→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   788→\t\t\tflusher.Flush()\n   789→\t\t}\n   790→\t}\n   791→}\n   792→\n   793→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   794→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   795→\n   796→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   797→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   798→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   799→\tf, err := os.Open(logPath)\n   800→\tif err != nil {\n   801→\t\treturn\n   802→\t}\n   803→\tdefer f.Close()\n   804→\n   805→\tscanner := bufio.NewScanner(f)\n   806→\tfor scanner.Scan() {\n   807→\t\ttext := scanner.Text()\n   808→\t\tline := parseFullLogLine(text)\n   809→\t\tdata, _ := json.Marshal(line)\n   810→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   811→\t\tflusher.Flush()\n   812→\t}\n   813→}\n   814→\n   815→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   816→func parseFullLogLine(text string) logstream.LogLine {\n   817→\tm := logLineRegex.FindStringSubmatch(text)\n   818→\tif m == nil {\n   819→\t\treturn logstream.LogLine{\n   820→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   821→\t\t\tType:      \"script\",\n   822→\t\t\tContent:   text,\n   823→\t\t}\n   824→\t}\n   825→\treturn logstream.LogLine{\n   826→\t\tTimestamp: m[1],\n   827→\t\tType:      m[2],\n   828→\t\tContent:   m[3],\n   829→\t}\n   830→}\n   831→\n   832→// --- Project detail handlers ---\n   833→\n   834→// resolveProjectDir resolves a project label from the URL to its directory path.\n   835→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   836→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   837→\tlabel := r.PathValue(\"name\")\n   838→\tprojects, _ := h.store.ListProjects(r.Context())\n   839→\tlabels := projectLabels(projects)\n   840→\tfor dir, l := range labels {\n   841→\t\tif l == label {\n   842→\t\t\treturn dir, label, true\n   843→\t\t}\n   844→\t}\n   845→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   846→\tw.WriteHeader(http.StatusNotFound)\n   847→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   848→\treturn \"\", \"\", false\n   849→}\n   850→\n   851→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   852→\tdir, label, ok := h.resolveProjectDir(w, r)\n   853→\tif !ok {\n   854→\t\treturn\n   855→\t}\n   856→\n   857→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   858→\tn := 10\n   859→\tif n > len(runs) {\n   860→\t\tn = len(runs)\n   861→\t}\n   862→\tdots := make([]recentRunDot, n)\n   863→\tfor i := 0; i < n; i++ {\n   864→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   865→\t}\n   866→\n   867→\tdata := map[string]any{\n   868→\t\t\"Title\":      label,\n   869→\t\t\"Label\":      label,\n   870→\t\t\"Dir\":        dir,\n   871→\t\t\"RecentRuns\": dots,\n   872→\t}\n   873→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   874→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   875→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   876→\t}\n   877→}\n   878→\n   879→func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   880→\tdir, _, ok := h.resolveProjectDir(w, r)\n   881→\tif !ok {\n   882→\t\treturn\n   883→\t}\n   884→\tif h.orchestrator == nil {\n   885→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   886→\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   887→\t\treturn\n   888→\t}\n   889→\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   890→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   891→\tjson.NewEncoder(w).Encode(map[string]any{\n   892→\t\t\"enabled\":     enabled,\n   893→\t\t\"in_flight\":   inFlight,\n   894→\t\t\"concurrency\": concurrency,\n   895→\t})\n   896→}\n   897→\n   898→func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   899→\tdir, _, ok := h.resolveProjectDir(w, r)\n   900→\tif !ok {\n   901→\t\treturn\n   902→\t}\n   903→\tif h.orchestrator == nil {\n   904→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   905→\t\tw.WriteHeader(http.StatusNotImplemented)\n   906→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   907→\t\treturn\n   908→\t}\n   909→\th.orchestrator.SetEnabled(dir, true)\n   910→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   911→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   912→}\n   913→\n   914→func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   915→\tdir, _, ok := h.resolveProjectDir(w, r)\n   916→\tif !ok {\n   917→\t\treturn\n   918→\t}\n   919→\tif h.orchestrator == nil {\n   920→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   921→\t\tw.WriteHeader(http.StatusNotImplemented)\n   922→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   923→\t\treturn\n   924→\t}\n   925→\th.orchestrator.SetEnabled(dir, false)\n   926→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   927→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   928→}\n   929→\n   930→func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   931→\tdir, _, ok := h.resolveProjectDir(w, r)\n   932→\tif !ok {\n   933→\t\treturn\n   934→\t}\n   935→\tif h.orchestrator == nil {\n   936→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   937→\t\tw.WriteHeader(http.StatusNotImplemented)\n   938→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   939→\t\treturn\n   940→\t}\n   941→\tvar body struct {\n   942→\t\tConcurrency int `json:\"concurrency\"`\n   943→\t}\n   944→\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n   945→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   946→\t\tw.WriteHeader(http.StatusBadRequest)\n   947→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n   948→\t\treturn\n   949→\t}\n   950→\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n   951→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   952→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   953→}\n   954→\n   955→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   956→\tdir, _, ok := h.resolveProjectDir(w, r)\n   957→\tif !ok {\n   958→\t\treturn\n   959→\t}\n   960→\n   961→\t// Docker image: read FROM line from Dockerfile\n   962→\tdockerImage := \"\"\n   963→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   964→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   965→\t\t// Find the last FROM line (final stage)\n   966→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   967→\t\t\ttrimmed := strings.TrimSpace(line)\n   968→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   969→\t\t\t\tparts := strings.Fields(trimmed)\n   970→\t\t\t\tif len(parts) >= 2 {\n   971→\t\t\t\t\tdockerImage = parts[1]\n   972→\t\t\t\t}\n   973→\t\t\t}\n   974→\t\t}\n   975→\t}\n   976→\n   977→\t// Version\n   978→\tversion := 0\n   979→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   980→\tif data, err := os.ReadFile(versionPath); err == nil {\n   981→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   982→\t\t\tversion = v\n   983→\t\t}\n   984→\t}\n   985→\n   986→\t// Prompt files history\n   987→\ttype commitEntry struct {\n   988→\t\tSHA     string `json:\"sha\"`\n   989→\t\tDate    string `json:\"date\"`\n   990→\t\tMessage string `json:\"message\"`\n   991→\t}\n   992→\ttype promptFile struct {\n   993→\t\tPath    string        `json:\"path\"`\n   994→\t\tHistory []commitEntry `json:\"history\"`\n   995→\t}\n   996→\n   997→\tvar promptFiles []promptFile\n   998→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   999→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n  1000→\t\tfor _, e := range entries {\n  1001→\t\t\tif e.IsDir() {\n  1002→\t\t\t\tcontinue\n  1003→\t\t\t}\n  1004→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n  1005→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n  1006→\t\t\tcmd.Dir = dir\n  1007→\t\t\tout, err := cmd.Output()\n  1008→\t\t\tif err != nil {\n  1009→\t\t\t\tcontinue\n  1010→\t\t\t}\n  1011→\t\t\tvar history []commitEntry\n  1012→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n  1013→\t\t\t\tif line == \"\" {\n  1014→\t\t\t\t\tcontinue\n  1015→\t\t\t\t}\n  1016→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1017→\t\t\t\tif len(parts) < 3 {\n  1018→\t\t\t\t\tcontinue\n  1019→\t\t\t\t}\n  1020→\t\t\t\t// Parse date to short form\n  1021→\t\t\t\tdateStr := parts[1]\n  1022→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1023→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1024→\t\t\t\t}\n  1025→\t\t\t\thistory = append(history, commitEntry{\n  1026→\t\t\t\t\tSHA:     parts[0][:7],\n  1027→\t\t\t\t\tDate:    dateStr,\n  1028→\t\t\t\t\tMessage: parts[2],\n  1029→\t\t\t\t})\n  1030→\t\t\t}\n  1031→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1032→\t\t}\n  1033→\t}\n  1034→\n  1035→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1036→\tjson.NewEncoder(w).Encode(map[string]any{\n  1037→\t\t\"docker_image\": dockerImage,\n  1038→\t\t\"version\":      version,\n  1039→\t\t\"prompt_files\": promptFiles,\n  1040→\t})\n  1041→}\n  1042→\n  1043→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1044→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1045→\tif !ok {\n  1046→\t\treturn\n  1047→\t}\n  1048→\tfile := r.URL.Query().Get(\"file\")\n  1049→\tsha := r.URL.Query().Get(\"sha\")\n  1050→\tif file == \"\" || sha == \"\" {\n  1051→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1052→\t\treturn\n  1053→\t}\n  1054→\n  1055→\t// Validate sha is alphanumeric to prevent injection\n  1056→\tfor _, c := range sha {\n  1057→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1058→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1059→\t\t\treturn\n  1060→\t\t}\n  1061→\t}\n  1062→\n  1063→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1064→\tcmd.Dir = dir\n  1065→\tout, err := cmd.Output()\n  1066→\tif err != nil {\n  1067→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1068→\t\treturn\n  1069→\t}\n  1070→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1071→\tw.Write(out)\n  1072→}\n  1073→\n  1074→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1075→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1076→\tif !ok {\n  1077→\t\treturn\n  1078→\t}\n  1079→\n  1080→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1081→\tentries, err := os.ReadDir(clocheDir)\n  1082→\tif err != nil {\n  1083→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1084→\t\tjson.NewEncoder(w).Encode([]any{})\n  1085→\t\treturn\n  1086→\t}\n  1087→\n  1088→\ttype apiWire struct {\n  1089→\t\tFrom   string `json:\"from\"`\n  1090→\t\tResult string `json:\"result\"`\n  1091→\t\tTo     string `json:\"to\"`\n  1092→\t}\n  1093→\ttype apiStepDef struct {\n  1094→\t\tName    string            `json:\"name\"`\n  1095→\t\tType    string            `json:\"type\"`\n  1096→\t\tResults []string          `json:\"results\"`\n  1097→\t\tConfig  map[string]string `json:\"config\"`\n  1098→\t}\n  1099→\ttype apiWorkflow struct {\n  1100→\t\tName      string       `json:\"name\"`\n  1101→\t\tFile      string       `json:\"file\"`\n  1102→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1103→\t\tWires     []apiWire    `json:\"wires\"`\n  1104→\t\tEntryStep string       `json:\"entry_step\"`\n  1105→\t}\n  1106→\n  1107→\tvar workflows []apiWorkflow\n  1108→\tfor _, e := range entries {\n  1109→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1110→\t\t\tcontinue\n  1111→\t\t}\n  1112→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1113→\t\tif err != nil {\n  1114→\t\t\tcontinue\n  1115→\t\t}\n  1116→\t\twf, err := dsl.Parse(string(data))\n  1117→\t\tif err != nil {\n  1118→\t\t\tcontinue\n  1119→\t\t}\n  1120→\t\tvar steps []apiStepDef\n  1121→\t\tfor _, s := range wf.Steps {\n  1122→\t\t\tsteps = append(steps, apiStepDef{\n  1123→\t\t\t\tName:    s.Name,\n  1124→\t\t\t\tType:    string(s.Type),\n  1125→\t\t\t\tResults: s.Results,\n  1126→\t\t\t\tConfig:  s.Config,\n  1127→\t\t\t})\n  1128→\t\t}\n  1129→\t\t// Sort steps by name for consistent ordering\n  1130→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1131→\n  1132→\t\tvar wires []apiWire\n  1133→\t\tfor _, wire := range wf.Wiring {\n  1134→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1135→\t\t}\n  1136→\n  1137→\t\tworkflows = append(workflows, apiWorkflow{\n  1138→\t\t\tName:      wf.Name,\n  1139→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1140→\t\t\tSteps:     steps,\n  1141→\t\t\tWires:     wires,\n  1142→\t\t\tEntryStep: wf.EntryStep,\n  1143→\t\t})\n  1144→\t}\n  1145→\n  1146→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1147→\tjson.NewEncoder(w).Encode(workflows)\n  1148→}\n  1149→\n  1150→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1151→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1152→\tif !ok {\n  1153→\t\treturn\n  1154→\t}\n  1155→\tworkflowName := r.PathValue(\"workflow\")\n  1156→\tstepName := r.PathValue(\"step\")\n  1157→\n  1158→\t// Find the workflow file\n  1159→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1160→\tvar wf *domain.Workflow\n  1161→\tentries, _ := os.ReadDir(clocheDir)\n  1162→\tfor _, e := range entries {\n  1163→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1164→\t\t\tcontinue\n  1165→\t\t}\n  1166→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1167→\t\tif err != nil {\n  1168→\t\t\tcontinue\n  1169→\t\t}\n  1170→\t\tparsed, err := dsl.Parse(string(data))\n  1171→\t\tif err != nil {\n  1172→\t\t\tcontinue\n  1173→\t\t}\n  1174→\t\tif parsed.Name == workflowName {\n  1175→\t\t\twf = parsed\n  1176→\t\t\tbreak\n  1177→\t\t}\n  1178→\t}\n  1179→\tif wf == nil {\n  1180→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1181→\t\treturn\n  1182→\t}\n  1183→\n  1184→\tstep, ok := wf.Steps[stepName]\n  1185→\tif !ok {\n  1186→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1187→\t\treturn\n  1188→\t}\n  1189→\n  1190→\t// Try to read the referenced file from step config\n  1191→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1192→\n  1193→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1194→\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1195→\t\tif err == nil {\n  1196→\t\t\tw.Write(data)\n  1197→\t\t\treturn\n  1198→\t\t}\n  1199→\t}\n  1200→\tif script := step.Config[\"command\"]; script != \"\" {\n  1201→\t\tw.Write([]byte(script))\n  1202→\t\treturn\n  1203→\t}\n  1204→\tif script := step.Config[\"script\"]; script != \"\" {\n  1205→\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1206→\t\tif err == nil {\n  1207→\t\t\tw.Write(data)\n  1208→\t\t\treturn\n  1209→\t\t}\n  1210→\t\tw.Write([]byte(script))\n  1211→\t\treturn\n  1212→\t}\n  1213→\n  1214→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1215→}\n  1216→\n  1217→// --- Template helpers ---\n  1218→\n  1219→func stateColor(state domain.RunState) string {\n  1220→\tswitch state {\n  1221→\tcase domain.RunStatePending:\n  1222→\t\treturn \"pending\"\n  1223→\tcase domain.RunStateRunning:\n  1224→\t\treturn \"running\"\n  1225→\tcase domain.RunStateSucceeded:\n  1226→\t\treturn \"succeeded\"\n  1227→\tcase domain.RunStateFailed:\n  1228→\t\treturn \"failed\"\n  1229→\tcase domain.RunStateCancelled:\n  1230→\t\treturn \"cancelled\"\n  1231→\tdefault:\n  1232→\t\treturn \"pending\"\n  1233→\t}\n  1234→}\n  1235→\n  1236→func healthColor(status domain.HealthStatus) string {\n  1237→\tswitch status {\n  1238→\tcase domain.HealthGreen:\n  1239→\t\treturn \"green\"\n  1240→\tcase domain.HealthYellow:\n  1241→\t\treturn \"yellow\"\n  1242→\tcase domain.HealthRed:\n  1243→\t\treturn \"red\"\n  1244→\tcase domain.HealthBlue:\n  1245→\t\treturn \"blue\"\n  1246→\tdefault:\n  1247→\t\treturn \"grey\"\n  1248→\t}\n  1249→}\n  1250→\n  1251→func formatTime(t time.Time) string {\n  1252→\tif t.IsZero() {\n  1253→\t\treturn \"\"\n  1254→\t}\n  1255→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1256→}\n  1257→\n  1258→func formatDuration(start, end time.Time) string {\n  1259→\tif start.IsZero() || end.IsZero() {\n  1260→\t\treturn \"\"\n  1261→\t}\n  1262→\td := end.Sub(start)\n  1263→\tif d < time.Second {\n  1264→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1265→\t}\n  1266→\tif d < time.Minute {\n  1267→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1268→\t}\n  1269→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1270→}\n  1271→\n  1272→func truncate(s string, n int) string {\n  1273→\tif len(s) <= n {\n  1274→\t\treturn s\n  1275→\t}\n  1276→\treturn s[:n] + \"...\"\n  1277→}\n  1278→\n  1279→func shortContainerID(id string) string {\n  1280→\tif len(id) > 12 {\n  1281→\t\treturn id[:12]\n  1282→\t}\n  1283→\treturn id\n  1284→}\n  1285→\n  1286→// projectLabels builds a mapping from full project directory paths to short\n  1287→// display labels. Each label is the final directory component (e.g.\n  1288→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1289→// the same final name, the parent directory is prepended to disambiguate\n  1290→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1291→func projectLabels(dirs []string) map[string]string {\n  1292→\tlabels := make(map[string]string, len(dirs))\n  1293→\t// Group dirs by their base name to detect conflicts.\n  1294→\tbyBase := map[string][]string{}\n  1295→\tfor _, d := range dirs {\n  1296→\t\tbase := filepath.Base(d)\n  1297→\t\tbyBase[base] = append(byBase[base], d)\n  1298→\t}\n  1299→\tfor base, paths := range byBase {\n  1300→\t\tif len(paths) == 1 {\n  1301→\t\t\tlabels[paths[0]] = base\n  1302→\t\t} else {\n  1303→\t\t\tfor _, p := range paths {\n  1304→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1305→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1306→\t\t\t}\n  1307→\t\t}\n  1308→\t}\n  1309→\treturn labels\n  1310→}\n  1311→\n  1312→type projectEntry struct {\n  1313→\tDir            string\n  1314→\tLabel          string\n  1315→\tContainerCount int\n  1316→}\n  1317→"}]},"parent_tool_use_id":null,"session_id":"e2a5f3fc-175a-4dd5-9109-6450dc6ac12c","uuid":"098eb7cd-76eb-42c6-8e7e-55474af9f5fd","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\nfunc WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n\treturn func(h *Handler) { h.orchestrateFn = fn }\n}\n\n// OrchestratorController provides per-project orchestrator control.\ntype OrchestratorController interface {\n\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n\tSetEnabled(dir string, enabled bool)\n\tSetConcurrency(dir string, concurrency int)\n}\n\n// WithOrchestrator sets the orchestrator controller for project-level control.\nfunc WithOrchestrator(oc OrchestratorController) HandlerOption {\n\treturn func(h *Handler) { h.orchestrator = oc }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore         ports.RunStore\n\tcaptures      ports.CaptureStore\n\tlogStore      ports.LogStore\n\tcontainer     ContainerLogger\n\tlogBroadcast  *logstream.Broadcaster\n\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n\torchestrator  OrchestratorController\n\tpages         map[string]*template.Template\n\tmux           *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\th.renderRunsList(w, r, r.URL.Query().Get(\"project\"), \"\")\n}\n\nfunc (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\th.renderRunsList(w, r, dir, label)\n\t\t\treturn\n\t\t}\n\t}\n\thttp.Error(w, \"project not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) renderRunsList(w http.ResponseWriter, r *http.Request, projectFilter, projectLabel string) {\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\n\t// Resolve label back to project directory via the store.\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tvar projectDir string\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\tprojectDir = dir\n\t\t\tbreak\n\t\t}\n\t}\n\tif projectDir == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\t\treturn\n\t}\n\n\tif h.orchestrateFn == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\n\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n\t\treturn\n\t}\n\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"enabled\":     enabled,\n\t\t\"in_flight\":   inFlight,\n\t\t\"concurrency\": concurrency,\n\t})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, true)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, false)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\tvar body struct {\n\t\tConcurrency int `json:\"concurrency\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n\t\treturn\n\t}\n\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\tif script := step.Config[\"command\"]; script != \"\" {\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1317,"startLine":1,"totalLines":1317}}}
