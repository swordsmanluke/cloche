}}\n{{end}}\n\n{{define \"scripts\"}}\n{{end}}\n","structuredPatch":[{"oldStart":24,"oldLines":7,"newStart":24,"newLines":7,"lines":["             {{end}}","         </div>","         <div class=\"project-actions\">","-            <a href=\"/runs?project={{.Dir}}\" class=\"btn btn-secondary\">View Runs</a>","+            <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary\">View Runs</a>","         </div>","     </div>","     {{end}}"]}],"userModified":false,"replaceAll":false}}
