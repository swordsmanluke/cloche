{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H2z2wEXidRcxbrQKHj54GF","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"os/exec\"\n    14→\t\"path/filepath\"\n    15→\t\"regexp\"\n    16→\t\"sort\"\n    17→\t\"strconv\"\n    18→\t\"strings\"\n    19→\t\"time\"\n    20→\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→)\n    26→\n    27→// HandlerOption configures optional Handler dependencies.\n    28→type HandlerOption func(*Handler)\n    29→\n    30→// WithContainerLogger sets the container runtime for fetching live logs.\n    31→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32→\treturn func(h *Handler) { h.container = c }\n    33→}\n    34→\n    35→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36→func WithContainerManager(c ContainerManager) HandlerOption {\n    37→\treturn func(h *Handler) { h.container = c }\n    38→}\n    39→\n    40→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42→\treturn func(h *Handler) { h.logBroadcast = b }\n    43→}\n    44→\n    45→// WithLogStore sets the log store for indexed log file lookups.\n    46→func WithLogStore(ls ports.LogStore) HandlerOption {\n    47→\treturn func(h *Handler) { h.logStore = ls }\n    48→}\n    49→\n    50→//go:embed templates/*.html static/*\n    51→var content embed.FS\n    52→\n    53→// Handler serves the web dashboard.\n    54→// ContainerLogger can retrieve logs from a container by ID.\n    55→type ContainerLogger interface {\n    56→\tLogs(ctx context.Context, containerID string) (string, error)\n    57→}\n    58→\n    59→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    60→type ContainerManager interface {\n    61→\tContainerLogger\n    62→\tRemove(ctx context.Context, containerID string) error\n    63→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    64→}\n    65→\n    66→type Handler struct {\n    67→\tstore        ports.RunStore\n    68→\tcaptures     ports.CaptureStore\n    69→\tlogStore     ports.LogStore\n    70→\tcontainer    ContainerLogger\n    71→\tlogBroadcast *logstream.Broadcaster\n    72→\tpages        map[string]*template.Template\n    73→\tmux          *http.ServeMux\n    74→}\n    75→\n    76→// NewHandler creates a web dashboard handler.\n    77→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    78→\tfuncMap := template.FuncMap{\n    79→\t\t\"stateColor\":       stateColor,\n    80→\t\t\"healthColor\":      healthColor,\n    81→\t\t\"formatTime\":       formatTime,\n    82→\t\t\"formatDuration\":   formatDuration,\n    83→\t\t\"truncate\":         truncate,\n    84→\t\t\"shortContainerID\": shortContainerID,\n    85→\t}\n    86→\n    87→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n    88→\tif err != nil {\n    89→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n    90→\t}\n    91→\n    92→\tpages := map[string]*template.Template{}\n    93→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n    94→\t\tclone, err := base.Clone()\n    95→\t\tif err != nil {\n    96→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n    97→\t\t}\n    98→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n    99→\t\tif err != nil {\n   100→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   101→\t\t}\n   102→\t\tpages[page] = clone\n   103→\t}\n   104→\n   105→\th := &Handler{\n   106→\t\tstore:    store,\n   107→\t\tcaptures: captures,\n   108→\t\tpages:    pages,\n   109→\t\tmux:      http.NewServeMux(),\n   110→\t}\n   111→\tfor _, opt := range opts {\n   112→\t\topt(h)\n   113→\t}\n   114→\n   115→\tstaticFS, err := fs.Sub(content, \"static\")\n   116→\tif err != nil {\n   117→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   118→\t}\n   119→\n   120→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   121→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   122→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   123→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   124→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   125→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   126→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   127→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   128→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   129→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   130→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   131→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   132→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   133→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   134→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   135→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   136→\n   137→\treturn h, nil\n   138→}\n   139→\n   140→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   141→\th.mux.ServeHTTP(w, r)\n   142→}\n   143→\n   144→// --- HTML handlers ---\n   145→\n   146→// projectOverviewEntry holds data for a single project card on the landing page.\n   147→type projectOverviewEntry struct {\n   148→\tDir         string\n   149→\tLabel       string\n   150→\tHealth      domain.HealthResult\n   151→\tRecentRuns  []recentRunDot\n   152→\tActiveCount int\n   153→}\n   154→\n   155→// recentRunDot is a minimal representation of a run for the mini history display.\n   156→type recentRunDot struct {\n   157→\tID    string\n   158→\tState string\n   159→}\n   160→\n   161→const healthWindowSize = 10\n   162→\n   163→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   164→\tprojects, _ := h.store.ListProjects(r.Context())\n   165→\tlabels := projectLabels(projects)\n   166→\n   167→\tvar entries []projectOverviewEntry\n   168→\tfor _, dir := range projects {\n   169→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   170→\t\tif err != nil {\n   171→\t\t\tcontinue\n   172→\t\t}\n   173→\n   174→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   175→\t\trunValues := make([]domain.Run, len(runs))\n   176→\t\tfor i, rr := range runs {\n   177→\t\t\trunValues[i] = *rr\n   178→\t\t}\n   179→\n   180→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   181→\n   182→\t\t// Take the last N runs for the mini history (most recent first).\n   183→\t\tn := healthWindowSize\n   184→\t\tif n > len(runs) {\n   185→\t\t\tn = len(runs)\n   186→\t\t}\n   187→\t\tdots := make([]recentRunDot, n)\n   188→\t\tfor i := 0; i < n; i++ {\n   189→\t\t\tdots[i] = recentRunDot{\n   190→\t\t\t\tID:    runs[i].ID,\n   191→\t\t\t\tState: string(runs[i].State),\n   192→\t\t\t}\n   193→\t\t}\n   194→\n   195→\t\tvar activeCount int\n   196→\t\tfor _, rr := range runs {\n   197→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   198→\t\t\t\tactiveCount++\n   199→\t\t\t}\n   200→\t\t}\n   201→\n   202→\t\tentries = append(entries, projectOverviewEntry{\n   203→\t\t\tDir:         dir,\n   204→\t\t\tLabel:       labels[dir],\n   205→\t\t\tHealth:      health,\n   206→\t\t\tRecentRuns:  dots,\n   207→\t\t\tActiveCount: activeCount,\n   208→\t\t})\n   209→\t}\n   210→\n   211→\tsort.Slice(entries, func(i, j int) bool {\n   212→\t\treturn entries[i].Label < entries[j].Label\n   213→\t})\n   214→\n   215→\tdata := map[string]any{\n   216→\t\t\"Title\":    \"Projects\",\n   217→\t\t\"Projects\": entries,\n   218→\t}\n   219→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   220→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   221→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   222→\t}\n   223→}\n   224→\n   225→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   226→\tprojectFilter := r.URL.Query().Get(\"project\")\n   227→\n   228→\tvar runs []*domain.Run\n   229→\tvar err error\n   230→\tif projectFilter != \"\" {\n   231→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   232→\t} else {\n   233→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   234→\t}\n   235→\tif err != nil {\n   236→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   237→\t\treturn\n   238→\t}\n   239→\n   240→\tprojects, _ := h.store.ListProjects(r.Context())\n   241→\tlabels := projectLabels(projects)\n   242→\n   243→\t// Count retained containers per project\n   244→\tcontainerCounts := map[string]int{}\n   245→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   246→\tfor _, run := range allRuns {\n   247→\t\tif run.ContainerKept {\n   248→\t\t\tcontainerCounts[run.ProjectDir]++\n   249→\t\t}\n   250→\t}\n   251→\n   252→\tvar projectList []projectEntry\n   253→\tfor _, dir := range projects {\n   254→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   255→\t}\n   256→\tsort.Slice(projectList, func(i, j int) bool {\n   257→\t\treturn projectList[i].Label < projectList[j].Label\n   258→\t})\n   259→\n   260→\tdata := map[string]any{\n   261→\t\t\"Title\":         \"Runs\",\n   262→\t\t\"Runs\":          runs,\n   263→\t\t\"Projects\":      projectList,\n   264→\t\t\"ProjectFilter\": projectFilter,\n   265→\t\t\"ProjectLabels\": labels,\n   266→\t}\n   267→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   268→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   269→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   270→\t}\n   271→}\n   272→\n   273→// stepEntry is a merged view of a step execution for the template.\n   274→type stepEntry struct {\n   275→\tIndex     int\n   276→\tStepName  string\n   277→\tResult    string\n   278→\tStartedAt time.Time\n   279→\tDuration  string\n   280→}\n   281→\n   282→// mergeCaptures collapses started/completed capture pairs into single entries.\n   283→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   284→\tvar entries []stepEntry\n   285→\t// Track pending started rows by step name (LIFO for retries)\n   286→\tpending := map[string]*domain.StepExecution{}\n   287→\n   288→\tfor _, c := range caps {\n   289→\t\tif c.Result == \"\" {\n   290→\t\t\t// step_started row\n   291→\t\t\tpending[c.StepName] = c\n   292→\t\t\tcontinue\n   293→\t\t}\n   294→\t\t// step_completed row — merge with pending started if available\n   295→\t\tstartedAt := c.StartedAt\n   296→\t\tif started := pending[c.StepName]; started != nil {\n   297→\t\t\tstartedAt = started.StartedAt\n   298→\t\t\tdelete(pending, c.StepName)\n   299→\t\t}\n   300→\t\tentries = append(entries, stepEntry{\n   301→\t\t\tIndex:     len(entries),\n   302→\t\t\tStepName:  c.StepName,\n   303→\t\t\tResult:    c.Result,\n   304→\t\t\tStartedAt: startedAt,\n   305→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   306→\t\t})\n   307→\t}\n   308→\n   309→\t// Append any started-but-not-completed steps (still running)\n   310→\tfor _, c := range caps {\n   311→\t\tif c.Result == \"\" {\n   312→\t\t\tif _, used := pending[c.StepName]; !used {\n   313→\t\t\t\tcontinue\n   314→\t\t\t}\n   315→\t\t\tentries = append(entries, stepEntry{\n   316→\t\t\t\tIndex:     len(entries),\n   317→\t\t\t\tStepName:  c.StepName,\n   318→\t\t\t\tStartedAt: c.StartedAt,\n   319→\t\t\t})\n   320→\t\t\tdelete(pending, c.StepName)\n   321→\t\t}\n   322→\t}\n   323→\n   324→\treturn entries\n   325→}\n   326→\n   327→// containerState inspects the container for a run and returns one of:\n   328→//   - \"running\"   – container exists and is running\n   329→//   - \"stopped\"   – container exists, not running, not kept\n   330→//   - \"available\" – container exists, not running, kept (can be deleted)\n   331→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   332→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   333→\tif run.ContainerID == \"\" {\n   334→\t\treturn \"removed\"\n   335→\t}\n   336→\tmgr, ok := h.container.(ContainerManager)\n   337→\tif !ok {\n   338→\t\treturn \"removed\"\n   339→\t}\n   340→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   341→\tif err != nil {\n   342→\t\treturn \"removed\"\n   343→\t}\n   344→\tif status.Running {\n   345→\t\treturn \"running\"\n   346→\t}\n   347→\tif run.ContainerKept {\n   348→\t\treturn \"available\"\n   349→\t}\n   350→\treturn \"stopped\"\n   351→}\n   352→\n   353→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   354→\tid := r.PathValue(\"id\")\n   355→\n   356→\trun, err := h.store.GetRun(r.Context(), id)\n   357→\tif err != nil {\n   358→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   359→\t\treturn\n   360→\t}\n   361→\n   362→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   363→\tif err != nil {\n   364→\t\tcaps = nil // non-fatal\n   365→\t}\n   366→\n   367→\tsteps := mergeCaptures(caps)\n   368→\n   369→\tdata := map[string]any{\n   370→\t\t\"Title\":          \"Run \" + run.ID,\n   371→\t\t\"Run\":            run,\n   372→\t\t\"Steps\":          steps,\n   373→\t\t\"Page\":           \"detail\",\n   374→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   375→\t}\n   376→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   377→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   378→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   379→\t}\n   380→}\n   381→\n   382→// --- JSON API handlers ---\n   383→\n   384→type apiRun struct {\n   385→\tID           string `json:\"id\"`\n   386→\tWorkflowName string `json:\"workflow_name\"`\n   387→\tProjectDir   string `json:\"project_dir\"`\n   388→\tProjectLabel string `json:\"project_label\"`\n   389→\tState        string `json:\"state\"`\n   390→\tStartedAt    string `json:\"started_at\"`\n   391→\tCompletedAt  string `json:\"completed_at\"`\n   392→\tContainerID  string `json:\"container_id\"`\n   393→\tErrorMessage string `json:\"error_message\"`\n   394→}\n   395→\n   396→type apiStep struct {\n   397→\tStepName    string `json:\"step_name\"`\n   398→\tResult      string `json:\"result\"`\n   399→\tStartedAt   string `json:\"started_at\"`\n   400→\tCompletedAt string `json:\"completed_at\"`\n   401→\tDuration    string `json:\"duration\"`\n   402→}\n   403→\n   404→type apiRunDetail struct {\n   405→\tapiRun\n   406→\tContainerState string    `json:\"container_state\"`\n   407→\tSteps          []apiStep `json:\"steps\"`\n   408→}\n   409→\n   410→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   411→\treturn apiRun{\n   412→\t\tID:           r.ID,\n   413→\t\tWorkflowName: r.WorkflowName,\n   414→\t\tProjectDir:   r.ProjectDir,\n   415→\t\tProjectLabel: labels[r.ProjectDir],\n   416→\t\tState:        string(r.State),\n   417→\t\tStartedAt:    formatTime(r.StartedAt),\n   418→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   419→\t\tContainerID:  r.ContainerID,\n   420→\t\tErrorMessage: r.ErrorMessage,\n   421→\t}\n   422→}\n   423→\n   424→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   425→\tprojectFilter := r.URL.Query().Get(\"project\")\n   426→\n   427→\tvar runs []*domain.Run\n   428→\tvar err error\n   429→\tif projectFilter != \"\" {\n   430→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   431→\t} else {\n   432→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   433→\t}\n   434→\tif err != nil {\n   435→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   436→\t\treturn\n   437→\t}\n   438→\n   439→\tprojects, _ := h.store.ListProjects(r.Context())\n   440→\tlabels := projectLabels(projects)\n   441→\n   442→\tresult := make([]apiRun, len(runs))\n   443→\tfor i, run := range runs {\n   444→\t\tresult[i] = toAPIRun(run, labels)\n   445→\t}\n   446→\n   447→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   448→\tjson.NewEncoder(w).Encode(result)\n   449→}\n   450→\n   451→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   452→\tprojects, err := h.store.ListProjects(r.Context())\n   453→\tif err != nil {\n   454→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   455→\t\treturn\n   456→\t}\n   457→\tlabels := projectLabels(projects)\n   458→\n   459→\ttype apiHealth struct {\n   460→\t\tStatus string `json:\"status\"`\n   461→\t\tPassed int    `json:\"passed\"`\n   462→\t\tFailed int    `json:\"failed\"`\n   463→\t\tTotal  int    `json:\"total\"`\n   464→\t}\n   465→\ttype apiProject struct {\n   466→\t\tDir         string    `json:\"dir\"`\n   467→\t\tLabel       string    `json:\"label\"`\n   468→\t\tHealth      apiHealth `json:\"health\"`\n   469→\t\tActiveCount int       `json:\"active_count\"`\n   470→\t}\n   471→\tresult := make([]apiProject, len(projects))\n   472→\tfor i, dir := range projects {\n   473→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   474→\t\trunValues := make([]domain.Run, len(runs))\n   475→\t\tfor j, rr := range runs {\n   476→\t\t\trunValues[j] = *rr\n   477→\t\t}\n   478→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   479→\t\tvar activeCount int\n   480→\t\tfor _, rr := range runs {\n   481→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   482→\t\t\t\tactiveCount++\n   483→\t\t\t}\n   484→\t\t}\n   485→\t\tresult[i] = apiProject{\n   486→\t\t\tDir:   dir,\n   487→\t\t\tLabel: labels[dir],\n   488→\t\t\tHealth: apiHealth{\n   489→\t\t\t\tStatus: string(health.Status),\n   490→\t\t\t\tPassed: health.Passed,\n   491→\t\t\t\tFailed: health.Failed,\n   492→\t\t\t\tTotal:  health.Total,\n   493→\t\t\t},\n   494→\t\t\tActiveCount: activeCount,\n   495→\t\t}\n   496→\t}\n   497→\n   498→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   499→\tjson.NewEncoder(w).Encode(result)\n   500→}\n   501→\n   502→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   503→\tid := r.PathValue(\"id\")\n   504→\n   505→\trun, err := h.store.GetRun(r.Context(), id)\n   506→\tif err != nil {\n   507→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   508→\t\treturn\n   509→\t}\n   510→\n   511→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   512→\tif err != nil {\n   513→\t\tcaps = nil\n   514→\t}\n   515→\n   516→\tprojects, _ := h.store.ListProjects(r.Context())\n   517→\tlabels := projectLabels(projects)\n   518→\n   519→\tmerged := mergeCaptures(caps)\n   520→\tsteps := make([]apiStep, len(merged))\n   521→\tfor i, e := range merged {\n   522→\t\tsteps[i] = apiStep{\n   523→\t\t\tStepName:  e.StepName,\n   524→\t\t\tResult:    e.Result,\n   525→\t\t\tStartedAt: formatTime(e.StartedAt),\n   526→\t\t\tDuration:  e.Duration,\n   527→\t\t}\n   528→\t}\n   529→\n   530→\tdetail := apiRunDetail{\n   531→\t\tapiRun:         toAPIRun(run, labels),\n   532→\t\tContainerState: h.containerState(r.Context(), run),\n   533→\t\tSteps:          steps,\n   534→\t}\n   535→\n   536→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   537→\tjson.NewEncoder(w).Encode(detail)\n   538→}\n   539→\n   540→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   541→\tid := r.PathValue(\"id\")\n   542→\tstep := r.PathValue(\"step\")\n   543→\tlogType := r.URL.Query().Get(\"type\")   // optional: \"script\", \"llm\"\n   544→\tformat := r.URL.Query().Get(\"format\")  // optional: \"raw\" to skip parsing\n   545→\n   546→\trun, err := h.store.GetRun(r.Context(), id)\n   547→\tif err != nil {\n   548→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   549→\t\treturn\n   550→\t}\n   551→\n   552→\twriteOutput := func(data []byte) {\n   553→\t\tif format != \"raw\" {\n   554→\t\t\tdata = logstream.ParseClaudeStream(data)\n   555→\t\t}\n   556→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   557→\t\tw.Write(data)\n   558→\t}\n   559→\n   560→\t// Try log index first for fast lookup\n   561→\tif h.logStore != nil {\n   562→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   563→\t\tif err == nil && len(logFiles) > 0 {\n   564→\t\t\t// If type filter specified, narrow results\n   565→\t\t\tfor _, lf := range logFiles {\n   566→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   567→\t\t\t\t\tcontinue\n   568→\t\t\t\t}\n   569→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   570→\t\t\t\tif readErr == nil && len(data) > 0 {\n   571→\t\t\t\t\twriteOutput(data)\n   572→\t\t\t\t\treturn\n   573→\t\t\t\t}\n   574→\t\t\t}\n   575→\t\t}\n   576→\t}\n   577→\n   578→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   579→\n   580→\t// Fall back to file path conventions\n   581→\t// If type is \"llm\", try llm-<step>.log\n   582→\tif logType == \"llm\" {\n   583→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   584→\t\tdata, err := os.ReadFile(llmPath)\n   585→\t\tif err == nil && len(data) > 0 {\n   586→\t\t\twriteOutput(data)\n   587→\t\t\treturn\n   588→\t\t}\n   589→\t}\n   590→\n   591→\t// Try per-step output first, fall back to container.log, then live docker logs\n   592→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   593→\tdata, err := os.ReadFile(outputPath)\n   594→\tif err == nil && len(data) > 0 {\n   595→\t\twriteOutput(data)\n   596→\t\treturn\n   597→\t}\n   598→\n   599→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   600→\tdata, err = os.ReadFile(containerLog)\n   601→\tif err == nil && len(data) > 0 {\n   602→\t\twriteOutput(data)\n   603→\t\treturn\n   604→\t}\n   605→\n   606→\t// Last resort: try live docker logs from still-existing container\n   607→\tif h.container != nil && run.ContainerID != \"\" {\n   608→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   609→\t\t\twriteOutput([]byte(logs))\n   610→\t\t\treturn\n   611→\t\t}\n   612→\t}\n   613→\n   614→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   615→}\n   616→\n   617→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   618→\tid := r.PathValue(\"id\")\n   619→\n   620→\trun, err := h.store.GetRun(r.Context(), id)\n   621→\tif err != nil {\n   622→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   623→\t\tw.WriteHeader(http.StatusNotFound)\n   624→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   625→\t\treturn\n   626→\t}\n   627→\n   628→\tmgr, ok := h.container.(ContainerManager)\n   629→\tif !ok || run.ContainerID == \"\" {\n   630→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   631→\t\tw.WriteHeader(http.StatusBadRequest)\n   632→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   633→\t\treturn\n   634→\t}\n   635→\n   636→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   637→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   638→\t\tw.WriteHeader(http.StatusInternalServerError)\n   639→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   640→\t\treturn\n   641→\t}\n   642→\n   643→\trun.ContainerKept = false\n   644→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   645→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   646→\t\tw.WriteHeader(http.StatusInternalServerError)\n   647→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   648→\t\treturn\n   649→\t}\n   650→\n   651→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   652→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   653→}\n   654→\n   655→// handleAPIStream serves an SSE stream of log lines for a run.\n   656→// For active runs, it subscribes to the live broadcaster.\n   657→// For completed runs, it serves the archived full.log then closes.\n   658→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   659→\tid := r.PathValue(\"id\")\n   660→\n   661→\trun, err := h.store.GetRun(r.Context(), id)\n   662→\tif err != nil {\n   663→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   664→\t\treturn\n   665→\t}\n   666→\n   667→\tflusher, ok := w.(http.Flusher)\n   668→\tif !ok {\n   669→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   670→\t\treturn\n   671→\t}\n   672→\n   673→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   674→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   675→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   676→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   677→\n   678→\tisComplete := run.State == domain.RunStateSucceeded ||\n   679→\t\trun.State == domain.RunStateFailed ||\n   680→\t\trun.State == domain.RunStateCancelled\n   681→\n   682→\tif isComplete {\n   683→\t\t// Serve archived full.log\n   684→\t\th.streamFullLog(w, flusher, run)\n   685→\t\t// Send done event\n   686→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   687→\t\tflusher.Flush()\n   688→\t\treturn\n   689→\t}\n   690→\n   691→\t// Active run: subscribe to live broadcaster\n   692→\tif h.logBroadcast == nil {\n   693→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   694→\t\treturn\n   695→\t}\n   696→\n   697→\tsub := h.logBroadcast.Subscribe(id)\n   698→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   699→\n   700→\tctx := r.Context()\n   701→\tfor {\n   702→\t\tselect {\n   703→\t\tcase <-ctx.Done():\n   704→\t\t\treturn\n   705→\t\tcase line, ok := <-sub.C:\n   706→\t\t\tif !ok {\n   707→\t\t\t\t// Stream finished (run completed)\n   708→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   709→\t\t\t\tflusher.Flush()\n   710→\t\t\t\treturn\n   711→\t\t\t}\n   712→\t\t\tline = parseLLMLogLine(line)\n   713→\t\t\tif line.Type == \"\" {\n   714→\t\t\t\tcontinue // skip protocol-only llm lines\n   715→\t\t\t}\n   716→\t\t\tdata, _ := json.Marshal(line)\n   717→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   718→\t\t\tflusher.Flush()\n   719→\t\t}\n   720→\t}\n   721→}\n   722→\n   723→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   724→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   725→\n   726→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   727→// LLM-type lines are parsed from raw Claude JSON into human-readable text.\n   728→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   729→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   730→\tf, err := os.Open(logPath)\n   731→\tif err != nil {\n   732→\t\treturn\n   733→\t}\n   734→\tdefer f.Close()\n   735→\n   736→\tscanner := bufio.NewScanner(f)\n   737→\tfor scanner.Scan() {\n   738→\t\ttext := scanner.Text()\n   739→\t\tline := parseFullLogLine(text)\n   740→\t\tline = parseLLMLogLine(line)\n   741→\t\tif line.Type == \"\" {\n   742→\t\t\tcontinue // skip protocol-only llm lines\n   743→\t\t}\n   744→\t\tdata, _ := json.Marshal(line)\n   745→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   746→\t\tflusher.Flush()\n   747→\t}\n   748→}\n   749→\n   750→// parseLLMLogLine parses a LogLine whose type is \"llm\". If the content is\n   751→// Claude stream JSON, it extracts the human-readable text. Protocol-only\n   752→// events return a LogLine with an empty Type (caller should skip it).\n   753→// Non-llm lines are returned unchanged.\n   754→func parseLLMLogLine(line logstream.LogLine) logstream.LogLine {\n   755→\tif line.Type != \"llm\" {\n   756→\t\treturn line\n   757→\t}\n   758→\ttext, ok := logstream.ParseClaudeLine([]byte(line.Content))\n   759→\tif !ok {\n   760→\t\treturn logstream.LogLine{} // signal to skip\n   761→\t}\n   762→\tline.Content = text\n   763→\treturn line\n   764→}\n   765→\n   766→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   767→func parseFullLogLine(text string) logstream.LogLine {\n   768→\tm := logLineRegex.FindStringSubmatch(text)\n   769→\tif m == nil {\n   770→\t\treturn logstream.LogLine{\n   771→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   772→\t\t\tType:      \"script\",\n   773→\t\t\tContent:   text,\n   774→\t\t}\n   775→\t}\n   776→\treturn logstream.LogLine{\n   777→\t\tTimestamp: m[1],\n   778→\t\tType:      m[2],\n   779→\t\tContent:   m[3],\n   780→\t}\n   781→}\n   782→\n   783→// --- Project detail handlers ---\n   784→\n   785→// resolveProjectDir resolves a project label from the URL to its directory path.\n   786→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   787→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   788→\tlabel := r.PathValue(\"name\")\n   789→\tprojects, _ := h.store.ListProjects(r.Context())\n   790→\tlabels := projectLabels(projects)\n   791→\tfor dir, l := range labels {\n   792→\t\tif l == label {\n   793→\t\t\treturn dir, label, true\n   794→\t\t}\n   795→\t}\n   796→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   797→\tw.WriteHeader(http.StatusNotFound)\n   798→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   799→\treturn \"\", \"\", false\n   800→}\n   801→\n   802→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   803→\tdir, label, ok := h.resolveProjectDir(w, r)\n   804→\tif !ok {\n   805→\t\treturn\n   806→\t}\n   807→\n   808→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   809→\tn := 10\n   810→\tif n > len(runs) {\n   811→\t\tn = len(runs)\n   812→\t}\n   813→\tdots := make([]recentRunDot, n)\n   814→\tfor i := 0; i < n; i++ {\n   815→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   816→\t}\n   817→\n   818→\tdata := map[string]any{\n   819→\t\t\"Title\":      label,\n   820→\t\t\"Label\":      label,\n   821→\t\t\"Dir\":        dir,\n   822→\t\t\"RecentRuns\": dots,\n   823→\t}\n   824→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   825→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   826→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   827→\t}\n   828→}\n   829→\n   830→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   831→\tdir, _, ok := h.resolveProjectDir(w, r)\n   832→\tif !ok {\n   833→\t\treturn\n   834→\t}\n   835→\n   836→\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   837→\tif err != nil {\n   838→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   839→\t\treturn\n   840→\t}\n   841→\n   842→\tprojects, _ := h.store.ListProjects(r.Context())\n   843→\tlabels := projectLabels(projects)\n   844→\n   845→\t// Count retained containers per project\n   846→\tcontainerCounts := map[string]int{}\n   847→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   848→\tfor _, run := range allRuns {\n   849→\t\tif run.ContainerKept {\n   850→\t\t\tcontainerCounts[run.ProjectDir]++\n   851→\t\t}\n   852→\t}\n   853→\n   854→\tvar projectList []projectEntry\n   855→\tfor _, d := range projects {\n   856→\t\tprojectList = append(projectList, projectEntry{Dir: d, Label: labels[d], ContainerCount: containerCounts[d]})\n   857→\t}\n   858→\tsort.Slice(projectList, func(i, j int) bool {\n   859→\t\treturn projectList[i].Label < projectList[j].Label\n   860→\t})\n   861→\n   862→\tdata := map[string]any{\n   863→\t\t\"Title\":         \"Runs\",\n   864→\t\t\"Runs\":          runs,\n   865→\t\t\"Projects\":      projectList,\n   866→\t\t\"ProjectFilter\": dir,\n   867→\t\t\"ProjectLabels\": labels,\n   868→\t}\n   869→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   870→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   871→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   872→\t}\n   873→}\n   874→\n   875→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   876→\tdir, _, ok := h.resolveProjectDir(w, r)\n   877→\tif !ok {\n   878→\t\treturn\n   879→\t}\n   880→\n   881→\t// Docker image: read FROM line from Dockerfile\n   882→\tdockerImage := \"\"\n   883→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   884→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   885→\t\t// Find the last FROM line (final stage)\n   886→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   887→\t\t\ttrimmed := strings.TrimSpace(line)\n   888→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   889→\t\t\t\tparts := strings.Fields(trimmed)\n   890→\t\t\t\tif len(parts) >= 2 {\n   891→\t\t\t\t\tdockerImage = parts[1]\n   892→\t\t\t\t}\n   893→\t\t\t}\n   894→\t\t}\n   895→\t}\n   896→\n   897→\t// Version\n   898→\tversion := 0\n   899→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   900→\tif data, err := os.ReadFile(versionPath); err == nil {\n   901→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   902→\t\t\tversion = v\n   903→\t\t}\n   904→\t}\n   905→\n   906→\t// Prompt files history\n   907→\ttype commitEntry struct {\n   908→\t\tSHA     string `json:\"sha\"`\n   909→\t\tDate    string `json:\"date\"`\n   910→\t\tMessage string `json:\"message\"`\n   911→\t}\n   912→\ttype promptFile struct {\n   913→\t\tPath    string        `json:\"path\"`\n   914→\t\tHistory []commitEntry `json:\"history\"`\n   915→\t}\n   916→\n   917→\tvar promptFiles []promptFile\n   918→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   919→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n   920→\t\tfor _, e := range entries {\n   921→\t\t\tif e.IsDir() {\n   922→\t\t\t\tcontinue\n   923→\t\t\t}\n   924→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n   925→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n   926→\t\t\tcmd.Dir = dir\n   927→\t\t\tout, err := cmd.Output()\n   928→\t\t\tif err != nil {\n   929→\t\t\t\tcontinue\n   930→\t\t\t}\n   931→\t\t\tvar history []commitEntry\n   932→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n   933→\t\t\t\tif line == \"\" {\n   934→\t\t\t\t\tcontinue\n   935→\t\t\t\t}\n   936→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n   937→\t\t\t\tif len(parts) < 3 {\n   938→\t\t\t\t\tcontinue\n   939→\t\t\t\t}\n   940→\t\t\t\t// Parse date to short form\n   941→\t\t\t\tdateStr := parts[1]\n   942→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n   943→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n   944→\t\t\t\t}\n   945→\t\t\t\thistory = append(history, commitEntry{\n   946→\t\t\t\t\tSHA:     parts[0][:7],\n   947→\t\t\t\t\tDate:    dateStr,\n   948→\t\t\t\t\tMessage: parts[2],\n   949→\t\t\t\t})\n   950→\t\t\t}\n   951→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n   952→\t\t}\n   953→\t}\n   954→\n   955→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   956→\tjson.NewEncoder(w).Encode(map[string]any{\n   957→\t\t\"docker_image\": dockerImage,\n   958→\t\t\"version\":      version,\n   959→\t\t\"prompt_files\": promptFiles,\n   960→\t})\n   961→}\n   962→\n   963→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n   964→\tdir, _, ok := h.resolveProjectDir(w, r)\n   965→\tif !ok {\n   966→\t\treturn\n   967→\t}\n   968→\tfile := r.URL.Query().Get(\"file\")\n   969→\tsha := r.URL.Query().Get(\"sha\")\n   970→\tif file == \"\" || sha == \"\" {\n   971→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n   972→\t\treturn\n   973→\t}\n   974→\n   975→\t// Validate sha is alphanumeric to prevent injection\n   976→\tfor _, c := range sha {\n   977→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n   978→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n   979→\t\t\treturn\n   980→\t\t}\n   981→\t}\n   982→\n   983→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n   984→\tcmd.Dir = dir\n   985→\tout, err := cmd.Output()\n   986→\tif err != nil {\n   987→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n   988→\t\treturn\n   989→\t}\n   990→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   991→\tw.Write(out)\n   992→}\n   993→\n   994→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n   995→\tdir, _, ok := h.resolveProjectDir(w, r)\n   996→\tif !ok {\n   997→\t\treturn\n   998→\t}\n   999→\n  1000→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1001→\tentries, err := os.ReadDir(clocheDir)\n  1002→\tif err != nil {\n  1003→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1004→\t\tjson.NewEncoder(w).Encode([]any{})\n  1005→\t\treturn\n  1006→\t}\n  1007→\n  1008→\ttype apiWire struct {\n  1009→\t\tFrom   string `json:\"from\"`\n  1010→\t\tResult string `json:\"result\"`\n  1011→\t\tTo     string `json:\"to\"`\n  1012→\t}\n  1013→\ttype apiStepDef struct {\n  1014→\t\tName    string            `json:\"name\"`\n  1015→\t\tType    string            `json:\"type\"`\n  1016→\t\tResults []string          `json:\"results\"`\n  1017→\t\tConfig  map[string]string `json:\"config\"`\n  1018→\t}\n  1019→\ttype apiWorkflow struct {\n  1020→\t\tName      string       `json:\"name\"`\n  1021→\t\tFile      string       `json:\"file\"`\n  1022→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1023→\t\tWires     []apiWire    `json:\"wires\"`\n  1024→\t\tEntryStep string       `json:\"entry_step\"`\n  1025→\t}\n  1026→\n  1027→\tvar workflows []apiWorkflow\n  1028→\tfor _, e := range entries {\n  1029→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1030→\t\t\tcontinue\n  1031→\t\t}\n  1032→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1033→\t\tif err != nil {\n  1034→\t\t\tcontinue\n  1035→\t\t}\n  1036→\t\twf, err := dsl.ParseForContainer(string(data))\n  1037→\t\tif err != nil {\n  1038→\t\t\tcontinue\n  1039→\t\t}\n  1040→\t\tvar steps []apiStepDef\n  1041→\t\tfor _, s := range wf.Steps {\n  1042→\t\t\tsteps = append(steps, apiStepDef{\n  1043→\t\t\t\tName:    s.Name,\n  1044→\t\t\t\tType:    string(s.Type),\n  1045→\t\t\t\tResults: s.Results,\n  1046→\t\t\t\tConfig:  s.Config,\n  1047→\t\t\t})\n  1048→\t\t}\n  1049→\t\t// Sort steps by name for consistent ordering\n  1050→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1051→\n  1052→\t\tvar wires []apiWire\n  1053→\t\tfor _, wire := range wf.Wiring {\n  1054→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1055→\t\t}\n  1056→\n  1057→\t\tworkflows = append(workflows, apiWorkflow{\n  1058→\t\t\tName:      wf.Name,\n  1059→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1060→\t\t\tSteps:     steps,\n  1061→\t\t\tWires:     wires,\n  1062→\t\t\tEntryStep: wf.EntryStep,\n  1063→\t\t})\n  1064→\t}\n  1065→\n  1066→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1067→\tjson.NewEncoder(w).Encode(workflows)\n  1068→}\n  1069→\n  1070→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1071→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1072→\tif !ok {\n  1073→\t\treturn\n  1074→\t}\n  1075→\tworkflowName := r.PathValue(\"workflow\")\n  1076→\tstepName := r.PathValue(\"step\")\n  1077→\n  1078→\t// Find the workflow file\n  1079→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1080→\tvar wf *domain.Workflow\n  1081→\tentries, _ := os.ReadDir(clocheDir)\n  1082→\tfor _, e := range entries {\n  1083→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1084→\t\t\tcontinue\n  1085→\t\t}\n  1086→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1087→\t\tif err != nil {\n  1088→\t\t\tcontinue\n  1089→\t\t}\n  1090→\t\tparsed, err := dsl.ParseForContainer(string(data))\n  1091→\t\tif err != nil {\n  1092→\t\t\tcontinue\n  1093→\t\t}\n  1094→\t\tif parsed.Name == workflowName {\n  1095→\t\t\twf = parsed\n  1096→\t\t\tbreak\n  1097→\t\t}\n  1098→\t}\n  1099→\tif wf == nil {\n  1100→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1101→\t\treturn\n  1102→\t}\n  1103→\n  1104→\tstep, ok := wf.Steps[stepName]\n  1105→\tif !ok {\n  1106→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1107→\t\treturn\n  1108→\t}\n  1109→\n  1110→\t// Try to read the referenced file from step config\n  1111→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1112→\n  1113→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1114→\t\tcontent, err := resolveFileRef(prompt, dir)\n  1115→\t\tif err == nil {\n  1116→\t\t\tw.Write([]byte(content))\n  1117→\t\t\treturn\n  1118→\t\t}\n  1119→\t}\n  1120→\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n  1121→\t\tcontent, _ := resolveFileRef(cmd, dir)\n  1122→\t\tw.Write([]byte(content))\n  1123→\t\treturn\n  1124→\t}\n  1125→\tif script := step.Config[\"script\"]; script != \"\" {\n  1126→\t\tcontent, _ := resolveFileRef(script, dir)\n  1127→\t\tw.Write([]byte(content))\n  1128→\t\treturn\n  1129→\t}\n  1130→\n  1131→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1132→}\n  1133→\n  1134→// --- Template helpers ---\n  1135→\n  1136→// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n  1137→// If the value uses file() syntax, the referenced file is read from disk.\n  1138→// Otherwise the value is returned as-is.\n  1139→func resolveFileRef(value, baseDir string) (string, error) {\n  1140→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n  1141→\t\tpath := value[6 : len(value)-2]\n  1142→\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n  1143→\t\tif err != nil {\n  1144→\t\t\treturn \"\", err\n  1145→\t\t}\n  1146→\t\treturn string(data), nil\n  1147→\t}\n  1148→\treturn value, nil\n  1149→}\n  1150→\n  1151→func stateColor(state domain.RunState) string {\n  1152→\tswitch state {\n  1153→\tcase domain.RunStatePending:\n  1154→\t\treturn \"pending\"\n  1155→\tcase domain.RunStateRunning:\n  1156→\t\treturn \"running\"\n  1157→\tcase domain.RunStateSucceeded:\n  1158→\t\treturn \"succeeded\"\n  1159→\tcase domain.RunStateFailed:\n  1160→\t\treturn \"failed\"\n  1161→\tcase domain.RunStateCancelled:\n  1162→\t\treturn \"cancelled\"\n  1163→\tdefault:\n  1164→\t\treturn \"pending\"\n  1165→\t}\n  1166→}\n  1167→\n  1168→func healthColor(status domain.HealthStatus) string {\n  1169→\tswitch status {\n  1170→\tcase domain.HealthGreen:\n  1171→\t\treturn \"green\"\n  1172→\tcase domain.HealthYellow:\n  1173→\t\treturn \"yellow\"\n  1174→\tcase domain.HealthRed:\n  1175→\t\treturn \"red\"\n  1176→\tcase domain.HealthBlue:\n  1177→\t\treturn \"blue\"\n  1178→\tdefault:\n  1179→\t\treturn \"grey\"\n  1180→\t}\n  1181→}\n  1182→\n  1183→func formatTime(t time.Time) string {\n  1184→\tif t.IsZero() {\n  1185→\t\treturn \"\"\n  1186→\t}\n  1187→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1188→}\n  1189→\n  1190→func formatDuration(start, end time.Time) string {\n  1191→\tif start.IsZero() || end.IsZero() {\n  1192→\t\treturn \"\"\n  1193→\t}\n  1194→\td := end.Sub(start)\n  1195→\tif d < time.Second {\n  1196→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1197→\t}\n  1198→\tif d < time.Minute {\n  1199→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1200→\t}\n  1201→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1202→}\n  1203→\n  1204→func truncate(s string, n int) string {\n  1205→\tif len(s) <= n {\n  1206→\t\treturn s\n  1207→\t}\n  1208→\treturn s[:n] + \"...\"\n  1209→}\n  1210→\n  1211→func shortContainerID(id string) string {\n  1212→\tif len(id) > 12 {\n  1213→\t\treturn id[:12]\n  1214→\t}\n  1215→\treturn id\n  1216→}\n  1217→\n  1218→// projectLabels builds a mapping from full project directory paths to short\n  1219→// display labels. Each label is the final directory component (e.g.\n  1220→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1221→// the same final name, the parent directory is prepended to disambiguate\n  1222→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1223→func projectLabels(dirs []string) map[string]string {\n  1224→\tlabels := make(map[string]string, len(dirs))\n  1225→\t// Group dirs by their base name to detect conflicts.\n  1226→\tbyBase := map[string][]string{}\n  1227→\tfor _, d := range dirs {\n  1228→\t\tbase := filepath.Base(d)\n  1229→\t\tbyBase[base] = append(byBase[base], d)\n  1230→\t}\n  1231→\tfor base, paths := range byBase {\n  1232→\t\tif len(paths) == 1 {\n  1233→\t\t\tlabels[paths[0]] = base\n  1234→\t\t} else {\n  1235→\t\t\tfor _, p := range paths {\n  1236→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1237→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1238→\t\t\t}\n  1239→\t\t}\n  1240→\t}\n  1241→\treturn labels\n  1242→}\n  1243→\n  1244→type projectEntry struct {\n  1245→\tDir            string\n  1246→\tLabel          string\n  1247→\tContainerCount int\n  1248→}\n  1249→"}]},"parent_tool_use_id":null,"session_id":"b57dc17a-fc9e-4ed7-b4d0-831f399e4ca7","uuid":"8bb06fca-8640-41b4-948d-c37fa07eed30","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogStore     ports.LogStore\n\tcontainer    ContainerLogger\n\tlogBroadcast *logstream.Broadcaster\n\tpages        map[string]*template.Template\n\tmux          *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\")   // optional: \"script\", \"llm\"\n\tformat := r.URL.Query().Get(\"format\")  // optional: \"raw\" to skip parsing\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\twriteOutput := func(data []byte) {\n\t\tif format != \"raw\" {\n\t\t\tdata = logstream.ParseClaudeStream(data)\n\t\t}\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\twriteOutput(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\twriteOutput(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\twriteOutput(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\twriteOutput(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\twriteOutput([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tline = parseLLMLogLine(line)\n\t\t\tif line.Type == \"\" {\n\t\t\t\tcontinue // skip protocol-only llm lines\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n// LLM-type lines are parsed from raw Claude JSON into human-readable text.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tline = parseLLMLogLine(line)\n\t\tif line.Type == \"\" {\n\t\t\tcontinue // skip protocol-only llm lines\n\t\t}\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseLLMLogLine parses a LogLine whose type is \"llm\". If the content is\n// Claude stream JSON, it extracts the human-readable text. Protocol-only\n// events return a LogLine with an empty Type (caller should skip it).\n// Non-llm lines are returned unchanged.\nfunc parseLLMLogLine(line logstream.LogLine) logstream.LogLine {\n\tif line.Type != \"llm\" {\n\t\treturn line\n\t}\n\ttext, ok := logstream.ParseClaudeLine([]byte(line.Content))\n\tif !ok {\n\t\treturn logstream.LogLine{} // signal to skip\n\t}\n\tline.Content = text\n\treturn line\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, d := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: d, Label: labels[d], ContainerCount: containerCounts[d]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": dir,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.ParseForContainer(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.ParseForContainer(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tcontent, err := resolveFileRef(prompt, dir)\n\t\tif err == nil {\n\t\t\tw.Write([]byte(content))\n\t\t\treturn\n\t\t}\n\t}\n\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n\t\tcontent, _ := resolveFileRef(cmd, dir)\n\t\tw.Write([]byte(content))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tcontent, _ := resolveFileRef(script, dir)\n\t\tw.Write([]byte(content))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\n// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n// If the value uses file() syntax, the referenced file is read from disk.\n// Otherwise the value is returned as-is.\nfunc resolveFileRef(value, baseDir string) (string, error) {\n\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n\t\tpath := value[6 : len(value)-2]\n\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n\t\tif err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\treturn string(data), nil\n\t}\n\treturn value, nil\n}\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1249,"startLine":1,"totalLines":1249}}}
