{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018sPNuESg4BeN9kB5Nbo4rz","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"net/http\"\n     8→\t\"net/http/httptest\"\n     9→\t\"os\"\n    10→\t\"path/filepath\"\n    11→\t\"testing\"\n    12→\t\"time\"\n    13→\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    17→\t\"github.com/stretchr/testify/assert\"\n    18→\t\"github.com/stretchr/testify/require\"\n    19→)\n    20→\n    21→// mockContainerManager implements ContainerManager for testing.\n    22→type mockContainerManager struct {\n    23→\tcontainers map[string]bool // containerID -> exists\n    24→\trunning    map[string]bool // containerID -> running\n    25→\tremoved    []string\n    26→}\n    27→\n    28→func newMockContainerManager() *mockContainerManager {\n    29→\treturn &mockContainerManager{\n    30→\t\tcontainers: map[string]bool{},\n    31→\t\trunning:    map[string]bool{},\n    32→\t}\n    33→}\n    34→\n    35→func (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n    36→\treturn \"mock logs\", nil\n    37→}\n    38→\n    39→func (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n    40→\tif !m.containers[containerID] {\n    41→\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n    42→\t}\n    43→\tdelete(m.containers, containerID)\n    44→\tm.removed = append(m.removed, containerID)\n    45→\treturn nil\n    46→}\n    47→\n    48→func (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n    49→\tif !m.containers[containerID] {\n    50→\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n    51→\t}\n    52→\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n    53→}\n    54→\n    55→func setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n    56→\tt.Helper()\n    57→\tstore, err := sqlite.NewStore(\":memory:\")\n    58→\trequire.NoError(t, err)\n    59→\tt.Cleanup(func() { store.Close() })\n    60→\n    61→\th, err := NewHandler(store, store)\n    62→\trequire.NoError(t, err)\n    63→\treturn h, store\n    64→}\n    65→\n    66→func seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n    67→\tt.Helper()\n    68→\tseedRunWithProject(t, store, id, workflow, state, \"\")\n    69→}\n    70→\n    71→func seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n    72→\tt.Helper()\n    73→\tctx := context.Background()\n    74→\trun := domain.NewRun(id, workflow)\n    75→\trun.ProjectDir = projectDir\n    76→\tif state != domain.RunStatePending {\n    77→\t\trun.Start()\n    78→\t\trun.ContainerID = \"abc123def456789\"\n    79→\t}\n    80→\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n    81→\t\trun.Complete(state)\n    82→\t}\n    83→\tif state == domain.RunStateFailed {\n    84→\t\trun.ErrorMessage = \"something went wrong\"\n    85→\t}\n    86→\trequire.NoError(t, store.CreateRun(ctx, run))\n    87→}\n    88→\n    89→func TestRunsList_WithRuns(t *testing.T) {\n    90→\th, store := setupHandler(t)\n    91→\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n    92→\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n    93→\n    94→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n    95→\tw := httptest.NewRecorder()\n    96→\th.ServeHTTP(w, req)\n    97→\n    98→\tassert.Equal(t, http.StatusOK, w.Code)\n    99→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   100→\tbody := w.Body.String()\n   101→\tassert.Contains(t, body, \"test-run-1\")\n   102→\tassert.Contains(t, body, \"test-run-2\")\n   103→\tassert.Contains(t, body, \"badge-running\")\n   104→\tassert.Contains(t, body, \"badge-succeeded\")\n   105→\tassert.Contains(t, body, \"develop\")\n   106→\tassert.Contains(t, body, \"deploy\")\n   107→}\n   108→\n   109→func TestRunsList_Empty(t *testing.T) {\n   110→\th, _ := setupHandler(t)\n   111→\n   112→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   113→\tw := httptest.NewRecorder()\n   114→\th.ServeHTTP(w, req)\n   115→\n   116→\tassert.Equal(t, http.StatusOK, w.Code)\n   117→\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n   118→}\n   119→\n   120→func TestRunDetail_WithCaptures(t *testing.T) {\n   121→\th, store := setupHandler(t)\n   122→\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n   123→\n   124→\tctx := context.Background()\n   125→\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n   126→\t\tStepName:    \"implement\",\n   127→\t\tResult:      \"success\",\n   128→\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n   129→\t\tCompletedAt: time.Now(),\n   130→\t}))\n   131→\n   132→\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n   133→\tw := httptest.NewRecorder()\n   134→\th.ServeHTTP(w, req)\n   135→\n   136→\tassert.Equal(t, http.StatusOK, w.Code)\n   137→\tbody := w.Body.String()\n   138→\tassert.Contains(t, body, \"run-detail-1\")\n   139→\tassert.Contains(t, body, \"implement\")\n   140→}\n   141→\n   142→func TestRunDetail_NotFound(t *testing.T) {\n   143→\th, _ := setupHandler(t)\n   144→\n   145→\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n   146→\tw := httptest.NewRecorder()\n   147→\th.ServeHTTP(w, req)\n   148→\n   149→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   150→}\n   151→\n   152→func TestAPIRuns(t *testing.T) {\n   153→\th, store := setupHandler(t)\n   154→\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n   155→\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n   156→\n   157→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   158→\tw := httptest.NewRecorder()\n   159→\th.ServeHTTP(w, req)\n   160→\n   161→\tassert.Equal(t, http.StatusOK, w.Code)\n   162→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   163→\n   164→\tvar runs []apiRun\n   165→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n   166→\tassert.Len(t, runs, 2)\n   167→\n   168→\tids := map[string]bool{}\n   169→\tfor _, r := range runs {\n   170→\t\tids[r.ID] = true\n   171→\t}\n   172→\tassert.True(t, ids[\"api-run-1\"])\n   173→\tassert.True(t, ids[\"api-run-2\"])\n   174→}\n   175→\n   176→func TestAPIRunDetail(t *testing.T) {\n   177→\th, store := setupHandler(t)\n   178→\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n   179→\n   180→\tctx := context.Background()\n   181→\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n   182→\t\tStepName:    \"build\",\n   183→\t\tResult:      \"success\",\n   184→\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n   185→\t\tCompletedAt: time.Now(),\n   186→\t}))\n   187→\n   188→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n   189→\tw := httptest.NewRecorder()\n   190→\th.ServeHTTP(w, req)\n   191→\n   192→\tassert.Equal(t, http.StatusOK, w.Code)\n   193→\n   194→\tvar detail apiRunDetail\n   195→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   196→\tassert.Equal(t, \"api-detail-1\", detail.ID)\n   197→\tassert.Equal(t, \"running\", detail.State)\n   198→\tassert.Len(t, detail.Steps, 1)\n   199→\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n   200→\tassert.NotEmpty(t, detail.Steps[0].Duration)\n   201→}\n   202→\n   203→func TestStaticCSS(t *testing.T) {\n   204→\th, _ := setupHandler(t)\n   205→\n   206→\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n   207→\tw := httptest.NewRecorder()\n   208→\th.ServeHTTP(w, req)\n   209→\n   210→\tassert.Equal(t, http.StatusOK, w.Code)\n   211→\tassert.Contains(t, w.Body.String(), \":root\")\n   212→\tassert.Contains(t, w.Body.String(), \"badge-running\")\n   213→}\n   214→\n   215→func TestHelpers(t *testing.T) {\n   216→\tt.Run(\"stateColor\", func(t *testing.T) {\n   217→\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n   218→\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n   219→\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n   220→\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n   221→\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n   222→\t})\n   223→\n   224→\tt.Run(\"formatTime\", func(t *testing.T) {\n   225→\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n   226→\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n   227→\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n   228→\t})\n   229→\n   230→\tt.Run(\"formatDuration\", func(t *testing.T) {\n   231→\t\tnow := time.Now()\n   232→\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n   233→\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n   234→\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n   235→\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n   236→\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n   237→\t})\n   238→\n   239→\tt.Run(\"truncate\", func(t *testing.T) {\n   240→\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n   241→\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n   242→\t})\n   243→\n   244→\tt.Run(\"shortContainerID\", func(t *testing.T) {\n   245→\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n   246→\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n   247→\t})\n   248→\n   249→\tt.Run(\"projectLabels\", func(t *testing.T) {\n   250→\t\t// No conflict: show base name only\n   251→\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n   252→\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n   253→\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n   254→\n   255→\t\t// Conflict: two dirs share the same base name\n   256→\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n   257→\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n   258→\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n   259→\n   260→\t\t// Mixed: some conflict, some don't\n   261→\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n   262→\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n   263→\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n   264→\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n   265→\n   266→\t\t// Empty list\n   267→\t\tlabels = projectLabels(nil)\n   268→\t\tassert.Empty(t, labels)\n   269→\t})\n   270→}\n   271→\n   272→func TestRunsList_ProjectFilter(t *testing.T) {\n   273→\th, store := setupHandler(t)\n   274→\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   275→\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   276→\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   277→\n   278→\t// Without filter: all runs shown\n   279→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   280→\tw := httptest.NewRecorder()\n   281→\th.ServeHTTP(w, req)\n   282→\tassert.Equal(t, http.StatusOK, w.Code)\n   283→\tbody := w.Body.String()\n   284→\tassert.Contains(t, body, \"run-a1\")\n   285→\tassert.Contains(t, body, \"run-b1\")\n   286→\n   287→\t// With project filter: only matching runs\n   288→\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n   289→\tw = httptest.NewRecorder()\n   290→\th.ServeHTTP(w, req)\n   291→\tassert.Equal(t, http.StatusOK, w.Code)\n   292→\tbody = w.Body.String()\n   293→\tassert.Contains(t, body, \"run-a1\")\n   294→\tassert.Contains(t, body, \"run-a2\")\n   295→\tassert.NotContains(t, body, \"run-b1\")\n   296→}\n   297→\n   298→func TestRunsList_ProjectColumn(t *testing.T) {\n   299→\th, store := setupHandler(t)\n   300→\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n   301→\n   302→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   303→\tw := httptest.NewRecorder()\n   304→\th.ServeHTTP(w, req)\n   305→\tassert.Equal(t, http.StatusOK, w.Code)\n   306→\tbody := w.Body.String()\n   307→\tassert.Contains(t, body, \"myproject\")\n   308→\tassert.Contains(t, body, \"Project\")\n   309→}\n   310→\n   311→func TestAPIRuns_ProjectFilter(t *testing.T) {\n   312→\th, store := setupHandler(t)\n   313→\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   314→\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   315→\n   316→\t// Without filter: all runs\n   317→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   318→\tw := httptest.NewRecorder()\n   319→\th.ServeHTTP(w, req)\n   320→\tassert.Equal(t, http.StatusOK, w.Code)\n   321→\n   322→\tvar allRuns []apiRun\n   323→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n   324→\tassert.Len(t, allRuns, 2)\n   325→\n   326→\t// With filter: only matching\n   327→\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n   328→\tw = httptest.NewRecorder()\n   329→\th.ServeHTTP(w, req)\n   330→\tassert.Equal(t, http.StatusOK, w.Code)\n   331→\n   332→\tvar filtered []apiRun\n   333→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n   334→\tassert.Len(t, filtered, 1)\n   335→\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n   336→\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n   337→\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n   338→}\n   339→\n   340→func setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n   341→\tt.Helper()\n   342→\tstore, err := sqlite.NewStore(\":memory:\")\n   343→\trequire.NoError(t, err)\n   344→\tt.Cleanup(func() { store.Close() })\n   345→\n   346→\tmgr := newMockContainerManager()\n   347→\th, err := NewHandler(store, store, WithContainerManager(mgr))\n   348→\trequire.NoError(t, err)\n   349→\treturn h, store, mgr\n   350→}\n   351→\n   352→func seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n   353→\tt.Helper()\n   354→\tctx := context.Background()\n   355→\trun := domain.NewRun(id, workflow)\n   356→\trun.ProjectDir = projectDir\n   357→\trun.Start()\n   358→\trun.ContainerID = containerID\n   359→\trun.ContainerKept = kept\n   360→\trun.Complete(domain.RunStateSucceeded)\n   361→\trequire.NoError(t, store.CreateRun(ctx, run))\n   362→\tif kept {\n   363→\t\tmgr.containers[containerID] = true\n   364→\t}\n   365→}\n   366→\n   367→func TestRunDetail_ContainerRunning(t *testing.T) {\n   368→\th, store, mgr := setupHandlerWithContainerManager(t)\n   369→\n   370→\tctx := context.Background()\n   371→\trun := domain.NewRun(\"run-cr\", \"develop\")\n   372→\trun.ProjectDir = \"/proj\"\n   373→\trun.Start()\n   374→\trun.ContainerID = \"cid-running\"\n   375→\trequire.NoError(t, store.CreateRun(ctx, run))\n   376→\tmgr.containers[\"cid-running\"] = true\n   377→\tmgr.running[\"cid-running\"] = true\n   378→\n   379→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n   380→\tw := httptest.NewRecorder()\n   381→\th.ServeHTTP(w, req)\n   382→\n   383→\tassert.Equal(t, http.StatusOK, w.Code)\n   384→\tbody := w.Body.String()\n   385→\tassert.Contains(t, body, \"Container running\")\n   386→\tassert.Contains(t, body, `badge-running\">Container running`)\n   387→}\n   388→\n   389→func TestRunDetail_ContainerStopped(t *testing.T) {\n   390→\th, store, mgr := setupHandlerWithContainerManager(t)\n   391→\n   392→\tctx := context.Background()\n   393→\trun := domain.NewRun(\"run-cs\", \"develop\")\n   394→\trun.ProjectDir = \"/proj\"\n   395→\trun.Start()\n   396→\trun.ContainerID = \"cid-stopped\"\n   397→\trun.ContainerKept = false\n   398→\trun.Complete(domain.RunStateSucceeded)\n   399→\trequire.NoError(t, store.CreateRun(ctx, run))\n   400→\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n   401→\n   402→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n   403→\tw := httptest.NewRecorder()\n   404→\th.ServeHTTP(w, req)\n   405→\n   406→\tassert.Equal(t, http.StatusOK, w.Code)\n   407→\tbody := w.Body.String()\n   408→\tassert.Contains(t, body, \"Container stopped\")\n   409→\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n   410→}\n   411→\n   412→func TestRunDetail_ContainerAvailable(t *testing.T) {\n   413→\th, store, mgr := setupHandlerWithContainerManager(t)\n   414→\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n   415→\n   416→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n   417→\tw := httptest.NewRecorder()\n   418→\th.ServeHTTP(w, req)\n   419→\n   420→\tassert.Equal(t, http.StatusOK, w.Code)\n   421→\tbody := w.Body.String()\n   422→\tassert.Contains(t, body, \"Container available\")\n   423→\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n   424→\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n   425→}\n   426→\n   427→func TestRunDetail_ContainerRemoved(t *testing.T) {\n   428→\th, store, _ := setupHandlerWithContainerManager(t)\n   429→\n   430→\tctx := context.Background()\n   431→\trun := domain.NewRun(\"run-c2\", \"develop\")\n   432→\trun.ProjectDir = \"/proj\"\n   433→\trun.Start()\n   434→\trun.ContainerID = \"cid-gone\"\n   435→\trun.ContainerKept = false\n   436→\trun.Complete(domain.RunStateSucceeded)\n   437→\trequire.NoError(t, store.CreateRun(ctx, run))\n   438→\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n   439→\n   440→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n   441→\tw := httptest.NewRecorder()\n   442→\th.ServeHTTP(w, req)\n   443→\n   444→\tassert.Equal(t, http.StatusOK, w.Code)\n   445→\tbody := w.Body.String()\n   446→\tassert.Contains(t, body, \"Container removed\")\n   447→\tassert.Contains(t, body, `badge-pending\">Container removed`)\n   448→}\n   449→\n   450→func TestAPIDeleteContainer_Success(t *testing.T) {\n   451→\th, store, mgr := setupHandlerWithContainerManager(t)\n   452→\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n   453→\n   454→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n   455→\tw := httptest.NewRecorder()\n   456→\th.ServeHTTP(w, req)\n   457→\n   458→\tassert.Equal(t, http.StatusOK, w.Code)\n   459→\n   460→\tvar resp map[string]string\n   461→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n   462→\tassert.Equal(t, \"ok\", resp[\"status\"])\n   463→\n   464→\t// Verify container was removed\n   465→\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n   466→\n   467→\t// Verify run was updated\n   468→\trun, err := store.GetRun(context.Background(), \"run-del1\")\n   469→\trequire.NoError(t, err)\n   470→\tassert.False(t, run.ContainerKept)\n   471→}\n   472→\n   473→func TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n   474→\th, _, _ := setupHandlerWithContainerManager(t)\n   475→\n   476→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n   477→\tw := httptest.NewRecorder()\n   478→\th.ServeHTTP(w, req)\n   479→\n   480→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   481→}\n   482→\n   483→func TestAPIDeleteContainer_NoManager(t *testing.T) {\n   484→\th, store := setupHandler(t) // no container manager\n   485→\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n   486→\n   487→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n   488→\tw := httptest.NewRecorder()\n   489→\th.ServeHTTP(w, req)\n   490→\n   491→\tassert.Equal(t, http.StatusBadRequest, w.Code)\n   492→}\n   493→\n   494→func TestAPIRunDetail_ContainerState(t *testing.T) {\n   495→\th, store, mgr := setupHandlerWithContainerManager(t)\n   496→\n   497→\t// Seed a running container\n   498→\tctx := context.Background()\n   499→\trun := domain.NewRun(\"api-cs1\", \"develop\")\n   500→\trun.ProjectDir = \"/proj\"\n   501→\trun.Start()\n   502→\trun.ContainerID = \"cid-api-running\"\n   503→\trequire.NoError(t, store.CreateRun(ctx, run))\n   504→\tmgr.containers[\"cid-api-running\"] = true\n   505→\tmgr.running[\"cid-api-running\"] = true\n   506→\n   507→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n   508→\tw := httptest.NewRecorder()\n   509→\th.ServeHTTP(w, req)\n   510→\n   511→\tassert.Equal(t, http.StatusOK, w.Code)\n   512→\n   513→\tvar detail apiRunDetail\n   514→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   515→\tassert.Equal(t, \"running\", detail.ContainerState)\n   516→\n   517→\t// Now stop it\n   518→\tmgr.running[\"cid-api-running\"] = false\n   519→\n   520→\tw = httptest.NewRecorder()\n   521→\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n   522→\n   523→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   524→\tassert.Equal(t, \"stopped\", detail.ContainerState)\n   525→}\n   526→\n   527→func TestRunsList_ContainerCount(t *testing.T) {\n   528→\th, store, mgr := setupHandlerWithContainerManager(t)\n   529→\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n   530→\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n   531→\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n   532→\n   533→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   534→\tw := httptest.NewRecorder()\n   535→\th.ServeHTTP(w, req)\n   536→\n   537→\tassert.Equal(t, http.StatusOK, w.Code)\n   538→\tbody := w.Body.String()\n   539→\t// alpha has 2 retained containers\n   540→\tassert.Contains(t, body, \"2 containers\")\n   541→\t// beta has 0, so no count should appear\n   542→\tassert.NotContains(t, body, \"0 container\")\n   543→}\n   544→\n   545→func TestAPIProjects(t *testing.T) {\n   546→\th, store := setupHandler(t)\n   547→\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   548→\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   549→\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   550→\n   551→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   552→\tw := httptest.NewRecorder()\n   553→\th.ServeHTTP(w, req)\n   554→\tassert.Equal(t, http.StatusOK, w.Code)\n   555→\n   556→\ttype apiHealth struct {\n   557→\t\tStatus string `json:\"status\"`\n   558→\t\tPassed int    `json:\"passed\"`\n   559→\t\tFailed int    `json:\"failed\"`\n   560→\t\tTotal  int    `json:\"total\"`\n   561→\t}\n   562→\ttype project struct {\n   563→\t\tDir         string    `json:\"dir\"`\n   564→\t\tLabel       string    `json:\"label\"`\n   565→\t\tHealth      apiHealth `json:\"health\"`\n   566→\t\tActiveCount int       `json:\"active_count\"`\n   567→\t}\n   568→\tvar projects []project\n   569→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   570→\tassert.Len(t, projects, 2)\n   571→\n   572→\tbyDir := map[string]project{}\n   573→\tfor _, p := range projects {\n   574→\t\tbyDir[p.Dir] = p\n   575→\t}\n   576→\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n   577→\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n   578→\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n   579→\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n   580→\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n   581→\t// beta has 1 running = blue (all in-progress), 1 active\n   582→\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n   583→\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n   584→}\n   585→\n   586→func TestProjectOverview_WithProjects(t *testing.T) {\n   587→\th, store := setupHandler(t)\n   588→\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   589→\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   590→\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   591→\n   592→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   593→\tw := httptest.NewRecorder()\n   594→\th.ServeHTTP(w, req)\n   595→\n   596→\tassert.Equal(t, http.StatusOK, w.Code)\n   597→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   598→\tbody := w.Body.String()\n   599→\t// Project cards should be present\n   600→\tassert.Contains(t, body, \"project-card\")\n   601→\tassert.Contains(t, body, \"alpha\")\n   602→\tassert.Contains(t, body, \"beta\")\n   603→\t// Health dots\n   604→\tassert.Contains(t, body, \"health-dot\")\n   605→\t// Run history dots\n   606→\tassert.Contains(t, body, \"run-dot\")\n   607→\t// Quick actions\n   608→\tassert.Contains(t, body, \"View Runs\")\n   609→}\n   610→\n   611→func TestProjectOverview_Empty(t *testing.T) {\n   612→\th, _ := setupHandler(t)\n   613→\n   614→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   615→\tw := httptest.NewRecorder()\n   616→\th.ServeHTTP(w, req)\n   617→\n   618→\tassert.Equal(t, http.StatusOK, w.Code)\n   619→\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n   620→}\n   621→\n   622→func TestHealthColor(t *testing.T) {\n   623→\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n   624→\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n   625→\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n   626→\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n   627→\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n   628→\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n   629→}\n   630→\n   631→func TestAPIProjects_HealthData(t *testing.T) {\n   632→\th, store := setupHandler(t)\n   633→\t// alpha: 3 succeeded, 1 failed → yellow\n   634→\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   635→\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   636→\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   637→\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   638→\n   639→\t// beta: all succeeded → green\n   640→\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   641→\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   642→\n   643→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   644→\tw := httptest.NewRecorder()\n   645→\th.ServeHTTP(w, req)\n   646→\tassert.Equal(t, http.StatusOK, w.Code)\n   647→\n   648→\ttype health struct {\n   649→\t\tStatus string `json:\"status\"`\n   650→\t\tPassed int    `json:\"passed\"`\n   651→\t\tFailed int    `json:\"failed\"`\n   652→\t\tTotal  int    `json:\"total\"`\n   653→\t}\n   654→\ttype project struct {\n   655→\t\tDir    string `json:\"dir\"`\n   656→\t\tLabel  string `json:\"label\"`\n   657→\t\tHealth health `json:\"health\"`\n   658→\t}\n   659→\tvar projects []project\n   660→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   661→\tassert.Len(t, projects, 2)\n   662→\n   663→\tbyDir := map[string]project{}\n   664→\tfor _, p := range projects {\n   665→\t\tbyDir[p.Dir] = p\n   666→\t}\n   667→\n   668→\talpha := byDir[\"/home/user/alpha\"]\n   669→\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n   670→\tassert.Equal(t, 3, alpha.Health.Passed)\n   671→\tassert.Equal(t, 1, alpha.Health.Failed)\n   672→\tassert.Equal(t, 4, alpha.Health.Total)\n   673→\n   674→\tbeta := byDir[\"/home/user/beta\"]\n   675→\tassert.Equal(t, \"green\", beta.Health.Status)\n   676→\tassert.Equal(t, 2, beta.Health.Passed)\n   677→\tassert.Equal(t, 0, beta.Health.Failed)\n   678→\tassert.Equal(t, 2, beta.Health.Total)\n   679→}\n   680→\n   681→func TestResolveFileRef(t *testing.T) {\n   682→\t// Create a temp directory with a test file\n   683→\tdir := t.TempDir()\n   684→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \"prompts\"), 0o755))\n   685→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \"prompts\", \"implement.md\"), []byte(\"# Implement\\nDo the thing.\"), 0o644))\n   686→\n   687→\tt.Run(\"file() reference resolves to contents\", func(t *testing.T) {\n   688→\t\tcontent, err := resolveFileRef(`file(\"prompts/implement.md\")`, dir)\n   689→\t\trequire.NoError(t, err)\n   690→\t\tassert.Equal(t, \"# Implement\\nDo the thing.\", content)\n   691→\t})\n   692→\n   693→\tt.Run(\"file() reference with missing file returns error\", func(t *testing.T) {\n   694→\t\t_, err := resolveFileRef(`file(\"prompts/nonexistent.md\")`, dir)\n   695→\t\tassert.Error(t, err)\n   696→\t})\n   697→\n   698→\tt.Run(\"plain string returned as-is\", func(t *testing.T) {\n   699→\t\tcontent, err := resolveFileRef(\"echo hello\", dir)\n   700→\t\trequire.NoError(t, err)\n   701→\t\tassert.Equal(t, \"echo hello\", content)\n   702→\t})\n   703→\n   704→\tt.Run(\"quoted string returned as-is\", func(t *testing.T) {\n   705→\t\tcontent, err := resolveFileRef(`\"some value\"`, dir)\n   706→\t\trequire.NoError(t, err)\n   707→\t\tassert.Equal(t, `\"some value\"`, content)\n   708→\t})\n   709→}\n   710→\n   711→func TestAPIStepContent_FileRef(t *testing.T) {\n   712→\th, store := setupHandler(t)\n   713→\n   714→\t// Create a temp project directory with a workflow and prompt file\n   715→\tdir := t.TempDir()\n   716→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0o755))\n   717→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"Build the feature.\"), 0o644))\n   718→\n   719→\tworkflowContent := `workflow \"develop\" {\n   720→    step implement {\n   721→        prompt = file(\".cloche/prompts/implement.md\")\n   722→        results = [success, fail]\n   723→    }\n   724→    implement:success -> done\n   725→    implement:fail -> abort\n   726→}\n   727→`\n   728→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"), []byte(workflowContent), 0o644))\n   729→\n   730→\t// Seed a run so the project is known\n   731→\tseedRunWithProject(t, store, \"sc-1\", \"develop\", domain.RunStateRunning, dir)\n   732→\n   733→\t// Request step content\n   734→\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+filepath.Base(dir)+\"/workflows/develop/steps/implement/content\", nil)\n   735→\tw := httptest.NewRecorder()\n   736→\th.ServeHTTP(w, req)\n   737→\n   738→\tassert.Equal(t, http.StatusOK, w.Code)\n   739→\tassert.Equal(t, \"Build the feature.\", w.Body.String())\n   740→}\n   741→\n   742→func TestProjectRuns(t *testing.T) {\n   743→\th, store := setupHandler(t)\n   744→\tseedRunWithProject(t, store, \"pr-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   745→\tseedRunWithProject(t, store, \"pr-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   746→\tseedRunWithProject(t, store, \"pr-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   747→\n   748→\t// GET /projects/alpha/runs should show only alpha's runs\n   749→\treq := httptest.NewRequest(\"GET\", \"/projects/alpha/runs\", nil)\n   750→\tw := httptest.NewRecorder()\n   751→\th.ServeHTTP(w, req)\n   752→\tassert.Equal(t, http.StatusOK, w.Code)\n   753→\tbody := w.Body.String()\n   754→\tassert.Contains(t, body, \"pr-a1\")\n   755→\tassert.Contains(t, body, \"pr-a2\")\n   756→\tassert.NotContains(t, body, \"pr-b1\")\n   757→\n   758→\t// GET /projects/nonexistent/runs should 404\n   759→\treq = httptest.NewRequest(\"GET\", \"/projects/nonexistent/runs\", nil)\n   760→\tw = httptest.NewRecorder()\n   761→\th.ServeHTTP(w, req)\n   762→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   763→}\n   764→\n   765→func TestAPIProjects_HealthNoRuns(t *testing.T) {\n   766→\th, _ := setupHandler(t)\n   767→\n   768→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   769→\tw := httptest.NewRecorder()\n   770→\th.ServeHTTP(w, req)\n   771→\tassert.Equal(t, http.StatusOK, w.Code)\n   772→\n   773→\t// No projects means empty array\n   774→\ttype project struct {\n   775→\t\tDir   string `json:\"dir\"`\n   776→\t\tLabel string `json:\"label\"`\n   777→\t}\n   778→\tvar projects []project\n   779→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   780→\tassert.Empty(t, projects)\n   781→}\n   782→"}]},"parent_tool_use_id":null,"session_id":"b57dc17a-fc9e-4ed7-b4d0-831f399e4ca7","uuid":"00f6ff5f-7c60-4796-a9ad-4ca5fc59b537","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler_test.go","content":"package web\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// mockContainerManager implements ContainerManager for testing.\ntype mockContainerManager struct {\n\tcontainers map[string]bool // containerID -> exists\n\trunning    map[string]bool // containerID -> running\n\tremoved    []string\n}\n\nfunc newMockContainerManager() *mockContainerManager {\n\treturn &mockContainerManager{\n\t\tcontainers: map[string]bool{},\n\t\trunning:    map[string]bool{},\n\t}\n}\n\nfunc (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n\treturn \"mock logs\", nil\n}\n\nfunc (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n\tif !m.containers[containerID] {\n\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\tdelete(m.containers, containerID)\n\tm.removed = append(m.removed, containerID)\n\treturn nil\n}\n\nfunc (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n\tif !m.containers[containerID] {\n\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n}\n\nfunc setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store)\n\trequire.NoError(t, err)\n\treturn h, store\n}\n\nfunc seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n\tt.Helper()\n\tseedRunWithProject(t, store, id, workflow, state, \"\")\n}\n\nfunc seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\tif state != domain.RunStatePending {\n\t\trun.Start()\n\t\trun.ContainerID = \"abc123def456789\"\n\t}\n\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n\t\trun.Complete(state)\n\t}\n\tif state == domain.RunStateFailed {\n\t\trun.ErrorMessage = \"something went wrong\"\n\t}\n\trequire.NoError(t, store.CreateRun(ctx, run))\n}\n\nfunc TestRunsList_WithRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"test-run-1\")\n\tassert.Contains(t, body, \"test-run-2\")\n\tassert.Contains(t, body, \"badge-running\")\n\tassert.Contains(t, body, \"badge-succeeded\")\n\tassert.Contains(t, body, \"develop\")\n\tassert.Contains(t, body, \"deploy\")\n}\n\nfunc TestRunsList_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n}\n\nfunc TestRunDetail_WithCaptures(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"implement\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-detail-1\")\n\tassert.Contains(t, body, \"implement\")\n}\n\nfunc TestRunDetail_NotFound(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar runs []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n\tassert.Len(t, runs, 2)\n\n\tids := map[string]bool{}\n\tfor _, r := range runs {\n\t\tids[r.ID] = true\n\t}\n\tassert.True(t, ids[\"api-run-1\"])\n\tassert.True(t, ids[\"api-run-2\"])\n}\n\nfunc TestAPIRunDetail(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"build\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"api-detail-1\", detail.ID)\n\tassert.Equal(t, \"running\", detail.State)\n\tassert.Len(t, detail.Steps, 1)\n\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n\tassert.NotEmpty(t, detail.Steps[0].Duration)\n}\n\nfunc TestStaticCSS(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \":root\")\n\tassert.Contains(t, w.Body.String(), \"badge-running\")\n}\n\nfunc TestHelpers(t *testing.T) {\n\tt.Run(\"stateColor\", func(t *testing.T) {\n\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n\t})\n\n\tt.Run(\"formatTime\", func(t *testing.T) {\n\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n\t})\n\n\tt.Run(\"formatDuration\", func(t *testing.T) {\n\t\tnow := time.Now()\n\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n\t})\n\n\tt.Run(\"truncate\", func(t *testing.T) {\n\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n\t})\n\n\tt.Run(\"shortContainerID\", func(t *testing.T) {\n\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n\t})\n\n\tt.Run(\"projectLabels\", func(t *testing.T) {\n\t\t// No conflict: show base name only\n\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n\n\t\t// Conflict: two dirs share the same base name\n\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n\n\t\t// Mixed: some conflict, some don't\n\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n\n\t\t// Empty list\n\t\tlabels = projectLabels(nil)\n\t\tassert.Empty(t, labels)\n\t})\n}\n\nfunc TestRunsList_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs shown\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-b1\")\n\n\t// With project filter: only matching runs\n\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody = w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-a2\")\n\tassert.NotContains(t, body, \"run-b1\")\n}\n\nfunc TestRunsList_ProjectColumn(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"myproject\")\n\tassert.Contains(t, body, \"Project\")\n}\n\nfunc TestAPIRuns_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar allRuns []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n\tassert.Len(t, allRuns, 2)\n\n\t// With filter: only matching\n\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar filtered []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n\tassert.Len(t, filtered, 1)\n\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n}\n\nfunc setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\tmgr := newMockContainerManager()\n\th, err := NewHandler(store, store, WithContainerManager(mgr))\n\trequire.NoError(t, err)\n\treturn h, store, mgr\n}\n\nfunc seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\trun.Start()\n\trun.ContainerID = containerID\n\trun.ContainerKept = kept\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tif kept {\n\t\tmgr.containers[containerID] = true\n\t}\n}\n\nfunc TestRunDetail_ContainerRunning(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cr\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-running\"] = true\n\tmgr.running[\"cid-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container running\")\n\tassert.Contains(t, body, `badge-running\">Container running`)\n}\n\nfunc TestRunDetail_ContainerStopped(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cs\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-stopped\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container stopped\")\n\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n}\n\nfunc TestRunDetail_ContainerAvailable(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container available\")\n\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n}\n\nfunc TestRunDetail_ContainerRemoved(t *testing.T) {\n\th, store, _ := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-c2\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-gone\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container removed\")\n\tassert.Contains(t, body, `badge-pending\">Container removed`)\n}\n\nfunc TestAPIDeleteContainer_Success(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"ok\", resp[\"status\"])\n\n\t// Verify container was removed\n\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n\n\t// Verify run was updated\n\trun, err := store.GetRun(context.Background(), \"run-del1\")\n\trequire.NoError(t, err)\n\tassert.False(t, run.ContainerKept)\n}\n\nfunc TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n\th, _, _ := setupHandlerWithContainerManager(t)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIDeleteContainer_NoManager(t *testing.T) {\n\th, store := setupHandler(t) // no container manager\n\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusBadRequest, w.Code)\n}\n\nfunc TestAPIRunDetail_ContainerState(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\t// Seed a running container\n\tctx := context.Background()\n\trun := domain.NewRun(\"api-cs1\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-api-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-api-running\"] = true\n\tmgr.running[\"cid-api-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"running\", detail.ContainerState)\n\n\t// Now stop it\n\tmgr.running[\"cid-api-running\"] = false\n\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"stopped\", detail.ContainerState)\n}\n\nfunc TestRunsList_ContainerCount(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\t// alpha has 2 retained containers\n\tassert.Contains(t, body, \"2 containers\")\n\t// beta has 0, so no count should appear\n\tassert.NotContains(t, body, \"0 container\")\n}\n\nfunc TestAPIProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n\t// beta has 1 running = blue (all in-progress), 1 active\n\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n}\n\nfunc TestProjectOverview_WithProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\t// Project cards should be present\n\tassert.Contains(t, body, \"project-card\")\n\tassert.Contains(t, body, \"alpha\")\n\tassert.Contains(t, body, \"beta\")\n\t// Health dots\n\tassert.Contains(t, body, \"health-dot\")\n\t// Run history dots\n\tassert.Contains(t, body, \"run-dot\")\n\t// Quick actions\n\tassert.Contains(t, body, \"View Runs\")\n}\n\nfunc TestProjectOverview_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n}\n\nfunc TestHealthColor(t *testing.T) {\n\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n}\n\nfunc TestAPIProjects_HealthData(t *testing.T) {\n\th, store := setupHandler(t)\n\t// alpha: 3 succeeded, 1 failed → yellow\n\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\t// beta: all succeeded → green\n\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype health struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir    string `json:\"dir\"`\n\t\tLabel  string `json:\"label\"`\n\t\tHealth health `json:\"health\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\n\talpha := byDir[\"/home/user/alpha\"]\n\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n\tassert.Equal(t, 3, alpha.Health.Passed)\n\tassert.Equal(t, 1, alpha.Health.Failed)\n\tassert.Equal(t, 4, alpha.Health.Total)\n\n\tbeta := byDir[\"/home/user/beta\"]\n\tassert.Equal(t, \"green\", beta.Health.Status)\n\tassert.Equal(t, 2, beta.Health.Passed)\n\tassert.Equal(t, 0, beta.Health.Failed)\n\tassert.Equal(t, 2, beta.Health.Total)\n}\n\nfunc TestResolveFileRef(t *testing.T) {\n\t// Create a temp directory with a test file\n\tdir := t.TempDir()\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \"prompts\"), 0o755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \"prompts\", \"implement.md\"), []byte(\"# Implement\\nDo the thing.\"), 0o644))\n\n\tt.Run(\"file() reference resolves to contents\", func(t *testing.T) {\n\t\tcontent, err := resolveFileRef(`file(\"prompts/implement.md\")`, dir)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, \"# Implement\\nDo the thing.\", content)\n\t})\n\n\tt.Run(\"file() reference with missing file returns error\", func(t *testing.T) {\n\t\t_, err := resolveFileRef(`file(\"prompts/nonexistent.md\")`, dir)\n\t\tassert.Error(t, err)\n\t})\n\n\tt.Run(\"plain string returned as-is\", func(t *testing.T) {\n\t\tcontent, err := resolveFileRef(\"echo hello\", dir)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, \"echo hello\", content)\n\t})\n\n\tt.Run(\"quoted string returned as-is\", func(t *testing.T) {\n\t\tcontent, err := resolveFileRef(`\"some value\"`, dir)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, `\"some value\"`, content)\n\t})\n}\n\nfunc TestAPIStepContent_FileRef(t *testing.T) {\n\th, store := setupHandler(t)\n\n\t// Create a temp project directory with a workflow and prompt file\n\tdir := t.TempDir()\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0o755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"Build the feature.\"), 0o644))\n\n\tworkflowContent := `workflow \"develop\" {\n    step implement {\n        prompt = file(\".cloche/prompts/implement.md\")\n        results = [success, fail]\n    }\n    implement:success -> done\n    implement:fail -> abort\n}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"), []byte(workflowContent), 0o644))\n\n\t// Seed a run so the project is known\n\tseedRunWithProject(t, store, \"sc-1\", \"develop\", domain.RunStateRunning, dir)\n\n\t// Request step content\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+filepath.Base(dir)+\"/workflows/develop/steps/implement/content\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Equal(t, \"Build the feature.\", w.Body.String())\n}\n\nfunc TestProjectRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"pr-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"pr-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"pr-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// GET /projects/alpha/runs should show only alpha's runs\n\treq := httptest.NewRequest(\"GET\", \"/projects/alpha/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"pr-a1\")\n\tassert.Contains(t, body, \"pr-a2\")\n\tassert.NotContains(t, body, \"pr-b1\")\n\n\t// GET /projects/nonexistent/runs should 404\n\treq = httptest.NewRequest(\"GET\", \"/projects/nonexistent/runs\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIProjects_HealthNoRuns(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\t// No projects means empty array\n\ttype project struct {\n\t\tDir   string `json:\"dir\"`\n\t\tLabel string `json:\"label\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Empty(t, projects)\n}\n","numLines":782,"startLine":1,"totalLines":782}}}
