{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LxQ4DztS5GNyZjsHJNdmHY","type":"tool_result","content":"     1→package domain\n     2→\n     3→import (\n     4→\t\"strings\"\n     5→\t\"time\"\n     6→)\n     7→\n     8→type RunState string\n     9→\n    10→const (\n    11→\tRunStatePending   RunState = \"pending\"\n    12→\tRunStateRunning   RunState = \"running\"\n    13→\tRunStateSucceeded RunState = \"succeeded\"\n    14→\tRunStateFailed    RunState = \"failed\"\n    15→\tRunStateCancelled RunState = \"cancelled\"\n    16→)\n    17→\n    18→type StepExecution struct {\n    19→\tStepName    string\n    20→\tResult      string\n    21→\tStartedAt   time.Time\n    22→\tCompletedAt time.Time\n    23→\tLogs        string\n    24→\tGitRef      string // output state\n    25→}\n    26→\n    27→func (e *StepExecution) Duration() time.Duration {\n    28→\treturn e.CompletedAt.Sub(e.StartedAt)\n    29→}\n    30→\n    31→type Run struct {\n    32→\tID             string\n    33→\tWorkflowName   string\n    34→\tState          RunState\n    35→\tActiveSteps    []string\n    36→\tStepExecutions []*StepExecution\n    37→\tStartedAt      time.Time\n    38→\tCompletedAt    time.Time\n    39→\tProjectDir     string\n    40→\tErrorMessage   string\n    41→\tContainerID    string\n    42→\tBaseSHA        string // Git HEAD at run start, for result branch creation\n    43→\tContainerKept  bool   // true when the container was retained after run completion\n    44→}\n    45→\n    46→func NewRun(id, workflowName string) *Run {\n    47→\treturn &Run{\n    48→\t\tID:           id,\n    49→\t\tWorkflowName: workflowName,\n    50→\t\tState:        RunStatePending,\n    51→\t}\n    52→}\n    53→\n    54→func (r *Run) Start() {\n    55→\tr.State = RunStateRunning\n    56→\tr.StartedAt = time.Now()\n    57→}\n    58→\n    59→func (r *Run) RecordStepStart(stepName string) {\n    60→\tr.ActiveSteps = append(r.ActiveSteps, stepName)\n    61→\tr.StepExecutions = append(r.StepExecutions, &StepExecution{\n    62→\t\tStepName:  stepName,\n    63→\t\tStartedAt: time.Now(),\n    64→\t})\n    65→}\n    66→\n    67→func (r *Run) RecordStepComplete(stepName, result string) {\n    68→\t// Remove from active steps\n    69→\tfor i, name := range r.ActiveSteps {\n    70→\t\tif name == stepName {\n    71→\t\t\tr.ActiveSteps = append(r.ActiveSteps[:i], r.ActiveSteps[i+1:]...)\n    72→\t\t\tbreak\n    73→\t\t}\n    74→\t}\n    75→\t// Mark execution complete\n    76→\tfor i := len(r.StepExecutions) - 1; i >= 0; i-- {\n    77→\t\tif r.StepExecutions[i].StepName == stepName && r.StepExecutions[i].CompletedAt.IsZero() {\n    78→\t\t\tr.StepExecutions[i].Result = result\n    79→\t\t\tr.StepExecutions[i].CompletedAt = time.Now()\n    80→\t\t\treturn\n    81→\t\t}\n    82→\t}\n    83→}\n    84→\n    85→// ActiveStepsString returns a comma-separated representation of active steps\n    86→// for backward-compatible serialization.\n    87→func (r *Run) ActiveStepsString() string {\n    88→\treturn strings.Join(r.ActiveSteps, \",\")\n    89→}\n    90→\n    91→// SetActiveStepsFromString parses a comma-separated string into ActiveSteps.\n    92→func (r *Run) SetActiveStepsFromString(s string) {\n    93→\tif s == \"\" {\n    94→\t\tr.ActiveSteps = nil\n    95→\t\treturn\n    96→\t}\n    97→\tr.ActiveSteps = strings.Split(s, \",\")\n    98→}\n    99→\n   100→func (r *Run) Complete(state RunState) {\n   101→\tr.State = state\n   102→\tr.CompletedAt = time.Now()\n   103→}\n   104→\n   105→func (r *Run) Fail(msg string) {\n   106→\tr.State = RunStateFailed\n   107→\tr.CompletedAt = time.Now()\n   108→\tr.ErrorMessage = msg\n   109→}\n   110→"}]},"parent_tool_use_id":"toolu_018kVm9VM4TvBwPKughR6bnn","session_id":"044f0678-c89a-4054-98f9-8679665edf9d","uuid":"e5defbe0-7fc6-4363-92e7-ae06c867f4c3"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V5SdcM9t9Uv94LoaP8Rpum","type":"tool_result","content":"     1→package domain\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"strings\"\n     6→)\n     7→\n     8→const (\n     9→\tStepDone  = \"done\"\n    10→\tStepAbort = \"abort\"\n    11→)\n    12→\n    13→type StepType string\n    14→\n    15→const (\n    16→\tStepTypeAgent    StepType = \"agent\"\n    17→\tStepTypeScript   StepType = \"script\"\n    18→\tStepTypeWorkflow StepType = \"workflow\"\n    19→)\n    20→\n    21→type Step struct {\n    22→\tName    string\n    23→\tType    StepType\n    24→\tResults []string\n    25→\tConfig  map[string]string\n    26→}\n    27→\n    28→type Wire struct {\n    29→\tFrom   string\n    30→\tResult string\n    31→\tTo     string\n    32→}\n    33→\n    34→type CollectMode string\n    35→\n    36→const (\n    37→\tCollectAll CollectMode = \"all\"\n    38→\tCollectAny CollectMode = \"any\"\n    39→)\n    40→\n    41→type WireCondition struct {\n    42→\tStep   string\n    43→\tResult string\n    44→}\n    45→\n    46→type Collect struct {\n    47→\tMode       CollectMode\n    48→\tConditions []WireCondition\n    49→\tTo         string\n    50→}\n    51→\n    52→type Workflow struct {\n    53→\tName      string\n    54→\tSteps     map[string]*Step\n    55→\tWiring    []Wire\n    56→\tCollects  []Collect\n    57→\tEntryStep string\n    58→\tConfig    map[string]string // workflow-level config (e.g. \"container.image\")\n    59→}\n    60→\n    61→func (w *Workflow) Validate() error {\n    62→\tif w.EntryStep == \"\" {\n    63→\t\treturn fmt.Errorf(\"workflow %q: no entry step defined\", w.Name)\n    64→\t}\n    65→\tif _, ok := w.Steps[w.EntryStep]; !ok {\n    66→\t\treturn fmt.Errorf(\"workflow %q: entry step %q not found\", w.Name, w.EntryStep)\n    67→\t}\n    68→\n    69→\twired := make(map[string]map[string]bool)\n    70→\treachable := map[string]bool{w.EntryStep: true}\n    71→\tfor _, wire := range w.Wiring {\n    72→\t\tif wired[wire.From] == nil {\n    73→\t\t\twired[wire.From] = make(map[string]bool)\n    74→\t\t}\n    75→\t\twired[wire.From][wire.Result] = true\n    76→\t\tif wire.To != StepDone && wire.To != StepAbort {\n    77→\t\t\treachable[wire.To] = true\n    78→\t\t}\n    79→\t}\n    80→\n    81→\t// Validate collects and count their results as wired\n    82→\tfor _, c := range w.Collects {\n    83→\t\t// Validate target step exists\n    84→\t\tif c.To != StepDone && c.To != StepAbort {\n    85→\t\t\tif _, ok := w.Steps[c.To]; !ok {\n    86→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect target step %q not found\", w.Name, c.To)\n    87→\t\t\t}\n    88→\t\t\treachable[c.To] = true\n    89→\t\t}\n    90→\n    91→\t\tfor _, cond := range c.Conditions {\n    92→\t\t\t// Validate condition step exists\n    93→\t\t\tstep, ok := w.Steps[cond.Step]\n    94→\t\t\tif !ok {\n    95→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references unknown step %q\", w.Name, cond.Step)\n    96→\t\t\t}\n    97→\t\t\t// Validate condition result is declared\n    98→\t\t\tfound := false\n    99→\t\t\tfor _, r := range step.Results {\n   100→\t\t\t\tif r == cond.Result {\n   101→\t\t\t\t\tfound = true\n   102→\t\t\t\t\tbreak\n   103→\t\t\t\t}\n   104→\t\t\t}\n   105→\t\t\tif !found {\n   106→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references undeclared result %q on step %q\", w.Name, cond.Result, cond.Step)\n   107→\t\t\t}\n   108→\t\t\t// Mark as wired so the \"every result must be wired\" check passes\n   109→\t\t\tif wired[cond.Step] == nil {\n   110→\t\t\t\twired[cond.Step] = make(map[string]bool)\n   111→\t\t\t}\n   112→\t\t\twired[cond.Step][cond.Result] = true\n   113→\t\t}\n   114→\t}\n   115→\n   116→\tfor name, step := range w.Steps {\n   117→\t\tfor _, result := range step.Results {\n   118→\t\t\tif !wired[name][result] {\n   119→\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q result %q is not wired\", w.Name, name, result)\n   120→\t\t\t}\n   121→\t\t}\n   122→\t}\n   123→\n   124→\tfor name := range w.Steps {\n   125→\t\tif !reachable[name] {\n   126→\t\t\treturn fmt.Errorf(\"workflow %q: step %q is orphaned (unreachable)\", w.Name, name)\n   127→\t\t}\n   128→\t}\n   129→\n   130→\treturn nil\n   131→}\n   132→\n   133→// knownStepConfigKeys lists recognized step-level config keys.\n   134→// Keys with a \"container.\" prefix are also allowed.\n   135→var knownStepConfigKeys = map[string]bool{\n   136→\t\"prompt\":        true,\n   137→\t\"run\":           true,\n   138→\t\"max_attempts\":  true,\n   139→\t\"timeout\":       true,\n   140→\t\"agent_command\": true,\n   141→\t\"agent_args\":    true,\n   142→\t\"results\":       true,\n   143→\t\"feedback\":      true,\n   144→\t\"workflow_name\": true,\n   145→\t\"prompt_step\":   true,\n   146→}\n   147→\n   148→// ValidateConfig checks step config keys against known keys and returns\n   149→// warnings for any unrecognized keys (likely typos).\n   150→func (w *Workflow) ValidateConfig() []string {\n   151→\tvar warnings []string\n   152→\tfor name, step := range w.Steps {\n   153→\t\tfor key := range step.Config {\n   154→\t\t\tif knownStepConfigKeys[key] {\n   155→\t\t\t\tcontinue\n   156→\t\t\t}\n   157→\t\t\tif strings.HasPrefix(key, \"container.\") {\n   158→\t\t\t\tcontinue\n   159→\t\t\t}\n   160→\t\t\twarnings = append(warnings, fmt.Sprintf(\n   161→\t\t\t\t\"workflow %q: step %q has unrecognized config key %q\", w.Name, name, key))\n   162→\t\t}\n   163→\t}\n   164→\treturn warnings\n   165→}\n   166→\n   167→// NextSteps returns all target step names wired from the given (stepName, result) pair.\n   168→// Multiple targets indicate fanout — parallel branches launched by the engine.\n   169→func (w *Workflow) NextSteps(stepName, result string) ([]string, error) {\n   170→\tvar targets []string\n   171→\tfor _, wire := range w.Wiring {\n   172→\t\tif wire.From == stepName && wire.Result == result {\n   173→\t\t\ttargets = append(targets, wire.To)\n   174→\t\t}\n   175→\t}\n   176→\tif len(targets) == 0 {\n   177→\t\treturn nil, fmt.Errorf(\"workflow %q: no wiring for step %q result %q\", w.Name, stepName, result)\n   178→\t}\n   179→\treturn targets, nil\n   180→}\n   181→\n   182→// Deprecated: NextStep returns the first target only. Use NextSteps for fanout support.\n   183→func (w *Workflow) NextStep(stepName, result string) (string, error) {\n   184→\ttargets, err := w.NextSteps(stepName, result)\n   185→\tif err != nil {\n   186→\t\treturn \"\", err\n   187→\t}\n   188→\treturn targets[0], nil\n   189→}\n   190→"}]},"parent_tool_use_id":"toolu_018kVm9VM4TvBwPKughR6bnn","session_id":"044f0678-c89a-4054-98f9-8679665edf9d","uuid":"7a6879a2-7c67-40b8-bc17-55e09dfb3cd0"}
