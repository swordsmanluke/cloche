tassert.Equal(t, http.StatusNotImplemented, w.Code)\n   578→\n   579→\t\tvar result map[string]string\n   580→\t\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   581→\t\tassert.Equal(t, \"orchestrator not configured\", result[\"error\"])\n   582→\t})\n   583→\n   584→\tt.Run(\"returns 404 when project not found\", func(t *testing.T) {\n   585→\t\tstore, err := sqlite.NewStore(\":memory:\")\n   586→\t\trequire.NoError(t, err)\n   587→\t\tt.Cleanup(func() { store.Close() })\n   588→\n   589→\t\torchestrateFn := func(ctx context.Context, projectDir string) (int, error) {\n   590→\t\t\treturn 0, nil\n   591→\t\t}\n   592→\n   593→\t\th, err := NewHandler(store, store, WithOrchestrateFunc(orchestrateFn))\n   594→\t\trequire.NoError(t, err)\n   595→\n   596→\t\treq := httptest.NewRequest(\"POST\", \"/api/projects/nonexistent/trigger\", nil)\n   597→\t\tw := httptest.NewRecorder()\n   598→\t\th.ServeHTTP(w, req)\n   599→\n   600→\t\tassert.Equal(t, http.StatusNotFound, w.Code)\n   601→\t})\n   602→}\n   603→\n   604→func TestHealthColor(t *testing.T) {\n   605→\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n   606→\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))"}]},"parent_tool_use_id":null,"session_id":"b087b9cf-0b89-4209-a323-a81546a0b0f9","uuid":"8dc55fd3-4fd4-41ed-bfe4-eee39c24fbad","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler_test.go","content":"func TestAPITriggerOrchestrator(t *testing.T) {\n\tt.Run(\"calls orchestrateFn and returns dispatched count\", func(t *testing.T) {\n\t\tstore, err := sqlite.NewStore(\":memory:\")\n\t\trequire.NoError(t, err)\n\t\tt.Cleanup(func() { store.Close() })\n\n\t\t// Seed a project so ListProjects returns it.\n\t\tseedRunWithProject(t, store, \"orch1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\t\tvar calledWith string\n\t\torchestrateFn := func(ctx context.Context, projectDir string) (int, error) {\n\t\t\tcalledWith = projectDir\n\t\t\treturn 3, nil\n\t\t}\n\n\t\th, err := NewHandler(store, store, WithOrchestrateFunc(orchestrateFn))\n\t\trequire.NoError(t, err)\n\n\t\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n\t\tw := httptest.NewRecorder()\n\t\th.ServeHTTP(w, req)\n\n\t\tassert.Equal(t, http.StatusAccepted, w.Code)\n\t\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\t\tassert.Equal(t, \"/home/user/myproject\", calledWith)\n\n\t\tvar result map[string]any\n\t\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\t\tassert.Equal(t, \"accepted\", result[\"status\"])\n\t\tassert.Equal(t, \"myproject\", result[\"project\"])\n\t\tassert.Equal(t, float64(3), result[\"dispatched\"])\n\t})\n\n\tt.Run(\"returns 501 when orchestrateFn is nil\", func(t *testing.T) {\n\t\th, _ := setupHandler(t)\n\n\t\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n\t\tw := httptest.NewRecorder()\n\t\th.ServeHTTP(w, req)\n\n\t\tassert.Equal(t, http.StatusNotImplemented, w.Code)\n\n\t\tvar result map[string]string\n\t\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\t\tassert.Equal(t, \"orchestrator not configured\", result[\"error\"])\n\t})\n\n\tt.Run(\"returns 404 when project not found\", func(t *testing.T) {\n\t\tstore, err := sqlite.NewStore(\":memory:\")\n\t\trequire.NoError(t, err)\n\t\tt.Cleanup(func() { store.Close() })\n\n\t\torchestrateFn := func(ctx context.Context, projectDir string) (int, error) {\n\t\t\treturn 0, nil\n\t\t}\n\n\t\th, err := NewHandler(store, store, WithOrchestrateFunc(orchestrateFn))\n\t\trequire.NoError(t, err)\n\n\t\treq := httptest.NewRequest(\"POST\", \"/api/projects/nonexistent/trigger\", nil)\n\t\tw := httptest.NewRecorder()\n\t\th.ServeHTTP(w, req)\n\n\t\tassert.Equal(t, http.StatusNotFound, w.Code)\n\t})\n}\n\nfunc TestHealthColor(t *testing.T) {\n\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))","numLines":70,"startLine":537,"totalLines":680}}}
