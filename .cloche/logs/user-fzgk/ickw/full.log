[2026-03-04T22:36:45Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012fYn4VH1vdzBzHFcvH7Y5C","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"net\"\n     7→\t\"net/http\"\n     8→\t\"os\"\n     9→\t\"os/signal\"\n    10→\t\"path/filepath\"\n    11→\t\"syscall\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/beads\"\n    15→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    16→\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    20→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    21→\t\"github.com/cloche-dev/cloche/internal/config\"\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    24→\t\"github.com/cloche-dev/cloche/internal/orchestrator\"\n    25→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    26→\t\"google.golang.org/grpc\"\n    27→)\n    28→\n    29→func main() {\n    30→\t// Load global config file (~/.config/cloche/config)\n    31→\tglobalCfg, err := config.LoadGlobal()\n    32→\tif err != nil {\n    33→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n    34→\t\tdefaults := config.Config{}\n    35→\t\tglobalCfg = &defaults\n    36→\t}\n    37→\n    38→\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, \"cloche.db\")\n    39→\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, \"unix:///tmp/cloche.sock\")\n    40→\n    41→\tstore, err := sqlite.NewStore(dbPath)\n    42→\tif err != nil {\n    43→\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    44→\t\tos.Exit(1)\n    45→\t}\n    46→\tdefer store.Close()\n    47→\n    48→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    49→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    50→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    51→\t} else if n > 0 {\n    52→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    53→\t}\n    54→\n    55→\truntime, err := initRuntime(globalCfg)\n    56→\tif err != nil {\n    57→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    58→\t\tos.Exit(1)\n    59→\t}\n    60→\n    61→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    62→\n    63→\tbroadcaster := logstream.NewBroadcaster()\n    64→\n    65→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    66→\tsrv.SetLogStore(store)\n    67→\tsrv.SetLogBroadcaster(broadcaster)\n    68→\n    69→\t// Set up evolution trigger\n    70→\tevoTrigger := initEvolution(globalCfg, store, store)\n    71→\tif evoTrigger != nil {\n    72→\t\tsrv.SetEvolution(evoTrigger)\n    73→\t}\n    74→\n    75→\t// Set up merge agent\n    76→\tmergeAgent := initMergeAgent(globalCfg, store)\n    77→\tif mergeAgent != nil {\n    78→\t\tsrv.SetOnMergeReady(func(ctx context.Context, projectDir string) {\n    79→\t\t\tmergeAgent.ProcessQueue(ctx, projectDir)\n    80→\t\t})\n    81→\t}\n    82→\n    83→\t// Set up orchestrator\n    84→\torch := initOrchestrator(globalCfg, srv)\n    85→\tif orch != nil {\n    86→\t\tsrv.SetOnRunComplete(func(ctx context.Context, projectDir string, state domain.RunState) {\n    87→\t\t\torch.OnRunComplete(ctx, projectDir)\n    88→\t\t})\n    89→\t\tsrv.SetOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n    90→\t\t\tif projectDir != \"\" {\n    91→\t\t\t\treturn orch.Run(ctx, projectDir)\n    92→\t\t\t}\n    93→\t\t\treturn orch.TriggerAll(ctx), nil\n    94→\t\t})\n    95→\t}\n    96→\n    97→\tgrpcServer := grpc.NewServer()\n    98→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    99→\n   100→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n   101→\n   102→\tlis, err := listen(listenAddr)\n   103→\tif err != nil {\n   104→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n   105→\t\tos.Exit(1)\n   106→\t}\n   107→\n   108→\tvar httpServer *http.Server\n   109→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n   110→\t\twebHandler, err := web.NewHandler(store, store, web.WithContainerLogger(runtime), web.WithLogStore(store), web.WithLogBroadcaster(broadcaster))\n   111→\t\tif err != nil {\n   112→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n   113→\t\t\tos.Exit(1)\n   114→\t\t}\n   115→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n   116→\t\tgo func() {\n   117→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   118→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   119→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   120→\t\t\t}\n   121→\t\t}()\n   122→\t}\n   123→\n   124→\tsigCh := make(chan os.Signal, 1)\n   125→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   126→\tgo func() {\n   127→\t\t<-sigCh\n   128→\t\tif httpServer != nil {\n   129→\t\t\thttpServer.Close()\n   130→\t\t}\n   131→\t\tgrpcServer.GracefulStop()\n   132→\t}()\n   133→\n   134→\t// Trigger orchestration on startup\n   135→\tif orch != nil {\n   136→\t\tgo func() {\n   137→\t\t\tn := orch.TriggerAll(context.Background())\n   138→\t\t\tif n > 0 {\n   139→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: orchestrator dispatched %d run(s)\\n\", n)\n   140→\t\t\t}\n   141→\t\t}()\n   142→\t}\n   143→\n   144→\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   145→\tif err := grpcServer.Serve(lis); err != nil {\n   146→\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   147→\t\tos.Exit(1)\n   148→\t}\n   149→}\n   150→\n   151→func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   152→\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   153→\n   154→\tswitch runtimeType {\n   155→\tcase \"local\":\n   156→\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   157→\t\tif agentPath == \"\" {\n   158→\t\t\t// Look for cloche-agent next to this binary\n   159→\t\t\texe, err := os.Executable()\n   160→\t\t\tif err == nil {\n   161→\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   162→\t\t\t} else {\n   163→\t\t\t\tagentPath = \"cloche-agent\"\n   164→\t\t\t}\n   165→\t\t}\n   166→\t\treturn local.NewRuntime(agentPath), nil\n   167→\tcase \"docker\":\n   168→\t\treturn docker.NewRuntime()\n   169→\tdefault:\n   170→\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   171→\t}\n   172→}\n   173→\n   174→func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   175→\t// Load config from working directory (daemon-level defaults)\n   176→\tcfg, err := config.Load(\".\")\n   177→\tif err != nil || !cfg.Evolution.Enabled {\n   178→\t\treturn nil\n   179→\t}\n   180→\n   181→\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   182→\tif llmCmd == \"\" {\n   183→\t\treturn nil\n   184→\t}\n   185→\n   186→\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   187→\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   188→\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   189→\t\t\t// Load per-project config for confidence threshold\n   190→\t\t\tprojCfg, err := config.Load(projectDir)\n   191→\t\t\tif err != nil {\n   192→\t\t\t\tprojCfg = cfg // fall back to daemon config\n   193→\t\t\t}\n   194→\n   195→\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   196→\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   197→\t\t\t\tProjectDir:    projectDir,\n   198→\t\t\t\tWorkflowName:  workflowName,\n   199→\t\t\t\tLLM:           llm,\n   200→\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   201→\t\t\t})\n   202→\n   203→\t\t\tctx := context.Background()\n   204→\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   205→\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   206→\t\t\t}\n   207→\t\t},\n   208→\t})\n   209→\n   210→\treturn trigger\n   211→}\n   212→\n   213→func listen(addr string) (net.Listener, error) {\n   214→\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   215→\t\tsockPath := addr[7:]\n   216→\t\tos.Remove(sockPath)\n   217→\t\treturn net.Listen(\"unix\", sockPath)\n   218→\t}\n   219→\treturn net.Listen(\"tcp\", addr)\n   220→}\n   221→\n   222→func initOrchestrator(globalCfg *config.Config, srv *adaptgrpc.ClocheServer) *orchestrator.Orchestrator {\n   223→\t// Check if the current working directory has orchestration enabled\n   224→\tcwd, err := os.Getwd()\n   225→\tif err != nil {\n   226→\t\treturn nil\n   227→\t}\n   228→\n   229→\tcfg, err := config.Load(cwd)\n   230→\tif err != nil || !cfg.Orchestration.Enabled {\n   231→\t\treturn nil\n   232→\t}\n   233→\n   234→\tllmClient := orchestrator.NewCommandLLMClientFromEnv()\n   235→\tpromptGen := &orchestrator.LLMPromptGenerator{LLM: llmClient}\n   236→\n   237→\tdispatch := func(ctx context.Context, workflowName, projectDir, prompt string) (string, error) {\n   238→\t\tresp, err := srv.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   239→\t\t\tWorkflowName: workflowName,\n   240→\t\t\tProjectDir:   projectDir,\n   241→\t\t\tPrompt:       prompt,\n   242→\t\t})\n   243→\t\tif err != nil {\n   244→\t\t\treturn \"\", err\n   245→\t\t}\n   246→\t\treturn resp.RunId, nil\n   247→\t}\n   248→\n   249→\torch := orchestrator.New(promptGen, dispatch)\n   250→\n   251→\t// Register the current project\n   252→\ttracker := beads.NewTracker(cwd)\n   253→\torch.Register(&orchestrator.ProjectConfig{\n   254→\t\tDir:         cwd,\n   255→\t\tWorkflow:    cfg.Orchestration.Workflow,\n   256→\t\tConcurrency: cfg.Orchestration.Concurrency,\n   257→\t\tTracker:     tracker,\n   258→\t})\n   259→\n   260→\treturn orch\n   261→}\n   262→\n   263→func initMergeAgent(globalCfg *config.Config, store ports.MergeQueueStore) *orchestrator.MergeAgent {\n   264→\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   265→\n   266→\tvar llm orchestrator.LLMClient\n   267→\tif llmCmd != \"\" {\n   268→\t\tllm = &orchestrator.CommandLLMClient{Command: llmCmd}\n   269→\t}\n   270→\n   271→\treturn &orchestrator.MergeAgent{\n   272→\t\tLLM:        llm,\n   273→\t\tMergeQueue: store,\n   274→\t}\n   275→}\n   276→\n   277→// envOrConfig returns the env var value if set, otherwise the config file\n   278→// value if non-empty, otherwise the fallback default.\n   279→func envOrConfig(envKey, configVal, fallback string) string {\n   280→\tif v := os.Getenv(envKey); v != \"\" {\n   281→\t\treturn v\n   282→\t}\n   283→\tif configVal != \"\" {\n   284→\t\treturn configVal\n   285→\t}\n   286→\treturn fallback\n   287→}\n   288→"}]},"parent_tool_use_id":"toolu_016zTJ5inGYFzdFxV4oCb3ra","session_id":"b087b9cf-0b89-4209-a323-a81546a0b0f9","uuid":"81e3e881-33e9-4f4c-87ca-89856a425094"}
