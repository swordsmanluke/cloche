[2026-03-04T22:36:45Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NSSSschsZWhGqdFzeSW8rX","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"net/http\"\n     8→\t\"net/http/httptest\"\n     9→\t\"testing\"\n    10→\t\"time\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    15→\t\"github.com/stretchr/testify/assert\"\n    16→\t\"github.com/stretchr/testify/require\"\n    17→)\n    18→\n    19→// mockContainerManager implements ContainerManager for testing.\n    20→type mockContainerManager struct {\n    21→\tcontainers map[string]bool // containerID -> exists\n    22→\tremoved    []string\n    23→}\n    24→\n    25→func newMockContainerManager() *mockContainerManager {\n    26→\treturn &mockContainerManager{containers: map[string]bool{}}\n    27→}\n    28→\n    29→func (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n    30→\treturn \"mock logs\", nil\n    31→}\n    32→\n    33→func (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n    34→\tif !m.containers[containerID] {\n    35→\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n    36→\t}\n    37→\tdelete(m.containers, containerID)\n    38→\tm.removed = append(m.removed, containerID)\n    39→\treturn nil\n    40→}\n    41→\n    42→func (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n    43→\tif !m.containers[containerID] {\n    44→\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n    45→\t}\n    46→\treturn &ports.ContainerStatus{Running: false, ExitCode: 0}, nil\n    47→}\n    48→\n    49→func setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n    50→\tt.Helper()\n    51→\tstore, err := sqlite.NewStore(\":memory:\")\n    52→\trequire.NoError(t, err)\n    53→\tt.Cleanup(func() { store.Close() })\n    54→\n    55→\th, err := NewHandler(store, store)\n    56→\trequire.NoError(t, err)\n    57→\treturn h, store\n    58→}\n    59→\n    60→func seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n    61→\tt.Helper()\n    62→\tseedRunWithProject(t, store, id, workflow, state, \"\")\n    63→}\n    64→\n    65→func seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n    66→\tt.Helper()\n    67→\tctx := context.Background()\n    68→\trun := domain.NewRun(id, workflow)\n    69→\trun.ProjectDir = projectDir\n    70→\tif state != domain.RunStatePending {\n    71→\t\trun.Start()\n    72→\t\trun.ContainerID = \"abc123def456789\"\n    73→\t}\n    74→\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n    75→\t\trun.Complete(state)\n    76→\t}\n    77→\tif state == domain.RunStateFailed {\n    78→\t\trun.ErrorMessage = \"something went wrong\"\n    79→\t}\n    80→\trequire.NoError(t, store.CreateRun(ctx, run))\n    81→}\n    82→\n    83→func TestRunsList_WithRuns(t *testing.T) {\n    84→\th, store := setupHandler(t)\n    85→\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n    86→\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n    87→\n    88→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n    89→\tw := httptest.NewRecorder()\n    90→\th.ServeHTTP(w, req)\n    91→\n    92→\tassert.Equal(t, http.StatusOK, w.Code)\n    93→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n    94→\tbody := w.Body.String()\n    95→\tassert.Contains(t, body, \"test-run-1\")\n    96→\tassert.Contains(t, body, \"test-run-2\")\n    97→\tassert.Contains(t, body, \"badge-running\")\n    98→\tassert.Contains(t, body, \"badge-succeeded\")\n    99→\tassert.Contains(t, body, \"develop\")\n   100→\tassert.Contains(t, body, \"deploy\")\n   101→}\n   102→\n   103→func TestRunsList_Empty(t *testing.T) {\n   104→\th, _ := setupHandler(t)\n   105→\n   106→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   107→\tw := httptest.NewRecorder()\n   108→\th.ServeHTTP(w, req)\n   109→\n   110→\tassert.Equal(t, http.StatusOK, w.Code)\n   111→\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n   112→}\n   113→\n   114→func TestRunDetail_WithCaptures(t *testing.T) {\n   115→\th, store := setupHandler(t)\n   116→\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n   117→\n   118→\tctx := context.Background()\n   119→\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n   120→\t\tStepName:    \"implement\",\n   121→\t\tResult:      \"success\",\n   122→\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n   123→\t\tCompletedAt: time.Now(),\n   124→\t}))\n   125→\n   126→\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n   127→\tw := httptest.NewRecorder()\n   128→\th.ServeHTTP(w, req)\n   129→\n   130→\tassert.Equal(t, http.StatusOK, w.Code)\n   131→\tbody := w.Body.String()\n   132→\tassert.Contains(t, body, \"run-detail-1\")\n   133→\tassert.Contains(t, body, \"implement\")\n   134→}\n   135→\n   136→func TestRunDetail_NotFound(t *testing.T) {\n   137→\th, _ := setupHandler(t)\n   138→\n   139→\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n   140→\tw := httptest.NewRecorder()\n   141→\th.ServeHTTP(w, req)\n   142→\n   143→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   144→}\n   145→\n   146→func TestAPIRuns(t *testing.T) {\n   147→\th, store := setupHandler(t)\n   148→\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n   149→\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n   150→\n   151→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   152→\tw := httptest.NewRecorder()\n   153→\th.ServeHTTP(w, req)\n   154→\n   155→\tassert.Equal(t, http.StatusOK, w.Code)\n   156→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   157→\n   158→\tvar runs []apiRun\n   159→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n   160→\tassert.Len(t, runs, 2)\n   161→\n   162→\tids := map[string]bool{}\n   163→\tfor _, r := range runs {\n   164→\t\tids[r.ID] = true\n   165→\t}\n   166→\tassert.True(t, ids[\"api-run-1\"])\n   167→\tassert.True(t, ids[\"api-run-2\"])\n   168→}\n   169→\n   170→func TestAPIRunDetail(t *testing.T) {\n   171→\th, store := setupHandler(t)\n   172→\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n   173→\n   174→\tctx := context.Background()\n   175→\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n   176→\t\tStepName:    \"build\",\n   177→\t\tResult:      \"success\",\n   178→\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n   179→\t\tCompletedAt: time.Now(),\n   180→\t}))\n   181→\n   182→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n   183→\tw := httptest.NewRecorder()\n   184→\th.ServeHTTP(w, req)\n   185→\n   186→\tassert.Equal(t, http.StatusOK, w.Code)\n   187→\n   188→\tvar detail apiRunDetail\n   189→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   190→\tassert.Equal(t, \"api-detail-1\", detail.ID)\n   191→\tassert.Equal(t, \"running\", detail.State)\n   192→\tassert.Len(t, detail.Steps, 1)\n   193→\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n   194→\tassert.NotEmpty(t, detail.Steps[0].Duration)\n   195→}\n   196→\n   197→func TestStaticCSS(t *testing.T) {\n   198→\th, _ := setupHandler(t)\n   199→\n   200→\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n   201→\tw := httptest.NewRecorder()\n   202→\th.ServeHTTP(w, req)\n   203→\n   204→\tassert.Equal(t, http.StatusOK, w.Code)\n   205→\tassert.Contains(t, w.Body.String(), \":root\")\n   206→\tassert.Contains(t, w.Body.String(), \"badge-running\")\n   207→}\n   208→\n   209→func TestHelpers(t *testing.T) {\n   210→\tt.Run(\"stateColor\", func(t *testing.T) {\n   211→\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n   212→\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n   213→\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n   214→\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n   215→\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n   216→\t})\n   217→\n   218→\tt.Run(\"formatTime\", func(t *testing.T) {\n   219→\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n   220→\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n   221→\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n   222→\t})\n   223→\n   224→\tt.Run(\"formatDuration\", func(t *testing.T) {\n   225→\t\tnow := time.Now()\n   226→\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n   227→\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n   228→\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n   229→\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n   230→\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n   231→\t})\n   232→\n   233→\tt.Run(\"truncate\", func(t *testing.T) {\n   234→\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n   235→\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n   236→\t})\n   237→\n   238→\tt.Run(\"shortContainerID\", func(t *testing.T) {\n   239→\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n   240→\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n   241→\t})\n   242→\n   243→\tt.Run(\"projectLabels\", func(t *testing.T) {\n   244→\t\t// No conflict: show base name only\n   245→\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n   246→\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n   247→\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n   248→\n   249→\t\t// Conflict: two dirs share the same base name\n   250→\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n   251→\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n   252→\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n   253→\n   254→\t\t// Mixed: some conflict, some don't\n   255→\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n   256→\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n   257→\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n   258→\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n   259→\n   260→\t\t// Empty list\n   261→\t\tlabels = projectLabels(nil)\n   262→\t\tassert.Empty(t, labels)\n   263→\t})\n   264→}\n   265→\n   266→func TestRunsList_ProjectFilter(t *testing.T) {\n   267→\th, store := setupHandler(t)\n   268→\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   269→\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   270→\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   271→\n   272→\t// Without filter: all runs shown\n   273→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   274→\tw := httptest.NewRecorder()\n   275→\th.ServeHTTP(w, req)\n   276→\tassert.Equal(t, http.StatusOK, w.Code)\n   277→\tbody := w.Body.String()\n   278→\tassert.Contains(t, body, \"run-a1\")\n   279→\tassert.Contains(t, body, \"run-b1\")\n   280→\n   281→\t// With project filter: only matching runs\n   282→\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n   283→\tw = httptest.NewRecorder()\n   284→\th.ServeHTTP(w, req)\n   285→\tassert.Equal(t, http.StatusOK, w.Code)\n   286→\tbody = w.Body.String()\n   287→\tassert.Contains(t, body, \"run-a1\")\n   288→\tassert.Contains(t, body, \"run-a2\")\n   289→\tassert.NotContains(t, body, \"run-b1\")\n   290→}\n   291→\n   292→func TestRunsList_ProjectColumn(t *testing.T) {\n   293→\th, store := setupHandler(t)\n   294→\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n   295→\n   296→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   297→\tw := httptest.NewRecorder()\n   298→\th.ServeHTTP(w, req)\n   299→\tassert.Equal(t, http.StatusOK, w.Code)\n   300→\tbody := w.Body.String()\n   301→\tassert.Contains(t, body, \"myproject\")\n   302→\tassert.Contains(t, body, \"Project\")\n   303→}\n   304→\n   305→func TestAPIRuns_ProjectFilter(t *testing.T) {\n   306→\th, store := setupHandler(t)\n   307→\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   308→\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   309→\n   310→\t// Without filter: all runs\n   311→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   312→\tw := httptest.NewRecorder()\n   313→\th.ServeHTTP(w, req)\n   314→\tassert.Equal(t, http.StatusOK, w.Code)\n   315→\n   316→\tvar allRuns []apiRun\n   317→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n   318→\tassert.Len(t, allRuns, 2)\n   319→\n   320→\t// With filter: only matching\n   321→\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n   322→\tw = httptest.NewRecorder()\n   323→\th.ServeHTTP(w, req)\n   324→\tassert.Equal(t, http.StatusOK, w.Code)\n   325→\n   326→\tvar filtered []apiRun\n   327→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n   328→\tassert.Len(t, filtered, 1)\n   329→\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n   330→\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n   331→\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n   332→}\n   333→\n   334→func setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n   335→\tt.Helper()\n   336→\tstore, err := sqlite.NewStore(\":memory:\")\n   337→\trequire.NoError(t, err)\n   338→\tt.Cleanup(func() { store.Close() })\n   339→\n   340→\tmgr := newMockContainerManager()\n   341→\th, err := NewHandler(store, store, WithContainerManager(mgr))\n   342→\trequire.NoError(t, err)\n   343→\treturn h, store, mgr\n   344→}\n   345→\n   346→func seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n   347→\tt.Helper()\n   348→\tctx := context.Background()\n   349→\trun := domain.NewRun(id, workflow)\n   350→\trun.ProjectDir = projectDir\n   351→\trun.Start()\n   352→\trun.ContainerID = containerID\n   353→\trun.ContainerKept = kept\n   354→\trun.Complete(domain.RunStateSucceeded)\n   355→\trequire.NoError(t, store.CreateRun(ctx, run))\n   356→\tif kept {\n   357→\t\tmgr.containers[containerID] = true\n   358→\t}\n   359→}\n   360→\n   361→func TestRunDetail_ContainerAvailable(t *testing.T) {\n   362→\th, store, mgr := setupHandlerWithContainerManager(t)\n   363→\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n   364→\n   365→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n   366→\tw := httptest.NewRecorder()\n   367→\th.ServeHTTP(w, req)\n   368→\n   369→\tassert.Equal(t, http.StatusOK, w.Code)\n   370→\tbody := w.Body.String()\n   371→\tassert.Contains(t, body, \"Container available\")\n   372→\tassert.Contains(t, body, \"delete-container-btn\")\n   373→}\n   374→\n   375→func TestRunDetail_ContainerRemoved(t *testing.T) {\n   376→\th, store, _ := setupHandlerWithContainerManager(t)\n   377→\n   378→\tctx := context.Background()\n   379→\trun := domain.NewRun(\"run-c2\", \"develop\")\n   380→\trun.ProjectDir = \"/proj\"\n   381→\trun.Start()\n   382→\trun.ContainerID = \"cid-gone\"\n   383→\trun.ContainerKept = false\n   384→\trun.Complete(domain.RunStateSucceeded)\n   385→\trequire.NoError(t, store.CreateRun(ctx, run))\n   386→\n   387→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n   388→\tw := httptest.NewRecorder()\n   389→\th.ServeHTTP(w, req)\n   390→\n   391→\tassert.Equal(t, http.StatusOK, w.Code)\n   392→\tbody := w.Body.String()\n   393→\tassert.Contains(t, body, \"Container removed\")\n   394→\tassert.NotContains(t, body, `id=\"delete-container-btn\"`)\n   395→}\n   396→\n   397→func TestAPIDeleteContainer_Success(t *testing.T) {\n   398→\th, store, mgr := setupHandlerWithContainerManager(t)\n   399→\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n   400→\n   401→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n   402→\tw := httptest.NewRecorder()\n   403→\th.ServeHTTP(w, req)\n   404→\n   405→\tassert.Equal(t, http.StatusOK, w.Code)\n   406→\n   407→\tvar resp map[string]string\n   408→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n   409→\tassert.Equal(t, \"ok\", resp[\"status\"])\n   410→\n   411→\t// Verify container was removed\n   412→\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n   413→\n   414→\t// Verify run was updated\n   415→\trun, err := store.GetRun(context.Background(), \"run-del1\")\n   416→\trequire.NoError(t, err)\n   417→\tassert.False(t, run.ContainerKept)\n   418→}\n   419→\n   420→func TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n   421→\th, _, _ := setupHandlerWithContainerManager(t)\n   422→\n   423→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n   424→\tw := httptest.NewRecorder()\n   425→\th.ServeHTTP(w, req)\n   426→\n   427→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   428→}\n   429→\n   430→func TestAPIDeleteContainer_NoManager(t *testing.T) {\n   431→\th, store := setupHandler(t) // no container manager\n   432→\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n   433→\n   434→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n   435→\tw := httptest.NewRecorder()\n   436→\th.ServeHTTP(w, req)\n   437→\n   438→\tassert.Equal(t, http.StatusBadRequest, w.Code)\n   439→}\n   440→\n   441→func TestRunsList_ContainerCount(t *testing.T) {\n   442→\th, store, mgr := setupHandlerWithContainerManager(t)\n   443→\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n   444→\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n   445→\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n   446→\n   447→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   448→\tw := httptest.NewRecorder()\n   449→\th.ServeHTTP(w, req)\n   450→\n   451→\tassert.Equal(t, http.StatusOK, w.Code)\n   452→\tbody := w.Body.String()\n   453→\t// alpha has 2 retained containers\n   454→\tassert.Contains(t, body, \"2 containers\")\n   455→\t// beta has 0, so no count should appear\n   456→\tassert.NotContains(t, body, \"0 container\")\n   457→}\n   458→\n   459→func TestAPIProjects(t *testing.T) {\n   460→\th, store := setupHandler(t)\n   461→\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   462→\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   463→\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   464→\n   465→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   466→\tw := httptest.NewRecorder()\n   467→\th.ServeHTTP(w, req)\n   468→\tassert.Equal(t, http.StatusOK, w.Code)\n   469→\n   470→\ttype apiHealth struct {\n   471→\t\tStatus string `json:\"status\"`\n   472→\t\tPassed int    `json:\"passed\"`\n   473→\t\tFailed int    `json:\"failed\"`\n   474→\t\tTotal  int    `json:\"total\"`\n   475→\t}\n   476→\ttype project struct {\n   477→\t\tDir         string    `json:\"dir\"`\n   478→\t\tLabel       string    `json:\"label\"`\n   479→\t\tHealth      apiHealth `json:\"health\"`\n   480→\t\tActiveCount int       `json:\"active_count\"`\n   481→\t}\n   482→\tvar projects []project\n   483→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   484→\tassert.Len(t, projects, 2)\n   485→\n   486→\tbyDir := map[string]project{}\n   487→\tfor _, p := range projects {\n   488→\t\tbyDir[p.Dir] = p\n   489→\t}\n   490→\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n   491→\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n   492→\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n   493→\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n   494→\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n   495→\t// beta has 1 running = blue (all in-progress), 1 active\n   496→\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n   497→\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n   498→}\n   499→\n   500→func TestProjectOverview_WithProjects(t *testing.T) {\n   501→\th, store := setupHandler(t)\n   502→\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   503→\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   504→\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   505→\n   506→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   507→\tw := httptest.NewRecorder()\n   508→\th.ServeHTTP(w, req)\n   509→\n   510→\tassert.Equal(t, http.StatusOK, w.Code)\n   511→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   512→\tbody := w.Body.String()\n   513→\t// Project cards should be present\n   514→\tassert.Contains(t, body, \"project-card\")\n   515→\tassert.Contains(t, body, \"alpha\")\n   516→\tassert.Contains(t, body, \"beta\")\n   517→\t// Health dots\n   518→\tassert.Contains(t, body, \"health-dot\")\n   519→\t// Run history dots\n   520→\tassert.Contains(t, body, \"run-dot\")\n   521→\t// Quick actions\n   522→\tassert.Contains(t, body, \"View Runs\")\n   523→\tassert.Contains(t, body, \"Trigger Orchestrator\")\n   524→}\n   525→\n   526→func TestProjectOverview_Empty(t *testing.T) {\n   527→\th, _ := setupHandler(t)\n   528→\n   529→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   530→\tw := httptest.NewRecorder()\n   531→\th.ServeHTTP(w, req)\n   532→\n   533→\tassert.Equal(t, http.StatusOK, w.Code)\n   534→\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n   535→}\n   536→\n   537→func TestAPITriggerOrchestrator(t *testing.T) {\n   538→\th, _ := setupHandler(t)\n   539→\n   540→\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n   541→\tw := httptest.NewRecorder()\n   542→\th.ServeHTTP(w, req)\n   543→\n   544→\tassert.Equal(t, http.StatusAccepted, w.Code)\n   545→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   546→\n   547→\tvar result map[string]string\n   548→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   549→\tassert.Equal(t, \"accepted\", result[\"status\"])\n   550→\tassert.Equal(t, \"myproject\", result[\"project\"])\n   551→}\n   552→\n   553→func TestHealthColor(t *testing.T) {\n   554→\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n   555→\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n   556→\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n   557→\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n   558→\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n   559→\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n   560→}\n   561→\n   562→func TestAPIProjects_HealthData(t *testing.T) {\n   563→\th, store := setupHandler(t)\n   564→\t// alpha: 3 succeeded, 1 failed → yellow\n   565→\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   566→\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   567→\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   568→\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   569→\n   570→\t// beta: all succeeded → green\n   571→\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   572→\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   573→\n   574→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   575→\tw := httptest.NewRecorder()\n   576→\th.ServeHTTP(w, req)\n   577→\tassert.Equal(t, http.StatusOK, w.Code)\n   578→\n   579→\ttype health struct {\n   580→\t\tStatus string `json:\"status\"`\n   581→\t\tPassed int    `json:\"passed\"`\n   582→\t\tFailed int    `json:\"failed\"`\n   583→\t\tTotal  int    `json:\"total\"`\n   584→\t}\n   585→\ttype project struct {\n   586→\t\tDir    string `json:\"dir\"`\n   587→\t\tLabel  string `json:\"label\"`\n   588→\t\tHealth health `json:\"health\"`\n   589→\t}\n   590→\tvar projects []project\n   591→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   592→\tassert.Len(t, projects, 2)\n   593→\n   594→\tbyDir := map[string]project{}\n   595→\tfor _, p := range projects {\n   596→\t\tbyDir[p.Dir] = p\n   597→\t}\n   598→\n   599→\talpha := byDir[\"/home/user/alpha\"]\n   600→\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n   601→\tassert.Equal(t, 3, alpha.Health.Passed)\n   602→\tassert.Equal(t, 1, alpha.Health.Failed)\n   603→\tassert.Equal(t, 4, alpha.Health.Total)\n   604→\n   605→\tbeta := byDir[\"/home/user/beta\"]\n   606→\tassert.Equal(t, \"green\", beta.Health.Status)\n   607→\tassert.Equal(t, 2, beta.Health.Passed)\n   608→\tassert.Equal(t, 0, beta.Health.Failed)\n   609→\tassert.Equal(t, 2, beta.Health.Total)\n   610→}\n   611→\n   612→func TestAPIProjects_HealthNoRuns(t *testing.T) {\n   613→\th, _ := setupHandler(t)\n   614→\n   615→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   616→\tw := httptest.NewRecorder()\n   617→\th.ServeHTTP(w, req)\n   618→\tassert.Equal(t, http.StatusOK, w.Code)\n   619→\n   620→\t// No projects means empty array\n   621→\ttype project struct {\n   622→\t\tDir   string `json:\"dir\"`\n   623→\t\tLabel string `json:\"label\"`\n   624→\t}\n   625→\tvar projects []project\n   626→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   627→\tassert.Empty(t, projects)\n   628→}\n   629→"}]},"parent_tool_use_id":"toolu_01R8dkTRtrMAibfUjmnHKhC3","session_id":"b087b9cf-0b89-4209-a323-a81546a0b0f9","uuid":"d4c70985-3bf0-49eb-b9c4-c2a28e48c568"}
