or\": fmt.Sprintf(\"orchestration failed: %v\", err)})\n\t\treturn\n\t}\n\n\tw.WriteHeader(http.StatusAccepted)\n\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"accepted\", \"project\": name, \"dispatched\": dispatched})\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":298,"cache_read_input_tokens":32143,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":298},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b087b9cf-0b89-4209-a323-a81546a0b0f9","uuid":"9ee9f0ba-e40c-49bd-9804-66c5033b0979"}
