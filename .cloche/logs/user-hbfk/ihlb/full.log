[2026-03-05T02:44:54Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SqQeaBYbopEdEP9fidBUFS","type":"tool_result","content":"     1â†’package main\n     2â†’\n     3â†’import (\n     4â†’\t\"context\"\n     5â†’\t\"fmt\"\n     6â†’\t\"net\"\n     7â†’\t\"net/http\"\n     8â†’\t\"os\"\n     9â†’\t\"os/signal\"\n    10â†’\t\"path/filepath\"\n    11â†’\t\"syscall\"\n    12â†’\n    13â†’\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14â†’\t\"github.com/cloche-dev/cloche/internal/adapters/beads\"\n    15â†’\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    16â†’\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    17â†’\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    18â†’\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    19â†’\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    20â†’\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    21â†’\t\"github.com/cloche-dev/cloche/internal/config\"\n    22â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23â†’\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    24â†’\t\"github.com/cloche-dev/cloche/internal/orchestrator\"\n    25â†’\t\"github.com/cloche-dev/cloche/internal/ports\"\n    26â†’\t\"google.golang.org/grpc\"\n    27â†’)\n    28â†’\n    29â†’func main() {\n    30â†’\t// Load global config file (~/.config/cloche/config)\n    31â†’\tglobalCfg, err := config.LoadGlobal()\n    32â†’\tif err != nil {\n    33â†’\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n    34â†’\t\tdefaults := config.Config{}\n    35â†’\t\tglobalCfg = &defaults\n    36â†’\t}\n    37â†’\n    38â†’\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, \"cloche.db\")\n    39â†’\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, \"unix:///tmp/cloche.sock\")\n    40â†’\n    41â†’\tstore, err := sqlite.NewStore(dbPath)\n    42â†’\tif err != nil {\n    43â†’\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    44â†’\t\tos.Exit(1)\n    45â†’\t}\n    46â†’\tdefer store.Close()\n    47â†’\n    48â†’\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    49â†’\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    50â†’\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    51â†’\t} else if n > 0 {\n    52â†’\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    53â†’\t}\n    54â†’\n    55â†’\truntime, err := initRuntime(globalCfg)\n    56â†’\tif err != nil {\n    57â†’\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    58â†’\t\tos.Exit(1)\n    59â†’\t}\n    60â†’\n    61â†’\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    62â†’\n    63â†’\tbroadcaster := logstream.NewBroadcaster()\n    64â†’\n    65â†’\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    66â†’\tsrv.SetLogStore(store)\n    67â†’\tsrv.SetLogBroadcaster(broadcaster)\n    68â†’\n    69â†’\t// Set up evolution trigger\n    70â†’\tevoTrigger := initEvolution(globalCfg, store, store)\n    71â†’\tif evoTrigger != nil {\n    72â†’\t\tsrv.SetEvolution(evoTrigger)\n    73â†’\t}\n    74â†’\n    75â†’\t// Set up merge agent\n    76â†’\tsrv.SetMergeQueue(store)\n    77â†’\tmergeAgent := initMergeAgent(globalCfg, store)\n    78â†’\tif mergeAgent != nil {\n    79â†’\t\tsrv.SetOnMergeReady(func(ctx context.Context, projectDir string) {\n    80â†’\t\t\tmergeAgent.ProcessQueue(ctx, projectDir)\n    81â†’\t\t})\n    82â†’\t}\n    83â†’\n    84â†’\t// Set up orchestrator\n    85â†’\torch := initOrchestrator(globalCfg, srv)\n    86â†’\tif orch != nil {\n    87â†’\t\tsrv.SetOnRunComplete(func(ctx context.Context, projectDir string, state domain.RunState) {\n    88â†’\t\t\torch.OnRunComplete(ctx, projectDir)\n    89â†’\t\t})\n    90â†’\t\tsrv.SetOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n    91â†’\t\t\tif projectDir != \"\" {\n    92â†’\t\t\t\treturn orch.Run(ctx, projectDir)\n    93â†’\t\t\t}\n    94â†’\t\t\treturn orch.TriggerAll(ctx), nil\n    95â†’\t\t})\n    96â†’\t}\n    97â†’\n    98â†’\tgrpcServer := grpc.NewServer()\n    99â†’\tpb.RegisterClocheServiceServer(grpcServer, srv)\n   100â†’\n   101â†’\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n   102â†’\n   103â†’\tlis, err := listen(listenAddr)\n   104â†’\tif err != nil {\n   105â†’\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n   106â†’\t\tos.Exit(1)\n   107â†’\t}\n   108â†’\n   109â†’\tvar httpServer *http.Server\n   110â†’\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n   111â†’\t\twebOpts := []web.HandlerOption{\n   112â†’\t\t\tweb.WithContainerLogger(runtime),\n   113â†’\t\t\tweb.WithLogStore(store),\n   114â†’\t\t\tweb.WithLogBroadcaster(broadcaster),\n   115â†’\t\t}\n   116â†’\t\tif orch != nil {\n   117â†’\t\t\twebOpts = append(webOpts, web.WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   118â†’\t\t\t\treturn orch.Run(ctx, projectDir)\n   119â†’\t\t\t}))\n   120â†’\t\t}\n   121â†’\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n   122â†’\t\tif err != nil {\n   123â†’\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n   124â†’\t\t\tos.Exit(1)\n   125â†’\t\t}\n   126â†’\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n   127â†’\t\tgo func() {\n   128â†’\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   129â†’\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   130â†’\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   131â†’\t\t\t}\n   132â†’\t\t}()\n   133â†’\t}\n   134â†’\n   135â†’\tsigCh := make(chan os.Signal, 1)\n   136â†’\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   137â†’\tgo func() {\n   138â†’\t\t<-sigCh\n   139â†’\t\tif httpServer != nil {\n   140â†’\t\t\thttpServer.Close()\n   141â†’\t\t}\n   142â†’\t\tgrpcServer.GracefulStop()\n   143â†’\t}()\n   144â†’\n   145â†’\t// Trigger orchestration on startup\n   146â†’\tif orch != nil {\n   147â†’\t\tgo func() {\n   148â†’\t\t\tn := orch.TriggerAll(context.Background())\n   149â†’\t\t\tif n > 0 {\n   150â†’\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: orchestrator dispatched %d run(s)\\n\", n)\n   151â†’\t\t\t}\n   152â†’\t\t}()\n   153â†’\t}\n   154â†’\n   155â†’\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   156â†’\tif err := grpcServer.Serve(lis); err != nil {\n   157â†’\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   158â†’\t\tos.Exit(1)\n   159â†’\t}\n   160â†’}\n   161â†’\n   162â†’func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   163â†’\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   164â†’\n   165â†’\tswitch runtimeType {\n   166â†’\tcase \"local\":\n   167â†’\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   168â†’\t\tif agentPath == \"\" {\n   169â†’\t\t\t// Look for cloche-agent next to this binary\n   170â†’\t\t\texe, err := os.Executable()\n   171â†’\t\t\tif err == nil {\n   172â†’\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   173â†’\t\t\t} else {\n   174â†’\t\t\t\tagentPath = \"cloche-agent\"\n   175â†’\t\t\t}\n   176â†’\t\t}\n   177â†’\t\treturn local.NewRuntime(agentPath), nil\n   178â†’\tcase \"docker\":\n   179â†’\t\treturn docker.NewRuntime()\n   180â†’\tdefault:\n   181â†’\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   182â†’\t}\n   183â†’}\n   184â†’\n   185â†’func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   186â†’\t// Load config from working directory (daemon-level defaults)\n   187â†’\tcfg, err := config.Load(\".\")\n   188â†’\tif err != nil || !cfg.Evolution.Enabled {\n   189â†’\t\treturn nil\n   190â†’\t}\n   191â†’\n   192â†’\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   193â†’\tif llmCmd == \"\" {\n   194â†’\t\treturn nil\n   195â†’\t}\n   196â†’\n   197â†’\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   198â†’\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   199â†’\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   200â†’\t\t\t// Load per-project config for confidence threshold\n   201â†’\t\t\tprojCfg, err := config.Load(projectDir)\n   202â†’\t\t\tif err != nil {\n   203â†’\t\t\t\tprojCfg = cfg // fall back to daemon config\n   204â†’\t\t\t}\n   205â†’\n   206â†’\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   207â†’\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   208â†’\t\t\t\tProjectDir:    projectDir,\n   209â†’\t\t\t\tWorkflowName:  workflowName,\n   210â†’\t\t\t\tLLM:           llm,\n   211â†’\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   212â†’\t\t\t})\n   213â†’\n   214â†’\t\t\tctx := context.Background()\n   215â†’\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   216â†’\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   217â†’\t\t\t}\n   218â†’\t\t},\n   219â†’\t})\n   220â†’\n   221â†’\treturn trigger\n   222â†’}\n   223â†’\n   224â†’func listen(addr string) (net.Listener, error) {\n   225â†’\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   226â†’\t\tsockPath := addr[7:]\n   227â†’\t\tos.Remove(sockPath)\n   228â†’\t\treturn net.Listen(\"unix\", sockPath)\n   229â†’\t}\n   230â†’\treturn net.Listen(\"tcp\", addr)\n   231â†’}\n   232â†’\n   233â†’func initOrchestrator(globalCfg *config.Config, srv *adaptgrpc.ClocheServer) *orchestrator.Orchestrator {\n   234â†’\t// Check if the current working directory has orchestration enabled\n   235â†’\tcwd, err := os.Getwd()\n   236â†’\tif err != nil {\n   237â†’\t\treturn nil\n   238â†’\t}\n   239â†’\n   240â†’\tcfg, err := config.Load(cwd)\n   241â†’\tif err != nil || !cfg.Orchestration.Enabled {\n   242â†’\t\treturn nil\n   243â†’\t}\n   244â†’\n   245â†’\tllmClient := orchestrator.NewCommandLLMClientFromEnv()\n   246â†’\tpromptGen := &orchestrator.LLMPromptGenerator{LLM: llmClient}\n   247â†’\n   248â†’\tdispatch := func(ctx context.Context, workflowName, projectDir, prompt string) (string, error) {\n   249â†’\t\tresp, err := srv.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   250â†’\t\t\tWorkflowName: workflowName,\n   251â†’\t\t\tProjectDir:   projectDir,\n   252â†’\t\t\tPrompt:       prompt,\n   253â†’\t\t})\n   254â†’\t\tif err != nil {\n   255â†’\t\t\treturn \"\", err\n   256â†’\t\t}\n   257â†’\t\treturn resp.RunId, nil\n   258â†’\t}\n   259â†’\n   260â†’\torch := orchestrator.New(promptGen, dispatch)\n   261â†’\n   262â†’\t// Register the current project\n   263â†’\ttracker := beads.NewTracker(cwd)\n   264â†’\torch.Register(&orchestrator.ProjectConfig{\n   265â†’\t\tDir:         cwd,\n   266â†’\t\tWorkflow:    cfg.Orchestration.Workflow,\n   267â†’\t\tConcurrency: cfg.Orchestration.Concurrency,\n   268â†’\t\tTracker:     tracker,\n   269â†’\t})\n   270â†’\n   271â†’\treturn orch\n   272â†’}\n   273â†’\n   274â†’func initMergeAgent(globalCfg *config.Config, store ports.MergeQueueStore) *orchestrator.MergeAgent {\n   275â†’\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   276â†’\n   277â†’\tvar llm orchestrator.LLMClient\n   278â†’\tif llmCmd != \"\" {\n   279â†’\t\tllm = &orchestrator.CommandLLMClient{Command: llmCmd}\n   280â†’\t}\n   281â†’\n   282â†’\treturn &orchestrator.MergeAgent{\n   283â†’\t\tLLM:        llm,\n   284â†’\t\tMergeQueue: store,\n   285â†’\t}\n   286â†’}\n   287â†’\n   288â†’// envOrConfig returns the env var value if set, otherwise the config file\n   289â†’// value if non-empty, otherwise the fallback default.\n   290â†’func envOrConfig(envKey, configVal, fallback string) string {\n   291â†’\tif v := os.Getenv(envKey); v != \"\" {\n   292â†’\t\treturn v\n   293â†’\t}\n   294â†’\tif configVal != \"\" {\n   295â†’\t\treturn configVal\n   296â†’\t}\n   297â†’\treturn fallback\n   298â†’}\n   299â†’"}]},"parent_tool_use_id":null,"session_id":"cc2e6e8c-da94-4b06-a140-1a3c72b18ec3","uuid":"46bd2048-8e37-4a99-ba48-8963b0373a88","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloched/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"path/filepath\"\n\t\"syscall\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/beads\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\t\"github.com/cloche-dev/cloche/internal/orchestrator\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"google.golang.org/grpc\"\n)\n\nfunc main() {\n\t// Load global config file (~/.config/cloche/config)\n\tglobalCfg, err := config.LoadGlobal()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n\t\tdefaults := config.Config{}\n\t\tglobalCfg = &defaults\n\t}\n\n\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, \"cloche.db\")\n\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, \"unix:///tmp/cloche.sock\")\n\n\tstore, err := sqlite.NewStore(dbPath)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer store.Close()\n\n\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n\t} else if n > 0 {\n\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n\t}\n\n\truntime, err := initRuntime(globalCfg)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n\n\tbroadcaster := logstream.NewBroadcaster()\n\n\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n\tsrv.SetLogStore(store)\n\tsrv.SetLogBroadcaster(broadcaster)\n\n\t// Set up evolution trigger\n\tevoTrigger := initEvolution(globalCfg, store, store)\n\tif evoTrigger != nil {\n\t\tsrv.SetEvolution(evoTrigger)\n\t}\n\n\t// Set up merge agent\n\tsrv.SetMergeQueue(store)\n\tmergeAgent := initMergeAgent(globalCfg, store)\n\tif mergeAgent != nil {\n\t\tsrv.SetOnMergeReady(func(ctx context.Context, projectDir string) {\n\t\t\tmergeAgent.ProcessQueue(ctx, projectDir)\n\t\t})\n\t}\n\n\t// Set up orchestrator\n\torch := initOrchestrator(globalCfg, srv)\n\tif orch != nil {\n\t\tsrv.SetOnRunComplete(func(ctx context.Context, projectDir string, state domain.RunState) {\n\t\t\torch.OnRunComplete(ctx, projectDir)\n\t\t})\n\t\tsrv.SetOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\t\tif projectDir != \"\" {\n\t\t\t\treturn orch.Run(ctx, projectDir)\n\t\t\t}\n\t\t\treturn orch.TriggerAll(ctx), nil\n\t\t})\n\t}\n\n\tgrpcServer := grpc.NewServer()\n\tpb.RegisterClocheServiceServer(grpcServer, srv)\n\n\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n\n\tlis, err := listen(listenAddr)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n\t\tos.Exit(1)\n\t}\n\n\tvar httpServer *http.Server\n\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n\t\twebOpts := []web.HandlerOption{\n\t\t\tweb.WithContainerLogger(runtime),\n\t\t\tweb.WithLogStore(store),\n\t\t\tweb.WithLogBroadcaster(broadcaster),\n\t\t}\n\t\tif orch != nil {\n\t\t\twebOpts = append(webOpts, web.WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\t\t\treturn orch.Run(ctx, projectDir)\n\t\t\t}))\n\t\t}\n\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n\t\tgo func() {\n\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n\t\t\t}\n\t\t}()\n\t}\n\n\tsigCh := make(chan os.Signal, 1)\n\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n\tgo func() {\n\t\t<-sigCh\n\t\tif httpServer != nil {\n\t\t\thttpServer.Close()\n\t\t}\n\t\tgrpcServer.GracefulStop()\n\t}()\n\n\t// Trigger orchestration on startup\n\tif orch != nil {\n\t\tgo func() {\n\t\t\tn := orch.TriggerAll(context.Background())\n\t\t\tif n > 0 {\n\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: orchestrator dispatched %d run(s)\\n\", n)\n\t\t\t}\n\t\t}()\n\t}\n\n\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n\tif err := grpcServer.Serve(lis); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n\nfunc initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n\n\tswitch runtimeType {\n\tcase \"local\":\n\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n\t\tif agentPath == \"\" {\n\t\t\t// Look for cloche-agent next to this binary\n\t\t\texe, err := os.Executable()\n\t\t\tif err == nil {\n\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n\t\t\t} else {\n\t\t\t\tagentPath = \"cloche-agent\"\n\t\t\t}\n\t\t}\n\t\treturn local.NewRuntime(agentPath), nil\n\tcase \"docker\":\n\t\treturn docker.NewRuntime()\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n\t}\n}\n\nfunc initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n\t// Load config from working directory (daemon-level defaults)\n\tcfg, err := config.Load(\".\")\n\tif err != nil || !cfg.Evolution.Enabled {\n\t\treturn nil\n\t}\n\n\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n\tif llmCmd == \"\" {\n\t\treturn nil\n\t}\n\n\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n\t\tRunFunc: func(projectDir, workflowName, runID string) {\n\t\t\t// Load per-project config for confidence threshold\n\t\t\tprojCfg, err := config.Load(projectDir)\n\t\t\tif err != nil {\n\t\t\t\tprojCfg = cfg // fall back to daemon config\n\t\t\t}\n\n\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n\t\t\t\tProjectDir:    projectDir,\n\t\t\t\tWorkflowName:  workflowName,\n\t\t\t\tLLM:           llm,\n\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n\t\t\t})\n\n\t\t\tctx := context.Background()\n\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n\t\t\t}\n\t\t},\n\t})\n\n\treturn trigger\n}\n\nfunc listen(addr string) (net.Listener, error) {\n\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n\t\tsockPath := addr[7:]\n\t\tos.Remove(sockPath)\n\t\treturn net.Listen(\"unix\", sockPath)\n\t}\n\treturn net.Listen(\"tcp\", addr)\n}\n\nfunc initOrchestrator(globalCfg *config.Config, srv *adaptgrpc.ClocheServer) *orchestrator.Orchestrator {\n\t// Check if the current working directory has orchestration enabled\n\tcwd, err := os.Getwd()\n\tif err != nil {\n\t\treturn nil\n\t}\n\n\tcfg, err := config.Load(cwd)\n\tif err != nil || !cfg.Orchestration.Enabled {\n\t\treturn nil\n\t}\n\n\tllmClient := orchestrator.NewCommandLLMClientFromEnv()\n\tpromptGen := &orchestrator.LLMPromptGenerator{LLM: llmClient}\n\n\tdispatch := func(ctx context.Context, workflowName, projectDir, prompt string) (string, error) {\n\t\tresp, err := srv.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\t\tWorkflowName: workflowName,\n\t\t\tProjectDir:   projectDir,\n\t\t\tPrompt:       prompt,\n\t\t})\n\t\tif err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\treturn resp.RunId, nil\n\t}\n\n\torch := orchestrator.New(promptGen, dispatch)\n\n\t// Register the current project\n\ttracker := beads.NewTracker(cwd)\n\torch.Register(&orchestrator.ProjectConfig{\n\t\tDir:         cwd,\n\t\tWorkflow:    cfg.Orchestration.Workflow,\n\t\tConcurrency: cfg.Orchestration.Concurrency,\n\t\tTracker:     tracker,\n\t})\n\n\treturn orch\n}\n\nfunc initMergeAgent(globalCfg *config.Config, store ports.MergeQueueStore) *orchestrator.MergeAgent {\n\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n\n\tvar llm orchestrator.LLMClient\n\tif llmCmd != \"\" {\n\t\tllm = &orchestrator.CommandLLMClient{Command: llmCmd}\n\t}\n\n\treturn &orchestrator.MergeAgent{\n\t\tLLM:        llm,\n\t\tMergeQueue: store,\n\t}\n}\n\n// envOrConfig returns the env var value if set, otherwise the config file\n// value if non-empty, otherwise the fallback default.\nfunc envOrConfig(envKey, configVal, fallback string) string {\n\tif v := os.Getenv(envKey); v != \"\" {\n\t\treturn v\n\t}\n\tif configVal != \"\" {\n\t\treturn configVal\n\t}\n\treturn fallback\n}\n","numLines":299,"startLine":1,"totalLines":299}}}
