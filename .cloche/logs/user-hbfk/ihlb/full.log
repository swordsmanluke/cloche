 agent\n    59â†’`\n    60â†’\n    61â†’var implementPrompt = `Implement the following change in this project.\n    62â†’\n    63â†’## User Request\n    64â†’(Contents of .cloche/prompt.txt will be injected here by the adapter)\n    65â†’\n    66â†’## Guidelines\n    67â†’- Follow existing project conventions if files already exist\n    68â†’- Write tests for new functionality\n    69â†’- Run tests locally before declaring success\n    70â†’`\n    71â†’\n    72â†’var fixPrompt = `Fix the code based on the validation failures below.\n    73â†’Only modify files that need fixing. Do not rewrite the entire project.\n    74â†’\n    75â†’## Validation Output\n    76â†’(Contents of .cloche/output/*.log will be injected here by the adapter)\n    77â†’`\n    78â†’\n    79â†’var updateDocsPrompt = `Review the CLI source code and update usage documentation to reflect any changes.\n    80â†’\n    81â†’## What to check\n    82â†’1. Read cmd/cloche/main.go and cmd/cloche/init.go to understand the current CLI surface\n    83â†’2. Compare against docs/USAGE.md\n    84â†’\n    85â†’## Sections to keep in sync\n    86â†’- CLI Reference: subcommands, flags, usage examples\n    87â†’- Setting Up a New Project: scaffolding steps, workflow template\n    88â†’- Daemon Configuration: environment variables\n    89â†’- Build Commands: Makefile targets\n    90â†’\n    91â†’## Rules\n    92â†’- Only modify docs/USAGE.md (and docs/workflows.md if workflow DSL syntax changed)\n    93â†’- Only make changes when there are actual discrepancies â€” do not rewrite for style\n    94â†’- If everything is already accurate, make no changes and report success\n    95â†’`\n    96â†’\n    97â†’func cmdInit(args []string) {\n    98â†’\tworkflow := \"develop\"\n    99â†’\timage := \"ubuntu:24.04\"\n   100â†’\n   101â†’\tfor i := 0; i < len(args); i++ {\n   102â†’\t\tswitch args[i] {\n   103â†’\t\tcase \"--workflow\":\n   104â†’\t\t\tif i+1 < len(args) {\n   105â†’\t\t\t\ti++\n   106â†’\t\t\t\tworkflow = args[i]\n   107â†’\t\t\t}\n   108â†’\t\tcase \"--image\":\n   109â†’\t\t\tif i+1 < len(args) {\n   110â†’\t\t\t\ti++\n   111â†’\t\t\t\timage = args[i]\n   112â†’\t\t\t}\n   113â†’\t\t}\n   114â†’\t}\n   115â†’\n   116â†’\tclocheDir := \".cloche\"\n   117â†’\tworkflowFile := filepath.Join(clocheDir, workflow+\".cloche\")\n   118â†’\n   119â†’\t// Refuse to overwrite existing workflow\n   120â†’\tif _, err := os.Stat(workflowFile); err == nil {\n   121â†’\t\tfmt.Fprintf(os.Stderr, \"error: %s already exists\\n\", workflowFile)\n   122â†’\t\tos.Exit(1)\n   123â†’\t}\n   124â†’\n   125â†’\t// Create directories\n   126â†’\tfor _, dir := range []string{\n   127â†’\t\tclocheDir,\n   128â†’\t\tfilepath.Join(clocheDir, \"prompts\"),\n   129â†’\t\tfilepath.Join(clocheDir, \"overrides\"),\n   130â†’\t} {\n   131â†’\t\tif err := os.MkdirAll(dir, 0755); err != nil {\n   132â†’\t\t\tfmt.Fprintf(os.Stderr, \"error creating %s/: %v\\n\", dir, err)\n   133â†’\t\t\tos.Exit(1)\n   134â†’\t\t}\n   135â†’\t}\n   136â†’\n   137â†’\t// Write all files, skipping any that already exist\n   138â†’\tfiles := []struct{ path, content string }{\n   139â†’\t\t{workflowFile, fmt.Sprintf(workflowTemplate, workflow)},\n   140â†’\t\t{filepath.Join(clocheDir, \"Dockerfile\"), fmt.Sprintf(dockerfileTemplate, image)},\n   141â†’\t\t{filepath.Join(clocheDir, \"prompts\", \"implement.md\"), implementPrompt},\n   142â†’\t\t{filepath.Join(clocheDir, \"prompts\", \"fix.md\"), fixPrompt},\n   143â†’\t\t{filepath.Join(clocheDir, \"prompts\", \"update-docs.md\"), updateDocsPrompt},\n   144â†’\t}\n   145â†’\n   146â†’\tfor _, f := range files {\n   147â†’\t\tif _, err := os.Stat(f.path); err == nil {\n   148â†’\t\t\tfmt.Fprintf(os.Stderr, \"  skip %s (already exists)\\n\", f.path)\n   149â†’\t\t\tcontinue\n   150â†’\t\t}\n   151â†’\t\tif err := os.WriteFile(f.path, []byte(f.content), 0644); err != nil {\n   152â†’\t\t\tfmt.Fprintf(os.Stderr, \"error writing %s: %v\\n\", f.path, err)\n   153â†’\t\t\tos.Exit(1)\n   154â†’\t\t}\n   155â†’\t\tfmt.Fprintf(os.Stderr, \"  create %s\\n\", f.path)\n   156â†’\t}\n   157â†’\n   158â†’\taddGitignoreEntries([]string{\n   159â†’\t\t\".cloche/*/\",\n   160â†’\t\t\"!.cloche/prompts/\",\n   161â†’\t\t\"!.cloche/overrides/\",\n   162â†’\t\t\"!.cloche/evolution/\",\n   163â†’\t\t\".gitworktrees/\",\n   164â†’\t})\n   165â†’\n   166â†’\tcwd, _ := os.Getwd()\n   167â†’\tfmt.Fprintf(os.Stderr, \"\\nInitialized Cloche project in %s\\n\", filepath.Base(cwd))\n   168â†’\tfmt.Fprintf(os.Stderr, \"\\nNext steps:\\n\")\n   169â†’\tfmt.Fprintf(os.Stderr, \"  1. Edit %s â€” change the test command for your project\\n\", workflowFile)\n   170â†’\tfmt.Fprintf(os.Stderr, \"  2. Edit %s â€” add your project's dependencies\\n\", filepath.Join(clocheDir, \"Dockerfile\"))\n   171â†’\tfmt.Fprintf(os.Stderr, \"  3. Add container-specific overrides to %s/ (e.g. CLAUDE.md)\\n\", filepath.Join(clocheDir, \"overrides\"))\n   172â†’\tfmt.Fprintf(os.Stderr, \"  4. docker build -t cloche-agent -f %s .\\n\", filepath.Join(clocheDir, \"Dockerfile\"))\n   173â†’\tfmt.Fprintf(os.Stderr, \"  5. cloche run --workflow %s --prompt \\\"...\\\"\\n\", workflow)\n   174â†’}\n   175â†’\n   176â†’func addGitignoreEntries(entries []string) {\n   177â†’\tconst gitignore = \".gitignore\"\n   178â†’\n   179â†’\texisting, _ := os.ReadFile(gitignore)\n   180â†’\tcontent := string(existing)\n   181â†’\n   182â†’\tvar toAdd []string\n   183â†’\tfor _, entry := range entries {\n   184â†’\t\tif !strings.Contains(content, entry) {\n   185â†’\t\t\ttoAdd = append(toAdd, entry)\n   186â†’\t\t}\n   187â†’\t}\n   188â†’\tif len(toAdd) == 0 {\n   189â†’\t\treturn\n   190â†’\t}\n   191â†’\n   192â†’\tif len(content) > 0 && !strings.HasSuffix(content, \"\\n\") {\n   193â†’\t\tcontent += \"\\n\"\n   194â†’\t}\n   195â†’\tcontent += strings.Join(toAdd, \"\\n\") + \"\\n\"\n   196â†’\n   197â†’\tif err := os.WriteFile(gitignore, []byte(content), 0644); err != nil {\n   198â†’\t\tfmt.Fprintf(os.Stderr, \"warning: could not update .gitignore: %v\\n\", err)\n   199â†’\t}\n   200â†’}\n   201â†’"}]},"parent_tool_use_id":null,"session_id":"cc2e6e8c-da94-4b06-a140-1a3c72b18ec3","uuid":"a1e43b1b-a6b8-4322-ab05-3304d5fb111a","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/init.go","content":"package main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n)\n\nvar workflowTemplate = `workflow \"%s\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n\n  step test {\n    run = \"make test 2>&1\"\n    results = [success, fail]\n  }\n\n  step fix {\n    prompt = file(\".cloche/prompts/fix.md\")\n    max_attempts = \"2\"\n    results = [success, fail, give-up]\n  }\n\n  step update-docs {\n    prompt = file(\".cloche/prompts/update-docs.md\")\n    results = [success, fail]\n  }\n\n  implement:success -> test\n  implement:fail -> abort\n  test:success -> update-docs\n  test:fail -> fix\n  fix:success -> test\n  fix:fail -> abort\n  fix:give-up -> abort\n  update-docs:success -> done\n  update-docs:fail -> done\n}\n`\n\nvar dockerfileTemplate = `FROM golang:1.25 AS cloche-builder\nWORKDIR /src\nCOPY go.mod go.sum ./\nRUN go mod download\nCOPY . .\nRUN CGO_ENABLED=0 go build -o /cloche-agent ./cmd/cloche-agent\n\nFROM %s\nRUN apt-get update && apt-get install -y git nodejs npm && rm -rf /var/lib/apt/lists/*\nRUN npm install -g @anthropic-ai/claude-code\nCOPY --from=cloche-builder /cloche-agent /usr/local/bin/cloche-agent\nRUN useradd -m -s /bin/bash agent\nWORKDIR /workspace\nRUN chown agent:agent /workspace\nUSER agent\n`\n\nvar implementPrompt = `Implement the following change in this project.\n\n## User Request\n(Contents of .cloche/prompt.txt will be injected here by the adapter)\n\n## Guidelines\n- Follow existing project conventions if files already exist\n- Write tests for new functionality\n- Run tests locally before declaring success\n`\n\nvar fixPrompt = `Fix the code based on the validation failures below.\nOnly modify files that need fixing. Do not rewrite the entire project.\n\n## Validation Output\n(Contents of .cloche/output/*.log will be injected here by the adapter)\n`\n\nvar updateDocsPrompt = `Review the CLI source code and update usage documentation to reflect any changes.\n\n## What to check\n1. Read cmd/cloche/main.go and cmd/cloche/init.go to understand the current CLI surface\n2. Compare against docs/USAGE.md\n\n## Sections to keep in sync\n- CLI Reference: subcommands, flags, usage examples\n- Setting Up a New Project: scaffolding steps, workflow template\n- Daemon Configuration: environment variables\n- Build Commands: Makefile targets\n\n## Rules\n- Only modify docs/USAGE.md (and docs/workflows.md if workflow DSL syntax changed)\n- Only make changes when there are actual discrepancies â€” do not rewrite for style\n- If everything is already accurate, make no changes and report success\n`\n\nfunc cmdInit(args []string) {\n\tworkflow := \"develop\"\n\timage := \"ubuntu:24.04\"\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--image\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\timage = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tclocheDir := \".cloche\"\n\tworkflowFile := filepath.Join(clocheDir, workflow+\".cloche\")\n\n\t// Refuse to overwrite existing workflow\n\tif _, err := os.Stat(workflowFile); err == nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %s already exists\\n\", workflowFile)\n\t\tos.Exit(1)\n\t}\n\n\t// Create directories\n\tfor _, dir := range []string{\n\t\tclocheDir,\n\t\tfilepath.Join(clocheDir, \"prompts\"),\n\t\tfilepath.Join(clocheDir, \"overrides\"),\n\t} {\n\t\tif err := os.MkdirAll(dir, 0755); err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error creating %s/: %v\\n\", dir, err)\n\t\t\tos.Exit(1)\n\t\t}\n\t}\n\n\t// Write all files, skipping any that already exist\n\tfiles := []struct{ path, content string }{\n\t\t{workflowFile, fmt.Sprintf(workflowTemplate, workflow)},\n\t\t{filepath.Join(clocheDir, \"Dockerfile\"), fmt.Sprintf(dockerfileTemplate, image)},\n\t\t{filepath.Join(clocheDir, \"prompts\", \"implement.md\"), implementPrompt},\n\t\t{filepath.Join(clocheDir, \"prompts\", \"fix.md\"), fixPrompt},\n\t\t{filepath.Join(clocheDir, \"prompts\", \"update-docs.md\"), updateDocsPrompt},\n\t}\n\n\tfor _, f := range files {\n\t\tif _, err := os.Stat(f.path); err == nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"  skip %s (already exists)\\n\", f.path)\n\t\t\tcontinue\n\t\t}\n\t\tif err := os.WriteFile(f.path, []byte(f.content), 0644); err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error writing %s: %v\\n\", f.path, err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Fprintf(os.Stderr, \"  create %s\\n\", f.path)\n\t}\n\n\taddGitignoreEntries([]string{\n\t\t\".cloche/*/\",\n\t\t\"!.cloche/prompts/\",\n\t\t\"!.cloche/overrides/\",\n\t\t\"!.cloche/evolution/\",\n\t\t\".gitworktrees/\",\n\t})\n\n\tcwd, _ := os.Getwd()\n\tfmt.Fprintf(os.Stderr, \"\\nInitialized Cloche project in %s\\n\", filepath.Base(cwd))\n\tfmt.Fprintf(os.Stderr, \"\\nNext steps:\\n\")\n\tfmt.Fprintf(os.Stderr, \"  1. Edit %s â€” change the test command for your project\\n\", workflowFile)\n\tfmt.Fprintf(os.Stderr, \"  2. Edit %s â€” add your project's dependencies\\n\", filepath.Join(clocheDir, \"Dockerfile\"))\n\tfmt.Fprintf(os.Stderr, \"  3. Add container-specific overrides to %s/ (e.g. CLAUDE.md)\\n\", filepath.Join(clocheDir, \"overrides\"))\n\tfmt.Fprintf(os.Stderr, \"  4. docker build -t cloche-agent -f %s .\\n\", filepath.Join(clocheDir, \"Dockerfile\"))\n\tfmt.Fprintf(os.Stderr, \"  5. cloche run --workflow %s --prompt \\\"...\\\"\\n\", workflow)\n}\n\nfunc addGitignoreEntries(entries []string) {\n\tconst gitignore = \".gitignore\"\n\n\texisting, _ := os.ReadFile(gitignore)\n\tcontent := string(existing)\n\n\tvar toAdd []string\n\tfor _, entry := range entries {\n\t\tif !strings.Contains(content, entry) {\n\t\t\ttoAdd = append(toAdd, entry)\n\t\t}\n\t}\n\tif len(toAdd) == 0 {\n\t\treturn\n\t}\n\n\tif len(content) > 0 && !strings.HasSuffix(content, \"\\n\") {\n\t\tcontent += \"\\n\"\n\t}\n\tcontent += strings.Join(toAdd, \"\\n\") + \"\\n\"\n\n\tif err := os.WriteFile(gitignore, []byte(content), 0644); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"warning: could not update .gitignore: %v\\n\", err)\n\t}\n}\n","numLines":201,"startLine":1,"totalLines":201}}}
[2026-03-05T02:44:54Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01SLQNp4d3xeDbE444q7nbBf","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01A82cZoBh5mQtaHoaa3nCPU","name":"Read","input":{"file_path":"/workspace/docs/USAGE.md"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2529,"cache_read_input_tokens":106208,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2529},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"cc2e6e8c-da94-4b06-a140-1a3c72b18ec3","uuid":"a9baeca0-712d-4725-834f-02059cbac977"}
[2026-03-05T02:44:54Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A82cZoBh5mQtaHoaa3nCPU","type":"tool_result","content":"     1â†’# Usage\n     2â†’\n     3â†’Cloche runs containerized workflows for autonomous coding agents. You write a\n     4â†’workflow graph in the `.cloche` DSL, point Cloche at a project directory, and it\n     5â†’handles execution, retry logic, and status tracking.\n     6â†’\n     7â†’## Prerequisites\n     8â†’\n     9â†’- Go 1.25+\n    10â†’- Docker\n    11â†’- Git\n    12â†’- An `ANTHROPIC_API_KEY` (for agent steps using Claude Code)\n    13â†’\n    14â†’For detailed installation options (pre-built binaries, `go install`, Homebrew,\n    15â†’Docker-based usage), see [INSTALL.md](INSTALL.md).\n    16â†’\n    17â†’## Quick Start\n    18â†’\n    19â†’### 1. Build everything\n    20â†’\n    21â†’```\n    22â†’make build\n    23â†’make docker-build\n    24â†’```\n    25â†’\n    26â†’This produces `bin/cloche`, `bin/cloched`, `bin/cloche-agent`, and the\n    27â†’`cloche-agent:latest` Docker image.\n    28â†’\n    29â†’### 2. Start the daemon\n    30â†’\n    31â†’```\n    32â†’bin/cloched\n    33â†’```\n    34â†’\n    35â†’The daemon listens on a Unix socket at `/tmp/cloche.sock` by default. It\n    36â†’manages Docker containers, tracks run state in SQLite, and handles\n    37â†’container cleanup. Containers are automatically removed after successful\n    38â†’runs unless `--keep-container` is set. Failed runs always keep their\n    39â†’container for debugging.\n    40â†’\n    41â†’To enable the web dashboard, set `CLOCHE_HTTP` (e.g.\n    42â†’`CLOCHE_HTTP=:8080 bin/cloched`). The dashboard is not started unless\n    43â†’this variable is set.\n    44â†’\n    45â†’### 3. Run a workflow\n    46â†’\n    47â†’From your project directory (must be inside a git repository):\n    48â†’\n    49â†’```\n    50â†’cd my-project\n    51â†’cloche run --workflow develop --prompt \"Add user authentication\"\n    52â†’```\n    53â†’\n    54â†’This will:\n    55â†’1. Write your prompt to `.cloche/<run-id>/prompt.txt`\n    56â†’2. Create a Docker container and copy your entire project into it (no bind mounts)\n    57â†’3. Apply any override files from `.cloche/overrides/` on top\n    58â†’4. Start the container, which runs `cloche-agent` to walk the workflow graph\n    59â†’5. When the workflow finishes, the daemon extracts results to a `cloche/<run-id>` branch\n    60â†’\n    61â†’### 4. Monitor progress\n    62â†’\n    63â†’```\n    64â†’cloche status <run-id>\n    65â†’cloche list\n    66â†’```\n    67â†’\n    68â†’### 5. Get the results\n    69â†’\n    70â†’When the run completes, the agent's work is on a git branch:\n    71â†’\n    72â†’```\n    73â†’git branch | grep cloche/\n    74â†’git diff main..cloche/<run-id>\n    75â†’```\n    76â†’\n    77â†’To merge results into your working branch:\n    78â†’\n    79â†’```\n    80â†’git merge cloche/<run-id>\n    81â†’# or cherry-pick, rebase, etc.\n    82â†’```\n    83â†’\n    84â†’To clean up run branches:\n    85â†’\n    86â†’```\n    87â†’git branch -D cloche/<run-id>\n    88â†’```\n    89â†’\n    90â†’## Container Isolation Model\n    91â†’\n    92â†’Cloche provides **total filesystem isolation** between the host and container:\n    93â†’\n    94â†’- **Files in**: `docker cp` copies the entire project root into the container at\n    95â†’  `/workspace/`. No bind mounts for project files. Override files from\n    96â†’  `.cloche/overrides/` are then copied on top (e.g., a container-specific\n    97â†’  `CLAUDE.md`). The `.git/` directory is included so agents have git context.\n    98â†’- **Files out**: When the workflow completes, the daemon extracts results from\n    99â†’  the container via `docker cp` into a git worktree and commits them to a\n   100â†’  `cloche/<run-id>` branch.\n   101â†’- **Auth mounts**: `~/.claude` and `~/.claude.json` are bind-mounted read-only\n   102â†’  for Claude Code OAuth session reuse. `ANTHROPIC_API_KEY` is passed as an\n   103â†’  environment variable.\n   104â†’- **Network**: Containers have network access (needed for API calls).\n   105â†’\n   106â†’Your project directory is never modified by the container. All changes live\n   107â†’on the run branch until you explicitly merge them.\n   108â†’\n   109â†’## CLI Reference\n   110â†’\n   111â†’### `cloche init`\n   112â†’\n   113â†’Scaffold a new Cloche project in the current directory.\n   114â†’\n   115â†’```\n   116â†’cloche init [--workflow <name>] [--image <base>]\n   117â†’```\n   118â†’\n   119â†’| Flag | Default | Description |\n   120â†’|------|---------|-------------|\n   121â†’| `--workflow <name>` | `develop` | Workflow name. Creates `.cloche/<name>.cloche`. |\n   122â†’| `--image <base>` | `ubuntu:24.04` | Base Docker image for the generated Dockerfile. |\n   123â†’\n   124â†’Creates `.cloche/` with a workflow file, Dockerfile, and prompt templates\n   125â†’(`implement.md`, `fix.md`, `update-docs.md`). Skips files that already exist.\n   126â†’Also adds gitignore entries for runtime state directories.\n   127â†’\n   128â†’### `cloche health`\n   129â†’\n   130â†’Show project health summary based on recent run results.\n   131â†’\n   132â†’```\n   133â†’cloche health\n   134â†’```\n   135â†’\n   136â†’Requires `CLOCHE_HTTP` to be set (e.g. `export CLOCHE_HTTP=localhost:8080`).\n   137â†’Fetches health data from the daemon's HTTP API (`GET /api/projects`) and\n   138â†’displays a table with per-project pass/fail counts:\n   139â†’\n   140â†’```\n   141â†’PROJECT          STATUS    PASSED  FAILED  TOTAL\n   142â†’my-project       green     5       0       5\n   143â†’other-project    yellow    3       2       5\n   144â†’```\n   145â†’\n   146â†’Status is colored (green/yellow/red) when output is a TTY.\n   147â†’\n   148â†’### `cloche run`\n   149â†’\n   150â†’Launch a workflow run.\n   151â†’\n   152â†’```\n   153â†’cloche run --workflow <name> [--prompt \"...\"] [--keep-container]\n   154â†’```\n   155â†’\n   156â†’| Flag | Description |\n   157â†’|------|-------------|\n   158â†’| `--workflow <name>` | Workflow name. Resolves to `.cloche/<name>.cloche` in the project directory. |\n   159â†’| `--prompt \"...\"`, `-p` | Inline prompt written to `.cloche/<run-id>/prompt.txt` and injected into agent steps. |\n   160â†’| `--keep-container` | Keep the Docker container even on success (default: remove on success). Failed runs always keep their container for debugging. |\n   161â†’\n   162â†’The current working directory is used as the project directory. It must be\n   163â†’inside a git repository (Cloche needs the repo root for result extraction\n   164â†’via git worktrees).\n   165â†’\n   166â†’When starting a run, the daemon checks whether the Docker image is up-to-date\n   167â†’with the project's `.cloche/Dockerfile`. If the Dockerfile has changed since\n   168â†’the last build (tracked via a SHA-256 label on the image), the daemon rebuilds\n   169â†’the image automatically before launching the container.\n   170â†’\n   171â†’### `cloche status`\n   172â†’\n   173â†’Check the status of a run.\n   174â†’\n   175â†’```\n   176â†’cloche status <run-id>\n   177â†’```\n   178â†’\n   179â†’Output includes the run state, active steps, and per-step results with timestamps.\n   180â†’\n   181â†’### `cloche list`\n   182â†’\n   183â†’List runs (last hour by default).\n   184â†’\n   185â†’```\n   186â†’cloche list [--all]\n   187â†’```\n   188â†’\n   189â†’| Flag | Description |\n   190â†’|------|-------------|\n   191â†’| `--all` | Show all runs, not just the last hour. |\n   192â†’\n   193â†’Columns: run ID, workflow name, state, container ID (if running), error message (if failed).\n   194â†’\n   195â†’### `cloche logs`\n   196â†’\n   197â†’Show logs for a run.\n   198â†’\n   199â†’```\n   200â†’cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n   201â†’```\n   202â†’\n   203â†’| Flag | Description |\n   204â†’|------|-------------|\n   205â†’| `--step <name>` | Show only logs for the specified step. |\n   206â†’| `--type <full\\|script\\|llm>` | Show only logs of the specified type (`full` = unified log, `script` = script output, `llm` = LLM conversation). |\n   207â†’| `--follow`, `-f` | Stream live log lines via SSE. Color-coded by type: status (blue), LLM (green), script (default). Exits when the run completes. Connects to the daemon's HTTP endpoint (see `CLOCHE_HTTP` in Client Configuration). |\n   208â†’\n   209â†’Without flags, shows the unified log (`full.log`) if available, otherwise streams\n   210â†’step start/completion events and run results.\n   211â†’With `--follow`, connects to the SSE endpoint and prints log lines in real-time.\n   212â†’\n   213â†’### `cloche poll`\n   214â†’\n   215â†’Wait for a run to finish, printing progress updates.\n   216â†’\n   217â†’```\n   218â†’cloche poll <run-id>\n   219â†’```\n   220â†’\n   221â†’Polls every 2 seconds. Exits 0 on success, 1 on failure or if the container\n   222â†’dies unexpectedly.\n   223â†’\n   224â†’### `cloche stop`\n   225â†’\n   226â†’Cancel a running workflow.\n   227â†’\n   228â†’```\n   229â†’cloche stop <run-id>\n   230â†’```\n   231â†’\n   232â†’### `cloche delete`\n   233â†’\n   234â†’Delete a retained Docker container. Accepts either a Docker container name/ID\n   235â†’or a Cloche run ID. If given a run ID, the daemon looks up the associated\n   236â†’container.\n   237â†’\n   238â†’```\n   239â†’cloche delete <container-or-run-id>\n   240â†’```\n   241â†’\n   242â†’### `cloche orchestrate`\n   243â†’\n   244â†’Dispatch ready workflow runs for the current project. Checks the project's\n   245â†’issue tracker for unclaimed tasks, generates prompts, and launches runs.\n   246â†’\n   247â†’```\n   248â†’cloche orchestrate\n   249â†’```\n   250â†’\n   251â†’Uses the current working directory as the project directory. Prints \"No ready\n   252â†’work found.\" if there are no tasks to dispatch, or \"Dispatched N run(s).\"\n   253â†’with the count.\n   254â†’\n   255â†’### `cloche shutdown`\n   256â†’\n   257â†’Shut down the daemon.\n   258â†’\n   259â†’```\n   260â†’cloche shutdown\n   261â†’```\n   262â†’\n   263â†’## Setting Up a New Project\n   264â†’\n   265â†’### 1. Scaffold the project\n   266â†’\n   267â†’Run `cloche init` from your project root to create the `.cloche/` directory with\n   268â†’default workflow, Dockerfile, and prompt templates:\n   269â†’\n   270â†’```\n   271â†’cd my-project\n   272â†’cloche init\n   273â†’```\n   274â†’\n   275â†’Or create the structure manually:\n   276â†’\n   277â†’### 2. Create a workflow file\n   278â†’\n   279â†’Add `.cloche/<name>.cloche`:\n   280â†’\n   281â†’```\n   282â†’workflow \"develop\" {\n   283â†’  step implement {\n   284â†’    prompt = file(\".cloche/prompts/implement.md\")\n   285â†’    results = [success, fail]\n   286â†’  }\n   287â†’\n   288â†’  step test {\n   289â†’    run = \"make test 2>&1\"\n   290â†’    results = [success, fail]\n   291â†’  }\n   292â†’\n   293â†’  step fix {\n   294â†’    prompt = file(\".cloche/prompts/fix.md\")\n   295â†’    max_attempts = \"2\"\n   296â†’    results = [success, fail, give-up]\n   297â†’  }\n   298â†’\n   299â†’  step update-docs {\n   300â†’    prompt = file(\".cloche/prompts/update-docs.md\")\n   301â†’    results = [success, fail]\n   302â†’  }\n   303â†’\n   304â†’  implement:success -> test\n   305â†’  implement:fail -> abort\n   306â†’\n   307â†’  test:success -> update-docs\n   308â†’  test:fail -> fix\n   309â†’\n   310â†’  fix:success -> test\n   311â†’  fix:fail -> abort\n   312â†’  fix:give-up -> abort\n   313â†’\n   314â†’  update-docs:success -> done\n   315â†’  update-docs:fail -> done\n   316â†’}\n   317â†’```\n   318â†’\n   319â†’### 3. Write prompt templates\n   320â†’\n   321â†’Create `.cloche/prompts/` with markdown files:\n   322â†’\n   323â†’**`.cloche/prompts/implement.md`** â€” Instructions for the initial implementation:\n   324â†’```markdown\n   325â†’You are working on a project. Implement the following change:\n   326â†’\n   327â†’## User Request\n   328â†’(The user prompt is injected automatically by the agent adapter)\n   329â†’\n   330â†’## Guidelines\n   331â†’- Follow existing project conventions\n   332â†’- Write tests for new functionality\n   333â†’- Run tests locally before declaring success\n   334â†’```\n   335â†’\n   336â†’**`.cloche/prompts/fix.md`** â€” Instructions for fixing failures:\n   337â†’```markdown\n   338â†’The previous attempt had failures. Review the output logs in .cloche/output/\n   339â†’and fix the issues.\n   340â†’\n   341â†’## Guidelines\n   342â†’- Read the test/lint output carefully\n   343â†’- Fix the root cause, not the symptoms\n   344â†’- Run tests again to verify your fix\n   345â†’```\n   346â†’\n   347â†’**`.cloche/prompts/update-docs.md`** â€” Instructions for keeping docs in sync:\n   348â†’```markdown\n   349â†’Review the CLI source code and update usage documentation to reflect any changes.\n   350â†’```\n   351â†’\n   352â†’### 4. Add overrides (optional)\n   353â†’\n   354â†’Files in `.cloche/overrides/` are copied on top of `/workspace/` in the\n   355â†’container. Use this for container-specific configuration:\n   356â†’\n   357â†’```\n   358â†’.cloche/overrides/\n   359â†’  CLAUDE.md              # Container-specific CLAUDE.md (replaces host version)\n   360â†’```\n   361â†’\n   362â†’### 5. Make sure your project builds in the container\n   363â†’\n   364â†’The default Dockerfile generated by `cloche init` uses `ubuntu:24.04` as its\n   365â†’base image (configurable via `--image`). If your project needs different\n   366â†’dependencies, edit `.cloche/Dockerfile`:\n   367â†’\n   368â†’```dockerfile\n   369â†’FROM golang:1.25 AS builder\n   370â†’WORKDIR /src\n   371â†’COPY go.mod go.sum ./\n   372â†’RUN go mod download\n   373â†’COPY . .\n   374â†’RUN CGO_ENABLED=0 go build -o /cloche-agent ./cmd/cloche-agent\n   375â†’\n   376â†’FROM ubuntu:24.04\n   377â†’RUN apt-get update && apt-get install -y git <your-deps> && rm -rf /var/lib/apt/lists/*\n   378â†’RUN npm install -g @anthropic-ai/claude-code\n   379â†’COPY --from=builder /cloche-agent /usr/local/bin/cloche-agent\n   380â†’RUN useradd -m -s /bin/bash agent\n   381â†’WORKDIR /workspace\n   382â†’RUN chown agent:agent /workspace\n   383â†’USER agent\n   384â†’```\n   385â†’\n   386â†’Key requirements for the image:\n   387â†’- `cloche-agent` binary at `/usr/local/bin/cloche-agent`\n   388â†’- `git` installed (for pushing results back)\n   389â†’- An `agent` user (cloche wraps the command with `chown` + `su agent`)\n   390â†’- `/workspace` as the working directory\n   391â†’- Your project's build dependencies\n   392â†’\n   393â†’The daemon automatically rebuilds the image when `.cloche/Dockerfile` changes\n   394â†’(see `cloche run` above). To build manually:\n   395â†’```\n   396â†’docker build -t my-project-agent -f .cloche/Dockerfile .\n   397â†’CLOCHE_IMAGE=my-project-agent:latest bin/cloched\n   398â†’```\n   399â†’\n   400â†’### 6. Run it\n   401â†’\n   402â†’```\n   403â†’cd my-project\n   404â†’cloche run --workflow develop --prompt \"Add feature X\"\n   405â†’```\n   406â†’\n   407â†’## Writing Workflows\n   408â†’\n   409â†’Workflow files use the `.cloche` extension and live in the `.cloche/` directory. See\n   410â†’[workflows.md](workflows.md) for full DSL reference.\n   411â†’\n   412â†’### Step Types\n   413â†’\n   414â†’**Agent steps** (has `prompt`) â€” Invokes a coding agent autonomously:\n   415â†’\n   416â†’```\n   417â†’step implement {\n   418â†’  prompt = file(\".cloche/prompts/implement.md\")\n   419â†’  results = [success, fail]\n   420â†’}\n   421â†’```\n   422â†’\n   423â†’**Script steps** (has `run`) â€” Runs a shell command:\n   424â†’\n   425â†’```\n   426â†’step test {\n   427â†’  run = \"make test 2>&1\"\n   428â†’  results = [success, fail]\n   429â†’}\n   430â†’```\n   431â†’\n   432â†’### Wiring\n   433â†’\n   434â†’Connect steps with `step:result -> next_step`:\n   435â†’\n   436â†’```\n   437â†’implement:success -> test\n   438â†’implement:fail -> abort\n   439â†’test:success -> done\n   440â†’test:fail -> fix\n   441â†’```\n   442â†’\n   443â†’`done` and `abort` are built-in terminals for success and failure.\n   444â†’\n   445â†’### Retry Loops\n   446â†’\n   447â†’Wire failures back to earlier steps:\n   448â†’\n   449â†’```\n   450â†’test:fail -> fix\n   451â†’fix:success -> test    // retry the test\n   452â†’fix:fail -> abort\n   453â†’```\n   454â†’\n   455â†’### Max Attempts\n   456â†’\n   457â†’Limit retries on agent steps. When exhausted, the step returns `give-up`:\n   458â†’\n   459â†’```\n   460â†’step fix {\n   461â†’  prompt = file(\".cloche/prompts/fix.md\")\n   462â†’  max_attempts = \"2\"\n   463â†’  results = [success, fail, give-up]\n   464â†’}\n   465â†’```\n   466â†’\n   467â†’### Parallel Branches\n   468â†’\n   469â†’Wire one result to multiple targets for concurrent execution:\n   470â†’\n   471â†’```\n   472â†’test:success -> lint\n   473â†’test:success -> quality\n   474â†’```\n   475â†’\n   476â†’### Collect (Join)\n   477â†’\n   478â†’Synchronize parallel branches:\n   479â†’\n   480â†’```\n   481â†’collect all(lint:success, quality:success) -> done\n   482â†’```\n   483â†’\n   484â†’`all` fires when every condition is met. `any` fires when at least one is.\n   485â†’\n   486â†’### Agent Command Override\n   487â†’\n   488â†’Agent steps use Claude Code by default. Override per-step:\n   489â†’\n   490â†’```\n   491â†’step implement {\n   492â†’  prompt = \"...\"\n   493â†’  agent_command = \"aider\"\n   494â†’  results = [success, fail]\n   495â†’}\n   496â†’```\n   497â†’\n   498â†’Or at the workflow level via a `container` block:\n   499â†’\n   500â†’```\n   501â†’workflow \"develop\" {\n   502â†’  container {\n   503â†’    agent_command = \"gemini\"\n   504â†’  }\n   505â†’  ...\n   506â†’}\n   507â†’```\n   508â†’\n   509â†’Or globally via `CLOCHE_AGENT_COMMAND` environment variable.\n   510â†’\n   511â†’Priority (highest to lowest): step-level `agent_command`, workflow-level\n   512â†’`container { agent_command }`, `CLOCHE_AGENT_COMMAND` env var, default (`claude`).\n   513â†’\n   514â†’### Agent Fallback Chains\n   515â†’\n   516â†’Use a comma-separated list in `agent_command` to configure fallback chains. If\n   517â†’the first agent errors without reporting a result, the system tries the next:\n   518â†’\n   519â†’```\n   520â†’step implement {\n   521â†’  prompt = \"...\"\n   522â†’  agent_command = \"claude,gemini,codex\"\n   523â†’  results = [success, fail]\n   524â†’}\n   525â†’```\n   526â†’\n   527â†’Fallback rules:\n   528â†’- **Command not found or failed to start** â€” fall back to next command\n   529â†’- **Exit non-zero without `CLOCHE_RESULT` marker** â€” fall back to next command\n   530â†’- **Exit non-zero with `CLOCHE_RESULT` marker** â€” use that result (no fallback)\n   531â†’- **Exit 0** â€” use result (no fallback)\n   532â†’- **All commands fail to start** â€” step returns an error\n   533â†’- **Last command crashes without marker** â€” step returns `fail`\n   534â†’\n   535â†’Known agents have default arguments (e.g., Claude gets\n   536â†’`-p --output-format text --dangerously-skip-permissions`). Other agents receive\n   537â†’the prompt on stdin with no extra flags. Override with `agent_args` at the step\n   538â†’or workflow level.\n   539â†’\n   540â†’## Result Protocol\n   541â†’\n   542â†’Steps report results by writing a marker to stdout:\n   543â†’\n   544â†’```\n   545â†’CLOCHE_RESULT:<name>\n   546â†’```\n   547â†’\n   548â†’For script steps, if no marker is written, the exit code determines the result:\n   549â†’0 = `success`, non-zero = `fail`. Agent steps follow the same convention.\n   550â†’\n   551â†’## Prompt Assembly\n   552â†’\n   553â†’When an agent step runs, Cloche assembles a prompt from multiple sources:\n   554â†’\n   555â†’1. The step's `prompt` content (inline or from `file()`)\n   556â†’2. The user prompt from `.cloche/<run-id>/prompt.txt` (set via `--prompt`)\n   557â†’3. Validation output from `.cloche/<run-id>/output/*.log` (output from previous script steps)\n   558â†’4. Result selection instructions listing the step's declared results\n   559â†’\n   560â†’## Project Directory Layout\n   561â†’\n   562â†’```\n   563â†’my-project/\n   564â†’â”śâ”€â”€ .cloche/\n   565â†’â”‚   â”śâ”€â”€ develop.cloche        # Workflow definition\n   566â†’â”‚   â”śâ”€â”€ Dockerfile            # Container image\n   567â†’â”‚   â”śâ”€â”€ prompts/\n   568â†’â”‚   â”‚   â”śâ”€â”€ implement.md      # Prompt templates\n   569â†’â”‚   â”‚   â”śâ”€â”€ fix.md\n   570â†’â”‚   â”‚   â””â”€â”€ update-docs.md\n   571â†’â”‚   â”śâ”€â”€ overrides/            # Files copied on top of /workspace/ in container\n   572â†’â”‚   â”‚   â””â”€â”€ CLAUDE.md         # Container-specific CLAUDE.md (optional)\n   573â†’â”‚   â””â”€â”€ <run-id>/             # Runtime state (gitignored)\n   574â†’â”‚       â”śâ”€â”€ prompt.txt        # User prompt (from --prompt flag)\n   575â†’â”‚       â”śâ”€â”€ output/\n   576â†’â”‚       â”‚   â”śâ”€â”€ full.log      # Unified chronological log (status + script + LLM)\n   577â†’â”‚       â”‚   â”śâ”€â”€ test.log      # Per-step script output\n   578â†’â”‚       â”‚   â””â”€â”€ llm-impl.log  # Per-step LLM conversation output\n   579â†’â”‚       â”śâ”€â”€ attempt_count/\n   580â†’â”‚       â”‚   â””â”€â”€ fix           # Retry counter for max_attempts\n   581â†’â”‚       â””â”€â”€ history.log       # Step execution log\n   582â†’â”śâ”€â”€ src/                      # Existing project source (untouched)\n   583â†’â”śâ”€â”€ CLAUDE.md                 # Host CLAUDE.md\n   584â†’â””â”€â”€ .git/\n   585â†’```\n   586â†’\n   587â†’## Daemon Configuration\n   588â†’\n   589â†’| Variable | Default | Description |\n   590â†’|----------|---------|-------------|\n   591â†’| `CLOCHE_LISTEN` | `unix:///tmp/cloche.sock` | Listen address (unix socket or TCP) |\n   592â†’| `CLOCHE_DB` | `cloche.db` | SQLite database path |\n   593â†’| `CLOCHE_RUNTIME` | `docker` | `docker` (container) or `local` (subprocess, for dev) |\n   594â†’| `CLOCHE_IMAGE` | `cloche-agent:latest` | Default Docker image |\n   595â†’| `CLOCHE_HTTP` | â€” | HTTP address for the web dashboard. Not started unless set. |\n   596â†’| `CLOCHE_AGENT_PATH` | (auto-detected) | Path to `cloche-agent` binary (local runtime) |\n   597â†’| `CLOCHE_LLM_COMMAND` | â€” | Command for LLM calls â€” evolution and merge conflict resolution (e.g. `claude`) |\n   598â†’| `ANTHROPIC_API_KEY` | â€” | Passed into Docker containers |\n   599â†’| `CLOCHE_EXTRA_MOUNTS` | â€” | Extra bind mounts (comma-separated `host:container`) |\n   600â†’| `CLOCHE_EXTRA_ENV` | â€” | Extra env vars (comma-separated `KEY=VALUE`) |\n   601â†’\n   602â†’### Client Configuration\n   603â†’\n   604â†’| Variable | Default | Description |\n   605â†’|----------|---------|-------------|\n   606â†’| `CLOCHE_ADDR` | `unix:///tmp/cloche.sock` | Daemon address (gRPC) |\n   607â†’| `CLOCHE_HTTP` | `localhost:8080` | Daemon HTTP address (web dashboard, `cloche logs --follow`) |\n   608â†’\n   609â†’## Build Commands\n   610â†’\n   611â†’```\n   612â†’make build          # Build all binaries to bin/\n   613â†’make test           # Run all tests\n   614â†’make test-short     # Run tests (skip slow ones)\n   615â†’make lint           # Run go vet\n   616â†’make proto          # Regenerate gRPC code from protobuf\n   617â†’make docker-build   # Build the cloche-agent Docker image\n   618â†’make install        # Build, install to ~/.local/bin/, restart daemon\n   619â†’make clean          # Remove bin/\n   620â†’```\n   621â†’"}]},"parent_tool_use_id":null,"session_id":"cc2e6e8c-da94-4b06-a140-1a3c72b18ec3","uuid":"2a305dc3-c88a-4fe7-a04d-3db051f86d03","tool_use_result":{"type":"text","file":{"filePath":"/workspace/docs/USAGE.md","content":"# Usage\n\nCloche runs containerized workflows for autonomous coding agents. You write a\nworkflow graph in the `.cloche` DSL, point Cloche at a project directory, and it\nhandles execution, retry logic, and status tracking.\n\n## Prerequisites\n\n- Go 1.25+\n- Docker\n- Git\n- An `ANTHROPIC_API_KEY` (for agent steps using Claude Code)\n\nFor detailed installation options (pre-built binaries, `go install`, Homebrew,\nDocker-based usage), see [INSTALL.md](INSTALL.md).\n\n## Quick Start\n\n### 1. Build everything\n\n```\nmake build\nmake docker-build\n```\n\nThis produces `bin/cloche`, `bin/cloched`, `bin/cloche-agent`, and the\n`cloche-agent:latest` Docker image.\n\n### 2. Start the daemon\n\n```\nbin/cloched\n```\n\nThe daemon listens on a Unix socket at `/tmp/cloche.sock` by default. It\nmanages Docker containers, tracks run state in SQLite, and handles\ncontainer cleanup. Containers are automatically removed after successful\nruns unless `--keep-container` is set. Failed runs always keep their\ncontainer for debugging.\n\nTo enable the web dashboard, set `CLOCHE_HTTP` (e.g.\n`CLOCHE_HTTP=:8080 bin/cloched`). The dashboard is not started unless\nthis variable is set.\n\n### 3. Run a workflow\n\nFrom your project directory (must be inside a git repository):\n\n```\ncd my-project\ncloche run --workflow develop --prompt \"Add user authentication\"\n```\n\nThis will:\n1. Write your prompt to `.cloche/<run-id>/prompt.txt`\n2. Create a Docker container and copy your entire project into it (no bind mounts)\n3. Apply any override files from `.cloche/overrides/` on top\n4. Start the container, which runs `cloche-agent` to walk the workflow graph\n5. When the workflow finishes, the daemon extracts results to a `cloche/<run-id>` branch\n\n### 4. Monitor progress\n\n```\ncloche status <run-id>\ncloche list\n```\n\n### 5. Get the results\n\nWhen the run completes, the agent's work is on a git branch:\n\n```\ngit branch | grep cloche/\ngit diff main..cloche/<run-id>\n```\n\nTo merge results into your working branch:\n\n```\ngit merge cloche/<run-id>\n# or cherry-pick, rebase, etc.\n```\n\nTo clean up run branches:\n\n```\ngit branch -D cloche/<run-id>\n```\n\n## Container Isolation Model\n\nCloche provides **total filesystem isolation** between the host and container:\n\n- **Files in**: `docker cp` copies the entire project root into the container at\n  `/workspace/`. No bind mounts for project files. Override files from\n  `.cloche/overrides/` are then copied on top (e.g., a container-specific\n  `CLAUDE.md`). The `.git/` directory is included so agents have git context.\n- **Files out**: When the workflow completes, the daemon extracts results from\n  the container via `docker cp` into a git worktree and commits them to a\n  `cloche/<run-id>` branch.\n- **Auth mounts**: `~/.claude` and `~/.claude.json` are bind-mounted read-only\n  for Claude Code OAuth session reuse. `ANTHROPIC_API_KEY` is passed as an\n  environment variable.\n- **Network**: Containers have network access (needed for API calls).\n\nYour project directory is never modified by the container. All changes live\non the run branch until you explicitly merge them.\n\n## CLI Reference\n\n### `cloche init`\n\nScaffold a new Cloche project in the current directory.\n\n```\ncloche init [--workflow <name>] [--image <base>]\n```\n\n| Flag | Default | Description |\n|------|---------|-------------|\n| `--workflow <name>` | `develop` | Workflow name. Creates `.cloche/<name>.cloche`. |\n| `--image <base>` | `ubuntu:24.04` | Base Docker image for the generated Dockerfile. |\n\nCreates `.cloche/` with a workflow file, Dockerfile, and prompt templates\n(`implement.md`, `fix.md`, `update-docs.md`). Skips files that already exist.\nAlso adds gitignore entries for runtime state directories.\n\n### `cloche health`\n\nShow project health summary based on recent run results.\n\n```\ncloche health\n```\n\nRequires `CLOCHE_HTTP` to be set (e.g. `export CLOCHE_HTTP=localhost:8080`).\nFetches health data from the daemon's HTTP API (`GET /api/projects`) and\ndisplays a table with per-project pass/fail counts:\n\n```\nPROJECT          STATUS    PASSED  FAILED  TOTAL\nmy-project       green     5       0       5\nother-project    yellow    3       2       5\n```\n\nStatus is colored (green/yellow/red) when output is a TTY.\n\n### `cloche run`\n\nLaunch a workflow run.\n\n```\ncloche run --workflow <name> [--prompt \"...\"] [--keep-container]\n```\n\n| Flag | Description |\n|------|-------------|\n| `--workflow <name>` | Workflow name. Resolves to `.cloche/<name>.cloche` in the project directory. |\n| `--prompt \"...\"`, `-p` | Inline prompt written to `.cloche/<run-id>/prompt.txt` and injected into agent steps. |\n| `--keep-container` | Keep the Docker container even on success (default: remove on success). Failed runs always keep their container for debugging. |\n\nThe current working directory is used as the project directory. It must be\ninside a git repository (Cloche needs the repo root for result extraction\nvia git worktrees).\n\nWhen starting a run, the daemon checks whether the Docker image is up-to-date\nwith the project's `.cloche/Dockerfile`. If the Dockerfile has changed since\nthe last build (tracked via a SHA-256 label on the image), the daemon rebuilds\nthe image automatically before launching the container.\n\n### `cloche status`\n\nCheck the status of a run.\n\n```\ncloche status <run-id>\n```\n\nOutput includes the run state, active steps, and per-step results with timestamps.\n\n### `cloche list`\n\nList runs (last hour by default).\n\n```\ncloche list [--all]\n```\n\n| Flag | Description |\n|------|-------------|\n| `--all` | Show all runs, not just the last hour. |\n\nColumns: run ID, workflow name, state, container ID (if running), error message (if failed).\n\n### `cloche logs`\n\nShow logs for a run.\n\n```\ncloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n```\n\n| Flag | Description |\n|------|-------------|\n| `--step <name>` | Show only logs for the specified step. |\n| `--type <full\\|script\\|llm>` | Show only logs of the specified type (`full` = unified log, `script` = script output, `llm` = LLM conversation). |\n| `--follow`, `-f` | Stream live log lines via SSE. Color-coded by type: status (blue), LLM (green), script (default). Exits when the run completes. Connects to the daemon's HTTP endpoint (see `CLOCHE_HTTP` in Client Configuration). |\n\nWithout flags, shows the unified log (`full.log`) if available, otherwise streams\nstep start/completion events and run results.\nWith `--follow`, connects to the SSE endpoint and prints log lines in real-time.\n\n### `cloche poll`\n\nWait for a run to finish, printing progress updates.\n\n```\ncloche poll <run-id>\n```\n\nPolls every 2 seconds. Exits 0 on success, 1 on failure or if the container\ndies unexpectedly.\n\n### `cloche stop`\n\nCancel a running workflow.\n\n```\ncloche stop <run-id>\n```\n\n### `cloche delete`\n\nDelete a retained Docker container. Accepts either a Docker container name/ID\nor a Cloche run ID. If given a run ID, the daemon looks up the associated\ncontainer.\n\n```\ncloche delete <container-or-run-id>\n```\n\n### `cloche orchestrate`\n\nDispatch ready workflow runs for the current project. Checks the project's\nissue tracker for unclaimed tasks, generates prompts, and launches runs.\n\n```\ncloche orchestrate\n```\n\nUses the current working directory as the project directory. Prints \"No ready\nwork found.\" if there are no tasks to dispatch, or \"Dispatched N run(s).\"\nwith the count.\n\n### `cloche shutdown`\n\nShut down the daemon.\n\n```\ncloche shutdown\n```\n\n## Setting Up a New Project\n\n### 1. Scaffold the project\n\nRun `cloche init` from your project root to create the `.cloche/` directory with\ndefault workflow, Dockerfile, and prompt templates:\n\n```\ncd my-project\ncloche init\n```\n\nOr create the structure manually:\n\n### 2. Create a workflow file\n\nAdd `.cloche/<name>.cloche`:\n\n```\nworkflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n\n  step test {\n    run = \"make test 2>&1\"\n    results = [success, fail]\n  }\n\n  step fix {\n    prompt = file(\".cloche/prompts/fix.md\")\n    max_attempts = \"2\"\n    results = [success, fail, give-up]\n  }\n\n  step update-docs {\n    prompt = file(\".cloche/prompts/update-docs.md\")\n    results = [success, fail]\n  }\n\n  implement:success -> test\n  implement:fail -> abort\n\n  test:success -> update-docs\n  test:fail -> fix\n\n  fix:success -> test\n  fix:fail -> abort\n  fix:give-up -> abort\n\n  update-docs:success -> done\n  update-docs:fail -> done\n}\n```\n\n### 3. Write prompt templates\n\nCreate `.cloche/prompts/` with markdown files:\n\n**`.cloche/prompts/implement.md`** â€” Instructions for the initial implementation:\n```markdown\nYou are working on a project. Implement the following change:\n\n## User Request\n(The user prompt is injected automatically by the agent adapter)\n\n## Guidelines\n- Follow existing project conventions\n- Write tests for new functionality\n- Run tests locally before declaring success\n```\n\n**`.cloche/prompts/fix.md`** â€” Instructions for fixing failures:\n```markdown\nThe previous attempt had failures. Review the output logs in .cloche/output/\nand fix the issues.\n\n## Guidelines\n- Read the test/lint output carefully\n- Fix the root cause, not the symptoms\n- Run tests again to verify your fix\n```\n\n**`.cloche/prompts/update-docs.md`** â€” Instructions for keeping docs in sync:\n```markdown\nReview the CLI source code and update usage documentation to reflect any changes.\n```\n\n### 4. Add overrides (optional)\n\nFiles in `.cloche/overrides/` are copied on top of `/workspace/` in the\ncontainer. Use this for container-specific configuration:\n\n```\n.cloche/overrides/\n  CLAUDE.md              # Container-specific CLAUDE.md (replaces host version)\n```\n\n### 5. Make sure your project builds in the container\n\nThe default Dockerfile generated by `cloche init` uses `ubuntu:24.04` as its\nbase image (configurable via `--image`). If your project needs different\ndependencies, edit `.cloche/Dockerfile`:\n\n```dockerfile\nFROM golang:1.25 AS builder\nWORKDIR /src\nCOPY go.mod go.sum ./\nRUN go mod download\nCOPY . .\nRUN CGO_ENABLED=0 go build -o /cloche-agent ./cmd/cloche-agent\n\nFROM ubuntu:24.04\nRUN apt-get update && apt-get install -y git <your-deps> && rm -rf /var/lib/apt/lists/*\nRUN npm install -g @anthropic-ai/claude-code\nCOPY --from=builder /cloche-agent /usr/local/bin/cloche-agent\nRUN useradd -m -s /bin/bash agent\nWORKDIR /workspace\nRUN chown agent:agent /workspace\nUSER agent\n```\n\nKey requirements for the image:\n- `cloche-agent` binary at `/usr/local/bin/cloche-agent`\n- `git` installed (for pushing results back)\n- An `agent` user (cloche wraps the command with `chown` + `su agent`)\n- `/workspace` as the working directory\n- Your project's build dependencies\n\nThe daemon automatically rebuilds the image when `.cloche/Dockerfile` changes\n(see `cloche run` above). To build manually:\n```\ndocker build -t my-project-agent -f .cloche/Dockerfile .\nCLOCHE_IMAGE=my-project-agent:latest bin/cloched\n```\n\n### 6. Run it\n\n```\ncd my-project\ncloche run --workflow develop --prompt \"Add feature X\"\n```\n\n## Writing Workflows\n\nWorkflow files use the `.cloche` extension and live in the `.cloche/` directory. See\n[workflows.md](workflows.md) for full DSL reference.\n\n### Step Types\n\n**Agent steps** (has `prompt`) â€” Invokes a coding agent autonomously:\n\n```\nstep implement {\n  prompt = file(\".cloche/prompts/implement.md\")\n  results = [success, fail]\n}\n```\n\n**Script steps** (has `run`) â€” Runs a shell command:\n\n```\nstep test {\n  run = \"make test 2>&1\"\n  results = [success, fail]\n}\n```\n\n### Wiring\n\nConnect steps with `step:result -> next_step`:\n\n```\nimplement:success -> test\nimplement:fail -> abort\ntest:success -> done\ntest:fail -> fix\n```\n\n`done` and `abort` are built-in terminals for success and failure.\n\n### Retry Loops\n\nWire failures back to earlier steps:\n\n```\ntest:fail -> fix\nfix:success -> test    // retry the test\nfix:fail -> abort\n```\n\n### Max Attempts\n\nLimit retries on agent steps. When exhausted, the step returns `give-up`:\n\n```\nstep fix {\n  prompt = file(\".cloche/prompts/fix.md\")\n  max_attempts = \"2\"\n  results = [success, fail, give-up]\n}\n```\n\n### Parallel Branches\n\nWire one result to multiple targets for concurrent execution:\n\n```\ntest:success -> lint\ntest:success -> quality\n```\n\n### Collect (Join)\n\nSynchronize parallel branches:\n\n```\ncollect all(lint:success, quality:success) -> done\n```\n\n`all` fires when every condition is met. `any` fires when at least one is.\n\n### Agent Command Override\n\nAgent steps use Claude Code by default. Override per-step:\n\n```\nstep implement {\n  prompt = \"...\"\n  agent_command = \"aider\"\n  results = [success, fail]\n}\n```\n\nOr at the workflow level via a `container` block:\n\n```\nworkflow \"develop\" {\n  container {\n    agent_command = \"gemini\"\n  }\n  ...\n}\n```\n\nOr globally via `CLOCHE_AGENT_COMMAND` environment variable.\n\nPriority (highest to lowest): step-level `agent_command`, workflow-level\n`container { agent_command }`, `CLOCHE_AGENT_COMMAND` env var, default (`claude`).\n\n### Agent Fallback Chains\n\nUse a comma-separated list in `agent_command` to configure fallback chains. If\nthe first agent errors without reporting a result, the system tries the next:\n\n```\nstep implement {\n  prompt = \"...\"\n  agent_command = \"claude,gemini,codex\"\n  results = [success, fail]\n}\n```\n\nFallback rules:\n- **Command not found or failed to start** â€” fall back to next command\n- **Exit non-zero without `CLOCHE_RESULT` marker** â€” fall back to next command\n- **Exit non-zero with `CLOCHE_RESULT` marker** â€” use that result (no fallback)\n- **Exit 0** â€” use result (no fallback)\n- **All commands fail to start** â€” step returns an error\n- **Last command crashes without marker** â€” step returns `fail`\n\nKnown agents have default arguments (e.g., Claude gets\n`-p --output-format text --dangerously-skip-permissions`). Other agents receive\nthe prompt on stdin with no extra flags. Override with `agent_args` at the step\nor workflow level.\n\n## Result Protocol\n\nSteps report results by writing a marker to stdout:\n\n```\nCLOCHE_RESULT:<name>\n```\n\nFor script steps, if no marker is written, the exit code determines the result:\n0 = `success`, non-zero = `fail`. Agent steps follow the same convention.\n\n## Prompt Assembly\n\nWhen an agent step runs, Cloche assembles a prompt from multiple sources:\n\n1. The step's `prompt` content (inline or from `file()`)\n2. The user prompt from `.cloche/<run-id>/prompt.txt` (set via `--prompt`)\n3. Validation output from `.cloche/<run-id>/output/*.log` (output from previous script steps)\n4. Result selection instructions listing the step's declared results\n\n## Project Directory Layout\n\n```\nmy-project/\nâ”śâ”€â”€ .cloche/\nâ”‚   â”śâ”€â”€ develop.cloche        # Workflow definition\nâ”‚   â”śâ”€â”€ Dockerfile            # Container image\nâ”‚   â”śâ”€â”€ prompts/\nâ”‚   â”‚   â”śâ”€â”€ implement.md      # Prompt templates\nâ”‚   â”‚   â”śâ”€â”€ fix.md\nâ”‚   â”‚   â””â”€â”€ update-docs.md\nâ”‚   â”śâ”€â”€ overrides/            # Files copied on top of /workspace/ in container\nâ”‚   â”‚   â””â”€â”€ CLAUDE.md         # Container-specific CLAUDE.md (optional)\nâ”‚   â””â”€â”€ <run-id>/             # Runtime state (gitignored)\nâ”‚       â”śâ”€â”€ prompt.txt        # User prompt (from --prompt flag)\nâ”‚       â”śâ”€â”€ output/\nâ”‚       â”‚   â”śâ”€â”€ full.log      # Unified chronological log (status + script + LLM)\nâ”‚       â”‚   â”śâ”€â”€ test.log      # Per-step script output\nâ”‚       â”‚   â””â”€â”€ llm-impl.log  # Per-step LLM conversation output\nâ”‚       â”śâ”€â”€ attempt_count/\nâ”‚       â”‚   â””â”€â”€ fix           # Retry counter for max_attempts\nâ”‚       â””â”€â”€ history.log       # Step execution log\nâ”śâ”€â”€ src/                      # Existing project source (untouched)\nâ”śâ”€â”€ CLAUDE.md                 # Host CLAUDE.md\nâ””â”€â”€ .git/\n```\n\n## Daemon Configuration\n\n| Variable | Default | Description |\n|----------|---------|-------------|\n| `CLOCHE_LISTEN` | `unix:///tmp/cloche.sock` | Listen address (unix socket or TCP) |\n| `CLOCHE_DB` | `cloche.db` | SQLite database path |\n| `CLOCHE_RUNTIME` | `docker` | `docker` (container) or `local` (subprocess, for dev) |\n| `CLOCHE_IMAGE` | `cloche-agent:latest` | Default Docker image |\n| `CLOCHE_HTTP` | â€” | HTTP address for the web dashboard. Not started unless set. |\n| `CLOCHE_AGENT_PATH` | (auto-detected) | Path to `cloche-agent` binary (local runtime) |\n| `CLOCHE_LLM_COMMAND` | â€” | Command for LLM calls â€” evolution and merge conflict resolution (e.g. `claude`) |\n| `ANTHROPIC_API_KEY` | â€” | Passed into Docker containers |\n| `CLOCHE_EXTRA_MOUNTS` | â€” | Extra bind mounts (comma-separated `host:container`) |\n| `CLOCHE_EXTRA_ENV` | â€” | Extra env vars (comma-separated `KEY=VALUE`) |\n\n### Client Configuration\n\n| Variable | Default | Description |\n|----------|---------|-------------|\n| `CLOCHE_ADDR` | `unix:///tmp/cloche.sock` | Daemon address (gRPC) |\n| `CLOCHE_HTTP` | `localhost:8080` | Daemon HTTP address (web dashboard, `cloche logs --follow`) |\n\n## Build Commands\n\n```\nmake build          # Build all binaries to bin/\nmake test           # Run all tests\nmake test-short     # Run tests (skip slow ones)\nmake lint           # Run go vet\nmake proto          # Regenerate gRPC code from protobuf\nmake docker-build   # Build the cloche-agent Docker image\nmake install        # Build, install to ~/.local/bin/, restart daemon\nmake clean          # Remove bin/\n```\n","numLines":621,"startLine":1,"totalLines":621}}}
