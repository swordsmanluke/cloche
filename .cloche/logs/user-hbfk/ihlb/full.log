ate\n    52â†’\t\t}\n    53â†’\n    54â†’\t\t// Check terminal states\n    55â†’\t\tswitch resp.State {\n    56â†’\t\tcase \"succeeded\":\n    57â†’\t\t\tos.Exit(0)\n    58â†’\t\tcase \"failed\", \"cancelled\":\n    59â†’\t\t\tif resp.ErrorMessage != \"\" {\n    60â†’\t\t\t\tfmt.Fprintf(os.Stderr, \"Error: %s\\n\", resp.ErrorMessage)\n    61â†’\t\t\t}\n    62â†’\t\t\tos.Exit(1)\n    63â†’\t\t}\n    64â†’\n    65â†’\t\t// Check container death\n    66â†’\t\tif !resp.ContainerAlive && resp.ContainerDeadSince != \"\" {\n    67â†’\t\t\tdeadSince, err := time.Parse(time.RFC3339Nano, resp.ContainerDeadSince)\n    68â†’\t\t\tif err == nil && time.Since(deadSince) > containerDeadThreshold {\n    69â†’\t\t\t\tfmt.Fprintf(os.Stderr, \"[%s] Container has been dead for >1 minute (since %s)\\n\",\n    70â†’\t\t\t\t\ttime.Now().Format(\"15:04:05\"), deadSince.Format(\"15:04:05\"))\n    71â†’\t\t\t\tos.Exit(1)\n    72â†’\t\t\t}\n    73â†’\t\t}\n    74â†’\n    75â†’\t\ttime.Sleep(pollInterval)\n    76â†’\t}\n    77â†’}\n    78â†’"}]},"parent_tool_use_id":null,"session_id":"cc2e6e8c-da94-4b06-a140-1a3c72b18ec3","uuid":"aa72b3ea-af3b-40c4-8469-3901cdf954a3","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/poll.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n)\n\nfunc cmdPoll(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche poll <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\trunID := args[0]\n\tpollInterval := 2 * time.Second\n\tcontainerDeadThreshold := 1 * time.Minute\n\n\tvar lastStepCount int\n\tvar lastState string\n\n\tfor {\n\t\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n\t\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: runID})\n\t\tcancel()\n\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\t// Pri