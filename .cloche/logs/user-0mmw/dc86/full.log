[2026-03-09T19:17:54Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011MsHdHbnhb97W12W3xeF56","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\"path/filepath\"\n    14→\t\"regexp\"\n    15→\t\"sort\"\n    16→\t\"strconv\"\n    17→\t\"strings\"\n    18→\t\"time\"\n    19→\n    20→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    21→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    22→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    23→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    24→)\n    25→\n    26→// HandlerOption configures optional Handler dependencies.\n    27→type HandlerOption func(*Handler)\n    28→\n    29→// WithContainerLogger sets the container runtime for fetching live logs.\n    30→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    31→\treturn func(h *Handler) { h.container = c }\n    32→}\n    33→\n    34→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    35→func WithContainerManager(c ContainerManager) HandlerOption {\n    36→\treturn func(h *Handler) { h.container = c }\n    37→}\n    38→\n    39→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    40→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    41→\treturn func(h *Handler) { h.logBroadcast = b }\n    42→}\n    43→\n    44→// WithLogStore sets the log store for indexed log file lookups.\n    45→func WithLogStore(ls ports.LogStore) HandlerOption {\n    46→\treturn func(h *Handler) { h.logStore = ls }\n    47→}\n    48→\n    49→// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    50→func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    51→\treturn func(h *Handler) { h.orchestrateFn = fn }\n    52→}\n    53→\n    54→// OrchestratorController provides per-project orchestrator control.\n    55→type OrchestratorController interface {\n    56→\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    57→\tSetEnabled(dir string, enabled bool)\n    58→\tSetConcurrency(dir string, concurrency int)\n    59→}\n    60→\n    61→// WithOrchestrator sets the orchestrator controller for project-level control.\n    62→func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    63→\treturn func(h *Handler) { h.orchestrator = oc }\n    64→}\n    65→\n    66→//go:embed templates/*.html static/*\n    67→var content embed.FS\n    68→\n    69→// Handler serves the web dashboard.\n    70→// ContainerLogger can retrieve logs from a container by ID.\n    71→type ContainerLogger interface {\n    72→\tLogs(ctx context.Context, containerID string) (string, error)\n    73→}\n    74→\n    75→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    76→type ContainerManager interface {\n    77→\tContainerLogger\n    78→\tRemove(ctx context.Context, containerID string) error\n    79→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    80→}\n    81→\n    82→type Handler struct {\n    83→\tstore         ports.RunStore\n    84→\tcaptures      ports.CaptureStore\n    85→\tlogStore      ports.LogStore\n    86→\tcontainer     ContainerLogger\n    87→\tlogBroadcast  *logstream.Broadcaster\n    88→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    89→\torchestrator  OrchestratorController\n    90→\tpages         map[string]*template.Template\n    91→\tmux           *http.ServeMux\n    92→}\n    93→\n    94→// NewHandler creates a web dashboard handler.\n    95→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    96→\tfuncMap := template.FuncMap{\n    97→\t\t\"stateColor\":       stateColor,\n    98→\t\t\"healthColor\":      healthColor,\n    99→\t\t\"formatTime\":       formatTime,\n   100→\t\t\"formatDuration\":   formatDuration,\n   101→\t\t\"truncate\":         truncate,\n   102→\t\t\"shortContainerID\": shortContainerID,\n   103→\t}\n   104→\n   105→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   106→\tif err != nil {\n   107→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   108→\t}\n   109→\n   110→\tpages := map[string]*template.Template{}\n   111→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   112→\t\tclone, err := base.Clone()\n   113→\t\tif err != nil {\n   114→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   115→\t\t}\n   116→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   117→\t\tif err != nil {\n   118→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   119→\t\t}\n   120→\t\tpages[page] = clone\n   121→\t}\n   122→\n   123→\th := &Handler{\n   124→\t\tstore:    store,\n   125→\t\tcaptures: captures,\n   126→\t\tpages:    pages,\n   127→\t\tmux:      http.NewServeMux(),\n   128→\t}\n   129→\tfor _, opt := range opts {\n   130→\t\topt(h)\n   131→\t}\n   132→\n   133→\tstaticFS, err := fs.Sub(content, \"static\")\n   134→\tif err != nil {\n   135→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   136→\t}\n   137→\n   138→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   139→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   140→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   141→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   142→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   143→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   144→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   145→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   146→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   147→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   148→\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   149→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   150→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   151→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   152→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   153→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   154→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   155→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   156→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   157→\n   158→\treturn h, nil\n   159→}\n   160→\n   161→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   162→\th.mux.ServeHTTP(w, r)\n   163→}\n   164→\n   165→// --- HTML handlers ---\n   166→\n   167→// projectOverviewEntry holds data for a single project card on the landing page.\n   168→type projectOverviewEntry struct {\n   169→\tDir         string\n   170→\tLabel       string\n   171→\tHealth      domain.HealthResult\n   172→\tRecentRuns  []recentRunDot\n   173→\tActiveCount int\n   174→}\n   175→\n   176→// recentRunDot is a minimal representation of a run for the mini history display.\n   177→type recentRunDot struct {\n   178→\tID    string\n   179→\tState string\n   180→}\n   181→\n   182→const healthWindowSize = 10\n   183→\n   184→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   185→\tprojects, _ := h.store.ListProjects(r.Context())\n   186→\tlabels := projectLabels(projects)\n   187→\n   188→\tvar entries []projectOverviewEntry\n   189→\tfor _, dir := range projects {\n   190→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   191→\t\tif err != nil {\n   192→\t\t\tcontinue\n   193→\t\t}\n   194→\n   195→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   196→\t\trunValues := make([]domain.Run, len(runs))\n   197→\t\tfor i, rr := range runs {\n   198→\t\t\trunValues[i] = *rr\n   199→\t\t}\n   200→\n   201→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   202→\n   203→\t\t// Take the last N runs for the mini history (most recent first).\n   204→\t\tn := healthWindowSize\n   205→\t\tif n > len(runs) {\n   206→\t\t\tn = len(runs)\n   207→\t\t}\n   208→\t\tdots := make([]recentRunDot, n)\n   209→\t\tfor i := 0; i < n; i++ {\n   210→\t\t\tdots[i] = recentRunDot{\n   211→\t\t\t\tID:    runs[i].ID,\n   212→\t\t\t\tState: string(runs[i].State),\n   213→\t\t\t}\n   214→\t\t}\n   215→\n   216→\t\tvar activeCount int\n   217→\t\tfor _, rr := range runs {\n   218→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   219→\t\t\t\tactiveCount++\n   220→\t\t\t}\n   221→\t\t}\n   222→\n   223→\t\tentries = append(entries, projectOverviewEntry{\n   224→\t\t\tDir:         dir,\n   225→\t\t\tLabel:       labels[dir],\n   226→\t\t\tHealth:      health,\n   227→\t\t\tRecentRuns:  dots,\n   228→\t\t\tActiveCount: activeCount,\n   229→\t\t})\n   230→\t}\n   231→\n   232→\tsort.Slice(entries, func(i, j int) bool {\n   233→\t\treturn entries[i].Label < entries[j].Label\n   234→\t})\n   235→\n   236→\tdata := map[string]any{\n   237→\t\t\"Title\":    \"Projects\",\n   238→\t\t\"Projects\": entries,\n   239→\t}\n   240→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   241→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   242→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   243→\t}\n   244→}\n   245→\n   246→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   247→\tprojectFilter := r.URL.Query().Get(\"project\")\n   248→\n   249→\tvar runs []*domain.Run\n   250→\tvar err error\n   251→\tif projectFilter != \"\" {\n   252→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   253→\t} else {\n   254→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   255→\t}\n   256→\tif err != nil {\n   257→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   258→\t\treturn\n   259→\t}\n   260→\n   261→\tprojects, _ := h.store.ListProjects(r.Context())\n   262→\tlabels := projectLabels(projects)\n   263→\n   264→\t// Count retained containers per project\n   265→\tcontainerCounts := map[string]int{}\n   266→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   267→\tfor _, run := range allRuns {\n   268→\t\tif run.ContainerKept {\n   269→\t\t\tcontainerCounts[run.ProjectDir]++\n   270→\t\t}\n   271→\t}\n   272→\n   273→\tvar projectList []projectEntry\n   274→\tfor _, dir := range projects {\n   275→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   276→\t}\n   277→\tsort.Slice(projectList, func(i, j int) bool {\n   278→\t\treturn projectList[i].Label < projectList[j].Label\n   279→\t})\n   280→\n   281→\tdata := map[string]any{\n   282→\t\t\"Title\":         \"Runs\",\n   283→\t\t\"Runs\":          runs,\n   284→\t\t\"Projects\":      projectList,\n   285→\t\t\"ProjectFilter\": projectFilter,\n   286→\t\t\"ProjectLabels\": labels,\n   287→\t}\n   288→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   289→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   290→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   291→\t}\n   292→}\n   293→\n   294→// stepEntry is a merged view of a step execution for the template.\n   295→type stepEntry struct {\n   296→\tIndex     int\n   297→\tStepName  string\n   298→\tResult    string\n   299→\tStartedAt time.Time\n   300→\tDuration  string\n   301→}\n   302→\n   303→// mergeCaptures collapses started/completed capture pairs into single entries.\n   304→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   305→\tvar entries []stepEntry\n   306→\t// Track pending started rows by step name (LIFO for retries)\n   307→\tpending := map[string]*domain.StepExecution{}\n   308→\n   309→\tfor _, c := range caps {\n   310→\t\tif c.Result == \"\" {\n   311→\t\t\t// step_started row\n   312→\t\t\tpending[c.StepName] = c\n   313→\t\t\tcontinue\n   314→\t\t}\n   315→\t\t// step_completed row — merge with pending started if available\n   316→\t\tstartedAt := c.StartedAt\n   317→\t\tif started := pending[c.StepName]; started != nil {\n   318→\t\t\tstartedAt = started.StartedAt\n   319→\t\t\tdelete(pending, c.StepName)\n   320→\t\t}\n   321→\t\tentries = append(entries, stepEntry{\n   322→\t\t\tIndex:     len(entries),\n   323→\t\t\tStepName:  c.StepName,\n   324→\t\t\tResult:    c.Result,\n   325→\t\t\tStartedAt: startedAt,\n   326→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   327→\t\t})\n   328→\t}\n   329→\n   330→\t// Append any started-but-not-completed steps (still running)\n   331→\tfor _, c := range caps {\n   332→\t\tif c.Result == \"\" {\n   333→\t\t\tif _, used := pending[c.StepName]; !used {\n   334→\t\t\t\tcontinue\n   335→\t\t\t}\n   336→\t\t\tentries = append(entries, stepEntry{\n   337→\t\t\t\tIndex:     len(entries),\n   338→\t\t\t\tStepName:  c.StepName,\n   339→\t\t\t\tStartedAt: c.StartedAt,\n   340→\t\t\t})\n   341→\t\t\tdelete(pending, c.StepName)\n   342→\t\t}\n   343→\t}\n   344→\n   345→\treturn entries\n   346→}\n   347→\n   348→// containerState inspects the container for a run and returns one of:\n   349→//   - \"running\"   – container exists and is running\n   350→//   - \"stopped\"   – container exists, not running, not kept\n   351→//   - \"available\" – container exists, not running, kept (can be deleted)\n   352→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   353→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   354→\tif run.ContainerID == \"\" {\n   355→\t\treturn \"removed\"\n   356→\t}\n   357→\tmgr, ok := h.container.(ContainerManager)\n   358→\tif !ok {\n   359→\t\treturn \"removed\"\n   360→\t}\n   361→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   362→\tif err != nil {\n   363→\t\treturn \"removed\"\n   364→\t}\n   365→\tif status.Running {\n   366→\t\treturn \"running\"\n   367→\t}\n   368→\tif run.ContainerKept {\n   369→\t\treturn \"available\"\n   370→\t}\n   371→\treturn \"stopped\"\n   372→}\n   373→\n   374→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   375→\tid := r.PathValue(\"id\")\n   376→\n   377→\trun, err := h.store.GetRun(r.Context(), id)\n   378→\tif err != nil {\n   379→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   380→\t\treturn\n   381→\t}\n   382→\n   383→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   384→\tif err != nil {\n   385→\t\tcaps = nil // non-fatal\n   386→\t}\n   387→\n   388→\tsteps := mergeCaptures(caps)\n   389→\n   390→\tdata := map[string]any{\n   391→\t\t\"Title\":          \"Run \" + run.ID,\n   392→\t\t\"Run\":            run,\n   393→\t\t\"Steps\":          steps,\n   394→\t\t\"Page\":           \"detail\",\n   395→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   396→\t}\n   397→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   398→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   399→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   400→\t}\n   401→}\n   402→\n   403→// --- JSON API handlers ---\n   404→\n   405→type apiRun struct {\n   406→\tID           string `json:\"id\"`\n   407→\tWorkflowName string `json:\"workflow_name\"`\n   408→\tProjectDir   string `json:\"project_dir\"`\n   409→\tProjectLabel string `json:\"project_label\"`\n   410→\tState        string `json:\"state\"`\n   411→\tStartedAt    string `json:\"started_at\"`\n   412→\tCompletedAt  string `json:\"completed_at\"`\n   413→\tContainerID  string `json:\"container_id\"`\n   414→\tErrorMessage string `json:\"error_message\"`\n   415→}\n   416→\n   417→type apiStep struct {\n   418→\tStepName    string `json:\"step_name\"`\n   419→\tResult      string `json:\"result\"`\n   420→\tStartedAt   string `json:\"started_at\"`\n   421→\tCompletedAt string `json:\"completed_at\"`\n   422→\tDuration    string `json:\"duration\"`\n   423→}\n   424→\n   425→type apiRunDetail struct {\n   426→\tapiRun\n   427→\tContainerState string    `json:\"container_state\"`\n   428→\tSteps          []apiStep `json:\"steps\"`\n   429→}\n   430→\n   431→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   432→\treturn apiRun{\n   433→\t\tID:           r.ID,\n   434→\t\tWorkflowName: r.WorkflowName,\n   435→\t\tProjectDir:   r.ProjectDir,\n   436→\t\tProjectLabel: labels[r.ProjectDir],\n   437→\t\tState:        string(r.State),\n   438→\t\tStartedAt:    formatTime(r.StartedAt),\n   439→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   440→\t\tContainerID:  r.ContainerID,\n   441→\t\tErrorMessage: r.ErrorMessage,\n   442→\t}\n   443→}\n   444→\n   445→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   446→\tprojectFilter := r.URL.Query().Get(\"project\")\n   447→\n   448→\tvar runs []*domain.Run\n   449→\tvar err error\n   450→\tif projectFilter != \"\" {\n   451→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   452→\t} else {\n   453→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   454→\t}\n   455→\tif err != nil {\n   456→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   457→\t\treturn\n   458→\t}\n   459→\n   460→\tprojects, _ := h.store.ListProjects(r.Context())\n   461→\tlabels := projectLabels(projects)\n   462→\n   463→\tresult := make([]apiRun, len(runs))\n   464→\tfor i, run := range runs {\n   465→\t\tresult[i] = toAPIRun(run, labels)\n   466→\t}\n   467→\n   468→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   469→\tjson.NewEncoder(w).Encode(result)\n   470→}\n   471→\n   472→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   473→\tprojects, err := h.store.ListProjects(r.Context())\n   474→\tif err != nil {\n   475→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   476→\t\treturn\n   477→\t}\n   478→\tlabels := projectLabels(projects)\n   479→\n   480→\ttype apiHealth struct {\n   481→\t\tStatus string `json:\"status\"`\n   482→\t\tPassed int    `json:\"passed\"`\n   483→\t\tFailed int    `json:\"failed\"`\n   484→\t\tTotal  int    `json:\"total\"`\n   485→\t}\n   486→\ttype apiProject struct {\n   487→\t\tDir         string    `json:\"dir\"`\n   488→\t\tLabel       string    `json:\"label\"`\n   489→\t\tHealth      apiHealth `json:\"health\"`\n   490→\t\tActiveCount int       `json:\"active_count\"`\n   491→\t}\n   492→\tresult := make([]apiProject, len(projects))\n   493→\tfor i, dir := range projects {\n   494→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   495→\t\trunValues := make([]domain.Run, len(runs))\n   496→\t\tfor j, rr := range runs {\n   497→\t\t\trunValues[j] = *rr\n   498→\t\t}\n   499→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   500→\t\tvar activeCount int\n   501→\t\tfor _, rr := range runs {\n   502→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   503→\t\t\t\tactiveCount++\n   504→\t\t\t}\n   505→\t\t}\n   506→\t\tresult[i] = apiProject{\n   507→\t\t\tDir:   dir,\n   508→\t\t\tLabel: labels[dir],\n   509→\t\t\tHealth: apiHealth{\n   510→\t\t\t\tStatus: string(health.Status),\n   511→\t\t\t\tPassed: health.Passed,\n   512→\t\t\t\tFailed: health.Failed,\n   513→\t\t\t\tTotal:  health.Total,\n   514→\t\t\t},\n   515→\t\t\tActiveCount: activeCount,\n   516→\t\t}\n   517→\t}\n   518→\n   519→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   520→\tjson.NewEncoder(w).Encode(result)\n   521→}\n   522→\n   523→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   524→\tid := r.PathValue(\"id\")\n   525→\n   526→\trun, err := h.store.GetRun(r.Context(), id)\n   527→\tif err != nil {\n   528→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   529→\t\treturn\n   530→\t}\n   531→\n   532→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   533→\tif err != nil {\n   534→\t\tcaps = nil\n   535→\t}\n   536→\n   537→\tprojects, _ := h.store.ListProjects(r.Context())\n   538→\tlabels := projectLabels(projects)\n   539→\n   540→\tmerged := mergeCaptures(caps)\n   541→\tsteps := make([]apiStep, len(merged))\n   542→\tfor i, e := range merged {\n   543→\t\tsteps[i] = apiStep{\n   544→\t\t\tStepName:  e.StepName,\n   545→\t\t\tResult:    e.Result,\n   546→\t\t\tStartedAt: formatTime(e.StartedAt),\n   547→\t\t\tDuration:  e.Duration,\n   548→\t\t}\n   549→\t}\n   550→\n   551→\tdetail := apiRunDetail{\n   552→\t\tapiRun:         toAPIRun(run, labels),\n   553→\t\tContainerState: h.containerState(r.Context(), run),\n   554→\t\tSteps:          steps,\n   555→\t}\n   556→\n   557→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   558→\tjson.NewEncoder(w).Encode(detail)\n   559→}\n   560→\n   561→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   562→\tid := r.PathValue(\"id\")\n   563→\tstep := r.PathValue(\"step\")\n   564→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   565→\n   566→\trun, err := h.store.GetRun(r.Context(), id)\n   567→\tif err != nil {\n   568→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   569→\t\treturn\n   570→\t}\n   571→\n   572→\t// Try log index first for fast lookup\n   573→\tif h.logStore != nil {\n   574→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   575→\t\tif err == nil && len(logFiles) > 0 {\n   576→\t\t\t// If type filter specified, narrow results\n   577→\t\t\tfor _, lf := range logFiles {\n   578→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   579→\t\t\t\t\tcontinue\n   580→\t\t\t\t}\n   581→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   582→\t\t\t\tif readErr == nil && len(data) > 0 {\n   583→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   584→\t\t\t\t\tw.Write(data)\n   585→\t\t\t\t\treturn\n   586→\t\t\t\t}\n   587→\t\t\t}\n   588→\t\t}\n   589→\t}\n   590→\n   591→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   592→\n   593→\t// Fall back to file path conventions\n   594→\t// If type is \"llm\", try llm-<step>.log\n   595→\tif logType == \"llm\" {\n   596→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   597→\t\tdata, err := os.ReadFile(llmPath)\n   598→\t\tif err == nil && len(data) > 0 {\n   599→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   600→\t\t\tw.Write(data)\n   601→\t\t\treturn\n   602→\t\t}\n   603→\t}\n   604→\n   605→\t// Try per-step output first, fall back to container.log, then live docker logs\n   606→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   607→\tdata, err := os.ReadFile(outputPath)\n   608→\tif err == nil && len(data) > 0 {\n   609→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   610→\t\tw.Write(data)\n   611→\t\treturn\n   612→\t}\n   613→\n   614→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   615→\tdata, err = os.ReadFile(containerLog)\n   616→\tif err == nil && len(data) > 0 {\n   617→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   618→\t\tw.Write(data)\n   619→\t\treturn\n   620→\t}\n   621→\n   622→\t// Last resort: try live docker logs from still-existing container\n   623→\tif h.container != nil && run.ContainerID != \"\" {\n   624→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   625→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   626→\t\t\tw.Write([]byte(logs))\n   627→\t\t\treturn\n   628→\t\t}\n   629→\t}\n   630→\n   631→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   632→}\n   633→\n   634→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   635→\tid := r.PathValue(\"id\")\n   636→\n   637→\trun, err := h.store.GetRun(r.Context(), id)\n   638→\tif err != nil {\n   639→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   640→\t\tw.WriteHeader(http.StatusNotFound)\n   641→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   642→\t\treturn\n   643→\t}\n   644→\n   645→\tmgr, ok := h.container.(ContainerManager)\n   646→\tif !ok || run.ContainerID == \"\" {\n   647→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   648→\t\tw.WriteHeader(http.StatusBadRequest)\n   649→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   650→\t\treturn\n   651→\t}\n   652→\n   653→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   654→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   655→\t\tw.WriteHeader(http.StatusInternalServerError)\n   656→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   657→\t\treturn\n   658→\t}\n   659→\n   660→\trun.ContainerKept = false\n   661→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   662→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   663→\t\tw.WriteHeader(http.StatusInternalServerError)\n   664→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   665→\t\treturn\n   666→\t}\n   667→\n   668→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   669→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   670→}\n   671→\n   672→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   673→\tlabel := r.PathValue(\"name\")\n   674→\n   675→\t// Resolve label back to project directory via the store.\n   676→\tprojects, _ := h.store.ListProjects(r.Context())\n   677→\tlabels := projectLabels(projects)\n   678→\tvar projectDir string\n   679→\tfor dir, l := range labels {\n   680→\t\tif l == label {\n   681→\t\t\tprojectDir = dir\n   682→\t\t\tbreak\n   683→\t\t}\n   684→\t}\n   685→\tif projectDir == \"\" {\n   686→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   687→\t\tw.WriteHeader(http.StatusNotFound)\n   688→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   689→\t\treturn\n   690→\t}\n   691→\n   692→\tif h.orchestrateFn == nil {\n   693→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   694→\t\tw.WriteHeader(http.StatusNotImplemented)\n   695→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   696→\t\treturn\n   697→\t}\n   698→\n   699→\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   700→\tif err != nil {\n   701→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   702→\t\tw.WriteHeader(http.StatusInternalServerError)\n   703→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   704→\t\treturn\n   705→\t}\n   706→\n   707→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   708→\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   709→}\n   710→\n   711→// handleAPIStream serves an SSE stream of log lines for a run.\n   712→// For active runs, it subscribes to the live broadcaster.\n   713→// For completed runs, it serves the archived full.log then closes.\n   714→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   715→\tid := r.PathValue(\"id\")\n   716→\n   717→\trun, err := h.store.GetRun(r.Context(), id)\n   718→\tif err != nil {\n   719→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   720→\t\treturn\n   721→\t}\n   722→\n   723→\tflusher, ok := w.(http.Flusher)\n   724→\tif !ok {\n   725→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   726→\t\treturn\n   727→\t}\n   728→\n   729→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   730→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   731→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   732→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   733→\n   734→\tisComplete := run.State == domain.RunStateSucceeded ||\n   735→\t\trun.State == domain.RunStateFailed ||\n   736→\t\trun.State == domain.RunStateCancelled\n   737→\n   738→\tif isComplete {\n   739→\t\t// Serve archived full.log\n   740→\t\th.streamFullLog(w, flusher, run)\n   741→\t\t// Send done event\n   742→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   743→\t\tflusher.Flush()\n   744→\t\treturn\n   745→\t}\n   746→\n   747→\t// Active run: subscribe to live broadcaster\n   748→\tif h.logBroadcast == nil {\n   749→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   750→\t\treturn\n   751→\t}\n   752→\n   753→\tsub := h.logBroadcast.Subscribe(id)\n   754→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   755→\n   756→\tctx := r.Context()\n   757→\tfor {\n   758→\t\tselect {\n   759→\t\tcase <-ctx.Done():\n   760→\t\t\treturn\n   761→\t\tcase line, ok := <-sub.C:\n   762→\t\t\tif !ok {\n   763→\t\t\t\t// Stream finished (run completed)\n   764→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   765→\t\t\t\tflusher.Flush()\n   766→\t\t\t\treturn\n   767→\t\t\t}\n   768→\t\t\tdata, _ := json.Marshal(line)\n   769→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   770→\t\t\tflusher.Flush()\n   771→\t\t}\n   772→\t}\n   773→}\n   774→\n   775→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   776→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   777→\n   778→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   779→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   780→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   781→\tf, err := os.Open(logPath)\n   782→\tif err != nil {\n   783→\t\treturn\n   784→\t}\n   785→\tdefer f.Close()\n   786→\n   787→\tscanner := bufio.NewScanner(f)\n   788→\tfor scanner.Scan() {\n   789→\t\ttext := scanner.Text()\n   790→\t\tline := parseFullLogLine(text)\n   791→\t\tdata, _ := json.Marshal(line)\n   792→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   793→\t\tflusher.Flush()\n   794→\t}\n   795→}\n   796→\n   797→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   798→func parseFullLogLine(text string) logstream.LogLine {\n   799→\tm := logLineRegex.FindStringSubmatch(text)\n   800→\tif m == nil {\n   801→\t\treturn logstream.LogLine{\n   802→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   803→\t\t\tType:      \"script\",\n   804→\t\t\tContent:   text,\n   805→\t\t}\n   806→\t}\n   807→\treturn logstream.LogLine{\n   808→\t\tTimestamp: m[1],\n   809→\t\tType:      m[2],\n   810→\t\tContent:   m[3],\n   811→\t}\n   812→}\n   813→\n   814→// --- Project detail handlers ---\n   815→\n   816→// resolveProjectDir resolves a project label from the URL to its directory path.\n   817→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   818→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   819→\tlabel := r.PathValue(\"name\")\n   820→\tprojects, _ := h.store.ListProjects(r.Context())\n   821→\tlabels := projectLabels(projects)\n   822→\tfor dir, l := range labels {\n   823→\t\tif l == label {\n   824→\t\t\treturn dir, label, true\n   825→\t\t}\n   826→\t}\n   827→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   828→\tw.WriteHeader(http.StatusNotFound)\n   829→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   830→\treturn \"\", \"\", false\n   831→}\n   832→\n   833→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   834→\tdir, label, ok := h.resolveProjectDir(w, r)\n   835→\tif !ok {\n   836→\t\treturn\n   837→\t}\n   838→\n   839→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   840→\tn := 10\n   841→\tif n > len(runs) {\n   842→\t\tn = len(runs)\n   843→\t}\n   844→\tdots := make([]recentRunDot, n)\n   845→\tfor i := 0; i < n; i++ {\n   846→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   847→\t}\n   848→\n   849→\tdata := map[string]any{\n   850→\t\t\"Title\":      label,\n   851→\t\t\"Label\":      label,\n   852→\t\t\"Dir\":        dir,\n   853→\t\t\"RecentRuns\": dots,\n   854→\t}\n   855→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   856→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   857→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   858→\t}\n   859→}\n   860→\n   861→func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   862→\tdir, _, ok := h.resolveProjectDir(w, r)\n   863→\tif !ok {\n   864→\t\treturn\n   865→\t}\n   866→\tif h.orchestrator == nil {\n   867→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   868→\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   869→\t\treturn\n   870→\t}\n   871→\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   872→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   873→\tjson.NewEncoder(w).Encode(map[string]any{\n   874→\t\t\"enabled\":     enabled,\n   875→\t\t\"in_flight\":   inFlight,\n   876→\t\t\"concurrency\": concurrency,\n   877→\t})\n   878→}\n   879→\n   880→func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   881→\tdir, _, ok := h.resolveProjectDir(w, r)\n   882→\tif !ok {\n   883→\t\treturn\n   884→\t}\n   885→\tif h.orchestrator == nil {\n   886→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   887→\t\tw.WriteHeader(http.StatusNotImplemented)\n   888→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   889→\t\treturn\n   890→\t}\n   891→\th.orchestrator.SetEnabled(dir, true)\n   892→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   893→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   894→}\n   895→\n   896→func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   897→\tdir, _, ok := h.resolveProjectDir(w, r)\n   898→\tif !ok {\n   899→\t\treturn\n   900→\t}\n   901→\tif h.orchestrator == nil {\n   902→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   903→\t\tw.WriteHeader(http.StatusNotImplemented)\n   904→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   905→\t\treturn\n   906→\t}\n   907→\th.orchestrator.SetEnabled(dir, false)\n   908→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   909→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   910→}\n   911→\n   912→func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   913→\tdir, _, ok := h.resolveProjectDir(w, r)\n   914→\tif !ok {\n   915→\t\treturn\n   916→\t}\n   917→\tif h.orchestrator == nil {\n   918→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   919→\t\tw.WriteHeader(http.StatusNotImplemented)\n   920→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   921→\t\treturn\n   922→\t}\n   923→\tvar body struct {\n   924→\t\tConcurrency int `json:\"concurrency\"`\n   925→\t}\n   926→\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n   927→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   928→\t\tw.WriteHeader(http.StatusBadRequest)\n   929→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n   930→\t\treturn\n   931→\t}\n   932→\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n   933→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   934→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   935→}\n   936→\n   937→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   938→\tdir, _, ok := h.resolveProjectDir(w, r)\n   939→\tif !ok {\n   940→\t\treturn\n   941→\t}\n   942→\n   943→\t// Docker image: read FROM line from Dockerfile\n   944→\tdockerImage := \"\"\n   945→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   946→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   947→\t\t// Find the last FROM line (final stage)\n   948→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   949→\t\t\ttrimmed := strings.TrimSpace(line)\n   950→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   951→\t\t\t\tparts := strings.Fields(trimmed)\n   952→\t\t\t\tif len(parts) >= 2 {\n   953→\t\t\t\t\tdockerImage = parts[1]\n   954→\t\t\t\t}\n   955→\t\t\t}\n   956→\t\t}\n   957→\t}\n   958→\n   959→\t// Version\n   960→\tversion := 0\n   961→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   962→\tif data, err := os.ReadFile(versionPath); err == nil {\n   963→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   964→\t\t\tversion = v\n   965→\t\t}\n   966→\t}\n   967→\n   968→\t// Prompt files with content\n   969→\ttype promptFile struct {\n   970→\t\tPath    string `json:\"path\"`\n   971→\t\tContent string `json:\"content\"`\n   972→\t}\n   973→\n   974→\tvar promptFiles []promptFile\n   975→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   976→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n   977→\t\tfor _, e := range entries {\n   978→\t\t\tif e.IsDir() {\n   979→\t\t\t\tcontinue\n   980→\t\t\t}\n   981→\t\t\tabsPath := filepath.Join(promptsDir, e.Name())\n   982→\t\t\tcontent, err := os.ReadFile(absPath)\n   983→\t\t\tif err != nil {\n   984→\t\t\t\tcontinue\n   985→\t\t\t}\n   986→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n   987→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, Content: string(content)})\n   988→\t\t}\n   989→\t}\n   990→\n   991→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   992→\tjson.NewEncoder(w).Encode(map[string]any{\n   993→\t\t\"docker_image\": dockerImage,\n   994→\t\t\"version\":      version,\n   995→\t\t\"prompt_files\": promptFiles,\n   996→\t})\n   997→}\n   998→\n   999→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1000→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1001→\tif !ok {\n  1002→\t\treturn\n  1003→\t}\n  1004→\n  1005→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1006→\tentries, err := os.ReadDir(clocheDir)\n  1007→\tif err != nil {\n  1008→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1009→\t\tjson.NewEncoder(w).Encode([]any{})\n  1010→\t\treturn\n  1011→\t}\n  1012→\n  1013→\ttype apiWire struct {\n  1014→\t\tFrom   string `json:\"from\"`\n  1015→\t\tResult string `json:\"result\"`\n  1016→\t\tTo     string `json:\"to\"`\n  1017→\t}\n  1018→\ttype apiStepDef struct {\n  1019→\t\tName    string            `json:\"name\"`\n  1020→\t\tType    string            `json:\"type\"`\n  1021→\t\tResults []string          `json:\"results\"`\n  1022→\t\tConfig  map[string]string `json:\"config\"`\n  1023→\t}\n  1024→\ttype apiWorkflow struct {\n  1025→\t\tName      string       `json:\"name\"`\n  1026→\t\tFile      string       `json:\"file\"`\n  1027→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1028→\t\tWires     []apiWire    `json:\"wires\"`\n  1029→\t\tEntryStep string       `json:\"entry_step\"`\n  1030→\t}\n  1031→\n  1032→\tvar workflows []apiWorkflow\n  1033→\tfor _, e := range entries {\n  1034→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1035→\t\t\tcontinue\n  1036→\t\t}\n  1037→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1038→\t\tif err != nil {\n  1039→\t\t\tcontinue\n  1040→\t\t}\n  1041→\t\twf, err := dsl.ParseForContainer(string(data))\n  1042→\t\tif err != nil {\n  1043→\t\t\tcontinue\n  1044→\t\t}\n  1045→\t\tvar steps []apiStepDef\n  1046→\t\tfor _, s := range wf.Steps {\n  1047→\t\t\tsteps = append(steps, apiStepDef{\n  1048→\t\t\t\tName:    s.Name,\n  1049→\t\t\t\tType:    string(s.Type),\n  1050→\t\t\t\tResults: s.Results,\n  1051→\t\t\t\tConfig:  s.Config,\n  1052→\t\t\t})\n  1053→\t\t}\n  1054→\t\t// Sort steps by name for consistent ordering\n  1055→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1056→\n  1057→\t\tvar wires []apiWire\n  1058→\t\tfor _, wire := range wf.Wiring {\n  1059→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1060→\t\t}\n  1061→\n  1062→\t\tworkflows = append(workflows, apiWorkflow{\n  1063→\t\t\tName:      wf.Name,\n  1064→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1065→\t\t\tSteps:     steps,\n  1066→\t\t\tWires:     wires,\n  1067→\t\t\tEntryStep: wf.EntryStep,\n  1068→\t\t})\n  1069→\t}\n  1070→\n  1071→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1072→\tjson.NewEncoder(w).Encode(workflows)\n  1073→}\n  1074→\n  1075→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1076→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1077→\tif !ok {\n  1078→\t\treturn\n  1079→\t}\n  1080→\tworkflowName := r.PathValue(\"workflow\")\n  1081→\tstepName := r.PathValue(\"step\")\n  1082→\n  1083→\t// Find the workflow file\n  1084→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1085→\tvar wf *domain.Workflow\n  1086→\tentries, _ := os.ReadDir(clocheDir)\n  1087→\tfor _, e := range entries {\n  1088→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1089→\t\t\tcontinue\n  1090→\t\t}\n  1091→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1092→\t\tif err != nil {\n  1093→\t\t\tcontinue\n  1094→\t\t}\n  1095→\t\tparsed, err := dsl.ParseForContainer(string(data))\n  1096→\t\tif err != nil {\n  1097→\t\t\tcontinue\n  1098→\t\t}\n  1099→\t\tif parsed.Name == workflowName {\n  1100→\t\t\twf = parsed\n  1101→\t\t\tbreak\n  1102→\t\t}\n  1103→\t}\n  1104→\tif wf == nil {\n  1105→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1106→\t\treturn\n  1107→\t}\n  1108→\n  1109→\tstep, ok := wf.Steps[stepName]\n  1110→\tif !ok {\n  1111→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1112→\t\treturn\n  1113→\t}\n  1114→\n  1115→\t// Try to read the referenced file from step config\n  1116→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1117→\n  1118→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1119→\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1120→\t\tif err == nil {\n  1121→\t\t\tw.Write(data)\n  1122→\t\t\treturn\n  1123→\t\t}\n  1124→\t}\n  1125→\tif script := step.Config[\"command\"]; script != \"\" {\n  1126→\t\tw.Write([]byte(script))\n  1127→\t\treturn\n  1128→\t}\n  1129→\tif script := step.Config[\"script\"]; script != \"\" {\n  1130→\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1131→\t\tif err == nil {\n  1132→\t\t\tw.Write(data)\n  1133→\t\t\treturn\n  1134→\t\t}\n  1135→\t\tw.Write([]byte(script))\n  1136→\t\treturn\n  1137→\t}\n  1138→\n  1139→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1140→}\n  1141→\n  1142→// --- Template helpers ---\n  1143→\n  1144→func stateColor(state domain.RunState) string {\n  1145→\tswitch state {\n  1146→\tcase domain.RunStatePending:\n  1147→\t\treturn \"pending\"\n  1148→\tcase domain.RunStateRunning:\n  1149→\t\treturn \"running\"\n  1150→\tcase domain.RunStateSucceeded:\n  1151→\t\treturn \"succeeded\"\n  1152→\tcase domain.RunStateFailed:\n  1153→\t\treturn \"failed\"\n  1154→\tcase domain.RunStateCancelled:\n  1155→\t\treturn \"cancelled\"\n  1156→\tdefault:\n  1157→\t\treturn \"pending\"\n  1158→\t}\n  1159→}\n  1160→\n  1161→func healthColor(status domain.HealthStatus) string {\n  1162→\tswitch status {\n  1163→\tcase domain.HealthGreen:\n  1164→\t\treturn \"green\"\n  1165→\tcase domain.HealthYellow:\n  1166→\t\treturn \"yellow\"\n  1167→\tcase domain.HealthRed:\n  1168→\t\treturn \"red\"\n  1169→\tcase domain.HealthBlue:\n  1170→\t\treturn \"blue\"\n  1171→\tdefault:\n  1172→\t\treturn \"grey\"\n  1173→\t}\n  1174→}\n  1175→\n  1176→func formatTime(t time.Time) string {\n  1177→\tif t.IsZero() {\n  1178→\t\treturn \"\"\n  1179→\t}\n  1180→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1181→}\n  1182→\n  1183→func formatDuration(start, end time.Time) string {\n  1184→\tif start.IsZero() || end.IsZero() {\n  1185→\t\treturn \"\"\n  1186→\t}\n  1187→\td := end.Sub(start)\n  1188→\tif d < time.Second {\n  1189→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1190→\t}\n  1191→\tif d < time.Minute {\n  1192→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1193→\t}\n  1194→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1195→}\n  1196→\n  1197→func truncate(s string, n int) string {\n  1198→\tif len(s) <= n {\n  1199→\t\treturn s\n  1200→\t}\n  1201→\treturn s[:n] + \"...\"\n  1202→}\n  1203→\n  1204→func shortContainerID(id string) string {\n  1205→\tif len(id) > 12 {\n  1206→\t\treturn id[:12]\n  1207→\t}\n  1208→\treturn id\n  1209→}\n  1210→\n  1211→// projectLabels builds a mapping from full project directory paths to short\n  1212→// display labels. Each label is the final directory component (e.g.\n  1213→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1214→// the same final name, the parent directory is prepended to disambiguate\n  1215→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1216→func projectLabels(dirs []string) map[string]string {\n  1217→\tlabels := make(map[string]string, len(dirs))\n  1218→\t// Group dirs by their base name to detect conflicts.\n  1219→\tbyBase := map[string][]string{}\n  1220→\tfor _, d := range dirs {\n  1221→\t\tbase := filepath.Base(d)\n  1222→\t\tbyBase[base] = append(byBase[base], d)\n  1223→\t}\n  1224→\tfor base, paths := range byBase {\n  1225→\t\tif len(paths) == 1 {\n  1226→\t\t\tlabels[paths[0]] = base\n  1227→\t\t} else {\n  1228→\t\t\tfor _, p := range paths {\n  1229→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1230→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1231→\t\t\t}\n  1232→\t\t}\n  1233→\t}\n  1234→\treturn labels\n  1235→}\n  1236→\n  1237→type projectEntry struct {\n  1238→\tDir            string\n  1239→\tLabel          string\n  1240→\tContainerCount int\n  1241→}\n  1242→"}]},"parent_tool_use_id":null,"session_id":"a4643c6c-1780-4e6b-9855-ae4202fd036f","uuid":"4c353aef-f426-4a4e-9f59-dc6fd088430f","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\nfunc WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n\treturn func(h *Handler) { h.orchestrateFn = fn }\n}\n\n// OrchestratorController provides per-project orchestrator control.\ntype OrchestratorController interface {\n\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n\tSetEnabled(dir string, enabled bool)\n\tSetConcurrency(dir string, concurrency int)\n}\n\n// WithOrchestrator sets the orchestrator controller for project-level control.\nfunc WithOrchestrator(oc OrchestratorController) HandlerOption {\n\treturn func(h *Handler) { h.orchestrator = oc }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore         ports.RunStore\n\tcaptures      ports.CaptureStore\n\tlogStore      ports.LogStore\n\tcontainer     ContainerLogger\n\tlogBroadcast  *logstream.Broadcaster\n\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n\torchestrator  OrchestratorController\n\tpages         map[string]*template.Template\n\tmux           *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\n\t// Resolve label back to project directory via the store.\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tvar projectDir string\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\tprojectDir = dir\n\t\t\tbreak\n\t\t}\n\t}\n\tif projectDir == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\t\treturn\n\t}\n\n\tif h.orchestrateFn == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\n\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n\t\treturn\n\t}\n\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"enabled\":     enabled,\n\t\t\"in_flight\":   inFlight,\n\t\t\"concurrency\": concurrency,\n\t})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, true)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, false)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\tvar body struct {\n\t\tConcurrency int `json:\"concurrency\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n\t\treturn\n\t}\n\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files with content\n\ttype promptFile struct {\n\t\tPath    string `json:\"path\"`\n\t\tContent string `json:\"content\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tabsPath := filepath.Join(promptsDir, e.Name())\n\t\t\tcontent, err := os.ReadFile(absPath)\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, Content: string(content)})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.ParseForContainer(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.ParseForContainer(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\tif script := step.Config[\"command\"]; script != \"\" {\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1242,"startLine":1,"totalLines":1242}}}
