t string `json:\"content\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tabsPath := filepath.Join(promptsDir, e.Name())\n\t\t\tcontent, err := os.ReadFile(absPath)\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, Content: string(content)})\n\t\t}\n\t}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":7044,"cache_read_input_tokens":16974,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":7044},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"574c1595-2097-4277-9692-dc2a13d938c4","uuid":"f34cf55b-6415-4d31-9759-3595c00259f2"}
