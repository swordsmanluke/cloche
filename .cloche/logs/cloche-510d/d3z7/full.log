as workflow name for backwards compat\n   197→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   198→\t\t\t\tworkflow = args[i]\n   199→\t\t\t}\n   200→\t\t}\n   201→\t}\n   202→\n   203→\tif workflow == \"\" {\n   204→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"] [--issue ID]\\n\")\n   205→\t\tos.Exit(1)\n   206→\t}\n   207→\n   208→\tcwd, _ := os.Getwd()\n   209→\n   210→\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n   211→\t// Try loading from any .cloche file; only extract image for container workflows.\n   212→\tvar image string\n   213→\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n   214→\t\timage = wf.Config[\"container.image\"]\n   215→\t}\n   216→\n   217→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   218→\t\tWorkflowName:  workflow,\n   219→\t\tProjectDir:    cwd,\n   220→\t\tImage:         image,\n   221→\t\tPrompt:        prompt,\n   222→\t\tKeepContainer: keepContainer,\n   223→\t\tTitle:         title,\n   224→\t\tIssueId:       issueID,\n   225→\t})\n   226→\tif err != nil {\n   227→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   228→\t\tos.Exit(1)\n   229→\t}\n   230→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   231→}\n   232→\n   233→func cmdResume(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   234→\tif len(args) < 1 {\n   235→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche resume <run-id> [step-name]\\n\")\n   236→\t\tos.Exit(1)\n   237→\t}\n   238→\n   239→\trunID := args[0]\n   240→\tstepName := \"\"\n   241→\tif len(args) > 1 {\n   242→\t\tstepName = args[1]\n   243→\t}\n   244→\n   245→\t// Send resume via gRPC metadata on a RunWorkflow call\n   246→\tmd := metadata.Pairs(\n   247→\t\t\"x-cloche-resume-run-id\", runID,\n   248→\t\t\"x-cloche-resume-step\", stepName,\n   249→\t)\n   250→\tctx = metadata.NewOutgoingCon