te: \"succeeded\"},\n    49→\t\t\t\t{RunId: \"run-2\", State: \"failed\"},\n    50→\t\t\t\t{RunId: \"run-3\", State: \"succeeded\"},\n    51→\t\t\t},\n    52→\t\t},\n    53→\t}\n    54→\n    55→\tvar buf bytes.Buffer\n    56→\tctx := context.Background()\n    57→\n    58→\t// Test the project-specific output path.\n    59→\tcmdStatusProject(ctx, client, &buf, \"/fake/project\")\n    60→\n    61→\tout := buf.String()\n    62→\tif !strings.Contains(out, \"Project: my-project\") {\n    63→\t\tt.Errorf(\"expected project name, got:\\n%s\", out)\n    64→\t}\n    65→\tif !strings.Contains(out, \"Concurrency: 3\") {\n    66→\t\tt.Errorf(\"expected concurrency, got:\\n%s\", out)\n    67→\t}\n    68→\tif !strings.Contains(out, \"Orchestration loop: running\") {\n    69→\t\tt.Errorf(\"expected loop running, got:\\n%s\", out)\n    70→\t}\n    71→\tif !strings.Contains(out, \"2 / 3 succeeded\") {\n    72→\t\tt.Errorf(\"expected 2/3 succeeded, got:\\n%s\", out)\n    73→\t}\n    74→\tif !strings.Contains(out, \"Active runs: 1\") {\n    75→\t\tt.Errorf(\"expected 1 active run, got:\\n%s\", out)\n    76→\t}\n    77→\tif !strings.Contains(out, \"run-abc:\") {\n    78→\t\tt.Errorf(\"expected active run ID, got:\\n%s\", out)\n    79→\t}\n    80→}\n    81→\n    82→func TestCmdStatusOverview_GlobalMode(t *testing.T) {\n    83→\tclient := &statusMockClient{\n    84→\t\tversionResp: &pb.GetVersionResponse{Version: \"1.7.0\"},\n    85→\t\tlistRunsResp: &pb.ListRunsResponse{\n    86→\t\t\tRuns: []*pb.RunSummary{\n    87→\t\t\t\t{RunId: \"run-1\", State: \"succeeded\", StartedAt: \"2026-03-14 10:00:00 +0000 UTC\"},\n    88→\t\t\t\t{RunId: \"run-2\", State: \"running\", StartedAt: \"2026-03-14 10:05:00 +0000 UTC\"},\n    89→\t\t\t\t{RunId: \"run-3\", State: \"failed\", StartedAt: \"2026-03-14 10:10:00 +0000 UTC\"},\n    90→\t\t\t},\n    91→\t\t},\n    92→\t}\n    93→\n    94→\tvar buf bytes.Buffer\n    95→\tctx := context.Background()\n    96→\tcmdStatusGlobal(ctx, client, &buf)\n    97→\n   