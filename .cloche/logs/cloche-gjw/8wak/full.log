20-\t\t\t\tID:    runs[i].ID,\n221-\t\t\t\tState: string(runs[i].State),\n222-\t\t\t}\n223-\t\t}\n224-\n--\n985:// handleAPIStream serves an SSE stream of log lines for a run.\n986-// For active runs, it subscribes to the live broadcaster.\n987-// For completed runs, it serves the archived full.log then closes.\n988:func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n989-\tid := r.PathValue(\"id\")\n990-\n991-\trun, err := h.store.GetRun(r.Context(), id)\n992-\tif err != nil {\n993-\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n994-\t\treturn\n995-\t}\n996-\n997-\tflusher, ok := w.(http.Flusher)\n998-\tif !ok {\n999-\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n1000-\t\treturn\n1001-\t}\n1002-","is_error":false}]},"parent_tool_use_id":"toolu_01A1Ma3kLe2eZceEu6Ga6SRP","session_id":"9cb7499f-9015-41ef-ba66-388e58c4a9f5","uuid":"0d9da8c7-005f-4a84-8b39-f9e16aec8997"}
