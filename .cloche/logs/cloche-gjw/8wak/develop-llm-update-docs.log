{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VbaSkziggRcu8xcw1vcQgh","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n     3→\n     4→<div class=\"run-history\" style=\"margin-bottom:1rem\">\n     5→    {{range .RecentRuns}}\n     6→    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n     7→    {{end}}\n     8→    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n     9→    {{if .ContainerCount}}\n    10→    <button class=\"btn btn-danger btn-sm\" id=\"delete-containers-btn\" onclick=\"deleteAllContainers()\" style=\"margin-left:0.5rem\">Delete {{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}</button>\n    11→    {{end}}\n    12→</div>\n    13→\n    14→<!-- Panel 1: Project Info -->\n    15→<div class=\"panel\" id=\"info-panel\">\n    16→    <div class=\"panel-header\">Project Info</div>\n    17→    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n    18→</div>\n    19→\n    20→<!-- Panel 2: Tasks -->\n    21→<div class=\"panel\" id=\"tasks-panel\">\n    22→    <div class=\"panel-header\">Tasks</div>\n    23→    <div class=\"panel-body\" id=\"tasks-body\">Loading...</div>\n    24→</div>\n    25→\n    26→<!-- Panel 3: Workflow View -->\n    27→<div class=\"panel\" id=\"workflow-panel\">\n    28→    <div class=\"panel-header\">Workflows</div>\n    29→    <div class=\"panel-body\">\n    30→        <div id=\"location-tabs\" class=\"tab-bar\"></div>\n    31→        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n    32→        <div id=\"workflow-dag\"></div>\n    33→    </div>\n    34→</div>\n    35→\n    36→<!-- Step Drawer -->\n    37→<div class=\"drawer\" id=\"step-drawer\">\n    38→    <div class=\"drawer-header\">\n    39→        <span id=\"drawer-title\"></span>\n    40→        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    41→    </div>\n    42→    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n    43→</div>\n    44→{{end}}\n    45→\n    46→{{define \"scripts\"}}\n    47→<script>\n    48→var projectLabel = {{.Label}};\n    49→\n    50→function loadProjectInfo() {\n    51→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n    52→        .then(function(r) { return r.json(); })\n    53→        .then(function(data) {\n    54→            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n    55→            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n    56→            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n    57→            html += '</dl>';\n    58→\n    59→            if (data.prompt_files && data.prompt_files.length > 0) {\n    60→                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n    61→                data.prompt_files.forEach(function(pf) {\n    62→                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n    63→                    if (pf.content) {\n    64→                        html += '<pre class=\"diff-block\">' + pf.content.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n    65→                    } else {\n    66→                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">Empty file</p>';\n    67→                    }\n    68→                    html += '</details>';\n    69→                });\n    70→            }\n    71→\n    72→            document.getElementById('project-info').innerHTML = html;\n    73→        });\n    74→}\n    75→\n    76→function toggleDiff(el) {\n    77→    var existing = el.nextElementSibling;\n    78→    if (existing && existing.classList.contains('diff-block')) {\n    79→        existing.remove();\n    80→        return;\n    81→    }\n    82→    var file = el.getAttribute('data-file');\n    83→    var sha = el.getAttribute('data-sha');\n    84→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n    85→        .then(function(r) { return r.text(); })\n    86→        .then(function(text) {\n    87→            var pre = document.createElement('pre');\n    88→            pre.className = 'diff-block';\n    89→            pre.textContent = text || '(no diff available)';\n    90→            el.parentNode.insertBefore(pre, el.nextSibling);\n    91→        });\n    92→}\n    93→\n    94→var workflowsData = [];\n    95→var activeLocation = 'container';\n    96→\n    97→function loadWorkflows() {\n    98→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n    99→        .then(function(r) { return r.json(); })\n   100→        .then(function(data) {\n   101→            workflowsData = data || [];\n   102→            if (workflowsData.length === 0) {\n   103→                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n   104→                return;\n   105→            }\n   106→\n   107→            // Check which locations exist\n   108→            var hasContainer = workflowsData.some(function(wf) { return wf.location === 'container'; });\n   109→            var hasHost = workflowsData.some(function(wf) { return wf.location === 'host'; });\n   110→\n   111→            // Render location tabs if both types exist\n   112→            var locationTabs = document.getElementById('location-tabs');\n   113→            if (hasContainer && hasHost) {\n   114→                var html = '';\n   115→                html += '<button class=\"tab-btn tab-active\" onclick=\"switchLocation(\\'container\\')\">Container</button>';\n   116→                html += '<button class=\"tab-btn\" onclick=\"switchLocation(\\'host\\')\">Host</button>';\n   117→                locationTabs.innerHTML = html;\n   118→            } else {\n   119→                locationTabs.innerHTML = '';\n   120→            }\n   121→\n   122→            // Default to whichever location exists\n   123→            activeLocation = hasContainer ? 'container' : 'host';\n   124→            renderWorkflowTabs();\n   125→        });\n   126→}\n   127→\n   128→function switchLocation(loc) {\n   129→    activeLocation = loc;\n   130→    var btns = document.querySelectorAll('#location-tabs .tab-btn');\n   131→    btns.forEach(function(b) {\n   132→        b.classList.toggle('tab-active', b.textContent === (loc === 'container' ? 'Container' : 'Host'));\n   133→    });\n   134→    renderWorkflowTabs();\n   135→}\n   136→\n   137→function renderWorkflowTabs() {\n   138→    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n   139→    var tabs = document.getElementById('workflow-tabs');\n   140→\n   141→    if (filtered.length === 0) {\n   142→        tabs.innerHTML = '';\n   143→        document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No ' + activeLocation + ' workflows found</p>';\n   144→        return;\n   145→    }\n   146→\n   147→    if (filtered.length > 1) {\n   148→        var html = '';\n   149→        filtered.forEach(function(wf, i) {\n   150→            html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showFilteredWorkflow(' + i + ')\">' + wf.name + '</button>';\n   151→        });\n   152→        tabs.innerHTML = html;\n   153→    } else {\n   154→        tabs.innerHTML = '';\n   155→    }\n   156→    showFilteredWorkflow(0);\n   157→}\n   158→\n   159→function showFilteredWorkflow(idx) {\n   160→    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n   161→    var btns = document.querySelectorAll('#workflow-tabs .tab-btn');\n   162→    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n   163→    showWorkflow(filtered[idx]);\n   164→}\n   165→\n   166→function showWorkflow(wf) {\n   167→    var dagEl = document.getElementById('workflow-dag');\n   168→\n   169→    if (!wf.steps || wf.steps.length === 0) {\n   170→        dagEl.innerHTML = '<p class=\"empty\">No steps defined</p>';\n   171→        return;\n   172→    }\n   173→\n   174→    var stepMap = {};\n   175→    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n   176→\n   177→    var wires = wf.wires || [];\n   178→\n   179→    // Collect terminal targets\n   180→    var terminals = {};\n   181→    wires.forEach(function(wire) {\n   182→        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n   183→    });\n   184→\n   185→    // Build adjacency maps\n   186→    var adj = {};    // from -> [wire]\n   187→    var revAdj = {}; // to -> [from] (unique)\n   188→    wires.forEach(function(wire) {\n   189→        if (!adj[wire.from]) adj[wire.from] = [];\n   190→        adj[wire.from].push(wire);\n   191→        if (!revAdj[wire.to]) revAdj[wire.to] = [];\n   192→        if (revAdj[wire.to].indexOf(wire.from) === -1) revAdj[wire.to].push(wire.from);\n   193→    });\n   194→\n   195→    // --- Layer assignment via longest path (Sugiyama-style) ---\n   196→    var stepNames = wf.steps.map(function(s) { return s.name; });\n   197→\n   198→    // Topological sort (Kahn's algorithm)\n   199→    var inDeg = {};\n   200→    stepNames.forEach(function(n) { inDeg[n] = 0; });\n   201→    wires.forEach(function(wire) {\n   202→        if (inDeg[wire.to] !== undefined) inDeg[wire.to]++;\n   203→    });\n   204→\n   205→    var queue = [];\n   206→    stepNames.forEach(function(n) { if (inDeg[n] === 0) queue.push(n); });\n   207→\n   208→    var topoOrder = [];\n   209→    while (queue.length > 0) {\n   210→        var n = queue.shift();\n   211→        topoOrder.push(n);\n   212→        (adj[n] || []).forEach(function(wire) {\n   213→            if (inDeg[wire.to] !== undefined) {\n   214→                inDeg[wire.to]--;\n   215→                if (inDeg[wire.to] === 0) queue.push(wire.to);\n   216→            }\n   217→        });\n   218→    }\n   219→    // Add remaining steps (cycles or disconnected)\n   220→    stepNames.forEach(function(n) { if (topoOrder.indexOf(n) === -1) topoOrder.push(n); });\n   221→\n   222→    // Assign layers: longest path from any source\n   223→    var layerOf = {};\n   224→    topoOrder.forEach(function(n) {\n   225→        var maxParent = -1;\n   226→        (revAdj[n] || []).forEach(function(p) {\n   227→            if (layerOf[p] !== undefined && layerOf[p] > maxParent) maxParent = layerOf[p];\n   228→        });\n   229→        layerOf[n] = maxParent + 1;\n   230→    });\n   231→\n   232→    var maxLayer = 0;\n   233→    stepNames.forEach(function(n) { if (layerOf[n] > maxLayer) maxLayer = layerOf[n]; });\n   234→\n   235→    // Terminals in rightmost layer\n   236→    var termLayer = maxLayer + 1;\n   237→    for (var t in terminals) { layerOf[t] = termLayer; }\n   238→    var numLayers = termLayer + 1;\n   239→\n   240→    // --- Build layer arrays ---\n   241→    var layers = [];\n   242→    for (var i = 0; i < numLayers; i++) layers.push([]);\n   243→    topoOrder.forEach(function(n) { layers[layerOf[n]].push(n); });\n   244→    for (var t in terminals) { layers[termLayer].push(t); }\n   245→\n   246→    // --- Barycenter ordering to minimize edge crossings ---\n   247→    for (var pass = 0; pass < 4; pass++) {\n   248→        // Forward pass\n   249→        for (var li = 1; li < numLayers; li++) {\n   250→            var bary = {};\n   251→            layers[li].forEach(function(n) {\n   252→                var pars = revAdj[n] || [];\n   253→                var sum = 0, cnt = 0;\n   254→                pars.forEach(function(p) {\n   255→                    var idx = layers[li - 1].indexOf(p);\n   256→                    if (idx >= 0) { sum += idx; cnt++; }\n   257→                });\n   258→                bary[n] = cnt > 0 ? sum / cnt : 999;\n   259→            });\n   260→            layers[li].sort(function(a, b) { return bary[a] - bary[b]; });\n   261→        }\n   262→        // Backward pass\n   263→        for (var li = numLayers - 2; li >= 0; li--) {\n   264→            var baryB = {};\n   265→            layers[li].forEach(function(n) {\n   266→                var children = (adj[n] || []).map(function(w) { return w.to; });\n   267→                var sum = 0, cnt = 0;\n   268→                children.forEach(function(c) {\n   269→                    var idx = layers[li + 1].indexOf(c);\n   270→                    if (idx >= 0) { sum += idx; cnt++; }\n   271→                });\n   272→                baryB[n] = cnt > 0 ? sum / cnt : 999;\n   273→            });\n   274→            layers[li].sort(function(a, b) { return baryB[a] - baryB[b]; });\n   275→        }\n   276→    }\n   277→\n   278→    // --- Position calculation ---\n   279→    var nodeW = 180, nodeH = 48;\n   280→    var layerGap = 120; // horizontal gap between layers\n   281→    var nodeGap = 28;   // vertical gap between nodes in same layer\n   282→    var padL = 30, padT = 30;\n   283→\n   284→    var maxInLayer = 1;\n   285→    layers.forEach(function(l) { if (l.length > maxInLayer) maxInLayer = l.length; });\n   286→    var totalLayerH = maxInLayer * nodeH + (maxInLayer - 1) * nodeGap;\n   287→\n   288→    var positions = {};\n   289→    layers.forEach(function(layer, li) {\n   290→        var lh = layer.length * nodeH + (layer.length - 1) * nodeGap;\n   291→        var offsetY = (totalLayerH - lh) / 2;\n   292→        layer.forEach(function(name, ni) {\n   293→            positions[name] = {\n   294→                x: padL + li * (nodeW + layerGap),\n   295→                y: padT + offsetY + ni * (nodeH + nodeGap)\n   296→            };\n   297→        });\n   298→    });\n   299→\n   300→    var svgW = padL * 2 + numLayers * nodeW + (numLayers - 1) * layerGap;\n   301→    var svgH = padT * 2 + totalLayerH;\n   302→\n   303→    // --- Generate SVG ---\n   304→    var svg = '<svg class=\"dag-svg\" width=\"' + svgW + '\" height=\"' + svgH + '\">';\n   305→    svg += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n   306→\n   307→    // Separate terminal wires (for merging) from normal wires\n   308→    var termWires = {};\n   309→    var normWires = [];\n   310→    wires.forEach(function(wire) {\n   311→        if (wire.to === 'done' || wire.to === 'abort') {\n   312→            if (!termWires[wire.to]) termWires[wire.to] = [];\n   313→            termWires[wire.to].push(wire);\n   314→        } else {\n   315→            normWires.push(wire);\n   316→        }\n   317→    });\n   318→\n   319→    // Draw normal edges with Bezier curves\n   320→    normWires.forEach(function(wire) {\n   321→        var from = positions[wire.from], to = positions[wire.to];\n   322→        if (!from || !to) return;\n   323→        var x1 = from.x + nodeW, y1 = from.y + nodeH / 2;\n   324→        var x2 = to.x, y2 = to.y + nodeH / 2;\n   325→        var dx = x2 - x1;\n   326→        svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + dx * 0.4) + ' ' + y1 + ' ' + (x1 + dx * 0.6) + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n   327→        svg += '<text x=\"' + (x1 + dx / 2) + '\" y=\"' + ((y1 + y2) / 2 - 6) + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n   328→    });\n   329→\n   330→    // Draw terminal edges with merge pattern for multiple wires\n   331→    for (var term in termWires) {\n   332→        var tWires = termWires[term];\n   333→        var tpos = positions[term];\n   334→        if (!tpos) continue;\n   335→\n   336→        if (tWires.length <= 1) {\n   337→            // Single wire to terminal - draw normally\n   338→            tWires.forEach(function(wire) {\n   339→                var from = positions[wire.from];\n   340→                if (!from) return;\n   341→                var x1 = from.x + nodeW, y1 = from.y + nodeH / 2;\n   342→                var x2 = tpos.x, y2 = tpos.y + nodeH / 2;\n   343→                var dx = x2 - x1;\n   344→                svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + dx * 0.4) + ' ' + y1 + ' ' + (x1 + dx * 0.6) + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n   345→                svg += '<text x=\"' + (x1 + dx / 2) + '\" y=\"' + ((y1 + y2) / 2 - 6) + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n   346→            });\n   347→            continue;\n   348→        }\n   349→\n   350→        // Multiple wires to same terminal: merge into a collector bus\n   351→        var mergeX = tpos.x - 50;\n   352→        var termY = tpos.y + nodeH / 2;\n   353→\n   354→        var srcPts = [];\n   355→        tWires.forEach(function(wire) {\n   356→            var from = positions[wire.from];\n   357→            if (!from) return;\n   358→            srcPts.push({ x: from.x + nodeW, y: from.y + nodeH / 2, result: wire.result });\n   359→        });\n   360→        srcPts.sort(function(a, b) { return a.y - b.y; });\n   361→\n   362→        // Individual curves from each source to the merge line\n   363→        srcPts.forEach(function(pt) {\n   364→            var dx = mergeX - pt.x;\n   365→            svg += '<path d=\"M' + pt.x + ' ' + pt.y + ' C' + (pt.x + dx * 0.5) + ' ' + pt.y + ' ' + (mergeX - 20) + ' ' + pt.y + ' ' + mergeX + ' ' + pt.y + '\" class=\"dag-edge\"/>';\n   366→            svg += '<text x=\"' + (pt.x + dx * 0.35) + '\" y=\"' + (pt.y - 6) + '\" class=\"dag-edge-label\">' + pt.result + '</text>';\n   367→        });\n   368→\n   369→        // Vertical collector line\n   370→        var minY = Math.min(srcPts[0].y, termY);\n   371→        var maxY = Math.max(srcPts[srcPts.length - 1].y, termY);\n   372→        svg += '<path d=\"M' + mergeX + ' ' + minY + ' L' + mergeX + ' ' + maxY + '\" class=\"dag-edge dag-merge-line\"/>';\n   373→\n   374→        // Merge point dots\n   375→        srcPts.forEach(function(pt) {\n   376→            svg += '<circle cx=\"' + mergeX + '\" cy=\"' + pt.y + '\" r=\"3\" class=\"dag-merge-dot\"/>';\n   377→        });\n   378→\n   379→        // Single line from collector to terminal\n   380→        svg += '<path d=\"M' + mergeX + ' ' + termY + ' L' + tpos.x + ' ' + termY + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n   381→    }\n   382→\n   383→    // Draw step nodes\n   384→    wf.steps.forEach(function(s) {\n   385→        var pos = positions[s.name];\n   386→        if (!pos) return;\n   387→        var icon = '\\u{1F4DC}';\n   388→        if (s.type === 'agent') icon = '\\u{1F916}';\n   389→        else if (s.type === 'workflow') icon = '\\u{1F501}';\n   390→        svg += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + s.name + '\\')\" style=\"cursor:pointer\">';\n   391→        svg += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n   392→        svg += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + s.name + '</text>';\n   393→        svg += '</g>';\n   394→    });\n   395→\n   396→    // Draw terminal nodes\n   397→    for (var t in terminals) {\n   398→        var pos = positions[t];\n   399→        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n   400→        svg += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n   401→        svg += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n   402→    }\n   403→\n   404→    svg += '</svg>';\n   405→    dagEl.innerHTML = svg;\n   406→}\n   407→\n   408→function openDrawer(workflowName, stepName) {\n   409→    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n   410→    if (!wf) return;\n   411→    var step = wf.steps.find(function(s) { return s.name === stepName; });\n   412→    if (!step) return;\n   413→\n   414→    document.getElementById('drawer-title').textContent = stepName;\n   415→    var body = '<dl class=\"run-meta\">';\n   416→    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n   417→    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n   418→    if (step.config) {\n   419→        for (var k in step.config) {\n   420→            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script' || k === 'run' || k === 'workflow_name') {\n   421→                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n   422→            }\n   423→        }\n   424→    }\n   425→    body += '</dl>';\n   426→    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n   427→\n   428→    document.getElementById('drawer-body').innerHTML = body;\n   429→    document.getElementById('step-drawer').classList.add('drawer-open');\n   430→\n   431→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n   432→        .then(function(r) { if (r.ok) return r.text(); return ''; })\n   433→        .then(function(text) {\n   434→            var el = document.getElementById('drawer-content');\n   435→            if (text) {\n   436→                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n   437→            } else {\n   438→                el.style.display = 'none';\n   439→            }\n   440→        });\n   441→}\n   442→\n   443→function closeDrawer() {\n   444→    document.getElementById('step-drawer').classList.remove('drawer-open');\n   445→}\n   446→\n   447→document.addEventListener('keydown', function(e) {\n   448→    if (e.key === 'Escape') closeDrawer();\n   449→});\n   450→\n   451→window.deleteAllContainers = function() {\n   452→    var btn = document.getElementById('delete-containers-btn');\n   453→    if (btn) btn.disabled = true;\n   454→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/containers', { method: 'DELETE' })\n   455→        .then(function(r) { return r.json(); })\n   456→        .then(function(data) {\n   457→            if (btn) {\n   458→                btn.textContent = 'Deleted ' + (data.deleted || 0) + ' container' + (data.deleted !== 1 ? 's' : '');\n   459→                btn.classList.remove('btn-danger');\n   460→                btn.classList.add('btn-secondary');\n   461→            }\n   462→        })\n   463→        .catch(function() {\n   464→            if (btn) {\n   465→                btn.textContent = 'Delete failed';\n   466→                btn.disabled = false;\n   467→            }\n   468→        });\n   469→};\n   470→\n   471→function escapeHtml(s) {\n   472→    var d = document.createElement('div');\n   473→    d.appendChild(document.createTextNode(s));\n   474→    return d.innerHTML;\n   475→}\n   476→\n   477→function loadTasks() {\n   478→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/tasks')\n   479→        .then(function(r) { return r.json(); })\n   480→        .then(function(tasks) {\n   481→            var body = document.getElementById('tasks-body');\n   482→            if (!tasks || tasks.length === 0) {\n   483→                body.innerHTML = '<p class=\"empty\">No tasks discovered</p>';\n   484→                return;\n   485→            }\n   486→            var html = '<table class=\"runs-table\" style=\"margin:0\"><thead><tr>';\n   487→            html += '<th>Task ID</th><th>Title</th><th>Status</th><th>Assigned</th><th>Run</th>';\n   488→            html += '</tr></thead><tbody>';\n   489→            for (var i = 0; i < tasks.length; i++) {\n   490→                var t = tasks[i];\n   491→                var statusClass = t.status === 'open' ? 'running' : (t.status === 'closed' ? 'succeeded' : 'pending');\n   492→                html += '<tr>';\n   493→                html += '<td class=\"mono\">' + escapeHtml(t.id) + '</td>';\n   494→                html += '<td>' + escapeHtml(t.title || '') + '</td>';\n   495→                html += '<td><span class=\"badge badge-' + statusClass + '\">' + escapeHtml(t.status) + '</span></td>';\n   496→                html += '<td>' + (t.assigned ? 'Yes' : 'No') + '</td>';\n   497→                html += '<td>' + (t.run_id ? '<a href=\"/runs/' + escapeHtml(t.run_id) + '\">' + escapeHtml(t.run_id) + '</a>' : '') + '</td>';\n   498→                html += '</tr>';\n   499→            }\n   500→            html += '</tbody></table>';\n   501→            body.innerHTML = html;\n   502→        })\n   503→        .catch(function() {});\n   504→}\n   505→\n   506→// Load all panels\n   507→loadProjectInfo();\n   508→loadWorkflows();\n   509→loadTasks();\n   510→setInterval(loadTasks, 5000);\n   511→</script>\n   512→{{end}}\n   513→"}]},"parent_tool_use_id":null,"session_id":"baab609c-7354-4992-8237-78467d40b185","uuid":"32e0c4f7-1aac-4926-a901-02adb0574d96","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/project_detail.html","content":"{{define \"content\"}}\n<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n\n<div class=\"run-history\" style=\"margin-bottom:1rem\">\n    {{range .RecentRuns}}\n    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n    {{end}}\n    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n    {{if .ContainerCount}}\n    <button class=\"btn btn-danger btn-sm\" id=\"delete-containers-btn\" onclick=\"deleteAllContainers()\" style=\"margin-left:0.5rem\">Delete {{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}</button>\n    {{end}}\n</div>\n\n<!-- Panel 1: Project Info -->\n<div class=\"panel\" id=\"info-panel\">\n    <div class=\"panel-header\">Project Info</div>\n    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n</div>\n\n<!-- Panel 2: Tasks -->\n<div class=\"panel\" id=\"tasks-panel\">\n    <div class=\"panel-header\">Tasks</div>\n    <div class=\"panel-body\" id=\"tasks-body\">Loading...</div>\n</div>\n\n<!-- Panel 3: Workflow View -->\n<div class=\"panel\" id=\"workflow-panel\">\n    <div class=\"panel-header\">Workflows</div>\n    <div class=\"panel-body\">\n        <div id=\"location-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-dag\"></div>\n    </div>\n</div>\n\n<!-- Step Drawer -->\n<div class=\"drawer\" id=\"step-drawer\">\n    <div class=\"drawer-header\">\n        <span id=\"drawer-title\"></span>\n        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    </div>\n    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n</div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\nvar projectLabel = {{.Label}};\n\nfunction loadProjectInfo() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n            html += '</dl>';\n\n            if (data.prompt_files && data.prompt_files.length > 0) {\n                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n                data.prompt_files.forEach(function(pf) {\n                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n                    if (pf.content) {\n                        html += '<pre class=\"diff-block\">' + pf.content.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n                    } else {\n                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">Empty file</p>';\n                    }\n                    html += '</details>';\n                });\n            }\n\n            document.getElementById('project-info').innerHTML = html;\n        });\n}\n\nfunction toggleDiff(el) {\n    var existing = el.nextElementSibling;\n    if (existing && existing.classList.contains('diff-block')) {\n        existing.remove();\n        return;\n    }\n    var file = el.getAttribute('data-file');\n    var sha = el.getAttribute('data-sha');\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n        .then(function(r) { return r.text(); })\n        .then(function(text) {\n            var pre = document.createElement('pre');\n            pre.className = 'diff-block';\n            pre.textContent = text || '(no diff available)';\n            el.parentNode.insertBefore(pre, el.nextSibling);\n        });\n}\n\nvar workflowsData = [];\nvar activeLocation = 'container';\n\nfunction loadWorkflows() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            workflowsData = data || [];\n            if (workflowsData.length === 0) {\n                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n                return;\n            }\n\n            // Check which locations exist\n            var hasContainer = workflowsData.some(function(wf) { return wf.location === 'container'; });\n            var hasHost = workflowsData.some(function(wf) { return wf.location === 'host'; });\n\n            // Render location tabs if both types exist\n            var locationTabs = document.getElementById('location-tabs');\n            if (hasContainer && hasHost) {\n                var html = '';\n                html += '<button class=\"tab-btn tab-active\" onclick=\"switchLocation(\\'container\\')\">Container</button>';\n                html += '<button class=\"tab-btn\" onclick=\"switchLocation(\\'host\\')\">Host</button>';\n                locationTabs.innerHTML = html;\n            } else {\n                locationTabs.innerHTML = '';\n            }\n\n            // Default to whichever location exists\n            activeLocation = hasContainer ? 'container' : 'host';\n            renderWorkflowTabs();\n        });\n}\n\nfunction switchLocation(loc) {\n    activeLocation = loc;\n    var btns = document.querySelectorAll('#location-tabs .tab-btn');\n    btns.forEach(function(b) {\n        b.classList.toggle('tab-active', b.textContent === (loc === 'container' ? 'Container' : 'Host'));\n    });\n    renderWorkflowTabs();\n}\n\nfunction renderWorkflowTabs() {\n    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n    var tabs = document.getElementById('workflow-tabs');\n\n    if (filtered.length === 0) {\n        tabs.innerHTML = '';\n        document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No ' + activeLocation + ' workflows found</p>';\n        return;\n    }\n\n    if (filtered.length > 1) {\n        var html = '';\n        filtered.forEach(function(wf, i) {\n            html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showFilteredWorkflow(' + i + ')\">' + wf.name + '</button>';\n        });\n        tabs.innerHTML = html;\n    } else {\n        tabs.innerHTML = '';\n    }\n    showFilteredWorkflow(0);\n}\n\nfunction showFilteredWorkflow(idx) {\n    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n    var btns = document.querySelectorAll('#workflow-tabs .tab-btn');\n    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n    showWorkflow(filtered[idx]);\n}\n\nfunction showWorkflow(wf) {\n    var dagEl = document.getElementById('workflow-dag');\n\n    if (!wf.steps || wf.steps.length === 0) {\n        dagEl.innerHTML = '<p class=\"empty\">No steps defined</p>';\n        return;\n    }\n\n    var stepMap = {};\n    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n\n    var wires = wf.wires || [];\n\n    // Collect terminal targets\n    var terminals = {};\n    wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n    });\n\n    // Build adjacency maps\n    var adj = {};    // from -> [wire]\n    var revAdj = {}; // to -> [from] (unique)\n    wires.forEach(function(wire) {\n        if (!adj[wire.from]) adj[wire.from] = [];\n        adj[wire.from].push(wire);\n        if (!revAdj[wire.to]) revAdj[wire.to] = [];\n        if (revAdj[wire.to].indexOf(wire.from) === -1) revAdj[wire.to].push(wire.from);\n    });\n\n    // --- Layer assignment via longest path (Sugiyama-style) ---\n    var stepNames = wf.steps.map(function(s) { return s.name; });\n\n    // Topological sort (Kahn's algorithm)\n    var inDeg = {};\n    stepNames.forEach(function(n) { inDeg[n] = 0; });\n    wires.forEach(function(wire) {\n        if (inDeg[wire.to] !== undefined) inDeg[wire.to]++;\n    });\n\n    var queue = [];\n    stepNames.forEach(function(n) { if (inDeg[n] === 0) queue.push(n); });\n\n    var topoOrder = [];\n    while (queue.length > 0) {\n        var n = queue.shift();\n        topoOrder.push(n);\n        (adj[n] || []).forEach(function(wire) {\n            if (inDeg[wire.to] !== undefined) {\n                inDeg[wire.to]--;\n                if (inDeg[wire.to] === 0) queue.push(wire.to);\n            }\n        });\n    }\n    // Add remaining steps (cycles or disconnected)\n    stepNames.forEach(function(n) { if (topoOrder.indexOf(n) === -1) topoOrder.push(n); });\n\n    // Assign layers: longest path from any source\n    var layerOf = {};\n    topoOrder.forEach(function(n) {\n        var maxParent = -1;\n        (revAdj[n] || []).forEach(function(p) {\n            if (layerOf[p] !== undefined && layerOf[p] > maxParent) maxParent = layerOf[p];\n        });\n        layerOf[n] = maxParent + 1;\n    });\n\n    var maxLayer = 0;\n    stepNames.forEach(function(n) { if (layerOf[n] > maxLayer) maxLayer = layerOf[n]; });\n\n    // Terminals in rightmost layer\n    var termLayer = maxLayer + 1;\n    for (var t in terminals) { layerOf[t] = termLayer; }\n    var numLayers = termLayer + 1;\n\n    // --- Build layer arrays ---\n    var layers = [];\n    for (var i = 0; i < numLayers; i++) layers.push([]);\n    topoOrder.forEach(function(n) { layers[layerOf[n]].push(n); });\n    for (var t in terminals) { layers[termLayer].push(t); }\n\n    // --- Barycenter ordering to minimize edge crossings ---\n    for (var pass = 0; pass < 4; pass++) {\n        // Forward pass\n        for (var li = 1; li < numLayers; li++) {\n            var bary = {};\n            layers[li].forEach(function(n) {\n                var pars = revAdj[n] || [];\n                var sum = 0, cnt = 0;\n                pars.forEach(function(p) {\n                    var idx = layers[li - 1].indexOf(p);\n                    if (idx >= 0) { sum += idx; cnt++; }\n                });\n                bary[n] = cnt > 0 ? sum / cnt : 999;\n            });\n            layers[li].sort(function(a, b) { return bary[a] - bary[b]; });\n        }\n        // Backward pass\n        for (var li = numLayers - 2; li >= 0; li--) {\n            var baryB = {};\n            layers[li].forEach(function(n) {\n                var children = (adj[n] || []).map(function(w) { return w.to; });\n                var sum = 0, cnt = 0;\n                children.forEach(function(c) {\n                    var idx = layers[li + 1].indexOf(c);\n                    if (idx >= 0) { sum += idx; cnt++; }\n                });\n                baryB[n] = cnt > 0 ? sum / cnt : 999;\n            });\n            layers[li].sort(function(a, b) { return baryB[a] - baryB[b]; });\n        }\n    }\n\n    // --- Position calculation ---\n    var nodeW = 180, nodeH = 48;\n    var layerGap = 120; // horizontal gap between layers\n    var nodeGap = 28;   // vertical gap between nodes in same layer\n    var padL = 30, padT = 30;\n\n    var maxInLayer = 1;\n    layers.forEach(function(l) { if (l.length > maxInLayer) maxInLayer = l.length; });\n    var totalLayerH = maxInLayer * nodeH + (maxInLayer - 1) * nodeGap;\n\n    var positions = {};\n    layers.forEach(function(layer, li) {\n        var lh = layer.length * nodeH + (layer.length - 1) * nodeGap;\n        var offsetY = (totalLayerH - lh) / 2;\n        layer.forEach(function(name, ni) {\n            positions[name] = {\n                x: padL + li * (nodeW + layerGap),\n                y: padT + offsetY + ni * (nodeH + nodeGap)\n            };\n        });\n    });\n\n    var svgW = padL * 2 + numLayers * nodeW + (numLayers - 1) * layerGap;\n    var svgH = padT * 2 + totalLayerH;\n\n    // --- Generate SVG ---\n    var svg = '<svg class=\"dag-svg\" width=\"' + svgW + '\" height=\"' + svgH + '\">';\n    svg += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n\n    // Separate terminal wires (for merging) from normal wires\n    var termWires = {};\n    var normWires = [];\n    wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') {\n            if (!termWires[wire.to]) termWires[wire.to] = [];\n            termWires[wire.to].push(wire);\n        } else {\n            normWires.push(wire);\n        }\n    });\n\n    // Draw normal edges with Bezier curves\n    normWires.forEach(function(wire) {\n        var from = positions[wire.from], to = positions[wire.to];\n        if (!from || !to) return;\n        var x1 = from.x + nodeW, y1 = from.y + nodeH / 2;\n        var x2 = to.x, y2 = to.y + nodeH / 2;\n        var dx = x2 - x1;\n        svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + dx * 0.4) + ' ' + y1 + ' ' + (x1 + dx * 0.6) + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n        svg += '<text x=\"' + (x1 + dx / 2) + '\" y=\"' + ((y1 + y2) / 2 - 6) + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n    });\n\n    // Draw terminal edges with merge pattern for multiple wires\n    for (var term in termWires) {\n        var tWires = termWires[term];\n        var tpos = positions[term];\n        if (!tpos) continue;\n\n        if (tWires.length <= 1) {\n            // Single wire to terminal - draw normally\n            tWires.forEach(function(wire) {\n                var from = positions[wire.from];\n                if (!from) return;\n                var x1 = from.x + nodeW, y1 = from.y + nodeH / 2;\n                var x2 = tpos.x, y2 = tpos.y + nodeH / 2;\n                var dx = x2 - x1;\n                svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + dx * 0.4) + ' ' + y1 + ' ' + (x1 + dx * 0.6) + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n                svg += '<text x=\"' + (x1 + dx / 2) + '\" y=\"' + ((y1 + y2) / 2 - 6) + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n            });\n            continue;\n        }\n\n        // Multiple wires to same terminal: merge into a collector bus\n        var mergeX = tpos.x - 50;\n        var termY = tpos.y + nodeH / 2;\n\n        var srcPts = [];\n        tWires.forEach(function(wire) {\n            var from = positions[wire.from];\n            if (!from) return;\n            srcPts.push({ x: from.x + nodeW, y: from.y + nodeH / 2, result: wire.result });\n        });\n        srcPts.sort(function(a, b) { return a.y - b.y; });\n\n        // Individual curves from each source to the merge line\n        srcPts.forEach(function(pt) {\n            var dx = mergeX - pt.x;\n            svg += '<path d=\"M' + pt.x + ' ' + pt.y + ' C' + (pt.x + dx * 0.5) + ' ' + pt.y + ' ' + (mergeX - 20) + ' ' + pt.y + ' ' + mergeX + ' ' + pt.y + '\" class=\"dag-edge\"/>';\n            svg += '<text x=\"' + (pt.x + dx * 0.35) + '\" y=\"' + (pt.y - 6) + '\" class=\"dag-edge-label\">' + pt.result + '</text>';\n        });\n\n        // Vertical collector line\n        var minY = Math.min(srcPts[0].y, termY);\n        var maxY = Math.max(srcPts[srcPts.length - 1].y, termY);\n        svg += '<path d=\"M' + mergeX + ' ' + minY + ' L' + mergeX + ' ' + maxY + '\" class=\"dag-edge dag-merge-line\"/>';\n\n        // Merge point dots\n        srcPts.forEach(function(pt) {\n            svg += '<circle cx=\"' + mergeX + '\" cy=\"' + pt.y + '\" r=\"3\" class=\"dag-merge-dot\"/>';\n        });\n\n        // Single line from collector to terminal\n        svg += '<path d=\"M' + mergeX + ' ' + termY + ' L' + tpos.x + ' ' + termY + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n    }\n\n    // Draw step nodes\n    wf.steps.forEach(function(s) {\n        var pos = positions[s.name];\n        if (!pos) return;\n        var icon = '\\u{1F4DC}';\n        if (s.type === 'agent') icon = '\\u{1F916}';\n        else if (s.type === 'workflow') icon = '\\u{1F501}';\n        svg += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + s.name + '\\')\" style=\"cursor:pointer\">';\n        svg += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n        svg += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + s.name + '</text>';\n        svg += '</g>';\n    });\n\n    // Draw terminal nodes\n    for (var t in terminals) {\n        var pos = positions[t];\n        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n        svg += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n        svg += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n    }\n\n    svg += '</svg>';\n    dagEl.innerHTML = svg;\n}\n\nfunction openDrawer(workflowName, stepName) {\n    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n    if (!wf) return;\n    var step = wf.steps.find(function(s) { return s.name === stepName; });\n    if (!step) return;\n\n    document.getElementById('drawer-title').textContent = stepName;\n    var body = '<dl class=\"run-meta\">';\n    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n    if (step.config) {\n        for (var k in step.config) {\n            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script' || k === 'run' || k === 'workflow_name') {\n                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n            }\n        }\n    }\n    body += '</dl>';\n    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n\n    document.getElementById('drawer-body').innerHTML = body;\n    document.getElementById('step-drawer').classList.add('drawer-open');\n\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n        .then(function(r) { if (r.ok) return r.text(); return ''; })\n        .then(function(text) {\n            var el = document.getElementById('drawer-content');\n            if (text) {\n                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n            } else {\n                el.style.display = 'none';\n            }\n        });\n}\n\nfunction closeDrawer() {\n    document.getElementById('step-drawer').classList.remove('drawer-open');\n}\n\ndocument.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') closeDrawer();\n});\n\nwindow.deleteAllContainers = function() {\n    var btn = document.getElementById('delete-containers-btn');\n    if (btn) btn.disabled = true;\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/containers', { method: 'DELETE' })\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            if (btn) {\n                btn.textContent = 'Deleted ' + (data.deleted || 0) + ' container' + (data.deleted !== 1 ? 's' : '');\n                btn.classList.remove('btn-danger');\n                btn.classList.add('btn-secondary');\n            }\n        })\n        .catch(function() {\n            if (btn) {\n                btn.textContent = 'Delete failed';\n                btn.disabled = false;\n            }\n        });\n};\n\nfunction escapeHtml(s) {\n    var d = document.createElement('div');\n    d.appendChild(document.createTextNode(s));\n    return d.innerHTML;\n}\n\nfunction loadTasks() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/tasks')\n        .then(function(r) { return r.json(); })\n        .then(function(tasks) {\n            var body = document.getElementById('tasks-body');\n            if (!tasks || tasks.length === 0) {\n                body.innerHTML = '<p class=\"empty\">No tasks discovered</p>';\n                return;\n            }\n            var html = '<table class=\"runs-table\" style=\"margin:0\"><thead><tr>';\n            html += '<th>Task ID</th><th>Title</th><th>Status</th><th>Assigned</th><th>Run</th>';\n            html += '</tr></thead><tbody>';\n            for (var i = 0; i < tasks.length; i++) {\n                var t = tasks[i];\n                var statusClass = t.status === 'open' ? 'running' : (t.status === 'closed' ? 'succeeded' : 'pending');\n                html += '<tr>';\n                html += '<td class=\"mono\">' + escapeHtml(t.id) + '</td>';\n                html += '<td>' + escapeHtml(t.title || '') + '</td>';\n                html += '<td><span class=\"badge badge-' + statusClass + '\">' + escapeHtml(t.status) + '</span></td>';\n                html += '<td>' + (t.assigned ? 'Yes' : 'No') + '</td>';\n                html += '<td>' + (t.run_id ? '<a href=\"/runs/' + escapeHtml(t.run_id) + '\">' + escapeHtml(t.run_id) + '</a>' : '') + '</td>';\n                html += '</tr>';\n            }\n            html += '</tbody></table>';\n            body.innerHTML = html;\n        })\n        .catch(function() {});\n}\n\n// Load all panels\nloadProjectInfo();\nloadWorkflows();\nloadTasks();\nsetInterval(loadTasks, 5000);\n</script>\n{{end}}\n","numLines":513,"startLine":1,"totalLines":513}}}
