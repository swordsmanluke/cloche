(t, tt.want, got)\n    97→\t\t})\n    98→\t}\n    99→}\n   100→\n   101→func TestTaskAggregateStatus(t *testing.T) {\n   102→\tnow := time.Now()\n   103→\tmkRun := func(state domain.RunState, startedAt time.Time) *domain.Run {\n   104→\t\tr := domain.NewRun(\"r\", \"wf\")\n   105→\t\tr.State = state\n   106→\t\tr.StartedAt = startedAt\n   107→\t\treturn r\n   108→\t}\n   109→\tmkHostRun := func(state domain.RunState, startedAt time.Time) *domain.Run {\n   110→\t\tr := mkRun(state, startedAt)\n   111→\t\tr.IsHost = true\n   112→\t\treturn r\n   113→\t}\n   114→\n   115→\ttests := []struct {\n   116→\t\tname string\n   117→\t\truns []*domain.Run\n   118→\t\twant domain.RunState\n   119→\t}{\n   120→\t\t{\n   121→\t\t\tname: \"empty returns pending\",\n   122→\t\t\truns: nil,\n   123→\t\t\twant: domain.RunStatePending,\n   124→\t\t},\n   125→\t\t{\n   126→\t\t\tname: \"single succeeded\",\n   127→\t\t\truns: []*domain.Run{mkRun(domain.RunStateSucceeded, now)},\n   128→\t\t\twant: domain.RunStateSucceeded,\n   129→\t\t},\n   130→\t\t{\n   131→\t\t\tname: \"single failed\",\n   132→\t\t\truns: []*domain.Run{mkRun(domain.RunStateFailed, now)},\n   133→\t\t\twant: domain.RunStateFailed,\n   134→\t\t},\n   135→\t\t{\n   136→\t\t\tname: \"running outweighs succeeded\",\n   137→\t\t\truns: []*domain.Run{\n   138→\t\t\t\tmkRun(domain.RunStateSucceeded, now.Add(-1*time.Minute)),\n   139→\t\t\t\tmkRun(domain.RunStateRunning, now),\n   140→\t\t\t},\n   141→\t\t\twant: domain.RunStateRunning,\n   142→\t\t},\n   143→\t\t{\n   144→\t\t\tname: \"running outweighs failed\",\n   145→\t\t\truns: []*domain.Run{\n   146→\t\t\t\tmkRun(domain.RunStateFailed, now.Add(-1*time.Minute)),\n   147→\t\t\t\tmkRun(domain.RunStateRunning, now),\n   148→\t\t\t},\n   149→\t\t\twant: domain.RunStateRunning,\n   150→\t\t},\n   151→\t\t{\n   152→\t\t\tname: \"pending outweighs terminal\",\n   153→\t\t\truns: []*domain.Run{\n   154→\t\t\t\tmkRun(domain.RunStateFailed, now.Add(-1*time.Minute)),\n   155→\t\t