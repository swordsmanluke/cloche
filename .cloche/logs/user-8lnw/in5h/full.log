xist\")\n    51→\t}\n    52→\tif _, err := os.Stat(filepath.Join(\".cloche\", \"develop.cloche\")); err == nil {\n    53→\t\tt.Error(\".cloche/develop.cloche should not exist with --workflow build\")\n    54→\t}\n    55→\n    56→\tdata, _ := os.ReadFile(filepath.Join(\".cloche\", \"Dockerfile\"))\n    57→\tif !strings.Contains(string(data), \"FROM python:3.12\") {\n    58→\t\tt.Error(\"Dockerfile should contain custom base image\")\n    59→\t}\n    60→\n    61→\tdata, _ = os.ReadFile(filepath.Join(\".cloche\", \"build.cloche\"))\n    62→\tif !strings.Contains(string(data), `workflow \"build\"`) {\n    63→\t\tt.Error(\"workflow file should contain custom workflow name\")\n    64→\t}\n    65→}\n    66→\n    67→func TestCmdInit_SkipsExistingFiles(t *testing.T) {\n    68→\tdir := t.TempDir()\n    69→\torigDir, _ := os.Getwd()\n    70→\tos.Chdir(dir)\n    71→\tdefer os.Chdir(origDir)\n    72→\n    73→\tos.MkdirAll(\".cloche\", 0755)\n    74→\tos.WriteFile(filepath.Join(\".cloche\", \"Dockerfile\"), []byte(\"custom\"), 0644)\n    75→\n    76→\tcmdInit([]string{})\n    77→\n    78→\tdata, _ := os.ReadFile(filepath.Join(\".cloche\", \"Dockerfile\"))\n    79→\tif string(data) != \"custom\" {\n    80→\t\tt.Error(\"existing Dockerfile was overwritten\")\n    81→\t}\n    82→\n    83→\tif _, err := os.Stat(filepath.Join(\".cloche\", \"develop.cloche\")); os.IsNotExist(err) {\n    84→\t\tt.Error(\".cloche/develop.cloche should still be created\")\n    85→\t}\n    86→}\n    87→\n    88→func TestCmdInit_GitignoreEntries(t *testing.T) {\n    89→\tdir := t.TempDir()\n    90→\torigDir, _ := os.Getwd()\n    91→\tos.Chdir(dir)\n    92→\tdefer os.Chdir(origDir)\n    93→\n    94→\tcmdInit([]string{})\n    95→\n    96→\tdata, err := os.ReadFile(\".gitignore\")\n    97→\tif err != nil {\n    98→\t\tt.Fatalf(\"expected .gitignore to exist: %v\", err)\n    99→\t}\n   100→\tcontent := string(data)\n   101→\tif !strings.Contains(content, \".cloche/*/\") {\n   102→\t\tt.Error(\".gitignore should