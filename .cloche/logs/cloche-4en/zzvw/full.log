workflow\n  1531→\tresult, err = runner.RunNamed(context.Background(), tmpDir, \"finalize\")\n  1532→\trequire.NoError(t, err)\n  1533→\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n  1534→}\n  1535→\n  1536→func TestRunner_RunNamed_NotFound(t *testing.T) {\n  1537→\ttmpDir := t.TempDir()\n  1538→\n  1539→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n  1540→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n  1541→\thostCloche := `workflow \"main\" {\n  1542→  step greet {\n  1543→    run     = \"echo hi\"\n  1544→    results = [success, fail]\n  1545→  }\n  1546→  greet:success -> done\n  1547→  greet:fail    -> abort\n  1548→}`\n  1549→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n  1550→\n  1551→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n  1552→\trunner := &Runner{\n  1553→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n  1554→\t\tStore:      store,\n  1555→\t}\n  1556→\n  1557→\t_, err := runner.RunNamed(context.Background(), tmpDir, \"nonexistent\")\n  1558→\trequire.Error(t, err)\n  1559→\tassert.Contains(t, err.Error(), \"no workflow \\\"nonexistent\\\"\")"}]},"parent_tool_use_id":"toolu_01XScxd2ztsRjVVnxbUDPP7q","session_id":"832f6df2-1a53-47c0-b762-a9ee0142818b","uuid":"049095c7-b320-41a6-8268-1ed90c3d6776"}
