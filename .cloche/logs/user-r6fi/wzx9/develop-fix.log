{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018TBWTQt8gXnLoU2C9fZmhE","type":"tool_result","content":"     1→package docker\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"context\"\n     6→\t\"fmt\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→)\n    11→\n    12→// ExtractResults copies the container workspace to a git branch using worktrees.\n    13→// It creates branch cloche/<runID> based on baseSHA, copies the container's\n    14→// /workspace into the worktree's cloche/ directory, commits, and cleans up.\n    15→func ExtractResults(ctx context.Context, containerID, projectDir, runID, baseSHA, workflowName, result string) error {\n    16→\tif baseSHA == \"\" {\n    17→\t\treturn fmt.Errorf(\"no base SHA recorded for run %s\", runID)\n    18→\t}\n    19→\n    20→\t// 1. Copy container workspace to temp dir\n    21→\ttmpDir, err := os.MkdirTemp(\"\", \"cloche-extract-\"+runID+\"-\")\n    22→\tif err != nil {\n    23→\t\treturn fmt.Errorf(\"creating temp dir: %w\", err)\n    24→\t}\n    25→\tdefer os.RemoveAll(tmpDir)\n    26→\n    27→\tcpCmd := exec.CommandContext(ctx, \"docker\", \"cp\", containerID+\":/workspace/.\", tmpDir+\"/\")\n    28→\tvar cpStderr bytes.Buffer\n    29→\tcpCmd.Stderr = &cpStderr\n    30→\tif err := cpCmd.Run(); err != nil {\n    31→\t\treturn fmt.Errorf(\"docker cp from container: %s: %w\", cpStderr.String(), err)\n    32→\t}\n    33→\n    34→\t// 2. Create git worktree\n    35→\tworktreeDir := filepath.Join(projectDir, \".gitworktrees\", \"cloche\", runID)\n    36→\tif err := os.MkdirAll(filepath.Dir(worktreeDir), 0755); err != nil {\n    37→\t\treturn fmt.Errorf(\"creating worktree parent: %w\", err)\n    38→\t}\n    39→\n    40→\taddCmd := exec.CommandContext(ctx, \"git\", \"worktree\", \"add\", \"--detach\", worktreeDir, baseSHA)\n    41→\taddCmd.Dir = projectDir\n    42→\tif out, err := addCmd.CombinedOutput(); err != nil {\n    43→\t\treturn fmt.Errorf(\"git worktree add: %s: %w\", out, err)\n    44→\t}\n    45→\tdefer func() {\n    46→\t\trmCmd := exec.CommandContext(ctx, \"git\", \"worktree\", \"remove\", \"--force\", worktreeDir)\n    47→\t\trmCmd.Dir = projectDir\n    48→\t\trmCmd.Run()\n    49→\t}()\n    50→\n    51→\t// 3. Copy temp dir contents into worktree root, excluding .git\n    52→\t// The container includes .git/ as a full directory, but the worktree has a\n    53→\t// .git file pointing back to the main repo. We must not overwrite it.\n    54→\tos.RemoveAll(filepath.Join(tmpDir, \".git\"))\n    55→\tcpLocalCmd := exec.CommandContext(ctx, \"cp\", \"-a\", tmpDir+\"/.\", worktreeDir+\"/\")\n    56→\tif out, err := cpLocalCmd.CombinedOutput(); err != nil {\n    57→\t\treturn fmt.Errorf(\"copying to worktree: %s: %w\", out, err)\n    58→\t}\n    59→\n    60→\t// 4. Create branch, add, commit\n    61→\tgitEnv := append(os.Environ(),\n    62→\t\t\"GIT_AUTHOR_NAME=cloche\", \"GIT_AUTHOR_EMAIL=cloche@local\",\n    63→\t\t\"GIT_COMMITTER_NAME=cloche\", \"GIT_COMMITTER_EMAIL=cloche@local\",\n    64→\t)\n    65→\n    66→\tbranch := \"cloche/\" + runID\n    67→\n    68→\tcheckoutCmd := exec.CommandContext(ctx, \"git\", \"checkout\", \"-b\", branch)\n    69→\tcheckoutCmd.Dir = worktreeDir\n    70→\tcheckoutCmd.Env = gitEnv\n    71→\tif out, err := checkoutCmd.CombinedOutput(); err != nil {\n    72→\t\treturn fmt.Errorf(\"git checkout -b: %s: %w\", out, err)\n    73→\t}\n    74→\n    75→\taddFilesCmd := exec.CommandContext(ctx, \"git\", \"add\", \"-A\")\n    76→\taddFilesCmd.Dir = worktreeDir\n    77→\taddFilesCmd.Env = gitEnv\n    78→\tif out, err := addFilesCmd.CombinedOutput(); err != nil {\n    79→\t\treturn fmt.Errorf(\"git add: %s: %w\", out, err)\n    80→\t}\n    81→\n    82→\tcommitMsg := fmt.Sprintf(\"cloche run %s: %s (%s)\", runID, workflowName, result)\n    83→\tcommitCmd := exec.CommandContext(ctx, \"git\", \"commit\", \"-m\", commitMsg, \"--allow-empty\")\n    84→\tcommitCmd.Dir = worktreeDir\n    85→\tcommitCmd.Env = gitEnv\n    86→\tif out, err := commitCmd.CombinedOutput(); err != nil {\n    87→\t\treturn fmt.Errorf(\"git commit: %s: %w\", out, err)\n    88→\t}\n    89→\n    90→\treturn nil\n    91→}\n    92→"}]},"parent_tool_use_id":"toolu_018B5Hj2Nng5NRAcwoSYggVk","session_id":"4b132cf9-7672-4d53-ba9d-f61c8661b9bb","uuid":"e2e7ebc4-67a8-4273-b6a5-cf845f08c72f"}
