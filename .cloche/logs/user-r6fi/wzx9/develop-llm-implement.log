{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Js5CZEP3n1NVGv3cUqYaes","type":"tool_result","content":"     1→package docker\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"bytes\"\n     6→\t\"context\"\n     7→\t\"crypto/sha256\"\n     8→\t\"encoding/hex\"\n     9→\t\"fmt\"\n    10→\t\"log\"\n    11→\t\"os\"\n    12→\t\"os/exec\"\n    13→\t\"path/filepath\"\n    14→\t\"strings\"\n    15→)\n    16→\n    17→const dockerfileHashLabel = \"cloche.dockerfile.hash\"\n    18→const baseImageDigestLabel = \"cloche.baseimage.digest\"\n    19→\n    20→// EnsureImage checks whether the Docker image is up-to-date with the project\n    21→// Dockerfile. If the image does not exist or the Dockerfile has changed since\n    22→// the image was built, it rebuilds automatically.\n    23→func (r *Runtime) EnsureImage(ctx context.Context, projectDir, image string) error {\n    24→\tdockerfilePath := filepath.Join(projectDir, \".cloche\", \"Dockerfile\")\n    25→\n    26→\tcontent, err := os.ReadFile(dockerfilePath)\n    27→\tif err != nil {\n    28→\t\tif os.IsNotExist(err) {\n    29→\t\t\t// No project Dockerfile — nothing to validate.\n    30→\t\t\treturn nil\n    31→\t\t}\n    32→\t\treturn fmt.Errorf(\"reading Dockerfile: %w\", err)\n    33→\t}\n    34→\n    35→\tcurrentHash := hashBytes(content)\n    36→\n    37→\tstoredHash, err := imageLabel(ctx, image, dockerfileHashLabel)\n    38→\tif err != nil {\n    39→\t\tlog.Printf(\"image %s not found or cannot inspect; building\", image)\n    40→\t\treturn buildImage(ctx, projectDir, dockerfilePath, image, currentHash, content)\n    41→\t}\n    42→\n    43→\tif storedHash != currentHash {\n    44→\t\tlog.Printf(\"image %s is stale (have %s, want %s); rebuilding\", image, storedHash[:12], currentHash[:12])\n    45→\t\treturn buildImage(ctx, projectDir, dockerfilePath, image, currentHash, content)\n    46→\t}\n    47→\n    48→\t// Dockerfile hash matches — check if the base image has changed locally.\n    49→\tif baseStale, reason := isBaseImageStale(ctx, image, content); baseStale {\n    50→\t\tlog.Printf(\"image %s base image is stale (%s); rebuilding\", image, reason)\n    51→\t\treturn buildImage(ctx, projectDir, dockerfilePath, image, currentHash, content)\n    52→\t}\n    53→\n    54→\tlog.Printf(\"image %s is up-to-date (dockerfile hash %s)\", image, currentHash[:12])\n    55→\treturn nil\n    56→}\n    57→\n    58→// parseBaseImage extracts the base image reference from the final FROM directive\n    59→// in a Dockerfile. It handles \"FROM image:tag\" and \"FROM image:tag AS stage\".\n    60→// Returns an empty string if no FROM directive is found.\n    61→func parseBaseImage(dockerfileContent []byte) string {\n    62→\tvar lastFrom string\n    63→\tscanner := bufio.NewScanner(bytes.NewReader(dockerfileContent))\n    64→\tfor scanner.Scan() {\n    65→\t\tline := strings.TrimSpace(scanner.Text())\n    66→\t\tif line == \"\" || strings.HasPrefix(line, \"#\") {\n    67→\t\t\tcontinue\n    68→\t\t}\n    69→\t\tupper := strings.ToUpper(line)\n    70→\t\tif !strings.HasPrefix(upper, \"FROM \") {\n    71→\t\t\tcontinue\n    72→\t\t}\n    73→\t\t// Extract the image reference. Skip any --flag=value options\n    74→\t\t// (e.g. --platform=linux/amd64) that appear before the image.\n    75→\t\tfields := strings.Fields(line)\n    76→\t\tfor _, f := range fields[1:] {\n    77→\t\t\tif !strings.HasPrefix(f, \"--\") {\n    78→\t\t\t\tlastFrom = f\n    79→\t\t\t\tbreak\n    80→\t\t\t}\n    81→\t\t}\n    82→\t}\n    83→\treturn lastFrom\n    84→}\n    85→\n    86→// baseImageID returns the image ID of a locally available Docker image.\n    87→// Returns an error if the image is not available locally.\n    88→func baseImageID(ctx context.Context, image string) (string, error) {\n    89→\tcmd := exec.CommandContext(ctx, \"docker\", \"inspect\", \"--format\", \"{{.Id}}\", image)\n    90→\tvar stdout, stderr bytes.Buffer\n    91→\tcmd.Stdout = &stdout\n    92→\tcmd.Stderr = &stderr\n    93→\tif err := cmd.Run(); err != nil {\n    94→\t\treturn \"\", fmt.Errorf(\"inspecting base image %s: %s: %w\", image, strings.TrimSpace(stderr.String()), err)\n    95→\t}\n    96→\tid := strings.TrimSpace(stdout.String())\n    97→\tif id == \"\" {\n    98→\t\treturn \"\", fmt.Errorf(\"empty image ID for %s\", image)\n    99→\t}\n   100→\treturn id, nil\n   101→}\n   102→\n   103→// isBaseImageStale checks whether the base image used to build the project\n   104→// image has changed locally since build time. It compares the stored base\n   105→// image digest label to the current local image ID of the base image.\n   106→// Returns (true, reason) if stale, (false, \"\") if up-to-date or if the\n   107→// check cannot be performed (e.g. base image not available locally).\n   108→func isBaseImageStale(ctx context.Context, image string, dockerfileContent []byte) (bool, string) {\n   109→\tbaseRef := parseBaseImage(dockerfileContent)\n   110→\tif baseRef == \"\" || strings.ToLower(baseRef) == \"scratch\" {\n   111→\t\treturn false, \"\"\n   112→\t}\n   113→\n   114→\tstoredDigest, err := imageLabel(ctx, image, baseImageDigestLabel)\n   115→\tif err != nil {\n   116→\t\t// Label not present (old build) — can't determine staleness.\n   117→\t\treturn false, \"\"\n   118→\t}\n   119→\n   120→\tcurrentID, err := baseImageID(ctx, baseRef)\n   121→\tif err != nil {\n   122→\t\t// Base image not available locally — can't compare.\n   123→\t\treturn false, \"\"\n   124→\t}\n   125→\n   126→\tif currentID != storedDigest {\n   127→\t\treturn true, fmt.Sprintf(\"base %s changed from %s to %s\", baseRef, storedDigest[:12], currentID[:12])\n   128→\t}\n   129→\treturn false, \"\"\n   130→}\n   131→\n   132→// hashBytes returns the hex-encoded SHA-256 digest of data.\n   133→func hashBytes(data []byte) string {\n   134→\th := sha256.Sum256(data)\n   135→\treturn hex.EncodeToString(h[:])\n   136→}\n   137→\n   138→// imageLabel retrieves a label value from a Docker image.\n   139→// Returns an error if the image does not exist or cannot be inspected.\n   140→func imageLabel(ctx context.Context, image, label string) (string, error) {\n   141→\tcmd := exec.CommandContext(ctx, \"docker\", \"inspect\",\n   142→\t\t\"--format\", fmt.Sprintf(\"{{index .Config.Labels %q}}\", label),\n   143→\t\timage)\n   144→\tvar stdout, stderr bytes.Buffer\n   145→\tcmd.Stdout = &stdout\n   146→\tcmd.Stderr = &stderr\n   147→\tif err := cmd.Run(); err != nil {\n   148→\t\treturn \"\", fmt.Errorf(\"inspecting image %s: %s: %w\", image, strings.TrimSpace(stderr.String()), err)\n   149→\t}\n   150→\tval := strings.TrimSpace(stdout.String())\n   151→\tif val == \"\" || val == \"<no value>\" {\n   152→\t\treturn \"\", fmt.Errorf(\"label %s not set on image %s\", label, image)\n   153→\t}\n   154→\treturn val, nil\n   155→}\n   156→\n   157→// buildImage runs docker build for the project, tagging the result with the\n   158→// given image name and embedding the Dockerfile hash and base image digest\n   159→// as labels.\n   160→func buildImage(ctx context.Context, projectDir, dockerfilePath, image, hash string, dockerfileContent []byte) error {\n   161→\tlog.Printf(\"building image %s from %s\", image, dockerfilePath)\n   162→\n   163→\targs := []string{\n   164→\t\t\"build\",\n   165→\t\t\"-t\", image,\n   166→\t\t\"-f\", dockerfilePath,\n   167→\t\t\"--label\", fmt.Sprintf(\"%s=%s\", dockerfileHashLabel, hash),\n   168→\t}\n   169→\n   170→\t// Record the base image digest so we can detect upstream changes later.\n   171→\tif baseRef := parseBaseImage(dockerfileContent); baseRef != \"\" && strings.ToLower(baseRef) != \"scratch\" {\n   172→\t\tif id, err := baseImageID(ctx, baseRef); err == nil {\n   173→\t\t\targs = append(args, \"--label\", fmt.Sprintf(\"%s=%s\", baseImageDigestLabel, id))\n   174→\t\t}\n   175→\t}\n   176→\n   177→\targs = append(args, projectDir)\n   178→\n   179→\tcmd := exec.CommandContext(ctx, \"docker\", args...)\n   180→\tcmd.Stdout = os.Stderr // stream build output to daemon stderr\n   181→\tcmd.Stderr = os.Stderr\n   182→\tif err := cmd.Run(); err != nil {\n   183→\t\treturn fmt.Errorf(\"building image %s: %w\", image, err)\n   184→\t}\n   185→\n   186→\tlog.Printf(\"image %s built successfully\", image)\n   187→\treturn nil\n   188→}\n   189→"}]},"parent_tool_use_id":null,"session_id":"d5852ca5-8605-4df2-ab4e-a8f4a3409842","uuid":"f24a0ef7-a4b5-4a9e-b4da-73be6116f381","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/docker/build.go","content":"package docker\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/sha256\"\n\t\"encoding/hex\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n)\n\nconst dockerfileHashLabel = \"cloche.dockerfile.hash\"\nconst baseImageDigestLabel = \"cloche.baseimage.digest\"\n\n// EnsureImage checks whether the Docker image is up-to-date with the project\n// Dockerfile. If the image does not exist or the Dockerfile has changed since\n// the image was built, it rebuilds automatically.\nfunc (r *Runtime) EnsureImage(ctx context.Context, projectDir, image string) error {\n\tdockerfilePath := filepath.Join(projectDir, \".cloche\", \"Dockerfile\")\n\n\tcontent, err := os.ReadFile(dockerfilePath)\n\tif err != nil {\n\t\tif os.IsNotExist(err) {\n\t\t\t// No project Dockerfile — nothing to validate.\n\t\t\treturn nil\n\t\t}\n\t\treturn fmt.Errorf(\"reading Dockerfile: %w\", err)\n\t}\n\n\tcurrentHash := hashBytes(content)\n\n\tstoredHash, err := imageLabel(ctx, image, dockerfileHashLabel)\n\tif err != nil {\n\t\tlog.Printf(\"image %s not found or cannot inspect; building\", image)\n\t\treturn buildImage(ctx, projectDir, dockerfilePath, image, currentHash, content)\n\t}\n\n\tif storedHash != currentHash {\n\t\tlog.Printf(\"image %s is stale (have %s, want %s); rebuilding\", image, storedHash[:12], currentHash[:12])\n\t\treturn buildImage(ctx, projectDir, dockerfilePath, image, currentHash, content)\n\t}\n\n\t// Dockerfile hash matches — check if the base image has changed locally.\n\tif baseStale, reason := isBaseImageStale(ctx, image, content); baseStale {\n\t\tlog.Printf(\"image %s base image is stale (%s); rebuilding\", image, reason)\n\t\treturn buildImage(ctx, projectDir, dockerfilePath, image, currentHash, content)\n\t}\n\n\tlog.Printf(\"image %s is up-to-date (dockerfile hash %s)\", image, currentHash[:12])\n\treturn nil\n}\n\n// parseBaseImage extracts the base image reference from the final FROM directive\n// in a Dockerfile. It handles \"FROM image:tag\" and \"FROM image:tag AS stage\".\n// Returns an empty string if no FROM directive is found.\nfunc parseBaseImage(dockerfileContent []byte) string {\n\tvar lastFrom string\n\tscanner := bufio.NewScanner(bytes.NewReader(dockerfileContent))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tif line == \"\" || strings.HasPrefix(line, \"#\") {\n\t\t\tcontinue\n\t\t}\n\t\tupper := strings.ToUpper(line)\n\t\tif !strings.HasPrefix(upper, \"FROM \") {\n\t\t\tcontinue\n\t\t}\n\t\t// Extract the image reference. Skip any --flag=value options\n\t\t// (e.g. --platform=linux/amd64) that appear before the image.\n\t\tfields := strings.Fields(line)\n\t\tfor _, f := range fields[1:] {\n\t\t\tif !strings.HasPrefix(f, \"--\") {\n\t\t\t\tlastFrom = f\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\treturn lastFrom\n}\n\n// baseImageID returns the image ID of a locally available Docker image.\n// Returns an error if the image is not available locally.\nfunc baseImageID(ctx context.Context, image string) (string, error) {\n\tcmd := exec.CommandContext(ctx, \"docker\", \"inspect\", \"--format\", \"{{.Id}}\", image)\n\tvar stdout, stderr bytes.Buffer\n\tcmd.Stdout = &stdout\n\tcmd.Stderr = &stderr\n\tif err := cmd.Run(); err != nil {\n\t\treturn \"\", fmt.Errorf(\"inspecting base image %s: %s: %w\", image, strings.TrimSpace(stderr.String()), err)\n\t}\n\tid := strings.TrimSpace(stdout.String())\n\tif id == \"\" {\n\t\treturn \"\", fmt.Errorf(\"empty image ID for %s\", image)\n\t}\n\treturn id, nil\n}\n\n// isBaseImageStale checks whether the base image used to build the project\n// image has changed locally since build time. It compares the stored base\n// image digest label to the current local image ID of the base image.\n// Returns (true, reason) if stale, (false, \"\") if up-to-date or if the\n// check cannot be performed (e.g. base image not available locally).\nfunc isBaseImageStale(ctx context.Context, image string, dockerfileContent []byte) (bool, string) {\n\tbaseRef := parseBaseImage(dockerfileContent)\n\tif baseRef == \"\" || strings.ToLower(baseRef) == \"scratch\" {\n\t\treturn false, \"\"\n\t}\n\n\tstoredDigest, err := imageLabel(ctx, image, baseImageDigestLabel)\n\tif err != nil {\n\t\t// Label not present (old build) — can't determine staleness.\n\t\treturn false, \"\"\n\t}\n\n\tcurrentID, err := baseImageID(ctx, baseRef)\n\tif err != nil {\n\t\t// Base image not available locally — can't compare.\n\t\treturn false, \"\"\n\t}\n\n\tif currentID != storedDigest {\n\t\treturn true, fmt.Sprintf(\"base %s changed from %s to %s\", baseRef, storedDigest[:12], currentID[:12])\n\t}\n\treturn false, \"\"\n}\n\n// hashBytes returns the hex-encoded SHA-256 digest of data.\nfunc hashBytes(data []byte) string {\n\th := sha256.Sum256(data)\n\treturn hex.EncodeToString(h[:])\n}\n\n// imageLabel retrieves a label value from a Docker image.\n// Returns an error if the image does not exist or cannot be inspected.\nfunc imageLabel(ctx context.Context, image, label string) (string, error) {\n\tcmd := exec.CommandContext(ctx, \"docker\", \"inspect\",\n\t\t\"--format\", fmt.Sprintf(\"{{index .Config.Labels %q}}\", label),\n\t\timage)\n\tvar stdout, stderr bytes.Buffer\n\tcmd.Stdout = &stdout\n\tcmd.Stderr = &stderr\n\tif err := cmd.Run(); err != nil {\n\t\treturn \"\", fmt.Errorf(\"inspecting image %s: %s: %w\", image, strings.TrimSpace(stderr.String()), err)\n\t}\n\tval := strings.TrimSpace(stdout.String())\n\tif val == \"\" || val == \"<no value>\" {\n\t\treturn \"\", fmt.Errorf(\"label %s not set on image %s\", label, image)\n\t}\n\treturn val, nil\n}\n\n// buildImage runs docker build for the project, tagging the result with the\n// given image name and embedding the Dockerfile hash and base image digest\n// as labels.\nfunc buildImage(ctx context.Context, projectDir, dockerfilePath, image, hash string, dockerfileContent []byte) error {\n\tlog.Printf(\"building image %s from %s\", image, dockerfilePath)\n\n\targs := []string{\n\t\t\"build\",\n\t\t\"-t\", image,\n\t\t\"-f\", dockerfilePath,\n\t\t\"--label\", fmt.Sprintf(\"%s=%s\", dockerfileHashLabel, hash),\n\t}\n\n\t// Record the base image digest so we can detect upstream changes later.\n\tif baseRef := parseBaseImage(dockerfileContent); baseRef != \"\" && strings.ToLower(baseRef) != \"scratch\" {\n\t\tif id, err := baseImageID(ctx, baseRef); err == nil {\n\t\t\targs = append(args, \"--label\", fmt.Sprintf(\"%s=%s\", baseImageDigestLabel, id))\n\t\t}\n\t}\n\n\targs = append(args, projectDir)\n\n\tcmd := exec.CommandContext(ctx, \"docker\", args...)\n\tcmd.Stdout = os.Stderr // stream build output to daemon stderr\n\tcmd.Stderr = os.Stderr\n\tif err := cmd.Run(); err != nil {\n\t\treturn fmt.Errorf(\"building image %s: %w\", image, err)\n\t}\n\n\tlog.Printf(\"image %s built successfully\", image)\n\treturn nil\n}\n","numLines":189,"startLine":1,"totalLines":189}}}
