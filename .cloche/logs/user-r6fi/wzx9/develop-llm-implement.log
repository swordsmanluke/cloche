{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018xkELZYf1Wp1ZrsDUXqZnE","type":"tool_result","content":"     1→package docker\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"os\"\n     6→\t\"os/exec\"\n     7→\t\"path/filepath\"\n     8→\t\"testing\"\n     9→\n    10→\t\"github.com/stretchr/testify/assert\"\n    11→\t\"github.com/stretchr/testify/require\"\n    12→)\n    13→\n    14→func TestHashBytes(t *testing.T) {\n    15→\th1 := hashBytes([]byte(\"hello\"))\n    16→\th2 := hashBytes([]byte(\"hello\"))\n    17→\th3 := hashBytes([]byte(\"world\"))\n    18→\n    19→\tassert.Equal(t, h1, h2, \"same input should produce same hash\")\n    20→\tassert.NotEqual(t, h1, h3, \"different input should produce different hash\")\n    21→\tassert.Len(t, h1, 64, \"SHA-256 hex digest should be 64 chars\")\n    22→}\n    23→\n    24→func TestEnsureImage_NoDockerfile(t *testing.T) {\n    25→\trt := &Runtime{}\n    26→\tdir := t.TempDir()\n    27→\n    28→\t// No .cloche/Dockerfile — should succeed (nothing to validate)\n    29→\terr := rt.EnsureImage(context.Background(), dir, \"test-image:latest\")\n    30→\tassert.NoError(t, err)\n    31→}\n    32→\n    33→func TestImageLabel_NonexistentImage(t *testing.T) {\n    34→\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n    35→\t\tt.Skip(\"Docker not available\")\n    36→\t}\n    37→\n    38→\t_, err := imageLabel(context.Background(), \"cloche-nonexistent-image-xyz:latest\", dockerfileHashLabel)\n    39→\tassert.Error(t, err)\n    40→}\n    41→\n    42→func TestEnsureImage_BuildsWhenImageMissing(t *testing.T) {\n    43→\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n    44→\t\tt.Skip(\"Docker not available\")\n    45→\t}\n    46→\n    47→\tdir := t.TempDir()\n    48→\tdockerfileDir := filepath.Join(dir, \".cloche\")\n    49→\trequire.NoError(t, os.MkdirAll(dockerfileDir, 0755))\n    50→\n    51→\t// Write a minimal Dockerfile\n    52→\tdockerfile := []byte(\"FROM alpine:latest\\nRUN echo hello\\n\")\n    53→\trequire.NoError(t, os.WriteFile(filepath.Join(dockerfileDir, \"Dockerfile\"), dockerfile, 0644))\n    54→\n    55→\timage := \"cloche-test-ensure-build:latest\"\n    56→\t// Clean up any pre-existing image\n    57→\texec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n    58→\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n    59→\n    60→\trt := &Runtime{}\n    61→\terr := rt.EnsureImage(context.Background(), dir, image)\n    62→\trequire.NoError(t, err)\n    63→\n    64→\t// Verify the image exists and has the label\n    65→\tlabel, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n    66→\trequire.NoError(t, err)\n    67→\tassert.Equal(t, hashBytes(dockerfile), label)\n    68→}\n    69→\n    70→func TestEnsureImage_SkipsWhenUpToDate(t *testing.T) {\n    71→\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n    72→\t\tt.Skip(\"Docker not available\")\n    73→\t}\n    74→\n    75→\tdir := t.TempDir()\n    76→\tdockerfileDir := filepath.Join(dir, \".cloche\")\n    77→\trequire.NoError(t, os.MkdirAll(dockerfileDir, 0755))\n    78→\n    79→\tdockerfile := []byte(\"FROM alpine:latest\\nRUN echo skip-test\\n\")\n    80→\trequire.NoError(t, os.WriteFile(filepath.Join(dockerfileDir, \"Dockerfile\"), dockerfile, 0644))\n    81→\n    82→\timage := \"cloche-test-ensure-skip:latest\"\n    83→\texec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n    84→\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n    85→\n    86→\trt := &Runtime{}\n    87→\n    88→\t// First call: builds\n    89→\terr := rt.EnsureImage(context.Background(), dir, image)\n    90→\trequire.NoError(t, err)\n    91→\n    92→\t// Second call with same Dockerfile: should skip (no rebuild)\n    93→\terr = rt.EnsureImage(context.Background(), dir, image)\n    94→\trequire.NoError(t, err)\n    95→\n    96→\t// Image should still have the correct label\n    97→\tlabel, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n    98→\trequire.NoError(t, err)\n    99→\tassert.Equal(t, hashBytes(dockerfile), label)\n   100→}\n   101→\n   102→func TestParseBaseImage(t *testing.T) {\n   103→\ttests := []struct {\n   104→\t\tname       string\n   105→\t\tdockerfile string\n   106→\t\twant       string\n   107→\t}{\n   108→\t\t{\n   109→\t\t\tname:       \"simple FROM\",\n   110→\t\t\tdockerfile: \"FROM ubuntu:22.04\\nRUN echo hello\\n\",\n   111→\t\t\twant:       \"ubuntu:22.04\",\n   112→\t\t},\n   113→\t\t{\n   114→\t\t\tname:       \"FROM with AS stage\",\n   115→\t\t\tdockerfile: \"FROM golang:1.21 AS builder\\nRUN go build\\nFROM alpine:3.18\\nCOPY --from=builder /app /app\\n\",\n   116→\t\t\twant:       \"alpine:3.18\",\n   117→\t\t},\n   118→\t\t{\n   119→\t\t\tname:       \"multi-stage uses last FROM\",\n   120→\t\t\tdockerfile: \"FROM node:18 AS frontend\\nRUN npm build\\nFROM golang:1.21 AS backend\\nRUN go build\\nFROM ubuntu:22.04\\nCOPY --from=frontend /dist /dist\\n\",\n   121→\t\t\twant:       \"ubuntu:22.04\",\n   122→\t\t},\n   123→\t\t{\n   124→\t\t\tname:       \"FROM scratch\",\n   125→\t\t\tdockerfile: \"FROM scratch\\nCOPY app /app\\n\",\n   126→\t\t\twant:       \"scratch\",\n   127→\t\t},\n   128→\t\t{\n   129→\t\t\tname:       \"no FROM\",\n   130→\t\t\tdockerfile: \"RUN echo hello\\n\",\n   131→\t\t\twant:       \"\",\n   132→\t\t},\n   133→\t\t{\n   134→\t\t\tname:       \"comments and blank lines\",\n   135→\t\t\tdockerfile: \"# This is a comment\\n\\nFROM alpine:latest\\nRUN echo hello\\n\",\n   136→\t\t\twant:       \"alpine:latest\",\n   137→\t\t},\n   138→\t\t{\n   139→\t\t\tname:       \"lowercase from\",\n   140→\t\t\tdockerfile: \"from ubuntu:20.04\\nRUN echo hello\\n\",\n   141→\t\t\twant:       \"ubuntu:20.04\",\n   142→\t\t},\n   143→\t\t{\n   144→\t\t\tname:       \"FROM with platform\",\n   145→\t\t\tdockerfile: \"FROM --platform=linux/amd64 golang:1.21\\nRUN echo hello\\n\",\n   146→\t\t\twant:       \"golang:1.21\",\n   147→\t\t},\n   148→\t}\n   149→\n   150→\tfor _, tt := range tests {\n   151→\t\tt.Run(tt.name, func(t *testing.T) {\n   152→\t\t\tgot := parseBaseImage([]byte(tt.dockerfile))\n   153→\t\t\tassert.Equal(t, tt.want, got)\n   154→\t\t})\n   155→\t}\n   156→}\n   157→\n   158→func TestIsBaseImageStale_NoLabel(t *testing.T) {\n   159→\t// When the built image doesn't have the base digest label, staleness\n   160→\t// cannot be determined — should return false.\n   161→\t// This is a unit-level test that doesn't need Docker since we test with\n   162→\t// a nonexistent image that will fail the imageLabel call.\n   163→\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n   164→\t\tt.Skip(\"Docker not available\")\n   165→\t}\n   166→\tcontent := []byte(\"FROM alpine:latest\\nRUN echo hello\\n\")\n   167→\tstale, _ := isBaseImageStale(context.Background(), \"cloche-nonexistent-image-xyz:latest\", content)\n   168→\tassert.False(t, stale)\n   169→}\n   170→\n   171→func TestEnsureImage_StoresBaseImageDigest(t *testing.T) {\n   172→\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n   173→\t\tt.Skip(\"Docker not available\")\n   174→\t}\n   175→\n   176→\tdir := t.TempDir()\n   177→\tdockerfileDir := filepath.Join(dir, \".cloche\")\n   178→\trequire.NoError(t, os.MkdirAll(dockerfileDir, 0755))\n   179→\n   180→\tdockerfile := []byte(\"FROM alpine:latest\\nRUN echo base-digest-test\\n\")\n   181→\trequire.NoError(t, os.WriteFile(filepath.Join(dockerfileDir, \"Dockerfile\"), dockerfile, 0644))\n   182→\n   183→\timage := \"cloche-test-base-digest:latest\"\n   184→\texec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n   185→\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n   186→\n   187→\trt := &Runtime{}\n   188→\terr := rt.EnsureImage(context.Background(), dir, image)\n   189→\trequire.NoError(t, err)\n   190→\n   191→\t// Verify the base image digest label was stored\n   192→\tlabel, err := imageLabel(context.Background(), image, baseImageDigestLabel)\n   193→\trequire.NoError(t, err)\n   194→\tassert.NotEmpty(t, label, \"base image digest label should be set\")\n   195→\n   196→\t// The stored digest should match the current alpine:latest image ID\n   197→\talpineID, err := baseImageID(context.Background(), \"alpine:latest\")\n   198→\trequire.NoError(t, err)\n   199→\tassert.Equal(t, alpineID, label)\n   200→}\n   201→\n   202→func TestEnsureImage_RebuildsWhenDockerfileChanges(t *testing.T) {\n   203→\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n   204→\t\tt.Skip(\"Docker not available\")\n   205→\t}\n   206→\n   207→\tdir := t.TempDir()\n   208→\tdockerfileDir := filepath.Join(dir, \".cloche\")\n   209→\trequire.NoError(t, os.MkdirAll(dockerfileDir, 0755))\n   210→\n   211→\tdockerfilePath := filepath.Join(dockerfileDir, \"Dockerfile\")\n   212→\n   213→\t// Initial Dockerfile\n   214→\tv1 := []byte(\"FROM alpine:latest\\nRUN echo v1\\n\")\n   215→\trequire.NoError(t, os.WriteFile(dockerfilePath, v1, 0644))\n   216→\n   217→\timage := \"cloche-test-ensure-rebuild:latest\"\n   218→\texec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n   219→\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n   220→\n   221→\trt := &Runtime{}\n   222→\n   223→\t// Build with v1\n   224→\terr := rt.EnsureImage(context.Background(), dir, image)\n   225→\trequire.NoError(t, err)\n   226→\n   227→\tlabel1, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n   228→\trequire.NoError(t, err)\n   229→\tassert.Equal(t, hashBytes(v1), label1)\n   230→\n   231→\t// Change Dockerfile to v2\n   232→\tv2 := []byte(\"FROM alpine:latest\\nRUN echo v2\\n\")\n   233→\trequire.NoError(t, os.WriteFile(dockerfilePath, v2, 0644))\n   234→\n   235→\t// Should detect change and rebuild\n   236→\terr = rt.EnsureImage(context.Background(), dir, image)\n   237→\trequire.NoError(t, err)\n   238→\n   239→\tlabel2, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n   240→\trequire.NoError(t, err)\n   241→\tassert.Equal(t, hashBytes(v2), label2)\n   242→\tassert.NotEqual(t, label1, label2, \"label should change after rebuild\")\n   243→}\n   244→"}]},"parent_tool_use_id":"toolu_013wwjsqmM3MdrTvaJaJWq2B","session_id":"d5852ca5-8605-4df2-ab4e-a8f4a3409842","uuid":"6bb90b65-5323-4373-b9f3-e1515f3e9d13"}
