.Background(), image, baseImageDigestLabel)\n   193→\trequire.NoError(t, err)\n   194→\tassert.NotEmpty(t, label, \"base image digest label should be set\")\n   195→\n   196→\t// The stored digest should match the current alpine:latest image ID\n   197→\talpineID, err := baseImageID(context.Background(), \"alpine:latest\")\n   198→\trequire.NoError(t, err)\n   199→\tassert.Equal(t, alpineID, label)\n   200→}\n   201→\n   202→func TestEnsureImage_RebuildsWhenDockerfileChanges(t *testing.T) {\n   203→\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n   204→\t\tt.Skip(\"Docker not available\")\n   205→\t}\n   206→\n   207→\tdir := t.TempDir()\n   208→\tdockerfileDir := filepath.Join(dir, \".cloche\")\n   209→\trequire.NoError(t, os.MkdirAll(dockerfileDir, 0755))\n   210→\n   211→\tdockerfilePath := filepath.Join(dockerfileDir, \"Dockerfile\")\n   212→\n   213→\t// Initial Dockerfile\n   214→\tv1 := []byte(\"FROM alpine:latest\\nRUN echo v1\\n\")\n   215→\trequire.NoError(t, os.WriteFile(dockerfilePath, v1, 0644))\n   216→\n   217→\timage := \"cloche-test-ensure-rebuild:latest\"\n   218→\texec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n   219→\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n   220→\n   221→\trt := &Runtime{}\n   222→\n   223→\t// Build with v1\n   224→\terr := rt.EnsureImage(context.Background(), dir, image)\n   225→\trequire.NoError(t, err)\n   226→\n   227→\tlabel1, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n   228→\trequire.NoError(t, err)\n   229→\tassert.Equal(t, hashBytes(v1), label1)\n   230→\n   231→\t// Change Dockerfile to v2\n   232→\tv2 := []byte(\"FROM alpine:latest\\nRUN echo v2\\n\")\n   233→\trequire.NoError(t, os.WriteFile(dockerfilePath, v2, 0644))\n   234→\n   235→\t// Should detect change and rebuild\n   236→\terr = rt.EnsureImage(context.Background(), dir, image)\n   237→\trequire.NoError(t, err)\n   238→\n   239→\tlabel2, err := imageLabel(context.Background(), imag