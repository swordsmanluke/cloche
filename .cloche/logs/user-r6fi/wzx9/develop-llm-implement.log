{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RJeFXbbSQqGSYFU8gJS6DN","type":"tool_result","content":"     1→package sqlite\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"database/sql\"\n     6→\t\"fmt\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11→\t_ \"modernc.org/sqlite\"\n    12→)\n    13→\n    14→type Store struct {\n    15→\tdb *sql.DB\n    16→}\n    17→\n    18→func NewStore(dsn string) (*Store, error) {\n    19→\tdb, err := sql.Open(\"sqlite\", dsn)\n    20→\tif err != nil {\n    21→\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n    22→\t}\n    23→\n    24→\t// Enable WAL mode for concurrent read/write access\n    25→\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n    26→\n    27→\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n    28→\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n    29→\n    30→\t// Serialize all Go-side access through a single connection so SQLite\n    31→\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n    32→\tdb.SetMaxOpenConns(1)\n    33→\n    34→\tif err := migrate(db); err != nil {\n    35→\t\tdb.Close()\n    36→\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n    37→\t}\n    38→\n    39→\treturn &Store{db: db}, nil\n    40→}\n    41→\n    42→func (s *Store) Close() error {\n    43→\treturn s.db.Close()\n    44→}\n    45→\n    46→func migrate(db *sql.DB) error {\n    47→\t_, err := db.Exec(`\n    48→\t\tCREATE TABLE IF NOT EXISTS runs (\n    49→\t\t\tid TEXT PRIMARY KEY,\n    50→\t\t\tworkflow_name TEXT NOT NULL,\n    51→\t\t\tstate TEXT NOT NULL,\n    52→\t\t\tactive_steps TEXT,\n    53→\t\t\tstarted_at TEXT,\n    54→\t\t\tcompleted_at TEXT\n    55→\t\t);\n    56→\t\tCREATE TABLE IF NOT EXISTS step_executions (\n    57→\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    58→\t\t\trun_id TEXT NOT NULL,\n    59→\t\t\tstep_name TEXT NOT NULL,\n    60→\t\t\tresult TEXT,\n    61→\t\t\tstarted_at TEXT NOT NULL,\n    62→\t\t\tcompleted_at TEXT,\n    63→\t\t\tlogs TEXT,\n    64→\t\t\tgit_ref TEXT,\n    65→\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    66→\t\t);\n    67→\t`)\n    68→\tif err != nil {\n    69→\t\treturn err\n    70→\t}\n    71→\n    72→\t// Evolution schema additions (idempotent)\n    73→\talterStmts := []string{\n    74→\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n    75→\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n    76→\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n    77→\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n    78→\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n    79→\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n    80→\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n    81→\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n    82→\t}\n    83→\tfor _, stmt := range alterStmts {\n    84→\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n    85→\t}\n    86→\n    87→\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n    88→\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    89→\t\trun_id TEXT NOT NULL,\n    90→\t\tstep_name TEXT,\n    91→\t\tfile_type TEXT NOT NULL,\n    92→\t\tfile_path TEXT NOT NULL,\n    93→\t\tfile_size INTEGER,\n    94→\t\tcreated_at TEXT NOT NULL,\n    95→\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    96→\t)`)\n    97→\tif errLog != nil {\n    98→\t\treturn errLog\n    99→\t}\n   100→\n   101→\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n   102→\t\trun_id TEXT PRIMARY KEY,\n   103→\t\tbranch TEXT NOT NULL,\n   104→\t\tproject TEXT NOT NULL,\n   105→\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n   106→\t\tenqueued_at TEXT NOT NULL,\n   107→\t\tcompleted_at TEXT\n   108→\t)`)\n   109→\tif errMQ != nil {\n   110→\t\treturn errMQ\n   111→\t}\n   112→\n   113→\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n   114→\t\tid TEXT PRIMARY KEY,\n   115→\t\tproject_dir TEXT NOT NULL,\n   116→\t\tworkflow_name TEXT NOT NULL,\n   117→\t\ttrigger_run_id TEXT NOT NULL,\n   118→\t\tcreated_at TEXT NOT NULL,\n   119→\t\tclassification TEXT,\n   120→\t\tchanges_json TEXT NOT NULL,\n   121→\t\tknowledge_delta TEXT\n   122→\t)`)\n   123→\tif err2 != nil {\n   124→\t\treturn err2\n   125→\t}\n   126→\n   127→\treturn nil\n   128→}\n   129→\n   130→func (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n   131→\t_, err := s.db.ExecContext(ctx,\n   132→\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept)\n   133→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   134→\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n   135→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, run.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept),\n   136→\t)\n   137→\treturn err\n   138→}\n   139→\n   140→func (s *Store) GetRun(ctx context.Context, id string) (*domain.Run, error) {\n   141→\trow := s.db.QueryRowContext(ctx,\n   142→\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0) FROM runs WHERE id = ?`, id)\n   143→\n   144→\trun := &domain.Run{}\n   145→\tvar activeSteps, startedAt, completedAt string\n   146→\tvar containerKept int\n   147→\terr := row.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept)\n   148→\tif err == sql.ErrNoRows {\n   149→\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n   150→\t}"}]},"parent_tool_use_id":"toolu_013wwjsqmM3MdrTvaJaJWq2B","session_id":"d5852ca5-8605-4df2-ab4e-a8f4a3409842","uuid":"d5e03534-6212-4822-b2af-eaf0f25cb8ab"}
