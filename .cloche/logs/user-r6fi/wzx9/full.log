\":\"lucas@perfectlunacy.com\",\"created_at\":\"2026-02-27T12:34:59.78809366-08:00\",\"created_by\":\"lucas\",\"updated_at\":\"2026-03-07T08:51:40.438970384-08:00\"}\n {\"id\":\"cloche-toz\",\"title\":\"Implement container retention policy for failed runs\",\"description\":\"Change container lifecycle so failed runs automatically keep their container for debugging. Successful runs continue to auto-delete. Preserve --keep-container flag for keeping containers regardless of outcome. Track retained containers in SQLite (container ID, run ID, project, creation time, status). See docs/plans/2026-03-03-next-features-design.md §5.\",\"acceptance_criteria\":\"Failed runs keep container. Successful runs delete container. --keep-container keeps regardless. Retained containers tracked in SQLite.\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"owner\":\"lucas@perfectlunacy.com\",\"created_at\":\"2026-03-03T10:41:56.900426871-08:00\",\"created_by\":\"lucas\",\"updated_at\":\"2026-03-03T11:38:08.318649084-08:00\",\"closed_at\":\"2026-03-03T11:38:08.318649084-08:00\",\"close_reason\":\"Closed\"}\n {\"id\":\"cloche-u6c\",\"title\":\"DSL parser\",\"description\":\"Parser that converts tokens into domain.Workflow. Handles steps, fields, wiring, container blocks. See implementation plan Task 5.\",\"status\":\"closed\",\"priority\":1,\"issue_type\":\"task\",\"owner\":\"lucas@perfectlunacy.com\",\"created_at\":\"2026-02-20T11:04:18.428363172-08:00\",\"created_by\":\"lucas\",\"updated_at\":\"2026-02-20T12:06:53.577444897-08:00\",\"closed_at\":\"2026-02-20T12:06:53.577444897-08:00\",\"close_reason\":\"Parser with type inference, container blocks, wiring\",\"dependencies\":[{\"issue_id\":\"cloche-u6c\",\"depends_on_id\":\"cloche-ucq\",\"type\":\"blocks\",\"created_at\":\"2026-02-20T11:04:18.429550055-08:00\",\"created_by\":\"lucas\"},{\"issue_id\":\"cloche-u6c\",\"depends_on_id\":\"cloche-8bi\",\"type\":\"blocks\",\"created_at\":\"2026-02-20T11:04:18.431125553-08:00\",\"cr