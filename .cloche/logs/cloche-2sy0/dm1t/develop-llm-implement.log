--badge-stopped-text); }\n\n@keyframes pulse {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0.6; }\n}\n\n/* Tables */\n.runs-table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 0.9rem;\n}\n\n.runs-table th,\n.runs-table td {\n    padding: 0.5rem 0.75rem;\n    text-align: left;\n    border-bottom: 1px solid var(--border);\n}\n\n.runs-table th {\n    background: var(--bg-surface);\n    font-weight: 600;\n    font-size: 0.8rem;\n    text-transform: uppercase;\n    letter-spacing: 0.03em;\n    color: var(--text-muted);\n}\n\n.runs-table tr:hover { background: var(--bg-surface); }\n.detail-row:hover { background: inherit; }\n.step-row { cursor: pointer; }\n.output-row td { padding: 0 !important; }\n.step-output {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 0.75rem;\n    font-family: var(--mono);\n    font-size: 0.8rem;\n    max-height: 500px;\n    overflow: auto;\n    white-space: pre-wrap;\n    word-break: break-word;\n    margin: 0.25rem 0.75rem 0.75rem;\n}\n\n.mono { font-family: var(--mono); font-size: 0.85em; }\n.empty { color: var(--text-muted); text-align: center; padding: 2rem 0; }\n.error-cell { color: var(--badge-failed-text); font-size: 0.85em; }\n\n/* Run metadata */\n.run-meta dl {\n    display: grid;\n    grid-template-columns: auto 1fr;\n    gap: 0.25rem 1rem;\n    margin: 0 0 1rem;\n    font-size: 0.9rem;\n}\n\n.run-meta dt { color: var(--text-muted); font-weight: 600; }\n.run-meta dd { margin: 0; }\n\n/* Error box */\n.error-box {\n    background: var(--error-bg);\n    border: 1px solid var(--error-border);\n    color: var(--error-text);\n    padding: 0.75rem 1rem;\n    border-radius: var(--radius);\n    margin-bottom: 1rem;\n    font-size: 0.9rem;\n}\n\n/* Details / pre */\ndetails {\n    margin: 0.5rem 0;\n}\n\ndetails summary {\n    cursor: pointer;\n    font-weight: 600;\n    font-size: 0.85rem;\n    color: var(--text-muted);\n}\n\ndetails pre {\