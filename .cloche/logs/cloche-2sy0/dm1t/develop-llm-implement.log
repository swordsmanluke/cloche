{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NqKh4vExdSoD7p9GscLbyC","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"net/url\"\n    13→\t\"os\"\n    14→\t\"os/exec\"\n    15→\t\"path/filepath\"\n    16→\t\"regexp\"\n    17→\t\"sort\"\n    18→\t\"strconv\"\n    19→\t\"strings\"\n    20→\t\"time\"\n    21→\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    24→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    25→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    26→)\n    27→\n    28→// HandlerOption configures optional Handler dependencies.\n    29→type HandlerOption func(*Handler)\n    30→\n    31→// WithContainerLogger sets the container runtime for fetching live logs.\n    32→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    33→\treturn func(h *Handler) { h.container = c }\n    34→}\n    35→\n    36→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    37→func WithContainerManager(c ContainerManager) HandlerOption {\n    38→\treturn func(h *Handler) { h.container = c }\n    39→}\n    40→\n    41→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    42→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    43→\treturn func(h *Handler) { h.logBroadcast = b }\n    44→}\n    45→\n    46→// WithLogStore sets the log store for indexed log file lookups.\n    47→func WithLogStore(ls ports.LogStore) HandlerOption {\n    48→\treturn func(h *Handler) { h.logStore = ls }\n    49→}\n    50→\n    51→// WithTaskProvider sets the task provider for querying orchestration loop task state.\n    52→func WithTaskProvider(tp TaskProvider) HandlerOption {\n    53→\treturn func(h *Handler) { h.taskProvider = tp }\n    54→}\n    55→\n    56→//go:embed templates/*.html static/*\n    57→var content embed.FS\n    58→\n    59→// Handler serves the web dashboard.\n    60→// ContainerLogger can retrieve logs from a container by ID.\n    61→type ContainerLogger interface {\n    62→\tLogs(ctx context.Context, containerID string) (string, error)\n    63→}\n    64→\n    65→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    66→type ContainerManager interface {\n    67→\tContainerLogger\n    68→\tStop(ctx context.Context, containerID string) error\n    69→\tRemove(ctx context.Context, containerID string) error\n    70→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    71→}\n    72→\n    73→// TaskEntry represents a task with its assignment state for external consumers.\n    74→type TaskEntry struct {\n    75→\tID          string            `json:\"id\"`\n    76→\tStatus      string            `json:\"status\"`\n    77→\tTitle       string            `json:\"title\"`\n    78→\tDescription string            `json:\"description,omitempty\"`\n    79→\tMetadata    map[string]string `json:\"metadata,omitempty\"`\n    80→\tAssigned    bool              `json:\"assigned\"`\n    81→\tAssignedAt  string            `json:\"assigned_at,omitempty\"`\n    82→\tRunID       string            `json:\"run_id,omitempty\"`\n    83→\tStale       bool              `json:\"stale,omitempty\"`\n    84→}\n    85→\n    86→// TaskProvider retrieves task pipeline state for a project's orchestration loop.\n    87→type TaskProvider interface {\n    88→\tGetLoopTasks(projectDir string) []TaskEntry\n    89→\tReleaseTask(ctx context.Context, projectDir string, taskID string) error\n    90→}\n    91→\n    92→type Handler struct {\n    93→\tstore        ports.RunStore\n    94→\tcaptures     ports.CaptureStore\n    95→\tlogStore     ports.LogStore\n    96→\tcontainer    ContainerLogger\n    97→\tlogBroadcast *logstream.Broadcaster\n    98→\ttaskProvider TaskProvider\n    99→\tpages        map[string]*template.Template\n   100→\tmux          *http.ServeMux\n   101→}\n   102→\n   103→// NewHandler creates a web dashboard handler.\n   104→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n   105→\tfuncMap := template.FuncMap{\n   106→\t\t\"stateColor\":       stateColor,\n   107→\t\t\"healthColor\":      healthColor,\n   108→\t\t\"formatTime\":       formatTime,\n   109→\t\t\"formatDuration\":   formatDuration,\n   110→\t\t\"formatRunTiming\":  formatRunTiming,\n   111→\t\t\"truncate\":         truncate,\n   112→\t\t\"shortContainerID\": shortContainerID,\n   113→\t\t\"jsonMap\":          jsonMap,\n   114→\t}\n   115→\n   116→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   117→\tif err != nil {\n   118→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   119→\t}\n   120→\n   121→\tpages := map[string]*template.Template{}\n   122→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   123→\t\tclone, err := base.Clone()\n   124→\t\tif err != nil {\n   125→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   126→\t\t}\n   127→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   128→\t\tif err != nil {\n   129→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   130→\t\t}\n   131→\t\tpages[page] = clone\n   132→\t}\n   133→\n   134→\th := &Handler{\n   135→\t\tstore:    store,\n   136→\t\tcaptures: captures,\n   137→\t\tpages:    pages,\n   138→\t\tmux:      http.NewServeMux(),\n   139→\t}\n   140→\tfor _, opt := range opts {\n   141→\t\topt(h)\n   142→\t}\n   143→\n   144→\tstaticFS, err := fs.Sub(content, \"static\")\n   145→\tif err != nil {\n   146→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   147→\t}\n   148→\n   149→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   150→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   151→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   152→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   153→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   154→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   155→\th.mux.HandleFunc(\"GET /api/projects/{name}/runs\", h.handleAPIProjectRuns)\n   156→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   157→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   158→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   159→\th.mux.HandleFunc(\"POST /api/runs/{id}/stop\", h.handleAPIStopRun)\n   160→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   161→\th.mux.HandleFunc(\"DELETE /api/projects/{name}/containers\", h.handleAPIDeleteProjectContainers)\n   162→\th.mux.HandleFunc(\"DELETE /api/containers\", h.handleAPIDeleteAllContainers)\n   163→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   164→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   165→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   166→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   167→\th.mux.HandleFunc(\"GET /api/projects/{name}/tasks\", h.handleAPITasks)\n   168→\th.mux.HandleFunc(\"POST /api/projects/{name}/tasks/{taskId}/release\", h.handleAPIReleaseTask)\n   169→\th.mux.HandleFunc(\"GET /api/runs/{id}/logs\", h.handleAPILogs)\n   170→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   171→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   172→\n   173→\treturn h, nil\n   174→}\n   175→\n   176→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   177→\th.mux.ServeHTTP(w, r)\n   178→}\n   179→\n   180→// --- HTML handlers ---\n   181→\n   182→// projectOverviewEntry holds data for a single project card on the landing page.\n   183→type projectOverviewEntry struct {\n   184→\tDir         string\n   185→\tLabel       string\n   186→\tHealth      domain.HealthResult\n   187→\tRecentRuns  []recentRunDot\n   188→\tActiveCount int\n   189→}\n   190→\n   191→// recentRunDot is a minimal representation of a run for the mini history display.\n   192→type recentRunDot struct {\n   193→\tID    string\n   194→\tState string\n   195→}\n   196→\n   197→const healthWindowSize = 10\n   198→\n   199→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   200→\tprojects, _ := h.store.ListProjects(r.Context())\n   201→\tlabels := projectLabels(projects)\n   202→\n   203→\tvar entries []projectOverviewEntry\n   204→\tfor _, dir := range projects {\n   205→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   206→\t\tif err != nil {\n   207→\t\t\tcontinue\n   208→\t\t}\n   209→\n   210→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   211→\t\trunValues := make([]domain.Run, len(runs))\n   212→\t\tfor i, rr := range runs {\n   213→\t\t\trunValues[i] = *rr\n   214→\t\t}\n   215→\n   216→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   217→\n   218→\t\t// Take the last N runs for the mini history (most recent first).\n   219→\t\tn := healthWindowSize\n   220→\t\tif n > len(runs) {\n   221→\t\t\tn = len(runs)\n   222→\t\t}\n   223→\t\tdots := make([]recentRunDot, n)\n   224→\t\tfor i := 0; i < n; i++ {\n   225→\t\t\tdots[i] = recentRunDot{\n   226→\t\t\t\tID:    runs[i].ID,\n   227→\t\t\t\tState: string(runs[i].State),\n   228→\t\t\t}\n   229→\t\t}\n   230→\n   231→\t\tvar activeCount int\n   232→\t\tfor _, rr := range runs {\n   233→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   234→\t\t\t\tactiveCount++\n   235→\t\t\t}\n   236→\t\t}\n   237→\n   238→\t\tentries = append(entries, projectOverviewEntry{\n   239→\t\t\tDir:         dir,\n   240→\t\t\tLabel:       labels[dir],\n   241→\t\t\tHealth:      health,\n   242→\t\t\tRecentRuns:  dots,\n   243→\t\t\tActiveCount: activeCount,\n   244→\t\t})\n   245→\t}\n   246→\n   247→\tsort.Slice(entries, func(i, j int) bool {\n   248→\t\treturn entries[i].Label < entries[j].Label\n   249→\t})\n   250→\n   251→\tdata := map[string]any{\n   252→\t\t\"Title\":    \"Projects\",\n   253→\t\t\"Projects\": entries,\n   254→\t}\n   255→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   256→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   257→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   258→\t}\n   259→}\n   260→\n   261→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   262→\tprojectFilter := r.URL.Query().Get(\"project\")\n   263→\n   264→\t// Redirect ?project=<dir> to clean URL /projects/<label>/runs.\n   265→\tif projectFilter != \"\" {\n   266→\t\tprojects, _ := h.store.ListProjects(r.Context())\n   267→\t\tlabels := projectLabels(projects)\n   268→\t\tif label, ok := labels[projectFilter]; ok {\n   269→\t\t\thttp.Redirect(w, r, \"/projects/\"+url.PathEscape(label)+\"/runs\", http.StatusFound)\n   270→\t\t\treturn\n   271→\t\t}\n   272→\t}\n   273→\n   274→\th.renderRunsList(w, r, \"\")\n   275→}\n   276→\n   277→// renderRunsList renders the runs list page, optionally filtered by project directory.\n   278→func (h *Handler) renderRunsList(w http.ResponseWriter, r *http.Request, projectFilter string) {\n   279→\tvar runs []*domain.Run\n   280→\tvar err error\n   281→\tif projectFilter != \"\" {\n   282→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   283→\t} else {\n   284→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   285→\t}\n   286→\tif err != nil {\n   287→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   288→\t\treturn\n   289→\t}\n   290→\n   291→\tprojects, _ := h.store.ListProjects(r.Context())\n   292→\tlabels := projectLabels(projects)\n   293→\n   294→\t// Count retained containers per project\n   295→\tcontainerCounts := map[string]int{}\n   296→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   297→\tfor _, run := range allRuns {\n   298→\t\tif run.ContainerKept {\n   299→\t\t\tcontainerCounts[run.ProjectDir]++\n   300→\t\t}\n   301→\t}\n   302→\n   303→\tvar projectList []projectEntry\n   304→\tfor _, dir := range projects {\n   305→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   306→\t}\n   307→\tsort.Slice(projectList, func(i, j int) bool {\n   308→\t\treturn projectList[i].Label < projectList[j].Label\n   309→\t})\n   310→\n   311→\tvar totalContainerCount int\n   312→\tfor _, c := range containerCounts {\n   313→\t\ttotalContainerCount += c\n   314→\t}\n   315→\n   316→\tgrouped := groupAndSortRuns(runs, labels, h.taskTitlesFromRuns(runs))\n   317→\n   318→\t// Build a JSON map of dir→label for the template JS.\n   319→\tdirToLabel := map[string]string{}\n   320→\tfor _, p := range projectList {\n   321→\t\tdirToLabel[p.Dir] = p.Label\n   322→\t}\n   323→\n   324→\t// Resolve the label for the active project filter, if any.\n   325→\tvar projectLabel string\n   326→\tif projectFilter != \"\" {\n   327→\t\tprojectLabel = labels[projectFilter]\n   328→\t}\n   329→\n   330→\tdata := map[string]any{\n   331→\t\t\"Title\":               \"Runs\",\n   332→\t\t\"GroupedRuns\":         grouped,\n   333→\t\t\"Projects\":            projectList,\n   334→\t\t\"ProjectFilter\":       projectFilter,\n   335→\t\t\"ProjectLabel\":        projectLabel,\n   336→\t\t\"ProjectLabels\":       labels,\n   337→\t\t\"DirToLabel\":          dirToLabel,\n   338→\t\t\"TotalContainerCount\": totalContainerCount,\n   339→\t}\n   340→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   341→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   342→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   343→\t}\n   344→}\n   345→\n   346→// handleProjectRuns renders the runs list filtered by the project in the URL path.\n   347→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   348→\tdir, _, ok := h.resolveProjectDir(w, r)\n   349→\tif !ok {\n   350→\t\treturn\n   351→\t}\n   352→\th.renderRunsList(w, r, dir)\n   353→}\n   354→\n   355→// stepEntry is a merged view of a step execution for the template.\n   356→type stepEntry struct {\n   357→\tIndex     int\n   358→\tStepName  string\n   359→\tResult    string\n   360→\tStartedAt time.Time\n   361→\tDuration  string\n   362→}\n   363→\n   364→// mergeCaptures collapses started/completed capture pairs into single entries.\n   365→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   366→\tvar entries []stepEntry\n   367→\t// Track pending started rows by step name (LIFO for retries)\n   368→\tpending := map[string]*domain.StepExecution{}\n   369→\n   370→\tfor _, c := range caps {\n   371→\t\tif c.Result == \"\" {\n   372→\t\t\t// step_started row\n   373→\t\t\tpending[c.StepName] = c\n   374→\t\t\tcontinue\n   375→\t\t}\n   376→\t\t// step_completed row — merge with pending started if available\n   377→\t\tstartedAt := c.StartedAt\n   378→\t\tif started := pending[c.StepName]; started != nil {\n   379→\t\t\tstartedAt = started.StartedAt\n   380→\t\t\tdelete(pending, c.StepName)\n   381→\t\t}\n   382→\t\tentries = append(entries, stepEntry{\n   383→\t\t\tIndex:     len(entries),\n   384→\t\t\tStepName:  c.StepName,\n   385→\t\t\tResult:    c.Result,\n   386→\t\t\tStartedAt: startedAt,\n   387→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   388→\t\t})\n   389→\t}\n   390→\n   391→\t// Append any started-but-not-completed steps (still running)\n   392→\tfor _, c := range caps {\n   393→\t\tif c.Result == \"\" {\n   394→\t\t\tif _, used := pending[c.StepName]; !used {\n   395→\t\t\t\tcontinue\n   396→\t\t\t}\n   397→\t\t\tentries = append(entries, stepEntry{\n   398→\t\t\t\tIndex:     len(entries),\n   399→\t\t\t\tStepName:  c.StepName,\n   400→\t\t\t\tStartedAt: c.StartedAt,\n   401→\t\t\t})\n   402→\t\t\tdelete(pending, c.StepName)\n   403→\t\t}\n   404→\t}\n   405→\n   406→\treturn entries\n   407→}\n   408→\n   409→// containerState inspects the container for a run and returns one of:\n   410→//   - \"running\"   – container exists and is running\n   411→//   - \"stopped\"   – container exists, not running, not kept\n   412→//   - \"available\" – container exists, not running, kept (can be deleted)\n   413→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   414→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   415→\tif run.ContainerID == \"\" {\n   416→\t\treturn \"removed\"\n   417→\t}\n   418→\tmgr, ok := h.container.(ContainerManager)\n   419→\tif !ok {\n   420→\t\treturn \"removed\"\n   421→\t}\n   422→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   423→\tif err != nil {\n   424→\t\treturn \"removed\"\n   425→\t}\n   426→\tif status.Running {\n   427→\t\treturn \"running\"\n   428→\t}\n   429→\tif run.ContainerKept {\n   430→\t\treturn \"available\"\n   431→\t}\n   432→\treturn \"stopped\"\n   433→}\n   434→\n   435→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   436→\tid := r.PathValue(\"id\")\n   437→\n   438→\trun, err := h.store.GetRun(r.Context(), id)\n   439→\tif err != nil {\n   440→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   441→\t\treturn\n   442→\t}\n   443→\n   444→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   445→\tif err != nil {\n   446→\t\tcaps = nil // non-fatal\n   447→\t}\n   448→\n   449→\tsteps := mergeCaptures(caps)\n   450→\n   451→\t// Fetch parent run if this is a child\n   452→\tvar parentRun *domain.Run\n   453→\tif run.ParentRunID != \"\" {\n   454→\t\tparentRun, _ = h.store.GetRun(r.Context(), run.ParentRunID)\n   455→\t}\n   456→\n   457→\t// Fetch child runs\n   458→\tchildRuns, _ := h.store.ListChildRuns(r.Context(), id)\n   459→\n   460→\tdata := map[string]any{\n   461→\t\t\"Title\":          \"Run \" + run.ID,\n   462→\t\t\"Run\":            run,\n   463→\t\t\"Steps\":          steps,\n   464→\t\t\"Page\":           \"detail\",\n   465→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   466→\t\t\"ParentRun\":      parentRun,\n   467→\t\t\"ChildRuns\":      childRuns,\n   468→\t}\n   469→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   470→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   471→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   472→\t}\n   473→}\n   474→\n   475→// --- JSON API handlers ---\n   476→\n   477→type apiRun struct {\n   478→\tID           string `json:\"id\"`\n   479→\tWorkflowName string `json:\"workflow_name\"`\n   480→\tProjectDir   string `json:\"project_dir\"`\n   481→\tProjectLabel string `json:\"project_label\"`\n   482→\tState        string `json:\"state\"`\n   483→\tStartedAt    string `json:\"started_at\"`\n   484→\tCompletedAt  string `json:\"completed_at\"`\n   485→\tTiming       string `json:\"timing\"`\n   486→\tContainerID  string `json:\"container_id\"`\n   487→\tErrorMessage string `json:\"error_message\"`\n   488→\tTitle        string `json:\"title\"`\n   489→\tIsHost       bool   `json:\"is_host\"`\n   490→\tParentRunID  string `json:\"parent_run_id,omitempty\"`\n   491→\tTaskID       string `json:\"task_id,omitempty\"`\n   492→}\n   493→\n   494→type apiStep struct {\n   495→\tStepName    string `json:\"step_name\"`\n   496→\tResult      string `json:\"result\"`\n   497→\tStartedAt   string `json:\"started_at\"`\n   498→\tCompletedAt string `json:\"completed_at\"`\n   499→\tDuration    string `json:\"duration\"`\n   500→}"}]},"parent_tool_use_id":"toolu_012cHDFabvg9usACfcVD5oxF","session_id":"1fb48c22-5522-4979-b41c-2ba7d12d90ca","uuid":"136227fe-3ec7-4e28-921d-628f12abceae"}
