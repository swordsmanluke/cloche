 dag-merge-line' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\"/>';\n\n        // Merge point dots (at offset positions for non-success wires)\n        srcPts.forEach(function(pt) {\n            var off = isSuccessResult(pt.result) ? 0 : nonsuccOffset;\n            svg += '<circle cx=\"' + mergeX + '\" cy=\"' + (pt.y + off) + '\" r=\"3\" class=\"dag-merge-dot\"/>';\n        });\n\n        // Single line from collector to terminal\n        var mergeMarker = hasNonSucc ? 'url(#arrowhead-fail)' : 'url(#arrowhead)';\n        svg += '<path d=\"M' + mergeX + ' ' + termY + ' L' + tpos.x + ' ' + termY + '\" class=\"dag-edge' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\" marker-end=\"' + mergeMarker + '\"/>';\n    }","new_string":"        // Multiple wires to same terminal: merge into a collector bus\n        var mergeY = tpos.y - 40;\n        var termX = tpos.x + nodeW / 2;\n\n        var srcPts = [];\n        tWires.forEach(function(wire) {\n            var from = positions[wire.from];\n            if (!from) return;\n            srcPts.push({ x: from.x + nodeW / 2, y: from.y + nodeH, result: wire.result });\n        });\n        srcPts.sort(function(a, b) { return a.x - b.x; });\n\n        // Individual curves from each source to the merge line (offset non-success)\n        srcPts.forEach(function(pt) {\n            var isSucc = isSuccessResult(pt.result);\n            var off = isSucc ? 0 : nonsuccOffset;\n            var dy = mergeY - pt.y;\n            var arcX = pt.x + off;\n            var cls = 'dag-edge' + (isSucc ? '' : ' dag-edge-nonsuccess');\n            svg += '<path d=\"M' + pt.x + ' ' + pt.y + ' C' + arcX + ' ' + (pt.y + dy * 0.5) + ' ' + arcX + ' ' + (mergeY - 20) + ' ' + arcX + ' ' + mergeY + '\" class=\"' + cls + '\"/>';\n            svg += '<text x=\"' + (arcX + 6) + '\" y=\"' + (pt.y + dy * 0.35) + '\" class=\"dag-edge-label\">' + pt.result + '</text>';\n        });\n\n        // Horizontal collector line\n        var mergeEnds = srcPts.map(function(pt) { return pt.x + (isSuccessResult(pt.result) ? 0 : nonsuccOffset); });\n        mergeEnds.push(termX);\n        var minX = Math.min.apply(null, mergeEnds);\n        var maxX = Math.max.apply(null, mergeEnds);\n        var hasNonSucc = tWires.some(function(w) { return !isSuccessResult(w.result); });\n        svg += '<path d=\"M' + minX + ' ' + mergeY + ' L' + maxX + ' ' + mergeY + '\" class=\"dag-edge dag-merge-line' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\"/>';\n\n        // Merge point dots (at offset positions for non-success wires)\n        srcPts.forEach(function(pt) {\n            var off = isSuccessResult(pt.result) ? 0 : nonsuccOffset;\n            svg += '<circle cx=\"' + (pt.x + off) + '\" cy=\"' + mergeY + '\" r=\"3\" class=\"dag-merge-dot\"/>';\n        });\n\n        // Single line from collector to terminal\n        var mergeMarker = hasNonSucc ? 'url(#arrowhead-fail)' : 'url(#arrowhead)';\n        svg += '<path d=\"M' + termX + ' ' + mergeY + ' L' + termX + ' ' + tpos.y + '\" class=\"dag-edge' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\" marker-end=\"' + mergeMarker + '\"/>';\n    }"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1087,"cache_read_input_tokens":30840,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1087},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"1fb48c22-5522-4979-b41c-2ba7d12d90ca","uuid":"93ebcaa3-f10e-484e-b4b5-db3feaf7d7c0"}
