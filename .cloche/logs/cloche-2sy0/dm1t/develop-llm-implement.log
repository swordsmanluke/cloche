75rem;\n    color: var(--text-muted);\n    text-transform: uppercase;\n    letter-spacing: 0.03em;\n}\n\n/* Mini run history dots */\n.run-history {\n    display: flex;\n    gap: 4px;\n    align-items: center;\n    min-height: 16px;\n}\n\n.run-dot {\n    display: inline-block;\n    width: 10px;\n    height: 10px;\n    border-radius: 50%;\n}\n\n.run-dot-succeeded { background: #22c55e; }\n.run-dot-failed    { background: #ef4444; }\n.run-dot-cancelled { background: #9ca3af; }\n.run-dot-running   { background: #3b82f6; animation: pulse 2s infinite; }\n.run-dot-pending   { background: #eab308; }\n\n/* Action buttons */\n.project-actions {\n    display: flex;\n    gap: 0.5rem;\n    margin-top: 0.25rem;\n}\n\n.btn {\n    display: inline-block;\n    padding: 0.35em 0.75em;\n    border-radius: var(--radius);\n    font-family: var(--font);\n    font-size: 0.8rem;\n    font-weight: 600;\n    border: 1px solid var(--border);\n    cursor: pointer;\n    text-decoration: none;\n    white-space: nowrap;\n}\n\n.btn:hover { text-decoration: none; }\n\n.btn-secondary {\n    background: var(--bg);\n    color: var(--link);\n}\n\n.btn-secondary:hover { background: var(--bg-surface); }\n\n.btn-primary {\n    background: var(--link);\n    color: #fff;\n    border-color: var(--link);\n}\n\n.btn-primary:hover { opacity: 0.9; }\n\n.btn-danger {\n    background: var(--badge-failed-bg);\n    color: var(--badge-failed-text);\n    border-color: var(--error-border);\n}\n\n.btn-danger:hover { opacity: 0.8; }\n\n.btn-sm { font-size: 0.75rem; padding: 0.15em 0.45em; }\n\n.btn:disabled {\n    opacity: 0.6;\n    cursor: not-allowed;\n}\n\n/* Log viewer */\n.log-viewer {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    max-height: 600px;\n    overflow: auto;\n    margin-bottom: 1.5rem;\n}\n\n.log-viewer pre {\n    margin: 0;\n    padding: 0.75rem;\n    font-family: var(--mono);\n    font-size: 0.8rem;\n    white-space: pre-wrap;\n    word-break: break-word;\n    line-height: 1.4;\n}\n\n/* Load-earlier button inside log viewer */\n.load-earlier-btn {\n    display: block;\n    width: 100%;\n    padding: 0.4rem;\n    text-align: center;\n    background: var(--bg-secondary);\n    border: none;\n    border-bottom: 1px solid var(--border);\n    cursor: pointer;\n    font-size: 0.8rem;\n    font-family: var(--mono);\n    color: var(--link);\n}\n.load-earlier-btn:hover { background: var(--border); }\n.load-earlier-btn:disabled { opacity: 0.5; cursor: wait; }\n\n.log-line { display: block; }\n.log-type-status { color: var(--badge-running-text); }\n.log-type-llm { color: var(--badge-succeeded-text); }\n.log-type-script { color: var(--text); }\n\n/* Panels */\n.panel {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    margin-bottom: 1rem;\n}\n\n.panel-header {\n    font-weight: 700;\n    font-size: 0.9rem;\n    padding: 0.6rem 1rem;\n    border-bottom: 1px solid var(--border);\n    text-transform: uppercase;\n    letter-spacing: 0.03em;\n    color: var(--text-muted);\n}\n\n.panel-body {\n    padding: 1rem;\n}\n\n/* Tabs */\n.tab-bar {\n    display: flex;\n    gap: 0;\n    border-bottom: 1px solid var(--border);\n    margin-bottom: 1rem;\n}\n.tab-bar:empty {\n    display: none;\n}\n\n.tab-btn {\n    padding: 0.4rem 1rem;\n    font-family: var(--font);\n    font-size: 0.85rem;\n    font-weight: 600;\n    background: none;\n    border: none;\n    border-bottom: 2px solid transparent;\n    color: var(--text-muted);\n    cursor: pointer;\n}\n\n.tab-btn:hover { color: var(--text); }\n.tab-btn.tab-active { color: var(--link); border-bottom-color: var(--link); }\n\n/* DAG */\n.dag-svg { display: block; }\n#workflow-dag { overflow-y: auto; }\n\n.dag-node-rect {\n    fill: var(--bg);\n    stroke: var(--border);\n    stroke-width: 1.5;\n    rx: 4;\n}\n\n.dag-node:hover .dag-node-rect { stroke: var(--link); stroke-width: 2; }\n\n.dag-node-text {\n    font-family: var(--font);\n    font-size: 13px;\n    fill: var(--text);\n}\n\n.dag-edge {\n    fill: none;\n    stroke: var(--text-muted);\n    stroke-width: 1.5;\n}\n\n.dag-edge-label {\n    font-family: var(--font);\n    font-size: 10px;\n    fill: var(--text-muted);\n    text-anchor: middle;\n}\n\n.dag-terminal-done { fill: var(--badge-succeeded-bg); stroke: var(--badge-succeeded-text); }\n.dag-terminal-abort { fill: var(--badge-failed-bg); stroke: var(--badge-failed-text); }\n\n.dag-merge-line { stroke-dasharray: 4 3; }\n.dag-merge-dot { fill: var(--text-muted); }\n\n.dag-edge-nonsuccess { stroke: var(--badge-failed-text); opacity: 0.7; }\n\n/* Drawer */\n.drawer {\n    position: fixed;\n    top: 0;\n    right: -420px;\n    width: 400px;\n    height: 100vh;\n    background: var(--bg-surface);\n    border-left: 1px solid var(--border);\n    box-shadow: -4px 0 12px rgba(0,0,0,0.1);\n    transition: right 0.25s ease;\n    z-index: 100;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n}\n\n.drawer.drawer-open { right: 0; }\n\n.drawer-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 0.75rem 1rem;\n    border-bottom: 1px solid var(--border);\n    font-weight: 700;\n    font-size: 1rem;\n}\n\n.drawer-close {\n    background: none;\n    border: none;\n    font-size: 1.4rem;\n    cursor: pointer;\n    color: var(--text-muted);\n    padding: 0 0.25rem;\n}\n\n.drawer-close:hover { color: var(--text); }\n\n.drawer-body {\n    padding: 1rem;\n    overflow-y: auto;\n    flex: 1;\n}\n\n.drawer-body pre {\n    background: var(--bg);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 0.75rem;\n    font-family: var(--mono);\n    font-size: 0.8rem;\n    max-height: 400px;\n    overflow: auto;\n    white-space: pre-wrap;\n    word-break: break-word;\n}\n\n/* Diff block */\n.diff-block {\n    background: var(--bg);\n    border: 1px solid var(--border);\n    border-radius: va