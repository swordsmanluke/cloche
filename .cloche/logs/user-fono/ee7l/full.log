rateRequest{ProjectDir: dir})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"host.cloche not found\")\n}\n\nfunc TestServer_Orchestrate_EmptyProjectDir(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\n\t_, err = srv.Orchestrate(context.Background(), &pb.OrchestrateRequest{ProjectDir: \"\"})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"project_dir is required\")\n}\n\n","new_string":""},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1194,"cache_read_input_tokens":45057,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1194},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d065b4bd-561d-4d97-a269-c4a0bb94c829","uuid":"724d65e1-3648-4d3f-81c0-690fc35c8c70"}
