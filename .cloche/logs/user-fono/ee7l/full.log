Status {\n    52→  string step_name = 1;\n    53→  string result = 2;\n    54→  string started_at = 3;\n    55→  string completed_at = 4;\n    56→}\n    57→\n    58→message StreamLogsRequest {\n    59→  string run_id = 1;\n    60→  string step_name = 2;\n    61→  string log_type = 3;\n    62→}\n    63→\n    64→message LogEntry {\n    65→  string type = 1;\n    66→  string step_name = 2;\n    67→  string result = 3;\n    68→  string message = 4;\n    69→  string timestamp = 5;\n    70→}\n    71→\n    72→message StopRunRequest {\n    73→  string run_id = 1;\n    74→}\n    75→\n    76→message StopRunResponse {}\n    77→\n    78→message ShutdownRequest {}\n    79→\n    80→message ShutdownResponse {}\n    81→\n    82→message DeleteContainerRequest {\n    83→  string id = 1;\n    84→}\n    85→\n    86→message DeleteContainerResponse {}\n    87→\n    88→message OrchestrateRequest {\n    89→  string project_dir = 1;\n    90→}\n    91→\n    92→message OrchestrateResponse {\n    93→  string run_id = 1;\n    94→}\n    95→\n    96→message ListRunsRequest {\n    97→  bool all = 1;\n    98→}\n    99→\n   100→message ListRunsResponse {\n   101→  repeated RunSummary runs = 1;\n   102→}\n   103→\n   104→message RunSummary {\n   105→  string run_id = 1;\n   106→  string workflow_name = 2;\n   107→  string state = 3;\n   108→  string started_at = 4;\n   109→  string error_message = 5;\n   110→  string container_id = 6;\n   111→  string title = 7;\n   112→  bool is_host = 8;\n   113→}\n   114→\n   115→message EnableLoopRequest {\n   116→  string project_dir = 1;\n   117→  int32 max_concurrent = 2;\n   118→}\n   119→\n   120→message EnableLoopResponse {}\n   121→\n   122→message DisableLoopRequest {\n   123→  string project_dir = 1;\n   124→}\n   125→\n   126→message DisableLoopResponse {}\n   127→"}]},"parent_tool_use_id":"toolu_01EmNnibDiBApwUA2G3spKT8","session_id":"d065b4bd-561d-4d97-a269-c4a0bb94c829","uuid":"5a6d66e4-59e8-44c2-bc03-014df5f4fc2c"}
