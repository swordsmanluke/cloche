trate(context.Background(), &pb.OrchestrateRequest{ProjectDir: dir})\n\trequire.NoError(t, err)\n\tassert.NotEmpty(t, resp.RunId, \"should return a run ID\")\n\n\t// Poll until the host workflow completes\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\trun, err := store.GetRun(context.Background(), resp.RunId)\n\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\trun, err := store.GetRun(context.Background(), resp.RunId)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\tassert.True(t, run.IsHost)\n}\n\nfunc TestServer_Orchestrate_MissingHostCloche(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\tsrv := server.NewClocheServer(store, nil)\n\n\t_, err = srv.Orchestrate(context.Background(), &pb.OrchestrateRequest{ProjectDir: dir})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"host.cloche not found\")\n}\n\nfunc TestServer_Orchestrate_EmptyProjectDir(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\n\t_, err = srv.Orchestrate(context.Background(), &pb.OrchestrateRequest{ProjectDir: \"\"})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"project_dir is required\")\n}\n\nfunc TestServer_StreamLogs_FullLog(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n","numLines":80,"startLine":1130,"totalLines":1262}}}
