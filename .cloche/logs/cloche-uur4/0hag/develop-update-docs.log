{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MKJbKBhBEMS76fFNobWvHR","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"net\"\n     7→\t\"net/http\"\n     8→\t\"os\"\n     9→\t\"os/signal\"\n    10→\t\"path/filepath\"\n    11→\t\"syscall\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    15→\t\"github.com/cloche-dev/cloche/internal/version\"\n    16→\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    20→\t\"github.com/cloche-dev/cloche/internal/config\"\n    21→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    22→\thostpkg \"github.com/cloche-dev/cloche/internal/host\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→\t\"google.golang.org/grpc\"\n    26→)\n    27→\n    28→func main() {\n    29→\tif len(os.Args) >= 2 && (os.Args[1] == \"-v\" || os.Args[1] == \"--version\") {\n    30→\t\tfmt.Printf(\"cloched %s\\n\", version.Version())\n    31→\t\treturn\n    32→\t}\n    33→\n    34→\t// Load global config file (~/.config/cloche/config)\n    35→\tglobalCfg, err := config.LoadGlobal()\n    36→\tif err != nil {\n    37→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n    38→\t\tdefaults := config.Config{}\n    39→\t\tglobalCfg = &defaults\n    40→\t}\n    41→\n    42→\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, \"cloche.db\")\n    43→\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, \"unix:///tmp/cloche.sock\")\n    44→\n    45→\tstore, err := sqlite.NewStore(dbPath)\n    46→\tif err != nil {\n    47→\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    48→\t\tos.Exit(1)\n    49→\t}\n    50→\tdefer store.Close()\n    51→\n    52→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    53→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    54→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    55→\t} else if n > 0 {\n    56→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    57→\t}\n    58→\n    59→\truntime, err := initRuntime(globalCfg)\n    60→\tif err != nil {\n    61→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    62→\t\tos.Exit(1)\n    63→\t}\n    64→\n    65→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    66→\n    67→\tbroadcaster := logstream.NewBroadcaster()\n    68→\n    69→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    70→\tsrv.SetLogStore(store)\n    71→\tsrv.SetLogBroadcaster(broadcaster)\n    72→\n    73→\t// Set up evolution trigger\n    74→\tevoTrigger := initEvolution(globalCfg, store, store)\n    75→\tif evoTrigger != nil {\n    76→\t\tsrv.SetEvolution(evoTrigger)\n    77→\t}\n    78→\n    79→\tgrpcServer := grpc.NewServer()\n    80→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    81→\n    82→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    83→\n    84→\tlis, err := listen(listenAddr)\n    85→\tif err != nil {\n    86→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    87→\t\tos.Exit(1)\n    88→\t}\n    89→\n    90→\tvar httpServer *http.Server\n    91→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n    92→\t\twebOpts := []web.HandlerOption{\n    93→\t\t\tweb.WithContainerLogger(runtime),\n    94→\t\t\tweb.WithLogStore(store),\n    95→\t\t\tweb.WithLogBroadcaster(broadcaster),\n    96→\t\t\tweb.WithTaskProvider(srv),\n    97→\t\t}\n    98→\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n    99→\t\tif err != nil {\n   100→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n   101→\t\t\tos.Exit(1)\n   102→\t\t}\n   103→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n   104→\t\tgo func() {\n   105→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   106→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   107→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   108→\t\t\t}\n   109→\t\t}()\n   110→\t}\n   111→\n   112→\t// Auto-execute main workflow for active projects\n   113→\tautoRunActiveProjects(store, srv)\n   114→\n   115→\tsigCh := make(chan os.Signal, 1)\n   116→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   117→\tgo func() {\n   118→\t\t<-sigCh\n   119→\t\tif httpServer != nil {\n   120→\t\t\thttpServer.Close()\n   121→\t\t}\n   122→\t\tgrpcServer.GracefulStop()\n   123→\t}()\n   124→\n   125→\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   126→\tif err := grpcServer.Serve(lis); err != nil {\n   127→\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   128→\t\tos.Exit(1)\n   129→\t}\n   130→}\n   131→\n   132→func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   133→\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   134→\n   135→\tswitch runtimeType {\n   136→\tcase \"local\":\n   137→\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   138→\t\tif agentPath == \"\" {\n   139→\t\t\t// Look for cloche-agent next to this binary\n   140→\t\t\texe, err := os.Executable()\n   141→\t\t\tif err == nil {\n   142→\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   143→\t\t\t} else {\n   144→\t\t\t\tagentPath = \"cloche-agent\"\n   145→\t\t\t}\n   146→\t\t}\n   147→\t\treturn local.NewRuntime(agentPath), nil\n   148→\tcase \"docker\":\n   149→\t\treturn docker.NewRuntime()\n   150→\tdefault:\n   151→\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   152→\t}\n   153→}\n   154→\n   155→func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   156→\t// Load config from working directory (daemon-level defaults)\n   157→\tcfg, err := config.Load(\".\")\n   158→\tif err != nil || !cfg.Evolution.Enabled {\n   159→\t\treturn nil\n   160→\t}\n   161→\n   162→\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   163→\tif llmCmd == \"\" {\n   164→\t\treturn nil\n   165→\t}\n   166→\n   167→\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   168→\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   169→\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   170→\t\t\t// Load per-project config for confidence threshold\n   171→\t\t\tprojCfg, err := config.Load(projectDir)\n   172→\t\t\tif err != nil {\n   173→\t\t\t\tprojCfg = cfg // fall back to daemon config\n   174→\t\t\t}\n   175→\n   176→\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   177→\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   178→\t\t\t\tProjectDir:    projectDir,\n   179→\t\t\t\tWorkflowName:  workflowName,\n   180→\t\t\t\tLLM:           llm,\n   181→\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   182→\t\t\t})\n   183→\n   184→\t\t\tctx := context.Background()\n   185→\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   186→\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   187→\t\t\t}\n   188→\t\t},\n   189→\t})\n   190→\n   191→\treturn trigger\n   192→}\n   193→\n   194→func listen(addr string) (net.Listener, error) {\n   195→\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   196→\t\tsockPath := addr[7:]\n   197→\t\tos.Remove(sockPath)\n   198→\t\treturn net.Listen(\"unix\", sockPath)\n   199→\t}\n   200→\treturn net.Listen(\"tcp\", addr)\n   201→}\n   202→\n   203→// autoRunActiveProjects scans known projects for active = true in their config,\n   204→// parses .cloche/host.cloche and executes the full host workflow step by step.\n   205→func autoRunActiveProjects(store ports.RunStore, srv *adaptgrpc.ClocheServer) {\n   206→\tctx := context.Background()\n   207→\tprojects, err := store.ListProjects(ctx)\n   208→\tif err != nil {\n   209→\t\tfmt.Fprintf(os.Stderr, \"startup: failed to list projects: %v\\n\", err)\n   210→\t\treturn\n   211→\t}\n   212→\n   213→\tfor _, projectDir := range projects {\n   214→\t\tcfg, err := config.Load(projectDir)\n   215→\t\tif err != nil || !cfg.Active {\n   216→\t\t\tcontinue\n   217→\t\t}\n   218→\n   219→\t\t// Verify host.cloche exists before launching\n   220→\t\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   221→\t\tif _, err := os.Stat(hostPath); err != nil {\n   222→\t\t\tfmt.Fprintf(os.Stderr, \"startup: skipping active project %s: %v\\n\", projectDir, err)\n   223→\t\t\tcontinue\n   224→\t\t}\n   225→\n   226→\t\tfmt.Fprintf(os.Stderr, \"startup: auto-running host workflow for active project %s\\n\", projectDir)\n   227→\t\tgo func(projDir string) {\n   228→\t\t\trunner := &hostpkg.Runner{\n   229→\t\t\t\tDispatcher: srv,\n   230→\t\t\t\tStore:      store,\n   231→\t\t\t}\n   232→\t\t\tresult, err := runner.Run(context.Background(), projDir)\n   233→\t\t\tif err != nil {\n   234→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow failed for %s: %v\\n\", projDir, err)\n   235→\t\t\t} else {\n   236→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow completed for %s: %s (run %s)\\n\", projDir, result.State, result.RunID)\n   237→\t\t\t}\n   238→\t\t}(projectDir)\n   239→\t}\n   240→}\n   241→\n   242→// envOrConfig returns the env var value if set, otherwise the config file\n   243→// value if non-empty, otherwise the fallback default.\n   244→func envOrConfig(envKey, configVal, fallback string) string {\n   245→\tif v := os.Getenv(envKey); v != \"\" {\n   246→\t\treturn v\n   247→\t}\n   248→\tif configVal != \"\" {\n   249→\t\treturn configVal\n   250→\t}\n   251→\treturn fallback\n   252→}\n   253→"}]},"parent_tool_use_id":"toolu_0118FTBggLp4JvT77dYBjSPm","session_id":"5888bf68-422b-4315-97ee-07c9cf3aacfd","uuid":"a46f9837-d80c-47d5-b215-d2442607b7a9"}
