10;\n    52→  bool is_host = 11;\n    53→}\n    54→\n    55→message StepExecutionStatus {\n    56→  string step_name = 1;\n    57→  string result = 2;\n    58→  string started_at = 3;\n    59→  string completed_at = 4;\n    60→}\n    61→\n    62→message StreamLogsRequest {\n    63→  string run_id = 1;\n    64→  string step_name = 2;\n    65→  string log_type = 3;\n    66→  bool follow = 4;  // When true, stream existing logs then continue tailing new lines (like tail -f).\n    67→                     // Passed via gRPC metadata header \"x-cloche-follow\" until proto is regenerated.\n    68→}\n    69→\n    70→message LogEntry {\n    71→  string type = 1;\n    72→  string step_name = 2;\n    73→  string result = 3;\n    74→  string message = 4;\n    75→  string timestamp = 5;\n    76→}\n    77→\n    78→message StopRunRequest {\n    79→  string run_id = 1;\n    80→}\n    81→\n    82→message StopRunResponse {}\n    83→\n    84→message ShutdownRequest {}\n    85→\n    86→message ShutdownResponse {}\n    87→\n    88→message DeleteContainerRequest {\n    89→  string id = 1;\n    90→}\n    91→\n    92→message DeleteContainerResponse {}\n    93→\n    94→message ListRunsRequest {\n    95→  bool all = 1;\n    96→  string project_dir = 2;\n    97→  string state = 3;\n    98→  int32 limit = 4;\n    99→  string task_id = 5;\n   100→}\n   101→\n   102→message ListRunsResponse {\n   103→  repeated RunSummary runs = 1;\n   104→}\n   105→\n   106→message RunSummary {\n   107→  string run_id = 1;\n   108→  string workflow_name = 2;\n   109→  string state = 3;\n   110→  string started_at = 4;\n   111→  string error_message = 5;\n   112→  string container_id = 6;\n   113→  string title = 7;\n   114→  bool is_host = 8;\n   115→  string project_dir = 9;\n   116→}\n   117→\n   118→message EnableLoopRequest {\n   119→  string project_dir = 1;\n   120→  int32 max_concurrent = 2;\n   121→}\n   122→\n   123→message EnableLoopResponse {}\n   124→\n   125→message DisableLoopRequest {\n   126→  string project_dir = 1;\n   127→}\n   128→\n   129→message DisableLoopResponse {}\n   130→\n   131→message GetProjectInfoRequest {\n   132→  string project_dir = 1;  // Resolve by absolute path (default: cwd)\n   133→  string name = 2;         // Resolve by project label (e.g. \"cloche\")\n   134→}\n   135→\n   136→message GetProjectInfoResponse {\n   137→  string project_dir = 1;\n   138→  string name = 2;\n   139→  bool active = 3;\n   140→  int32 concurrency = 4;\n   141→  double stagger_seconds = 5;\n   142→  double dedup_seconds = 6;\n   143→  bool evolution_enabled = 7;\n   144→  bool loop_running = 8;\n   145→  repeated RunSummary active_runs = 9;\n   146→  repeated string container_workflows = 10;\n   147→  repeated string host_workflows = 11;\n   148→}\n   149→\n   150→message GetVersionRequest {}\n   151→\n   152→message GetVersionResponse {\n   153→  string version = 1;\n   154→}\n   155→"}]},"parent_tool_use_id":"toolu_0118FTBggLp4JvT77dYBjSPm","session_id":"5888bf68-422b-4315-97ee-07c9cf3aacfd","uuid":"38f0ac36-722f-4466-8a7e-2526bc1a9d16"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018osFdbEBKFbNxFJmCtEHME","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"sort\"\n    13→\t\"strings\"\n    14→\t\"sync\"\n    15→\t\"time\"\n    16→\n    17→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    20→\t\"github.com/cloche-dev/cloche/internal/config\"\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    24→\t\"github.com/cloche-dev/cloche/internal/host\"\n    25→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    26→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    27→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    28→\t\"github.com/cloche-dev/cloche/internal/version\"\n    29→\trpcgrpc \"google.golang.org/grpc\"\n    30→\t\"google.golang.org/grpc/metadata\"\n    31→)\n    32→\n    33→type ClocheServer struct {\n    34→\tpb.UnimplementedClocheServiceServer\n    35→\tstore        ports.RunStore\n    36→\tcaptures     ports.CaptureStore\n    37→\tlogStore     ports.LogStore\n    38→\tcontainer    ports.ContainerRuntime\n    39→\tdefaultImage string\n    40→\tevolution    *evolution.Trigger\n    41→\tlogBroadcast *logstream.Broadcaster\n    42→\tshutdownFn   func()\n    43→\tmu           sync.Mutex\n    44→\trunIDs       map[string]string      // run_id -> container_id\n    45→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    46→}\n    47→\n    48→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    49→\treturn &ClocheServer{\n    50→\t\tstore:     store,\n    51→\t\tcontainer: container,\n    52→\t\trunIDs:    make(map[string]string),\n    53→\t\tloops:     make(map[string]*host.Loop),\n    54→\t}\n    55→}\n    56→\n    57→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    58→\treturn &ClocheServer{\n    59→\t\tstore:        store,\n    60→\t\tcaptures:     captures,\n    61→\t\tcontainer:    container,\n    62→\t\tdefaultImage: defaultImage,\n    63→\t\trunIDs:       make(map[string]string),\n    64→\t\tloops:        make(map[string]*host.Loop),\n    65→\t}\n    66→}\n    67→\n    68→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    69→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    70→\ts.logStore = ls\n    71→}\n    72→\n    73→\n    74→// SetEvolution attaches an evolution trigger to the server.\n    75→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    76→\ts.evolution = trigger\n    77→}\n    78→\n    79→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    80→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    81→\ts.logBroadcast = b\n    82→}\n    83→\n    84→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    85→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    86→\ts.shutdownFn = fn\n    87→}\n    88→\n    89→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    90→\tif s.container == nil {\n    91→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    92→\t}\n    93→\n    94→\t// Generate a unique run ID, retrying on collision\n    95→\tvar runID string\n    96→\tfor attempts := 0; attempts < 10; attempts++ {\n    97→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    98→\t\texisting, err := s.store.GetRun(ctx, runID)\n    99→\t\tif err != nil {\n   100→\t\t\tbreak // ID is free\n   101→\t\t}\n   102→\t\t// Reuse if completed more than 1 hour ago\n   103→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   104→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   105→\t\t\tbreak\n   106→\t\t}\n   107→\t}\n   108→\n   109→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   110→\tif req.Prompt != \"\" {\n   111→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   112→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   113→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   114→\t\t}\n   115→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   116→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   117→\t\t}\n   118→\t}\n   119→\trun := domain.NewRun(runID, req.WorkflowName)\n   120→\trun.ProjectDir = req.ProjectDir\n   121→\trun.Title = req.Title\n   122→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   123→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   124→\t}\n   125→\n   126→\t// Resolve image: request-level override, then server default\n   127→\timage := req.Image\n   128→\tif image == \"\" {\n   129→\t\timage = s.defaultImage\n   130→\t}\n   131→\n   132→\t// Launch container start + tracking in background so the RPC returns immediately.\n   133→\t// The run stays in \"pending\" state until the container is up.\n   134→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   135→\n   136→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   137→}\n   138→\n   139→// launchAndTrack starts the container and then tracks it to completion.\n   140→// It runs in a background goroutine with its own context, independent of the\n   141→// RPC context which may be cancelled after RunWorkflow returns.\n   142→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   143→\tctx := context.Background()\n   144→\n   145→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   146→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   147→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   148→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   149→\t\t\tif run != nil {\n   150→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   151→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   152→\t\t\t}\n   153→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   154→\t\t\t\treturn\n   155→\t\t}\n   156→\t}\n   157→\n   158→\tbaseSHA := gitHEAD(req.ProjectDir)\n   159→\n   160→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   161→\t\tImage:        image,\n   162→\t\tWorkflowName: req.WorkflowName,\n   163→\t\tProjectDir:   req.ProjectDir,\n   164→\t\tRunID:        runID,\n   165→\t\tNetworkAllow: []string{\"*\"},\n   166→\t})\n   167→\tif err != nil {\n   168→\t\trun, _ := s.store.GetRun(ctx, runID)\n   169→\t\tif run != nil {\n   170→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   171→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   172→\t\t}\n   173→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   174→\t\treturn\n   175→\t}\n   176→\n   177→\ts.mu.Lock()\n   178→\ts.runIDs[runID] = containerID\n   179→\ts.mu.Unlock()\n   180→\n   181→\trun, _ := s.store.GetRun(ctx, runID)\n   182→\tif run != nil {\n   183→\t\trun.Start()\n   184→\t\trun.ContainerID = containerID\n   185→\t\trun.BaseSHA = baseSHA\n   186→\t\t_ = s.store.UpdateRun(ctx, run)\n   187→\t}\n   188→\n   189→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   190→}\n   191→\n   192→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   193→\tctx := context.Background()\n   194→\n   195→\t// Attach to agent output\n   196→\treader, err := s.container.AttachOutput(ctx, containerID)\n   197→\tif err != nil {\n   198→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   199→\t\t\treturn\n   200→\t}\n   201→\n   202→\t// Parse JSON-lines status messages\n   203→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   204→\tscanner := bufio.NewScanner(reader)\n   205→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   206→\tfor scanner.Scan() {\n   207→\t\tvar msg protocol.StatusMessage\n   208→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   209→\t\t\tcontinue\n   210→\t\t}\n   211→\n   212→\t\t// Fast path: log messages don't need store interaction.\n   213→\t\tif msg.Type == protocol.MsgLog {\n   214→\t\t\tif s.logBroadcast != nil {\n   215→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   216→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   217→\t\t\t\t\tType:      \"llm\",\n   218→\t\t\t\t\tContent:   msg.Message,\n   219→\t\t\t\t\tStepName:  msg.StepName,\n   220→\t\t\t\t})\n   221→\t\t\t}\n   222→\t\t\tcontinue\n   223→\t\t}\n   224→\n   225→\t\trun, err := s.store.GetRun(ctx, runID)\n   226→\t\tif err != nil {\n   227→\t\t\tcontinue\n   228→\t\t}\n   229→\n   230→\t\tswitch msg.Type {\n   231→\t\tcase protocol.MsgStepStarted:\n   232→\t\t\trun.RecordStepStart(msg.StepName)\n   233→\t\t\tif s.captures != nil {\n   234→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   235→\t\t\t\t\tStepName:  msg.StepName,\n   236→\t\t\t\t\tStartedAt: msg.Timestamp,\n   237→\t\t\t\t})\n   238→\t\t\t}\n   239→\t\t\tif s.logBroadcast != nil {\n   240→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   241→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   242→\t\t\t\t\tType:      \"status\",\n   243→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   244→\t\t\t\t\tStepName:  msg.StepName,\n   245→\t\t\t\t})\n   246→\t\t\t}\n   247→\t\tcase protocol.MsgStepCompleted:\n   248→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   249→\t\t\tif s.captures != nil {\n   250→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   251→\t\t\t\t\tStepName:    msg.StepName,\n   252→\t\t\t\t\tResult:      msg.Result,\n   253→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   254→\t\t\t\t})\n   255→\t\t\t}\n   256→\t\t\tif s.logBroadcast != nil {\n   257→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   258→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   259→\t\t\t\t\tType:      \"status\",\n   260→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   261→\t\t\t\t\tStepName:  msg.StepName,\n   262→\t\t\t\t})\n   263→\t\t\t}\n   264→\t\tcase protocol.MsgRunTitle:\n   265→\t\t\tif run.Title == \"\" {\n   266→\t\t\t\trun.Title = msg.Message\n   267→\t\t\t}\n   268→\t\tcase protocol.MsgRunCompleted:\n   269→\t\t\treportedResult = msg.Result\n   270→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   271→\t\t}\n   272→\n   273→\t\t_ = s.store.UpdateRun(ctx, run)\n   274→\t}\n   275→\treader.Close()\n   276→\n   277→\t// Signal live-stream subscribers that this run is done.\n   278→\tif s.logBroadcast != nil {\n   279→\t\ts.logBroadcast.Finish(runID)\n   280→\t}\n   281→\n   282→\t// Wait for process exit\n   283→\texitCode, err := s.container.Wait(ctx, containerID)\n   284→\tif err != nil {\n   285→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   286→\t}\n   287→\n   288→\t// Extract step output files from container before it's removed\n   289→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   290→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   291→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   292→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   293→\t\t}\n   294→\t}\n   295→\n   296→\t// Capture full container stdout/stderr before the container is removed\n   297→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   298→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   299→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   300→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   301→\t\t}\n   302→\t}\n   303→\n   304→\t// Index extracted log files in the log store\n   305→\tif s.logStore != nil {\n   306→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   307→\t}\n   308→\n   309→\t// Extract results to git branch BEFORE finalizing state, so that\n   310→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   311→\t// before the run is marked complete.\n   312→\tresultLabel := reportedResult\n   313→\tif resultLabel == \"\" {\n   314→\t\tif exitCode == 0 {\n   315→\t\t\tresultLabel = \"succeeded\"\n   316→\t\t} else {\n   317→\t\t\tresultLabel = \"failed\"\n   318→\t\t}\n   319→\t}\n   320→\t{\n   321→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   322→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   323→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   324→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   325→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   326→\t\t\t} else {\n   327→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   328→\t\t\t}\n   329→\t\t} else {\n   330→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   331→\t\t}\n   332→\t}\n   333→\n   334→\t// Now finalize run state\n   335→\trun, err := s.store.GetRun(ctx, runID)\n   336→\tif err != nil {\n   337→\t\treturn\n   338→\t}\n   339→\tif run.State == domain.RunStateRunning {\n   340→\t\tif reportedResult == \"succeeded\" {\n   341→\t\t\trun.Complete(domain.RunStateSucceeded)\n   342→\t\t} else if reportedResult != \"\" {\n   343→\t\t\trun.Complete(domain.RunStateFailed)\n   344→\t\t} else if exitCode == 0 {\n   345→\t\t\trun.Complete(domain.RunStateSucceeded)\n   346→\t\t} else {\n   347→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   348→\t\t}\n   349→\t\t_ = s.store.UpdateRun(ctx, run)\n   350→\t}\n   351→\n   352→\t// Fire evolution trigger if configured\n   353→\tif s.evolution != nil {\n   354→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   355→\t}\n   356→\n   357→\t// Merge is handled as a workflow step in host.cloche, not here.\n   358→\n   359→\t// Container retention policy:\n   360→\t// - Failed runs: always keep the container for debugging\n   361→\t// - Successful runs + --keep-container: keep the container\n   362→\t// - Successful runs without --keep-container: remove the container\n   363→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   364→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   365→\n   366→\tif keepContainer || runFailed {\n   367→\t\treason := \"--keep-container\"\n   368→\t\tif runFailed {\n   369→\t\t\treason = \"run failed\"\n   370→\t\t}\n   371→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   372→\t\tif runFinal != nil {\n   373→\t\t\trunFinal.ContainerKept = true\n   374→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   375→\t\t}\n   376→\t} else {\n   377→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   378→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   379→\t\t} else {\n   380→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   381→\t\t}\n   382→\t}\n   383→\n   384→\t// Cleanup mapping\n   385→\ts.mu.Lock()\n   386→\tdelete(s.runIDs, runID)\n   387→\ts.mu.Unlock()\n   388→}\n   389→\n   390→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   391→\tfilter := domain.RunListFilter{\n   392→\t\tProjectDir: req.ProjectDir,\n   393→\t\tState:      domain.RunState(req.State),\n   394→\t\tTaskID:     req.TaskId,\n   395→\t\tLimit:      int(req.Limit),\n   396→\t}\n   397→\n   398→\t// When no project filter and not --all, default to last hour\n   399→\tif filter.ProjectDir == \"\" && !req.All {\n   400→\t\tfilter.Since = time.Now().Add(-1 * time.Hour)\n   401→\t}\n   402→\n   403→\truns, err := s.store.ListRunsFiltered(ctx, filter)\n   404→\tif err != nil {\n   405→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   406→\t}\n   407→\n   408→\tresp := &pb.ListRunsResponse{}\n   409→\tfor _, run := range runs {\n   410→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   411→\t\t\tRunId:        run.ID,\n   412→\t\t\tWorkflowName: run.WorkflowName,\n   413→\t\t\tState:        string(run.State),\n   414→\t\t\tStartedAt:    run.StartedAt.String(),\n   415→\t\t\tErrorMessage: run.ErrorMessage,\n   416→\t\t\tContainerId:  run.ContainerID,\n   417→\t\t\tTitle:        run.Title,\n   418→\t\t\tIsHost:       run.IsHost,\n   419→\t\t\tProjectDir:   run.ProjectDir,\n   420→\t\t})\n   421→\t}\n   422→\treturn resp, nil\n   423→}\n   424→\n   425→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   426→\trun, err := s.store.GetRun(ctx, req.RunId)\n   427→\tif err != nil {\n   428→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   429→\t}\n   430→\n   431→\tresp := &pb.GetStatusResponse{\n   432→\t\tRunId:        run.ID,\n   433→\t\tWorkflowName: run.WorkflowName,\n   434→\t\tState:        string(run.State),\n   435→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   436→\t\tErrorMessage: run.ErrorMessage,\n   437→\t\tContainerId:  run.ContainerID,\n   438→\t\tTitle:        run.Title,\n   439→\t\tIsHost:       run.IsHost,\n   440→\t}\n   441→\n   442→\t// Check container liveness\n   443→\tif run.ContainerID != \"\" && s.container != nil {\n   444→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   445→\t\t\tresp.ContainerAlive = cs.Running\n   446→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   447→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   448→\t\t\t}\n   449→\t\t}\n   450→\t}\n   451→\n   452→\t// Load step executions from captures store if available\n   453→\tif s.captures != nil {\n   454→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   455→\t\tif err == nil {\n   456→\t\t\tfor _, exec := range captures {\n   457→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   458→\t\t\t\t\tStepName:    exec.StepName,\n   459→\t\t\t\t\tResult:      exec.Result,\n   460→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   461→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   462→\t\t\t\t})\n   463→\t\t\t}\n   464→\t\t}\n   465→\t} else {\n   466→\t\tfor _, exec := range run.StepExecutions {\n   467→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   468→\t\t\t\tStepName:    exec.StepName,\n   469→\t\t\t\tResult:      exec.Result,\n   470→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   471→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   472→\t\t\t})\n   473→\t\t}\n   474→\t}\n   475→\n   476→\treturn resp, nil\n   477→}\n   478→\n   479→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   480→\tctx := stream.Context()\n   481→\n   482→\t// Check for follow mode via gRPC metadata.\n   483→\tfollow := followFromContext(ctx)\n   484→\n   485→\t// Verify run exists\n   486→\trun, err := s.store.GetRun(ctx, req.RunId)\n   487→\tif err != nil {\n   488→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   489→\t}\n   490→\n   491→\t// If step_name or log_type filter is set, serve content directly from the log index\n   492→\tif req.StepName != \"\" || req.LogType != \"\" {\n   493→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   494→\t}\n   495→\n   496→\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n   497→\n   498→\t// With -f on an active run: send existing logs then tail live output.\n   499→\tif follow && isActive && s.logBroadcast != nil {\n   500→\t\treturn s.streamFollowLogs(req.RunId, run, stream)\n   501→\t}\n   502→\n   503→\t// Without -f on an active run: snapshot existing logs and return.\n   504→\t// (Legacy callers that relied on implicit live streaming should use -f.)\n   505→\t// With -f on a completed run: same as without -f — no new lines will arrive.\n   506→\n   507→\t// Check for full.log first — if it exists, serve it as the unified log\n   508→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   509→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   510→\t\tif err := stream.Send(&pb.LogEntry{\n   511→\t\t\tType:    \"full_log\",\n   512→\t\t\tMessage: string(data),\n   513→\t\t}); err != nil {\n   514→\t\t\treturn err\n   515→\t\t}\n   516→\t\tif !isActive {\n   517→\t\t\tif err := stream.Send(&pb.LogEntry{\n   518→\t\t\t\tType:      \"run_completed\",\n   519→\t\t\t\tResult:    string(run.State),\n   520→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   521→\t\t\t\tMessage:   run.ErrorMessage,\n   522→\t\t\t}); err != nil {\n   523→\t\t\t\treturn err\n   524→\t\t\t}\n   525→\t\t}\n   526→\t\treturn nil\n   527→\t}\n   528→\n   529→\tif s.captures == nil {\n   530→\t\treturn fmt.Errorf(\"captures store not configured\")\n   531→\t}\n   532→\n   533→\t// Fall back to capture-based streaming\n   534→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   535→\tif err != nil {\n   536→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   537→\t}\n   538→\n   539→\tfor _, exec := range captures {\n   540→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   541→\t\t// and one for step_completed (has Result).\n   542→\t\tif exec.Result == \"\" {\n   543→\t\t\tentry := &pb.LogEntry{\n   544→\t\t\t\tType:      \"step_started\",\n   545→\t\t\t\tStepName:  exec.StepName,\n   546→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   547→\t\t\t}\n   548→\t\t\tif err := stream.Send(entry); err != nil {\n   549→\t\t\t\treturn err\n   550→\t\t\t}\n   551→\t\t} else {\n   552→\t\t\t// Read step output from per-step output file.\n   553→\t\t\t// Container runs write .log, host runs write .out — try both.\n   554→\t\t\tvar output string\n   555→\t\t\tfor _, ext := range []string{\".log\", \".out\"} {\n   556→\t\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+ext)\n   557→\t\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   558→\t\t\t\t\toutput = string(data)\n   559→\t\t\t\t\tbreak\n   560→\t\t\t\t}\n   561→\t\t\t}\n   562→\t\t\tentry := &pb.LogEntry{\n   563→\t\t\t\tType:      \"step_completed\",\n   564→\t\t\t\tStepName:  exec.StepName,\n   565→\t\t\t\tResult:    exec.Result,\n   566→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   567→\t\t\t\tMessage:   output,\n   568→\t\t\t}\n   569→\t\t\tif err := stream.Send(entry); err != nil {\n   570→\t\t\t\treturn err\n   571→\t\t\t}\n   572→\t\t}\n   573→\t}\n   574→\n   575→\t// Send run completion entry\n   576→\tif !isActive {\n   577→\t\tif err := stream.Send(&pb.LogEntry{\n   578→\t\t\tType:      \"run_completed\",\n   579→\t\t\tResult:    string(run.State),\n   580→\t\t\tTimestamp: run.CompletedAt.String(),\n   581→\t\t\tMessage:   run.ErrorMessage,\n   582→\t\t}); err != nil {\n   583→\t\t\treturn err\n   584→\t\t}\n   585→\t}\n   586→\n   587→\treturn nil\n   588→}\n   589→\n   590→// followFromContext checks for the follow flag in gRPC metadata.\n   591→func followFromContext(ctx context.Context) bool {\n   592→\tmd, ok := metadata.FromIncomingContext(ctx)\n   593→\tif !ok {\n   594→\t\treturn false\n   595→\t}\n   596→\tvals := md.Get(\"x-cloche-follow\")\n   597→\treturn len(vals) > 0 && vals[0] == \"true\"\n   598→}\n   599→\n   600→// streamFollowLogs sends existing log content then tails live output from the\n   601→// broadcaster. It combines snapshot + live streaming (like tail -f).\n   602→func (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   603→\t// Subscribe first so we don't miss lines written between read and subscribe.\n   604→\tsub := s.logBroadcast.Subscribe(runID)\n   605→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   606→\n   607→\t// Send existing full.log content if available.\n   608→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n   609→\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n   610→\t\tif err := stream.Send(&pb.LogEntry{\n   611→\t\t\tType:    \"full_log\",\n   612→\t\t\tMessage: string(data),\n   613→\t\t}); err != nil {\n   614→\t\t\treturn err\n   615→\t\t}\n   616→\t}\n   617→\n   618→\t// Now tail live output from the broadcaster.\n   619→\tctx := stream.Context()\n   620→\tfor {\n   621→\t\tselect {\n   622→\t\tcase <-ctx.Done():\n   623→\t\t\treturn ctx.Err()\n   624→\t\tcase line, ok := <-sub.C:\n   625→\t\t\tif !ok {\n   626→\t\t\t\t// Run completed — send terminal entry.\n   627→\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n   628→\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n   629→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   630→\t\t\t\t\t\tType:      \"run_completed\",\n   631→\t\t\t\t\t\tResult:    string(r.State),\n   632→\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n   633→\t\t\t\t\t\tMessage:   r.ErrorMessage,\n   634→\t\t\t\t\t})\n   635→\t\t\t\t}\n   636→\t\t\t\treturn nil\n   637→\t\t\t}\n   638→\t\t\tif err := stream.Send(&pb.LogEntry{\n   639→\t\t\t\tType:      \"log\",\n   640→\t\t\t\tStepName:  line.StepName,\n   641→\t\t\t\tMessage:   line.Content,\n   642→\t\t\t\tTimestamp: line.Timestamp,\n   643→\t\t\t}); err != nil {\n   644→\t\t\t\treturn err\n   645→\t\t\t}\n   646→\t\t}\n   647→\t}\n   648→}\n   649→\n   650→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   651→// It uses the log index when available, falling back to file path conventions.\n   652→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   653→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   654→\n   655→\t// Try log index first\n   656→\tif s.logStore != nil {\n   657→\t\tvar logFiles []*ports.LogFileEntry\n   658→\t\tvar err error\n   659→\n   660→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   661→\t\t\t// Filter by both step and type\n   662→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   663→\t\t\tif err == nil {\n   664→\t\t\t\tfiltered := logFiles[:0]\n   665→\t\t\t\tfor _, lf := range logFiles {\n   666→\t\t\t\t\tif lf.FileType == req.LogType {\n   667→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   668→\t\t\t\t\t}\n   669→\t\t\t\t}\n   670→\t\t\t\tlogFiles = filtered\n   671→\t\t\t}\n   672→\t\t} else if req.StepName != \"\" {\n   673→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   674→\t\t} else {\n   675→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   676→\t\t}\n   677→\n   678→\t\tif err == nil && len(logFiles) > 0 {\n   679→\t\t\tfor _, lf := range logFiles {\n   680→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   681→\t\t\t\tif readErr != nil {\n   682→\t\t\t\t\tcontinue\n   683→\t\t\t\t}\n   684→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   685→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   686→\t\t\t\t\tStepName: lf.StepName,\n   687→\t\t\t\t\tMessage:  string(data),\n   688→\t\t\t\t}); err != nil {\n   689→\t\t\t\t\treturn err\n   690→\t\t\t\t}\n   691→\t\t\t}\n   692→\t\t\treturn nil\n   693→\t\t}\n   694→\t}\n   695→\n   696→\t// Fall back to file path conventions\n   697→\tif req.StepName != \"\" {\n   698→\t\tvar logPath string\n   699→\t\tswitch req.LogType {\n   700→\t\tcase \"llm\":\n   701→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   702→\t\tdefault:\n   703→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   704→\t\t}\n   705→\n   706→\t\tdata, err := os.ReadFile(logPath)\n   707→\t\tif err != nil {\n   708→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   709→\t\t}\n   710→\t\treturn stream.Send(&pb.LogEntry{\n   711→\t\t\tType:     \"step_log\",\n   712→\t\t\tStepName: req.StepName,\n   713→\t\t\tMessage:  string(data),\n   714→\t\t})\n   715→\t}\n   716→\n   717→\treturn fmt.Errorf(\"no log files found matching filter\")\n   718→}\n   719→\n   720→// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n   721→// time for an active run. The stream closes when the run completes or the\n   722→// client disconnects.\n   723→func (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   724→\tsub := s.logBroadcast.Subscribe(runID)\n   725→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   726→\n   727→\tctx := stream.Context()\n   728→\tfor {\n   729→\t\tselect {\n   730→\t\tcase <-ctx.Done():\n   731→\t\t\treturn ctx.Err()\n   732→\t\tcase line, ok := <-sub.C:\n   733→\t\t\tif !ok {\n   734→\t\t\t\t// Run completed — send terminal entry.\n   735→\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   736→\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   737→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   738→\t\t\t\t\t\tType:      \"run_completed\",\n   739→\t\t\t\t\t\tResult:    string(run.State),\n   740→\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   741→\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   742→\t\t\t\t\t})\n   743→\t\t\t\t}\n   744→\t\t\t\treturn nil\n   745→\t\t\t}\n   746→\t\t\tif err := stream.Send(&pb.LogEntry{\n   747→\t\t\t\tType:      \"log\",\n   748→\t\t\t\tStepName:  line.StepName,\n   749→\t\t\t\tMessage:   line.Content,\n   750→\t\t\t\tTimestamp: line.Timestamp,\n   751→\t\t\t}); err != nil {\n   752→\t\t\t\treturn err\n   753→\t\t\t}\n   754→\t\t}\n   755→\t}\n   756→}\n   757→\n   758→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   759→\ts.mu.Lock()\n   760→\tcontainerID, ok := s.runIDs[req.RunId]\n   761→\ts.mu.Unlock()\n   762→\n   763→\tif !ok {\n   764→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   765→\t}\n   766→\n   767→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   768→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   769→\t}\n   770→\n   771→\t// Mark as cancelled in store\n   772→\trun, err := s.store.GetRun(ctx, req.RunId)\n   773→\tif err == nil {\n   774→\t\trun.Complete(domain.RunStateCancelled)\n   775→\t\t_ = s.store.UpdateRun(ctx, run)\n   776→\t}\n   777→\n   778→\treturn &pb.StopRunResponse{}, nil\n   779→}\n   780→\n   781→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   782→\tif s.container == nil {\n   783→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   784→\t}\n   785→\n   786→\tid := req.Id\n   787→\tif id == \"\" {\n   788→\t\treturn nil, fmt.Errorf(\"id is required\")\n   789→\t}\n   790→\n   791→\t// Try to resolve as a run ID first\n   792→\tcontainerID := id\n   793→\trun, err := s.store.GetRun(ctx, id)\n   794→\tif err == nil {\n   795→\t\t// It's a run ID — use the container ID from the run record\n   796→\t\tif run.ContainerID == \"\" {\n   797→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   798→\t\t}\n   799→\t\tcontainerID = run.ContainerID\n   800→\t}\n   801→\n   802→\t// Remove the container\n   803→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   804→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   805→\t}\n   806→\n   807→\t// If we resolved a run, clear the container_kept flag\n   808→\tif run != nil {\n   809→\t\trun.ContainerKept = false\n   810→\t\t_ = s.store.UpdateRun(ctx, run)\n   811→\t}\n   812→\n   813→\treturn &pb.DeleteContainerResponse{}, nil\n   814→}\n   815→\n   816→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   817→\tprojectDir := req.ProjectDir\n   818→\tif projectDir == \"\" {\n   819→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   820→\t}\n   821→\n   822→\t// Verify host.cloche exists\n   823→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   824→\tif _, err := os.Stat(hostPath); err != nil {\n   825→\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n   826→\t}\n   827→\n   828→\t// Load project config for defaults.\n   829→\tprojCfg, _ := config.Load(projectDir)\n   830→\n   831→\tmaxConc := int(req.MaxConcurrent)\n   832→\tif maxConc <= 0 {\n   833→\t\tmaxConc = projCfg.Orchestration.Concurrency\n   834→\t}\n   835→\tif maxConc <= 0 {\n   836→\t\tmaxConc = 1\n   837→\t}\n   838→\n   839→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   840→\n   841→\t// Compute dedup timeout from config (default 5 minutes).\n   842→\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n   843→\n   844→\tloopCfg := host.LoopConfig{\n   845→\t\tProjectDir:    projectDir,\n   846→\t\tMaxConcurrent: maxConc,\n   847→\t\tStaggerDelay:  stagger,\n   848→\t\tDedupTimeout:  dedupTimeout,\n   849→\t}\n   850→\n   851→\ts.mu.Lock()\n   852→\tdefer s.mu.Unlock()\n   853→\n   854→\t// Stop existing loop if running.\n   855→\tif existing, ok := s.loops[projectDir]; ok {\n   856→\t\texisting.Stop()\n   857→\t}\n   858→\n   859→\t// Check if host.cloche defines a list-tasks workflow for three-phase mode.\n   860→\tvar loop *host.Loop\n   861→\tif s.hasWorkflow(hostPath, \"list-tasks\") {\n   862→\t\tloop = s.createPhaseLoop(loopCfg, projectDir, hostPath, dedupTimeout)\n   863→\t} else {\n   864→\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n   865→\t}\n   866→\n   867→\ts.loops[projectDir] = loop\n   868→\tloop.Start()\n   869→\n   870→\treturn &pb.EnableLoopResponse{}, nil\n   871→}\n   872→\n   873→// hasWorkflow checks if host.cloche contains a workflow with the given name.\n   874→func (s *ClocheServer) hasWorkflow(hostPath, workflowName string) bool {\n   875→\tdata, err := os.ReadFile(hostPath)\n   876→\tif err != nil {\n   877→\t\treturn false\n   878→\t}\n   879→\treturn strings.Contains(string(data), fmt.Sprintf(\"workflow %q\", workflowName))\n   880→}\n   881→\n   882→// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n   883→// main, and finalize workflows from host.cloche.\n   884→func (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir, hostPath string, dedupTimeout time.Duration) *host.Loop {\n   885→\t// Phase 1: list-tasks function\n   886→\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n   887→\t\trunner := &host.Runner{\n   888→\t\t\tDispatcher: s,\n   889→\t\t\tStore:      s.store,\n   890→\t\t}\n   891→\t\ttasks, _, err := host.RunListTasksWorkflow(ctx, runner, projDir)\n   892→\t\treturn tasks, err\n   893→\t}\n   894→\n   895→\t// Phase 2: main function\n   896→\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   897→\t\trunner := &host.Runner{\n   898→\t\t\tDispatcher:   s,\n   899→\t\t\tStore:        s.store,\n   900→\t\t\tCaptures:     s.captures,\n   901→\t\t\tLogBroadcast: s.logBroadcast,\n   902→\t\t\tTaskID:       taskID,\n   903→\t\t}\n   904→\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n   905→\t}\n   906→\n   907→\t// Phase 3: finalize function (optional — only if host.cloche has it)\n   908→\tvar finalizeFn host.FinalizeFunc\n   909→\tif s.hasWorkflow(hostPath, \"finalize\") {\n   910→\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n   911→\t\t\tmainRunID := \"\"\n   912→\t\t\tmainOutcome := \"failed\"\n   913→\t\t\tif mainResult != nil {\n   914→\t\t\t\tmainRunID = mainResult.RunID\n   915→\t\t\t\tmainOutcome = string(mainResult.State)\n   916→\t\t\t}\n   917→\t\t\trunner := &host.Runner{\n   918→\t\t\t\tDispatcher:   s,\n   919→\t\t\t\tStore:        s.store,\n   920→\t\t\t\tCaptures:     s.captures,\n   921→\t\t\t\tLogBroadcast: s.logBroadcast,\n   922→\t\t\t\tTaskID:       taskID,\n   923→\t\t\t\tExtraEnv: []string{\n   924→\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n   925→\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n   926→\t\t\t\t},\n   927→\t\t\t}\n   928→\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n   929→\t\t}\n   930→\t}\n   931→\n   932→\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n   933→\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n   934→}\n   935→\n   936→// createLegacyLoop creates a legacy single-function orchestration loop.\n   937→func (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n   938→\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   939→\t\trunner := &host.Runner{\n   940→\t\t\tDispatcher:   s,\n   941→\t\t\tStore:        s.store,\n   942→\t\t\tCaptures:     s.captures,\n   943→\t\t\tLogBroadcast: s.logBroadcast,\n   944→\t\t\tTaskID:       taskID,\n   945→\t\t}\n   946→\t\treturn runner.Run(ctx, projDir)\n   947→\t}\n   948→\n   949→\tloop := host.NewLoop(loopCfg, s.store, runFn)\n   950→\n   951→\t// Configure daemon-managed task assignment if a list-tasks command is set.\n   952→\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n   953→\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n   954→\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n   955→\t}\n   956→\n   957→\treturn loop\n   958→}\n   959→\n   960→// GetLoopTasks returns the current task pipeline state for a project's\n   961→// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n   962→// loop is active for the project.\n   963→func (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n   964→\ts.mu.Lock()\n   965→\tloop, ok := s.loops[projectDir]\n   966→\ts.mu.Unlock()\n   967→\tif !ok {\n   968→\t\treturn nil\n   969→\t}\n   970→\tsnapshot := loop.GetTaskSnapshot()\n   971→\tentries := make([]web.TaskEntry, len(snapshot))\n   972→\tfor i, e := range snapshot {\n   973→\t\tentry := web.TaskEntry{\n   974→\t\t\tID:          e.Task.ID,\n   975→\t\t\tStatus:      e.Task.Status,\n   976→\t\t\tTitle:       e.Task.Title,\n   977→\t\t\tDescription: e.Task.Description,\n   978→\t\t\tMetadata:    e.Task.Metadata,\n   979→\t\t\tAssigned:    e.Assigned,\n   980→\t\t\tRunID:       e.RunID,\n   981→\t\t}\n   982→\t\tif !e.AssignedAt.IsZero() {\n   983→\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n   984→\t\t}\n   985→\t\tentries[i] = entry\n   986→\t}\n   987→\treturn entries\n   988→}\n   989→\n   990→func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n   991→\tprojectDir := req.ProjectDir\n   992→\tif projectDir == \"\" {\n   993→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   994→\t}\n   995→\n   996→\ts.mu.Lock()\n   997→\tdefer s.mu.Unlock()\n   998→\n   999→\tif loop, ok := s.loops[projectDir]; ok {\n  1000→\t\tloop.Stop()\n  1001→\t\tdelete(s.loops, projectDir)\n  1002→\t}\n  1003→\n  1004→\treturn &pb.DisableLoopResponse{}, nil\n  1005→}\n  1006→\n  1007→func (s *ClocheServer) GetProjectInfo(ctx context.Context, req *pb.GetProjectInfoRequest) (*pb.GetProjectInfoResponse, error) {\n  1008→\tprojectDir := req.ProjectDir\n  1009→\n  1010→\t// Resolve by name if provided.\n  1011→\tif req.Name != \"\" && projectDir == \"\" {\n  1012→\t\tprojects, err := s.store.ListProjects(ctx)\n  1013→\t\tif err != nil {\n  1014→\t\t\treturn nil, fmt.Errorf(\"listing projects: %w\", err)\n  1015→\t\t}\n  1016→\t\tlabels := projectLabels(projects)\n  1017→\t\tfound := false\n  1018→\t\tfor dir, label := range labels {\n  1019→\t\t\tif label == req.Name {\n  1020→\t\t\t\tprojectDir = dir\n  1021→\t\t\t\tfound = true\n  1022→\t\t\t\tbreak\n  1023→\t\t\t}\n  1024→\t\t}\n  1025→\t\tif !found {\n  1026→\t\t\treturn nil, fmt.Errorf(\"project %q not found\", req.Name)\n  1027→\t\t}\n  1028→\t}\n  1029→\n  1030→\tif projectDir == \"\" {\n  1031→\t\treturn nil, fmt.Errorf(\"project_dir or name is required\")\n  1032→\t}\n  1033→\n  1034→\t// Derive project label.\n  1035→\tprojects, _ := s.store.ListProjects(ctx)\n  1036→\tlabels := projectLabels(projects)\n  1037→\tlabel := labels[projectDir]\n  1038→\tif label == \"\" {\n  1039→\t\tlabel = filepath.Base(projectDir)\n  1040→\t}\n  1041→\n  1042→\t// Load config.\n  1043→\tcfg, _ := config.Load(projectDir)\n  1044→\n  1045→\t// Check loop state.\n  1046→\ts.mu.Lock()\n  1047→\tloop, loopExists := s.loops[projectDir]\n  1048→\ts.mu.Unlock()\n  1049→\tloopRunning := loopExists && loop != nil && loop.Running()\n  1050→\n  1051→\t// Get active runs.\n  1052→\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n  1053→\tvar activeRuns []*pb.RunSummary\n  1054→\tfor _, run := range allRuns {\n  1055→\t\tif run.State == domain.RunStatePending || run.State == domain.RunStateRunning {\n  1056→\t\t\tactiveRuns = append(activeRuns, &pb.RunSummary{\n  1057→\t\t\t\tRunId:        run.ID,\n  1058→\t\t\t\tWorkflowName: run.WorkflowName,\n  1059→\t\t\t\tState:        string(run.State),\n  1060→\t\t\t\tStartedAt:    run.StartedAt.String(),\n  1061→\t\t\t\tTitle:        run.Title,\n  1062→\t\t\t\tIsHost:       run.IsHost,\n  1063→\t\t\t\tContainerId:  run.ContainerID,\n  1064→\t\t\t})\n  1065→\t\t}\n  1066→\t}\n  1067→\n  1068→\t// Discover workflows.\n  1069→\tvar containerWorkflows, hostWorkflows []string\n  1070→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n  1071→\tentries, _ := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n  1072→\tfor _, path := range entries {\n  1073→\t\tbase := filepath.Base(path)\n  1074→\t\tdata, err := os.ReadFile(path)\n  1075→\t\tif err != nil {\n  1076→\t\t\tcontinue\n  1077→\t\t}\n  1078→\t\tif base == \"host.cloche\" {\n  1079→\t\t\twfs, err := dsl.ParseAllForHost(string(data))\n  1080→\t\t\tif err != nil {\n  1081→\t\t\t\tcontinue\n  1082→\t\t\t}\n  1083→\t\t\tfor name := range wfs {\n  1084→\t\t\t\thostWorkflows = append(hostWorkflows, name)\n  1085→\t\t\t}\n  1086→\t\t} else {\n  1087→\t\t\twf, err := dsl.ParseForContainer(string(data))\n  1088→\t\t\tif err != nil {\n  1089→\t\t\t\tcontinue\n  1090→\t\t\t}\n  1091→\t\t\tcontainerWorkflows = append(containerWorkflows, wf.Name)\n  1092→\t\t}\n  1093→\t}\n  1094→\n  1095→\tsort.Strings(containerWorkflows)\n  1096→\tsort.Strings(hostWorkflows)\n  1097→\n  1098→\treturn &pb.GetProjectInfoResponse{\n  1099→\t\tProjectDir:         projectDir,\n  1100→\t\tName:               label,\n  1101→\t\tActive:             cfg.Active,\n  1102→\t\tConcurrency:        int32(cfg.Orchestration.Concurrency),\n  1103→\t\tStaggerSeconds:     cfg.Orchestration.StaggerSeconds,\n  1104→\t\tDedupSeconds:       cfg.Orchestration.DedupSeconds,\n  1105→\t\tEvolutionEnabled:   cfg.Evolution.Enabled,\n  1106→\t\tLoopRunning:        loopRunning,\n  1107→\t\tActiveRuns:         activeRuns,\n  1108→\t\tContainerWorkflows: containerWorkflows,\n  1109→\t\tHostWorkflows:      hostWorkflows,\n  1110→\t}, nil\n  1111→}\n  1112→\n  1113→// projectLabels maps each project directory to a short display label.\n  1114→// Uses basename unless there are conflicts, in which case parent/basename is used.\n  1115→func projectLabels(dirs []string) map[string]string {\n  1116→\tlabels := make(map[string]string, len(dirs))\n  1117→\tbyBase := map[string][]string{}\n  1118→\tfor _, d := range dirs {\n  1119→\t\tbase := filepath.Base(d)\n  1120→\t\tbyBase[base] = append(byBase[base], d)\n  1121→\t}\n  1122→\tfor base, paths := range byBase {\n  1123→\t\tif len(paths) == 1 {\n  1124→\t\t\tlabels[paths[0]] = base\n  1125→\t\t} else {\n  1126→\t\t\tfor _, p := range paths {\n  1127→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1128→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1129→\t\t\t}\n  1130→\t\t}\n  1131→\t}\n  1132→\treturn labels\n  1133→}\n  1134→\n  1135→func (s *ClocheServer) GetVersion(ctx context.Context, req *pb.GetVersionRequest) (*pb.GetVersionResponse, error) {\n  1136→\treturn &pb.GetVersionResponse{Version: version.Version()}, nil\n  1137→}\n  1138→\n  1139→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n  1140→\t// Stop all orchestration loops.\n  1141→\ts.mu.Lock()\n  1142→\tfor _, loop := range s.loops {\n  1143→\t\tloop.Stop()\n  1144→\t}\n  1145→\ts.loops = make(map[string]*host.Loop)\n  1146→\ts.mu.Unlock()\n  1147→\n  1148→\tif s.shutdownFn == nil {\n  1149→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n  1150→\t}\n  1151→\tgo s.shutdownFn()\n  1152→\treturn &pb.ShutdownResponse{}, nil\n  1153→}\n  1154→\n  1155→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n  1156→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n  1157→\tentries, err := os.ReadDir(outputDir)\n  1158→\tif err != nil {\n  1159→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n  1160→\t\treturn\n  1161→\t}\n  1162→\n  1163→\tnow := time.Now()\n  1164→\tfor _, entry := range entries {\n  1165→\t\tif entry.IsDir() {\n  1166→\t\t\tcontinue\n  1167→\t\t}\n  1168→\t\tname := entry.Name()\n  1169→\t\tif !strings.HasSuffix(name, \".log\") {\n  1170→\t\t\tcontinue\n  1171→\t\t}\n  1172→\n  1173→\t\tvar fileType, stepName string\n  1174→\t\tbase := strings.TrimSuffix(name, \".log\")\n  1175→\n  1176→\t\tswitch {\n  1177→\t\tcase name == \"full.log\":\n  1178→\t\t\tfileType = \"full\"\n  1179→\t\tcase name == \"container.log\":\n  1180→\t\t\t// container.log is internal, not indexed as a user-facing log type\n  1181→\t\t\tcontinue\n  1182→\t\tcase strings.HasPrefix(name, \"llm-\"):\n  1183→\t\t\tfileType = \"llm\"\n  1184→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n  1185→\t\tdefault:\n  1186→\t\t\tfileType = \"script\"\n  1187→\t\t\tstepName = base\n  1188→\t\t}\n  1189→\n  1190→\t\tinfo, _ := entry.Info()\n  1191→\t\tvar fileSize int64\n  1192→\t\tif info != nil {\n  1193→\t\t\tfileSize = info.Size()\n  1194→\t\t}\n  1195→\n  1196→\t\tlogEntry := &ports.LogFileEntry{\n  1197→\t\t\tRunID:     runID,\n  1198→\t\t\tStepName:  stepName,\n  1199→\t\t\tFileType:  fileType,\n  1200→\t\t\tFilePath:  filepath.Join(outputDir, name),\n  1201→\t\t\tFileSize:  fileSize,\n  1202→\t\t\tCreatedAt: now,\n  1203→\t\t}\n  1204→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n  1205→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n  1206→\t\t}\n  1207→\t}\n  1208→}\n  1209→\n  1210→func gitHEAD(dir string) string {\n  1211→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n  1212→\tcmd.Dir = dir\n  1213→\tout, err := cmd.Output()\n  1214→\tif err != nil {\n  1215→\t\treturn \"\"\n  1216→\t}\n  1217→\treturn strings.TrimSpace(string(out))\n  1218→}\n  1219→"}]},"parent_tool_use_id":"toolu_0118FTBggLp4JvT77dYBjSPm","session_id":"5888bf68-422b-4315-97ee-07c9cf3aacfd","uuid":"31c92891-c018-4e5d-88b0-63f77e392a6a"}
