NULL,\n    59→\t\t\tstep_name TEXT NOT NULL,\n    60→\t\t\tresult TEXT,\n    61→\t\t\tstarted_at TEXT NOT NULL,\n    62→\t\t\tcompleted_at TEXT,\n    63→\t\t\tlogs TEXT,\n    64→\t\t\tgit_ref TEXT,\n    65→\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    66→\t\t);\n    67→\t`)\n    68→\tif err != nil {\n    69→\t\treturn err\n    70→\t}\n    71→\n    72→\t// Evolution schema additions (idempotent)\n    73→\talterStmts := []string{\n    74→\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n    75→\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n    76→\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n    77→\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n    78→\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n    79→\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n    80→\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n    81→\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n    82→\t\t`ALTER TABLE runs ADD COLUMN title TEXT NOT NULL DEFAULT ''`,\n    83→\t\t`ALTER TABLE runs ADD COLUMN is_host INTEGER NOT NULL DEFAULT 0`,\n    84→\t\t`ALTER TABLE runs ADD COLUMN parent_run_id TEXT NOT NULL DEFAULT ''`,\n    85→\t\t`ALTER TABLE runs ADD COLUMN task_id TEXT NOT NULL DEFAULT ''`,\n    86→\t}\n    87→\tfor _, stmt := range alterStmts {\n    88→\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n    89→\t}\n    90→\n    91→\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n    92→\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    93→\t\trun_id TEXT NOT NULL,\n    94→\t\tstep_name TEXT,\n    95→\t\tfile_type TEXT NOT NULL,\n    96→\t\tfile_path TEXT NOT NULL,\n    97→\t\tfile_size INTEGER,\n    98→\t\tcreated_at TEXT NOT NULL,\n    99→\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n   100→\t)`)\n   101→\tif errLog != nil {\n   102→\t\treturn errLog\n   103→\t}\n   104→\n   105→\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n   106→\t\trun_id TEXT PRIMARY KEY,\n   107→\t\tbranch TEXT NOT NULL,\n   108→\t\tproject TEXT NOT NULL,\n   109→\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n   110→\t\tenqueued_at TEXT NOT NULL,\n   111→\t\tcompleted_at TEXT\n   112→\t)`)\n   113→\tif errMQ != nil {\n   114→\t\treturn errMQ\n   115→\t}\n   116→\n   117→\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n   118→\t\tid TEXT PRIMARY KEY,\n   119→\t\tproject_dir TEXT NOT NULL,\n   120→\t\tworkflow_name TEXT NOT NULL,\n   121→\t\ttrigger_run_id TEXT NOT NULL,\n   122→\t\tcreated_at TEXT NOT NULL,\n   123→\t\tclassification TEXT,\n   124→\t\tchanges_json TEXT NOT NULL,\n   125→\t\tknowledge_delta TEXT\n   126→\t)`)\n   127→\tif err2 != nil {\n   128→\t\treturn err2\n   129→\t}\n   130→\n   131→\treturn nil\n   132→}\n   133→\n   134→func (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n   135→\t_, err := s.db.ExecContext(ctx,\n   136→\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept, title, is_host, parent_run_id, task_id)\n   137→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   138→\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n   139→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, truncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID,\n   140→\t)\n   141→\treturn err\n   142→}\n   143→\n   144→// runSelectCols is the standard column list for scanning a Run row.\n   145→const runSelectCols = `id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,''), COALESCE(is_host,0), COALESCE(parent_run_id,''), COALESCE(task_id,'')`\n   146→\n   147→// scanRun scans a single row into a *domain.Run.\n   148→func scanRun(scanner interface{ Scan(...any) error }) (*domain.Run, error) {\n   149→\trun := &domain.Run{}\n   150→\tvar activeSteps, startedAt, completedAt string"}]},"parent_tool_use_id":"toolu_01F81cnT9Hi7BVCZkVgug3tU","session_id":"8a8a233a-9bc4-4d5b-81f2-86c5b6995110","uuid":"df91c4e5-f521-47c9-a58a-3c566a9c6883"}
