[2026-03-13T19:18:43Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EMHXoBW1qXHz2PpEuSSD5K","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"sort\"\n    13→\t\"strings\"\n    14→\t\"sync\"\n    15→\t\"time\"\n    16→\n    17→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    20→\t\"github.com/cloche-dev/cloche/internal/config\"\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    24→\t\"github.com/cloche-dev/cloche/internal/host\"\n    25→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    26→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    27→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    28→\trpcgrpc \"google.golang.org/grpc\"\n    29→\t\"google.golang.org/grpc/metadata\"\n    30→)\n    31→\n    32→type ClocheServer struct {\n    33→\tpb.UnimplementedClocheServiceServer\n    34→\tstore        ports.RunStore\n    35→\tcaptures     ports.CaptureStore\n    36→\tlogStore     ports.LogStore\n    37→\tcontainer    ports.ContainerRuntime\n    38→\tdefaultImage string\n    39→\tevolution    *evolution.Trigger\n    40→\tlogBroadcast *logstream.Broadcaster\n    41→\tshutdownFn   func()\n    42→\tmu           sync.Mutex\n    43→\trunIDs       map[string]string      // run_id -> container_id\n    44→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    45→}\n    46→\n    47→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    48→\treturn &ClocheServer{\n    49→\t\tstore:     store,\n    50→\t\tcontainer: container,\n    51→\t\trunIDs:    make(map[string]string),\n    52→\t\tloops:     make(map[string]*host.Loop),\n    53→\t}\n    54→}\n    55→\n    56→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    57→\treturn &ClocheServer{\n    58→\t\tstore:        store,\n    59→\t\tcaptures:     captures,\n    60→\t\tcontainer:    container,\n    61→\t\tdefaultImage: defaultImage,\n    62→\t\trunIDs:       make(map[string]string),\n    63→\t\tloops:        make(map[string]*host.Loop),\n    64→\t}\n    65→}\n    66→\n    67→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    68→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    69→\ts.logStore = ls\n    70→}\n    71→\n    72→\n    73→// SetEvolution attaches an evolution trigger to the server.\n    74→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    75→\ts.evolution = trigger\n    76→}\n    77→\n    78→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    79→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    80→\ts.logBroadcast = b\n    81→}\n    82→\n    83→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    84→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    85→\ts.shutdownFn = fn\n    86→}\n    87→\n    88→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    89→\tif s.container == nil {\n    90→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    91→\t}\n    92→\n    93→\t// Generate a unique run ID, retrying on collision\n    94→\tvar runID string\n    95→\tfor attempts := 0; attempts < 10; attempts++ {\n    96→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    97→\t\texisting, err := s.store.GetRun(ctx, runID)\n    98→\t\tif err != nil {\n    99→\t\t\tbreak // ID is free\n   100→\t\t}\n   101→\t\t// Reuse if completed more than 1 hour ago\n   102→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   103→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   104→\t\t\tbreak\n   105→\t\t}\n   106→\t}\n   107→\n   108→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   109→\tif req.Prompt != \"\" {\n   110→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   111→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   112→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   113→\t\t}\n   114→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   115→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   116→\t\t}\n   117→\t}\n   118→\trun := domain.NewRun(runID, req.WorkflowName)\n   119→\trun.ProjectDir = req.ProjectDir\n   120→\trun.Title = req.Title\n   121→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   122→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   123→\t}\n   124→\n   125→\t// Resolve image: request-level override, then server default\n   126→\timage := req.Image\n   127→\tif image == \"\" {\n   128→\t\timage = s.defaultImage\n   129→\t}\n   130→\n   131→\t// Launch container start + tracking in background so the RPC returns immediately.\n   132→\t// The run stays in \"pending\" state until the container is up.\n   133→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   134→\n   135→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   136→}\n   137→\n   138→// launchAndTrack starts the container and then tracks it to completion.\n   139→// It runs in a background goroutine with its own context, independent of the\n   140→// RPC context which may be cancelled after RunWorkflow returns.\n   141→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   142→\tctx := context.Background()\n   143→\n   144→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   145→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   146→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   147→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   148→\t\t\tif run != nil {\n   149→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   150→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   151→\t\t\t}\n   152→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   153→\t\t\t\treturn\n   154→\t\t}\n   155→\t}\n   156→\n   157→\tbaseSHA := gitHEAD(req.ProjectDir)\n   158→\n   159→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   160→\t\tImage:        image,\n   161→\t\tWorkflowName: req.WorkflowName,\n   162→\t\tProjectDir:   req.ProjectDir,\n   163→\t\tRunID:        runID,\n   164→\t\tNetworkAllow: []string{\"*\"},\n   165→\t})\n   166→\tif err != nil {\n   167→\t\trun, _ := s.store.GetRun(ctx, runID)\n   168→\t\tif run != nil {\n   169→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   170→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   171→\t\t}\n   172→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   173→\t\treturn\n   174→\t}\n   175→\n   176→\ts.mu.Lock()\n   177→\ts.runIDs[runID] = containerID\n   178→\ts.mu.Unlock()\n   179→\n   180→\trun, _ := s.store.GetRun(ctx, runID)\n   181→\tif run != nil {\n   182→\t\trun.Start()\n   183→\t\trun.ContainerID = containerID\n   184→\t\trun.BaseSHA = baseSHA\n   185→\t\t_ = s.store.UpdateRun(ctx, run)\n   186→\t}\n   187→\n   188→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   189→}\n   190→\n   191→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   192→\tctx := context.Background()\n   193→\n   194→\t// Attach to agent output\n   195→\treader, err := s.container.AttachOutput(ctx, containerID)\n   196→\tif err != nil {\n   197→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   198→\t\t\treturn\n   199→\t}\n   200→\n   201→\t// Parse JSON-lines status messages\n   202→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   203→\tscanner := bufio.NewScanner(reader)\n   204→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   205→\tfor scanner.Scan() {\n   206→\t\tvar msg protocol.StatusMessage\n   207→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   208→\t\t\tcontinue\n   209→\t\t}\n   210→\n   211→\t\t// Fast path: log messages don't need store interaction.\n   212→\t\tif msg.Type == protocol.MsgLog {\n   213→\t\t\tif s.logBroadcast != nil {\n   214→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   215→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   216→\t\t\t\t\tType:      \"llm\",\n   217→\t\t\t\t\tContent:   msg.Message,\n   218→\t\t\t\t\tStepName:  msg.StepName,\n   219→\t\t\t\t})\n   220→\t\t\t}\n   221→\t\t\tcontinue\n   222→\t\t}\n   223→\n   224→\t\trun, err := s.store.GetRun(ctx, runID)\n   225→\t\tif err != nil {\n   226→\t\t\tcontinue\n   227→\t\t}\n   228→\n   229→\t\tswitch msg.Type {\n   230→\t\tcase protocol.MsgStepStarted:\n   231→\t\t\trun.RecordStepStart(msg.StepName)\n   232→\t\t\tif s.captures != nil {\n   233→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   234→\t\t\t\t\tStepName:  msg.StepName,\n   235→\t\t\t\t\tStartedAt: msg.Timestamp,\n   236→\t\t\t\t})\n   237→\t\t\t}\n   238→\t\t\tif s.logBroadcast != nil {\n   239→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   240→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   241→\t\t\t\t\tType:      \"status\",\n   242→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   243→\t\t\t\t\tStepName:  msg.StepName,\n   244→\t\t\t\t})\n   245→\t\t\t}\n   246→\t\tcase protocol.MsgStepCompleted:\n   247→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   248→\t\t\tif s.captures != nil {\n   249→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   250→\t\t\t\t\tStepName:    msg.StepName,\n   251→\t\t\t\t\tResult:      msg.Result,\n   252→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   253→\t\t\t\t})\n   254→\t\t\t}\n   255→\t\t\tif s.logBroadcast != nil {\n   256→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   257→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   258→\t\t\t\t\tType:      \"status\",\n   259→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   260→\t\t\t\t\tStepName:  msg.StepName,\n   261→\t\t\t\t})\n   262→\t\t\t}\n   263→\t\tcase protocol.MsgRunTitle:\n   264→\t\t\tif run.Title == \"\" {\n   265→\t\t\t\trun.Title = msg.Message\n   266→\t\t\t}\n   267→\t\tcase protocol.MsgRunCompleted:\n   268→\t\t\treportedResult = msg.Result\n   269→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   270→\t\t}\n   271→\n   272→\t\t_ = s.store.UpdateRun(ctx, run)\n   273→\t}\n   274→\treader.Close()\n   275→\n   276→\t// Signal live-stream subscribers that this run is done.\n   277→\tif s.logBroadcast != nil {\n   278→\t\ts.logBroadcast.Finish(runID)\n   279→\t}\n   280→\n   281→\t// Wait for process exit\n   282→\texitCode, err := s.container.Wait(ctx, containerID)\n   283→\tif err != nil {\n   284→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   285→\t}\n   286→\n   287→\t// Extract step output files from container before it's removed\n   288→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   289→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   290→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   291→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   292→\t\t}\n   293→\t}\n   294→\n   295→\t// Capture full container stdout/stderr before the container is removed\n   296→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   297→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   298→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   299→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   300→\t\t}\n   301→\t}\n   302→\n   303→\t// Index extracted log files in the log store\n   304→\tif s.logStore != nil {\n   305→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   306→\t}\n   307→\n   308→\t// Extract results to git branch BEFORE finalizing state, so that\n   309→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   310→\t// before the run is marked complete.\n   311→\tresultLabel := reportedResult\n   312→\tif resultLabel == \"\" {\n   313→\t\tif exitCode == 0 {\n   314→\t\t\tresultLabel = \"succeeded\"\n   315→\t\t} else {\n   316→\t\t\tresultLabel = \"failed\"\n   317→\t\t}\n   318→\t}\n   319→\t{\n   320→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   321→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   322→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   323→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   324→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   325→\t\t\t} else {\n   326→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   327→\t\t\t}\n   328→\t\t} else {\n   329→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   330→\t\t}\n   331→\t}\n   332→\n   333→\t// Now finalize run state\n   334→\trun, err := s.store.GetRun(ctx, runID)\n   335→\tif err != nil {\n   336→\t\treturn\n   337→\t}\n   338→\tif run.State == domain.RunStateRunning {\n   339→\t\tif reportedResult == \"succeeded\" {\n   340→\t\t\trun.Complete(domain.RunStateSucceeded)\n   341→\t\t} else if reportedResult != \"\" {\n   342→\t\t\trun.Complete(domain.RunStateFailed)\n   343→\t\t} else if exitCode == 0 {\n   344→\t\t\trun.Complete(domain.RunStateSucceeded)\n   345→\t\t} else {\n   346→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   347→\t\t}\n   348→\t\t_ = s.store.UpdateRun(ctx, run)\n   349→\t}\n   350→\n   351→\t// Fire evolution trigger if configured\n   352→\tif s.evolution != nil {\n   353→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   354→\t}\n   355→\n   356→\t// Merge is handled as a workflow step in host.cloche, not here.\n   357→\n   358→\t// Container retention policy:\n   359→\t// - Failed runs: always keep the container for debugging\n   360→\t// - Successful runs + --keep-container: keep the container\n   361→\t// - Successful runs without --keep-container: remove the container\n   362→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   363→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   364→\n   365→\tif keepContainer || runFailed {\n   366→\t\treason := \"--keep-container\"\n   367→\t\tif runFailed {\n   368→\t\t\treason = \"run failed\"\n   369→\t\t}\n   370→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   371→\t\tif runFinal != nil {\n   372→\t\t\trunFinal.ContainerKept = true\n   373→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   374→\t\t}\n   375→\t} else {\n   376→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   377→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   378→\t\t} else {\n   379→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   380→\t\t}\n   381→\t}\n   382→\n   383→\t// Cleanup mapping\n   384→\ts.mu.Lock()\n   385→\tdelete(s.runIDs, runID)\n   386→\ts.mu.Unlock()\n   387→}\n   388→\n   389→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   390→\tfilter := domain.RunListFilter{\n   391→\t\tProjectDir: req.ProjectDir,\n   392→\t\tState:      domain.RunState(req.State),\n   393→\t\tTaskID:     req.TaskId,\n   394→\t\tLimit:      int(req.Limit),\n   395→\t}\n   396→\n   397→\t// When no project filter and not --all, default to last hour\n   398→\tif filter.ProjectDir == \"\" && !req.All {\n   399→\t\tfilter.Since = time.Now().Add(-1 * time.Hour)\n   400→\t}\n   401→\n   402→\truns, err := s.store.ListRunsFiltered(ctx, filter)\n   403→\tif err != nil {\n   404→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   405→\t}\n   406→\n   407→\tresp := &pb.ListRunsResponse{}\n   408→\tfor _, run := range runs {\n   409→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   410→\t\t\tRunId:        run.ID,\n   411→\t\t\tWorkflowName: run.WorkflowName,\n   412→\t\t\tState:        string(run.State),\n   413→\t\t\tStartedAt:    run.StartedAt.String(),\n   414→\t\t\tErrorMessage: run.ErrorMessage,\n   415→\t\t\tContainerId:  run.ContainerID,\n   416→\t\t\tTitle:        run.Title,\n   417→\t\t\tIsHost:       run.IsHost,\n   418→\t\t\tProjectDir:   run.ProjectDir,\n   419→\t\t})\n   420→\t}\n   421→\treturn resp, nil\n   422→}\n   423→\n   424→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   425→\trun, err := s.store.GetRun(ctx, req.RunId)\n   426→\tif err != nil {\n   427→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   428→\t}\n   429→\n   430→\tresp := &pb.GetStatusResponse{\n   431→\t\tRunId:        run.ID,\n   432→\t\tWorkflowName: run.WorkflowName,\n   433→\t\tState:        string(run.State),\n   434→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   435→\t\tErrorMessage: run.ErrorMessage,\n   436→\t\tContainerId:  run.ContainerID,\n   437→\t\tTitle:        run.Title,\n   438→\t\tIsHost:       run.IsHost,\n   439→\t}\n   440→\n   441→\t// Check container liveness\n   442→\tif run.ContainerID != \"\" && s.container != nil {\n   443→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   444→\t\t\tresp.ContainerAlive = cs.Running\n   445→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   446→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   447→\t\t\t}\n   448→\t\t}\n   449→\t}\n   450→\n   451→\t// Load step executions from captures store if available\n   452→\tif s.captures != nil {\n   453→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   454→\t\tif err == nil {\n   455→\t\t\tfor _, exec := range captures {\n   456→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   457→\t\t\t\t\tStepName:    exec.StepName,\n   458→\t\t\t\t\tResult:      exec.Result,\n   459→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   460→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   461→\t\t\t\t})\n   462→\t\t\t}\n   463→\t\t}\n   464→\t} else {\n   465→\t\tfor _, exec := range run.StepExecutions {\n   466→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   467→\t\t\t\tStepName:    exec.StepName,\n   468→\t\t\t\tResult:      exec.Result,\n   469→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   470→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   471→\t\t\t})\n   472→\t\t}\n   473→\t}\n   474→\n   475→\treturn resp, nil\n   476→}\n   477→\n   478→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   479→\tctx := stream.Context()\n   480→\n   481→\t// Check for follow mode via gRPC metadata.\n   482→\tfollow := followFromContext(ctx)\n   483→\n   484→\t// Verify run exists\n   485→\trun, err := s.store.GetRun(ctx, req.RunId)\n   486→\tif err != nil {\n   487→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   488→\t}\n   489→\n   490→\t// If step_name or log_type filter is set, serve content directly from the log index\n   491→\tif req.StepName != \"\" || req.LogType != \"\" {\n   492→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   493→\t}\n   494→\n   495→\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n   496→\n   497→\t// With -f on an active run: send existing logs then tail live output.\n   498→\tif follow && isActive && s.logBroadcast != nil {\n   499→\t\treturn s.streamFollowLogs(req.RunId, run, stream)\n   500→\t}\n   501→\n   502→\t// Without -f on an active run: snapshot existing logs and return.\n   503→\t// (Legacy callers that relied on implicit live streaming should use -f.)\n   504→\t// With -f on a completed run: same as without -f — no new lines will arrive.\n   505→\n   506→\t// Check for full.log first — if it exists, serve it as the unified log\n   507→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   508→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   509→\t\tif err := stream.Send(&pb.LogEntry{\n   510→\t\t\tType:    \"full_log\",\n   511→\t\t\tMessage: string(data),\n   512→\t\t}); err != nil {\n   513→\t\t\treturn err\n   514→\t\t}\n   515→\t\tif !isActive {\n   516→\t\t\tif err := stream.Send(&pb.LogEntry{\n   517→\t\t\t\tType:      \"run_completed\",\n   518→\t\t\t\tResult:    string(run.State),\n   519→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   520→\t\t\t\tMessage:   run.ErrorMessage,\n   521→\t\t\t}); err != nil {\n   522→\t\t\t\treturn err\n   523→\t\t\t}\n   524→\t\t}\n   525→\t\treturn nil\n   526→\t}\n   527→\n   528→\tif s.captures == nil {\n   529→\t\treturn fmt.Errorf(\"captures store not configured\")\n   530→\t}\n   531→\n   532→\t// Fall back to capture-based streaming\n   533→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   534→\tif err != nil {\n   535→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   536→\t}\n   537→\n   538→\tfor _, exec := range captures {\n   539→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   540→\t\t// and one for step_completed (has Result).\n   541→\t\tif exec.Result == \"\" {\n   542→\t\t\tentry := &pb.LogEntry{\n   543→\t\t\t\tType:      \"step_started\",\n   544→\t\t\t\tStepName:  exec.StepName,\n   545→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   546→\t\t\t}\n   547→\t\t\tif err := stream.Send(entry); err != nil {\n   548→\t\t\t\treturn err\n   549→\t\t\t}\n   550→\t\t} else {\n   551→\t\t\t// Read step output from per-step output file.\n   552→\t\t\t// Container runs write .log, host runs write .out — try both.\n   553→\t\t\tvar output string\n   554→\t\t\tfor _, ext := range []string{\".log\", \".out\"} {\n   555→\t\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+ext)\n   556→\t\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   557→\t\t\t\t\toutput = string(data)\n   558→\t\t\t\t\tbreak\n   559→\t\t\t\t}\n   560→\t\t\t}\n   561→\t\t\tentry := &pb.LogEntry{\n   562→\t\t\t\tType:      \"step_completed\",\n   563→\t\t\t\tStepName:  exec.StepName,\n   564→\t\t\t\tResult:    exec.Result,\n   565→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   566→\t\t\t\tMessage:   output,\n   567→\t\t\t}\n   568→\t\t\tif err := stream.Send(entry); err != nil {\n   569→\t\t\t\treturn err\n   570→\t\t\t}\n   571→\t\t}\n   572→\t}\n   573→\n   574→\t// Send run completion entry\n   575→\tif !isActive {\n   576→\t\tif err := stream.Send(&pb.LogEntry{\n   577→\t\t\tType:      \"run_completed\",\n   578→\t\t\tResult:    string(run.State),\n   579→\t\t\tTimestamp: run.CompletedAt.String(),\n   580→\t\t\tMessage:   run.ErrorMessage,\n   581→\t\t}); err != nil {\n   582→\t\t\treturn err\n   583→\t\t}\n   584→\t}\n   585→\n   586→\treturn nil\n   587→}\n   588→\n   589→// followFromContext checks for the follow flag in gRPC metadata.\n   590→func followFromContext(ctx context.Context) bool {\n   591→\tmd, ok := metadata.FromIncomingContext(ctx)\n   592→\tif !ok {\n   593→\t\treturn false\n   594→\t}\n   595→\tvals := md.Get(\"x-cloche-follow\")\n   596→\treturn len(vals) > 0 && vals[0] == \"true\"\n   597→}\n   598→\n   599→// streamFollowLogs sends existing log content then tails live output from the\n   600→// broadcaster. It combines snapshot + live streaming (like tail -f).\n   601→func (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   602→\t// Subscribe first so we don't miss lines written between read and subscribe.\n   603→\tsub := s.logBroadcast.Subscribe(runID)\n   604→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   605→\n   606→\t// Send existing full.log content if available.\n   607→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n   608→\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n   609→\t\tif err := stream.Send(&pb.LogEntry{\n   610→\t\t\tType:    \"full_log\",\n   611→\t\t\tMessage: string(data),\n   612→\t\t}); err != nil {\n   613→\t\t\treturn err\n   614→\t\t}\n   615→\t}\n   616→\n   617→\t// Now tail live output from the broadcaster.\n   618→\tctx := stream.Context()\n   619→\tfor {\n   620→\t\tselect {\n   621→\t\tcase <-ctx.Done():\n   622→\t\t\treturn ctx.Err()\n   623→\t\tcase line, ok := <-sub.C:\n   624→\t\t\tif !ok {\n   625→\t\t\t\t// Run completed — send terminal entry.\n   626→\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n   627→\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n   628→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   629→\t\t\t\t\t\tType:      \"run_completed\",\n   630→\t\t\t\t\t\tResult:    string(r.State),\n   631→\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n   632→\t\t\t\t\t\tMessage:   r.ErrorMessage,\n   633→\t\t\t\t\t})\n   634→\t\t\t\t}\n   635→\t\t\t\treturn nil\n   636→\t\t\t}\n   637→\t\t\tif err := stream.Send(&pb.LogEntry{\n   638→\t\t\t\tType:      \"log\",\n   639→\t\t\t\tStepName:  line.StepName,\n   640→\t\t\t\tMessage:   line.Content,\n   641→\t\t\t\tTimestamp: line.Timestamp,\n   642→\t\t\t}); err != nil {\n   643→\t\t\t\treturn err\n   644→\t\t\t}\n   645→\t\t}\n   646→\t}\n   647→}\n   648→\n   649→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   650→// It uses the log index when available, falling back to file path conventions.\n   651→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   652→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   653→\n   654→\t// Try log index first\n   655→\tif s.logStore != nil {\n   656→\t\tvar logFiles []*ports.LogFileEntry\n   657→\t\tvar err error\n   658→\n   659→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   660→\t\t\t// Filter by both step and type\n   661→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   662→\t\t\tif err == nil {\n   663→\t\t\t\tfiltered := logFiles[:0]\n   664→\t\t\t\tfor _, lf := range logFiles {\n   665→\t\t\t\t\tif lf.FileType == req.LogType {\n   666→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   667→\t\t\t\t\t}\n   668→\t\t\t\t}\n   669→\t\t\t\tlogFiles = filtered\n   670→\t\t\t}\n   671→\t\t} else if req.StepName != \"\" {\n   672→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   673→\t\t} else {\n   674→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   675→\t\t}\n   676→\n   677→\t\tif err == nil && len(logFiles) > 0 {\n   678→\t\t\tfor _, lf := range logFiles {\n   679→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   680→\t\t\t\tif readErr != nil {\n   681→\t\t\t\t\tcontinue\n   682→\t\t\t\t}\n   683→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   684→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   685→\t\t\t\t\tStepName: lf.StepName,\n   686→\t\t\t\t\tMessage:  string(data),\n   687→\t\t\t\t}); err != nil {\n   688→\t\t\t\t\treturn err\n   689→\t\t\t\t}\n   690→\t\t\t}\n   691→\t\t\treturn nil\n   692→\t\t}\n   693→\t}\n   694→\n   695→\t// Fall back to file path conventions\n   696→\tif req.StepName != \"\" {\n   697→\t\tvar logPath string\n   698→\t\tswitch req.LogType {\n   699→\t\tcase \"llm\":\n   700→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   701→\t\tdefault:\n   702→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   703→\t\t}\n   704→\n   705→\t\tdata, err := os.ReadFile(logPath)\n   706→\t\tif err != nil {\n   707→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   708→\t\t}\n   709→\t\treturn stream.Send(&pb.LogEntry{\n   710→\t\t\tType:     \"step_log\",\n   711→\t\t\tStepName: req.StepName,\n   712→\t\t\tMessage:  string(data),\n   713→\t\t})\n   714→\t}\n   715→\n   716→\treturn fmt.Errorf(\"no log files found matching filter\")\n   717→}\n   718→\n   719→// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n   720→// time for an active run. The stream closes when the run completes or the\n   721→// client disconnects.\n   722→func (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   723→\tsub := s.logBroadcast.Subscribe(runID)\n   724→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   725→\n   726→\tctx := stream.Context()\n   727→\tfor {\n   728→\t\tselect {\n   729→\t\tcase <-ctx.Done():\n   730→\t\t\treturn ctx.Err()\n   731→\t\tcase line, ok := <-sub.C:\n   732→\t\t\tif !ok {\n   733→\t\t\t\t// Run completed — send terminal entry.\n   734→\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   735→\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   736→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   737→\t\t\t\t\t\tType:      \"run_completed\",\n   738→\t\t\t\t\t\tResult:    string(run.State),\n   739→\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   740→\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   741→\t\t\t\t\t})\n   742→\t\t\t\t}\n   743→\t\t\t\treturn nil\n   744→\t\t\t}\n   745→\t\t\tif err := stream.Send(&pb.LogEntry{\n   746→\t\t\t\tType:      \"log\",\n   747→\t\t\t\tStepName:  line.StepName,\n   748→\t\t\t\tMessage:   line.Content,\n   749→\t\t\t\tTimestamp: line.Timestamp,\n   750→\t\t\t}); err != nil {\n   751→\t\t\t\treturn err\n   752→\t\t\t}\n   753→\t\t}\n   754→\t}\n   755→}\n   756→\n   757→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   758→\ts.mu.Lock()\n   759→\tcontainerID, ok := s.runIDs[req.RunId]\n   760→\ts.mu.Unlock()\n   761→\n   762→\tif !ok {\n   763→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   764→\t}\n   765→\n   766→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   767→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   768→\t}\n   769→\n   770→\t// Mark as cancelled in store\n   771→\trun, err := s.store.GetRun(ctx, req.RunId)\n   772→\tif err == nil {\n   773→\t\trun.Complete(domain.RunStateCancelled)\n   774→\t\t_ = s.store.UpdateRun(ctx, run)\n   775→\t}\n   776→\n   777→\treturn &pb.StopRunResponse{}, nil\n   778→}\n   779→\n   780→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   781→\tif s.container == nil {\n   782→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   783→\t}\n   784→\n   785→\tid := req.Id\n   786→\tif id == \"\" {\n   787→\t\treturn nil, fmt.Errorf(\"id is required\")\n   788→\t}\n   789→\n   790→\t// Try to resolve as a run ID first\n   791→\tcontainerID := id\n   792→\trun, err := s.store.GetRun(ctx, id)\n   793→\tif err == nil {\n   794→\t\t// It's a run ID — use the container ID from the run record\n   795→\t\tif run.ContainerID == \"\" {\n   796→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   797→\t\t}\n   798→\t\tcontainerID = run.ContainerID\n   799→\t}\n   800→\n   801→\t// Remove the container\n   802→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   803→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   804→\t}\n   805→\n   806→\t// If we resolved a run, clear the container_kept flag\n   807→\tif run != nil {\n   808→\t\trun.ContainerKept = false\n   809→\t\t_ = s.store.UpdateRun(ctx, run)\n   810→\t}\n   811→\n   812→\treturn &pb.DeleteContainerResponse{}, nil\n   813→}\n   814→\n   815→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   816→\tprojectDir := req.ProjectDir\n   817→\tif projectDir == \"\" {\n   818→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   819→\t}\n   820→\n   821→\t// Verify host.cloche exists\n   822→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   823→\tif _, err := os.Stat(hostPath); err != nil {\n   824→\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n   825→\t}\n   826→\n   827→\t// Load project config for defaults.\n   828→\tprojCfg, _ := config.Load(projectDir)\n   829→\n   830→\tmaxConc := int(req.MaxConcurrent)\n   831→\tif maxConc <= 0 {\n   832→\t\tmaxConc = projCfg.Orchestration.Concurrency\n   833→\t}\n   834→\tif maxConc <= 0 {\n   835→\t\tmaxConc = 1\n   836→\t}\n   837→\n   838→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   839→\n   840→\t// Compute dedup timeout from config (default 5 minutes).\n   841→\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n   842→\n   843→\tloopCfg := host.LoopConfig{\n   844→\t\tProjectDir:    projectDir,\n   845→\t\tMaxConcurrent: maxConc,\n   846→\t\tStaggerDelay:  stagger,\n   847→\t\tDedupTimeout:  dedupTimeout,\n   848→\t}\n   849→\n   850→\ts.mu.Lock()\n   851→\tdefer s.mu.Unlock()\n   852→\n   853→\t// Stop existing loop if running.\n   854→\tif existing, ok := s.loops[projectDir]; ok {\n   855→\t\texisting.Stop()\n   856→\t}\n   857→\n   858→\t// Check if host.cloche defines a list-tasks workflow for three-phase mode.\n   859→\tvar loop *host.Loop\n   860→\tif s.hasWorkflow(hostPath, \"list-tasks\") {\n   861→\t\tloop = s.createPhaseLoop(loopCfg, projectDir, hostPath, dedupTimeout)\n   862→\t} else {\n   863→\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n   864→\t}\n   865→\n   866→\ts.loops[projectDir] = loop\n   867→\tloop.Start()\n   868→\n   869→\treturn &pb.EnableLoopResponse{}, nil\n   870→}\n   871→\n   872→// hasWorkflow checks if host.cloche contains a workflow with the given name.\n   873→func (s *ClocheServer) hasWorkflow(hostPath, workflowName string) bool {\n   874→\tdata, err := os.ReadFile(hostPath)\n   875→\tif err != nil {\n   876→\t\treturn false\n   877→\t}\n   878→\treturn strings.Contains(string(data), fmt.Sprintf(\"workflow %q\", workflowName))\n   879→}\n   880→\n   881→// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n   882→// main, and finalize workflows from host.cloche.\n   883→func (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir, hostPath string, dedupTimeout time.Duration) *host.Loop {\n   884→\t// Phase 1: list-tasks function\n   885→\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n   886→\t\trunner := &host.Runner{\n   887→\t\t\tDispatcher: s,\n   888→\t\t\tStore:      s.store,\n   889→\t\t}\n   890→\t\ttasks, _, err := host.RunListTasksWorkflow(ctx, runner, projDir)\n   891→\t\treturn tasks, err\n   892→\t}\n   893→\n   894→\t// Phase 2: main function\n   895→\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   896→\t\trunner := &host.Runner{\n   897→\t\t\tDispatcher:   s,\n   898→\t\t\tStore:        s.store,\n   899→\t\t\tCaptures:     s.captures,\n   900→\t\t\tLogBroadcast: s.logBroadcast,\n   901→\t\t\tTaskID:       taskID,\n   902→\t\t}\n   903→\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n   904→\t}\n   905→\n   906→\t// Phase 3: finalize function (optional — only if host.cloche has it)\n   907→\tvar finalizeFn host.FinalizeFunc\n   908→\tif s.hasWorkflow(hostPath, \"finalize\") {\n   909→\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n   910→\t\t\tmainRunID := \"\"\n   911→\t\t\tmainOutcome := \"failed\"\n   912→\t\t\tif mainResult != nil {\n   913→\t\t\t\tmainRunID = mainResult.RunID\n   914→\t\t\t\tmainOutcome = string(mainResult.State)\n   915→\t\t\t}\n   916→\t\t\trunner := &host.Runner{\n   917→\t\t\t\tDispatcher:   s,\n   918→\t\t\t\tStore:        s.store,\n   919→\t\t\t\tCaptures:     s.captures,\n   920→\t\t\t\tLogBroadcast: s.logBroadcast,\n   921→\t\t\t\tTaskID:       taskID,\n   922→\t\t\t\tExtraEnv: []string{\n   923→\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n   924→\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n   925→\t\t\t\t},\n   926→\t\t\t}\n   927→\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n   928→\t\t}\n   929→\t}\n   930→\n   931→\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n   932→\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n   933→}\n   934→\n   935→// createLegacyLoop creates a legacy single-function orchestration loop.\n   936→func (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n   937→\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   938→\t\trunner := &host.Runner{\n   939→\t\t\tDispatcher:   s,\n   940→\t\t\tStore:        s.store,\n   941→\t\t\tCaptures:     s.captures,\n   942→\t\t\tLogBroadcast: s.logBroadcast,\n   943→\t\t\tTaskID:       taskID,\n   944→\t\t}\n   945→\t\treturn runner.Run(ctx, projDir)\n   946→\t}\n   947→\n   948→\tloop := host.NewLoop(loopCfg, s.store, runFn)\n   949→\n   950→\t// Configure daemon-managed task assignment if a list-tasks command is set.\n   951→\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n   952→\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n   953→\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n   954→\t}\n   955→\n   956→\treturn loop\n   957→}\n   958→\n   959→// GetLoopTasks returns the current task pipeline state for a project's\n   960→// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n   961→// loop is active for the project.\n   962→func (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n   963→\ts.mu.Lock()\n   964→\tloop, ok := s.loops[projectDir]\n   965→\ts.mu.Unlock()\n   966→\tif !ok {\n   967→\t\treturn nil\n   968→\t}\n   969→\tsnapshot := loop.GetTaskSnapshot()\n   970→\tentries := make([]web.TaskEntry, len(snapshot))\n   971→\tfor i, e := range snapshot {\n   972→\t\tentry := web.TaskEntry{\n   973→\t\t\tID:          e.Task.ID,\n   974→\t\t\tStatus:      e.Task.Status,\n   975→\t\t\tTitle:       e.Task.Title,\n   976→\t\t\tDescription: e.Task.Description,\n   977→\t\t\tMetadata:    e.Task.Metadata,\n   978→\t\t\tAssigned:    e.Assigned,\n   979→\t\t\tRunID:       e.RunID,\n   980→\t\t}\n   981→\t\tif !e.AssignedAt.IsZero() {\n   982→\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n   983→\t\t}\n   984→\t\tentries[i] = entry\n   985→\t}\n   986→\treturn entries\n   987→}\n   988→\n   989→func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n   990→\tprojectDir := req.ProjectDir\n   991→\tif projectDir == \"\" {\n   992→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   993→\t}\n   994→\n   995→\ts.mu.Lock()\n   996→\tdefer s.mu.Unlock()\n   997→\n   998→\tif loop, ok := s.loops[projectDir]; ok {\n   999→\t\tloop.Stop()\n  1000→\t\tdelete(s.loops, projectDir)\n  1001→\t}\n  1002→\n  1003→\treturn &pb.DisableLoopResponse{}, nil\n  1004→}\n  1005→\n  1006→func (s *ClocheServer) GetProjectInfo(ctx context.Context, req *pb.GetProjectInfoRequest) (*pb.GetProjectInfoResponse, error) {\n  1007→\tprojectDir := req.ProjectDir\n  1008→\n  1009→\t// Resolve by name if provided.\n  1010→\tif req.Name != \"\" && projectDir == \"\" {\n  1011→\t\tprojects, err := s.store.ListProjects(ctx)\n  1012→\t\tif err != nil {\n  1013→\t\t\treturn nil, fmt.Errorf(\"listing projects: %w\", err)\n  1014→\t\t}\n  1015→\t\tlabels := projectLabels(projects)\n  1016→\t\tfound := false\n  1017→\t\tfor dir, label := range labels {\n  1018→\t\t\tif label == req.Name {\n  1019→\t\t\t\tprojectDir = dir\n  1020→\t\t\t\tfound = true\n  1021→\t\t\t\tbreak\n  1022→\t\t\t}\n  1023→\t\t}\n  1024→\t\tif !found {\n  1025→\t\t\treturn nil, fmt.Errorf(\"project %q not found\", req.Name)\n  1026→\t\t}\n  1027→\t}\n  1028→\n  1029→\tif projectDir == \"\" {\n  1030→\t\treturn nil, fmt.Errorf(\"project_dir or name is required\")\n  1031→\t}\n  1032→\n  1033→\t// Derive project label.\n  1034→\tprojects, _ := s.store.ListProjects(ctx)\n  1035→\tlabels := projectLabels(projects)\n  1036→\tlabel := labels[projectDir]\n  1037→\tif label == \"\" {\n  1038→\t\tlabel = filepath.Base(projectDir)\n  1039→\t}\n  1040→\n  1041→\t// Load config.\n  1042→\tcfg, _ := config.Load(projectDir)\n  1043→\n  1044→\t// Check loop state.\n  1045→\ts.mu.Lock()\n  1046→\tloop, loopExists := s.loops[projectDir]\n  1047→\ts.mu.Unlock()\n  1048→\tloopRunning := loopExists && loop != nil && loop.Running()\n  1049→\n  1050→\t// Get active runs.\n  1051→\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n  1052→\tvar activeRuns []*pb.RunSummary\n  1053→\tfor _, run := range allRuns {\n  1054→\t\tif run.State == domain.RunStatePending || run.State == domain.RunStateRunning {\n  1055→\t\t\tactiveRuns = append(activeRuns, &pb.RunSummary{\n  1056→\t\t\t\tRunId:        run.ID,\n  1057→\t\t\t\tWorkflowName: run.WorkflowName,\n  1058→\t\t\t\tState:        string(run.State),\n  1059→\t\t\t\tStartedAt:    run.StartedAt.String(),\n  1060→\t\t\t\tTitle:        run.Title,\n  1061→\t\t\t\tIsHost:       run.IsHost,\n  1062→\t\t\t\tContainerId:  run.ContainerID,\n  1063→\t\t\t})\n  1064→\t\t}\n  1065→\t}\n  1066→\n  1067→\t// Discover workflows.\n  1068→\tvar containerWorkflows, hostWorkflows []string\n  1069→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n  1070→\tentries, _ := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n  1071→\tfor _, path := range entries {\n  1072→\t\tbase := filepath.Base(path)\n  1073→\t\tdata, err := os.ReadFile(path)\n  1074→\t\tif err != nil {\n  1075→\t\t\tcontinue\n  1076→\t\t}\n  1077→\t\tif base == \"host.cloche\" {\n  1078→\t\t\twfs, err := dsl.ParseAllForHost(string(data))\n  1079→\t\t\tif err != nil {\n  1080→\t\t\t\tcontinue\n  1081→\t\t\t}\n  1082→\t\t\tfor name := range wfs {\n  1083→\t\t\t\thostWorkflows = append(hostWorkflows, name)\n  1084→\t\t\t}\n  1085→\t\t} else {\n  1086→\t\t\twf, err := dsl.ParseForContainer(string(data))\n  1087→\t\t\tif err != nil {\n  1088→\t\t\t\tcontinue\n  1089→\t\t\t}\n  1090→\t\t\tcontainerWorkflows = append(containerWorkflows, wf.Name)\n  1091→\t\t}\n  1092→\t}\n  1093→\n  1094→\tsort.Strings(containerWorkflows)\n  1095→\tsort.Strings(hostWorkflows)\n  1096→\n  1097→\treturn &pb.GetProjectInfoResponse{\n  1098→\t\tProjectDir:         projectDir,\n  1099→\t\tName:               label,\n  1100→\t\tActive:             cfg.Active,\n  1101→\t\tConcurrency:        int32(cfg.Orchestration.Concurrency),\n  1102→\t\tStaggerSeconds:     cfg.Orchestration.StaggerSeconds,\n  1103→\t\tDedupSeconds:       cfg.Orchestration.DedupSeconds,\n  1104→\t\tEvolutionEnabled:   cfg.Evolution.Enabled,\n  1105→\t\tLoopRunning:        loopRunning,\n  1106→\t\tActiveRuns:         activeRuns,\n  1107→\t\tContainerWorkflows: containerWorkflows,\n  1108→\t\tHostWorkflows:      hostWorkflows,\n  1109→\t}, nil\n  1110→}\n  1111→\n  1112→// projectLabels maps each project directory to a short display label.\n  1113→// Uses basename unless there are conflicts, in which case parent/basename is used.\n  1114→func projectLabels(dirs []string) map[string]string {\n  1115→\tlabels := make(map[string]string, len(dirs))\n  1116→\tbyBase := map[string][]string{}\n  1117→\tfor _, d := range dirs {\n  1118→\t\tbase := filepath.Base(d)\n  1119→\t\tbyBase[base] = append(byBase[base], d)\n  1120→\t}\n  1121→\tfor base, paths := range byBase {\n  1122→\t\tif len(paths) == 1 {\n  1123→\t\t\tlabels[paths[0]] = base\n  1124→\t\t} else {\n  1125→\t\t\tfor _, p := range paths {\n  1126→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1127→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1128→\t\t\t}\n  1129→\t\t}\n  1130→\t}\n  1131→\treturn labels\n  1132→}\n  1133→\n  1134→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n  1135→\t// Stop all orchestration loops.\n  1136→\ts.mu.Lock()\n  1137→\tfor _, loop := range s.loops {\n  1138→\t\tloop.Stop()\n  1139→\t}\n  1140→\ts.loops = make(map[string]*host.Loop)\n  1141→\ts.mu.Unlock()\n  1142→\n  1143→\tif s.shutdownFn == nil {\n  1144→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n  1145→\t}\n  1146→\tgo s.shutdownFn()\n  1147→\treturn &pb.ShutdownResponse{}, nil\n  1148→}\n  1149→\n  1150→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n  1151→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n  1152→\tentries, err := os.ReadDir(outputDir)\n  1153→\tif err != nil {\n  1154→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n  1155→\t\treturn\n  1156→\t}\n  1157→\n  1158→\tnow := time.Now()\n  1159→\tfor _, entry := range entries {\n  1160→\t\tif entry.IsDir() {\n  1161→\t\t\tcontinue\n  1162→\t\t}\n  1163→\t\tname := entry.Name()\n  1164→\t\tif !strings.HasSuffix(name, \".log\") {\n  1165→\t\t\tcontinue\n  1166→\t\t}\n  1167→\n  1168→\t\tvar fileType, stepName string\n  1169→\t\tbase := strings.TrimSuffix(name, \".log\")\n  1170→\n  1171→\t\tswitch {\n  1172→\t\tcase name == \"full.log\":\n  1173→\t\t\tfileType = \"full\"\n  1174→\t\tcase name == \"container.log\":\n  1175→\t\t\t// container.log is internal, not indexed as a user-facing log type\n  1176→\t\t\tcontinue\n  1177→\t\tcase strings.HasPrefix(name, \"llm-\"):\n  1178→\t\t\tfileType = \"llm\"\n  1179→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n  1180→\t\tdefault:\n  1181→\t\t\tfileType = \"script\"\n  1182→\t\t\tstepName = base\n  1183→\t\t}\n  1184→\n  1185→\t\tinfo, _ := entry.Info()\n  1186→\t\tvar fileSize int64\n  1187→\t\tif info != nil {\n  1188→\t\t\tfileSize = info.Size()\n  1189→\t\t}\n  1190→\n  1191→\t\tlogEntry := &ports.LogFileEntry{\n  1192→\t\t\tRunID:     runID,\n  1193→\t\t\tStepName:  stepName,\n  1194→\t\t\tFileType:  fileType,\n  1195→\t\t\tFilePath:  filepath.Join(outputDir, name),\n  1196→\t\t\tFileSize:  fileSize,\n  1197→\t\t\tCreatedAt: now,\n  1198→\t\t}\n  1199→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n  1200→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n  1201→\t\t}\n  1202→\t}\n  1203→}\n  1204→\n  1205→func gitHEAD(dir string) string {\n  1206→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n  1207→\tcmd.Dir = dir\n  1208→\tout, err := cmd.Output()\n  1209→\tif err != nil {\n  1210→\t\treturn \"\"\n  1211→\t}\n  1212→\treturn strings.TrimSpace(string(out))\n  1213→}\n  1214→"}]},"parent_tool_use_id":null,"session_id":"8a8a233a-9bc4-4d5b-81f2-86c5b6995110","uuid":"a2fe2924-5eea-4739-b0a7-8fed16e744e1","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server.go","content":"package grpc\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\t\"github.com/cloche-dev/cloche/internal/host\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\trpcgrpc \"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\ntype ClocheServer struct {\n\tpb.UnimplementedClocheServiceServer\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogStore     ports.LogStore\n\tcontainer    ports.ContainerRuntime\n\tdefaultImage string\n\tevolution    *evolution.Trigger\n\tlogBroadcast *logstream.Broadcaster\n\tshutdownFn   func()\n\tmu           sync.Mutex\n\trunIDs       map[string]string      // run_id -> container_id\n\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n}\n\nfunc NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:     store,\n\t\tcontainer: container,\n\t\trunIDs:    make(map[string]string),\n\t\tloops:     make(map[string]*host.Loop),\n\t}\n}\n\nfunc NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:        store,\n\t\tcaptures:     captures,\n\t\tcontainer:    container,\n\t\tdefaultImage: defaultImage,\n\t\trunIDs:       make(map[string]string),\n\t\tloops:        make(map[string]*host.Loop),\n\t}\n}\n\n// SetLogStore attaches a log store to the server for indexing extracted log files.\nfunc (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n\ts.logStore = ls\n}\n\n\n// SetEvolution attaches an evolution trigger to the server.\nfunc (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n\ts.evolution = trigger\n}\n\n// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\nfunc (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n\ts.logBroadcast = b\n}\n\n// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\nfunc (s *ClocheServer) SetShutdownFunc(fn func()) {\n\ts.shutdownFn = fn\n}\n\nfunc (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\t// Generate a unique run ID, retrying on collision\n\tvar runID string\n\tfor attempts := 0; attempts < 10; attempts++ {\n\t\trunID = domain.GenerateRunID(req.WorkflowName)\n\t\texisting, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tbreak // ID is free\n\t\t}\n\t\t// Reuse if completed more than 1 hour ago\n\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n\t\t\t_ = s.store.DeleteRun(ctx, runID)\n\t\t\tbreak\n\t\t}\n\t}\n\n\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n\tif req.Prompt != \"\" {\n\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n\t\t}\n\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n\t\t}\n\t}\n\trun := domain.NewRun(runID, req.WorkflowName)\n\trun.ProjectDir = req.ProjectDir\n\trun.Title = req.Title\n\tif err := s.store.CreateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n\t}\n\n\t// Resolve image: request-level override, then server default\n\timage := req.Image\n\tif image == \"\" {\n\t\timage = s.defaultImage\n\t}\n\n\t// Launch container start + tracking in background so the RPC returns immediately.\n\t// The run stays in \"pending\" state until the container is up.\n\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n\n\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n}\n\n// launchAndTrack starts the container and then tracks it to completion.\n// It runs in a background goroutine with its own context, independent of the\n// RPC context which may be cancelled after RunWorkflow returns.\nfunc (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n\tctx := context.Background()\n\n\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n\t\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\t\tif run != nil {\n\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t\t}\n\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n\t\t\t\treturn\n\t\t}\n\t}\n\n\tbaseSHA := gitHEAD(req.ProjectDir)\n\n\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n\t\tImage:        image,\n\t\tWorkflowName: req.WorkflowName,\n\t\tProjectDir:   req.ProjectDir,\n\t\tRunID:        runID,\n\t\tNetworkAllow: []string{\"*\"},\n\t})\n\tif err != nil {\n\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\tif run != nil {\n\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t}\n\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n\t\treturn\n\t}\n\n\ts.mu.Lock()\n\ts.runIDs[runID] = containerID\n\ts.mu.Unlock()\n\n\trun, _ := s.store.GetRun(ctx, runID)\n\tif run != nil {\n\t\trun.Start()\n\t\trun.ContainerID = containerID\n\t\trun.BaseSHA = baseSHA\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n}\n\nfunc (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n\tctx := context.Background()\n\n\t// Attach to agent output\n\treader, err := s.container.AttachOutput(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n\t\t\treturn\n\t}\n\n\t// Parse JSON-lines status messages\n\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n\tscanner := bufio.NewScanner(reader)\n\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n\tfor scanner.Scan() {\n\t\tvar msg protocol.StatusMessage\n\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Fast path: log messages don't need store interaction.\n\t\tif msg.Type == protocol.MsgLog {\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"llm\",\n\t\t\t\t\tContent:   msg.Message,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\trun, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch msg.Type {\n\t\tcase protocol.MsgStepStarted:\n\t\t\trun.RecordStepStart(msg.StepName)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t\tStartedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"status\",\n\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgStepCompleted:\n\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:    msg.StepName,\n\t\t\t\t\tResult:      msg.Result,\n\t\t\t\t\tCompletedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"status\",\n\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgRunTitle:\n\t\t\tif run.Title == \"\" {\n\t\t\t\trun.Title = msg.Message\n\t\t\t}\n\t\tcase protocol.MsgRunCompleted:\n\t\t\treportedResult = msg.Result\n\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n\t\t}\n\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\treader.Close()\n\n\t// Signal live-stream subscribers that this run is done.\n\tif s.logBroadcast != nil {\n\t\ts.logBroadcast.Finish(runID)\n\t}\n\n\t// Wait for process exit\n\texitCode, err := s.container.Wait(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n\t}\n\n\t// Extract step output files from container before it's removed\n\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n\t\t}\n\t}\n\n\t// Capture full container stdout/stderr before the container is removed\n\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n\t\t}\n\t}\n\n\t// Index extracted log files in the log store\n\tif s.logStore != nil {\n\t\ts.indexLogFiles(ctx, runID, outputDst)\n\t}\n\n\t// Extract results to git branch BEFORE finalizing state, so that\n\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n\t// before the run is marked complete.\n\tresultLabel := reportedResult\n\tif resultLabel == \"\" {\n\t\tif exitCode == 0 {\n\t\t\tresultLabel = \"succeeded\"\n\t\t} else {\n\t\t\tresultLabel = \"failed\"\n\t\t}\n\t}\n\t{\n\t\textractRun, _ := s.store.GetRun(ctx, runID)\n\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n\t\t\t} else {\n\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n\t\t\t}\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n\t\t}\n\t}\n\n\t// Now finalize run state\n\trun, err := s.store.GetRun(ctx, runID)\n\tif err != nil {\n\t\treturn\n\t}\n\tif run.State == domain.RunStateRunning {\n\t\tif reportedResult == \"succeeded\" {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else if reportedResult != \"\" {\n\t\t\trun.Complete(domain.RunStateFailed)\n\t\t} else if exitCode == 0 {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else {\n\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n\t\t}\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\t// Fire evolution trigger if configured\n\tif s.evolution != nil {\n\t\ts.evolution.Fire(projectDir, workflowName, runID)\n\t}\n\n\t// Merge is handled as a workflow step in host.cloche, not here.\n\n\t// Container retention policy:\n\t// - Failed runs: always keep the container for debugging\n\t// - Successful runs + --keep-container: keep the container\n\t// - Successful runs without --keep-container: remove the container\n\trunFinal, _ := s.store.GetRun(ctx, runID)\n\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n\n\tif keepContainer || runFailed {\n\t\treason := \"--keep-container\"\n\t\tif runFailed {\n\t\t\treason = \"run failed\"\n\t\t}\n\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n\t\tif runFinal != nil {\n\t\t\trunFinal.ContainerKept = true\n\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n\t\t}\n\t} else {\n\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n\t\t}\n\t}\n\n\t// Cleanup mapping\n\ts.mu.Lock()\n\tdelete(s.runIDs, runID)\n\ts.mu.Unlock()\n}\n\nfunc (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n\tfilter := domain.RunListFilter{\n\t\tProjectDir: req.ProjectDir,\n\t\tState:      domain.RunState(req.State),\n\t\tTaskID:     req.TaskId,\n\t\tLimit:      int(req.Limit),\n\t}\n\n\t// When no project filter and not --all, default to last hour\n\tif filter.ProjectDir == \"\" && !req.All {\n\t\tfilter.Since = time.Now().Add(-1 * time.Hour)\n\t}\n\n\truns, err := s.store.ListRunsFiltered(ctx, filter)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n\t}\n\n\tresp := &pb.ListRunsResponse{}\n\tfor _, run := range runs {\n\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n\t\t\tRunId:        run.ID,\n\t\t\tWorkflowName: run.WorkflowName,\n\t\t\tState:        string(run.State),\n\t\t\tStartedAt:    run.StartedAt.String(),\n\t\t\tErrorMessage: run.ErrorMessage,\n\t\t\tContainerId:  run.ContainerID,\n\t\t\tTitle:        run.Title,\n\t\t\tIsHost:       run.IsHost,\n\t\t\tProjectDir:   run.ProjectDir,\n\t\t})\n\t}\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n\t}\n\n\tresp := &pb.GetStatusResponse{\n\t\tRunId:        run.ID,\n\t\tWorkflowName: run.WorkflowName,\n\t\tState:        string(run.State),\n\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n\t\tErrorMessage: run.ErrorMessage,\n\t\tContainerId:  run.ContainerID,\n\t\tTitle:        run.Title,\n\t\tIsHost:       run.IsHost,\n\t}\n\n\t// Check container liveness\n\tif run.ContainerID != \"\" && s.container != nil {\n\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n\t\t\tresp.ContainerAlive = cs.Running\n\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n\t\t\t}\n\t\t}\n\t}\n\n\t// Load step executions from captures store if available\n\tif s.captures != nil {\n\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\t\tif err == nil {\n\t\t\tfor _, exec := range captures {\n\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\t\tStepName:    exec.StepName,\n\t\t\t\t\tResult:      exec.Result,\n\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, exec := range run.StepExecutions {\n\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\tStepName:    exec.StepName,\n\t\t\t\tResult:      exec.Result,\n\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t})\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tctx := stream.Context()\n\n\t// Check for follow mode via gRPC metadata.\n\tfollow := followFromContext(ctx)\n\n\t// Verify run exists\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n\t}\n\n\t// If step_name or log_type filter is set, serve content directly from the log index\n\tif req.StepName != \"\" || req.LogType != \"\" {\n\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n\t}\n\n\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n\n\t// With -f on an active run: send existing logs then tail live output.\n\tif follow && isActive && s.logBroadcast != nil {\n\t\treturn s.streamFollowLogs(req.RunId, run, stream)\n\t}\n\n\t// Without -f on an active run: snapshot existing logs and return.\n\t// (Legacy callers that relied on implicit live streaming should use -f.)\n\t// With -f on a completed run: same as without -f — no new lines will arrive.\n\n\t// Check for full.log first — if it exists, serve it as the unified log\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: string(data),\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif !isActive {\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"run_completed\",\n\t\t\t\tResult:    string(run.State),\n\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}\n\n\tif s.captures == nil {\n\t\treturn fmt.Errorf(\"captures store not configured\")\n\t}\n\n\t// Fall back to capture-based streaming\n\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n\t}\n\n\tfor _, exec := range captures {\n\t\t// Captures are stored as separate rows: one for step_started (no Result)\n\t\t// and one for step_completed (has Result).\n\t\tif exec.Result == \"\" {\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_started\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tTimestamp: exec.StartedAt.String(),\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t} else {\n\t\t\t// Read step output from per-step output file.\n\t\t\t// Container runs write .log, host runs write .out — try both.\n\t\t\tvar output string\n\t\t\tfor _, ext := range []string{\".log\", \".out\"} {\n\t\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+ext)\n\t\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\t\t\t\toutput = string(data)\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_completed\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tResult:    exec.Result,\n\t\t\t\tTimestamp: exec.CompletedAt.String(),\n\t\t\t\tMessage:   output,\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\t// Send run completion entry\n\tif !isActive {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:      \"run_completed\",\n\t\t\tResult:    string(run.State),\n\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\tMessage:   run.ErrorMessage,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// followFromContext checks for the follow flag in gRPC metadata.\nfunc followFromContext(ctx context.Context) bool {\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif !ok {\n\t\treturn false\n\t}\n\tvals := md.Get(\"x-cloche-follow\")\n\treturn len(vals) > 0 && vals[0] == \"true\"\n}\n\n// streamFollowLogs sends existing log content then tails live output from the\n// broadcaster. It combines snapshot + live streaming (like tail -f).\nfunc (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\t// Subscribe first so we don't miss lines written between read and subscribe.\n\tsub := s.logBroadcast.Subscribe(runID)\n\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n\n\t// Send existing full.log content if available.\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: string(data),\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\t// Now tail live output from the broadcaster.\n\tctx := stream.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Run completed — send terminal entry.\n\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n\t\t\t\t\t\tType:      \"run_completed\",\n\t\t\t\t\t\tResult:    string(r.State),\n\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n\t\t\t\t\t\tMessage:   r.ErrorMessage,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"log\",\n\t\t\t\tStepName:  line.StepName,\n\t\t\t\tMessage:   line.Content,\n\t\t\t\tTimestamp: line.Timestamp,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n}\n\n// streamFilteredLogs serves log content filtered by step name and/or log type.\n// It uses the log index when available, falling back to file path conventions.\nfunc (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n\n\t// Try log index first\n\tif s.logStore != nil {\n\t\tvar logFiles []*ports.LogFileEntry\n\t\tvar err error\n\n\t\tif req.StepName != \"\" && req.LogType != \"\" {\n\t\t\t// Filter by both step and type\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t\tif err == nil {\n\t\t\t\tfiltered := logFiles[:0]\n\t\t\t\tfor _, lf := range logFiles {\n\t\t\t\t\tif lf.FileType == req.LogType {\n\t\t\t\t\t\tfiltered = append(filtered, lf)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tlogFiles = filtered\n\t\t\t}\n\t\t} else if req.StepName != \"\" {\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t} else {\n\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n\t\t}\n\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr != nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\t\tType:     lf.FileType + \"_log\",\n\t\t\t\t\tStepName: lf.StepName,\n\t\t\t\t\tMessage:  string(data),\n\t\t\t\t}); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Fall back to file path conventions\n\tif req.StepName != \"\" {\n\t\tvar logPath string\n\t\tswitch req.LogType {\n\t\tcase \"llm\":\n\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n\t\tdefault:\n\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n\t\t}\n\n\t\tdata, err := os.ReadFile(logPath)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n\t\t}\n\t\treturn stream.Send(&pb.LogEntry{\n\t\t\tType:     \"step_log\",\n\t\t\tStepName: req.StepName,\n\t\t\tMessage:  string(data),\n\t\t})\n\t}\n\n\treturn fmt.Errorf(\"no log files found matching filter\")\n}\n\n// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n// time for an active run. The stream closes when the run completes or the\n// client disconnects.\nfunc (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tsub := s.logBroadcast.Subscribe(runID)\n\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n\n\tctx := stream.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Run completed — send terminal entry.\n\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n\t\t\t\t\t\tType:      \"run_completed\",\n\t\t\t\t\t\tResult:    string(run.State),\n\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"log\",\n\t\t\t\tStepName:  line.StepName,\n\t\t\t\tMessage:   line.Content,\n\t\t\t\tTimestamp: line.Timestamp,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n\ts.mu.Lock()\n\tcontainerID, ok := s.runIDs[req.RunId]\n\ts.mu.Unlock()\n\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n\t}\n\n\tif err := s.container.Stop(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n\t}\n\n\t// Mark as cancelled in store\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err == nil {\n\t\trun.Complete(domain.RunStateCancelled)\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.StopRunResponse{}, nil\n}\n\nfunc (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\tid := req.Id\n\tif id == \"\" {\n\t\treturn nil, fmt.Errorf(\"id is required\")\n\t}\n\n\t// Try to resolve as a run ID first\n\tcontainerID := id\n\trun, err := s.store.GetRun(ctx, id)\n\tif err == nil {\n\t\t// It's a run ID — use the container ID from the run record\n\t\tif run.ContainerID == \"\" {\n\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n\t\t}\n\t\tcontainerID = run.ContainerID\n\t}\n\n\t// Remove the container\n\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n\t}\n\n\t// If we resolved a run, clear the container_kept flag\n\tif run != nil {\n\t\trun.ContainerKept = false\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.DeleteContainerResponse{}, nil\n}\n\nfunc (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n\tprojectDir := req.ProjectDir\n\tif projectDir == \"\" {\n\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n\t}\n\n\t// Verify host.cloche exists\n\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n\tif _, err := os.Stat(hostPath); err != nil {\n\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n\t}\n\n\t// Load project config for defaults.\n\tprojCfg, _ := config.Load(projectDir)\n\n\tmaxConc := int(req.MaxConcurrent)\n\tif maxConc <= 0 {\n\t\tmaxConc = projCfg.Orchestration.Concurrency\n\t}\n\tif maxConc <= 0 {\n\t\tmaxConc = 1\n\t}\n\n\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n\n\t// Compute dedup timeout from config (default 5 minutes).\n\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n\n\tloopCfg := host.LoopConfig{\n\t\tProjectDir:    projectDir,\n\t\tMaxConcurrent: maxConc,\n\t\tStaggerDelay:  stagger,\n\t\tDedupTimeout:  dedupTimeout,\n\t}\n\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\t// Stop existing loop if running.\n\tif existing, ok := s.loops[projectDir]; ok {\n\t\texisting.Stop()\n\t}\n\n\t// Check if host.cloche defines a list-tasks workflow for three-phase mode.\n\tvar loop *host.Loop\n\tif s.hasWorkflow(hostPath, \"list-tasks\") {\n\t\tloop = s.createPhaseLoop(loopCfg, projectDir, hostPath, dedupTimeout)\n\t} else {\n\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n\t}\n\n\ts.loops[projectDir] = loop\n\tloop.Start()\n\n\treturn &pb.EnableLoopResponse{}, nil\n}\n\n// hasWorkflow checks if host.cloche contains a workflow with the given name.\nfunc (s *ClocheServer) hasWorkflow(hostPath, workflowName string) bool {\n\tdata, err := os.ReadFile(hostPath)\n\tif err != nil {\n\t\treturn false\n\t}\n\treturn strings.Contains(string(data), fmt.Sprintf(\"workflow %q\", workflowName))\n}\n\n// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n// main, and finalize workflows from host.cloche.\nfunc (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir, hostPath string, dedupTimeout time.Duration) *host.Loop {\n\t// Phase 1: list-tasks function\n\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n\t\trunner := &host.Runner{\n\t\t\tDispatcher: s,\n\t\t\tStore:      s.store,\n\t\t}\n\t\ttasks, _, err := host.RunListTasksWorkflow(ctx, runner, projDir)\n\t\treturn tasks, err\n\t}\n\n\t// Phase 2: main function\n\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n\t\trunner := &host.Runner{\n\t\t\tDispatcher:   s,\n\t\t\tStore:        s.store,\n\t\t\tCaptures:     s.captures,\n\t\t\tLogBroadcast: s.logBroadcast,\n\t\t\tTaskID:       taskID,\n\t\t}\n\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n\t}\n\n\t// Phase 3: finalize function (optional — only if host.cloche has it)\n\tvar finalizeFn host.FinalizeFunc\n\tif s.hasWorkflow(hostPath, \"finalize\") {\n\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n\t\t\tmainRunID := \"\"\n\t\t\tmainOutcome := \"failed\"\n\t\t\tif mainResult != nil {\n\t\t\t\tmainRunID = mainResult.RunID\n\t\t\t\tmainOutcome = string(mainResult.State)\n\t\t\t}\n\t\t\trunner := &host.Runner{\n\t\t\t\tDispatcher:   s,\n\t\t\t\tStore:        s.store,\n\t\t\t\tCaptures:     s.captures,\n\t\t\t\tLogBroadcast: s.logBroadcast,\n\t\t\t\tTaskID:       taskID,\n\t\t\t\tExtraEnv: []string{\n\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n\t\t\t\t},\n\t\t\t}\n\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n\t\t}\n\t}\n\n\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n}\n\n// createLegacyLoop creates a legacy single-function orchestration loop.\nfunc (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n\t\trunner := &host.Runner{\n\t\t\tDispatcher:   s,\n\t\t\tStore:        s.store,\n\t\t\tCaptures:     s.captures,\n\t\t\tLogBroadcast: s.logBroadcast,\n\t\t\tTaskID:       taskID,\n\t\t}\n\t\treturn runner.Run(ctx, projDir)\n\t}\n\n\tloop := host.NewLoop(loopCfg, s.store, runFn)\n\n\t// Configure daemon-managed task assignment if a list-tasks command is set.\n\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n\t}\n\n\treturn loop\n}\n\n// GetLoopTasks returns the current task pipeline state for a project's\n// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n// loop is active for the project.\nfunc (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n\ts.mu.Lock()\n\tloop, ok := s.loops[projectDir]\n\ts.mu.Unlock()\n\tif !ok {\n\t\treturn nil\n\t}\n\tsnapshot := loop.GetTaskSnapshot()\n\tentries := make([]web.TaskEntry, len(snapshot))\n\tfor i, e := range snapshot {\n\t\tentry := web.TaskEntry{\n\t\t\tID:          e.Task.ID,\n\t\t\tStatus:      e.Task.Status,\n\t\t\tTitle:       e.Task.Title,\n\t\t\tDescription: e.Task.Description,\n\t\t\tMetadata:    e.Task.Metadata,\n\t\t\tAssigned:    e.Assigned,\n\t\t\tRunID:       e.RunID,\n\t\t}\n\t\tif !e.AssignedAt.IsZero() {\n\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n\t\t}\n\t\tentries[i] = entry\n\t}\n\treturn entries\n}\n\nfunc (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n\tprojectDir := req.ProjectDir\n\tif projectDir == \"\" {\n\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n\t}\n\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\tif loop, ok := s.loops[projectDir]; ok {\n\t\tloop.Stop()\n\t\tdelete(s.loops, projectDir)\n\t}\n\n\treturn &pb.DisableLoopResponse{}, nil\n}\n\nfunc (s *ClocheServer) GetProjectInfo(ctx context.Context, req *pb.GetProjectInfoRequest) (*pb.GetProjectInfoResponse, error) {\n\tprojectDir := req.ProjectDir\n\n\t// Resolve by name if provided.\n\tif req.Name != \"\" && projectDir == \"\" {\n\t\tprojects, err := s.store.ListProjects(ctx)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"listing projects: %w\", err)\n\t\t}\n\t\tlabels := projectLabels(projects)\n\t\tfound := false\n\t\tfor dir, label := range labels {\n\t\t\tif label == req.Name {\n\t\t\t\tprojectDir = dir\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\treturn nil, fmt.Errorf(\"project %q not found\", req.Name)\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\treturn nil, fmt.Errorf(\"project_dir or name is required\")\n\t}\n\n\t// Derive project label.\n\tprojects, _ := s.store.ListProjects(ctx)\n\tlabels := projectLabels(projects)\n\tlabel := labels[projectDir]\n\tif label == \"\" {\n\t\tlabel = filepath.Base(projectDir)\n\t}\n\n\t// Load config.\n\tcfg, _ := config.Load(projectDir)\n\n\t// Check loop state.\n\ts.mu.Lock()\n\tloop, loopExists := s.loops[projectDir]\n\ts.mu.Unlock()\n\tloopRunning := loopExists && loop != nil && loop.Running()\n\n\t// Get active runs.\n\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n\tvar activeRuns []*pb.RunSummary\n\tfor _, run := range allRuns {\n\t\tif run.State == domain.RunStatePending || run.State == domain.RunStateRunning {\n\t\t\tactiveRuns = append(activeRuns, &pb.RunSummary{\n\t\t\t\tRunId:        run.ID,\n\t\t\t\tWorkflowName: run.WorkflowName,\n\t\t\t\tState:        string(run.State),\n\t\t\t\tStartedAt:    run.StartedAt.String(),\n\t\t\t\tTitle:        run.Title,\n\t\t\t\tIsHost:       run.IsHost,\n\t\t\t\tContainerId:  run.ContainerID,\n\t\t\t})\n\t\t}\n\t}\n\n\t// Discover workflows.\n\tvar containerWorkflows, hostWorkflows []string\n\tclocheDir := filepath.Join(projectDir, \".cloche\")\n\tentries, _ := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n\tfor _, path := range entries {\n\t\tbase := filepath.Base(path)\n\t\tdata, err := os.ReadFile(path)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif base == \"host.cloche\" {\n\t\t\twfs, err := dsl.ParseAllForHost(string(data))\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor name := range wfs {\n\t\t\t\thostWorkflows = append(hostWorkflows, name)\n\t\t\t}\n\t\t} else {\n\t\t\twf, err := dsl.ParseForContainer(string(data))\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tcontainerWorkflows = append(containerWorkflows, wf.Name)\n\t\t}\n\t}\n\n\tsort.Strings(containerWorkflows)\n\tsort.Strings(hostWorkflows)\n\n\treturn &pb.GetProjectInfoResponse{\n\t\tProjectDir:         projectDir,\n\t\tName:               label,\n\t\tActive:             cfg.Active,\n\t\tConcurrency:        int32(cfg.Orchestration.Concurrency),\n\t\tStaggerSeconds:     cfg.Orchestration.StaggerSeconds,\n\t\tDedupSeconds:       cfg.Orchestration.DedupSeconds,\n\t\tEvolutionEnabled:   cfg.Evolution.Enabled,\n\t\tLoopRunning:        loopRunning,\n\t\tActiveRuns:         activeRuns,\n\t\tContainerWorkflows: containerWorkflows,\n\t\tHostWorkflows:      hostWorkflows,\n\t}, nil\n}\n\n// projectLabels maps each project directory to a short display label.\n// Uses basename unless there are conflicts, in which case parent/basename is used.\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\nfunc (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n\t// Stop all orchestration loops.\n\ts.mu.Lock()\n\tfor _, loop := range s.loops {\n\t\tloop.Stop()\n\t}\n\ts.loops = make(map[string]*host.Loop)\n\ts.mu.Unlock()\n\n\tif s.shutdownFn == nil {\n\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n\t}\n\tgo s.shutdownFn()\n\treturn &pb.ShutdownResponse{}, nil\n}\n\n// indexLogFiles scans the extracted output directory and creates log_files index entries.\nfunc (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tname := entry.Name()\n\t\tif !strings.HasSuffix(name, \".log\") {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar fileType, stepName string\n\t\tbase := strings.TrimSuffix(name, \".log\")\n\n\t\tswitch {\n\t\tcase name == \"full.log\":\n\t\t\tfileType = \"full\"\n\t\tcase name == \"container.log\":\n\t\t\t// container.log is internal, not indexed as a user-facing log type\n\t\t\tcontinue\n\t\tcase strings.HasPrefix(name, \"llm-\"):\n\t\t\tfileType = \"llm\"\n\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n\t\tdefault:\n\t\t\tfileType = \"script\"\n\t\t\tstepName = base\n\t\t}\n\n\t\tinfo, _ := entry.Info()\n\t\tvar fileSize int64\n\t\tif info != nil {\n\t\t\tfileSize = info.Size()\n\t\t}\n\n\t\tlogEntry := &ports.LogFileEntry{\n\t\t\tRunID:     runID,\n\t\t\tStepName:  stepName,\n\t\t\tFileType:  fileType,\n\t\t\tFilePath:  filepath.Join(outputDir, name),\n\t\t\tFileSize:  fileSize,\n\t\t\tCreatedAt: now,\n\t\t}\n\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n\t\t}\n\t}\n}\n\nfunc gitHEAD(dir string) string {\n\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\treturn strings.TrimSpace(string(out))\n}\n","numLines":1214,"startLine":1,"totalLines":1214}}}
