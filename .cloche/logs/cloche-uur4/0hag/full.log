loche-agent %s\\n\", agentVersion)\n\n\t// Warn about version mismatches\n\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n\t}\n\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n\t}\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":322,"cache_read_input_tokens":84417,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":322},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8a8a233a-9bc4-4d5b-81f2-86c5b6995110","uuid":"1b5a381d-27c4-4ce5-96af-55a10c656222"}
