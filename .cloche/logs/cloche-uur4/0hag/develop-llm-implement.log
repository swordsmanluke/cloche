{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019FxpkKQrZRBw4b6NyHgtdh","type":"tool_result","content":"package main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n)\n\nvar workflowTemplate = `workflow \"%s\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n\n  step test {\n    run = \"make test 2>&1\"\n    results = [success, fail]\n  }\n\n  step fix {\n    prompt = file(\".cloche/prompts/fix.md\")\n    max_attempts = \"2\"\n    results = [success, fail, give-up]\n  }\n\n  step update-docs {\n    prompt = file(\".cloche/prompts/update-docs.md\")\n    results = [success, fail]\n  }\n\n  implement:success -> test\n  implement:fail -> abort\n  test:success -> update-docs\n  test:fail -> fix\n  fix:success -> test\n  fix:fail -> abort\n  fix:give-up -> abort\n  update-docs:success -> done\n  update-docs:fail -> done\n}\n`\n\nvar dockerfileTemplate = `FROM %s\nUSER root\n\n# Add your project's dependencies here.\n# Example:\n#   RUN apt-get update && apt-get install -y --no-install-recommends python3 && rm -rf /var/lib/apt/lists/*\n#   RUN npm install -g @anthropic-ai/claude-code","is_error":false}]},"parent_tool_use_id":"toolu_01F81cnT9Hi7BVCZkVgug3tU","session_id":"8a8a233a-9bc4-4d5b-81f2-86c5b6995110","uuid":"d68cbf94-f9e0-40e9-9541-ca663020c8f1"}
