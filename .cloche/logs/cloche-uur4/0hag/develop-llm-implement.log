  128→\n   129→message GetProjectInfoRequest {\n   130→  string project_dir = 1;  // Resolve by absolute path (default: cwd)\n   131→  string name = 2;         // Resolve by project label (e.g. \"cloche\")\n   132→}\n   133→\n   134→message GetProjectInfoResponse {\n   135→  string project_dir = 1;\n   136→  string name = 2;\n   137→  bool active = 3;\n   138→  int32 concurrency = 4;\n   139→  double stagger_seconds = 5;\n   140→  double dedup_seconds = 6;\n   141→  bool evolution_enabled = 7;\n   142→  bool loop_running = 8;\n   143→  repeated RunSummary active_runs = 9;\n   144→  repeated string container_workflows = 10;\n   145→  repeated string host_workflows = 11;\n   146→}\n   147→"}]},"parent_tool_use_id":null,"session_id":"8a8a233a-9bc4-4d5b-81f2-86c5b6995110","uuid":"949e82a5-2694-4498-81d3-d20bb62f705f","tool_use_result":{"type":"text","file":{"filePath":"/workspace/api/proto/cloche/v1/cloche.proto","content":"syntax = \"proto3\";\n\npackage cloche.v1;\n\noption go_package = \"github.com/cloche-dev/cloche/api/clochepb\";\n\nservice ClocheService {\n  rpc RunWorkflow(RunWorkflowRequest) returns (RunWorkflowResponse);\n  rpc GetStatus(GetStatusRequest) returns (GetStatusResponse);\n  rpc StreamLogs(StreamLogsRequest) returns (stream LogEntry);\n  rpc StopRun(StopRunRequest) returns (StopRunResponse);\n  rpc ListRuns(ListRunsRequest) returns (ListRunsResponse);\n  rpc Shutdown(ShutdownRequest) returns (ShutdownResponse);\n  rpc DeleteContainer(DeleteContainerRequest) returns (DeleteContainerResponse);\n\n  rpc EnableLoop(EnableLoopRequest) returns (EnableLoopResponse);\n  rpc DisableLoop(DisableLoopRequest) returns (DisableLoopResponse);\n\n  rpc GetProjectInfo(GetProjectInfoRequest) returns (GetProjectInfoResponse);\n}\n\nmessage RunWorkflowRequest {\n  string workflow_name = 1;\n  string project_dir = 2;\n  string image = 3;\n  string prompt = 4;\n  bool keep_container = 5;\n  string title = 6;\n}\n\nmessage RunWorkflowResponse {\n  string run_id = 1;\n}\n\nmessage GetStatusRequest {\n  string run_id = 1;\n}\n\nmessage GetStatusResponse {\n  string run_id = 1;\n  string workflow_name = 2;\n  string state = 3;\n  string current_step = 4;\n  repeated StepExecutionStatus step_executions = 5;\n  string error_message = 6;\n  string container_id = 7;\n  bool container_alive = 8;\n  string container_dead_since = 9;\n  string title = 10;\n  bool is_host = 11;\n}\n\nmessage StepExecutionStatus {\n  string step_name = 1;\n  string result = 2;\n  string started_at = 3;\n  string completed_at = 4;\n}\n\nmessage StreamLogsRequest {\n  string run_id = 1;\n  string step_name = 2;\n  string log_type = 3;\n  bool follow = 4;  // When true, stream existing logs then continue tailing new lines (like tail -f).\n                     // Passed via gRPC metadata header \"x-cloche-follow\" until proto is regenerated.\n}\n\nmessage LogEntry {\n  string type = 1;\n  string step_name = 2;\n  string result = 3;\n  string message = 4;\n  string timestamp = 5;\n}\n\nmessage StopRunRequest {\n  string run_id = 1;\n}\n\nmessage StopRunResponse {}\n\nmessage ShutdownRequest {}\n\nmessage ShutdownResponse {}\n\nmessage DeleteContainerRequest {\n  string id = 1;\n}\n\nmessage DeleteContainerResponse {}\n\nmessage ListRunsRequest {\n  bool all = 1;\n  string project_dir = 2;\n  string state = 3;\n  int32 limit = 4;\n  string task_id = 5;\n}\n\nmessage ListRunsResponse {\n  repeated RunSummary runs = 1;\n}\n\nmessage RunSummary {\n  string run_id = 1;\n  string workflow_name = 2;\n  string state = 3;\n  string started_at = 4;\n  string error_message = 5;\n  string container_id = 6;\n  string title = 7;\n  bool is_host = 8;\n  string project_dir = 9;\n}\n\nmessage EnableLoopRequest {\n  string project_dir = 1;\n  int32 max_concurrent = 2;\n}\n\nmessage EnableLoopResponse {}\n\nmessage DisableLoopRequest {\n  string project_dir = 1;\n}\n\nmessage DisableLoopResponse {}\n\nmessage GetProjectInfoRequest {\n  string project_dir = 1;  // Resolve by absolute path (default: cwd)\n  string name = 2;         // Resolve by project label (e.g. \"cloche\")\n}\n\nmessage GetProjectInfoResponse {\n  string project_dir = 1;\n  string name = 2;\n  bool active = 3;\n  int32 concurrency = 4;\n  double stagger_seconds = 5;\n  double dedup_seconds = 6;\n  bool evolution_enabled = 7;\n  bool loop_running = 8;\n  repeated RunSummary active_runs = 9;\n  repeated string container_workflows = 10;\n  repeated string host_workflows = 11;\n}\n","numLines":147,"startLine":1,"totalLines":147}}}
