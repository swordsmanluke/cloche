x, client, os.Args[2:])\n   126→\tcase \"logs\":\n   127→\t\tcmdLogs(client, os.Args[2:])\n   128→\tcase \"poll\":\n   129→\t\tcmdPoll(client, os.Args[2:])\n   130→\tcase \"list\":\n   131→\t\tcmdList(ctx, client, os.Args[2:])\n   132→\tcase \"stop\":\n   133→\t\tcmdStop(ctx, client, os.Args[2:])\n   134→\tcase \"delete\":\n   135→\t\tcmdDelete(ctx, client, os.Args[2:])\n   136→\tcase \"loop\":\n   137→\t\tcmdLoop(ctx, client, os.Args[2:])\n   138→\tcase \"shutdown\":\n   139→\t\tcmdShutdown(ctx, client)\n   140→\tdefault:\n   141→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   142→\t\tprintTopLevelHelp()\n   143→\t\tos.Exit(1)\n   144→\t}\n   145→}\n   146→\n   147→\n   148→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   149→\tvar workflow, prompt, title string\n   150→\tvar keepContainer bool\n   151→\n   152→\tfor i := 0; i < len(args); i++ {\n   153→\t\tswitch args[i] {\n   154→\t\tcase \"--workflow\":\n   155→\t\t\tif i+1 < len(args) {\n   156→\t\t\t\ti++\n   157→\t\t\t\tworkflow = args[i]\n   158→\t\t\t}\n   159→\t\tcase \"--prompt\", \"-p\":\n   160→\t\t\tif i+1 < len(args) {\n   161→\t\t\t\ti++\n   162→\t\t\t\tprompt = args[i]\n   163→\t\t\t}\n   164→\t\tcase \"--title\":\n   165→\t\t\tif i+1 < len(args) {\n   166→\t\t\t\ti++\n   167→\t\t\t\ttitle = args[i]\n   168→\t\t\t}\n   169→\t\tcase \"--keep-container\":\n   170→\t\t\tkeepContainer = true\n   171→\t\tdefault:\n   172→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   173→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   174→\t\t\t\tworkflow = args[i]\n   175→\t\t\t}\n   176→\t\t}\n   177→\t}\n   178→\n   179→\tif workflow == \"\" {\n   180→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   181→\t\tos.Exit(1)\n   182→\t}\n   183→\n   184→\tcwd, _ := os.Getwd()\n   185→\n   186→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   187→\tvar image string\n   188→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   189→\tif data, err := os.ReadFile(wfPath); err == nil {\n   190→\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   191→\t\t\timage = wf.Config[\"container.image\"]\n   192→\t\t}\n   193→\t}\n   194→\n   195→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   196→\t\tWorkflowName:  workflow,\n   197→\t\tProjectDir:    cwd,\n   198→\t\tImage:         image,\n   199→\t\tPrompt:        prompt,\n   200→\t\tKeepContainer: keepContainer,\n   201→\t\tTitle:         title,\n   202→\t})\n   203→\tif err != nil {\n   204→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   205→\t\tos.Exit(1)\n   206→\t}\n   207→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   208→}\n   209→\n   210→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   211→\tif len(args) < 1 {\n   212→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   213→\t\tos.Exit(1)\n   214→\t}\n   215→\n   216→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   217→\tif err != nil {\n   218→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   219→\t\tos.Exit(1)\n   220→\t}\n   221→\n   222→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   223→\tif resp.Title != \"\" {\n   224→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   225→\t}\n   226→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   227→\tif resp.IsHost {\n   228→\t\tfmt.Printf(\"Type:      host\\n\")\n   229→\t} else {\n   230→\t\tfmt.Printf(\"Type:      container\\n\")\n   231→\t}\n   232→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   233→\tif resp.ContainerId != \"\" {\n   234→\t\tcid := resp.ContainerId\n   235→\t\tif len(cid) > 12 {\n   236→\t\t\tcid = cid[:12]\n   237→\t\t}\n   238→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   239→\t}\n   240→\tif resp.ErrorMessage != \"\" {\n   241→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   242→\t}\n   243→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   244→\tfor _, exec := range resp.StepExecutions {\n   245→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   246→\t}\n   247→}\n   248→\n   249→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   250→\tvar all bool\n   251→\tvar projectDir, stateFilter, issueFilter string\n   252→\tvar limit int32\n   253→\n   254→\tfor i := 0; i < len(args); i++ {\n   255→\t\tswitch args[i] {\n   256→\t\tcase \"--all\":\n   257→\t\t\tall = true\n   258→\t\tcase \"--project\", \"-p\":\n   259→\t\t\tif i+1 < len(args) {\n   260→\t\t\t\ti++\n   261→\t\t\t\tprojectDir = args[i]\n   262→\t\t\t}\n   263→\t\tcase \"--state\", \"-s\":\n   264→\t\t\tif i+1 < len(args) {\n   265→\t\t\t\ti++\n   266→\t\t\t\tstateFilter = args[i]\n   267→\t\t\t}\n   268→\t\tcase \"--limit\", \"-n\":\n   269→\t\t\tif i+1 < len(args) {\n   270→\t\t\t\ti++\n   271→\t\t\t\tn, err := strconv.Atoi(args[i])\n   272→\t\t\t\tif err != nil {\n   273→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   274→\t\t\t\t\tos.Exit(1)\n   275→\t\t\t\t}\n   276→\t\t\t\tlimit = int32(n)\n   277→\t\t\t}\n   278→\t\tcase \"--issue\", \"-i\":\n   279→\t\t\tif i+1 < len(args) {\n   280→\t\t\t\ti++\n   281→\t\t\t\tissueFilter = args[i]\n   282→\t\t\t}\n   283→\t\t}\n   284→\t}\n   285→\n   286→\treq := &pb.ListRunsRequest{\n   287→\t\tState:  stateFilter,\n   288→\t\tLimit:  limit,\n   289→\t\tTaskId: issueFilter,\n   290→\t}\n   291→\tif projectDir != \"\" {\n   292→\t\treq.ProjectDir = projectDir\n   293→\t} else if all {\n   294→\t\treq.All = true\n   295→\t} else {\n   296→\t\t// Default: filter to current project\n   297→\t\tcwd, _ := os.Getwd()\n   298→\t\treq.ProjectDir = cwd\n   299→\t}\n   300→\n   301→\tresp, err := client.ListRuns(ctx, req)\n   302→\tif err != nil {\n   303→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   304→\t\tos.Exit(1)\n   305→\t}\n   306→\n   307→\tif len(resp.Runs) == 0 {\n   308→\t\tfmt.Println(\"No runs found.\")\n   309→\t\treturn\n   310→\t}\n   311→\n   312→\tfor _, run := range resp.Runs {\n   313→\t\trunType := \"container\"\n   314→\t\tif run.IsHost {\n   315→\t\t\trunType = \"host\"\n   316→\t\t}\n   317→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   318→\t\tif run.Title != \"\" {\n   319→\t\t\tt := run.Title\n   320→\t\t\tif len(t) > 40 {\n   321→\t\t\t\tt = t[:37] + \"...\"\n   322→\t\t\t}\n   323→\t\t\tline += \"  \" + t\n   324→\t\t}\n   325→\t\tif run.ContainerId != \"\" {\n   326→\t\t\tline += \"  \" + run.ContainerId\n   327→\t\t}\n   328→\t\tif run.ErrorMessage != \"\" {\n   329→\t\t\terrMsg := run.ErrorMessage\n   330→\t\t\tif len(errMsg) > 60 {\n   331→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   332→\t\t\t}\n   333→\t\t\tline += \"  \" + errMsg\n   334→\t\t}\n   335→\t\tfmt.Println(line)\n   336→\t}\n   337→}\n   338→\n   339→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   340→\tif len(args) < 1 {\n   341→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n   342→\t\tos.Exit(1)\n   343→\t}\n   344→\n   345→\tvar stepFilter, typeFilter string\n   346→\tvar follow bool\n   347→\trunID := args[0]\n   348→\n   349→\tfor i := 1; i < len(args); i++ {\n   350→\t\tswitch args[i] {\n   351→\t\tcase \"--step\":\n   352→\t\t\tif i+1 < len(args) {\n   353→\t\t\t\ti++\n   354→\t\t\t\tstepFilter = args[i]\n   355→\t\t\t}\n   356→\t\tcase \"--type\":\n   357→\t\t\tif i+1 < len(args) {\n   358→\t\t\t\ti++\n   359→\t\t\t\ttypeFilter = args[i]\n   360→\t\t\t}\n   361→\t\tcase \"--follow\", \"-f\":\n   362→\t\t\tfollow = true\n   363→\t\t}\n   364→\t}\n   365→\n   366→\t// Use background context — log output can be large and follow mode blocks.\n   367→\tctx := context.Background()\n   368→\tif follow {\n   369→\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n   370→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   371→\t}\n   372→\n   373→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   374→\t\tRunId:    runID,\n   375→\t\tStepName: stepFilter,\n   376→\t\tLogType:  typeFilter,\n   377→\t})\n   378→\tif err != nil {\n   379→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   380→\t\tos.Exit(1)\n   381→\t}\n   382→\n   383→\tfor {\n   384→\t\tentry, err := stream.Recv()\n   385→\t\tif err != nil {\n   386→\t\t\tif errors.Is(err, io.EOF) {\n   387→\t\t\t\tbreak\n   388→\t\t\t}\n   389→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   390→\t\t\tos.Exit(1)\n   391→\t\t}\n   392→\n   393→\t\tswitch entry.Type {\n   394→\t\tcase \"step_started\":\n   395→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   396→\t\t\tif entry.Message != \"\" {\n   397→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   398→\t\t\t}\n   399→\t\tcase \"step_completed\":\n   400→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   401→\t\t\tif entry.Message != \"\" {\n   402→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   403→\t\t\t}\n   404→\t\tcase \"run_completed\":\n   405→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   406→\t\t\tif entry.Message != \"\" {\n   407→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   408→\t\t\t}\n   409→\t\tcase \"full_log\":\n   410→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   411→\t\tcase \"log\":\n   412→\t\t\t// Live-streamed log line from an active run.\n   413→\t\t\tfmt.Println(entry.Message)\n   414→\t\tdefault:\n   415→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   416→\t\t\tif entry.StepName != \"\" {\n   417→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   418→\t\t\t}\n   419→\t\t\tif entry.Message != \"\" {\n   420→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   421→\t\t\t}\n   422→\t\t}\n   423→\t}\n   424→}\n   425→\n   426→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   427→\tif len(args) < 1 {\n   428→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   429→\t\tos.Exit(1)\n   430→\t}\n   431→\n   432→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   433→\tif err != nil {\n   434→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   435→\t\tos.Exit(1)\n   436→\t}\n   437→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   438→}\n   439→\n   440→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   441→\tif len(args) < 1 {\n   442→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   443→\t\tos.Exit(1)\n   444→\t}\n   445→\n   446→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   447→\tif err != nil {\n   448→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   449→\t\tos.Exit(1)\n   450→\t}\n   451→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   452→}\n   453→\n   454→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   455→\tcwd, _ := os.Getwd()\n   456→\n   457→\t// Check for \"stop\" subcommand\n   458→\tif len(args) > 0 && args[0] == \"stop\" {\n   459→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   460→\t\tif err != nil {\n   461→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   462→\t\t\tos.Exit(1)\n   463→\t\t}\n   464→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   465→\t\treturn\n   466→\t}\n   467→\n   468→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   469→\tvar maxConcurrent int32\n   470→\tfor i := 0; i < len(args); i++ {\n   471→\t\tswitch args[i] {\n   472→\t\tcase \"--max\":\n   473→\t\t\tif i+1 < len(args) {\n   474→\t\t\t\ti++\n   475→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   476→\t\t\t\tif n != 1 || err != nil {\n   477→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   478→\t\t\t\t\tos.Exit(1)\n   479→\t\t\t\t}\n   480→\t\t\t}\n   481→\t\t}\n   482→\t}\n   483→\n   484→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   485→\t\tProjectDir:    cwd,\n   486→\t\tMaxConcurrent: maxConcurrent,\n   487→\t})\n   488→\tif err != nil {\n   489→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   490→\t\tos.Exit(1)\n   491→\t}\n   492→\tif maxConcurrent > 0 {\n   493→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   494→\t} else {\n   495→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   496→\t}\n   497→}\n   498→\n   499→func cmdTasks(args []string) {\n   500→\t// Determine HTTP address from env\n   501→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   502→\tif httpAddr == \"\" {\n   503→\t\thttpAddr = \"localhost:8080\"\n   504→\t}\n   505→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   506→\n   507→\t// Determine project label from --project flag or current directory\n   508→\tprojectDir := \"\"\n   509→\tfor i := 0; i < len(args); i++ {\n   510→\t\tswitch args[i] {\n   511→\t\tcase \"--project\":\n   512→\t\t\tif i+1 < len(args) {\n   513→\t\t\t\ti++\n   514→\t\t\t\tprojectDir = args[i]\n   515→\t\t\t}\n   516→\t\t}\n   517→\t}\n   518→\n   519→\tif projectDir == \"\" {\n   520→\t\tcwd, _ := os.Getwd()\n   521→\t\tprojectDir = filepath.Base(cwd)\n   522→\t}\n   523→\n   524→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   525→\tresp, err := http.Get(tasksURL)\n   526→\tif err != nil {\n   527→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   528→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   529→\t\tos.Exit(1)\n   530→\t}\n   531→\tdefer resp.Body.Close()\n   532→\n   533→\tif resp.StatusCode != 200 {\n   534→\t\tbody, _ := io.ReadAll(resp.Body)\n   535→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   536→\t\tos.Exit(1)\n   537→\t}\n   538→\n   539→\ttype taskEntry struct {\n   540→\t\tID          string `json:\"id\"`\n   541→\t\tStatus      string `json:\"status\"`\n   542→\t\tTitle       string `json:\"title\"`\n   543→\t\tDescription string `json:\"description\"`\n   544→\t\tAssigned    bool   `json:\"assigned\"`\n   545→\t\tAssignedAt  string `json:\"assigned_at\"`\n   546→\t\tRunID       string `json:\"run_id\"`\n   547→\t}\n   548→\n   549→\tvar tasks []taskEntry\n   550→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   551→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   552→\t\tos.Exit(1)\n   553→\t}\n   554→\n   555→\tif len(tasks) == 0 {\n   556→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   557→\t\treturn\n   558→\t}\n   559→\n   560→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   561→\tfor _, t := range tasks {\n   562→\t\tstatus := t.Status\n   563→\t\tif status == \"\" {\n   564→\t\t\tstatus = \"open\"\n   565→\t\t}\n   566→\t\tassigned := \"-\"\n   567→\t\tif t.Assigned {\n   568→\t\t\tassigned = \"yes\"\n   569→\t\t}\n   570→\t\trunID := \"\"\n   571→\t\tif t.RunID != \"\" {\n   572→\t\t\trunID = t.RunID\n   573→\t\t\tif len(runID) > 30 {\n   574→\t\t\t\trunID = runID[:27] + \"...\"\n   575→\t\t\t}\n   576→\t\t}\n   577→\t\ttitle := t.Title\n   578→\t\tif len(title) > 40 {\n   579→\t\t\ttitle = title[:37] + \"...\"\n   580→\t\t}\n   581→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   582→\t}\n   583→}\n   584→\n   585→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   586→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   587→\tif err != nil {\n   588→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   589→\t\tos.Exit(1)\n   590→\t}\n   591→\tfmt.Println(\"Daemon shutting down.\")\n   592→}\n   593→\n   594→// resolveRunContext returns the project directory and run ID for context\n   595→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   596→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   597→func resolveRunContext() (projectDir, runID string, err error) {\n   598→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   599→\tif runID == \"\" {\n   600→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   601→\t}\n   602→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   603→\tif projectDir == \"\" {\n   604→\t\tprojectDir, err = os.Getwd()\n   605→\t\tif err != nil {\n   606→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   607→\t\t}\n   608→\t}\n   609→\treturn projectDir, runID, nil\n   610→}\n   611→\n   612→func cmdGet(args []string) {\n   613→\tif len(args) < 1 {\n   614→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   615→\t\tos.Exit(1)\n   616→\t}\n   617→\n   618→\tprojectDir, runID, err := resolveRunContext()\n   619→\tif err != nil {\n   620→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   621→\t\tos.Exit(1)\n   622→\t}\n   623→\n   624→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   625→\tif err != nil {\n   626→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   627→\t\tos.Exit(1)\n   628→\t}\n   629→\tif !ok {\n   630→\t\tos.Exit(1)\n   631→\t}\n   632→\tfmt.Println(val)\n   633→}\n   634→\n   635→func cmdSet(args []string) {\n   636→\tif len(args) < 2 {\n   637→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   638→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   639→\t\tos.Exit(1)\n   640→\t}\n   641→\n   642→\tprojectDir, runID, err := resolveRunContext()\n   643→\tif err != nil {\n   644→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   645→\t\tos.Exit(1)\n   646→\t}\n   647→\n   648→\tvalue := args[1]\n   649→\tif value == \"-\" {\n   650→\t\tdata, err := io.ReadAll(os.Stdin)\n   651→\t\tif err != nil {\n   652→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   653→\t\t\tos.Exit(1)\n   654→\t\t}\n   655→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   656→\t}\n   657→\n   658→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   659→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   660→\t\tos.Exit(1)\n   661→\t}\n   662→}\n   663→"}]},"parent_tool_use_id":null,"session_id":"8a8a233a-9bc4-4d5b-81f2-86c5b6995110","uuid":"012ba742-f348-4456-ac83-79e29759c883","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n\n\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n\tswitch os.Args[1] {\n\tcase \"help\":\n\t\tprintHelp(os.Args[2:])\n\t\treturn\n\tcase \"--help\", \"-h\":\n\t\tprintTopLevelHelp()\n\t\treturn\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"init\")\n\t\t\treturn\n\t\t}\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"health\")\n\t\t\treturn\n\t\t}\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\tcase \"get\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"get\")\n\t\t\treturn\n\t\t}\n\t\tcmdGet(os.Args[2:])\n\t\treturn\n\tcase \"set\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"set\")\n\t\t\treturn\n\t\t}\n\t\tcmdSet(os.Args[2:])\n\t\treturn\n\tcase \"tasks\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"tasks\")\n\t\t\treturn\n\t\t}\n\t\tcmdTasks(os.Args[2:])\n\t\treturn\n\tcase \"workflow\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"workflow\")\n\t\t\treturn\n\t\t}\n\t\tcmdWorkflow(os.Args[2:])\n\t\treturn\n\tcase \"project\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"project\")\n\t\t\treturn\n\t\t}\n\t\tcmdProject(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Handle --help for daemon commands before connecting\n\tdaemonCmds := map[string]bool{\n\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n\t}\n\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n\t\tprintSubcommandHelp(os.Args[1])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client)\n\tdefault:\n\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n}\n\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n\tvar image string\n\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n\tif data, err := os.ReadFile(wfPath); err == nil {\n\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n\t\t\timage = wf.Config[\"container.image\"]\n\t\t}\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tvar projectDir, stateFilter, issueFilter string\n\tvar limit int32\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--all\":\n\t\t\tall = true\n\t\tcase \"--project\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\tcase \"--state\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstateFilter = args[i]\n\t\t\t}\n\t\tcase \"--limit\", \"-n\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = int32(n)\n\t\t\t}\n\t\tcase \"--issue\", \"-i\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tissueFilter = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\treq := &pb.ListRunsRequest{\n\t\tState:  stateFilter,\n\t\tLimit:  limit,\n\t\tTaskId: issueFilter,\n\t}\n\tif projectDir != \"\" {\n\t\treq.ProjectDir = projectDir\n\t} else if all {\n\t\treq.All = true\n\t} else {\n\t\t// Default: filter to current project\n\t\tcwd, _ := os.Getwd()\n\t\treq.ProjectDir = cwd\n\t}\n\n\tresp, err := client.ListRuns(ctx, req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n\t\tif run.Title != \"\" {\n\t\t\tt := run.Title\n\t\t\tif len(t) > 40 {\n\t\t\t\tt = t[:37] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + t\n\t\t}\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\t}\n\t}\n\n\t// Use background context — log output can be large and follow mode blocks.\n\tctx := context.Background()\n\tif follow {\n\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n\t\tctx = metadata.NewOutgoingContext(ctx, md)\n\t}\n\n\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdTasks(args []string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\t// Determine project label from --project flag or current directory\n\tprojectDir := \"\"\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tcwd, _ := os.Getwd()\n\t\tprojectDir = filepath.Base(cwd)\n\t}\n\n\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n\tresp, err := http.Get(tasksURL)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\ttype taskEntry struct {\n\t\tID          string `json:\"id\"`\n\t\tStatus      string `json:\"status\"`\n\t\tTitle       string `json:\"title\"`\n\t\tDescription string `json:\"description\"`\n\t\tAssigned    bool   `json:\"assigned\"`\n\t\tAssignedAt  string `json:\"assigned_at\"`\n\t\tRunID       string `json:\"run_id\"`\n\t}\n\n\tvar tasks []taskEntry\n\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(tasks) == 0 {\n\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n\t\treturn\n\t}\n\n\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n\tfor _, t := range tasks {\n\t\tstatus := t.Status\n\t\tif status == \"\" {\n\t\t\tstatus = \"open\"\n\t\t}\n\t\tassigned := \"-\"\n\t\tif t.Assigned {\n\t\t\tassigned = \"yes\"\n\t\t}\n\t\trunID := \"\"\n\t\tif t.RunID != \"\" {\n\t\t\trunID = t.RunID\n\t\t\tif len(runID) > 30 {\n\t\t\t\trunID = runID[:27] + \"...\"\n\t\t\t}\n\t\t}\n\t\ttitle := t.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n\n// resolveRunContext returns the project directory and run ID for context\n// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n// from CLOCHE_PROJECT_DIR (falling back to cwd).\nfunc resolveRunContext() (projectDir, runID string, err error) {\n\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n\tif runID == \"\" {\n\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n\t}\n\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n\tif projectDir == \"\" {\n\t\tprojectDir, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n\t\t}\n\t}\n\treturn projectDir, runID, nil\n}\n\nfunc cmdGet(args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif !ok {\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(val)\n}\n\nfunc cmdSet(args []string) {\n\tif len(args) < 2 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvalue := args[1]\n\tif value == \"-\" {\n\t\tdata, err := io.ReadAll(os.Stdin)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n\t}\n\n\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n","numLines":663,"startLine":1,"totalLines":663}}}
