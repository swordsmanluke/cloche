{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015FhahQxkjN2kvDYNWKKDej","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# Default prompt generator.\n     3→# Writes a JSON object with the task prompt and metadata to stdout and to\n     4→# $CLOCHE_STEP_OUTPUT.  Downstream wire mappings can extract individual fields.\n     5→set -euo pipefail\n     6→\n     7→task_id=\"${CLOCHE_TASK_ID:-}\"\n     8→task_title=\"${CLOCHE_TASK_TITLE:-}\"\n     9→task_body=\"${CLOCHE_TASK_BODY:-}\"\n    10→\n    11→if [ -z \"$task_title\" ]; then\n    12→  echo \"error: CLOCHE_TASK_TITLE is not set\" >&2\n    13→  exit 1\n    14→fi\n    15→\n    16→prompt=\"## Task: ${task_title}\n    17→\n    18→${task_body}\"\n    19→\n    20→output=$(jq -n \\\n    21→  --arg prompt \"$prompt\" \\\n    22→  --arg task_id \"$task_id\" \\\n    23→  '{prompt: $prompt, task_id: $task_id}')\n    24→\n    25→echo \"$output\"\n    26→[ -n \"${CLOCHE_STEP_OUTPUT:-}\" ] && echo \"$output\" > \"$CLOCHE_STEP_OUTPUT\"\n    27→"}]},"parent_tool_use_id":null,"session_id":"3fb2401a-6b6a-4fd9-9eca-7aeee6bcc4bd","uuid":"c54e26b7-8abd-4c72-b01c-1536b8dc1d6a","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.cloche/scripts/prepare-prompt.sh","content":"#!/usr/bin/env bash\n# Default prompt generator.\n# Writes a JSON object with the task prompt and metadata to stdout and to\n# $CLOCHE_STEP_OUTPUT.  Downstream wire mappings can extract individual fields.\nset -euo pipefail\n\ntask_id=\"${CLOCHE_TASK_ID:-}\"\ntask_title=\"${CLOCHE_TASK_TITLE:-}\"\ntask_body=\"${CLOCHE_TASK_BODY:-}\"\n\nif [ -z \"$task_title\" ]; then\n  echo \"error: CLOCHE_TASK_TITLE is not set\" >&2\n  exit 1\nfi\n\nprompt=\"## Task: ${task_title}\n\n${task_body}\"\n\noutput=$(jq -n \\\n  --arg prompt \"$prompt\" \\\n  --arg task_id \"$task_id\" \\\n  '{prompt: $prompt, task_id: $task_id}')\n\necho \"$output\"\n[ -n \"${CLOCHE_STEP_OUTPUT:-}\" ] && echo \"$output\" > \"$CLOCHE_STEP_OUTPUT\"\n","numLines":27,"startLine":1,"totalLines":27}}}
