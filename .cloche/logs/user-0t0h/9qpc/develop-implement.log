{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014bz2QiUvQyrdYQKXNfepE1","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# merge-to-main.sh — Rebase a cloche run branch onto main and fast-forward.\n     3→# Expects CLOCHE_PREV_OUTPUT to point to a file containing the run ID.\n     4→# On conflict, prefers main's version. On failure, preserves the branch.\n     5→set -euo pipefail\n     6→\n     7→if [ -z \"${CLOCHE_PREV_OUTPUT:-}\" ] || [ ! -f \"$CLOCHE_PREV_OUTPUT\" ]; then\n     8→  echo \"error: CLOCHE_PREV_OUTPUT not set or file missing\" >&2\n     9→  exit 1\n    10→fi\n    11→\n    12→RUN_ID=$(cat \"$CLOCHE_PREV_OUTPUT\" | tr -d '[:space:]')\n    13→BRANCH=\"cloche/${RUN_ID}\"\n    14→PROJECT_DIR=\"${CLOCHE_PROJECT_DIR:-.}\"\n    15→\n    16→export GIT_AUTHOR_NAME=cloche\n    17→export GIT_AUTHOR_EMAIL=cloche@local\n    18→export GIT_COMMITTER_NAME=cloche\n    19→export GIT_COMMITTER_EMAIL=cloche@local\n    20→\n    21→# Verify the branch exists\n    22→if ! git -C \"$PROJECT_DIR\" rev-parse --verify \"$BRANCH\" >/dev/null 2>&1; then\n    23→  echo \"error: branch $BRANCH does not exist\" >&2\n    24→  exit 1\n    25→fi\n    26→\n    27→WORKTREE_DIR=\"$PROJECT_DIR/.gitworktrees/merge/$RUN_ID\"\n    28→mkdir -p \"$(dirname \"$WORKTREE_DIR\")\"\n    29→\n    30→cleanup_worktree() {\n    31→  git -C \"$PROJECT_DIR\" worktree remove --force \"$WORKTREE_DIR\" 2>/dev/null || true\n    32→}\n    33→\n    34→# Create worktree at the feature branch\n    35→git -C \"$PROJECT_DIR\" worktree add \"$WORKTREE_DIR\" \"$BRANCH\"\n    36→\n    37→# Rebase onto main — fail on conflict rather than silently dropping changes\n    38→if ! git -C \"$WORKTREE_DIR\" rebase main; then\n    39→  echo \"error: rebase failed — branch $BRANCH preserved for review\" >&2\n    40→  git -C \"$WORKTREE_DIR\" rebase --abort 2>/dev/null || true\n    41→  cleanup_worktree\n    42→  exit 1\n    43→fi\n    44→\n    45→# Update the branch ref to the rebased result so main can fast-forward to it\n    46→REBASED_HEAD=$(git -C \"$WORKTREE_DIR\" rev-parse HEAD)\n    47→\n    48→# Remove the worktree before merging (git won't allow branch deletion while\n    49→# a worktree is attached)\n    50→cleanup_worktree\n    51→\n    52→# Update the branch ref to the rebased HEAD (worktree removal detaches it)\n    53→git -C \"$PROJECT_DIR\" update-ref \"refs/heads/$BRANCH\" \"$REBASED_HEAD\"\n    54→\n    55→# Fast-forward main, updating the working tree\n    56→git -C \"$PROJECT_DIR\" merge --ff-only \"$BRANCH\"\n    57→\n    58→# Delete the feature branch\n    59→git -C \"$PROJECT_DIR\" branch -D \"$BRANCH\" 2>/dev/null || echo \"warning: could not delete branch $BRANCH\" >&2\n    60→\n    61→echo \"Merged $BRANCH into main ($REBASED_HEAD)\"\n    62→"}]},"parent_tool_use_id":null,"session_id":"23f795de-0327-40d7-8a35-e0692b6daa7b","uuid":"f278cb2b-745e-4ea5-b7f1-4d137b01c6b6","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.cloche/scripts/merge-to-main.sh","content":"#!/usr/bin/env bash\n# merge-to-main.sh — Rebase a cloche run branch onto main and fast-forward.\n# Expects CLOCHE_PREV_OUTPUT to point to a file containing the run ID.\n# On conflict, prefers main's version. On failure, preserves the branch.\nset -euo pipefail\n\nif [ -z \"${CLOCHE_PREV_OUTPUT:-}\" ] || [ ! -f \"$CLOCHE_PREV_OUTPUT\" ]; then\n  echo \"error: CLOCHE_PREV_OUTPUT not set or file missing\" >&2\n  exit 1\nfi\n\nRUN_ID=$(cat \"$CLOCHE_PREV_OUTPUT\" | tr -d '[:space:]')\nBRANCH=\"cloche/${RUN_ID}\"\nPROJECT_DIR=\"${CLOCHE_PROJECT_DIR:-.}\"\n\nexport GIT_AUTHOR_NAME=cloche\nexport GIT_AUTHOR_EMAIL=cloche@local\nexport GIT_COMMITTER_NAME=cloche\nexport GIT_COMMITTER_EMAIL=cloche@local\n\n# Verify the branch exists\nif ! git -C \"$PROJECT_DIR\" rev-parse --verify \"$BRANCH\" >/dev/null 2>&1; then\n  echo \"error: branch $BRANCH does not exist\" >&2\n  exit 1\nfi\n\nWORKTREE_DIR=\"$PROJECT_DIR/.gitworktrees/merge/$RUN_ID\"\nmkdir -p \"$(dirname \"$WORKTREE_DIR\")\"\n\ncleanup_worktree() {\n  git -C \"$PROJECT_DIR\" worktree remove --force \"$WORKTREE_DIR\" 2>/dev/null || true\n}\n\n# Create worktree at the feature branch\ngit -C \"$PROJECT_DIR\" worktree add \"$WORKTREE_DIR\" \"$BRANCH\"\n\n# Rebase onto main — fail on conflict rather than silently dropping changes\nif ! git -C \"$WORKTREE_DIR\" rebase main; then\n  echo \"error: rebase failed — branch $BRANCH preserved for review\" >&2\n  git -C \"$WORKTREE_DIR\" rebase --abort 2>/dev/null || true\n  cleanup_worktree\n  exit 1\nfi\n\n# Update the branch ref to the rebased result so main can fast-forward to it\nREBASED_HEAD=$(git -C \"$WORKTREE_DIR\" rev-parse HEAD)\n\n# Remove the worktree before merging (git won't allow branch deletion while\n# a worktree is attached)\ncleanup_worktree\n\n# Update the branch ref to the rebased HEAD (worktree removal detaches it)\ngit -C \"$PROJECT_DIR\" update-ref \"refs/heads/$BRANCH\" \"$REBASED_HEAD\"\n\n# Fast-forward main, updating the working tree\ngit -C \"$PROJECT_DIR\" merge --ff-only \"$BRANCH\"\n\n# Delete the feature branch\ngit -C \"$PROJECT_DIR\" branch -D \"$BRANCH\" 2>/dev/null || echo \"warning: could not delete branch $BRANCH\" >&2\n\necho \"Merged $BRANCH into main ($REBASED_HEAD)\"\n","numLines":62,"startLine":1,"totalLines":62}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MtiwGJKSaAmbQ15eRMbHfQ","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# cleanup-run.sh — Remove the worktree and branch left over from a cloche run.\n     3→# Expects CLOCHE_PREV_OUTPUT to point to a file containing the run ID.\n     4→set -euo pipefail\n     5→\n     6→if [ -z \"${CLOCHE_PREV_OUTPUT:-}\" ] || [ ! -f \"$CLOCHE_PREV_OUTPUT\" ]; then\n     7→  echo \"error: CLOCHE_PREV_OUTPUT not set or file missing\" >&2\n     8→  exit 1\n     9→fi\n    10→\n    11→RUN_ID=$(cat \"$CLOCHE_PREV_OUTPUT\" | tr -d '[:space:]')\n    12→PROJECT_DIR=\"${CLOCHE_PROJECT_DIR:-.}\"\n    13→BRANCH=\"cloche/${RUN_ID}\"\n    14→WORKTREE_DIR=\"$PROJECT_DIR/.gitworktrees/cloche/$RUN_ID\"\n    15→\n    16→# Remove the extraction worktree if it still exists\n    17→if [ -d \"$WORKTREE_DIR\" ]; then\n    18→  git -C \"$PROJECT_DIR\" worktree remove --force \"$WORKTREE_DIR\" 2>/dev/null || true\n    19→fi\n    20→\n    21→# Prune any stale worktree bookkeeping\n    22→git -C \"$PROJECT_DIR\" worktree prune 2>/dev/null || true\n    23→\n    24→# Delete the branch if it still exists (merge may have already removed it)\n    25→if git -C \"$PROJECT_DIR\" rev-parse --verify \"$BRANCH\" >/dev/null 2>&1; then\n    26→  git -C \"$PROJECT_DIR\" branch -D \"$BRANCH\" 2>/dev/null || true\n    27→fi\n    28→\n    29→echo \"Cleaned up run $RUN_ID\"\n    30→"}]},"parent_tool_use_id":null,"session_id":"23f795de-0327-40d7-8a35-e0692b6daa7b","uuid":"0672ed90-e3ed-4061-9146-cd297f413023","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.cloche/scripts/cleanup-run.sh","content":"#!/usr/bin/env bash\n# cleanup-run.sh — Remove the worktree and branch left over from a cloche run.\n# Expects CLOCHE_PREV_OUTPUT to point to a file containing the run ID.\nset -euo pipefail\n\nif [ -z \"${CLOCHE_PREV_OUTPUT:-}\" ] || [ ! -f \"$CLOCHE_PREV_OUTPUT\" ]; then\n  echo \"error: CLOCHE_PREV_OUTPUT not set or file missing\" >&2\n  exit 1\nfi\n\nRUN_ID=$(cat \"$CLOCHE_PREV_OUTPUT\" | tr -d '[:space:]')\nPROJECT_DIR=\"${CLOCHE_PROJECT_DIR:-.}\"\nBRANCH=\"cloche/${RUN_ID}\"\nWORKTREE_DIR=\"$PROJECT_DIR/.gitworktrees/cloche/$RUN_ID\"\n\n# Remove the extraction worktree if it still exists\nif [ -d \"$WORKTREE_DIR\" ]; then\n  git -C \"$PROJECT_DIR\" worktree remove --force \"$WORKTREE_DIR\" 2>/dev/null || true\nfi\n\n# Prune any stale worktree bookkeeping\ngit -C \"$PROJECT_DIR\" worktree prune 2>/dev/null || true\n\n# Delete the branch if it still exists (merge may have already removed it)\nif git -C \"$PROJECT_DIR\" rev-parse --verify \"$BRANCH\" >/dev/null 2>&1; then\n  git -C \"$PROJECT_DIR\" branch -D \"$BRANCH\" 2>/dev/null || true\nfi\n\necho \"Cleaned up run $RUN_ID\"\n","numLines":30,"startLine":1,"totalLines":30}}}
