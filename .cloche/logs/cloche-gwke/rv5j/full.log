ected 0 active runs, got:\\n%s\", out)\n   200→\t}\n   201→\tif !strings.Contains(out, \"2 / 2 succeeded\") {\n   202→\t\tt.Errorf(\"expected 2/2 succeeded, got:\\n%s\", out)\n   203→\t}\n   204→}\n   205→\n   206→func TestFormatDuration(t *testing.T) {\n   207→\ttests := []struct {\n   208→\t\tname     string\n   209→\t\tinput    string\n   210→\t\tcontains string\n   211→\t}{\n   212→\t\t{\"invalid\", \"not-a-date\", \"not-a-date\"},\n   213→\t}\n   214→\tfor _, tt := range tests {\n   215→\t\tt.Run(tt.name, func(t *testing.T) {\n   216→\t\t\tgot := formatDuration(tt.input)\n   217→\t\t\tif !strings.Contains(got, tt.contains) {\n   218→\t\t\t\tt.Errorf(\"formatDuration(%q) = %q, want containing %q\", tt.input, got, tt.contains)\n   219→\t\t\t}\n   220→\t\t})\n   221→\t}\n   222→}\n   223→\n   224→func TestStatusHelpText(t *testing.T) {\n   225→\ttext, ok := subcommandHelp[\"status\"]\n   226→\tif !ok {\n   227→\t\tt.Fatal(\"missing help text for status subcommand\")\n   228→\t}\n   229→\tif !strings.Contains(text, \"--all\") {\n   230→\t\tt.Error(\"status help should mention --all flag\")\n   231→\t}\n   232→\tif !strings.Contains(text, \"daemon status\") {\n   233→\t\tt.Error(\"status help should mention daemon status overview\")\n   234→\t}\n   235→}\n   236→"}]},"parent_tool_use_id":"toolu_017YkHPD2WmmpmoLQEEpxtgG","session_id":"65bc676b-72d7-4782-b6ab-9d19356a227f","uuid":"8838edfb-0989-4799-85a1-b6e51ba2c221","timestamp":"2026-03-17T15:50:38.499Z"}
