{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K7gjWtkZjiTWGEmmdyQXc6","type":"tool_result","content":"diff --git a/cmd/cloche/main.go b/cmd/cloche/main.go\nindex d94321d..c395d91 100644\n--- a/cmd/cloche/main.go\n+++ b/cmd/cloche/main.go\n@@ -378,32 +378,21 @@ func cmdStatusProject(ctx context.Context, client pb.ClocheServiceClient, w io.W\n }\n \n func cmdStatusGlobal(ctx context.Context, client pb.ClocheServiceClient, w io.Writer) {\n-\t// Fetch all runs (server defaults to past hour when no project filter and not --all).\n-\t// We pass All=true but the server returns everything; we filter client-side to past hour.\n-\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: true})\n+\t// Server filters to past hour when All is not set.\n+\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{})\n \tif err != nil {\n \t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n \t\tos.Exit(1)\n \t}\n \n-\tvar succeeded, total, activeCount int\n+\tvar succeeded, activeCount int\n \ttype activeRun struct {\n \t\tid        string\n \t\tstartedAt string\n \t}\n \tvar actives []activeRun\n \n-\toneHourAgo := time.Now().Add(-1 * time.Hour)\n \tfor _, run := range listResp.Runs {\n-\t\tparsed, parseErr := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", run.StartedAt)\n-\t\tif parseErr != nil {\n-\t\t\t// Fall back: count all runs returned.\n-\t\t\tparsed = time.Time{}\n-\t\t}\n-\t\tif !parsed.IsZero() && parsed.Before(oneHourAgo) {\n-\t\t\tcontinue\n-\t\t}\n-\t\ttotal++\n \t\tif run.State == \"succeeded\" {\n \t\t\tsucceeded++\n \t\t}\n@@ -413,7 +402,7 @@ func cmdStatusGlobal(ctx context.Context, client pb.ClocheServiceClient, w io.Wr\n \t\t}\n \t}\n \n-\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, total)\n+\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n \tfmt.Fprintf(w, \"Active runs: %d\\n\", activeCount)\n \tfor _, a := range actives {\n \t\tdur := formatDuration(a.startedAt)\ndiff --git a/internal/adapters/grpc/server.go b/internal/adapters/grpc/server.go\nindex f03ca74..8edefd5 100644\n--- a/internal/adapters/grpc/server.go\n+++ b/internal/adapters/grpc/server.go\n@@ -589,8 +589,8 @@ func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*\n \t\tLimit:      int(req.Limit),\n \t}\n \n-\t// When no project filter and not --all, default to last hour\n-\tif filter.ProjectDir == \"\" && !req.All {\n+\t// Unless --all is set, default to last hour\n+\tif !req.All {\n \t\tfilter.Since = time.Now().Add(-1 * time.Hour)\n \t}\n \ndiff --git a/internal/adapters/sqlite/store.go b/internal/adapters/sqlite/store.go\nindex 7fd291f..af56044 100644\n--- a/internal/adapters/sqlite/store.go\n+++ b/internal/adapters/sqlite/store.go\n@@ -258,7 +258,7 @@ func (s *Store) ListRunsFiltered(ctx context.Context, filter domain.RunListFilte\n \t\targs = append(args, filter.TaskID)\n \t}\n \tif !filter.Since.IsZero() {\n-\t\tquery += ` AND started_at >= ?`\n+\t\tquery += ` AND (completed_at >= ? OR state IN ('running', 'pending'))`\n \t\targs = append(args, formatTime(filter.Since))\n \t}","is_error":false}]},"parent_tool_use_id":null,"session_id":"d23a26a9-4b14-45aa-b691-bc42bf4c11ee","uuid":"5edb4ddf-0a69-46b7-886e-1996ea967004","timestamp":"2026-03-17T15:57:12.108Z","tool_use_result":{"stdout":"diff --git a/cmd/cloche/main.go b/cmd/cloche/main.go\nindex d94321d..c395d91 100644\n--- a/cmd/cloche/main.go\n+++ b/cmd/cloche/main.go\n@@ -378,32 +378,21 @@ func cmdStatusProject(ctx context.Context, client pb.ClocheServiceClient, w io.W\n }\n \n func cmdStatusGlobal(ctx context.Context, client pb.ClocheServiceClient, w io.Writer) {\n-\t// Fetch all runs (server defaults to past hour when no project filter and not --all).\n-\t// We pass All=true but the server returns everything; we filter client-side to past hour.\n-\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: true})\n+\t// Server filters to past hour when All