[2026-03-05T03:44:00Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WkaNBkZ2s1V9cCHS56EMec","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"path/filepath\"\n    14→\t\"regexp\"\n    15→\t\"sort\"\n    16→\t\"time\"\n    17→\n    18→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    19→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    20→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    21→)\n    22→\n    23→// HandlerOption configures optional Handler dependencies.\n    24→type HandlerOption func(*Handler)\n    25→\n    26→// WithContainerLogger sets the container runtime for fetching live logs.\n    27→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    28→\treturn func(h *Handler) { h.container = c }\n    29→}\n    30→\n    31→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    32→func WithContainerManager(c ContainerManager) HandlerOption {\n    33→\treturn func(h *Handler) { h.container = c }\n    34→}\n    35→\n    36→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    37→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    38→\treturn func(h *Handler) { h.logBroadcast = b }\n    39→}\n    40→\n    41→// WithLogStore sets the log store for indexed log file lookups.\n    42→func WithLogStore(ls ports.LogStore) HandlerOption {\n    43→\treturn func(h *Handler) { h.logStore = ls }\n    44→}\n    45→\n    46→// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    47→func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    48→\treturn func(h *Handler) { h.orchestrateFn = fn }\n    49→}\n    50→\n    51→//go:embed templates/*.html static/*\n    52→var content embed.FS\n    53→\n    54→// Handler serves the web dashboard.\n    55→// ContainerLogger can retrieve logs from a container by ID.\n    56→type ContainerLogger interface {\n    57→\tLogs(ctx context.Context, containerID string) (string, error)\n    58→}\n    59→\n    60→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    61→type ContainerManager interface {\n    62→\tContainerLogger\n    63→\tRemove(ctx context.Context, containerID string) error\n    64→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    65→}\n    66→\n    67→type Handler struct {\n    68→\tstore         ports.RunStore\n    69→\tcaptures      ports.CaptureStore\n    70→\tlogStore      ports.LogStore\n    71→\tcontainer     ContainerLogger\n    72→\tlogBroadcast  *logstream.Broadcaster\n    73→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    74→\tpages         map[string]*template.Template\n    75→\tmux           *http.ServeMux\n    76→}\n    77→\n    78→// NewHandler creates a web dashboard handler.\n    79→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    80→\tfuncMap := template.FuncMap{\n    81→\t\t\"stateColor\":       stateColor,\n    82→\t\t\"healthColor\":      healthColor,\n    83→\t\t\"formatTime\":       formatTime,\n    84→\t\t\"formatDuration\":   formatDuration,\n    85→\t\t\"truncate\":         truncate,\n    86→\t\t\"shortContainerID\": shortContainerID,\n    87→\t}\n    88→\n    89→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n    90→\tif err != nil {\n    91→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n    92→\t}\n    93→\n    94→\tpages := map[string]*template.Template{}\n    95→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\"} {\n    96→\t\tclone, err := base.Clone()\n    97→\t\tif err != nil {\n    98→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n    99→\t\t}\n   100→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   101→\t\tif err != nil {\n   102→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   103→\t\t}\n   104→\t\tpages[page] = clone\n   105→\t}\n   106→\n   107→\th := &Handler{\n   108→\t\tstore:    store,\n   109→\t\tcaptures: captures,\n   110→\t\tpages:    pages,\n   111→\t\tmux:      http.NewServeMux(),\n   112→\t}\n   113→\tfor _, opt := range opts {\n   114→\t\topt(h)\n   115→\t}\n   116→\n   117→\tstaticFS, err := fs.Sub(content, \"static\")\n   118→\tif err != nil {\n   119→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   120→\t}\n   121→\n   122→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   123→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   124→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   125→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   126→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   127→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   128→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   129→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   130→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   131→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   132→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   133→\n   134→\treturn h, nil\n   135→}\n   136→\n   137→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   138→\th.mux.ServeHTTP(w, r)\n   139→}\n   140→\n   141→// --- HTML handlers ---\n   142→\n   143→// projectOverviewEntry holds data for a single project card on the landing page.\n   144→type projectOverviewEntry struct {\n   145→\tDir        string\n   146→\tLabel      string\n   147→\tHealth     domain.HealthResult\n   148→\tRecentRuns []recentRunDot\n   149→\tActiveCount int\n   150→}\n   151→\n   152→// recentRunDot is a minimal representation of a run for the mini history display.\n   153→type recentRunDot struct {\n   154→\tID    string\n   155→\tState string\n   156→}\n   157→\n   158→const healthWindowSize = 10\n   159→\n   160→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   161→\tprojects, _ := h.store.ListProjects(r.Context())\n   162→\tlabels := projectLabels(projects)\n   163→\n   164→\tvar entries []projectOverviewEntry\n   165→\tfor _, dir := range projects {\n   166→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   167→\t\tif err != nil {\n   168→\t\t\tcontinue\n   169→\t\t}\n   170→\n   171→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   172→\t\trunValues := make([]domain.Run, len(runs))\n   173→\t\tfor i, rr := range runs {\n   174→\t\t\trunValues[i] = *rr\n   175→\t\t}\n   176→\n   177→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   178→\n   179→\t\t// Take the last N runs for the mini history (most recent first).\n   180→\t\tn := healthWindowSize\n   181→\t\tif n > len(runs) {\n   182→\t\t\tn = len(runs)\n   183→\t\t}\n   184→\t\tdots := make([]recentRunDot, n)\n   185→\t\tfor i := 0; i < n; i++ {\n   186→\t\t\tdots[i] = recentRunDot{\n   187→\t\t\t\tID:    runs[i].ID,\n   188→\t\t\t\tState: string(runs[i].State),\n   189→\t\t\t}\n   190→\t\t}\n   191→\n   192→\t\tvar activeCount int\n   193→\t\tfor _, rr := range runs {\n   194→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   195→\t\t\t\tactiveCount++\n   196→\t\t\t}\n   197→\t\t}\n   198→\n   199→\t\tentries = append(entries, projectOverviewEntry{\n   200→\t\t\tDir:         dir,\n   201→\t\t\tLabel:       labels[dir],\n   202→\t\t\tHealth:      health,\n   203→\t\t\tRecentRuns:  dots,\n   204→\t\t\tActiveCount: activeCount,\n   205→\t\t})\n   206→\t}\n   207→\n   208→\tsort.Slice(entries, func(i, j int) bool {\n   209→\t\treturn entries[i].Label < entries[j].Label\n   210→\t})\n   211→\n   212→\tdata := map[string]any{\n   213→\t\t\"Title\":    \"Projects\",\n   214→\t\t\"Projects\": entries,\n   215→\t}\n   216→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   217→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   218→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   219→\t}\n   220→}\n   221→\n   222→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   223→\tprojectFilter := r.URL.Query().Get(\"project\")\n   224→\n   225→\tvar runs []*domain.Run\n   226→\tvar err error\n   227→\tif projectFilter != \"\" {\n   228→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   229→\t} else {\n   230→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   231→\t}\n   232→\tif err != nil {\n   233→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   234→\t\treturn\n   235→\t}\n   236→\n   237→\tprojects, _ := h.store.ListProjects(r.Context())\n   238→\tlabels := projectLabels(projects)\n   239→\n   240→\t// Count retained containers per project\n   241→\tcontainerCounts := map[string]int{}\n   242→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   243→\tfor _, run := range allRuns {\n   244→\t\tif run.ContainerKept {\n   245→\t\t\tcontainerCounts[run.ProjectDir]++\n   246→\t\t}\n   247→\t}\n   248→\n   249→\tvar projectList []projectEntry\n   250→\tfor _, dir := range projects {\n   251→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   252→\t}\n   253→\tsort.Slice(projectList, func(i, j int) bool {\n   254→\t\treturn projectList[i].Label < projectList[j].Label\n   255→\t})\n   256→\n   257→\tdata := map[string]any{\n   258→\t\t\"Title\":         \"Runs\",\n   259→\t\t\"Runs\":          runs,\n   260→\t\t\"Projects\":      projectList,\n   261→\t\t\"ProjectFilter\": projectFilter,\n   262→\t\t\"ProjectLabels\": labels,\n   263→\t}\n   264→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   265→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   266→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   267→\t}\n   268→}\n   269→\n   270→// stepEntry is a merged view of a step execution for the template.\n   271→type stepEntry struct {\n   272→\tIndex     int\n   273→\tStepName  string\n   274→\tResult    string\n   275→\tStartedAt time.Time\n   276→\tDuration  string\n   277→}\n   278→\n   279→// mergeCaptures collapses started/completed capture pairs into single entries.\n   280→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   281→\tvar entries []stepEntry\n   282→\t// Track pending started rows by step name (LIFO for retries)\n   283→\tpending := map[string]*domain.StepExecution{}\n   284→\n   285→\tfor _, c := range caps {\n   286→\t\tif c.Result == \"\" {\n   287→\t\t\t// step_started row\n   288→\t\t\tpending[c.StepName] = c\n   289→\t\t\tcontinue\n   290→\t\t}\n   291→\t\t// step_completed row — merge with pending started if available\n   292→\t\tstartedAt := c.StartedAt\n   293→\t\tif started := pending[c.StepName]; started != nil {\n   294→\t\t\tstartedAt = started.StartedAt\n   295→\t\t\tdelete(pending, c.StepName)\n   296→\t\t}\n   297→\t\tentries = append(entries, stepEntry{\n   298→\t\t\tIndex:     len(entries),\n   299→\t\t\tStepName:  c.StepName,\n   300→\t\t\tResult:    c.Result,\n   301→\t\t\tStartedAt: startedAt,\n   302→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   303→\t\t})\n   304→\t}\n   305→\n   306→\t// Append any started-but-not-completed steps (still running)\n   307→\tfor _, c := range caps {\n   308→\t\tif c.Result == \"\" {\n   309→\t\t\tif _, used := pending[c.StepName]; !used {\n   310→\t\t\t\tcontinue\n   311→\t\t\t}\n   312→\t\t\tentries = append(entries, stepEntry{\n   313→\t\t\t\tIndex:     len(entries),\n   314→\t\t\t\tStepName:  c.StepName,\n   315→\t\t\t\tStartedAt: c.StartedAt,\n   316→\t\t\t})\n   317→\t\t\tdelete(pending, c.StepName)\n   318→\t\t}\n   319→\t}\n   320→\n   321→\treturn entries\n   322→}\n   323→\n   324→// containerState inspects the container for a run and returns one of:\n   325→//   - \"running\"   – container exists and is running\n   326→//   - \"stopped\"   – container exists, not running, not kept\n   327→//   - \"available\" – container exists, not running, kept (can be deleted)\n   328→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   329→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   330→\tif run.ContainerID == \"\" {\n   331→\t\treturn \"removed\"\n   332→\t}\n   333→\tmgr, ok := h.container.(ContainerManager)\n   334→\tif !ok {\n   335→\t\treturn \"removed\"\n   336→\t}\n   337→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   338→\tif err != nil {\n   339→\t\treturn \"removed\"\n   340→\t}\n   341→\tif status.Running {\n   342→\t\treturn \"running\"\n   343→\t}\n   344→\tif run.ContainerKept {\n   345→\t\treturn \"available\"\n   346→\t}\n   347→\treturn \"stopped\"\n   348→}\n   349→\n   350→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   351→\tid := r.PathValue(\"id\")\n   352→\n   353→\trun, err := h.store.GetRun(r.Context(), id)\n   354→\tif err != nil {\n   355→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   356→\t\treturn\n   357→\t}\n   358→\n   359→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   360→\tif err != nil {\n   361→\t\tcaps = nil // non-fatal\n   362→\t}\n   363→\n   364→\tsteps := mergeCaptures(caps)\n   365→\n   366→\tdata := map[string]any{\n   367→\t\t\"Title\":          \"Run \" + run.ID,\n   368→\t\t\"Run\":            run,\n   369→\t\t\"Steps\":          steps,\n   370→\t\t\"Page\":           \"detail\",\n   371→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   372→\t}\n   373→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   374→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   375→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   376→\t}\n   377→}\n   378→\n   379→// --- JSON API handlers ---\n   380→\n   381→type apiRun struct {\n   382→\tID           string `json:\"id\"`\n   383→\tWorkflowName string `json:\"workflow_name\"`\n   384→\tProjectDir   string `json:\"project_dir\"`\n   385→\tProjectLabel string `json:\"project_label\"`\n   386→\tState        string `json:\"state\"`\n   387→\tStartedAt    string `json:\"started_at\"`\n   388→\tCompletedAt  string `json:\"completed_at\"`\n   389→\tContainerID  string `json:\"container_id\"`\n   390→\tErrorMessage string `json:\"error_message\"`\n   391→}\n   392→\n   393→type apiStep struct {\n   394→\tStepName    string `json:\"step_name\"`\n   395→\tResult      string `json:\"result\"`\n   396→\tStartedAt   string `json:\"started_at\"`\n   397→\tCompletedAt string `json:\"completed_at\"`\n   398→\tDuration    string `json:\"duration\"`\n   399→}\n   400→\n   401→type apiRunDetail struct {\n   402→\tapiRun\n   403→\tContainerState string    `json:\"container_state\"`\n   404→\tSteps          []apiStep `json:\"steps\"`\n   405→}\n   406→\n   407→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   408→\treturn apiRun{\n   409→\t\tID:           r.ID,\n   410→\t\tWorkflowName: r.WorkflowName,\n   411→\t\tProjectDir:   r.ProjectDir,\n   412→\t\tProjectLabel: labels[r.ProjectDir],\n   413→\t\tState:        string(r.State),\n   414→\t\tStartedAt:    formatTime(r.StartedAt),\n   415→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   416→\t\tContainerID:  r.ContainerID,\n   417→\t\tErrorMessage: r.ErrorMessage,\n   418→\t}\n   419→}\n   420→\n   421→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   422→\tprojectFilter := r.URL.Query().Get(\"project\")\n   423→\n   424→\tvar runs []*domain.Run\n   425→\tvar err error\n   426→\tif projectFilter != \"\" {\n   427→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   428→\t} else {\n   429→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   430→\t}\n   431→\tif err != nil {\n   432→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   433→\t\treturn\n   434→\t}\n   435→\n   436→\tprojects, _ := h.store.ListProjects(r.Context())\n   437→\tlabels := projectLabels(projects)\n   438→\n   439→\tresult := make([]apiRun, len(runs))\n   440→\tfor i, run := range runs {\n   441→\t\tresult[i] = toAPIRun(run, labels)\n   442→\t}\n   443→\n   444→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   445→\tjson.NewEncoder(w).Encode(result)\n   446→}\n   447→\n   448→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   449→\tprojects, err := h.store.ListProjects(r.Context())\n   450→\tif err != nil {\n   451→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   452→\t\treturn\n   453→\t}\n   454→\tlabels := projectLabels(projects)\n   455→\n   456→\ttype apiHealth struct {\n   457→\t\tStatus string `json:\"status\"`\n   458→\t\tPassed int    `json:\"passed\"`\n   459→\t\tFailed int    `json:\"failed\"`\n   460→\t\tTotal  int    `json:\"total\"`\n   461→\t}\n   462→\ttype apiProject struct {\n   463→\t\tDir         string    `json:\"dir\"`\n   464→\t\tLabel       string    `json:\"label\"`\n   465→\t\tHealth      apiHealth `json:\"health\"`\n   466→\t\tActiveCount int       `json:\"active_count\"`\n   467→\t}\n   468→\tresult := make([]apiProject, len(projects))\n   469→\tfor i, dir := range projects {\n   470→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   471→\t\trunValues := make([]domain.Run, len(runs))\n   472→\t\tfor j, rr := range runs {\n   473→\t\t\trunValues[j] = *rr\n   474→\t\t}\n   475→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   476→\t\tvar activeCount int\n   477→\t\tfor _, rr := range runs {\n   478→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   479→\t\t\t\tactiveCount++\n   480→\t\t\t}\n   481→\t\t}\n   482→\t\tresult[i] = apiProject{\n   483→\t\t\tDir:   dir,\n   484→\t\t\tLabel: labels[dir],\n   485→\t\t\tHealth: apiHealth{\n   486→\t\t\t\tStatus: string(health.Status),\n   487→\t\t\t\tPassed: health.Passed,\n   488→\t\t\t\tFailed: health.Failed,\n   489→\t\t\t\tTotal:  health.Total,\n   490→\t\t\t},\n   491→\t\t\tActiveCount: activeCount,\n   492→\t\t}\n   493→\t}\n   494→\n   495→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   496→\tjson.NewEncoder(w).Encode(result)\n   497→}\n   498→\n   499→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   500→\tid := r.PathValue(\"id\")\n   501→\n   502→\trun, err := h.store.GetRun(r.Context(), id)\n   503→\tif err != nil {\n   504→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   505→\t\treturn\n   506→\t}\n   507→\n   508→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   509→\tif err != nil {\n   510→\t\tcaps = nil\n   511→\t}\n   512→\n   513→\tprojects, _ := h.store.ListProjects(r.Context())\n   514→\tlabels := projectLabels(projects)\n   515→\n   516→\tmerged := mergeCaptures(caps)\n   517→\tsteps := make([]apiStep, len(merged))\n   518→\tfor i, e := range merged {\n   519→\t\tsteps[i] = apiStep{\n   520→\t\t\tStepName:  e.StepName,\n   521→\t\t\tResult:    e.Result,\n   522→\t\t\tStartedAt: formatTime(e.StartedAt),\n   523→\t\t\tDuration:  e.Duration,\n   524→\t\t}\n   525→\t}\n   526→\n   527→\tdetail := apiRunDetail{\n   528→\t\tapiRun:         toAPIRun(run, labels),\n   529→\t\tContainerState: h.containerState(r.Context(), run),\n   530→\t\tSteps:          steps,\n   531→\t}\n   532→\n   533→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   534→\tjson.NewEncoder(w).Encode(detail)\n   535→}\n   536→\n   537→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   538→\tid := r.PathValue(\"id\")\n   539→\tstep := r.PathValue(\"step\")\n   540→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   541→\n   542→\trun, err := h.store.GetRun(r.Context(), id)\n   543→\tif err != nil {\n   544→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   545→\t\treturn\n   546→\t}\n   547→\n   548→\t// Try log index first for fast lookup\n   549→\tif h.logStore != nil {\n   550→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   551→\t\tif err == nil && len(logFiles) > 0 {\n   552→\t\t\t// If type filter specified, narrow results\n   553→\t\t\tfor _, lf := range logFiles {\n   554→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   555→\t\t\t\t\tcontinue\n   556→\t\t\t\t}\n   557→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   558→\t\t\t\tif readErr == nil && len(data) > 0 {\n   559→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   560→\t\t\t\t\tw.Write(data)\n   561→\t\t\t\t\treturn\n   562→\t\t\t\t}\n   563→\t\t\t}\n   564→\t\t}\n   565→\t}\n   566→\n   567→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   568→\n   569→\t// Fall back to file path conventions\n   570→\t// If type is \"llm\", try llm-<step>.log\n   571→\tif logType == \"llm\" {\n   572→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   573→\t\tdata, err := os.ReadFile(llmPath)\n   574→\t\tif err == nil && len(data) > 0 {\n   575→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   576→\t\t\tw.Write(data)\n   577→\t\t\treturn\n   578→\t\t}\n   579→\t}\n   580→\n   581→\t// Try per-step output first, fall back to container.log, then live docker logs\n   582→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   583→\tdata, err := os.ReadFile(outputPath)\n   584→\tif err == nil && len(data) > 0 {\n   585→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   586→\t\tw.Write(data)\n   587→\t\treturn\n   588→\t}\n   589→\n   590→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   591→\tdata, err = os.ReadFile(containerLog)\n   592→\tif err == nil && len(data) > 0 {\n   593→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   594→\t\tw.Write(data)\n   595→\t\treturn\n   596→\t}\n   597→\n   598→\t// Last resort: try live docker logs from still-existing container\n   599→\tif h.container != nil && run.ContainerID != \"\" {\n   600→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   601→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   602→\t\t\tw.Write([]byte(logs))\n   603→\t\t\treturn\n   604→\t\t}\n   605→\t}\n   606→\n   607→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   608→}\n   609→\n   610→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   611→\tid := r.PathValue(\"id\")\n   612→\n   613→\trun, err := h.store.GetRun(r.Context(), id)\n   614→\tif err != nil {\n   615→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   616→\t\tw.WriteHeader(http.StatusNotFound)\n   617→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   618→\t\treturn\n   619→\t}\n   620→\n   621→\tmgr, ok := h.container.(ContainerManager)\n   622→\tif !ok || run.ContainerID == \"\" {\n   623→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   624→\t\tw.WriteHeader(http.StatusBadRequest)\n   625→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   626→\t\treturn\n   627→\t}\n   628→\n   629→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   630→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   631→\t\tw.WriteHeader(http.StatusInternalServerError)\n   632→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   633→\t\treturn\n   634→\t}\n   635→\n   636→\trun.ContainerKept = false\n   637→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   638→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   639→\t\tw.WriteHeader(http.StatusInternalServerError)\n   640→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   641→\t\treturn\n   642→\t}\n   643→\n   644→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   645→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   646→}\n   647→\n   648→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   649→\tlabel := r.PathValue(\"name\")\n   650→\n   651→\t// Resolve label back to project directory via the store.\n   652→\tprojects, _ := h.store.ListProjects(r.Context())\n   653→\tlabels := projectLabels(projects)\n   654→\tvar projectDir string\n   655→\tfor dir, l := range labels {\n   656→\t\tif l == label {\n   657→\t\t\tprojectDir = dir\n   658→\t\t\tbreak\n   659→\t\t}\n   660→\t}\n   661→\tif projectDir == \"\" {\n   662→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   663→\t\tw.WriteHeader(http.StatusNotFound)\n   664→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   665→\t\treturn\n   666→\t}\n   667→\n   668→\tif h.orchestrateFn == nil {\n   669→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   670→\t\tw.WriteHeader(http.StatusNotImplemented)\n   671→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   672→\t\treturn\n   673→\t}\n   674→\n   675→\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   676→\tif err != nil {\n   677→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   678→\t\tw.WriteHeader(http.StatusInternalServerError)\n   679→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   680→\t\treturn\n   681→\t}\n   682→\n   683→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   684→\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   685→}\n   686→\n   687→// handleAPIStream serves an SSE stream of log lines for a run.\n   688→// For active runs, it subscribes to the live broadcaster.\n   689→// For completed runs, it serves the archived full.log then closes.\n   690→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   691→\tid := r.PathValue(\"id\")\n   692→\n   693→\trun, err := h.store.GetRun(r.Context(), id)\n   694→\tif err != nil {\n   695→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   696→\t\treturn\n   697→\t}\n   698→\n   699→\tflusher, ok := w.(http.Flusher)\n   700→\tif !ok {\n   701→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   702→\t\treturn\n   703→\t}\n   704→\n   705→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   706→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   707→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   708→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   709→\n   710→\tisComplete := run.State == domain.RunStateSucceeded ||\n   711→\t\trun.State == domain.RunStateFailed ||\n   712→\t\trun.State == domain.RunStateCancelled\n   713→\n   714→\tif isComplete {\n   715→\t\t// Serve archived full.log\n   716→\t\th.streamFullLog(w, flusher, run)\n   717→\t\t// Send done event\n   718→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   719→\t\tflusher.Flush()\n   720→\t\treturn\n   721→\t}\n   722→\n   723→\t// Active run: subscribe to live broadcaster\n   724→\tif h.logBroadcast == nil {\n   725→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   726→\t\treturn\n   727→\t}\n   728→\n   729→\tsub := h.logBroadcast.Subscribe(id)\n   730→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   731→\n   732→\tctx := r.Context()\n   733→\tfor {\n   734→\t\tselect {\n   735→\t\tcase <-ctx.Done():\n   736→\t\t\treturn\n   737→\t\tcase line, ok := <-sub.C:\n   738→\t\t\tif !ok {\n   739→\t\t\t\t// Stream finished (run completed)\n   740→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   741→\t\t\t\tflusher.Flush()\n   742→\t\t\t\treturn\n   743→\t\t\t}\n   744→\t\t\tdata, _ := json.Marshal(line)\n   745→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   746→\t\t\tflusher.Flush()\n   747→\t\t}\n   748→\t}\n   749→}\n   750→\n   751→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   752→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   753→\n   754→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   755→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   756→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   757→\tf, err := os.Open(logPath)\n   758→\tif err != nil {\n   759→\t\treturn\n   760→\t}\n   761→\tdefer f.Close()\n   762→\n   763→\tscanner := bufio.NewScanner(f)\n   764→\tfor scanner.Scan() {\n   765→\t\ttext := scanner.Text()\n   766→\t\tline := parseFullLogLine(text)\n   767→\t\tdata, _ := json.Marshal(line)\n   768→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   769→\t\tflusher.Flush()\n   770→\t}\n   771→}\n   772→\n   773→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   774→func parseFullLogLine(text string) logstream.LogLine {\n   775→\tm := logLineRegex.FindStringSubmatch(text)\n   776→\tif m == nil {\n   777→\t\treturn logstream.LogLine{\n   778→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   779→\t\t\tType:      \"script\",\n   780→\t\t\tContent:   text,\n   781→\t\t}\n   782→\t}\n   783→\treturn logstream.LogLine{\n   784→\t\tTimestamp: m[1],\n   785→\t\tType:      m[2],\n   786→\t\tContent:   m[3],\n   787→\t}\n   788→}\n   789→\n   790→// --- Template helpers ---\n   791→\n   792→func stateColor(state domain.RunState) string {\n   793→\tswitch state {\n   794→\tcase domain.RunStatePending:\n   795→\t\treturn \"pending\"\n   796→\tcase domain.RunStateRunning:\n   797→\t\treturn \"running\"\n   798→\tcase domain.RunStateSucceeded:\n   799→\t\treturn \"succeeded\"\n   800→\tcase domain.RunStateFailed:\n   801→\t\treturn \"failed\"\n   802→\tcase domain.RunStateCancelled:\n   803→\t\treturn \"cancelled\"\n   804→\tdefault:\n   805→\t\treturn \"pending\"\n   806→\t}\n   807→}\n   808→\n   809→func healthColor(status domain.HealthStatus) string {\n   810→\tswitch status {\n   811→\tcase domain.HealthGreen:\n   812→\t\treturn \"green\"\n   813→\tcase domain.HealthYellow:\n   814→\t\treturn \"yellow\"\n   815→\tcase domain.HealthRed:\n   816→\t\treturn \"red\"\n   817→\tcase domain.HealthBlue:\n   818→\t\treturn \"blue\"\n   819→\tdefault:\n   820→\t\treturn \"grey\"\n   821→\t}\n   822→}\n   823→\n   824→func formatTime(t time.Time) string {\n   825→\tif t.IsZero() {\n   826→\t\treturn \"\"\n   827→\t}\n   828→\treturn t.Format(\"2006-01-02 15:04:05\")\n   829→}\n   830→\n   831→func formatDuration(start, end time.Time) string {\n   832→\tif start.IsZero() || end.IsZero() {\n   833→\t\treturn \"\"\n   834→\t}\n   835→\td := end.Sub(start)\n   836→\tif d < time.Second {\n   837→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n   838→\t}\n   839→\tif d < time.Minute {\n   840→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n   841→\t}\n   842→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n   843→}\n   844→\n   845→func truncate(s string, n int) string {\n   846→\tif len(s) <= n {\n   847→\t\treturn s\n   848→\t}\n   849→\treturn s[:n] + \"...\"\n   850→}\n   851→\n   852→func shortContainerID(id string) string {\n   853→\tif len(id) > 12 {\n   854→\t\treturn id[:12]\n   855→\t}\n   856→\treturn id\n   857→}\n   858→\n   859→// projectLabels builds a mapping from full project directory paths to short\n   860→// display labels. Each label is the final directory component (e.g.\n   861→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n   862→// the same final name, the parent directory is prepended to disambiguate\n   863→// (e.g. \"foo/bar\" vs \"baz/bar\").\n   864→func projectLabels(dirs []string) map[string]string {\n   865→\tlabels := make(map[string]string, len(dirs))\n   866→\t// Group dirs by their base name to detect conflicts.\n   867→\tbyBase := map[string][]string{}\n   868→\tfor _, d := range dirs {\n   869→\t\tbase := filepath.Base(d)\n   870→\t\tbyBase[base] = append(byBase[base], d)\n   871→\t}\n   872→\tfor base, paths := range byBase {\n   873→\t\tif len(paths) == 1 {\n   874→\t\t\tlabels[paths[0]] = base\n   875→\t\t} else {\n   876→\t\t\tfor _, p := range paths {\n   877→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n   878→\t\t\t\tlabels[p] = parent + \"/\" + base\n   879→\t\t\t}\n   880→\t\t}\n   881→\t}\n   882→\treturn labels\n   883→}\n   884→\n   885→type projectEntry struct {\n   886→\tDir            string\n   887→\tLabel          string\n   888→\tContainerCount int\n   889→}\n   890→"}]},"parent_tool_use_id":null,"session_id":"37afa36f-7fb3-451e-b071-6a41f6fd7f54","uuid":"d4adc8c2-57ac-45c2-ab56-1cbad8afa9c0","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\nfunc WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n\treturn func(h *Handler) { h.orchestrateFn = fn }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore         ports.RunStore\n\tcaptures      ports.CaptureStore\n\tlogStore      ports.LogStore\n\tcontainer     ContainerLogger\n\tlogBroadcast  *logstream.Broadcaster\n\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n\tpages         map[string]*template.Template\n\tmux           *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir        string\n\tLabel      string\n\tHealth     domain.HealthResult\n\tRecentRuns []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\n\t// Resolve label back to project directory via the store.\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tvar projectDir string\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\tprojectDir = dir\n\t\t\tbreak\n\t\t}\n\t}\n\tif projectDir == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\t\treturn\n\t}\n\n\tif h.orchestrateFn == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\n\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Template helpers ---\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":890,"startLine":1,"totalLines":890}}}
