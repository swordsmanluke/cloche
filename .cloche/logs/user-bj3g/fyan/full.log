.target;\n    42→    btn.disabled = true;\n    43→    btn.textContent = 'Triggering...';\n    44→    fetch('/api/projects/' + encodeURIComponent(label) + '/trigger', {method: 'POST'})\n    45→        .then(function(r) {\n    46→            if (r.ok) {\n    47→                r.json().then(function(data) {\n    48→                    if (data.dispatched > 0) {\n    49→                        btn.textContent = 'Dispatched ' + data.dispatched;\n    50→                    } else {\n    51→                        btn.textContent = 'No tasks ready';\n    52→                    }\n    53→                    setTimeout(function() {\n    54→                        btn.disabled = false;\n    55→                        btn.textContent = 'Trigger Orchestrator';\n    56→                    }, 2000);\n    57→                });\n    58→            } else {\n    59→                r.json().then(function(data) {\n    60→                    btn.textContent = 'Failed: ' + (data.error || 'unknown');\n    61→                }).catch(function() {\n    62→                    btn.textContent = 'Failed';\n    63→                });\n    64→                setTimeout(function() {\n    65→                    btn.disabled = false;\n    66→                    btn.textContent = 'Trigger Orchestrator';\n    67→                }, 4000);\n    68→            }\n    69→        })\n    70→        .catch(function() {\n    71→            btn.textContent = 'Failed';\n    72→            setTimeout(function() {\n    73→                btn.disabled = false;\n    74→                btn.textContent = 'Trigger Orchestrator';\n    75→            }, 2000);\n    76→        });\n    77→}\n    78→</script>\n    79→{{end}}\n    80→"}]},"parent_tool_use_id":null,"session_id":"37afa36f-7fb3-451e-b071-6a41f6fd7f54","uuid":"c4426a79-73ca-4468-8d6c-a30e722e1dfb","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/projects.html","content":"{{define \"content\"}}\n<h1>Projects</h1>\n{{if .Projects}}\n<div class=\"project-cards\">\n    {{range .Projects}}\n    <div class=\"project-card\">\n        <div class=\"project-header\">\n            <span class=\"health-dot health-{{healthColor .Health.Status}}\" title=\"{{.Health.Status}}\"></span>\n            <span class=\"project-name\">{{.Label}}</span>\n        </div>\n        <div class=\"project-stats\">\n            <div class=\"stat\">\n                <span class=\"stat-value\">{{.Health.Passed}}/{{.Health.Total}}</span>\n                <span class=\"stat-label\">recent passed</span>\n            </div>\n            <div class=\"stat\">\n                <span class=\"stat-value\">{{.ActiveCount}}</span>\n                <span class=\"stat-label\">active</span>\n            </div>\n        </div>\n        <div class=\"run-history\">\n            {{range .RecentRuns}}\n            <span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span>\n            {{end}}\n        </div>\n        <div class=\"project-actions\">\n            <a href=\"/runs?project={{.Dir}}\" class=\"btn btn-secondary\">View Runs</a>\n            <button class=\"btn btn-primary\" onclick=\"triggerOrchestrator('{{.Label}}', '{{.Dir}}')\">Trigger Orchestrator</button>\n        </div>\n    </div>\n    {{end}}\n</div>\n{{else}}\n<p class=\"empty\">No projects yet. Start a workflow run to see projects here.</p>\n{{end}}\n{{end}}\n\n{{define \"scripts\"}}\n<script>\nfunction triggerOrchestrator(label, dir) {\n    var btn = event.target;\n    btn.disabled = true;\n    btn.textContent = 'Triggering...';\n    fetch('/api/projects/' + encodeURIComponent(label) + '/trigger', {method: 'POST'})\n        .then(function(r) {\n            if (r.ok) {\n                r.json().then(function(data) {\n                    if (data.dispatched > 0) {\n                        btn.textContent = 'Dispatched ' + data.dispatched;\n                    } else {\n                        btn.textContent = 'No tasks ready';\n                    }\n                    setTimeout(function() {\n                        btn.disabled = false;\n                        btn.textContent = 'Trigger Orchestrator';\n                    }, 2000);\n                });\n            } else {\n                r.json().then(function(data) {\n                    btn.textContent = 'Failed: ' + (data.error || 'unknown');\n                }).catch(function() {\n                    btn.textContent = 'Failed';\n                });\n                setTimeout(function() {\n                    btn.disabled = false;\n                    btn.textContent = 'Trigger Orchestrator';\n                }, 4000);\n            }\n        })\n        .catch(function() {\n            btn.textContent = 'Failed';\n            setTimeout(function() {\n                btn.disabled = false;\n                btn.textContent = 'Trigger Orchestrator';\n            }, 2000);\n        });\n}\n</script>\n{{end}}\n","numLines":80,"startLine":1,"totalLines":80}}}
