":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\t// Read actual file contents\n\t\t\tcontent := \"\"\n\t\t\tfilePath := filepath.Join(dir, relPath)\n\t\t\tif data, err := os.ReadFile(filePath); err == nil {\n\t\t\t\tcontent = string(data)\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, Content: content, History: history})","numLines":40,"startLine":983,"totalLines":1308}}}
