{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VnT9YzH7Gen2BVFkPMa7uf","type":"tool_result","content":"     1→package prompt\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"bytes\"\n     6→\t\"context\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strconv\"\n    13→\t\"strings\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17→)\n    18→\n    19→// defaultAgentArgs maps known agent commands to their default arguments.\n    20→// Commands not in this map receive no default arguments (prompt on stdin only).\n    21→var defaultAgentArgs = map[string][]string{\n    22→\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n    23→}\n    24→\n    25→type Adapter struct {\n    26→\tCommands     []string // ordered fallback chain of agent commands\n    27→\tExplicitArgs []string // if non-nil, overrides default args for all commands\n    28→\tRunID        string\n    29→\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n    30→}\n    31→\n    32→func New() *Adapter {\n    33→\treturn &Adapter{\n    34→\t\tCommands: []string{\"claude\"},\n    35→\t}\n    36→}\n    37→\n    38→func (a *Adapter) Name() string {\n    39→\treturn \"prompt\"\n    40→}\n    41→\n    42→// argsFor returns the arguments for the given command. If ExplicitArgs is set,\n    43→// it is used for all commands. Otherwise, known agents get their default args.\n    44→func (a *Adapter) argsFor(command string) []string {\n    45→\tif a.ExplicitArgs != nil {\n    46→\t\treturn a.ExplicitArgs\n    47→\t}\n    48→\tif args, ok := defaultAgentArgs[command]; ok {\n    49→\t\treturn args\n    50→\t}\n    51→\treturn nil\n    52→}\n    53→\n    54→// ParseCommands splits a comma-separated agent_command string into individual\n    55→// command names, trimming whitespace from each entry.\n    56→func ParseCommands(s string) []string {\n    57→\tparts := strings.Split(s, \",\")\n    58→\tvar cmds []string\n    59→\tfor _, p := range parts {\n    60→\t\tp = strings.TrimSpace(p)\n    61→\t\tif p != \"\" {\n    62→\t\t\tcmds = append(cmds, p)\n    63→\t\t}\n    64→\t}\n    65→\treturn cmds\n    66→}\n    67→\n    68→func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    69→\t// Check attempt count for retry limiting\n    70→\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n    71→\t\tmax, err := strconv.Atoi(maxStr)\n    72→\t\tif err == nil {\n    73→\t\t\tcount := readAttemptCount(workDir, step.Name)\n    74→\t\t\tif count >= max {\n    75→\t\t\t\treturn \"give-up\", nil\n    76→\t\t\t}\n    77→\t\t}\n    78→\t}\n    79→\tincrementAttemptCount(workDir, step.Name)\n    80→\n    81→\t// Build the full prompt\n    82→\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n    83→\tif err != nil {\n    84→\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n    85→\t}\n    86→\n    87→\t// Try each command in the fallback chain\n    88→\tvar lastResult string\n    89→\tvar lastStdout []byte\n    90→\tvar lastErr error\n    91→\tran := false\n    92→\n    93→\tfor _, command := range a.Commands {\n    94→\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n    95→\t\tlastResult = result\n    96→\t\tlastStdout = stdout\n    97→\t\tlastErr = fallbackErr\n    98→\n    99→\t\tif fallbackErr == nil {\n   100→\t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n   101→\t\t\tbreak\n   102→\t\t}\n   103→\t\tif stdout != nil {\n   104→\t\t\tran = true\n   105→\t\t}\n   106→\t\t// Fallback-eligible — try next command\n   107→\t}\n   108→\n   109→\tif lastErr != nil && !ran && lastStdout == nil {\n   110→\t\t// All commands failed to produce any output (e.g., all not found)\n   111→\t\treturn \"\", lastErr\n   112→\t}\n   113→\n   114→\tresult := lastResult\n   115→\tif lastErr != nil {\n   116→\t\t// Last command in chain crashed without a result marker\n   117→\t\tresult = \"fail\"\n   118→\t}\n   119→\n   120→\t// Write output file\n   121→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   122→\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n   123→\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n   124→\t}\n   125→\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n   126→\treturn result, nil\n   127→}\n   128→\n   129→// tryCommand executes a single agent command and returns:\n   130→//   - result: the step result name (e.g. \"success\", \"fail\")\n   131→//   - stdout: captured stdout bytes\n   132→//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n   133→//\n   134→// Fallback-eligible conditions:\n   135→//   - Command not found or failed to start (stdout will be nil)\n   136→//   - Command exited non-zero without a CLOCHE_RESULT marker\n   137→//\n   138→// Definitive (non-fallback) conditions:\n   139→//   - Command exited 0\n   140→//   - Command exited non-zero but produced a CLOCHE_RESULT marker\n   141→func (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n   142→\targs := a.argsFor(command)\n   143→\tcmd := exec.CommandContext(ctx, command, args...)\n   144→\tcmd.Dir = workDir\n   145→\tcmd.Stdin = strings.NewReader(prompt)\n   146→\n   147→\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n   148→\tif a.StatusWriter == nil {\n   149→\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n   150→\t\tcmd.Stdout = &stdoutBuf\n   151→\t\tcmd.Stderr = &stderrBuf\n   152→\n   153→\t\trunErr := cmd.Run()\n   154→\t\tstdoutBytes := stdoutBuf.Bytes()\n   155→\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n   156→\t}\n   157→\n   158→\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n   159→\tpipe, err := cmd.StdoutPipe()\n   160→\tif err != nil {\n   161→\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n   162→\t}\n   163→\tcmd.Stderr = nil // discard stderr\n   164→\n   165→\tif err := cmd.Start(); err != nil {\n   166→\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n   167→\t}\n   168→\n   169→\t// textBuf accumulates extracted text content for result extraction.\n   170→\t// rawBuf accumulates raw stdout for the output log file.\n   171→\tvar textBuf, rawBuf bytes.Buffer\n   172→\t// lineBuf accumulates text deltas into lines for streaming.\n   173→\tvar lineBuf strings.Builder\n   174→\n   175→\tscanner := bufio.NewScanner(pipe)\n   176→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n   177→\tfor scanner.Scan() {\n   178→\t\traw := scanner.Bytes()\n   179→\t\trawBuf.Write(raw)\n   180→\t\trawBuf.WriteByte('\\n')\n   181→\n   182→\t\ttext := extractStreamText(raw)\n   183→\t\tif text == \"\" {\n   184→\t\t\tcontinue\n   185→\t\t}\n   186→\t\ttextBuf.WriteString(text)\n   187→\n   188→\t\t// Stream complete lines to StatusWriter as they form.\n   189→\t\tlineBuf.WriteString(text)\n   190→\t\tfor {\n   191→\t\t\ts := lineBuf.String()\n   192→\t\t\tidx := strings.IndexByte(s, '\\n')\n   193→\t\t\tif idx < 0 {\n   194→\t\t\t\tbreak\n   195→\t\t\t}\n   196→\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n   197→\t\t\tlineBuf.Reset()\n   198→\t\t\tlineBuf.WriteString(s[idx+1:])\n   199→\t\t}\n   200→\t}\n   201→\t// Flush any remaining partial line.\n   202→\tif lineBuf.Len() > 0 {\n   203→\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n   204→\t}\n   205→\tif scanErr := scanner.Err(); scanErr != nil {\n   206→\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n   207→\t}\n   208→\n   209→\twaitErr := cmd.Wait()\n   210→\t// Prefer extracted text (stream-json) for result classification; fall back\n   211→\t// to raw output for non-JSON commands (scripts, non-claude agents).\n   212→\tclassifyBuf := textBuf.Bytes()\n   213→\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n   214→\t\tclassifyBuf = rawBuf.Bytes()\n   215→\t}\n   216→\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n   217→\treturn result, rawBuf.Bytes(), fallbackErr\n   218→}\n   219→\n   220→// classifyResult interprets the command's exit status and stdout to determine\n   221→// the step result.\n   222→func (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n   223→\tif runErr != nil {\n   224→\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n   225→\t\t\t// Command failed to start (not found, permission denied, etc.)\n   226→\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n   227→\t\t}\n   228→\t\t// Command ran but exited non-zero\n   229→\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   230→\t\tif found {\n   231→\t\t\treturn markerResult, stdoutBytes, nil\n   232→\t\t}\n   233→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n   234→\t}\n   235→\n   236→\t// Command succeeded (exit 0)\n   237→\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n   238→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n   239→\t}\n   240→\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   241→\tresult := \"success\"\n   242→\tif found {\n   243→\t\tresult = markerResult\n   244→\t}\n   245→\treturn result, stdoutBytes, nil\n   246→}\n   247→\n   248→// extractStreamText parses a stream-json line and returns text content.\n   249→// It handles both content_block_delta (text_delta) events for streaming and\n   250→// result events for final output (which contains the CLOCHE_RESULT marker).\n   251→func extractStreamText(line []byte) string {\n   252→\t// Fast path: only parse lines that could contain text we care about.\n   253→\tif bytes.Contains(line, []byte(`\"text_delta\"`)) {\n   254→\t\tvar event struct {\n   255→\t\t\tType  string `json:\"type\"`\n   256→\t\t\tDelta struct {\n   257→\t\t\t\tType string `json:\"type\"`\n   258→\t\t\t\tText string `json:\"text\"`\n   259→\t\t\t} `json:\"delta\"`\n   260→\t\t}\n   261→\t\tif json.Unmarshal(line, &event) == nil &&\n   262→\t\t\tevent.Type == \"content_block_delta\" && event.Delta.Type == \"text_delta\" {\n   263→\t\t\treturn event.Delta.Text\n   264→\t\t}\n   265→\t}\n   266→\n   267→\t// Also extract the final result text (contains CLOCHE_RESULT marker).\n   268→\tif bytes.Contains(line, []byte(`\"result\"`)) && bytes.Contains(line, []byte(`\"subtype\"`)) {\n   269→\t\tvar event struct {\n   270→\t\t\tType   string `json:\"type\"`\n   271→\t\t\tResult string `json:\"result\"`\n   272→\t\t}\n   273→\t\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n   274→\t\t\treturn event.Result\n   275→\t\t}\n   276→\t}\n   277→\n   278→\treturn \"\"\n   279→}\n   280→\n   281→func assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n   282→\tvar parts []string\n   283→\n   284→\t// 1. Read system template from step config\n   285→\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n   286→\t\tcontent, err := resolveContent(tmpl, workDir)\n   287→\t\tif err != nil {\n   288→\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n   289→\t\t}\n   290→\t\tparts = append(parts, content)\n   291→\t}\n   292→\n   293→\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n   294→\tuserPrompt := readUserPrompt(workDir, runID)\n   295→\tif userPrompt != \"\" {\n   296→\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n   297→\t}\n   298→\n   299→\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n   300→\tif step.Config[\"feedback\"] == \"true\" {\n   301→\t\tfeedback := readFeedback(workDir)\n   302→\t\tif feedback != \"\" {\n   303→\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n   304→\t\t}\n   305→\t}\n   306→\n   307→\t// 4. Result selection instructions\n   308→\tif len(step.Results) > 0 {\n   309→\t\tvar resultLines []string\n   310→\t\tresultLines = append(resultLines, \"## Result Selection\")\n   311→\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n   312→\t\tfor _, r := range step.Results {\n   313→\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n   314→\t\t}\n   315→\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n   316→\t}\n   317→\n   318→\treturn strings.Join(parts, \"\\n\\n\"), nil\n   319→}\n   320→\n   321→// resolveContent handles file(\"path\") syntax or returns the string directly.\n   322→func resolveContent(value string, workDir string) (string, error) {\n   323→\t// Check for file(\"path\") syntax from DSL parser\n   324→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n   325→\t\tpath := value[6 : len(value)-2]\n   326→\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n   327→\t\tif err != nil {\n   328→\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n   329→\t\t}\n   330→\t\treturn string(data), nil\n   331→\t}\n   332→\treturn value, nil\n   333→}\n   334→\n   335→func readFeedback(workDir string) string {\n   336→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   337→\tentries, err := os.ReadDir(outputDir)\n   338→\tif err != nil {\n   339→\t\treturn \"\"\n   340→\t}\n   341→\n   342→\tvar parts []string\n   343→\tfor _, entry := range entries {\n   344→\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n   345→\t\t\tcontinue\n   346→\t\t}\n   347→\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n   348→\t\tif err != nil {\n   349→\t\t\tcontinue\n   350→\t\t}\n   351→\t\tcontent := strings.TrimSpace(string(data))\n   352→\t\tif content != \"\" {\n   353→\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n   354→\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n   355→\t\t}\n   356→\t}\n   357→\n   358→\treturn strings.Join(parts, \"\\n\\n\")\n   359→}\n   360→\n   361→func readAttemptCount(workDir, stepName string) int {\n   362→\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n   363→\tdata, err := os.ReadFile(path)\n   364→\tif err != nil {\n   365→\t\treturn 0\n   366→\t}\n   367→\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n   368→\treturn n\n   369→}\n   370→\n   371→// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\n   372→func readUserPrompt(workDir, runID string) string {\n   373→\tif runID == \"\" {\n   374→\t\treturn \"\"\n   375→\t}\n   376→\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   377→\tif data, err := os.ReadFile(path); err == nil {\n   378→\t\treturn string(data)\n   379→\t}\n   380→\treturn \"\"\n   381→}\n   382→\n   383→func incrementAttemptCount(workDir, stepName string) {\n   384→\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n   385→\t_ = os.MkdirAll(dir, 0755)\n   386→\tcount := readAttemptCount(workDir, stepName) + 1\n   387→\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n   388→}\n   389→"}]},"parent_tool_use_id":"toolu_015sCCiwMXbpnk7XRXMqAL48","session_id":"cd1b14cf-06c4-4c38-9c6b-7ee6a915d4c8","uuid":"301a4842-d90a-41e8-9e96-ba3f458fd1dc"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CGmBmukT4CwpNPwMncvjDn","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"os/exec\"\n    14→\t\"path/filepath\"\n    15→\t\"regexp\"\n    16→\t\"sort\"\n    17→\t\"strconv\"\n    18→\t\"strings\"\n    19→\t\"time\"\n    20→\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→)\n    26→\n    27→// HandlerOption configures optional Handler dependencies.\n    28→type HandlerOption func(*Handler)\n    29→\n    30→// WithContainerLogger sets the container runtime for fetching live logs.\n    31→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32→\treturn func(h *Handler) { h.container = c }\n    33→}\n    34→\n    35→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36→func WithContainerManager(c ContainerManager) HandlerOption {\n    37→\treturn func(h *Handler) { h.container = c }\n    38→}\n    39→\n    40→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42→\treturn func(h *Handler) { h.logBroadcast = b }\n    43→}\n    44→\n    45→// WithLogStore sets the log store for indexed log file lookups.\n    46→func WithLogStore(ls ports.LogStore) HandlerOption {\n    47→\treturn func(h *Handler) { h.logStore = ls }\n    48→}\n    49→\n    50→// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    51→func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    52→\treturn func(h *Handler) { h.orchestrateFn = fn }\n    53→}\n    54→\n    55→// OrchestratorController provides per-project orchestrator control.\n    56→type OrchestratorController interface {\n    57→\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    58→\tSetEnabled(dir string, enabled bool)\n    59→\tSetConcurrency(dir string, concurrency int)\n    60→}\n    61→\n    62→// WithOrchestrator sets the orchestrator controller for project-level control.\n    63→func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    64→\treturn func(h *Handler) { h.orchestrator = oc }\n    65→}\n    66→\n    67→//go:embed templates/*.html static/*\n    68→var content embed.FS\n    69→\n    70→// Handler serves the web dashboard.\n    71→// ContainerLogger can retrieve logs from a container by ID.\n    72→type ContainerLogger interface {\n    73→\tLogs(ctx context.Context, containerID string) (string, error)\n    74→}\n    75→\n    76→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    77→type ContainerManager interface {\n    78→\tContainerLogger\n    79→\tRemove(ctx context.Context, containerID string) error\n    80→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    81→}\n    82→\n    83→type Handler struct {\n    84→\tstore         ports.RunStore\n    85→\tcaptures      ports.CaptureStore\n    86→\tlogStore      ports.LogStore\n    87→\tcontainer     ContainerLogger\n    88→\tlogBroadcast  *logstream.Broadcaster\n    89→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    90→\torchestrator  OrchestratorController\n    91→\tpages         map[string]*template.Template\n    92→\tmux           *http.ServeMux\n    93→}\n    94→\n    95→// NewHandler creates a web dashboard handler.\n    96→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    97→\tfuncMap := template.FuncMap{\n    98→\t\t\"stateColor\":       stateColor,\n    99→\t\t\"healthColor\":      healthColor,\n   100→\t\t\"formatTime\":       formatTime,\n   101→\t\t\"formatDuration\":   formatDuration,\n   102→\t\t\"truncate\":         truncate,\n   103→\t\t\"shortContainerID\": shortContainerID,\n   104→\t}\n   105→\n   106→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   107→\tif err != nil {\n   108→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   109→\t}\n   110→\n   111→\tpages := map[string]*template.Template{}\n   112→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   113→\t\tclone, err := base.Clone()\n   114→\t\tif err != nil {\n   115→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   116→\t\t}\n   117→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   118→\t\tif err != nil {\n   119→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   120→\t\t}\n   121→\t\tpages[page] = clone\n   122→\t}\n   123→\n   124→\th := &Handler{\n   125→\t\tstore:    store,\n   126→\t\tcaptures: captures,\n   127→\t\tpages:    pages,\n   128→\t\tmux:      http.NewServeMux(),\n   129→\t}\n   130→\tfor _, opt := range opts {\n   131→\t\topt(h)\n   132→\t}\n   133→\n   134→\tstaticFS, err := fs.Sub(content, \"static\")\n   135→\tif err != nil {\n   136→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   137→\t}\n   138→\n   139→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   140→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   141→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   142→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   143→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   144→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   145→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   146→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   147→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   148→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   149→\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   150→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   151→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   152→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   153→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   154→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   155→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   156→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   157→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   158→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   159→\n   160→\treturn h, nil\n   161→}\n   162→\n   163→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   164→\th.mux.ServeHTTP(w, r)\n   165→}\n   166→\n   167→// --- HTML handlers ---\n   168→\n   169→// projectOverviewEntry holds data for a single project card on the landing page.\n   170→type projectOverviewEntry struct {\n   171→\tDir         string\n   172→\tLabel       string\n   173→\tHealth      domain.HealthResult\n   174→\tRecentRuns  []recentRunDot\n   175→\tActiveCount int\n   176→}\n   177→\n   178→// recentRunDot is a minimal representation of a run for the mini history display.\n   179→type recentRunDot struct {\n   180→\tID    string\n   181→\tState string\n   182→}\n   183→\n   184→const healthWindowSize = 10\n   185→\n   186→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   187→\tprojects, _ := h.store.ListProjects(r.Context())\n   188→\tlabels := projectLabels(projects)\n   189→\n   190→\tvar entries []projectOverviewEntry\n   191→\tfor _, dir := range projects {\n   192→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   193→\t\tif err != nil {\n   194→\t\t\tcontinue\n   195→\t\t}\n   196→\n   197→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   198→\t\trunValues := make([]domain.Run, len(runs))\n   199→\t\tfor i, rr := range runs {\n   200→\t\t\trunValues[i] = *rr\n   201→\t\t}\n   202→\n   203→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   204→\n   205→\t\t// Take the last N runs for the mini history (most recent first).\n   206→\t\tn := healthWindowSize\n   207→\t\tif n > len(runs) {\n   208→\t\t\tn = len(runs)\n   209→\t\t}\n   210→\t\tdots := make([]recentRunDot, n)\n   211→\t\tfor i := 0; i < n; i++ {\n   212→\t\t\tdots[i] = recentRunDot{\n   213→\t\t\t\tID:    runs[i].ID,\n   214→\t\t\t\tState: string(runs[i].State),\n   215→\t\t\t}\n   216→\t\t}\n   217→\n   218→\t\tvar activeCount int\n   219→\t\tfor _, rr := range runs {\n   220→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   221→\t\t\t\tactiveCount++\n   222→\t\t\t}\n   223→\t\t}\n   224→\n   225→\t\tentries = append(entries, projectOverviewEntry{\n   226→\t\t\tDir:         dir,\n   227→\t\t\tLabel:       labels[dir],\n   228→\t\t\tHealth:      health,\n   229→\t\t\tRecentRuns:  dots,\n   230→\t\t\tActiveCount: activeCount,\n   231→\t\t})\n   232→\t}\n   233→\n   234→\tsort.Slice(entries, func(i, j int) bool {\n   235→\t\treturn entries[i].Label < entries[j].Label\n   236→\t})\n   237→\n   238→\tdata := map[string]any{\n   239→\t\t\"Title\":    \"Projects\",\n   240→\t\t\"Projects\": entries,\n   241→\t}\n   242→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   243→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   244→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   245→\t}\n   246→}\n   247→\n   248→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   249→\tprojectFilter := r.URL.Query().Get(\"project\")\n   250→\n   251→\tvar runs []*domain.Run\n   252→\tvar err error\n   253→\tif projectFilter != \"\" {\n   254→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   255→\t} else {\n   256→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   257→\t}\n   258→\tif err != nil {\n   259→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   260→\t\treturn\n   261→\t}\n   262→\n   263→\tprojects, _ := h.store.ListProjects(r.Context())\n   264→\tlabels := projectLabels(projects)\n   265→\n   266→\t// Count retained containers per project\n   267→\tcontainerCounts := map[string]int{}\n   268→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   269→\tfor _, run := range allRuns {\n   270→\t\tif run.ContainerKept {\n   271→\t\t\tcontainerCounts[run.ProjectDir]++\n   272→\t\t}\n   273→\t}\n   274→\n   275→\tvar projectList []projectEntry\n   276→\tfor _, dir := range projects {\n   277→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   278→\t}\n   279→\tsort.Slice(projectList, func(i, j int) bool {\n   280→\t\treturn projectList[i].Label < projectList[j].Label\n   281→\t})\n   282→\n   283→\tdata := map[string]any{\n   284→\t\t\"Title\":         \"Runs\",\n   285→\t\t\"Runs\":          runs,\n   286→\t\t\"Projects\":      projectList,\n   287→\t\t\"ProjectFilter\": projectFilter,\n   288→\t\t\"ProjectLabels\": labels,\n   289→\t}\n   290→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   291→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   292→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   293→\t}\n   294→}\n   295→\n   296→// stepEntry is a merged view of a step execution for the template.\n   297→type stepEntry struct {\n   298→\tIndex     int\n   299→\tStepName  string\n   300→\tResult    string\n   301→\tStartedAt time.Time\n   302→\tDuration  string\n   303→}\n   304→\n   305→// mergeCaptures collapses started/completed capture pairs into single entries.\n   306→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   307→\tvar entries []stepEntry\n   308→\t// Track pending started rows by step name (LIFO for retries)\n   309→\tpending := map[string]*domain.StepExecution{}\n   310→\n   311→\tfor _, c := range caps {\n   312→\t\tif c.Result == \"\" {\n   313→\t\t\t// step_started row\n   314→\t\t\tpending[c.StepName] = c\n   315→\t\t\tcontinue\n   316→\t\t}\n   317→\t\t// step_completed row — merge with pending started if available\n   318→\t\tstartedAt := c.StartedAt\n   319→\t\tif started := pending[c.StepName]; started != nil {\n   320→\t\t\tstartedAt = started.StartedAt\n   321→\t\t\tdelete(pending, c.StepName)\n   322→\t\t}\n   323→\t\tentries = append(entries, stepEntry{\n   324→\t\t\tIndex:     len(entries),\n   325→\t\t\tStepName:  c.StepName,\n   326→\t\t\tResult:    c.Result,\n   327→\t\t\tStartedAt: startedAt,\n   328→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   329→\t\t})\n   330→\t}\n   331→\n   332→\t// Append any started-but-not-completed steps (still running)\n   333→\tfor _, c := range caps {\n   334→\t\tif c.Result == \"\" {\n   335→\t\t\tif _, used := pending[c.StepName]; !used {\n   336→\t\t\t\tcontinue\n   337→\t\t\t}\n   338→\t\t\tentries = append(entries, stepEntry{\n   339→\t\t\t\tIndex:     len(entries),\n   340→\t\t\t\tStepName:  c.StepName,\n   341→\t\t\t\tStartedAt: c.StartedAt,\n   342→\t\t\t})\n   343→\t\t\tdelete(pending, c.StepName)\n   344→\t\t}\n   345→\t}\n   346→\n   347→\treturn entries\n   348→}\n   349→\n   350→// containerState inspects the container for a run and returns one of:\n   351→//   - \"running\"   – container exists and is running\n   352→//   - \"stopped\"   – container exists, not running, not kept\n   353→//   - \"available\" – container exists, not running, kept (can be deleted)\n   354→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   355→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   356→\tif run.ContainerID == \"\" {\n   357→\t\treturn \"removed\"\n   358→\t}\n   359→\tmgr, ok := h.container.(ContainerManager)\n   360→\tif !ok {\n   361→\t\treturn \"removed\"\n   362→\t}\n   363→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   364→\tif err != nil {\n   365→\t\treturn \"removed\"\n   366→\t}\n   367→\tif status.Running {\n   368→\t\treturn \"running\"\n   369→\t}\n   370→\tif run.ContainerKept {\n   371→\t\treturn \"available\"\n   372→\t}\n   373→\treturn \"stopped\"\n   374→}\n   375→\n   376→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   377→\tid := r.PathValue(\"id\")\n   378→\n   379→\trun, err := h.store.GetRun(r.Context(), id)\n   380→\tif err != nil {\n   381→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   382→\t\treturn\n   383→\t}\n   384→\n   385→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   386→\tif err != nil {\n   387→\t\tcaps = nil // non-fatal\n   388→\t}\n   389→\n   390→\tsteps := mergeCaptures(caps)\n   391→\n   392→\tdata := map[string]any{\n   393→\t\t\"Title\":          \"Run \" + run.ID,\n   394→\t\t\"Run\":            run,\n   395→\t\t\"Steps\":          steps,\n   396→\t\t\"Page\":           \"detail\",\n   397→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   398→\t}\n   399→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   400→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   401→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   402→\t}\n   403→}\n   404→\n   405→// --- JSON API handlers ---\n   406→\n   407→type apiRun struct {\n   408→\tID           string `json:\"id\"`\n   409→\tWorkflowName string `json:\"workflow_name\"`\n   410→\tProjectDir   string `json:\"project_dir\"`\n   411→\tProjectLabel string `json:\"project_label\"`\n   412→\tState        string `json:\"state\"`\n   413→\tStartedAt    string `json:\"started_at\"`\n   414→\tCompletedAt  string `json:\"completed_at\"`\n   415→\tContainerID  string `json:\"container_id\"`\n   416→\tErrorMessage string `json:\"error_message\"`\n   417→}\n   418→\n   419→type apiStep struct {\n   420→\tStepName    string `json:\"step_name\"`\n   421→\tResult      string `json:\"result\"`\n   422→\tStartedAt   string `json:\"started_at\"`\n   423→\tCompletedAt string `json:\"completed_at\"`\n   424→\tDuration    string `json:\"duration\"`\n   425→}\n   426→\n   427→type apiRunDetail struct {\n   428→\tapiRun\n   429→\tContainerState string    `json:\"container_state\"`\n   430→\tSteps          []apiStep `json:\"steps\"`\n   431→}\n   432→\n   433→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   434→\treturn apiRun{\n   435→\t\tID:           r.ID,\n   436→\t\tWorkflowName: r.WorkflowName,\n   437→\t\tProjectDir:   r.ProjectDir,\n   438→\t\tProjectLabel: labels[r.ProjectDir],\n   439→\t\tState:        string(r.State),\n   440→\t\tStartedAt:    formatTime(r.StartedAt),\n   441→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   442→\t\tContainerID:  r.ContainerID,\n   443→\t\tErrorMessage: r.ErrorMessage,\n   444→\t}\n   445→}\n   446→\n   447→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   448→\tprojectFilter := r.URL.Query().Get(\"project\")\n   449→\n   450→\tvar runs []*domain.Run\n   451→\tvar err error\n   452→\tif projectFilter != \"\" {\n   453→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   454→\t} else {\n   455→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   456→\t}\n   457→\tif err != nil {\n   458→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   459→\t\treturn\n   460→\t}\n   461→\n   462→\tprojects, _ := h.store.ListProjects(r.Context())\n   463→\tlabels := projectLabels(projects)\n   464→\n   465→\tresult := make([]apiRun, len(runs))\n   466→\tfor i, run := range runs {\n   467→\t\tresult[i] = toAPIRun(run, labels)\n   468→\t}\n   469→\n   470→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   471→\tjson.NewEncoder(w).Encode(result)\n   472→}\n   473→\n   474→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   475→\tprojects, err := h.store.ListProjects(r.Context())\n   476→\tif err != nil {\n   477→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   478→\t\treturn\n   479→\t}\n   480→\tlabels := projectLabels(projects)\n   481→\n   482→\ttype apiHealth struct {\n   483→\t\tStatus string `json:\"status\"`\n   484→\t\tPassed int    `json:\"passed\"`\n   485→\t\tFailed int    `json:\"failed\"`\n   486→\t\tTotal  int    `json:\"total\"`\n   487→\t}\n   488→\ttype apiProject struct {\n   489→\t\tDir         string    `json:\"dir\"`\n   490→\t\tLabel       string    `json:\"label\"`\n   491→\t\tHealth      apiHealth `json:\"health\"`\n   492→\t\tActiveCount int       `json:\"active_count\"`\n   493→\t}\n   494→\tresult := make([]apiProject, len(projects))\n   495→\tfor i, dir := range projects {\n   496→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   497→\t\trunValues := make([]domain.Run, len(runs))\n   498→\t\tfor j, rr := range runs {\n   499→\t\t\trunValues[j] = *rr\n   500→\t\t}\n   501→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   502→\t\tvar activeCount int\n   503→\t\tfor _, rr := range runs {\n   504→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   505→\t\t\t\tactiveCount++\n   506→\t\t\t}\n   507→\t\t}\n   508→\t\tresult[i] = apiProject{\n   509→\t\t\tDir:   dir,\n   510→\t\t\tLabel: labels[dir],\n   511→\t\t\tHealth: apiHealth{\n   512→\t\t\t\tStatus: string(health.Status),\n   513→\t\t\t\tPassed: health.Passed,\n   514→\t\t\t\tFailed: health.Failed,\n   515→\t\t\t\tTotal:  health.Total,\n   516→\t\t\t},\n   517→\t\t\tActiveCount: activeCount,\n   518→\t\t}\n   519→\t}\n   520→\n   521→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   522→\tjson.NewEncoder(w).Encode(result)\n   523→}\n   524→\n   525→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   526→\tid := r.PathValue(\"id\")\n   527→\n   528→\trun, err := h.store.GetRun(r.Context(), id)\n   529→\tif err != nil {\n   530→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   531→\t\treturn\n   532→\t}\n   533→\n   534→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   535→\tif err != nil {\n   536→\t\tcaps = nil\n   537→\t}\n   538→\n   539→\tprojects, _ := h.store.ListProjects(r.Context())\n   540→\tlabels := projectLabels(projects)\n   541→\n   542→\tmerged := mergeCaptures(caps)\n   543→\tsteps := make([]apiStep, len(merged))\n   544→\tfor i, e := range merged {\n   545→\t\tsteps[i] = apiStep{\n   546→\t\t\tStepName:  e.StepName,\n   547→\t\t\tResult:    e.Result,\n   548→\t\t\tStartedAt: formatTime(e.StartedAt),\n   549→\t\t\tDuration:  e.Duration,\n   550→\t\t}\n   551→\t}\n   552→\n   553→\tdetail := apiRunDetail{\n   554→\t\tapiRun:         toAPIRun(run, labels),\n   555→\t\tContainerState: h.containerState(r.Context(), run),\n   556→\t\tSteps:          steps,\n   557→\t}\n   558→\n   559→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   560→\tjson.NewEncoder(w).Encode(detail)\n   561→}\n   562→\n   563→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   564→\tid := r.PathValue(\"id\")\n   565→\tstep := r.PathValue(\"step\")\n   566→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   567→\n   568→\trun, err := h.store.GetRun(r.Context(), id)\n   569→\tif err != nil {\n   570→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   571→\t\treturn\n   572→\t}\n   573→\n   574→\t// Try log index first for fast lookup\n   575→\tif h.logStore != nil {\n   576→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   577→\t\tif err == nil && len(logFiles) > 0 {\n   578→\t\t\t// If type filter specified, narrow results\n   579→\t\t\tfor _, lf := range logFiles {\n   580→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   581→\t\t\t\t\tcontinue\n   582→\t\t\t\t}\n   583→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   584→\t\t\t\tif readErr == nil && len(data) > 0 {\n   585→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   586→\t\t\t\t\tw.Write(data)\n   587→\t\t\t\t\treturn\n   588→\t\t\t\t}\n   589→\t\t\t}\n   590→\t\t}\n   591→\t}\n   592→\n   593→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   594→\n   595→\t// Fall back to file path conventions\n   596→\t// If type is \"llm\", try llm-<step>.log\n   597→\tif logType == \"llm\" {\n   598→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   599→\t\tdata, err := os.ReadFile(llmPath)\n   600→\t\tif err == nil && len(data) > 0 {\n   601→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   602→\t\t\tw.Write(data)\n   603→\t\t\treturn\n   604→\t\t}\n   605→\t}\n   606→\n   607→\t// Try per-step output first, fall back to container.log, then live docker logs\n   608→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   609→\tdata, err := os.ReadFile(outputPath)\n   610→\tif err == nil && len(data) > 0 {\n   611→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   612→\t\tw.Write(data)\n   613→\t\treturn\n   614→\t}\n   615→\n   616→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   617→\tdata, err = os.ReadFile(containerLog)\n   618→\tif err == nil && len(data) > 0 {\n   619→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   620→\t\tw.Write(data)\n   621→\t\treturn\n   622→\t}\n   623→\n   624→\t// Last resort: try live docker logs from still-existing container\n   625→\tif h.container != nil && run.ContainerID != \"\" {\n   626→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   627→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   628→\t\t\tw.Write([]byte(logs))\n   629→\t\t\treturn\n   630→\t\t}\n   631→\t}\n   632→\n   633→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   634→}\n   635→\n   636→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   637→\tid := r.PathValue(\"id\")\n   638→\n   639→\trun, err := h.store.GetRun(r.Context(), id)\n   640→\tif err != nil {\n   641→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   642→\t\tw.WriteHeader(http.StatusNotFound)\n   643→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   644→\t\treturn\n   645→\t}\n   646→\n   647→\tmgr, ok := h.container.(ContainerManager)\n   648→\tif !ok || run.ContainerID == \"\" {\n   649→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   650→\t\tw.WriteHeader(http.StatusBadRequest)\n   651→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   652→\t\treturn\n   653→\t}\n   654→\n   655→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   656→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   657→\t\tw.WriteHeader(http.StatusInternalServerError)\n   658→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   659→\t\treturn\n   660→\t}\n   661→\n   662→\trun.ContainerKept = false\n   663→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   664→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   665→\t\tw.WriteHeader(http.StatusInternalServerError)\n   666→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   667→\t\treturn\n   668→\t}\n   669→\n   670→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   671→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   672→}\n   673→\n   674→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   675→\tlabel := r.PathValue(\"name\")\n   676→\n   677→\t// Resolve label back to project directory via the store.\n   678→\tprojects, _ := h.store.ListProjects(r.Context())\n   679→\tlabels := projectLabels(projects)\n   680→\tvar projectDir string\n   681→\tfor dir, l := range labels {\n   682→\t\tif l == label {\n   683→\t\t\tprojectDir = dir\n   684→\t\t\tbreak\n   685→\t\t}\n   686→\t}\n   687→\tif projectDir == \"\" {\n   688→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   689→\t\tw.WriteHeader(http.StatusNotFound)\n   690→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   691→\t\treturn\n   692→\t}\n   693→\n   694→\tif h.orchestrateFn == nil {\n   695→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   696→\t\tw.WriteHeader(http.StatusNotImplemented)\n   697→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   698→\t\treturn\n   699→\t}\n   700→\n   701→\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   702→\tif err != nil {\n   703→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   704→\t\tw.WriteHeader(http.StatusInternalServerError)\n   705→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   706→\t\treturn\n   707→\t}\n   708→\n   709→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   710→\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   711→}\n   712→\n   713→// handleAPIStream serves an SSE stream of log lines for a run.\n   714→// For active runs, it subscribes to the live broadcaster.\n   715→// For completed runs, it serves the archived full.log then closes.\n   716→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   717→\tid := r.PathValue(\"id\")\n   718→\n   719→\trun, err := h.store.GetRun(r.Context(), id)\n   720→\tif err != nil {\n   721→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   722→\t\treturn\n   723→\t}\n   724→\n   725→\tflusher, ok := w.(http.Flusher)\n   726→\tif !ok {\n   727→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   728→\t\treturn\n   729→\t}\n   730→\n   731→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   732→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   733→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   734→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   735→\n   736→\tisComplete := run.State == domain.RunStateSucceeded ||\n   737→\t\trun.State == domain.RunStateFailed ||\n   738→\t\trun.State == domain.RunStateCancelled\n   739→\n   740→\tif isComplete {\n   741→\t\t// Serve archived full.log\n   742→\t\th.streamFullLog(w, flusher, run)\n   743→\t\t// Send done event\n   744→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   745→\t\tflusher.Flush()\n   746→\t\treturn\n   747→\t}\n   748→\n   749→\t// Active run: subscribe to live broadcaster\n   750→\tif h.logBroadcast == nil {\n   751→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   752→\t\treturn\n   753→\t}\n   754→\n   755→\tsub := h.logBroadcast.Subscribe(id)\n   756→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   757→\n   758→\tctx := r.Context()\n   759→\tfor {\n   760→\t\tselect {\n   761→\t\tcase <-ctx.Done():\n   762→\t\t\treturn\n   763→\t\tcase line, ok := <-sub.C:\n   764→\t\t\tif !ok {\n   765→\t\t\t\t// Stream finished (run completed)\n   766→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   767→\t\t\t\tflusher.Flush()\n   768→\t\t\t\treturn\n   769→\t\t\t}\n   770→\t\t\tdata, _ := json.Marshal(line)\n   771→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   772→\t\t\tflusher.Flush()\n   773→\t\t}\n   774→\t}\n   775→}\n   776→\n   777→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   778→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   779→\n   780→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   781→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   782→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   783→\tf, err := os.Open(logPath)\n   784→\tif err != nil {\n   785→\t\treturn\n   786→\t}\n   787→\tdefer f.Close()\n   788→\n   789→\tscanner := bufio.NewScanner(f)\n   790→\tfor scanner.Scan() {\n   791→\t\ttext := scanner.Text()\n   792→\t\tline := parseFullLogLine(text)\n   793→\t\tdata, _ := json.Marshal(line)\n   794→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   795→\t\tflusher.Flush()\n   796→\t}\n   797→}\n   798→\n   799→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   800→func parseFullLogLine(text string) logstream.LogLine {\n   801→\tm := logLineRegex.FindStringSubmatch(text)\n   802→\tif m == nil {\n   803→\t\treturn logstream.LogLine{\n   804→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   805→\t\t\tType:      \"script\",\n   806→\t\t\tContent:   text,\n   807→\t\t}\n   808→\t}\n   809→\treturn logstream.LogLine{\n   810→\t\tTimestamp: m[1],\n   811→\t\tType:      m[2],\n   812→\t\tContent:   m[3],\n   813→\t}\n   814→}\n   815→\n   816→// --- Project detail handlers ---\n   817→\n   818→// resolveProjectDir resolves a project label from the URL to its directory path.\n   819→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   820→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   821→\tlabel := r.PathValue(\"name\")\n   822→\tprojects, _ := h.store.ListProjects(r.Context())\n   823→\tlabels := projectLabels(projects)\n   824→\tfor dir, l := range labels {\n   825→\t\tif l == label {\n   826→\t\t\treturn dir, label, true\n   827→\t\t}\n   828→\t}\n   829→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   830→\tw.WriteHeader(http.StatusNotFound)\n   831→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   832→\treturn \"\", \"\", false\n   833→}\n   834→\n   835→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   836→\tdir, label, ok := h.resolveProjectDir(w, r)\n   837→\tif !ok {\n   838→\t\treturn\n   839→\t}\n   840→\n   841→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   842→\tn := 10\n   843→\tif n > len(runs) {\n   844→\t\tn = len(runs)\n   845→\t}\n   846→\tdots := make([]recentRunDot, n)\n   847→\tfor i := 0; i < n; i++ {\n   848→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   849→\t}\n   850→\n   851→\tdata := map[string]any{\n   852→\t\t\"Title\":      label,\n   853→\t\t\"Label\":      label,\n   854→\t\t\"Dir\":        dir,\n   855→\t\t\"RecentRuns\": dots,\n   856→\t}\n   857→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   858→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   859→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   860→\t}\n   861→}\n   862→\n   863→func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   864→\tdir, _, ok := h.resolveProjectDir(w, r)\n   865→\tif !ok {\n   866→\t\treturn\n   867→\t}\n   868→\tif h.orchestrator == nil {\n   869→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   870→\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   871→\t\treturn\n   872→\t}\n   873→\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   874→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   875→\tjson.NewEncoder(w).Encode(map[string]any{\n   876→\t\t\"enabled\":     enabled,\n   877→\t\t\"in_flight\":   inFlight,\n   878→\t\t\"concurrency\": concurrency,\n   879→\t})\n   880→}\n   881→\n   882→func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   883→\tdir, _, ok := h.resolveProjectDir(w, r)\n   884→\tif !ok {\n   885→\t\treturn\n   886→\t}\n   887→\tif h.orchestrator == nil {\n   888→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   889→\t\tw.WriteHeader(http.StatusNotImplemented)\n   890→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   891→\t\treturn\n   892→\t}\n   893→\th.orchestrator.SetEnabled(dir, true)\n   894→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   895→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   896→}\n   897→\n   898→func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   899→\tdir, _, ok := h.resolveProjectDir(w, r)\n   900→\tif !ok {\n   901→\t\treturn\n   902→\t}\n   903→\tif h.orchestrator == nil {\n   904→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   905→\t\tw.WriteHeader(http.StatusNotImplemented)\n   906→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   907→\t\treturn\n   908→\t}\n   909→\th.orchestrator.SetEnabled(dir, false)\n   910→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   911→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   912→}\n   913→\n   914→func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   915→\tdir, _, ok := h.resolveProjectDir(w, r)\n   916→\tif !ok {\n   917→\t\treturn\n   918→\t}\n   919→\tif h.orchestrator == nil {\n   920→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   921→\t\tw.WriteHeader(http.StatusNotImplemented)\n   922→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   923→\t\treturn\n   924→\t}\n   925→\tvar body struct {\n   926→\t\tConcurrency int `json:\"concurrency\"`\n   927→\t}\n   928→\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n   929→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   930→\t\tw.WriteHeader(http.StatusBadRequest)\n   931→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n   932→\t\treturn\n   933→\t}\n   934→\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n   935→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   936→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   937→}\n   938→\n   939→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   940→\tdir, _, ok := h.resolveProjectDir(w, r)\n   941→\tif !ok {\n   942→\t\treturn\n   943→\t}\n   944→\n   945→\t// Docker image: read FROM line from Dockerfile\n   946→\tdockerImage := \"\"\n   947→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   948→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   949→\t\t// Find the last FROM line (final stage)\n   950→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   951→\t\t\ttrimmed := strings.TrimSpace(line)\n   952→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   953→\t\t\t\tparts := strings.Fields(trimmed)\n   954→\t\t\t\tif len(parts) >= 2 {\n   955→\t\t\t\t\tdockerImage = parts[1]\n   956→\t\t\t\t}\n   957→\t\t\t}\n   958→\t\t}\n   959→\t}\n   960→\n   961→\t// Version\n   962→\tversion := 0\n   963→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   964→\tif data, err := os.ReadFile(versionPath); err == nil {\n   965→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   966→\t\t\tversion = v\n   967→\t\t}\n   968→\t}\n   969→\n   970→\t// Prompt files history\n   971→\ttype commitEntry struct {\n   972→\t\tSHA     string `json:\"sha\"`\n   973→\t\tDate    string `json:\"date\"`\n   974→\t\tMessage string `json:\"message\"`\n   975→\t}\n   976→\ttype promptFile struct {\n   977→\t\tPath    string        `json:\"path\"`\n   978→\t\tHistory []commitEntry `json:\"history\"`\n   979→\t}\n   980→\n   981→\tvar promptFiles []promptFile\n   982→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   983→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n   984→\t\tfor _, e := range entries {\n   985→\t\t\tif e.IsDir() {\n   986→\t\t\t\tcontinue\n   987→\t\t\t}\n   988→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n   989→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n   990→\t\t\tcmd.Dir = dir\n   991→\t\t\tout, err := cmd.Output()\n   992→\t\t\tif err != nil {\n   993→\t\t\t\tcontinue\n   994→\t\t\t}\n   995→\t\t\tvar history []commitEntry\n   996→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n   997→\t\t\t\tif line == \"\" {\n   998→\t\t\t\t\tcontinue\n   999→\t\t\t\t}\n  1000→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1001→\t\t\t\tif len(parts) < 3 {\n  1002→\t\t\t\t\tcontinue\n  1003→\t\t\t\t}\n  1004→\t\t\t\t// Parse date to short form\n  1005→\t\t\t\tdateStr := parts[1]\n  1006→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1007→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1008→\t\t\t\t}\n  1009→\t\t\t\thistory = append(history, commitEntry{\n  1010→\t\t\t\t\tSHA:     parts[0][:7],\n  1011→\t\t\t\t\tDate:    dateStr,\n  1012→\t\t\t\t\tMessage: parts[2],\n  1013→\t\t\t\t})\n  1014→\t\t\t}\n  1015→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1016→\t\t}\n  1017→\t}\n  1018→\n  1019→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1020→\tjson.NewEncoder(w).Encode(map[string]any{\n  1021→\t\t\"docker_image\": dockerImage,\n  1022→\t\t\"version\":      version,\n  1023→\t\t\"prompt_files\": promptFiles,\n  1024→\t})\n  1025→}\n  1026→\n  1027→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1028→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1029→\tif !ok {\n  1030→\t\treturn\n  1031→\t}\n  1032→\tfile := r.URL.Query().Get(\"file\")\n  1033→\tsha := r.URL.Query().Get(\"sha\")\n  1034→\tif file == \"\" || sha == \"\" {\n  1035→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1036→\t\treturn\n  1037→\t}\n  1038→\n  1039→\t// Validate sha is alphanumeric to prevent injection\n  1040→\tfor _, c := range sha {\n  1041→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1042→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1043→\t\t\treturn\n  1044→\t\t}\n  1045→\t}\n  1046→\n  1047→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1048→\tcmd.Dir = dir\n  1049→\tout, err := cmd.Output()\n  1050→\tif err != nil {\n  1051→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1052→\t\treturn\n  1053→\t}\n  1054→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1055→\tw.Write(out)\n  1056→}\n  1057→\n  1058→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1059→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1060→\tif !ok {\n  1061→\t\treturn\n  1062→\t}\n  1063→\n  1064→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1065→\tentries, err := os.ReadDir(clocheDir)\n  1066→\tif err != nil {\n  1067→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1068→\t\tjson.NewEncoder(w).Encode([]any{})\n  1069→\t\treturn\n  1070→\t}\n  1071→\n  1072→\ttype apiWire struct {\n  1073→\t\tFrom   string `json:\"from\"`\n  1074→\t\tResult string `json:\"result\"`\n  1075→\t\tTo     string `json:\"to\"`\n  1076→\t}\n  1077→\ttype apiStepDef struct {\n  1078→\t\tName    string            `json:\"name\"`\n  1079→\t\tType    string            `json:\"type\"`\n  1080→\t\tResults []string          `json:\"results\"`\n  1081→\t\tConfig  map[string]string `json:\"config\"`\n  1082→\t}\n  1083→\ttype apiWorkflow struct {\n  1084→\t\tName      string       `json:\"name\"`\n  1085→\t\tFile      string       `json:\"file\"`\n  1086→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1087→\t\tWires     []apiWire    `json:\"wires\"`\n  1088→\t\tEntryStep string       `json:\"entry_step\"`\n  1089→\t}\n  1090→\n  1091→\tvar workflows []apiWorkflow\n  1092→\tfor _, e := range entries {\n  1093→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1094→\t\t\tcontinue\n  1095→\t\t}\n  1096→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1097→\t\tif err != nil {\n  1098→\t\t\tcontinue\n  1099→\t\t}\n  1100→\t\twf, err := dsl.Parse(string(data))\n  1101→\t\tif err != nil {\n  1102→\t\t\tcontinue\n  1103→\t\t}\n  1104→\t\tvar steps []apiStepDef\n  1105→\t\tfor _, s := range wf.Steps {\n  1106→\t\t\tsteps = append(steps, apiStepDef{\n  1107→\t\t\t\tName:    s.Name,\n  1108→\t\t\t\tType:    string(s.Type),\n  1109→\t\t\t\tResults: s.Results,\n  1110→\t\t\t\tConfig:  s.Config,\n  1111→\t\t\t})\n  1112→\t\t}\n  1113→\t\t// Sort steps by name for consistent ordering\n  1114→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1115→\n  1116→\t\tvar wires []apiWire\n  1117→\t\tfor _, wire := range wf.Wiring {\n  1118→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1119→\t\t}\n  1120→\n  1121→\t\tworkflows = append(workflows, apiWorkflow{\n  1122→\t\t\tName:      wf.Name,\n  1123→\t\t\tFile:      filepath.Join(\".cloche