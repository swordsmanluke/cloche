{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G5a6sAB8VtdX5X7qscdaFC","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n     3→\n     4→<div class=\"run-history\" style=\"margin-bottom:1rem\">\n     5→    {{range .RecentRuns}}\n     6→    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n     7→    {{end}}\n     8→    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n     9→</div>\n    10→\n    11→<!-- Panel 1: Project Info -->\n    12→<div class=\"panel\" id=\"info-panel\">\n    13→    <div class=\"panel-header\">Project Info</div>\n    14→    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n    15→</div>\n    16→\n    17→<!-- Panel 3: Workflow View -->\n    18→<div class=\"panel\" id=\"workflow-panel\">\n    19→    <div class=\"panel-header\">Workflows</div>\n    20→    <div class=\"panel-body\">\n    21→        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n    22→        <div id=\"workflow-dag\"></div>\n    23→    </div>\n    24→</div>\n    25→\n    26→<!-- Step Drawer -->\n    27→<div class=\"drawer\" id=\"step-drawer\">\n    28→    <div class=\"drawer-header\">\n    29→        <span id=\"drawer-title\"></span>\n    30→        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    31→    </div>\n    32→    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n    33→</div>\n    34→{{end}}\n    35→\n    36→{{define \"scripts\"}}\n    37→<script>\n    38→var projectLabel = {{.Label}};\n    39→\n    40→function loadProjectInfo() {\n    41→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n    42→        .then(function(r) { return r.json(); })\n    43→        .then(function(data) {\n    44→            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n    45→            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n    46→            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n    47→            html += '</dl>';\n    48→\n    49→            if (data.prompt_files && data.prompt_files.length > 0) {\n    50→                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n    51→                data.prompt_files.forEach(function(pf) {\n    52→                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n    53→                    if (pf.history && pf.history.length > 0) {\n    54→                        html += '<div style=\"margin:0.5rem 0\">';\n    55→                        pf.history.forEach(function(h) {\n    56→                            html += '<div class=\"prompt-commit\" data-file=\"' + pf.path + '\" data-sha=\"' + h.sha + '\" onclick=\"toggleDiff(this)\" style=\"cursor:pointer;padding:0.25rem 0;font-size:0.85rem\">';\n    57→                            html += '<span class=\"mono\" style=\"color:var(--link)\">' + h.sha + '</span> ';\n    58→                            html += '<span style=\"color:var(--text-muted)\">' + h.date + '</span> ';\n    59→                            html += h.message;\n    60→                            html += '</div>';\n    61→                        });\n    62→                        html += '</div>';\n    63→                    } else {\n    64→                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">No history</p>';\n    65→                    }\n    66→                    html += '</details>';\n    67→                });\n    68→            }\n    69→\n    70→            document.getElementById('project-info').innerHTML = html;\n    71→        });\n    72→}\n    73→\n    74→function toggleDiff(el) {\n    75→    var existing = el.nextElementSibling;\n    76→    if (existing && existing.classList.contains('diff-block')) {\n    77→        existing.remove();\n    78→        return;\n    79→    }\n    80→    var file = el.getAttribute('data-file');\n    81→    var sha = el.getAttribute('data-sha');\n    82→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n    83→        .then(function(r) { return r.text(); })\n    84→        .then(function(text) {\n    85→            var pre = document.createElement('pre');\n    86→            pre.className = 'diff-block';\n    87→            pre.textContent = text || '(no diff available)';\n    88→            el.parentNode.insertBefore(pre, el.nextSibling);\n    89→        });\n    90→}\n    91→\n    92→var workflowsData = [];\n    93→function loadWorkflows() {\n    94→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n    95→        .then(function(r) { return r.json(); })\n    96→        .then(function(data) {\n    97→            workflowsData = data || [];\n    98→            if (workflowsData.length === 0) {\n    99→                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n   100→                return;\n   101→            }\n   102→            var tabs = document.getElementById('workflow-tabs');\n   103→            if (workflowsData.length > 1) {\n   104→                var html = '';\n   105→                workflowsData.forEach(function(wf, i) {\n   106→                    html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showWorkflow(' + i + ')\">' + wf.name + '</button>';\n   107→                });\n   108→                tabs.innerHTML = html;\n   109→            }\n   110→            showWorkflow(0);\n   111→        });\n   112→}\n   113→\n   114→function showWorkflow(idx) {\n   115→    var btns = document.querySelectorAll('.tab-btn');\n   116→    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n   117→\n   118→    var wf = workflowsData[idx];\n   119→    var dagEl = document.getElementById('workflow-dag');\n   120→\n   121→    // Build step order via topological sort from entry\n   122→    var ordered = [];\n   123→    var visited = {};\n   124→    function visit(name) {\n   125→        if (visited[name] || name === 'done' || name === 'abort') return;\n   126→        visited[name] = true;\n   127→        ordered.push(name);\n   128→        wf.wires.forEach(function(wire) {\n   129→            if (wire.from === name) visit(wire.to);\n   130→        });\n   131→    }\n   132→    if (wf.entry_step) visit(wf.entry_step);\n   133→    // Add any unvisited steps\n   134→    wf.steps.forEach(function(s) { if (!visited[s.name]) { ordered.push(s.name); visited[s.name] = true; } });\n   135→\n   136→    // Collect terminal targets\n   137→    var terminals = {};\n   138→    wf.wires.forEach(function(wire) {\n   139→        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n   140→    });\n   141→\n   142→    var stepMap = {};\n   143→    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n   144→\n   145→    var nodeH = 48, nodeW = 180, gapY = 24, gapX = 40, padTop = 20, padLeft = 30;\n   146→\n   147→    // Assign positions\n   148→    var positions = {};\n   149→    ordered.forEach(function(name, i) {\n   150→        positions[name] = {x: padLeft, y: padTop + i * (nodeH + gapY)};\n   151→    });\n   152→    var termIdx = ordered.length;\n   153→    for (var t in terminals) {\n   154→        positions[t] = {x: padLeft, y: padTop + termIdx * (nodeH + gapY)};\n   155→        termIdx++;\n   156→    }\n   157→\n   158→    var totalH = padTop + termIdx * (nodeH + gapY) + 10;\n   159→    var totalW = padLeft + nodeW + gapX + 80;\n   160→\n   161→    var html = '<svg class=\"dag-svg\" width=\"' + totalW + '\" height=\"' + totalH + '\">';\n   162→    html += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n   163→\n   164→    // Draw wires\n   165→    wf.wires.forEach(function(wire) {\n   166→        var from = positions[wire.from];\n   167→        var to = positions[wire.to];\n   168→        if (!from || !to) return;\n   169→        var x1 = from.x + nodeW;\n   170→        var y1 = from.y + nodeH / 2;\n   171→        var x2 = to.x;\n   172→        var y2 = to.y + nodeH / 2;\n   173→        var cx = x1 + gapX / 2;\n   174→        html += '<path d=\"M' + x1 + ' ' + y1 + ' C' + cx + ' ' + y1 + ' ' + cx + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n   175→        var lx = (x1 + x2) / 2, ly = (y1 + y2) / 2 - 6;\n   176→        html += '<text x=\"' + lx + '\" y=\"' + ly + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n   177→    });\n   178→\n   179→    // Draw step nodes\n   180→    ordered.forEach(function(name) {\n   181→        var pos = positions[name];\n   182→        var s = stepMap[name];\n   183→        var icon = s && s.type === 'agent' ? '\\u{1F916}' : '\\u{1F4DC}';\n   184→        html += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + name + '\\')\" style=\"cursor:pointer\">';\n   185→        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n   186→        html += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + name + '</text>';\n   187→        html += '</g>';\n   188→    });\n   189→\n   190→    // Draw terminal nodes\n   191→    for (var t in terminals) {\n   192→        var pos = positions[t];\n   193→        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n   194→        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n   195→        html += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n   196→    }\n   197→\n   198→    html += '</svg>';\n   199→    dagEl.innerHTML = html;\n   200→}\n   201→\n   202→function openDrawer(workflowName, stepName) {\n   203→    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n   204→    if (!wf) return;\n   205→    var step = wf.steps.find(function(s) { return s.name === stepName; });\n   206→    if (!step) return;\n   207→\n   208→    document.getElementById('drawer-title').textContent = stepName;\n   209→    var body = '<dl class=\"run-meta\">';\n   210→    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n   211→    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n   212→    if (step.config) {\n   213→        for (var k in step.config) {\n   214→            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script') {\n   215→                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n   216→            }\n   217→        }\n   218→    }\n   219→    body += '</dl>';\n   220→    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n   221→\n   222→    document.getElementById('drawer-body').innerHTML = body;\n   223→    document.getElementById('step-drawer').classList.add('drawer-open');\n   224→\n   225→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n   226→        .then(function(r) { if (r.ok) return r.text(); return ''; })\n   227→        .then(function(text) {\n   228→            var el = document.getElementById('drawer-content');\n   229→            if (text) {\n   230→                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n   231→            } else {\n   232→                el.innerHTML = '<p style=\"color:var(--text-muted)\">No content available</p>';\n   233→            }\n   234→        });\n   235→}\n   236→\n   237→function closeDrawer() {\n   238→    document.getElementById('step-drawer').classList.remove('drawer-open');\n   239→}\n   240→\n   241→document.addEventListener('keydown', function(e) {\n   242→    if (e.key === 'Escape') closeDrawer();\n   243→});\n   244→\n   245→// Load all panels\n   246→loadProjectInfo();\n   247→loadWorkflows();\n   248→</script>\n   249→{{end}}\n   250→"}]},"parent_tool_use_id":null,"session_id":"8d363198-c076-4c57-820f-5b3722f41f4f","uuid":"6679eb2f-d3af-4349-9e37-9107228b2bda","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/project_detail.html","content":"{{define \"content\"}}\n<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n\n<div class=\"run-history\" style=\"margin-bottom:1rem\">\n    {{range .RecentRuns}}\n    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n    {{end}}\n    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n</div>\n\n<!-- Panel 1: Project Info -->\n<div class=\"panel\" id=\"info-panel\">\n    <div class=\"panel-header\">Project Info</div>\n    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n</div>\n\n<!-- Panel 3: Workflow View -->\n<div class=\"panel\" id=\"workflow-panel\">\n    <div class=\"panel-header\">Workflows</div>\n    <div class=\"panel-body\">\n        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-dag\"></div>\n    </div>\n</div>\n\n<!-- Step Drawer -->\n<div class=\"drawer\" id=\"step-drawer\">\n    <div class=\"drawer-header\">\n        <span id=\"drawer-title\"></span>\n        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    </div>\n    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n</div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\nvar projectLabel = {{.Label}};\n\nfunction loadProjectInfo() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n            html += '</dl>';\n\n            if (data.prompt_files && data.prompt_files.length > 0) {\n                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n                data.prompt_files.forEach(function(pf) {\n                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n                    if (pf.history && pf.history.length > 0) {\n                        html += '<div style=\"margin:0.5rem 0\">';\n                        pf.history.forEach(function(h) {\n                            html += '<div class=\"prompt-commit\" data-file=\"' + pf.path + '\" data-sha=\"' + h.sha + '\" onclick=\"toggleDiff(this)\" style=\"cursor:pointer;padding:0.25rem 0;font-size:0.85rem\">';\n                            html += '<span class=\"mono\" style=\"color:var(--link)\">' + h.sha + '</span> ';\n                            html += '<span style=\"color:var(--text-muted)\">' + h.date + '</span> ';\n                            html += h.message;\n                            html += '</div>';\n                        });\n                        html += '</div>';\n                    } else {\n                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">No history</p>';\n                    }\n                    html += '</details>';\n                });\n            }\n\n            document.getElementById('project-info').innerHTML = html;\n        });\n}\n\nfunction toggleDiff(el) {\n    var existing = el.nextElementSibling;\n    if (existing && existing.classList.contains('diff-block')) {\n        existing.remove();\n        return;\n    }\n    var file = el.getAttribute('data-file');\n    var sha = el.getAttribute('data-sha');\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n        .then(function(r) { return r.text(); })\n        .then(function(text) {\n            var pre = document.createElement('pre');\n            pre.className = 'diff-block';\n            pre.textContent = text || '(no diff available)';\n            el.parentNode.insertBefore(pre, el.nextSibling);\n        });\n}\n\nvar workflowsData = [];\nfunction loadWorkflows() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            workflowsData = data || [];\n            if (workflowsData.length === 0) {\n                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n                return;\n            }\n            var tabs = document.getElementById('workflow-tabs');\n            if (workflowsData.length > 1) {\n                var html = '';\n                workflowsData.forEach(function(wf, i) {\n                    html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showWorkflow(' + i + ')\">' + wf.name + '</button>';\n                });\n                tabs.innerHTML = html;\n            }\n            showWorkflow(0);\n        });\n}\n\nfunction showWorkflow(idx) {\n    var btns = document.querySelectorAll('.tab-btn');\n    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n\n    var wf = workflowsData[idx];\n    var dagEl = document.getElementById('workflow-dag');\n\n    // Build step order via topological sort from entry\n    var ordered = [];\n    var visited = {};\n    function visit(name) {\n        if (visited[name] || name === 'done' || name === 'abort') return;\n        visited[name] = true;\n        ordered.push(name);\n        wf.wires.forEach(function(wire) {\n            if (wire.from === name) visit(wire.to);\n        });\n    }\n    if (wf.entry_step) visit(wf.entry_step);\n    // Add any unvisited steps\n    wf.steps.forEach(function(s) { if (!visited[s.name]) { ordered.push(s.name); visited[s.name] = true; } });\n\n    // Collect terminal targets\n    var terminals = {};\n    wf.wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n    });\n\n    var stepMap = {};\n    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n\n    var nodeH = 48, nodeW = 180, gapY = 24, gapX = 40, padTop = 20, padLeft = 30;\n\n    // Assign positions\n    var positions = {};\n    ordered.forEach(function(name, i) {\n        positions[name] = {x: padLeft, y: padTop + i * (nodeH + gapY)};\n    });\n    var termIdx = ordered.length;\n    for (var t in terminals) {\n        positions[t] = {x: padLeft, y: padTop + termIdx * (nodeH + gapY)};\n        termIdx++;\n    }\n\n    var totalH = padTop + termIdx * (nodeH + gapY) + 10;\n    var totalW = padLeft + nodeW + gapX + 80;\n\n    var html = '<svg class=\"dag-svg\" width=\"' + totalW + '\" height=\"' + totalH + '\">';\n    html += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n\n    // Draw wires\n    wf.wires.forEach(function(wire) {\n        var from = positions[wire.from];\n        var to = positions[wire.to];\n        if (!from || !to) return;\n        var x1 = from.x + nodeW;\n        var y1 = from.y + nodeH / 2;\n        var x2 = to.x;\n        var y2 = to.y + nodeH / 2;\n        var cx = x1 + gapX / 2;\n        html += '<path d=\"M' + x1 + ' ' + y1 + ' C' + cx + ' ' + y1 + ' ' + cx + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n        var lx = (x1 + x2) / 2, ly = (y1 + y2) / 2 - 6;\n        html += '<text x=\"' + lx + '\" y=\"' + ly + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n    });\n\n    // Draw step nodes\n    ordered.forEach(function(name) {\n        var pos = positions[name];\n        var s = stepMap[name];\n        var icon = s && s.type === 'agent' ? '\\u{1F916}' : '\\u{1F4DC}';\n        html += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + name + '\\')\" style=\"cursor:pointer\">';\n        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n        html += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + name + '</text>';\n        html += '</g>';\n    });\n\n    // Draw terminal nodes\n    for (var t in terminals) {\n        var pos = positions[t];\n        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n        html += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n    }\n\n    html += '</svg>';\n    dagEl.innerHTML = html;\n}\n\nfunction openDrawer(workflowName, stepName) {\n    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n    if (!wf) return;\n    var step = wf.steps.find(function(s) { return s.name === stepName; });\n    if (!step) return;\n\n    document.getElementById('drawer-title').textContent = stepName;\n    var body = '<dl class=\"run-meta\">';\n    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n    if (step.config) {\n        for (var k in step.config) {\n            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script') {\n                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n            }\n        }\n    }\n    body += '</dl>';\n    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n\n    document.getElementById('drawer-body').innerHTML = body;\n    document.getElementById('step-drawer').classList.add('drawer-open');\n\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n        .then(function(r) { if (r.ok) return r.text(); return ''; })\n        .then(function(text) {\n            var el = document.getElementById('drawer-content');\n            if (text) {\n                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n            } else {\n                el.innerHTML = '<p style=\"color:var(--text-muted)\">No content available</p>';\n            }\n        });\n}\n\nfunction closeDrawer() {\n    document.getElementById('step-drawer').classList.remove('drawer-open');\n}\n\ndocument.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') closeDrawer();\n});\n\n// Load all panels\nloadProjectInfo();\nloadWorkflows();\n</script>\n{{end}}\n","numLines":250,"startLine":1,"totalLines":250}}}
