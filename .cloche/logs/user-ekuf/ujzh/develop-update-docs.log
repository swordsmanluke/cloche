{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DNz9FQYd6WfnPaFUae8eAA","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"os/exec\"\n    14→\t\"path/filepath\"\n    15→\t\"regexp\"\n    16→\t\"sort\"\n    17→\t\"strconv\"\n    18→\t\"strings\"\n    19→\t\"time\"\n    20→\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→)\n    26→\n    27→// HandlerOption configures optional Handler dependencies.\n    28→type HandlerOption func(*Handler)\n    29→\n    30→// WithContainerLogger sets the container runtime for fetching live logs.\n    31→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32→\treturn func(h *Handler) { h.container = c }\n    33→}\n    34→\n    35→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36→func WithContainerManager(c ContainerManager) HandlerOption {\n    37→\treturn func(h *Handler) { h.container = c }\n    38→}\n    39→\n    40→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42→\treturn func(h *Handler) { h.logBroadcast = b }\n    43→}\n    44→\n    45→// WithLogStore sets the log store for indexed log file lookups.\n    46→func WithLogStore(ls ports.LogStore) HandlerOption {\n    47→\treturn func(h *Handler) { h.logStore = ls }\n    48→}\n    49→\n    50→//go:embed templates/*.html static/*\n    51→var content embed.FS\n    52→\n    53→// Handler serves the web dashboard.\n    54→// ContainerLogger can retrieve logs from a container by ID.\n    55→type ContainerLogger interface {\n    56→\tLogs(ctx context.Context, containerID string) (string, error)\n    57→}\n    58→\n    59→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    60→type ContainerManager interface {\n    61→\tContainerLogger\n    62→\tRemove(ctx context.Context, containerID string) error\n    63→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    64→}\n    65→\n    66→type Handler struct {\n    67→\tstore        ports.RunStore\n    68→\tcaptures     ports.CaptureStore\n    69→\tlogStore     ports.LogStore\n    70→\tcontainer    ContainerLogger\n    71→\tlogBroadcast *logstream.Broadcaster\n    72→\tpages        map[string]*template.Template\n    73→\tmux          *http.ServeMux\n    74→}\n    75→\n    76→// NewHandler creates a web dashboard handler.\n    77→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    78→\tfuncMap := template.FuncMap{\n    79→\t\t\"stateColor\":       stateColor,\n    80→\t\t\"healthColor\":      healthColor,\n    81→\t\t\"formatTime\":       formatTime,\n    82→\t\t\"formatDuration\":   formatDuration,\n    83→\t\t\"truncate\":         truncate,\n    84→\t\t\"shortContainerID\": shortContainerID,\n    85→\t}\n    86→\n    87→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n    88→\tif err != nil {\n    89→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n    90→\t}\n    91→\n    92→\tpages := map[string]*template.Template{}\n    93→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n    94→\t\tclone, err := base.Clone()\n    95→\t\tif err != nil {\n    96→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n    97→\t\t}\n    98→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n    99→\t\tif err != nil {\n   100→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   101→\t\t}\n   102→\t\tpages[page] = clone\n   103→\t}\n   104→\n   105→\th := &Handler{\n   106→\t\tstore:    store,\n   107→\t\tcaptures: captures,\n   108→\t\tpages:    pages,\n   109→\t\tmux:      http.NewServeMux(),\n   110→\t}\n   111→\tfor _, opt := range opts {\n   112→\t\topt(h)\n   113→\t}\n   114→\n   115→\tstaticFS, err := fs.Sub(content, \"static\")\n   116→\tif err != nil {\n   117→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   118→\t}\n   119→\n   120→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   121→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   122→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   123→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   124→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   125→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   126→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   127→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   128→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   129→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   130→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   131→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   132→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   133→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   134→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   135→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   136→\n   137→\treturn h, nil\n   138→}\n   139→\n   140→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   141→\th.mux.ServeHTTP(w, r)\n   142→}\n   143→\n   144→// --- HTML handlers ---\n   145→\n   146→// projectOverviewEntry holds data for a single project card on the landing page.\n   147→type projectOverviewEntry struct {\n   148→\tDir         string\n   149→\tLabel       string\n   150→\tHealth      domain.HealthResult\n   151→\tRecentRuns  []recentRunDot\n   152→\tActiveCount int\n   153→}\n   154→\n   155→// recentRunDot is a minimal representation of a run for the mini history display.\n   156→type recentRunDot struct {\n   157→\tID    string\n   158→\tState string\n   159→}\n   160→\n   161→const healthWindowSize = 10\n   162→\n   163→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   164→\tprojects, _ := h.store.ListProjects(r.Context())\n   165→\tlabels := projectLabels(projects)\n   166→\n   167→\tvar entries []projectOverviewEntry\n   168→\tfor _, dir := range projects {\n   169→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   170→\t\tif err != nil {\n   171→\t\t\tcontinue\n   172→\t\t}\n   173→\n   174→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   175→\t\trunValues := make([]domain.Run, len(runs))\n   176→\t\tfor i, rr := range runs {\n   177→\t\t\trunValues[i] = *rr\n   178→\t\t}\n   179→\n   180→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   181→\n   182→\t\t// Take the last N runs for the mini history (most recent first).\n   183→\t\tn := healthWindowSize\n   184→\t\tif n > len(runs) {\n   185→\t\t\tn = len(runs)\n   186→\t\t}\n   187→\t\tdots := make([]recentRunDot, n)\n   188→\t\tfor i := 0; i < n; i++ {\n   189→\t\t\tdots[i] = recentRunDot{\n   190→\t\t\t\tID:    runs[i].ID,\n   191→\t\t\t\tState: string(runs[i].State),\n   192→\t\t\t}\n   193→\t\t}\n   194→\n   195→\t\tvar activeCount int\n   196→\t\tfor _, rr := range runs {\n   197→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   198→\t\t\t\tactiveCount++\n   199→\t\t\t}\n   200→\t\t}\n   201→\n   202→\t\tentries = append(entries, projectOverviewEntry{\n   203→\t\t\tDir:         dir,\n   204→\t\t\tLabel:       labels[dir],\n   205→\t\t\tHealth:      health,\n   206→\t\t\tRecentRuns:  dots,\n   207→\t\t\tActiveCount: activeCount,\n   208→\t\t})\n   209→\t}\n   210→\n   211→\tsort.Slice(entries, func(i, j int) bool {\n   212→\t\treturn entries[i].Label < entries[j].Label\n   213→\t})\n   214→\n   215→\tdata := map[string]any{\n   216→\t\t\"Title\":    \"Projects\",\n   217→\t\t\"Projects\": entries,\n   218→\t}\n   219→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   220→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   221→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   222→\t}\n   223→}\n   224→\n   225→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   226→\tprojectFilter := r.URL.Query().Get(\"project\")\n   227→\n   228→\tvar runs []*domain.Run\n   229→\tvar err error\n   230→\tif projectFilter != \"\" {\n   231→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   232→\t} else {\n   233→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   234→\t}\n   235→\tif err != nil {\n   236→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   237→\t\treturn\n   238→\t}\n   239→\n   240→\tprojects, _ := h.store.ListProjects(r.Context())\n   241→\tlabels := projectLabels(projects)\n   242→\n   243→\t// Count retained containers per project\n   244→\tcontainerCounts := map[string]int{}\n   245→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   246→\tfor _, run := range allRuns {\n   247→\t\tif run.ContainerKept {\n   248→\t\t\tcontainerCounts[run.ProjectDir]++\n   249→\t\t}\n   250→\t}\n   251→\n   252→\tvar projectList []projectEntry\n   253→\tfor _, dir := range projects {\n   254→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   255→\t}\n   256→\tsort.Slice(projectList, func(i, j int) bool {\n   257→\t\treturn projectList[i].Label < projectList[j].Label\n   258→\t})\n   259→\n   260→\t// Compute filter label for URL generation\n   261→\tvar filterLabel string\n   262→\tif projectFilter != \"\" {\n   263→\t\tfilterLabel = labels[projectFilter]\n   264→\t}\n   265→\n   266→\tdata := map[string]any{\n   267→\t\t\"Title\":              \"Runs\",\n   268→\t\t\"Runs\":               runs,\n   269→\t\t\"Projects\":           projectList,\n   270→\t\t\"ProjectFilter\":      projectFilter,\n   271→\t\t\"ProjectFilterLabel\": filterLabel,\n   272→\t\t\"ProjectLabels\":      labels,\n   273→\t}\n   274→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   275→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   276→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   277→\t}\n   278→}\n   279→\n   280→// stepEntry is a merged view of a step execution for the template.\n   281→type stepEntry struct {\n   282→\tIndex     int\n   283→\tStepName  string\n   284→\tResult    string\n   285→\tStartedAt time.Time\n   286→\tDuration  string\n   287→}\n   288→\n   289→// mergeCaptures collapses started/completed capture pairs into single entries.\n   290→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   291→\tvar entries []stepEntry\n   292→\t// Track pending started rows by step name (LIFO for retries)\n   293→\tpending := map[string]*domain.StepExecution{}\n   294→\n   295→\tfor _, c := range caps {\n   296→\t\tif c.Result == \"\" {\n   297→\t\t\t// step_started row\n   298→\t\t\tpending[c.StepName] = c\n   299→\t\t\tcontinue\n   300→\t\t}\n   301→\t\t// step_completed row — merge with pending started if available\n   302→\t\tstartedAt := c.StartedAt\n   303→\t\tif started := pending[c.StepName]; started != nil {\n   304→\t\t\tstartedAt = started.StartedAt\n   305→\t\t\tdelete(pending, c.StepName)\n   306→\t\t}\n   307→\t\tentries = append(entries, stepEntry{\n   308→\t\t\tIndex:     len(entries),\n   309→\t\t\tStepName:  c.StepName,\n   310→\t\t\tResult:    c.Result,\n   311→\t\t\tStartedAt: startedAt,\n   312→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   313→\t\t})\n   314→\t}\n   315→\n   316→\t// Append any started-but-not-completed steps (still running)\n   317→\tfor _, c := range caps {\n   318→\t\tif c.Result == \"\" {\n   319→\t\t\tif _, used := pending[c.StepName]; !used {\n   320→\t\t\t\tcontinue\n   321→\t\t\t}\n   322→\t\t\tentries = append(entries, stepEntry{\n   323→\t\t\t\tIndex:     len(entries),\n   324→\t\t\t\tStepName:  c.StepName,\n   325→\t\t\t\tStartedAt: c.StartedAt,\n   326→\t\t\t})\n   327→\t\t\tdelete(pending, c.StepName)\n   328→\t\t}\n   329→\t}\n   330→\n   331→\treturn entries\n   332→}\n   333→\n   334→// containerState inspects the container for a run and returns one of:\n   335→//   - \"running\"   – container exists and is running\n   336→//   - \"stopped\"   – container exists, not running, not kept\n   337→//   - \"available\" – container exists, not running, kept (can be deleted)\n   338→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   339→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   340→\tif run.ContainerID == \"\" {\n   341→\t\treturn \"removed\"\n   342→\t}\n   343→\tmgr, ok := h.container.(ContainerManager)\n   344→\tif !ok {\n   345→\t\treturn \"removed\"\n   346→\t}\n   347→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   348→\tif err != nil {\n   349→\t\treturn \"removed\"\n   350→\t}\n   351→\tif status.Running {\n   352→\t\treturn \"running\"\n   353→\t}\n   354→\tif run.ContainerKept {\n   355→\t\treturn \"available\"\n   356→\t}\n   357→\treturn \"stopped\"\n   358→}\n   359→\n   360→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   361→\tid := r.PathValue(\"id\")\n   362→\n   363→\trun, err := h.store.GetRun(r.Context(), id)\n   364→\tif err != nil {\n   365→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   366→\t\treturn\n   367→\t}\n   368→\n   369→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   370→\tif err != nil {\n   371→\t\tcaps = nil // non-fatal\n   372→\t}\n   373→\n   374→\tsteps := mergeCaptures(caps)\n   375→\n   376→\tdata := map[string]any{\n   377→\t\t\"Title\":          \"Run \" + run.ID,\n   378→\t\t\"Run\":            run,\n   379→\t\t\"Steps\":          steps,\n   380→\t\t\"Page\":           \"detail\",\n   381→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   382→\t}\n   383→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   384→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   385→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   386→\t}\n   387→}\n   388→\n   389→// --- JSON API handlers ---\n   390→\n   391→type apiRun struct {\n   392→\tID           string `json:\"id\"`\n   393→\tWorkflowName string `json:\"workflow_name\"`\n   394→\tProjectDir   string `json:\"project_dir\"`\n   395→\tProjectLabel string `json:\"project_label\"`\n   396→\tState        string `json:\"state\"`\n   397→\tStartedAt    string `json:\"started_at\"`\n   398→\tCompletedAt  string `json:\"completed_at\"`\n   399→\tContainerID  string `json:\"container_id\"`\n   400→\tErrorMessage string `json:\"error_message\"`\n   401→}\n   402→\n   403→type apiStep struct {\n   404→\tStepName    string `json:\"step_name\"`\n   405→\tResult      string `json:\"result\"`\n   406→\tStartedAt   string `json:\"started_at\"`\n   407→\tCompletedAt string `json:\"completed_at\"`\n   408→\tDuration    string `json:\"duration\"`\n   409→}\n   410→\n   411→type apiRunDetail struct {\n   412→\tapiRun\n   413→\tContainerState string    `json:\"container_state\"`\n   414→\tSteps          []apiStep `json:\"steps\"`\n   415→}\n   416→\n   417→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   418→\treturn apiRun{\n   419→\t\tID:           r.ID,\n   420→\t\tWorkflowName: r.WorkflowName,\n   421→\t\tProjectDir:   r.ProjectDir,\n   422→\t\tProjectLabel: labels[r.ProjectDir],\n   423→\t\tState:        string(r.State),\n   424→\t\tStartedAt:    formatTime(r.StartedAt),\n   425→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   426→\t\tContainerID:  r.ContainerID,\n   427→\t\tErrorMessage: r.ErrorMessage,\n   428→\t}\n   429→}\n   430→\n   431→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   432→\tprojectFilter := r.URL.Query().Get(\"project\")\n   433→\n   434→\tvar runs []*domain.Run\n   435→\tvar err error\n   436→\tif projectFilter != \"\" {\n   437→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   438→\t} else {\n   439→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   440→\t}\n   441→\tif err != nil {\n   442→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   443→\t\treturn\n   444→\t}\n   445→\n   446→\tprojects, _ := h.store.ListProjects(r.Context())\n   447→\tlabels := projectLabels(projects)\n   448→\n   449→\tresult := make([]apiRun, len(runs))\n   450→\tfor i, run := range runs {\n   451→\t\tresult[i] = toAPIRun(run, labels)\n   452→\t}\n   453→\n   454→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   455→\tjson.NewEncoder(w).Encode(result)\n   456→}\n   457→\n   458→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   459→\tprojects, err := h.store.ListProjects(r.Context())\n   460→\tif err != nil {\n   461→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   462→\t\treturn\n   463→\t}\n   464→\tlabels := projectLabels(projects)\n   465→\n   466→\ttype apiHealth struct {\n   467→\t\tStatus string `json:\"status\"`\n   468→\t\tPassed int    `json:\"passed\"`\n   469→\t\tFailed int    `json:\"failed\"`\n   470→\t\tTotal  int    `json:\"total\"`\n   471→\t}\n   472→\ttype apiProject struct {\n   473→\t\tDir         string    `json:\"dir\"`\n   474→\t\tLabel       string    `json:\"label\"`\n   475→\t\tHealth      apiHealth `json:\"health\"`\n   476→\t\tActiveCount int       `json:\"active_count\"`\n   477→\t}\n   478→\tresult := make([]apiProject, len(projects))\n   479→\tfor i, dir := range projects {\n   480→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   481→\t\trunValues := make([]domain.Run, len(runs))\n   482→\t\tfor j, rr := range runs {\n   483→\t\t\trunValues[j] = *rr\n   484→\t\t}\n   485→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   486→\t\tvar activeCount int\n   487→\t\tfor _, rr := range runs {\n   488→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   489→\t\t\t\tactiveCount++\n   490→\t\t\t}\n   491→\t\t}\n   492→\t\tresult[i] = apiProject{\n   493→\t\t\tDir:   dir,\n   494→\t\t\tLabel: labels[dir],\n   495→\t\t\tHealth: apiHealth{\n   496→\t\t\t\tStatus: string(health.Status),\n   497→\t\t\t\tPassed: health.Passed,\n   498→\t\t\t\tFailed: health.Failed,\n   499→\t\t\t\tTotal:  health.Total,\n   500→\t\t\t},\n   501→\t\t\tActiveCount: activeCount,\n   502→\t\t}\n   503→\t}\n   504→\n   505→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   506→\tjson.NewEncoder(w).Encode(result)\n   507→}\n   508→\n   509→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   510→\tid := r.PathValue(\"id\")\n   511→\n   512→\trun, err := h.store.GetRun(r.Context(), id)\n   513→\tif err != nil {\n   514→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   515→\t\treturn\n   516→\t}\n   517→\n   518→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   519→\tif err != nil {\n   520→\t\tcaps = nil\n   521→\t}\n   522→\n   523→\tprojects, _ := h.store.ListProjects(r.Context())\n   524→\tlabels := projectLabels(projects)\n   525→\n   526→\tmerged := mergeCaptures(caps)\n   527→\tsteps := make([]apiStep, len(merged))\n   528→\tfor i, e := range merged {\n   529→\t\tsteps[i] = apiStep{\n   530→\t\t\tStepName:  e.StepName,\n   531→\t\t\tResult:    e.Result,\n   532→\t\t\tStartedAt: formatTime(e.StartedAt),\n   533→\t\t\tDuration:  e.Duration,\n   534→\t\t}\n   535→\t}\n   536→\n   537→\tdetail := apiRunDetail{\n   538→\t\tapiRun:         toAPIRun(run, labels),\n   539→\t\tContainerState: h.containerState(r.Context(), run),\n   540→\t\tSteps:          steps,\n   541→\t}\n   542→\n   543→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   544→\tjson.NewEncoder(w).Encode(detail)\n   545→}\n   546→\n   547→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   548→\tid := r.PathValue(\"id\")\n   549→\tstep := r.PathValue(\"step\")\n   550→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   551→\n   552→\trun, err := h.store.GetRun(r.Context(), id)\n   553→\tif err != nil {\n   554→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   555→\t\treturn\n   556→\t}\n   557→\n   558→\t// Try log index first for fast lookup\n   559→\tif h.logStore != nil {\n   560→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   561→\t\tif err == nil && len(logFiles) > 0 {\n   562→\t\t\t// If type filter specified, narrow results\n   563→\t\t\tfor _, lf := range logFiles {\n   564→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   565→\t\t\t\t\tcontinue\n   566→\t\t\t\t}\n   567→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   568→\t\t\t\tif readErr == nil && len(data) > 0 {\n   569→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   570→\t\t\t\t\tw.Write(data)\n   571→\t\t\t\t\treturn\n   572→\t\t\t\t}\n   573→\t\t\t}\n   574→\t\t}\n   575→\t}\n   576→\n   577→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   578→\n   579→\t// Fall back to file path conventions\n   580→\t// If type is \"llm\", try llm-<step>.log\n   581→\tif logType == \"llm\" {\n   582→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   583→\t\tdata, err := os.ReadFile(llmPath)\n   584→\t\tif err == nil && len(data) > 0 {\n   585→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   586→\t\t\tw.Write(data)\n   587→\t\t\treturn\n   588→\t\t}\n   589→\t}\n   590→\n   591→\t// Try per-step output first, fall back to container.log, then live docker logs\n   592→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   593→\tdata, err := os.ReadFile(outputPath)\n   594→\tif err == nil && len(data) > 0 {\n   595→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   596→\t\tw.Write(data)\n   597→\t\treturn\n   598→\t}\n   599→\n   600→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   601→\tdata, err = os.ReadFile(containerLog)\n   602→\tif err == nil && len(data) > 0 {\n   603→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   604→\t\tw.Write(data)\n   605→\t\treturn\n   606→\t}\n   607→\n   608→\t// Last resort: try live docker logs from still-existing container\n   609→\tif h.container != nil && run.ContainerID != \"\" {\n   610→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   611→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   612→\t\t\tw.Write([]byte(logs))\n   613→\t\t\treturn\n   614→\t\t}\n   615→\t}\n   616→\n   617→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   618→}\n   619→\n   620→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   621→\tid := r.PathValue(\"id\")\n   622→\n   623→\trun, err := h.store.GetRun(r.Context(), id)\n   624→\tif err != nil {\n   625→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   626→\t\tw.WriteHeader(http.StatusNotFound)\n   627→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   628→\t\treturn\n   629→\t}\n   630→\n   631→\tmgr, ok := h.container.(ContainerManager)\n   632→\tif !ok || run.ContainerID == \"\" {\n   633→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   634→\t\tw.WriteHeader(http.StatusBadRequest)\n   635→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   636→\t\treturn\n   637→\t}\n   638→\n   639→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   640→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   641→\t\tw.WriteHeader(http.StatusInternalServerError)\n   642→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   643→\t\treturn\n   644→\t}\n   645→\n   646→\trun.ContainerKept = false\n   647→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   648→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   649→\t\tw.WriteHeader(http.StatusInternalServerError)\n   650→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   651→\t\treturn\n   652→\t}\n   653→\n   654→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   655→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   656→}\n   657→\n   658→// handleAPIStream serves an SSE stream of log lines for a run.\n   659→// For active runs, it subscribes to the live broadcaster.\n   660→// For completed runs, it serves the archived full.log then closes.\n   661→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   662→\tid := r.PathValue(\"id\")\n   663→\n   664→\trun, err := h.store.GetRun(r.Context(), id)\n   665→\tif err != nil {\n   666→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   667→\t\treturn\n   668→\t}\n   669→\n   670→\tflusher, ok := w.(http.Flusher)\n   671→\tif !ok {\n   672→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   673→\t\treturn\n   674→\t}\n   675→\n   676→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   677→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   678→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   679→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   680→\n   681→\tisComplete := run.State == domain.RunStateSucceeded ||\n   682→\t\trun.State == domain.RunStateFailed ||\n   683→\t\trun.State == domain.RunStateCancelled\n   684→\n   685→\tif isComplete {\n   686→\t\t// Serve archived full.log\n   687→\t\th.streamFullLog(w, flusher, run)\n   688→\t\t// Send done event\n   689→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   690→\t\tflusher.Flush()\n   691→\t\treturn\n   692→\t}\n   693→\n   694→\t// Active run: subscribe to live broadcaster\n   695→\tif h.logBroadcast == nil {\n   696→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   697→\t\treturn\n   698→\t}\n   699→\n   700→\tsub := h.logBroadcast.Subscribe(id)\n   701→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   702→\n   703→\tctx := r.Context()\n   704→\tfor {\n   705→\t\tselect {\n   706→\t\tcase <-ctx.Done():\n   707→\t\t\treturn\n   708→\t\tcase line, ok := <-sub.C:\n   709→\t\t\tif !ok {\n   710→\t\t\t\t// Stream finished (run completed)\n   711→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   712→\t\t\t\tflusher.Flush()\n   713→\t\t\t\treturn\n   714→\t\t\t}\n   715→\t\t\tdata, _ := json.Marshal(line)\n   716→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   717→\t\t\tflusher.Flush()\n   718→\t\t}\n   719→\t}\n   720→}\n   721→\n   722→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   723→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   724→\n   725→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   726→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   727→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   728→\tf, err := os.Open(logPath)\n   729→\tif err != nil {\n   730→\t\treturn\n   731→\t}\n   732→\tdefer f.Close()\n   733→\n   734→\tscanner := bufio.NewScanner(f)\n   735→\tfor scanner.Scan() {\n   736→\t\ttext := scanner.Text()\n   737→\t\tline := parseFullLogLine(text)\n   738→\t\tdata, _ := json.Marshal(line)\n   739→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   740→\t\tflusher.Flush()\n   741→\t}\n   742→}\n   743→\n   744→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   745→func parseFullLogLine(text string) logstream.LogLine {\n   746→\tm := logLineRegex.FindStringSubmatch(text)\n   747→\tif m == nil {\n   748→\t\treturn logstream.LogLine{\n   749→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   750→\t\t\tType:      \"script\",\n   751→\t\t\tContent:   text,\n   752→\t\t}\n   753→\t}\n   754→\treturn logstream.LogLine{\n   755→\t\tTimestamp: m[1],\n   756→\t\tType:      m[2],\n   757→\t\tContent:   m[3],\n   758→\t}\n   759→}\n   760→\n   761→// --- Project detail handlers ---\n   762→\n   763→// resolveProjectDir resolves a project label from the URL to its directory path.\n   764→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   765→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   766→\tlabel := r.PathValue(\"name\")\n   767→\tprojects, _ := h.store.ListProjects(r.Context())\n   768→\tlabels := projectLabels(projects)\n   769→\tfor dir, l := range labels {\n   770→\t\tif l == label {\n   771→\t\t\treturn dir, label, true\n   772→\t\t}\n   773→\t}\n   774→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   775→\tw.WriteHeader(http.StatusNotFound)\n   776→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   777→\treturn \"\", \"\", false\n   778→}\n   779→\n   780→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   781→\tdir, label, ok := h.resolveProjectDir(w, r)\n   782→\tif !ok {\n   783→\t\treturn\n   784→\t}\n   785→\n   786→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   787→\tn := 10\n   788→\tif n > len(runs) {\n   789→\t\tn = len(runs)\n   790→\t}\n   791→\tdots := make([]recentRunDot, n)\n   792→\tfor i := 0; i < n; i++ {\n   793→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   794→\t}\n   795→\n   796→\tdata := map[string]any{\n   797→\t\t\"Title\":      label,\n   798→\t\t\"Label\":      label,\n   799→\t\t\"Dir\":        dir,\n   800→\t\t\"RecentRuns\": dots,\n   801→\t}\n   802→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   803→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   804→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   805→\t}\n   806→}\n   807→\n   808→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   809→\tlabel := r.PathValue(\"name\")\n   810→\tprojects, _ := h.store.ListProjects(r.Context())\n   811→\tlabels := projectLabels(projects)\n   812→\n   813→\tvar projectDir string\n   814→\tfor dir, l := range labels {\n   815→\t\tif l == label {\n   816→\t\t\tprojectDir = dir\n   817→\t\t\tbreak\n   818→\t\t}\n   819→\t}\n   820→\tif projectDir == \"\" {\n   821→\t\thttp.Error(w, \"project not found\", http.StatusNotFound)\n   822→\t\treturn\n   823→\t}\n   824→\n   825→\truns, err := h.store.ListRunsByProject(r.Context(), projectDir, time.Time{})\n   826→\tif err != nil {\n   827→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   828→\t\treturn\n   829→\t}\n   830→\n   831→\t// Count retained containers per project\n   832→\tcontainerCounts := map[string]int{}\n   833→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   834→\tfor _, run := range allRuns {\n   835→\t\tif run.ContainerKept {\n   836→\t\t\tcontainerCounts[run.ProjectDir]++\n   837→\t\t}\n   838→\t}\n   839→\n   840→\tvar projectList []projectEntry\n   841→\tfor _, dir := range projects {\n   842→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   843→\t}\n   844→\tsort.Slice(projectList, func(i, j int) bool {\n   845→\t\treturn projectList[i].Label < projectList[j].Label\n   846→\t})\n   847→\n   848→\tdata := map[string]any{\n   849→\t\t\"Title\":              \"Runs\",\n   850→\t\t\"Runs\":               runs,\n   851→\t\t\"Projects\":           projectList,\n   852→\t\t\"ProjectFilter\":      projectDir,\n   853→\t\t\"ProjectFilterLabel\": label,\n   854→\t\t\"ProjectLabels\":      labels,\n   855→\t}\n   856→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   857→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   858→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   859→\t}\n   860→}\n   861→\n   862→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   863→\tdir, _, ok := h.resolveProjectDir(w, r)\n   864→\tif !ok {\n   865→\t\treturn\n   866→\t}\n   867→\n   868→\t// Docker image: read FROM line from Dockerfile\n   869→\tdockerImage := \"\"\n   870→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   871→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   872→\t\t// Find the last FROM line (final stage)\n   873→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   874→\t\t\ttrimmed := strings.TrimSpace(line)\n   875→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   876→\t\t\t\tparts := strings.Fields(trimmed)\n   877→\t\t\t\tif len(parts) >= 2 {\n   878→\t\t\t\t\tdockerImage = parts[1]\n   879→\t\t\t\t}\n   880→\t\t\t}\n   881→\t\t}\n   882→\t}\n   883→\n   884→\t// Version\n   885→\tversion := 0\n   886→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   887→\tif data, err := os.ReadFile(versionPath); err == nil {\n   888→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   889→\t\t\tversion = v\n   890→\t\t}\n   891→\t}\n   892→\n   893→\t// Prompt files history\n   894→\ttype commitEntry struct {\n   895→\t\tSHA     string `json:\"sha\"`\n   896→\t\tDate    string `json:\"date\"`\n   897→\t\tMessage string `json:\"message\"`\n   898→\t}\n   899→\ttype promptFile struct {\n   900→\t\tPath    string        `json:\"path\"`\n   901→\t\tHistory []commitEntry `json:\"history\"`\n   902→\t}\n   903→\n   904→\tvar promptFiles []promptFile\n   905→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   906→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n   907→\t\tfor _, e := range entries {\n   908→\t\t\tif e.IsDir() {\n   909→\t\t\t\tcontinue\n   910→\t\t\t}\n   911→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n   912→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n   913→\t\t\tcmd.Dir = dir\n   914→\t\t\tout, err := cmd.Output()\n   915→\t\t\tif err != nil {\n   916→\t\t\t\tcontinue\n   917→\t\t\t}\n   918→\t\t\tvar history []commitEntry\n   919→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n   920→\t\t\t\tif line == \"\" {\n   921→\t\t\t\t\tcontinue\n   922→\t\t\t\t}\n   923→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n   924→\t\t\t\tif len(parts) < 3 {\n   925→\t\t\t\t\tcontinue\n   926→\t\t\t\t}\n   927→\t\t\t\t// Parse date to short form\n   928→\t\t\t\tdateStr := parts[1]\n   929→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n   930→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n   931→\t\t\t\t}\n   932→\t\t\t\thistory = append(history, commitEntry{\n   933→\t\t\t\t\tSHA:     parts[0][:7],\n   934→\t\t\t\t\tDate:    dateStr,\n   935→\t\t\t\t\tMessage: parts[2],\n   936→\t\t\t\t})\n   937→\t\t\t}\n   938→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n   939→\t\t}\n   940→\t}\n   941→\n   942→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   943→\tjson.NewEncoder(w).Encode(map[string]any{\n   944→\t\t\"docker_image\": dockerImage,\n   945→\t\t\"version\":      version,\n   946→\t\t\"prompt_files\": promptFiles,\n   947→\t})\n   948→}\n   949→\n   950→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n   951→\tdir, _, ok := h.resolveProjectDir(w, r)\n   952→\tif !ok {\n   953→\t\treturn\n   954→\t}\n   955→\tfile := r.URL.Query().Get(\"file\")\n   956→\tsha := r.URL.Query().Get(\"sha\")\n   957→\tif file == \"\" || sha == \"\" {\n   958→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n   959→\t\treturn\n   960→\t}\n   961→\n   962→\t// Validate sha is alphanumeric to prevent injection\n   963→\tfor _, c := range sha {\n   964→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n   965→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n   966→\t\t\treturn\n   967→\t\t}\n   968→\t}\n   969→\n   970→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n   971→\tcmd.Dir = dir\n   972→\tout, err := cmd.Output()\n   973→\tif err != nil {\n   974→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n   975→\t\treturn\n   976→\t}\n   977→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   978→\tw.Write(out)\n   979→}\n   980→\n   981→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n   982→\tdir, _, ok := h.resolveProjectDir(w, r)\n   983→\tif !ok {\n   984→\t\treturn\n   985→\t}\n   986→\n   987→\tclocheDir := filepath.Join(dir, \".cloche\")\n   988→\tentries, err := os.ReadDir(clocheDir)\n   989→\tif err != nil {\n   990→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   991→\t\tjson.NewEncoder(w).Encode([]any{})\n   992→\t\treturn\n   993→\t}\n   994→\n   995→\ttype apiWire struct {\n   996→\t\tFrom   string `json:\"from\"`\n   997→\t\tResult string `json:\"result\"`\n   998→\t\tTo     string `json:\"to\"`\n   999→\t}\n  1000→\ttype apiStepDef struct {\n  1001→\t\tName    string            `json:\"name\"`\n  1002→\t\tType    string            `json:\"type\"`\n  1003→\t\tResults []string          `json:\"results\"`\n  1004→\t\tConfig  map[string]string `json:\"config\"`\n  1005→\t}\n  1006→\ttype apiWorkflow struct {\n  1007→\t\tName      string       `json:\"name\"`\n  1008→\t\tFile      string       `json:\"file\"`\n  1009→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1010→\t\tWires     []apiWire    `json:\"wires\"`\n  1011→\t\tEntryStep string       `json:\"entry_step\"`\n  1012→\t}\n  1013→\n  1014→\tvar workflows []apiWorkflow\n  1015→\tfor _, e := range entries {\n  1016→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1017→\t\t\tcontinue\n  1018→\t\t}\n  1019→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1020→\t\tif err != nil {\n  1021→\t\t\tcontinue\n  1022→\t\t}\n  1023→\t\twf, err := dsl.ParseForContainer(string(data))\n  1024→\t\tif err != nil {\n  1025→\t\t\tcontinue\n  1026→\t\t}\n  1027→\t\tvar steps []apiStepDef\n  1028→\t\tfor _, s := range wf.Steps {\n  1029→\t\t\tsteps = append(steps, apiStepDef{\n  1030→\t\t\t\tName:    s.Name,\n  1031→\t\t\t\tType:    string(s.Type),\n  1032→\t\t\t\tResults: s.Results,\n  1033→\t\t\t\tConfig:  s.Config,\n  1034→\t\t\t})\n  1035→\t\t}\n  1036→\t\t// Sort steps by name for consistent ordering\n  1037→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1038→\n  1039→\t\tvar wires []apiWire\n  1040→\t\tfor _, wire := range wf.Wiring {\n  1041→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1042→\t\t}\n  1043→\n  1044→\t\tworkflows = append(workflows, apiWorkflow{\n  1045→\t\t\tName:      wf.Name,\n  1046→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1047→\t\t\tSteps:     steps,\n  1048→\t\t\tWires:     wires,\n  1049→\t\t\tEntryStep: wf.EntryStep,\n  1050→\t\t})\n  1051→\t}\n  1052→\n  1053→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1054→\tjson.NewEncoder(w).Encode(workflows)\n  1055→}\n  1056→\n  1057→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1058→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1059→\tif !ok {\n  1060→\t\treturn\n  1061→\t}\n  1062→\tworkflowName := r.PathValue(\"workflow\")\n  1063→\tstepName := r.PathValue(\"step\")\n  1064→\n  1065→\t// Find the workflow file\n  1066→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1067→\tvar wf *domain.Workflow\n  1068→\tentries, _ := os.ReadDir(clocheDir)\n  1069→\tfor _, e := range entries {\n  1070→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1071→\t\t\tcontinue\n  1072→\t\t}\n  1073→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1074→\t\tif err != nil {\n  1075→\t\t\tcontinue\n  1076→\t\t}\n  1077→\t\tparsed, err := dsl.ParseForContainer(string(data))\n  1078→\t\tif err != nil {\n  1079→\t\t\tcontinue\n  1080→\t\t}\n  1081→\t\tif parsed.Name == workflowName {\n  1082→\t\t\twf = parsed\n  1083→\t\t\tbreak\n  1084→\t\t}\n  1085→\t}\n  1086→\tif wf == nil {\n  1087→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1088→\t\treturn\n  1089→\t}\n  1090→\n  1091→\tstep, ok := wf.Steps[stepName]\n  1092→\tif !ok {\n  1093→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1094→\t\treturn\n  1095→\t}\n  1096→\n  1097→\t// Try to read the referenced file from step config\n  1098→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1099→\n  1100→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1101→\t\tcontent, err := resolveFileRef(prompt, dir)\n  1102→\t\tif err == nil {\n  1103→\t\t\tw.Write([]byte(content))\n  1104→\t\t\treturn\n  1105→\t\t}\n  1106→\t}\n  1107→\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n  1108→\t\tcontent, _ := resolveFileRef(cmd, dir)\n  1109→\t\tw.Write([]byte(content))\n  1110→\t\treturn\n  1111→\t}\n  1112→\tif script := step.Config[\"script\"]; script != \"\" {\n  1113→\t\tcontent, _ := resolveFileRef(script, dir)\n  1114→\t\tw.Write([]byte(content))\n  1115→\t\treturn\n  1116→\t}\n  1117→\n  1118→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1119→}\n  1120→\n  1121→// --- Template helpers ---\n  1122→\n  1123→// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n  1124→// If the value uses file() syntax, the referenced file is read from disk.\n  1125→// Otherwise the value is returned as-is.\n  1126→func resolveFileRef(value, baseDir string) (string, error) {\n  1127→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n  1128→\t\tpath := value[6 : len(value)-2]\n  1129→\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n  1130→\t\tif err != nil {\n  1131→\t\t\treturn \"\", err\n  1132→\t\t}\n  1133→\t\treturn string(data), nil\n  1134→\t}\n  1135→\treturn value, nil\n  1136→}\n  1137→\n  1138→func stateColor(state domain.RunState) string {\n  1139→\tswitch state {\n  1140→\tcase domain.RunStatePending:\n  1141→\t\treturn \"pending\"\n  1142→\tcase domain.RunStateRunning:\n  1143→\t\treturn \"running\"\n  1144→\tcase domain.RunStateSucceeded:\n  1145→\t\treturn \"succeeded\"\n  1146→\tcase domain.RunStateFailed:\n  1147→\t\treturn \"failed\"\n  1148→\tcase domain.RunStateCancelled:\n  1149→\t\treturn \"cancelled\"\n  1150→\tdefault:\n  1151→\t\treturn \"pending\"\n  1152→\t}\n  1153→}\n  1154→\n  1155→func healthColor(status domain.HealthStatus) string {\n  1156→\tswitch status {\n  1157→\tcase domain.HealthGreen:\n  1158→\t\treturn \"green\"\n  1159→\tcase domain.HealthYellow:\n  1160→\t\treturn \"yellow\"\n  1161→\tcase domain.HealthRed:\n  1162→\t\treturn \"red\"\n  1163→\tcase domain.HealthBlue:\n  1164→\t\treturn \"blue\"\n  1165→\tdefault:\n  1166→\t\treturn \"grey\"\n  1167→\t}\n  1168→}\n  1169→\n  1170→func formatTime(t time.Time) string {\n  1171→\tif t.IsZero() {\n  1172→\t\treturn \"\"\n  1173→\t}\n  1174→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1175→}\n  1176→\n  1177→func formatDuration(start, end time.Time) string {\n  1178→\tif start.IsZero() || end.IsZero() {\n  1179→\t\treturn \"\"\n  1180→\t}\n  1181→\td := end.Sub(start)\n  1182→\tif d < time.Second {\n  1183→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1184→\t}\n  1185→\tif d < time.Minute {\n  1186→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1187→\t}\n  1188→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1189→}\n  1190→\n  1191→func truncate(s string, n int) string {\n  1192→\tif len(s) <= n {\n  1193→\t\treturn s\n  1194→\t}\n  1195→\treturn s[:n] + \"...\"\n  1196→}\n  1197→\n  1198→func shortContainerID(id string) string {\n  1199→\tif len(id) > 12 {\n  1200→\t\treturn id[:12]\n  1201→\t}\n  1202→\treturn id\n  1203→}\n  1204→\n  1205→// projectLabels builds a mapping from full project directory paths to short\n  1206→// display labels. Each label is the final directory component (e.g.\n  1207→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1208→// the same final name, the parent directory is prepended to disambiguate\n  1209→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1210→func projectLabels(dirs []string) map[string]string {\n  1211→\tlabels := make(map[string]string, len(dirs))\n  1212→\t// Group dirs by their base name to detect conflicts.\n  1213→\tbyBase := map[string][]string{}\n  1214→\tfor _, d := range dirs {\n  1215→\t\tbase := filepath.Base(d)\n  1216→\t\tbyBase[base] = append(byBase[base], d)\n  1217→\t}\n  1218→\tfor base, paths := range byBase {\n  1219→\t\tif len(paths) == 1 {\n  1220→\t\t\tlabels[paths[0]] = base\n  1221→\t\t} else {\n  1222→\t\t\tfor _, p := range paths {\n  1223→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1224→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1225→\t\t\t}\n  1226→\t\t}\n  1227→\t}\n  1228→\treturn labels\n  1229→}\n  1230→\n  1231→type projectEntry struct {\n  1232→\tDir            string\n  1233→\tLabel          string\n  1234→\tContainerCount int\n  1235→}\n  1236→"}]},"parent_tool_use_id":null,"session_id":"8d363198-c076-4c57-820f-5b3722f41f4f","uuid":"ade3861b-3f84-47d3-a43e-e2b09dbc2b7e","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogStore     ports.LogStore\n\tcontainer    ContainerLogger\n\tlogBroadcast *logstream.Broadcaster\n\tpages        map[string]*template.Template\n\tmux          *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\t// Compute filter label for URL generation\n\tvar filterLabel string\n\tif projectFilter != \"\" {\n\t\tfilterLabel = labels[projectFilter]\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":              \"Runs\",\n\t\t\"Runs\":               runs,\n\t\t\"Projects\":           projectList,\n\t\t\"ProjectFilter\":      projectFilter,\n\t\t\"ProjectFilterLabel\": filterLabel,\n\t\t\"ProjectLabels\":      labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar projectDir string\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\tprojectDir = dir\n\t\t\tbreak\n\t\t}\n\t}\n\tif projectDir == \"\" {\n\t\thttp.Error(w, \"project not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\truns, err := h.store.ListRunsByProject(r.Context(), projectDir, time.Time{})\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":              \"Runs\",\n\t\t\"Runs\":               runs,\n\t\t\"Projects\":           projectList,\n\t\t\"ProjectFilter\":      projectDir,\n\t\t\"ProjectFilterLabel\": label,\n\t\t\"ProjectLabels\":      labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.ParseForContainer(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.ParseForContainer(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tcontent, err := resolveFileRef(prompt, dir)\n\t\tif err == nil {\n\t\t\tw.Write([]byte(content))\n\t\t\treturn\n\t\t}\n\t}\n\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n\t\tcontent, _ := resolveFileRef(cmd, dir)\n\t\tw.Write([]byte(content))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tcontent, _ := resolveFileRef(script, dir)\n\t\tw.Write([]byte(content))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\n// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n// If the value uses file() syntax, the referenced file is read from disk.\n// Otherwise the value is returned as-is.\nfunc resolveFileRef(value, baseDir string) (string, error) {\n\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n\t\tpath := value[6 : len(value)-2]\n\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n\t\tif err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\treturn string(data), nil\n\t}\n\treturn value, nil\n}\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1236,"startLine":1,"totalLines":1236}}}
