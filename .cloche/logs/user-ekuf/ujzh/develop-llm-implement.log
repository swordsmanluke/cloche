{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L6pqzSrdhJrdLXoKW7BCYY","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"os/exec\"\n    14→\t\"path/filepath\"\n    15→\t\"regexp\"\n    16→\t\"sort\"\n    17→\t\"strconv\"\n    18→\t\"strings\"\n    19→\t\"time\"\n    20→\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→)\n    26→\n    27→// HandlerOption configures optional Handler dependencies.\n    28→type HandlerOption func(*Handler)\n    29→\n    30→// WithContainerLogger sets the container runtime for fetching live logs.\n    31→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32→\treturn func(h *Handler) { h.container = c }\n    33→}\n    34→\n    35→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36→func WithContainerManager(c ContainerManager) HandlerOption {\n    37→\treturn func(h *Handler) { h.container = c }\n    38→}\n    39→\n    40→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42→\treturn func(h *Handler) { h.logBroadcast = b }\n    43→}\n    44→\n    45→// WithLogStore sets the log store for indexed log file lookups.\n    46→func WithLogStore(ls ports.LogStore) HandlerOption {\n    47→\treturn func(h *Handler) { h.logStore = ls }\n    48→}\n    49→\n    50→//go:embed templates/*.html static/*\n    51→var content embed.FS\n    52→\n    53→// Handler serves the web dashboard.\n    54→// ContainerLogger can retrieve logs from a container by ID.\n    55→type ContainerLogger interface {\n    56→\tLogs(ctx context.Context, containerID string) (string, error)\n    57→}\n    58→\n    59→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    60→type ContainerManager interface {\n    61→\tContainerLogger\n    62→\tRemove(ctx context.Context, containerID string) error\n    63→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    64→}\n    65→\n    66→type Handler struct {\n    67→\tstore        ports.RunStore\n    68→\tcaptures     ports.CaptureStore\n    69→\tlogStore     ports.LogStore\n    70→\tcontainer    ContainerLogger\n    71→\tlogBroadcast *logstream.Broadcaster\n    72→\tpages        map[string]*template.Template\n    73→\tmux          *http.ServeMux\n    74→}\n    75→\n    76→// NewHandler creates a web dashboard handler.\n    77→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    78→\tfuncMap := template.FuncMap{\n    79→\t\t\"stateColor\":       stateColor,\n    80→\t\t\"healthColor\":      healthColor,\n    81→\t\t\"formatTime\":       formatTime,\n    82→\t\t\"formatDuration\":   formatDuration,\n    83→\t\t\"truncate\":         truncate,\n    84→\t\t\"shortContainerID\": shortContainerID,\n    85→\t}\n    86→\n    87→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n    88→\tif err != nil {\n    89→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n    90→\t}\n    91→\n    92→\tpages := map[string]*template.Template{}\n    93→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n    94→\t\tclone, err := base.Clone()\n    95→\t\tif err != nil {\n    96→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n    97→\t\t}\n    98→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n    99→\t\tif err != nil {\n   100→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   101→\t\t}\n   102→\t\tpages[page] = clone\n   103→\t}\n   104→\n   105→\th := &Handler{\n   106→\t\tstore:    store,\n   107→\t\tcaptures: captures,\n   108→\t\tpages:    pages,\n   109→\t\tmux:      http.NewServeMux(),\n   110→\t}\n   111→\tfor _, opt := range opts {\n   112→\t\topt(h)\n   113→\t}\n   114→\n   115→\tstaticFS, err := fs.Sub(content, \"static\")\n   116→\tif err != nil {\n   117→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   118→\t}\n   119→\n   120→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   121→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   122→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   123→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   124→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   125→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   126→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   127→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   128→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   129→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   130→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   131→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   132→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   133→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   134→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   135→\n   136→\treturn h, nil\n   137→}\n   138→\n   139→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   140→\th.mux.ServeHTTP(w, r)\n   141→}\n   142→\n   143→// --- HTML handlers ---\n   144→\n   145→// projectOverviewEntry holds data for a single project card on the landing page.\n   146→type projectOverviewEntry struct {\n   147→\tDir         string\n   148→\tLabel       string\n   149→\tHealth      domain.HealthResult\n   150→\tRecentRuns  []recentRunDot\n   151→\tActiveCount int\n   152→}\n   153→\n   154→// recentRunDot is a minimal representation of a run for the mini history display.\n   155→type recentRunDot struct {\n   156→\tID    string\n   157→\tState string\n   158→}\n   159→\n   160→const healthWindowSize = 10\n   161→\n   162→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   163→\tprojects, _ := h.store.ListProjects(r.Context())\n   164→\tlabels := projectLabels(projects)\n   165→\n   166→\tvar entries []projectOverviewEntry\n   167→\tfor _, dir := range projects {\n   168→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   169→\t\tif err != nil {\n   170→\t\t\tcontinue\n   171→\t\t}\n   172→\n   173→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   174→\t\trunValues := make([]domain.Run, len(runs))\n   175→\t\tfor i, rr := range runs {\n   176→\t\t\trunValues[i] = *rr\n   177→\t\t}\n   178→\n   179→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   180→\n   181→\t\t// Take the last N runs for the mini history (most recent first).\n   182→\t\tn := healthWindowSize\n   183→\t\tif n > len(runs) {\n   184→\t\t\tn = len(runs)\n   185→\t\t}\n   186→\t\tdots := make([]recentRunDot, n)\n   187→\t\tfor i := 0; i < n; i++ {\n   188→\t\t\tdots[i] = recentRunDot{\n   189→\t\t\t\tID:    runs[i].ID,\n   190→\t\t\t\tState: string(runs[i].State),\n   191→\t\t\t}\n   192→\t\t}\n   193→\n   194→\t\tvar activeCount int\n   195→\t\tfor _, rr := range runs {\n   196→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   197→\t\t\t\tactiveCount++\n   198→\t\t\t}\n   199→\t\t}\n   200→\n   201→\t\tentries = append(entries, projectOverviewEntry{\n   202→\t\t\tDir:         dir,\n   203→\t\t\tLabel:       labels[dir],\n   204→\t\t\tHealth:      health,\n   205→\t\t\tRecentRuns:  dots,\n   206→\t\t\tActiveCount: activeCount,\n   207→\t\t})\n   208→\t}\n   209→\n   210→\tsort.Slice(entries, func(i, j int) bool {\n   211→\t\treturn entries[i].Label < entries[j].Label\n   212→\t})\n   213→\n   214→\tdata := map[string]any{\n   215→\t\t\"Title\":    \"Projects\",\n   216→\t\t\"Projects\": entries,\n   217→\t}\n   218→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   219→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   220→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   221→\t}\n   222→}\n   223→\n   224→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   225→\tprojectFilter := r.URL.Query().Get(\"project\")\n   226→\n   227→\tvar runs []*domain.Run\n   228→\tvar err error\n   229→\tif projectFilter != \"\" {\n   230→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   231→\t} else {\n   232→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   233→\t}\n   234→\tif err != nil {\n   235→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   236→\t\treturn\n   237→\t}\n   238→\n   239→\tprojects, _ := h.store.ListProjects(r.Context())\n   240→\tlabels := projectLabels(projects)\n   241→\n   242→\t// Count retained containers per project\n   243→\tcontainerCounts := map[string]int{}\n   244→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   245→\tfor _, run := range allRuns {\n   246→\t\tif run.ContainerKept {\n   247→\t\t\tcontainerCounts[run.ProjectDir]++\n   248→\t\t}\n   249→\t}\n   250→\n   251→\tvar projectList []projectEntry\n   252→\tfor _, dir := range projects {\n   253→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   254→\t}\n   255→\tsort.Slice(projectList, func(i, j int) bool {\n   256→\t\treturn projectList[i].Label < projectList[j].Label\n   257→\t})\n   258→\n   259→\tdata := map[string]any{\n   260→\t\t\"Title\":         \"Runs\",\n   261→\t\t\"Runs\":          runs,\n   262→\t\t\"Projects\":      projectList,\n   263→\t\t\"ProjectFilter\": projectFilter,\n   264→\t\t\"ProjectLabels\": labels,\n   265→\t}\n   266→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   267→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   268→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   269→\t}\n   270→}\n   271→\n   272→// stepEntry is a merged view of a step execution for the template.\n   273→type stepEntry struct {\n   274→\tIndex     int\n   275→\tStepName  string\n   276→\tResult    string\n   277→\tStartedAt time.Time\n   278→\tDuration  string\n   279→}\n   280→\n   281→// mergeCaptures collapses started/completed capture pairs into single entries.\n   282→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   283→\tvar entries []stepEntry\n   284→\t// Track pending started rows by step name (LIFO for retries)\n   285→\tpending := map[string]*domain.StepExecution{}\n   286→\n   287→\tfor _, c := range caps {\n   288→\t\tif c.Result == \"\" {\n   289→\t\t\t// step_started row\n   290→\t\t\tpending[c.StepName] = c\n   291→\t\t\tcontinue\n   292→\t\t}\n   293→\t\t// step_completed row — merge with pending started if available\n   294→\t\tstartedAt := c.StartedAt\n   295→\t\tif started := pending[c.StepName]; started != nil {\n   296→\t\t\tstartedAt = started.StartedAt\n   297→\t\t\tdelete(pending, c.StepName)\n   298→\t\t}\n   299→\t\tentries = append(entries, stepEntry{\n   300→\t\t\tIndex:     len(entries),\n   301→\t\t\tStepName:  c.StepName,\n   302→\t\t\tResult:    c.Result,\n   303→\t\t\tStartedAt: startedAt,\n   304→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   305→\t\t})\n   306→\t}\n   307→\n   308→\t// Append any started-but-not-completed steps (still running)\n   309→\tfor _, c := range caps {\n   310→\t\tif c.Result == \"\" {\n   311→\t\t\tif _, used := pending[c.StepName]; !used {\n   312→\t\t\t\tcontinue\n   313→\t\t\t}\n   314→\t\t\tentries = append(entries, stepEntry{\n   315→\t\t\t\tIndex:     len(entries),\n   316→\t\t\t\tStepName:  c.StepName,\n   317→\t\t\t\tStartedAt: c.StartedAt,\n   318→\t\t\t})\n   319→\t\t\tdelete(pending, c.StepName)\n   320→\t\t}\n   321→\t}\n   322→\n   323→\treturn entries\n   324→}\n   325→\n   326→// containerState inspects the container for a run and returns one of:\n   327→//   - \"running\"   – container exists and is running\n   328→//   - \"stopped\"   – container exists, not running, not kept\n   329→//   - \"available\" – container exists, not running, kept (can be deleted)\n   330→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   331→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   332→\tif run.ContainerID == \"\" {\n   333→\t\treturn \"removed\"\n   334→\t}\n   335→\tmgr, ok := h.container.(ContainerManager)\n   336→\tif !ok {\n   337→\t\treturn \"removed\"\n   338→\t}\n   339→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   340→\tif err != nil {\n   341→\t\treturn \"removed\"\n   342→\t}\n   343→\tif status.Running {\n   344→\t\treturn \"running\"\n   345→\t}\n   346→\tif run.ContainerKept {\n   347→\t\treturn \"available\"\n   348→\t}\n   349→\treturn \"stopped\"\n   350→}\n   351→\n   352→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   353→\tid := r.PathValue(\"id\")\n   354→\n   355→\trun, err := h.store.GetRun(r.Context(), id)\n   356→\tif err != nil {\n   357→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   358→\t\treturn\n   359→\t}\n   360→\n   361→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   362→\tif err != nil {\n   363→\t\tcaps = nil // non-fatal\n   364→\t}\n   365→\n   366→\tsteps := mergeCaptures(caps)\n   367→\n   368→\tdata := map[string]any{\n   369→\t\t\"Title\":          \"Run \" + run.ID,\n   370→\t\t\"Run\":            run,\n   371→\t\t\"Steps\":          steps,\n   372→\t\t\"Page\":           \"detail\",\n   373→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   374→\t}\n   375→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   376→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   377→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   378→\t}\n   379→}\n   380→\n   381→// --- JSON API handlers ---\n   382→\n   383→type apiRun struct {\n   384→\tID           string `json:\"id\"`\n   385→\tWorkflowName string `json:\"workflow_name\"`\n   386→\tProjectDir   string `json:\"project_dir\"`\n   387→\tProjectLabel string `json:\"project_label\"`\n   388→\tState        string `json:\"state\"`\n   389→\tStartedAt    string `json:\"started_at\"`\n   390→\tCompletedAt  string `json:\"completed_at\"`\n   391→\tContainerID  string `json:\"container_id\"`\n   392→\tErrorMessage string `json:\"error_message\"`\n   393→}\n   394→\n   395→type apiStep struct {\n   396→\tStepName    string `json:\"step_name\"`\n   397→\tResult      string `json:\"result\"`\n   398→\tStartedAt   string `json:\"started_at\"`\n   399→\tCompletedAt string `json:\"completed_at\"`\n   400→\tDuration    string `json:\"duration\"`\n   401→}\n   402→\n   403→type apiRunDetail struct {\n   404→\tapiRun\n   405→\tContainerState string    `json:\"container_state\"`\n   406→\tSteps          []apiStep `json:\"steps\"`\n   407→}\n   408→\n   409→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   410→\treturn apiRun{\n   411→\t\tID:           r.ID,\n   412→\t\tWorkflowName: r.WorkflowName,\n   413→\t\tProjectDir:   r.ProjectDir,\n   414→\t\tProjectLabel: labels[r.ProjectDir],\n   415→\t\tState:        string(r.State),\n   416→\t\tStartedAt:    formatTime(r.StartedAt),\n   417→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   418→\t\tContainerID:  r.ContainerID,\n   419→\t\tErrorMessage: r.ErrorMessage,\n   420→\t}\n   421→}\n   422→\n   423→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   424→\tprojectFilter := r.URL.Query().Get(\"project\")\n   425→\n   426→\tvar runs []*domain.Run\n   427→\tvar err error\n   428→\tif projectFilter != \"\" {\n   429→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   430→\t} else {\n   431→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   432→\t}\n   433→\tif err != nil {\n   434→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   435→\t\treturn\n   436→\t}\n   437→\n   438→\tprojects, _ := h.store.ListProjects(r.Context())\n   439→\tlabels := projectLabels(projects)\n   440→\n   441→\tresult := make([]apiRun, len(runs))\n   442→\tfor i, run := range runs {\n   443→\t\tresult[i] = toAPIRun(run, labels)\n   444→\t}\n   445→\n   446→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   447→\tjson.NewEncoder(w).Encode(result)\n   448→}\n   449→\n   450→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   451→\tprojects, err := h.store.ListProjects(r.Context())\n   452→\tif err != nil {\n   453→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   454→\t\treturn\n   455→\t}\n   456→\tlabels := projectLabels(projects)\n   457→\n   458→\ttype apiHealth struct {\n   459→\t\tStatus string `json:\"status\"`\n   460→\t\tPassed int    `json:\"passed\"`\n   461→\t\tFailed int    `json:\"failed\"`\n   462→\t\tTotal  int    `json:\"total\"`\n   463→\t}\n   464→\ttype apiProject struct {\n   465→\t\tDir         string    `json:\"dir\"`\n   466→\t\tLabel       string    `json:\"label\"`\n   467→\t\tHealth      apiHealth `json:\"health\"`\n   468→\t\tActiveCount int       `json:\"active_count\"`\n   469→\t}\n   470→\tresult := make([]apiProject, len(projects))\n   471→\tfor i, dir := range projects {\n   472→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   473→\t\trunValues := make([]domain.Run, len(runs))\n   474→\t\tfor j, rr := range runs {\n   475→\t\t\trunValues[j] = *rr\n   476→\t\t}\n   477→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   478→\t\tvar activeCount int\n   479→\t\tfor _, rr := range runs {\n   480→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   481→\t\t\t\tactiveCount++\n   482→\t\t\t}\n   483→\t\t}\n   484→\t\tresult[i] = apiProject{\n   485→\t\t\tDir:   dir,\n   486→\t\t\tLabel: labels[dir],\n   487→\t\t\tHealth: apiHealth{\n   488→\t\t\t\tStatus: string(health.Status),\n   489→\t\t\t\tPassed: health.Passed,\n   490→\t\t\t\tFailed: health.Failed,\n   491→\t\t\t\tTotal:  health.Total,\n   492→\t\t\t},\n   493→\t\t\tActiveCount: activeCount,\n   494→\t\t}\n   495→\t}\n   496→\n   497→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   498→\tjson.NewEncoder(w).Encode(result)\n   499→}\n   500→\n   501→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   502→\tid := r.PathValue(\"id\")\n   503→\n   504→\trun, err := h.store.GetRun(r.Context(), id)\n   505→\tif err != nil {\n   506→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   507→\t\treturn\n   508→\t}\n   509→\n   510→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   511→\tif err != nil {\n   512→\t\tcaps = nil\n   513→\t}\n   514→\n   515→\tprojects, _ := h.store.ListProjects(r.Context())\n   516→\tlabels := projectLabels(projects)\n   517→\n   518→\tmerged := mergeCaptures(caps)\n   519→\tsteps := make([]apiStep, len(merged))\n   520→\tfor i, e := range merged {\n   521→\t\tsteps[i] = apiStep{\n   522→\t\t\tStepName:  e.StepName,\n   523→\t\t\tResult:    e.Result,\n   524→\t\t\tStartedAt: formatTime(e.StartedAt),\n   525→\t\t\tDuration:  e.Duration,\n   526→\t\t}\n   527→\t}\n   528→\n   529→\tdetail := apiRunDetail{\n   530→\t\tapiRun:         toAPIRun(run, labels),\n   531→\t\tContainerState: h.containerState(r.Context(), run),\n   532→\t\tSteps:          steps,\n   533→\t}\n   534→\n   535→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   536→\tjson.NewEncoder(w).Encode(detail)\n   537→}\n   538→\n   539→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   540→\tid := r.PathValue(\"id\")\n   541→\tstep := r.PathValue(\"step\")\n   542→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   543→\n   544→\trun, err := h.store.GetRun(r.Context(), id)\n   545→\tif err != nil {\n   546→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   547→\t\treturn\n   548→\t}\n   549→\n   550→\t// Try log index first for fast lookup\n   551→\tif h.logStore != nil {\n   552→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   553→\t\tif err == nil && len(logFiles) > 0 {\n   554→\t\t\t// If type filter specified, narrow results\n   555→\t\t\tfor _, lf := range logFiles {\n   556→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   557→\t\t\t\t\tcontinue\n   558→\t\t\t\t}\n   559→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   560→\t\t\t\tif readErr == nil && len(data) > 0 {\n   561→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   562→\t\t\t\t\tw.Write(data)\n   563→\t\t\t\t\treturn\n   564→\t\t\t\t}\n   565→\t\t\t}\n   566→\t\t}\n   567→\t}\n   568→\n   569→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   570→\n   571→\t// Fall back to file path conventions\n   572→\t// If type is \"llm\", try llm-<step>.log\n   573→\tif logType == \"llm\" {\n   574→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   575→\t\tdata, err := os.ReadFile(llmPath)\n   576→\t\tif err == nil && len(data) > 0 {\n   577→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   578→\t\t\tw.Write(data)\n   579→\t\t\treturn\n   580→\t\t}\n   581→\t}\n   582→\n   583→\t// Try per-step output first, fall back to container.log, then live docker logs\n   584→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   585→\tdata, err := os.ReadFile(outputPath)\n   586→\tif err == nil && len(data) > 0 {\n   587→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   588→\t\tw.Write(data)\n   589→\t\treturn\n   590→\t}\n   591→\n   592→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   593→\tdata, err = os.ReadFile(containerLog)\n   594→\tif err == nil && len(data) > 0 {\n   595→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   596→\t\tw.Write(data)\n   597→\t\treturn\n   598→\t}\n   599→\n   600→\t// Last resort: try live docker logs from still-existing container\n   601→\tif h.container != nil && run.ContainerID != \"\" {\n   602→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   603→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   604→\t\t\tw.Write([]byte(logs))\n   605→\t\t\treturn\n   606→\t\t}\n   607→\t}\n   608→\n   609→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   610→}\n   611→\n   612→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   613→\tid := r.PathValue(\"id\")\n   614→\n   615→\trun, err := h.store.GetRun(r.Context(), id)\n   616→\tif err != nil {\n   617→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   618→\t\tw.WriteHeader(http.StatusNotFound)\n   619→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   620→\t\treturn\n   621→\t}\n   622→\n   623→\tmgr, ok := h.container.(ContainerManager)\n   624→\tif !ok || run.ContainerID == \"\" {\n   625→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   626→\t\tw.WriteHeader(http.StatusBadRequest)\n   627→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   628→\t\treturn\n   629→\t}\n   630→\n   631→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   632→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   633→\t\tw.WriteHeader(http.StatusInternalServerError)\n   634→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   635→\t\treturn\n   636→\t}\n   637→\n   638→\trun.ContainerKept = false\n   639→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   640→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   641→\t\tw.WriteHeader(http.StatusInternalServerError)\n   642→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   643→\t\treturn\n   644→\t}\n   645→\n   646→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   647→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   648→}\n   649→\n   650→// handleAPIStream serves an SSE stream of log lines for a run.\n   651→// For active runs, it subscribes to the live broadcaster.\n   652→// For completed runs, it serves the archived full.log then closes.\n   653→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   654→\tid := r.PathValue(\"id\")\n   655→\n   656→\trun, err := h.store.GetRun(r.Context(), id)\n   657→\tif err != nil {\n   658→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   659→\t\treturn\n   660→\t}\n   661→\n   662→\tflusher, ok := w.(http.Flusher)\n   663→\tif !ok {\n   664→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   665→\t\treturn\n   666→\t}\n   667→\n   668→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   669→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   670→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   671→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   672→\n   673→\tisComplete := run.State == domain.RunStateSucceeded ||\n   674→\t\trun.State == domain.RunStateFailed ||\n   675→\t\trun.State == domain.RunStateCancelled\n   676→\n   677→\tif isComplete {\n   678→\t\t// Serve archived full.log\n   679→\t\th.streamFullLog(w, flusher, run)\n   680→\t\t// Send done event\n   681→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   682→\t\tflusher.Flush()\n   683→\t\treturn\n   684→\t}\n   685→\n   686→\t// Active run: subscribe to live broadcaster\n   687→\tif h.logBroadcast == nil {\n   688→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   689→\t\treturn\n   690→\t}\n   691→\n   692→\tsub := h.logBroadcast.Subscribe(id)\n   693→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   694→\n   695→\tctx := r.Context()\n   696→\tfor {\n   697→\t\tselect {\n   698→\t\tcase <-ctx.Done():\n   699→\t\t\treturn\n   700→\t\tcase line, ok := <-sub.C:\n   701→\t\t\tif !ok {\n   702→\t\t\t\t// Stream finished (run completed)\n   703→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   704→\t\t\t\tflusher.Flush()\n   705→\t\t\t\treturn\n   706→\t\t\t}\n   707→\t\t\tdata, _ := json.Marshal(line)\n   708→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   709→\t\t\tflusher.Flush()\n   710→\t\t}\n   711→\t}\n   712→}\n   713→\n   714→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   715→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   716→\n   717→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   718→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   719→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   720→\tf, err := os.Open(logPath)\n   721→\tif err != nil {\n   722→\t\treturn\n   723→\t}\n   724→\tdefer f.Close()\n   725→\n   726→\tscanner := bufio.NewScanner(f)\n   727→\tfor scanner.Scan() {\n   728→\t\ttext := scanner.Text()\n   729→\t\tline := parseFullLogLine(text)\n   730→\t\tdata, _ := json.Marshal(line)\n   731→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   732→\t\tflusher.Flush()\n   733→\t}\n   734→}\n   735→\n   736→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   737→func parseFullLogLine(text string) logstream.LogLine {\n   738→\tm := logLineRegex.FindStringSubmatch(text)\n   739→\tif m == nil {\n   740→\t\treturn logstream.LogLine{\n   741→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   742→\t\t\tType:      \"script\",\n   743→\t\t\tContent:   text,\n   744→\t\t}\n   745→\t}\n   746→\treturn logstream.LogLine{\n   747→\t\tTimestamp: m[1],\n   748→\t\tType:      m[2],\n   749→\t\tContent:   m[3],\n   750→\t}\n   751→}\n   752→\n   753→// --- Project detail handlers ---\n   754→\n   755→// resolveProjectDir resolves a project label from the URL to its directory path.\n   756→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   757→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   758→\tlabel := r.PathValue(\"name\")\n   759→\tprojects, _ := h.store.ListProjects(r.Context())\n   760→\tlabels := projectLabels(projects)\n   761→\tfor dir, l := range labels {\n   762→\t\tif l == label {\n   763→\t\t\treturn dir, label, true\n   764→\t\t}\n   765→\t}\n   766→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   767→\tw.WriteHeader(http.StatusNotFound)\n   768→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   769→\treturn \"\", \"\", false\n   770→}\n   771→\n   772→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   773→\tdir, label, ok := h.resolveProjectDir(w, r)\n   774→\tif !ok {\n   775→\t\treturn\n   776→\t}\n   777→\n   778→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   779→\tn := 10\n   780→\tif n > len(runs) {\n   781→\t\tn = len(runs)\n   782→\t}\n   783→\tdots := make([]recentRunDot, n)\n   784→\tfor i := 0; i < n; i++ {\n   785→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   786→\t}\n   787→\n   788→\tdata := map[string]any{\n   789→\t\t\"Title\":      label,\n   790→\t\t\"Label\":      label,\n   791→\t\t\"Dir\":        dir,\n   792→\t\t\"RecentRuns\": dots,\n   793→\t}\n   794→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   795→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   796→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   797→\t}\n   798→}\n   799→\n   800→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   801→\tdir, _, ok := h.resolveProjectDir(w, r)\n   802→\tif !ok {\n   803→\t\treturn\n   804→\t}\n   805→\n   806→\t// Docker image: read FROM line from Dockerfile\n   807→\tdockerImage := \"\"\n   808→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   809→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   810→\t\t// Find the last FROM line (final stage)\n   811→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   812→\t\t\ttrimmed := strings.TrimSpace(line)\n   813→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   814→\t\t\t\tparts := strings.Fields(trimmed)\n   815→\t\t\t\tif len(parts) >= 2 {\n   816→\t\t\t\t\tdockerImage = parts[1]\n   817→\t\t\t\t}\n   818→\t\t\t}\n   819→\t\t}\n   820→\t}\n   821→\n   822→\t// Version\n   823→\tversion := 0\n   824→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   825→\tif data, err := os.ReadFile(versionPath); err == nil {\n   826→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   827→\t\t\tversion = v\n   828→\t\t}\n   829→\t}\n   830→\n   831→\t// Prompt files history\n   832→\ttype commitEntry struct {\n   833→\t\tSHA     string `json:\"sha\"`\n   834→\t\tDate    string `json:\"date\"`\n   835→\t\tMessage string `json:\"message\"`\n   836→\t}\n   837→\ttype promptFile struct {\n   838→\t\tPath    string        `json:\"path\"`\n   839→\t\tHistory []commitEntry `json:\"history\"`\n   840→\t}\n   841→\n   842→\tvar promptFiles []promptFile\n   843→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   844→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n   845→\t\tfor _, e := range entries {\n   846→\t\t\tif e.IsDir() {\n   847→\t\t\t\tcontinue\n   848→\t\t\t}\n   849→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n   850→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n   851→\t\t\tcmd.Dir = dir\n   852→\t\t\tout, err := cmd.Output()\n   853→\t\t\tif err != nil {\n   854→\t\t\t\tcontinue\n   855→\t\t\t}\n   856→\t\t\tvar history []commitEntry\n   857→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n   858→\t\t\t\tif line == \"\" {\n   859→\t\t\t\t\tcontinue\n   860→\t\t\t\t}\n   861→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n   862→\t\t\t\tif len(parts) < 3 {\n   863→\t\t\t\t\tcontinue\n   864→\t\t\t\t}\n   865→\t\t\t\t// Parse date to short form\n   866→\t\t\t\tdateStr := parts[1]\n   867→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n   868→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n   869→\t\t\t\t}\n   870→\t\t\t\thistory = append(history, commitEntry{\n   871→\t\t\t\t\tSHA:     parts[0][:7],\n   872→\t\t\t\t\tDate:    dateStr,\n   873→\t\t\t\t\tMessage: parts[2],\n   874→\t\t\t\t})\n   875→\t\t\t}\n   876→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n   877→\t\t}\n   878→\t}\n   879→\n   880→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   881→\tjson.NewEncoder(w).Encode(map[string]any{\n   882→\t\t\"docker_image\": dockerImage,\n   883→\t\t\"version\":      version,\n   884→\t\t\"prompt_files\": promptFiles,\n   885→\t})\n   886→}\n   887→\n   888→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n   889→\tdir, _, ok := h.resolveProjectDir(w, r)\n   890→\tif !ok {\n   891→\t\treturn\n   892→\t}\n   893→\tfile := r.URL.Query().Get(\"file\")\n   894→\tsha := r.URL.Query().Get(\"sha\")\n   895→\tif file == \"\" || sha == \"\" {\n   896→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n   897→\t\treturn\n   898→\t}\n   899→\n   900→\t// Validate sha is alphanumeric to prevent injection\n   901→\tfor _, c := range sha {\n   902→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n   903→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n   904→\t\t\treturn\n   905→\t\t}\n   906→\t}\n   907→\n   908→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n   909→\tcmd.Dir = dir\n   910→\tout, err := cmd.Output()\n   911→\tif err != nil {\n   912→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n   913→\t\treturn\n   914→\t}\n   915→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   916→\tw.Write(out)\n   917→}\n   918→\n   919→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n   920→\tdir, _, ok := h.resolveProjectDir(w, r)\n   921→\tif !ok {\n   922→\t\treturn\n   923→\t}\n   924→\n   925→\tclocheDir := filepath.Join(dir, \".cloche\")\n   926→\tentries, err := os.ReadDir(clocheDir)\n   927→\tif err != nil {\n   928→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   929→\t\tjson.NewEncoder(w).Encode([]any{})\n   930→\t\treturn\n   931→\t}\n   932→\n   933→\ttype apiWire struct {\n   934→\t\tFrom   string `json:\"from\"`\n   935→\t\tResult string `json:\"result\"`\n   936→\t\tTo     string `json:\"to\"`\n   937→\t}\n   938→\ttype apiStepDef struct {\n   939→\t\tName    string            `json:\"name\"`\n   940→\t\tType    string            `json:\"type\"`\n   941→\t\tResults []string          `json:\"results\"`\n   942→\t\tConfig  map[string]string `json:\"config\"`\n   943→\t}\n   944→\ttype apiWorkflow struct {\n   945→\t\tName      string       `json:\"name\"`\n   946→\t\tFile      string       `json:\"file\"`\n   947→\t\tSteps     []apiStepDef `json:\"steps\"`\n   948→\t\tWires     []apiWire    `json:\"wires\"`\n   949→\t\tEntryStep string       `json:\"entry_step\"`\n   950→\t}\n   951→\n   952→\tvar workflows []apiWorkflow\n   953→\tfor _, e := range entries {\n   954→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n   955→\t\t\tcontinue\n   956→\t\t}\n   957→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n   958→\t\tif err != nil {\n   959→\t\t\tcontinue\n   960→\t\t}\n   961→\t\twf, err := dsl.ParseForContainer(string(data))\n   962→\t\tif err != nil {\n   963→\t\t\tcontinue\n   964→\t\t}\n   965→\t\tvar steps []apiStepDef\n   966→\t\tfor _, s := range wf.Steps {\n   967→\t\t\tsteps = append(steps, apiStepDef{\n   968→\t\t\t\tName:    s.Name,\n   969→\t\t\t\tType:    string(s.Type),\n   970→\t\t\t\tResults: s.Results,\n   971→\t\t\t\tConfig:  s.Config,\n   972→\t\t\t})\n   973→\t\t}\n   974→\t\t// Sort steps by name for consistent ordering\n   975→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n   976→\n   977→\t\tvar wires []apiWire\n   978→\t\tfor _, wire := range wf.Wiring {\n   979→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n   980→\t\t}\n   981→\n   982→\t\tworkflows = append(workflows, apiWorkflow{\n   983→\t\t\tName:      wf.Name,\n   984→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n   985→\t\t\tSteps:     steps,\n   986→\t\t\tWires:     wires,\n   987→\t\t\tEntryStep: wf.EntryStep,\n   988→\t\t})\n   989→\t}\n   990→\n   991→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   992→\tjson.NewEncoder(w).Encode(workflows)\n   993→}\n   994→\n   995→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n   996→\tdir, _, ok := h.resolveProjectDir(w, r)\n   997→\tif !ok {\n   998→\t\treturn\n   999→\t}\n  1000→\tworkflowName := r.PathValue(\"workflow\")\n  1001→\tstepName := r.PathValue(\"step\")\n  1002→\n  1003→\t// Find the workflow file\n  1004→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1005→\tvar wf *domain.Workflow\n  1006→\tentries, _ := os.ReadDir(clocheDir)\n  1007→\tfor _, e := range entries {\n  1008→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1009→\t\t\tcontinue\n  1010→\t\t}\n  1011→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1012→\t\tif err != nil {\n  1013→\t\t\tcontinue\n  1014→\t\t}\n  1015→\t\tparsed, err := dsl.ParseForContainer(string(data))\n  1016→\t\tif err != nil {\n  1017→\t\t\tcontinue\n  1018→\t\t}\n  1019→\t\tif parsed.Name == workflowName {\n  1020→\t\t\twf = parsed\n  1021→\t\t\tbreak\n  1022→\t\t}\n  1023→\t}\n  1024→\tif wf == nil {\n  1025→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1026→\t\treturn\n  1027→\t}\n  1028→\n  1029→\tstep, ok := wf.Steps[stepName]\n  1030→\tif !ok {\n  1031→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1032→\t\treturn\n  1033→\t}\n  1034→\n  1035→\t// Try to read the referenced file from step config\n  1036→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1037→\n  1038→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1039→\t\tcontent, err := resolveFileRef(prompt, dir)\n  1040→\t\tif err == nil {\n  1041→\t\t\tw.Write([]byte(content))\n  1042→\t\t\treturn\n  1043→\t\t}\n  1044→\t}\n  1045→\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n  1046→\t\tcontent, _ := resolveFileRef(cmd, dir)\n  1047→\t\tw.Write([]byte(content))\n  1048→\t\treturn\n  1049→\t}\n  1050→\tif script := step.Config[\"script\"]; script != \"\" {\n  1051→\t\tcontent, _ := resolveFileRef(script, dir)\n  1052→\t\tw.Write([]byte(content))\n  1053→\t\treturn\n  1054→\t}\n  1055→\n  1056→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1057→}\n  1058→\n  1059→// --- Template helpers ---\n  1060→\n  1061→// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n  1062→// If the value uses file() syntax, the referenced file is read from disk.\n  1063→// Otherwise the value is returned as-is.\n  1064→func resolveFileRef(value, baseDir string) (string, error) {\n  1065→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n  1066→\t\tpath := value[6 : len(value)-2]\n  1067→\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n  1068→\t\tif err != nil {\n  1069→\t\t\treturn \"\", err\n  1070→\t\t}\n  1071→\t\treturn string(data), nil\n  1072→\t}\n  1073→\treturn value, nil\n  1074→}\n  1075→\n  1076→func stateColor(state domain.RunState) string {\n  1077→\tswitch state {\n  1078→\tcase domain.RunStatePending:\n  1079→\t\treturn \"pending\"\n  1080→\tcase domain.RunStateRunning:\n  1081→\t\treturn \"running\"\n  1082→\tcase domain.RunStateSucceeded:\n  1083→\t\treturn \"succeeded\"\n  1084→\tcase domain.RunStateFailed:\n  1085→\t\treturn \"failed\"\n  1086→\tcase domain.RunStateCancelled:\n  1087→\t\treturn \"cancelled\"\n  1088→\tdefault:\n  1089→\t\treturn \"pending\"\n  1090→\t}\n  1091→}\n  1092→\n  1093→func healthColor(status domain.HealthStatus) string {\n  1094→\tswitch status {\n  1095→\tcase domain.HealthGreen:\n  1096→\t\treturn \"green\"\n  1097→\tcase domain.HealthYellow:\n  1098→\t\treturn \"yellow\"\n  1099→\tcase domain.HealthRed:\n  1100→\t\treturn \"red\"\n  1101→\tcase domain.HealthBlue:\n  1102→\t\treturn \"blue\"\n  1103→\tdefault:\n  1104→\t\treturn \"grey\"\n  1105→\t}\n  1106→}\n  1107→\n  1108→func formatTime(t time.Time) string {\n  1109→\tif t.IsZero() {\n  1110→\t\treturn \"\"\n  1111→\t}\n  1112→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1113→}\n  1114→\n  1115→func formatDuration(start, end time.Time) string {\n  1116→\tif start.IsZero() || end.IsZero() {\n  1117→\t\treturn \"\"\n  1118→\t}\n  1119→\td := end.Sub(start)\n  1120→\tif d < time.Second {\n  1121→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1122→\t}\n  1123→\tif d < time.Minute {\n  1124→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1125→\t}\n  1126→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1127→}\n  1128→\n  1129→func truncate(s string, n int) string {\n  1130→\tif len(s) <= n {\n  1131→\t\treturn s\n  1132→\t}\n  1133→\treturn s[:n] + \"...\"\n  1134→}\n  1135→\n  1136→func shortContainerID(id string) string {\n  1137→\tif len(id) > 12 {\n  1138→\t\treturn id[:12]\n  1139→\t}\n  1140→\treturn id\n  1141→}\n  1142→\n  1143→// projectLabels builds a mapping from full project directory paths to short\n  1144→// display labels. Each label is the final directory component (e.g.\n  1145→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1146→// the same final name, the parent directory is prepended to disambiguate\n  1147→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1148→func projectLabels(dirs []string) map[string]string {\n  1149→\tlabels := make(map[string]string, len(dirs))\n  1150→\t// Group dirs by their base name to detect conflicts.\n  1151→\tbyBase := map[string][]string{}\n  1152→\tfor _, d := range dirs {\n  1153→\t\tbase := filepath.Base(d)\n  1154→\t\tbyBase[base] = append(byBase[base], d)\n  1155→\t}\n  1156→\tfor base, paths := range byBase {\n  1157→\t\tif len(paths) == 1 {\n  1158→\t\t\tlabels[paths[0]] = base\n  1159→\t\t} else {\n  1160→\t\t\tfor _, p := range paths {\n  1161→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1162→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1163→\t\t\t}\n  1164→\t\t}\n  1165→\t}\n  1166→\treturn labels\n  1167→}\n  1168→\n  1169→type projectEntry struct {\n  1170→\tDir            string\n  1171→\tLabel          string\n  1172→\tContainerCount int\n  1173→}\n  1174→"}]},"parent_tool_use_id":null,"session_id":"107e28cc-d907-4d13-a791-846631d9b275","uuid":"0752654f-3958-4595-9fdd-091972b0c415","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogStore     ports.LogStore\n\tcontainer    ContainerLogger\n\tlogBroadcast *logstream.Broadcaster\n\tpages        map[string]*template.Template\n\tmux          *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.ParseForContainer(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.ParseForContainer(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tcontent, err := resolveFileRef(prompt, dir)\n\t\tif err == nil {\n\t\t\tw.Write([]byte(content))\n\t\t\treturn\n\t\t}\n\t}\n\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n\t\tcontent, _ := resolveFileRef(cmd, dir)\n\t\tw.Write([]byte(content))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tcontent, _ := resolveFileRef(script, dir)\n\t\tw.Write([]byte(content))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\n// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n// If the value uses file() syntax, the referenced file is read from disk.\n// Otherwise the value is returned as-is.\nfunc resolveFileRef(value, baseDir string) (string, error) {\n\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n\t\tpath := value[6 : len(value)-2]\n\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n\t\tif err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\treturn string(data), nil\n\t}\n\treturn value, nil\n}\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1174,"startLine":1,"totalLines":1174}}}
