       .then(function(r) { return r.json(); })\n    86→            .then(function(data) {\n    87→                if (btn) {\n    88→                    btn.textContent = 'Cleaned up ' + data.deleted + ' container' + (data.deleted !== 1 ? 's' : '');\n    89→                }\n    90→            })\n    91→            .catch(function() {\n    92→                if (btn) {\n    93→                    btn.textContent = 'Cleanup failed';\n    94→                    btn.disabled = false;\n    95→                }\n    96→            });\n    97→    };\n    98→\n    99→    function poll() {\n   100→        var url;\n   101→        if (currentProject) {\n   102→            var label = dirToLabel[currentProject];\n   103→            url = label ? '/api/projects/' + encodeURIComponent(label) + '/runs' : '/api/runs';\n   104→        } else {\n   105→            url = '/api/runs';\n   106→        }\n   107→        fetch(url)\n   108→            .then(function(r) { return r.json(); })\n   109→            .then(function(entries) {\n   110→                var tbody = document.getElementById('runs-body');\n   111→                if (!entries || entries.length === 0) {\n   112→                    tbody.innerHTML = '<tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>';\n   113→                    return;\n   114→                }\n   115→\n   116→                var html = '';\n   117→                for (var i = 0; i < entries.length; i++) {\n   118→                    var entry = entries[i];\n   119→                    if (entry.task_header) {\n   120→                        var ts = entry.task_status || 'pending';\n   121→                        var taskLabel = escapeHtml(entry.task_id);\n   122→                        if (entry.task_title) taskLabel += ': ' + escapeHtml(entry.task_title);\n   123→                        html += '<tr class=\"run-task-header\"><td colspan=\"9\">Task: ' + taskLabel + ' <span class=\"badge badge-' + ts + '\">' + ts + '</span></td></tr>';\n   124→                        continue;\n   125→                    }\n   126→                    var r = entry.run;\n   127→                    if (!r) continue;\n   128→                    var cid = r.container_id || '';\n   129→                    if (cid.length > 12) cid = cid.substring(0, 12);\n   130→                    var err = r.error_message || '';\n   131→                    if (err.length > 80) err = err.substring(0, 80) + '...';\n   132→                    var title = r.title || '';\n   133→                    if (title.length > 50) title = title.substring(0, 47) + '...';\n   134→                    var runType = r.is_host ? 'host' : 'container';\n   135→                    var rowClass = entry.is_child ? 'run-child-row' : (entry.is_parent ? 'run-parent-row' : '');\n   136→                    var timing = r.timing || '';\n   137→                    var wfName = r.workflow_name || '';\n   138→                    var state = r.state || '';\n   139→                    html += '<tr class=\"' + rowClass + '\">' +\n   140→                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n   141→                        '<td>' + escapeHtml(title) + '</td>' +\n   142→                        '<td>' + escapeHtml(r.project_label || '') + '</td>' +\n   143→                        '<td>' + wfName + '</td>' +\n   144→                        '<td>' + runType + '</td>' +\n   145→                        '<td><span class=\"badge badge-' + state + '\">' + state + '</span></td>' +\n   146→                        '<td>' + escapeHtml(timing) + '</td>' +\n   147→                        '<td class=\"mono\">' + cid + '</td>' +\n   148→                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n   149→                        '</tr>';\n   150→                }\n   151→                tbody.innerHTML = html;\n   152→            })\n   153→            .catch(function() {});\n   154→    }\n   155→    function escapeHtml(s) {\n   156→        var d = document.createElement('div');\n   157→        d.appendChild(document.createTextNode(s));\n   158→        return d.innerHTML;\n   159→    }\n   160→    setInterval(poll, 3000);\n   161→})();\n   162→</script>\n   163→{{end}}\n   164→"}]},"parent_tool_use_id":null,"session_id":"4544fa8d-d9f6-4e57-8374-6a5c036ca271","uuid":"1d9d7e69-4598-4995-aa8a-f908aba1075f","timestamp":"2026-03-18T18:19:10.758Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/runs.html","content":"{{define \"content\"}}\n{{if .ProjectLabel}}\n<h1><a href=\"/\">Projects</a> / <a href=\"/projects/{{.ProjectLabel}}\">{{.ProjectLabel}}</a> / Runs</h1>\n{{else}}\n<h1>Runs</h1>\n{{end}}\n{{if .Projects}}\n<div class=\"project-filter\">\n    <label for=\"project-select\">Project:</label>\n    <select id=\"project-select\" onchange=\"filterByProject(this.value)\">\n        <option value=\"\">All projects</option>\n        {{range .Projects}}\n        <option value=\"{{.Dir}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>\n        {{end}}\n    </select>\n    {{if .TotalContainerCount}}\n    <button class=\"btn btn-danger btn-sm\" id=\"cleanup-containers-btn\" onclick=\"cleanupContainers()\" style=\"margin-left:0.5rem\">Clean up {{.TotalContainerCount}} old container{{if gt .TotalContainerCount 1}}s{{end}}</button>\n    {{end}}\n</div>\n{{end}}\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Run ID</th>\n            <th>Title</th>\n            <th>Project</th>\n            <th>Workflow</th>\n            <th>Type</th>\n            <th>State</th>\n            <th>Timing</th>\n            <th>Container</th>\n            <th>Error</th>\n        </tr>\n    </thead>\n    <tbody id=\"runs-body\">\n    {{if .GroupedRuns}}\n        {{range .GroupedRuns}}\n        {{if .TaskHeader}}\n        <tr class=\"run-task-header\"><td colspan=\"9\">Task: {{.TaskID}}{{if .TaskTitle}}: {{.TaskTitle}}{{end}} <span class=\"badge badge-{{.TaskStatus}}\">{{.TaskStatus}}</span></td></tr>\n        {{else if .Run}}\n        <tr class=\"{{if .IsChild}}run-child-row{{else if .IsParent}}run-parent-row{{end}}\">\n            <td><a href=\"/runs/{{.Run.ID}}\">{{.Run.ID}}</a></td>\n            <td>{{truncate .Run.Title 50}}</td>\n            <td>{{.Run.ProjectLabel}}</td>\n            <td>{{.Run.WorkflowName}}</td>\n            <td>{{if .Run.IsHost}}host{{else}}container{{end}}</td>\n            <td><span class=\"badge badge-{{.Run.State}}\">{{.Run.State}}</span></td>\n            <td>{{.Run.Timing}}</td>\n            <td class=\"mono\">{{shortContainerID .Run.ContainerID}}</td>\n            <td class=\"error-cell\">{{truncate .Run.ErrorMessage 80}}</td>\n        </tr>\n        {{end}}\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var currentProject = '{{.ProjectFilter}}';\n    var dirToLabel = {{jsonMap .DirToLabel}};\n\n    function filterByProject(dir) {\n        if (dir) {\n            var label = dirToLabel[dir];\n            if (label) {\n                window.location.href = '/projects/' + encodeURIComponent(label) + '/runs';\n            } else {\n                window.location.href = '/runs';\n            }\n        } else {\n            window.location.href = '/runs';\n        }\n    }\n    window.filterByProject = filterByProject;\n\n    window.cleanupContainers = function() {\n        var btn = document.getElementById('cleanup-containers-btn');\n        if (btn) btn.disabled = true;\n        fetch('/api/containers', { method: 'DELETE' })\n            .then(function(r) { return r.json(); })\n            .then(function(data) {\n                if (btn) {\n                    btn.textContent = 'Cleaned up ' + data.deleted + ' container' + (data.deleted !== 1 ? 's' : '');\n                }\n            })\n            .catch(function() {\n                if (btn) {\n                    btn.textContent = 'Cleanup failed';\n                    btn.disabled = false;\n                }\n            });\n    };\n\n    function poll() {\n        var url;\n        if (currentProject) {\n            var label = dirToLabel[currentProject];\n            url = label ? '/api/projects/' + encodeURIComponent(label) + '/runs' : '/api/runs';\n        } else {\n            url = '/api/runs';\n        }\n        fetch(url)\n            .then(function(r) { return r.json(); })\n            .then(function(entries) {\n                var tbody = document.getElementById('runs-body');\n                if (!entries || entries.length === 0) {\n                    tbody.innerHTML = '<tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>';\n                    return;\n                }\n\n                var html = '';\n                for (var i = 0; i < entries.length; i++) {\n                    var entry = entries[i];\n                    if (entry.task_header) {\n                        var ts = entry.task_status || 'pending';\n                        var taskLabel = escapeHtml(entry.task_id);\n                        if (entry.task_title) taskLabel += ': ' + escapeHtml(entry.task_title);\n                        html += '<tr class=\"run-task-header\"><td colspan=\"9\">Task: ' + taskLabel + ' <span class=\"badge badge-' + ts + '\">' + ts + '</span></td></tr>';\n                        continue;\n                    }\n                    var r = entry.run;\n                    if (!r) continue;\n                    var cid = r.container_id || '';\n                    if (cid.length > 12) cid = cid.substring(0, 12);\n                    var err = r.error_message || '';\n                    if (err.length > 80) err = err.substring(0, 80) + '...';\n                    var title = r.title || '';\n                    if (title.length > 50) title = title.substring(0, 47) + '...';\n                    var runType = r.is_host ? 'host' : 'container';\n                    var rowClass = entry.is_child ? 'run-child-row' : (entry.is_parent ? 'run-parent-row' : '');\n                    var timing = r.timing || '';\n                    var wfName = r.workflow_name || '';\n                    var state = r.state || '';\n                    html += '<tr class=\"' + rowClass + '\">' +\n                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n                        '<td>' + escapeHtml(title) + '</td>' +\n                        '<td>' + escapeHtml(r.project_label || '') + '</td>' +\n                        '<td>' + wfName + '</td>' +\n                        '<td>' + runType + '</td>' +\n                        '<td><span class=\"badge badge-' + state + '\">' + state + '</span></td>' +\n                        '<td>' + escapeHtml(timing) + '</td>' +\n                        '<td class=\"mono\">' + cid + '</td>' +\n                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                        '</tr>';\n                }\n                tbody.innerHTML = html;\n            })\n            .catch(function() {});\n    }\n    function escapeHtml(s) {\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n    setInterval(poll, 3000);\n})();\n</script>\n{{end}}\n","numLines":164,"startLine":1,"totalLines":164}}}
