{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ja39QDn369riqh4HW7N6jK","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n     3→\n     4→<div class=\"run-history\" style=\"margin-bottom:1rem\">\n     5→    {{range .RecentRuns}}\n     6→    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n     7→    {{end}}\n     8→    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n     9→    {{if .ContainerCount}}\n    10→    <button class=\"btn btn-danger btn-sm\" id=\"delete-containers-btn\" onclick=\"deleteAllContainers()\" style=\"margin-left:0.5rem\">Delete {{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}</button>\n    11→    {{end}}\n    12→</div>\n    13→\n    14→<!-- Panel 1: Project Info -->\n    15→<div class=\"panel\" id=\"info-panel\">\n    16→    <div class=\"panel-header\">Project Info</div>\n    17→    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n    18→</div>\n    19→\n    20→<!-- Panel 2: In-progress Tasks -->\n    21→<div class=\"panel\" id=\"in-progress-panel\">\n    22→    <div class=\"panel-header\">In-progress Tasks</div>\n    23→    <div class=\"panel-body\" id=\"in-progress-body\">Loading...</div>\n    24→</div>\n    25→\n    26→<!-- Panel 3: Upcoming Tasks -->\n    27→<div class=\"panel\" id=\"upcoming-panel\">\n    28→    <div class=\"panel-header\">Upcoming Tasks</div>\n    29→    <div class=\"panel-body\" id=\"upcoming-body\">Loading...</div>\n    30→</div>\n    31→\n    32→<!-- Panel 3: Workflow View -->\n    33→<div class=\"panel\" id=\"workflow-panel\">\n    34→    <div class=\"panel-header\">Workflows</div>\n    35→    <div class=\"panel-body\">\n    36→        <div id=\"location-tabs\" class=\"tab-bar\"></div>\n    37→        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n    38→        <div id=\"workflow-dag\"></div>\n    39→    </div>\n    40→</div>\n    41→\n    42→<!-- Step Drawer -->\n    43→<div class=\"drawer\" id=\"step-drawer\">\n    44→    <div class=\"drawer-header\">\n    45→        <span id=\"drawer-title\"></span>\n    46→        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    47→    </div>\n    48→    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n    49→</div>\n    50→{{end}}\n    51→\n    52→{{define \"scripts\"}}\n    53→<script>\n    54→var projectLabel = {{.Label}};\n    55→\n    56→function loadProjectInfo() {\n    57→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n    58→        .then(function(r) { return r.json(); })\n    59→        .then(function(data) {\n    60→            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n    61→            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n    62→            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n    63→            html += '</dl>';\n    64→\n    65→            if (data.prompt_files && data.prompt_files.length > 0) {\n    66→                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n    67→                data.prompt_files.forEach(function(pf) {\n    68→                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n    69→                    if (pf.content) {\n    70→                        html += '<pre class=\"diff-block\">' + pf.content.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n    71→                    } else {\n    72→                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">Empty file</p>';\n    73→                    }\n    74→                    html += '</details>';\n    75→                });\n    76→            }\n    77→\n    78→            document.getElementById('project-info').innerHTML = html;\n    79→        });\n    80→}\n    81→\n    82→function toggleDiff(el) {\n    83→    var existing = el.nextElementSibling;\n    84→    if (existing && existing.classList.contains('diff-block')) {\n    85→        existing.remove();\n    86→        return;\n    87→    }\n    88→    var file = el.getAttribute('data-file');\n    89→    var sha = el.getAttribute('data-sha');\n    90→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n    91→        .then(function(r) { return r.text(); })\n    92→        .then(function(text) {\n    93→            var pre = document.createElement('pre');\n    94→            pre.className = 'diff-block';\n    95→            pre.textContent = text || '(no diff available)';\n    96→            el.parentNode.insertBefore(pre, el.nextSibling);\n    97→        });\n    98→}\n    99→\n   100→var workflowsData = [];\n   101→var activeLocation = 'container';\n   102→\n   103→function loadWorkflows() {\n   104→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n   105→        .then(function(r) { return r.json(); })\n   106→        .then(function(data) {\n   107→            workflowsData = data || [];\n   108→            if (workflowsData.length === 0) {\n   109→                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n   110→                return;\n   111→            }\n   112→\n   113→            // Check which locations exist\n   114→            var hasContainer = workflowsData.some(function(wf) { return wf.location === 'container'; });\n   115→            var hasHost = workflowsData.some(function(wf) { return wf.location === 'host'; });\n   116→\n   117→            // Render location tabs if both types exist\n   118→            var locationTabs = document.getElementById('location-tabs');\n   119→            if (hasContainer && hasHost) {\n   120→                var html = '';\n   121→                html += '<button class=\"tab-btn tab-active\" onclick=\"switchLocation(\\'container\\')\">Container</button>';\n   122→                html += '<button class=\"tab-btn\" onclick=\"switchLocation(\\'host\\')\">Host</button>';\n   123→                locationTabs.innerHTML = html;\n   124→            } else {\n   125→                locationTabs.innerHTML = '';\n   126→            }\n   127→\n   128→            // Default to whichever location exists\n   129→            activeLocation = hasContainer ? 'container' : 'host';\n   130→            renderWorkflowTabs();\n   131→        });\n   132→}\n   133→\n   134→function switchLocation(loc) {\n   135→    activeLocation = loc;\n   136→    var btns = document.querySelectorAll('#location-tabs .tab-btn');\n   137→    btns.forEach(function(b) {\n   138→        b.classList.toggle('tab-active', b.textContent === (loc === 'container' ? 'Container' : 'Host'));\n   139→    });\n   140→    renderWorkflowTabs();\n   141→}\n   142→\n   143→function renderWorkflowTabs() {\n   144→    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n   145→    var tabs = document.getElementById('workflow-tabs');\n   146→\n   147→    if (filtered.length === 0) {\n   148→        tabs.innerHTML = '';\n   149→        document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No ' + activeLocation + ' workflows found</p>';\n   150→        return;\n   151→    }\n   152→\n   153→    if (filtered.length > 1) {\n   154→        var html = '';\n   155→        filtered.forEach(function(wf, i) {\n   156→            html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showFilteredWorkflow(' + i + ')\">' + wf.name + '</button>';\n   157→        });\n   158→        tabs.innerHTML = html;\n   159→    } else {\n   160→        tabs.innerHTML = '';\n   161→    }\n   162→    showFilteredWorkflow(0);\n   163→}\n   164→\n   165→function showFilteredWorkflow(idx) {\n   166→    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n   167→    var btns = document.querySelectorAll('#workflow-tabs .tab-btn');\n   168→    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n   169→    showWorkflow(filtered[idx]);\n   170→}\n   171→\n   172→function showWorkflow(wf) {\n   173→    var dagEl = document.getElementById('workflow-dag');\n   174→\n   175→    if (!wf.steps || wf.steps.length === 0) {\n   176→        dagEl.innerHTML = '<p class=\"empty\">No steps defined</p>';\n   177→        return;\n   178→    }\n   179→\n   180→    var stepMap = {};\n   181→    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n   182→\n   183→    var wires = wf.wires || [];\n   184→\n   185→    // Helper: determine if a result is the success/happy-path\n   186→    function isSuccessResult(r) { return r === 'success' || r === 'ok' || r === 'done' || r === 'pass'; }\n   187→    function isFailureResult(r) { return r === 'failed' || r === 'fail' || r === 'error'; }\n   188→\n   189→    // --- Color system: map result types to colors ---\n   190→    var colorPalette = ['#2196f3', '#ffc107', '#e040fb', '#00bcd4', '#ff9800'];\n   191→    var otherColorIdx = 0;\n   192→    var resultColorCache = {};\n   193→\n   194→    function resultColor(r) {\n   195→        if (resultColorCache[r]) return resultColorCache[r];\n   196→        if (isSuccessResult(r)) { resultColorCache[r] = '#4caf50'; }\n   197→        else if (isFailureResult(r)) { resultColorCache[r] = '#e53935'; }\n   198→        else {\n   199→            resultColorCache[r] = colorPalette[otherColorIdx % colorPalette.length];\n   200→            otherColorIdx++;\n   201→        }\n   202→        return resultColorCache[r];\n   203→    }\n   204→\n   205→    // Pre-compute colors for all wire results\n   206→    wires.forEach(function(w) { resultColor(w.result); });\n   207→\n   208→    // Collect terminal targets\n   209→    var terminals = {};\n   210→    wires.forEach(function(wire) {\n   211→        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n   212→    });\n   213→\n   214→    // Build adjacency maps\n   215→    var adj = {};    // from -> [wire]\n   216→    var revAdj = {}; // to -> [from] (unique)\n   217→    wires.forEach(function(wire) {\n   218→        if (!adj[wire.from]) adj[wire.from] = [];\n   219→        adj[wire.from].push(wire);\n   220→        if (!revAdj[wire.to]) revAdj[wire.to] = [];\n   221→        if (revAdj[wire.to].indexOf(wire.from) === -1) revAdj[wire.to].push(wire.from);\n   222→    });\n   223→\n   224→    // --- Layer assignment via longest path (Sugiyama-style) ---\n   225→    var stepNames = wf.steps.map(function(s) { return s.name; });\n   226→\n   227→    // Topological sort (Kahn's algorithm)\n   228→    var inDeg = {};\n   229→    stepNames.forEach(function(n) { inDeg[n] = 0; });\n   230→    wires.forEach(function(wire) {\n   231→        if (inDeg[wire.to] !== undefined) inDeg[wire.to]++;\n   232→    });\n   233→\n   234→    var queue = [];\n   235→    stepNames.forEach(function(n) { if (inDeg[n] === 0) queue.push(n); });\n   236→\n   237→    var topoOrder = [];\n   238→    while (queue.length > 0) {\n   239→        var n = queue.shift();\n   240→        topoOrder.push(n);\n   241→        (adj[n] || []).forEach(function(wire) {\n   242→            if (inDeg[wire.to] !== undefined) {\n   243→                inDeg[wire.to]--;\n   244→                if (inDeg[wire.to] === 0) queue.push(wire.to);\n   245→            }\n   246→        });\n   247→    }\n   248→    // Add remaining steps (cycles) in BFS order from already-ordered nodes.\n   249→    // This ensures forward dependencies are processed before their targets,\n   250→    // so layer assignment sees correct parent layers even within cycles.\n   251→    var topoVisited = {};\n   252→    topoOrder.forEach(function(n) { topoVisited[n] = true; });\n   253→    var bfsQ = topoOrder.slice();\n   254→    while (bfsQ.length > 0) {\n   255→        var bn = bfsQ.shift();\n   256→        (adj[bn] || []).forEach(function(wire) {\n   257→            if (!topoVisited[wire.to] && inDeg[wire.to] !== undefined) {\n   258→                topoVisited[wire.to] = true;\n   259→                topoOrder.push(wire.to);\n   260→                bfsQ.push(wire.to);\n   261→            }\n   262→        });\n   263→    }\n   264→    // Add any truly disconnected nodes\n   265→    stepNames.forEach(function(n) { if (!topoVisited[n]) { topoOrder.push(n); } });\n   266→\n   267→    // Assign layers: longest path from any source\n   268→    var layerOf = {};\n   269→    topoOrder.forEach(function(n) {\n   270→        var maxParent = -1;\n   271→        (revAdj[n] || []).forEach(function(p) {\n   272→            if (layerOf[p] !== undefined && layerOf[p] > maxParent) maxParent = layerOf[p];\n   273→        });\n   274→        layerOf[n] = maxParent + 1;\n   275→    });\n   276→\n   277→    var maxLayer = 0;\n   278→    stepNames.forEach(function(n) { if (layerOf[n] > maxLayer) maxLayer = layerOf[n]; });\n   279→\n   280→    // Terminals in rightmost layer\n   281→    var termLayer = maxLayer + 1;\n   282→    for (var t in terminals) { layerOf[t] = termLayer; }\n   283→    var numLayers = termLayer + 1;\n   284→\n   285→    // --- Build layer arrays ---\n   286→    var layers = [];\n   287→    for (var i = 0; i < numLayers; i++) layers.push([]);\n   288→    topoOrder.forEach(function(n) { layers[layerOf[n]].push(n); });\n   289→    for (var t in terminals) { layers[termLayer].push(t); }\n   290→\n   291→    // --- Barycenter ordering to minimize edge crossings ---\n   292→    for (var pass = 0; pass < 4; pass++) {\n   293→        // Forward pass\n   294→        for (var li = 1; li < numLayers; li++) {\n   295→            var bary = {};\n   296→            layers[li].forEach(function(n) {\n   297→                var pars = revAdj[n] || [];\n   298→                var sum = 0, cnt = 0;\n   299→                pars.forEach(function(p) {\n   300→                    var idx = layers[li - 1].indexOf(p);\n   301→                    if (idx >= 0) { sum += idx; cnt++; }\n   302→                });\n   303→                bary[n] = cnt > 0 ? sum / cnt : 999;\n   304→            });\n   305→            layers[li].sort(function(a, b) { return bary[a] - bary[b]; });\n   306→        }\n   307→        // Backward pass\n   308→        for (var li = numLayers - 2; li >= 0; li--) {\n   309→            var baryB = {};\n   310→            layers[li].forEach(function(n) {\n   311→                var children = (adj[n] || []).map(function(w) { return w.to; });\n   312→                var sum = 0, cnt = 0;\n   313→                children.forEach(function(c) {\n   314→                    var idx = layers[li + 1].indexOf(c);\n   315→                    if (idx >= 0) { sum += idx; cnt++; }\n   316→                });\n   317→                baryB[n] = cnt > 0 ? sum / cnt : 999;\n   318→            });\n   319→            layers[li].sort(function(a, b) { return baryB[a] - baryB[b]; });\n   320→        }\n   321→    }\n   322→\n   323→    // --- Position calculation (top-to-bottom layout) ---\n   324→    var nodeW = 180, nodeH = 48;\n   325→    var layerGap = 80;  // vertical gap between layers\n   326→    var nodeGap = 40;   // horizontal gap between nodes in same layer\n   327→    var nonsuccOffset = 35; // horizontal offset for non-success bezier wires\n   328→    var padL = 30, padT = 30;\n   329→\n   330→    var maxInLayer = 1;\n   331→    layers.forEach(function(l) { if (l.length > maxInLayer) maxInLayer = l.length; });\n   332→    var totalLayerW = maxInLayer * nodeW + (maxInLayer - 1) * nodeGap;\n   333→\n   334→    var positions = {};\n   335→    layers.forEach(function(layer, li) {\n   336→        var lw = layer.length * nodeW + (layer.length - 1) * nodeGap;\n   337→        var offsetX = (totalLayerW - lw) / 2;\n   338→        layer.forEach(function(name, ni) {\n   339→            positions[name] = {\n   340→                x: padL + offsetX + ni * (nodeW + nodeGap),\n   341→                y: padT + li * (nodeH + layerGap)\n   342→            };\n   343→        });\n   344→    });\n   345→\n   346→    // --- Wire columns for non-success terminal wires ---\n   347→    // Separate terminal wires from normal wires\n   348→    var termWires = {};\n   349→    var normWires = [];\n   350→    wires.forEach(function(wire) {\n   351→        if (wire.to === 'done' || wire.to === 'abort') {\n   352→            if (!termWires[wire.to]) termWires[wire.to] = [];\n   353→            termWires[wire.to].push(wire);\n   354→        } else {\n   355→            normWires.push(wire);\n   356→        }\n   357→    });\n   358→\n   359→    // Build wire columns: one per (terminal, result) pair for non-success wires\n   360→    var wireColStart = padL + totalLayerW + 50;\n   361→    var wireColGap = 40;\n   362→    var wireColumns = {};  // key \"term:result\" -> { x, terminal, result, wires }\n   363→    var wireColIdx = 0;\n   364→\n   365→    for (var term in termWires) {\n   366→        var tw = termWires[term];\n   367→        var nonSucc = tw.filter(function(w) { return !isSuccessResult(w.result); });\n   368→        if (nonSucc.length > 0) {\n   369→            var byResult = {};\n   370→            nonSucc.forEach(function(w) {\n   371→                if (!byResult[w.result]) byResult[w.result] = [];\n   372→                byResult[w.result].push(w);\n   373→            });\n   374→            for (var result in byResult) {\n   375→                var colKey = term + ':' + result;\n   376→                wireColumns[colKey] = {\n   377→                    x: wireColStart + wireColIdx * wireColGap,\n   378→                    terminal: term,\n   379→                    result: result,\n   380→                    wires: byResult[result]\n   381→                };\n   382→                wireColIdx++;\n   383→            }\n   384→        }\n   385→    }\n   386→\n   387→    // Reposition terminals that only receive non-success wires under wire columns\n   388→    for (var term in termWires) {\n   389→        var tw = termWires[term];\n   390→        var hasSucc = tw.some(function(w) { return isSuccessResult(w.result); });\n   391→        if (!hasSucc) {\n   392→            var colXs = [];\n   393→            for (var ck in wireColumns) {\n   394→                if (wireColumns[ck].terminal === term) colXs.push(wireColumns[ck].x);\n   395→            }\n   396→            if (colXs.length > 0) {\n   397→                var avgX = colXs.reduce(function(a, b) { return a + b; }, 0) / colXs.length;\n   398→                positions[term] = {\n   399→                    x: avgX - nodeW / 2,\n   400→                    y: positions[term].y\n   401→                };\n   402→            }\n   403→        }\n   404→    }\n   405→\n   406→    // Calculate SVG dimensions accounting for wire columns and repositioned terminals\n   407→    var maxX = padL + totalLayerW;\n   408→    for (var ck in wireColumns) {\n   409→        if (wireColumns[ck].x + 20 > maxX) maxX = wireColumns[ck].x + 20;\n   410→    }\n   411→    for (var t in terminals) {\n   412→        var tx = positions[t].x + nodeW + 10;\n   413→        if (tx > maxX) maxX = tx;\n   414→    }\n   415→\n   416→    var svgW = maxX + padL;\n   417→    var svgH = padT * 2 + numLayers * nodeH + (numLayers - 1) * layerGap;\n   418→\n   419→    // --- Generate SVG ---\n   420→    var svg = '<svg class=\"dag-svg\" width=\"' + svgW + '\" height=\"' + svgH + '\">';\n   421→\n   422→    // Generate colored arrowhead markers for each result color\n   423→    svg += '<defs>';\n   424→    var markersDone = {};\n   425→    for (var r in resultColorCache) {\n   426→        var c = resultColorCache[r];\n   427→        if (markersDone[c]) continue;\n   428→        markersDone[c] = true;\n   429→        svg += '<marker id=\"arrow-' + c.replace('#','') + '\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"' + c + '\"/></marker>';\n   430→    }\n   431→    svg += '</defs>';\n   432→\n   433→    function mkr(color) { return 'url(#arrow-' + color.replace('#','') + ')'; }\n   434→\n   435→    // --- Draw normal (non-terminal) edges with colored Bezier curves ---\n   436→    normWires.forEach(function(wire) {\n   437→        var from = positions[wire.from], to = positions[wire.to];\n   438→        if (!from || !to) return;\n   439→        var color = resultColor(wire.result);\n   440→        var isSucc = isSuccessResult(wire.result);\n   441→        var x1 = from.x + nodeW / 2, y1 = from.y + nodeH;\n   442→        var x2 = to.x + nodeW / 2, y2 = to.y;\n   443→        var dy = y2 - y1;\n   444→        var off = isSucc ? 0 : nonsuccOffset;\n   445→        svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + off) + ' ' + (y1 + dy * 0.4) + ' ' + (x2 + off) + ' ' + (y1 + dy * 0.6) + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" style=\"stroke:' + color + '\" marker-end=\"' + mkr(color) + '\"/>';\n   446→        svg += '<text x=\"' + ((x1 + x2) / 2 + off + 6) + '\" y=\"' + (y1 + dy / 2) + '\" class=\"dag-edge-label\" style=\"fill:' + color + '\">' + wire.result + '</text>';\n   447→    });\n   448→\n   449→    // --- Draw success terminal wires with colored Bezier curves ---\n   450→    for (var term in termWires) {\n   451→        var tw = termWires[term];\n   452→        var tpos = positions[term];\n   453→        if (!tpos) continue;\n   454→\n   455→        tw.filter(function(w) { return isSuccessResult(w.result); }).forEach(function(wire) {\n   456→            var from = positions[wire.from];\n   457→            if (!from) return;\n   458→            var color = resultColor(wire.result);\n   459→            var x1 = from.x + nodeW / 2, y1 = from.y + nodeH;\n   460→            var x2 = tpos.x + nodeW / 2, y2 = tpos.y;\n   461→            var dy = y2 - y1;\n   462→            svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + x1 + ' ' + (y1 + dy * 0.4) + ' ' + x2 + ' ' + (y1 + dy * 0.6) + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" style=\"stroke:' + color + '\" marker-end=\"' + mkr(color) + '\"/>';\n   463→            svg += '<text x=\"' + ((x1 + x2) / 2 + 6) + '\" y=\"' + (y1 + dy / 2) + '\" class=\"dag-edge-label\" style=\"fill:' + color + '\">' + wire.result + '</text>';\n   464→        });\n   465→    }\n   466→\n   467→    // --- Draw wire column paths for non-success terminal wires ---\n   468→    // Each column routes: source right edge -> horizontal to column -> vertical down -> terminal\n   469→    for (var ck in wireColumns) {\n   470→        var col = wireColumns[ck];\n   471→        var color = resultColor(col.result);\n   472→        var tpos = positions[col.terminal];\n   473→        if (!tpos) continue;\n   474→\n   475→        // Collect link node positions (right edge of each source node)\n   476→        var links = [];\n   477→        col.wires.forEach(function(wire) {\n   478→            var from = positions[wire.from];\n   479→            if (!from) return;\n   480→            links.push({ srcX: from.x + nodeW, srcY: from.y + nodeH / 2 });\n   481→        });\n   482→        links.sort(function(a, b) { return a.srcY - b.srcY; });\n   483→        if (links.length === 0) continue;\n   484→\n   485→        // Draw horizontal segments from each source to wire column + link node dots\n   486→        links.forEach(function(ln) {\n   487→            svg += '<path d=\"M' + ln.srcX + ' ' + ln.srcY + ' L' + col.x + ' ' + ln.srcY + '\" class=\"dag-edge\" style=\"stroke:' + color + '\"/>';\n   488→            svg += '<circle cx=\"' + col.x + '\" cy=\"' + ln.srcY + '\" r=\"3\" class=\"dag-link-node\" style=\"fill:' + color + '\"/>';\n   489→            svg += '<text x=\"' + (ln.srcX + 6) + '\" y=\"' + (ln.srcY - 6) + '\" class=\"dag-edge-label\" style=\"fill:' + color + '\">' + col.result + '</text>';\n   490→        });\n   491→\n   492→        // Draw vertical wire column line from topmost link to terminal\n   493→        var topY = links[0].srcY;\n   494→        var termCX = tpos.x + nodeW / 2;\n   495→        var termTY = tpos.y;\n   496→\n   497→        if (Math.abs(col.x - termCX) < 5) {\n   498→            // Wire column is directly above terminal — straight down\n   499→            svg += '<path d=\"M' + col.x + ' ' + topY + ' L' + col.x + ' ' + termTY + '\" class=\"dag-edge\" style=\"stroke:' + color + '\" marker-end=\"' + mkr(color) + '\"/>';\n   500→        } else {\n   501→            // Wire column offset from terminal — go down then curve to terminal center\n   502→            var curveR = 15;\n   503→            var dir = termCX > col.x ? 1 : -1;\n   504→            svg += '<path d=\"M' + col.x + ' ' + topY + ' L' + col.x + ' ' + (termTY - curveR) + ' Q' + col.x + ' ' + termTY + ' ' + (col.x + dir * curveR) + ' ' + termTY + ' L' + termCX + ' ' + termTY + '\" class=\"dag-edge\" style=\"stroke:' + color + '\" marker-end=\"' + mkr(color) + '\"/>';\n   505→        }\n   506→    }\n   507→\n   508→    // Draw step nodes\n   509→    wf.steps.forEach(function(s) {\n   510→        var pos = positions[s.name];\n   511→        if (!pos) return;\n   512→        var icon = '\\u{1F4DC}';\n   513→        if (s.type === 'agent') icon = '\\u{1F916}';\n   514→        else if (s.type === 'workflow') icon = '\\u{1F501}';\n   515→        svg += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + s.name + '\\')\" style=\"cursor:pointer\">';\n   516→        svg += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n   517→        svg += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + s.name + '</text>';\n   518→        svg += '</g>';\n   519→    });\n   520→\n   521→    // Draw terminal nodes\n   522→    for (var t in terminals) {\n   523→        var pos = positions[t];\n   524→        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n   525→        svg += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n   526→        svg += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n   527→    }\n   528→\n   529→    svg += '</svg>';\n   530→    dagEl.innerHTML = svg;\n   531→}\n   532→\n   533→function openDrawer(workflowName, stepName) {\n   534→    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n   535→    if (!wf) return;\n   536→    var step = wf.steps.find(function(s) { return s.name === stepName; });\n   537→    if (!step) return;\n   538→\n   539→    document.getElementById('drawer-title').textContent = stepName;\n   540→    var body = '<dl class=\"run-meta\">';\n   541→    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n   542→    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n   543→    if (step.config) {\n   544→        for (var k in step.config) {\n   545→            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script' || k === 'run' || k === 'workflow_name') {\n   546→                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n   547→            }\n   548→        }\n   549→    }\n   550→    body += '</dl>';\n   551→    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n   552→\n   553→    document.getElementById('drawer-body').innerHTML = body;\n   554→    document.getElementById('step-drawer').classList.add('drawer-open');\n   555→\n   556→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n   557→        .then(function(r) { if (r.ok) return r.text(); return ''; })\n   558→        .then(function(text) {\n   559→            var el = document.getElementById('drawer-content');\n   560→            if (text) {\n   561→                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n   562→            } else {\n   563→                el.style.display = 'none';\n   564→            }\n   565→        });\n   566→}\n   567→\n   568→function closeDrawer() {\n   569→    document.getElementById('step-drawer').classList.remove('drawer-open');\n   570→}\n   571→\n   572→document.addEventListener('keydown', function(e) {\n   573→    if (e.key === 'Escape') closeDrawer();\n   574→});\n   575→\n   576→window.deleteAllContainers = function() {\n   577→    var btn = document.getElementById('delete-containers-btn');\n   578→    if (btn) btn.disabled = true;\n   579→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/containers', { method: 'DELETE' })\n   580→        .then(function(r) { return r.json(); })\n   581→        .then(function(data) {\n   582→            if (btn) {\n   583→                btn.textContent = 'Deleted ' + (data.deleted || 0) + ' container' + (data.deleted !== 1 ? 's' : '');\n   584→                btn.classList.remove('btn-danger');\n   585→                btn.classList.add('btn-secondary');\n   586→            }\n   587→        })\n   588→        .catch(function() {\n   589→            if (btn) {\n   590→                btn.textContent = 'Delete failed';\n   591→                btn.disabled = false;\n   592→            }\n   593→        });\n   594→};\n   595→\n   596→function escapeHtml(s) {\n   597→    var d = document.createElement('div');\n   598→    d.appendChild(document.createTextNode(s));\n   599→    return d.innerHTML;\n   600→}\n   601→\n   602→function releaseTask(taskId) {\n   603→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/tasks/' + encodeURIComponent(taskId) + '/release', { method: 'POST' })\n   604→        .then(function(r) { return r.json(); })\n   605→        .then(function(data) {\n   606→            if (data.error) {\n   607→                alert('Failed to release task: ' + data.error);\n   608→            } else {\n   609→                loadTasks();\n   610→            }\n   611→        })\n   612→        .catch(function() { alert('Failed to release task'); });\n   613→}\n   614→\n   615→function renderTaskTable(tasks, showRelease) {\n   616→    if (!tasks || tasks.length === 0) {\n   617→        return '<p class=\"empty\">No tasks</p>';\n   618→    }\n   619→    var html = '<table class=\"runs-table\" style=\"margin:0\"><thead><tr>';\n   620→    html += '<th>Task ID</th><th>Title</th><th>Status</th><th>Assigned</th><th>Run</th>';\n   621→    if (showRelease) html += '<th></th>';\n   622→    html += '</tr></thead><tbody>';\n   623→    for (var i = 0; i < tasks.length; i++) {\n   624→        var t = tasks[i];\n   625→        var statusClass = t.status === 'open' ? 'running' : (t.status === 'closed' ? 'succeeded' : 'pending');\n   626→        html += '<tr>';\n   627→        html += '<td class=\"mono\">' + escapeHtml(t.id) + '</td>';\n   628→        html += '<td>' + escapeHtml(t.title || '') + '</td>';\n   629→        html += '<td><span class=\"badge badge-' + statusClass + '\">' + escapeHtml(t.status) + '</span></td>';\n   630→        html += '<td>' + (t.assigned ? 'Yes' : 'No') + '</td>';\n   631→        html += '<td>' + (t.run_id ? '<a href=\"/runs/' + escapeHtml(t.run_id) + '\">' + escapeHtml(t.run_id) + '</a>' : '') + '</td>';\n   632→        if (showRelease) {\n   633→            html += '<td>';\n   634→            if (t.stale) {\n   635→                html += '<button class=\"btn btn-secondary btn-sm\" onclick=\"releaseTask(\\'' + escapeHtml(t.id) + '\\')\">Release</button>';\n   636→            }\n   637→            html += '</td>';\n   638→        }\n   639→        html += '</tr>';\n   640→    }\n   641→    html += '</tbody></table>';\n   642→    return html;\n   643→}\n   644→\n   645→function loadTasks() {\n   646→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/tasks')\n   647→        .then(function(r) { return r.json(); })\n   648→        .then(function(tasks) {\n   649→            var inProgress = [];\n   650→            var upcoming = [];\n   651→            if (tasks) {\n   652→                for (var i = 0; i < tasks.length; i++) {\n   653→                    var t = tasks[i];\n   654→                    if (t.status === 'in-progress' || t.status === 'in_progress') {\n   655→                        inProgress.push(t);\n   656→                    } else if (t.status === 'open' || t.status === '') {\n   657→                        upcoming.push(t);\n   658→                    }\n   659→                }\n   660→            }\n   661→            document.getElementById('in-progress-body').innerHTML = renderTaskTable(inProgress, true);\n   662→            document.getElementById('upcoming-body').innerHTML = renderTaskTable(upcoming, false);\n   663→        })\n   664→        .catch(function() {});\n   665→}\n   666→\n   667→// Load all panels\n   668→loadProjectInfo();\n   669→loadWorkflows();\n   670→loadTasks();\n   671→setInterval(loadTasks, 5000);\n   672→</script>\n   673→{{end}}\n   674→"}]},"parent_tool_use_id":null,"session_id":"4544fa8d-d9f6-4e57-8374-6a5c036ca271","uuid":"e25306f8-b45c-4731-bd7c-3c2384483ac8","timestamp":"2026-03-18T18:19:13.069Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/project_detail.html","content":"{{define \"content\"}}\n<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n\n<div class=\"run-history\" style=\"margin-bottom:1rem\">\n    {{range .RecentRuns}}\n    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n    {{end}}\n    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n    {{if .ContainerCount}}\n    <button class=\"btn btn-danger btn-sm\" id=\"delete-containers-btn\" onclick=\"deleteAllContainers()\" style=\"margin-left:0.5rem\">Delete {{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}</button>\n    {{end}}\n</div>\n\n<!-- Panel 1: Project Info -->\n<div class=\"panel\" id=\"info-panel\">\n    <div class=\"panel-header\">Project Info</div>\n    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n</div>\n\n<!-- Panel 2: In-progress Tasks -->\n<div class=\"panel\" id=\"in-progress-panel\">\n    <div class=\"panel-header\">In-progress Tasks</div>\n    <div class=\"panel-body\" id=\"in-progress-body\">Loading...</div>\n</div>\n\n<!-- Panel 3: Upcoming Tasks -->\n<div class=\"panel\" id=\"upcoming-panel\">\n    <div class=\"panel-header\">Upcoming Tasks</div>\n    <div class=\"panel-body\" id=\"upcoming-body\">Loading...</div>\n</div>\n\n<!-- Panel 3: Workflow View -->\n<div class=\"panel\" id=\"workflow-panel\">\n    <div class=\"panel-header\">Workflows</div>\n    <div class=\"panel-body\">\n        <div id=\"location-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-dag\"></div>\n    </div>\n</div>\n\n<!-- Step Drawer -->\n<div class=\"drawer\" id=\"step-drawer\">\n    <div class=\"drawer-header\">\n        <span id=\"drawer-title\"></span>\n        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    </div>\n    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n</div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\nvar projectLabel = {{.Label}};\n\nfunction loadProjectInfo() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n            html += '</dl>';\n\n            if (data.prompt_files && data.prompt_files.length > 0) {\n                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n                data.prompt_files.forEach(function(pf) {\n                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n                    if (pf.content) {\n                        html += '<pre class=\"diff-block\">' + pf.content.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n                    } else {\n                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">Empty file</p>';\n                    }\n                    html += '</details>';\n                });\n            }\n\n            document.getElementById('project-info').innerHTML = html;\n        });\n}\n\nfunction toggleDiff(el) {\n    var existing = el.nextElementSibling;\n    if (existing && existing.classList.contains('diff-block')) {\n        existing.remove();\n        return;\n    }\n    var file = el.getAttribute('data-file');\n    var sha = el.getAttribute('data-sha');\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n        .then(function(r) { return r.text(); })\n        .then(function(text) {\n            var pre = document.createElement('pre');\n            pre.className = 'diff-block';\n            pre.textContent = text || '(no diff available)';\n            el.parentNode.insertBefore(pre, el.nextSibling);\n        });\n}\n\nvar workflowsData = [];\nvar activeLocation = 'container';\n\nfunction loadWorkflows() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            workflowsData = data || [];\n            if (workflowsData.length === 0) {\n                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n                return;\n            }\n\n            // Check which locations exist\n            var hasContainer = workflowsData.some(function(wf) { return wf.location === 'container'; });\n            var hasHost = workflowsData.some(function(wf) { return wf.location === 'host'; });\n\n            // Render location tabs if both types exist\n            var locationTabs = document.getElementById('location-tabs');\n            if (hasContainer && hasHost) {\n                var html = '';\n                html += '<button class=\"tab-btn tab-active\" onclick=\"switchLocation(\\'container\\')\">Container</button>';\n                html += '<button class=\"tab-btn\" onclick=\"switchLocation(\\'host\\')\">Host</button>';\n                locationTabs.innerHTML = html;\n            } else {\n                locationTabs.innerHTML = '';\n            }\n\n            // Default to whichever location exists\n            activeLocation = hasContainer ? 'container' : 'host';\n            renderWorkflowTabs();\n        });\n}\n\nfunction switchLocation(loc) {\n    activeLocation = loc;\n    var btns = document.querySelectorAll('#location-tabs .tab-btn');\n    btns.forEach(function(b) {\n        b.classList.toggle('tab-active', b.textContent === (loc === 'container' ? 'Container' : 'Host'));\n    });\n    renderWorkflowTabs();\n}\n\nfunction renderWorkflowTabs() {\n    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n    var tabs = document.getElementById('workflow-tabs');\n\n    if (filtered.length === 0) {\n        tabs.innerHTML = '';\n        document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No ' + activeLocation + ' workflows found</p>';\n        return;\n    }\n\n    if (filtered.length > 1) {\n        var html = '';\n        filtered.forEach(function(wf, i) {\n            html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showFilteredWorkflow(' + i + ')\">' + wf.name + '</button>';\n        });\n        tabs.innerHTML = html;\n    } else {\n        tabs.innerHTML = '';\n    }\n    showFilteredWorkflow(0);\n}\n\nfunction showFilteredWorkflow(idx) {\n    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n    var btns = document.querySelectorAll('#workflow-tabs .tab-btn');\n    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n    showWorkflow(filtered[idx]);\n}\n\nfunction showWorkflow(wf) {\n    var dagEl = document.getElementById('workflow-dag');\n\n    if (!wf.steps || wf.steps.length === 0) {\n        dagEl.innerHTML = '<p class=\"empty\">No steps defined</p>';\n        return;\n    }\n\n    var stepMap = {};\n    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n\n    var wires = wf.wires || [];\n\n    // Helper: determine if a result is the success/happy-path\n    function isSuccessResult(r) { return r === 'success' || r === 'ok' || r === 'done' || r === 'pass'; }\n    function isFailureResult(r) { return r === 'failed' || r === 'fail' || r === 'error'; }\n\n    // --- Color system: map result types to colors ---\n    var colorPalette = ['#2196f3', '#ffc107', '#e040fb', '#00bcd4', '#ff9800'];\n    var otherColorIdx = 0;\n    var resultColorCache = {};\n\n    function resultColor(r) {\n        if (resultColorCache[r]) return resultColorCache[r];\n        if (isSuccessResult(r)) { resultColorCache[r] = '#4caf50'; }\n        else if (isFailureResult(r)) { resultColorCache[r] = '#e53935'; }\n        else {\n            resultColorCache[r] = colorPalette[otherColorIdx % colorPalette.length];\n            otherColorIdx++;\n        }\n        return resultColorCache[r];\n    }\n\n    // Pre-compute colors for all wire results\n    wires.forEach(function(w) { resultColor(w.result); });\n\n    // Collect terminal targets\n    var terminals = {};\n    wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n    });\n\n    // Build adjacency maps\n    var adj = {};    // from -> [wire]\n    var revAdj = {}; // to -> [from] (unique)\n    wires.forEach(function(wire) {\n        if (!adj[wire.from]) adj[wire.from] = [];\n        adj[wire.from].push(wire);\n        if (!revAdj[wire.to]) revAdj[wire.to] = [];\n        if (revAdj[wire.to].indexOf(wire.from) === -1) revAdj[wire.to].push(wire.from);\n    });\n\n    // --- Layer assignment via longest path (Sugiyama-style) ---\n    var stepNames = wf.steps.map(function(s) { return s.name; });\n\n    // Topological sort (Kahn's algorithm)\n    var inDeg = {};\n    stepNames.forEach(function(n) { inDeg[n] = 0; });\n    wires.forEach(function(wire) {\n        if (inDeg[wire.to] !== undefined) inDeg[wire.to]++;\n    });\n\n    var queue = [];\n    stepNames.forEach(function(n) { if (inDeg[n] === 0) queue.push(n); });\n\n    var topoOrder = [];\n    while (queue.length > 0) {\n        var n = queue.shift();\n        topoOrder.push(n);\n        (adj[n] || []).forEach(function(wire) {\n            if (inDeg[wire.to] !== undefined) {\n                inDeg[wire.to]--;\n                if (inDeg[wire.to] === 0) queue.push(wire.to);\n            }\n        });\n    }\n    // Add remaining steps (cycles) in BFS order from already-ordered nodes.\n    // This ensures forward dependencies are processed before their targets,\n    // so layer assignment sees correct parent layers even within cycles.\n    var topoVisited = {};\n    topoOrder.forEach(function(n) { topoVisited[n] = true; });\n    var bfsQ = topoOrder.slice();\n    while (bfsQ.length > 0) {\n        var bn = bfsQ.shift();\n        (adj[bn] || []).forEach(function(wire) {\n            if (!topoVisited[wire.to] && inDeg[wire.to] !== undefined) {\n                topoVisited[wire.to] = true;\n                topoOrder.push(wire.to);\n                bfsQ.push(wire.to);\n            }\n        });\n    }\n    // Add any truly disconnected nodes\n    stepNames.forEach(function(n) { if (!topoVisited[n]) { topoOrder.push(n); } });\n\n    // Assign layers: longest path from any source\n    var layerOf = {};\n    topoOrder.forEach(function(n) {\n        var maxParent = -1;\n        (revAdj[n] || []).forEach(function(p) {\n            if (layerOf[p] !== undefined && layerOf[p] > maxParent) maxParent = layerOf[p];\n        });\n        layerOf[n] = maxParent + 1;\n    });\n\n    var maxLayer = 0;\n    stepNames.forEach(function(n) { if (layerOf[n] > maxLayer) maxLayer = layerOf[n]; });\n\n    // Terminals in rightmost layer\n    var termLayer = maxLayer + 1;\n    for (var t in terminals) { layerOf[t] = termLayer; }\n    var numLayers = termLayer + 1;\n\n    // --- Build layer arrays ---\n    var layers = [];\n    for (var i = 0; i < numLayers; i++) layers.push([]);\n    topoOrder.forEach(function(n) { layers[layerOf[n]].push(n); });\n    for (var t in terminals) { layers[termLayer].push(t); }\n\n    // --- Barycenter ordering to minimize edge crossings ---\n    for (var pass = 0; pass < 4; pass++) {\n        // Forward pass\n        for (var li = 1; li < numLayers; li++) {\n            var bary = {};\n            layers[li].forEach(function(n) {\n                var pars = revAdj[n] || [];\n                var sum = 0, cnt = 0;\n                pars.forEach(function(p) {\n                    var idx = layers[li - 1].indexOf(p);\n                    if (idx >= 0) { sum += idx; cnt++; }\n                });\n                bary[n] = cnt > 0 ? sum / cnt : 999;\n            });\n            layers[li].sort(function(a, b) { return bary[a] - bary[b]; });\n        }\n        // Backward pass\n        for (var li = numLayers - 2; li >= 0; li--) {\n            var baryB = {};\n            layers[li].forEach(function(n) {\n                var children = (adj[n] || []).map(function(w) { return w.to; });\n                var sum = 0, cnt = 0;\n                children.forEach(function(c) {\n                    var idx = layers[li + 1].indexOf(c);\n                    if (idx >= 0) { sum += idx; cnt++; }\n                });\n                baryB[n] = cnt > 0 ? sum / cnt : 999;\n            });\n            layers[li].sort(function(a, b) { return baryB[a] - baryB[b]; });\n        }\n    }\n\n    // --- Position calculation (top-to-bottom layout) ---\n    var nodeW = 180, nodeH = 48;\n    var layerGap = 80;  // vertical gap between layers\n    var nodeGap = 40;   // horizontal gap between nodes in same layer\n    var nonsuccOffset = 35; // horizontal offset for non-success bezier wires\n    var padL = 30, padT = 30;\n\n    var maxInLayer = 1;\n    layers.forEach(function(l) { if (l.length > maxInLayer) maxInLayer = l.length; });\n    var totalLayerW = maxInLayer * nodeW + (maxInLayer - 1) * nodeGap;\n\n    var positions = {};\n    layers.forEach(function(layer, li) {\n        var lw = layer.length * nodeW + (layer.length - 1) * nodeGap;\n        var offsetX = (totalLayerW - lw) / 2;\n        layer.forEach(function(name, ni) {\n            positions[name] = {\n                x: padL + offsetX + ni * (nodeW + nodeGap),\n                y: padT + li * (nodeH + layerGap)\n            };\n        });\n    });\n\n    // --- Wire columns for non-success terminal wires ---\n    // Separate terminal wires from normal wires\n    var termWires = {};\n    var normWires = [];\n    wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') {\n            if (!termWires[wire.to]) termWires[wire.to] = [];\n            termWires[wire.to].push(wire);\n        } else {\n            normWires.push(wire);\n        }\n    });\n\n    // Build wire columns: one per (terminal, result) pair for non-success wires\n    var wireColStart = padL + totalLayerW + 50;\n    var wireColGap = 40;\n    var wireColumns = {};  // key \"term:result\" -> { x, terminal, result, wires }\n    var wireColIdx = 0;\n\n    for (var term in termWires) {\n        var tw = termWires[term];\n        var nonSucc = tw.filter(function(w) { return !isSuccessResult(w.result); });\n        if (nonSucc.length > 0) {\n            var byResult = {};\n            nonSucc.forEach(function(w) {\n                if (!byResult[w.result]) byResult[w.result] = [];\n                byResult[w.result].push(w);\n            });\n            for (var result in byResult) {\n                var colKey = term + ':' + result;\n                wireColumns[colKey] = {\n                    x: wireColStart + wireColIdx * wireColGap,\n                    terminal: term,\n                    result: result,\n                    wires: byResult[result]\n                };\n                wireColIdx++;\n            }\n        }\n    }\n\n    // Reposition terminals that only receive non-success wires under wire columns\n    for (var term in termWires) {\n        var tw = termWires[term];\n        var hasSucc = tw.some(function(w) { return isSuccessResult(w.result); });\n        if (!hasSucc) {\n            var colXs = [];\n            for (var ck in wireColumns) {\n                if (wireColumns[ck].terminal === term) colXs.push(wireColumns[ck].x);\n            }\n            if (colXs.length > 0) {\n                var avgX = colXs.reduce(function(a, b) { return a + b; }, 0) / colXs.length;\n                positions[term] = {\n                    x: avgX - nodeW / 2,\n                    y: positions[term].y\n                };\n            }\n        }\n    }\n\n    // Calculate SVG dimensions accounting for wire columns and repositioned terminals\n    var maxX = padL + totalLayerW;\n    for (var ck in wireColumns) {\n        if (wireColumns[ck].x + 20 > maxX) maxX = wireColumns[ck].x + 20;\n    }\n    for (var t in terminals) {\n        var tx = positions[t].x + nodeW + 10;\n        if (tx > maxX) maxX = tx;\n    }\n\n    var svgW = maxX + padL;\n    var svgH = padT * 2 + numLayers * nodeH + (numLayers - 1) * layerGap;\n\n    // --- Generate SVG ---\n    var svg = '<svg class=\"dag-svg\" width=\"' + svgW + '\" height=\"' + svgH + '\">';\n\n    // Generate colored arrowhead markers for each result color\n    svg += '<defs>';\n    var markersDone = {};\n    for (var r in resultColorCache) {\n        var c = resultColorCache[r];\n        if (markersDone[c]) continue;\n        markersDone[c] = true;\n        svg += '<marker id=\"arrow-' + c.replace('#','') + '\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"' + c + '\"/></marker>';\n    }\n    svg += '</defs>';\n\n    function mkr(color) { return 'url(#arrow-' + color.replace('#','') + ')'; }\n\n    // --- Draw normal (non-terminal) edges with colored Bezier curves ---\n    normWires.forEach(function(wire) {\n        var from = positions[wire.from], to = positions[wire.to];\n        if (!from || !to) return;\n        var color = resultColor(wire.result);\n        var isSucc = isSuccessResult(wire.result);\n        var x1 = from.x + nodeW / 2, y1 = from.y + nodeH;\n        var x2 = to.x + nodeW / 2, y2 = to.y;\n        var dy = y2 - y1;\n        var off = isSucc ? 0 : nonsuccOffset;\n        svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + off) + ' ' + (y1 + dy * 0.4) + ' ' + (x2 + off) + ' ' + (y1 + dy * 0.6) + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" style=\"stroke:' + color + '\" marker-end=\"' + mkr(color) + '\"/>';\n        svg += '<text x=\"' + ((x1 + x2) / 2 + off + 6) + '\" y=\"' + (y1 + dy / 2) + '\" class=\"dag-edge-label\" style=\"fill:' + color + '\">' + wire.result + '</text>';\n    });\n\n    // --- Draw success terminal wires with colored Bezier curves ---\n    for (var term in termWires) {\n        var tw = termWires[term];\n        var tpos = positions[term];\n        if (!tpos) continue;\n\n        tw.filter(function(w) { return isSuccessResult(w.result); }).forEach(function(wire) {\n            var from = positions[wire.from];\n            if (!from) return;\n            var color = resultColor(wire.result);\n            var x1 = from.x + nodeW / 2, y1 = from.y + nodeH;\n            var x2 = tpos.x + nodeW / 2, y2 = tpos.y;\n            var dy = y2 - y1;\n            svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + x1 + ' ' + (y1 + dy * 0.4) + ' ' + x2 + ' ' + (y1 + dy * 0.6) + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" style=\"stroke:' + color + '\" marker-end=\"' + mkr(color) + '\"/>';\n            svg += '<text x=\"' + ((x1 + x2) / 2 + 6) + '\" y=\"' + (y1 + dy / 2) + '\" class=\"dag-edge-label\" style=\"fill:' + color + '\">' + wire.result + '</text>';\n        });\n    }\n\n    // --- Draw wire column paths for non-success terminal wires ---\n    // Each column routes: source right edge -> horizontal to column -> vertical down -> terminal\n    for (var ck in wireColumns) {\n        var col = wireColumns[ck];\n        var color = resultColor(col.result);\n        var tpos = positions[col.terminal];\n        if (!tpos) continue;\n\n        // Collect link node positions (right edge of each source node)\n        var links = [];\n        col.wires.forEach(function(wire) {\n            var from = positions[wire.from];\n            if (!from) return;\n            links.push({ srcX: from.x + nodeW, srcY: from.y + nodeH / 2 });\n        });\n        links.sort(function(a, b) { return a.srcY - b.srcY; });\n        if (links.length === 0) continue;\n\n        // Draw horizontal segments from each source to wire column + link node dots\n        links.forEach(function(ln) {\n            svg += '<path d=\"M' + ln.srcX + ' ' + ln.srcY + ' L' + col.x + ' ' + ln.srcY + '\" class=\"dag-edge\" style=\"stroke:' + color + '\"/>';\n            svg += '<circle cx=\"' + col.x + '\" cy=\"' + ln.srcY + '\" r=\"3\" class=\"dag-link-node\" style=\"fill:' + color + '\"/>';\n            svg += '<text x=\"' + (ln.srcX + 6) + '\" y=\"' + (ln.srcY - 6) + '\" class=\"dag-edge-label\" style=\"fill:' + color + '\">' + col.result + '</text>';\n        });\n\n        // Draw vertical wire column line from topmost link to terminal\n        var topY = links[0].srcY;\n        var termCX = tpos.x + nodeW / 2;\n        var termTY = tpos.y;\n\n        if (Math.abs(col.x - termCX) < 5) {\n            // Wire column is directly above terminal — straight down\n            svg += '<path d=\"M' + col.x + ' ' + topY + ' L' + col.x + ' ' + termTY + '\" class=\"dag-edge\" style=\"stroke:' + color + '\" marker-end=\"' + mkr(color) + '\"/>';\n        } else {\n            // Wire column offset from terminal — go down then curve to terminal center\n            var curveR = 15;\n            var dir = termCX > col.x ? 1 : -1;\n            svg += '<path d=\"M' + col.x + ' ' + topY + ' L' + col.x + ' ' + (termTY - curveR) + ' Q' + col.x + ' ' + termTY + ' ' + (col.x + dir * curveR) + ' ' + termTY + ' L' + termCX + ' ' + termTY + '\" class=\"dag-edge\" style=\"stroke:' + color + '\" marker-end=\"' + mkr(color) + '\"/>';\n        }\n    }\n\n    // Draw step nodes\n    wf.steps.forEach(function(s) {\n        var pos = positions[s.name];\n        if (!pos) return;\n        var icon = '\\u{1F4DC}';\n        if (s.type === 'agent') icon = '\\u{1F916}';\n        else if (s.type === 'workflow') icon = '\\u{1F501}';\n        svg += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + s.name + '\\')\" style=\"cursor:pointer\">';\n        svg += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n        svg += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + s.name + '</text>';\n        svg += '</g>';\n    });\n\n    // Draw terminal nodes\n    for (var t in terminals) {\n        var pos = positions[t];\n        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n        svg += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n        svg += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n    }\n\n    svg += '</svg>';\n    dagEl.innerHTML = svg;\n}\n\nfunction openDrawer(workflowName, stepName) {\n    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n    if (!wf) return;\n    var step = wf.steps.find(function(s) { return s.name === stepName; });\n    if (!step) return;\n\n    document.getElementById('drawer-title').textContent = stepName;\n    var body = '<dl class=\"run-meta\">';\n    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n    if (step.config) {\n        for (var k in step.config) {\n            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script' || k === 'run' || k === 'workflow_name') {\n                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n            }\n        }\n    }\n    body += '</dl>';\n    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n\n    document.getElementById('drawer-body').innerHTML = body;\n    document.getElementById('step-drawer').classList.add('drawer-open');\n\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n        .then(function(r) { if (r.ok) return r.text(); return ''; })\n        .then(function(text) {\n            var el = document.getElementById('drawer-content');\n            if (text) {\n                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n            } else {\n                el.style.display = 'none';\n            }\n        });\n}\n\nfunction closeDrawer() {\n    document.getElementById('step-drawer').classList.remove('drawer-open');\n}\n\ndocument.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') closeDrawer();\n});\n\nwindow.deleteAllContainers = function() {\n    var btn = document.getElementById('delete-containers-btn');\n    if (btn) btn.disabled = true;\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/containers', { method: 'DELETE' })\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            if (btn) {\n                btn.textContent = 'Deleted ' + (data.deleted || 0) + ' container' + (data.deleted !== 1 ? 's' : '');\n                btn.classList.remove('btn-danger');\n                btn.classList.add('btn-secondary');\n            }\n        })\n        .catch(function() {\n            if (btn) {\n                btn.textContent = 'Delete failed';\n                btn.disabled = false;\n            }\n        });\n};\n\nfunction escapeHtml(s) {\n    var d = document.createElement('div');\n    d.appendChild(document.createTextNode(s));\n    return d.innerHTML;\n}\n\nfunction releaseTask(taskId) {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/tasks/' + encodeURIComponent(taskId) + '/release', { method: 'POST' })\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            if (data.error) {\n                alert('Failed to release task: ' + data.error);\n            } else {\n                loadTasks();\n            }\n        })\n        .catch(function() { alert('Failed to release task'); });\n}\n\nfunction renderTaskTable(tasks, showRelease) {\n    if (!tasks || tasks.length === 0) {\n        return '<p class=\"empty\">No tasks</p>';\n    }\n    var html = '<table class=\"runs-table\" style=\"margin:0\"><thead><tr>';\n    html += '<th>Task ID</th><th>Title</th><th>Status</th><th>Assigned</th><th>Run</th>';\n    if (showRelease) html += '<th></th>';\n    html += '</tr></thead><tbody>';\n    for (var i = 0; i < tasks.length; i++) {\n        var t = tasks[i];\n        var statusClass = t.status === 'open' ? 'running' : (t.status === 'closed' ? 'succeeded' : 'pending');\n        html += '<tr>';\n        html += '<td class=\"mono\">' + escapeHtml(t.id) + '</td>';\n        html += '<td>' + escapeHtml(t.title || '') + '</td>';\n        html += '<td><span class=\"badge badge-' + statusClass + '\">' + escapeHtml(t.status) + '</span></td>';\n        html += '<td>' + (t.assigned ? 'Yes' : 'No') + '</td>';\n        html += '<td>' + (t.run_id ? '<a href=\"/runs/' + escapeHtml(t.run_id) + '\">' + escapeHtml(t.run_id) + '</a>' : '') + '</td>';\n        if (showRelease) {\n            html += '<td>';\n            if (t.stale) {\n                html += '<button class=\"btn btn-secondary btn-sm\" onclick=\"releaseTask(\\'' + escapeHtml(t.id) + '\\')\">Release</button>';\n            }\n            html += '</td>';\n        }\n        html += '</tr>';\n    }\n    html += '</tbody></table>';\n    return html;\n}\n\nfunction loadTasks() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/tasks')\n        .then(function(r) { return r.json(); })\n        .then(function(tasks) {\n            var inProgress = [];\n            var upcoming = [];\n            if (tasks) {\n                for (var i = 0; i < tasks.length; i++) {\n                    var t = tasks[i];\n                    if (t.status === 'in-progress' || t.status === 'in_progress') {\n                        inProgress.push(t);\n                    } else if (t.status === 'open' || t.status === '') {\n                        upcoming.push(t);\n                    }\n                }\n            }\n            document.getElementById('in-progress-body').innerHTML = renderTaskTable(inProgress, true);\n            document.getElementById('upcoming-body').innerHTML = renderTaskTable(upcoming, false);\n        })\n        .catch(function() {});\n}\n\n// Load all panels\nloadProjectInfo();\nloadWorkflows();\nloadTasks();\nsetInterval(loadTasks, 5000);\n</script>\n{{end}}\n","numLines":674,"startLine":1,"totalLines":674}}}
