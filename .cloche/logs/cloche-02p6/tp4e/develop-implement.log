{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y6R42S1xRB7JKSNwfBVHZT","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"net/http\"\n     9→\t\"net/http/httptest\"\n    10→\t\"os\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"testing\"\n    14→\t\"time\"\n    15→\n    16→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    17→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    18→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    19→\t\"github.com/stretchr/testify/assert\"\n    20→\t\"github.com/stretchr/testify/require\"\n    21→)\n    22→\n    23→func setupHandlerWithBroadcaster(t *testing.T) (*Handler, *sqlite.Store, *logstream.Broadcaster) {\n    24→\tt.Helper()\n    25→\tstore, err := sqlite.NewStore(\":memory:\")\n    26→\trequire.NoError(t, err)\n    27→\tt.Cleanup(func() { store.Close() })\n    28→\n    29→\tb := logstream.NewBroadcaster()\n    30→\th, err := NewHandler(store, store, WithLogBroadcaster(b))\n    31→\trequire.NoError(t, err)\n    32→\treturn h, store, b\n    33→}\n    34→\n    35→func TestSSE_CompletedRun_ServesFullLog(t *testing.T) {\n    36→\th, store, _ := setupHandlerWithBroadcaster(t)\n    37→\n    38→\tdir := t.TempDir()\n    39→\n    40→\t// Create a completed run\n    41→\tctx := context.Background()\n    42→\trun := domain.NewRun(\"sse-test-1\", \"develop\")\n    43→\trun.ProjectDir = dir\n    44→\trun.Start()\n    45→\trun.ContainerID = \"abc123\"\n    46→\trun.Complete(domain.RunStateSucceeded)\n    47→\trequire.NoError(t, store.CreateRun(ctx, run))\n    48→\n    49→\t// Write full.log\n    50→\toutputDir := filepath.Join(dir, \".cloche\", \"sse-test-1\", \"output\")\n    51→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n    52→\tlogContent := \"[2026-03-03T10:15:00Z] [status] step_started: build\\n\" +\n    53→\t\t\"[2026-03-03T10:15:01Z] [script] npm run build\\n\" +\n    54→\t\t\"[2026-03-03T10:15:02Z] [llm] Claude: Starting analysis\\n\"\n    55→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"full.log\"), []byte(logContent), 0644))\n    56→\n    57→\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-test-1/stream\", nil)\n    58→\tw := httptest.NewRecorder()\n    59→\th.ServeHTTP(w, req)\n    60→\n    61→\tassert.Equal(t, http.StatusOK, w.Code)\n    62→\tassert.Equal(t, \"text/event-stream\", w.Header().Get(\"Content-Type\"))\n    63→\n    64→\t// Parse SSE events\n    65→\tbody := w.Body.String()\n    66→\tlines := strings.Split(body, \"\\n\")\n    67→\n    68→\tvar events []logstream.LogLine\n    69→\tfor _, line := range lines {\n    70→\t\tif strings.HasPrefix(line, \"data: \") {\n    71→\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n    72→\t\t\tvar ll logstream.LogLine\n    73→\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n    74→\t\t\t\tevents = append(events, ll)\n    75→\t\t\t}\n    76→\t\t}\n    77→\t}\n    78→\n    79→\trequire.Len(t, events, 3)\n    80→\tassert.Equal(t, \"status\", events[0].Type)\n    81→\tassert.Equal(t, \"step_started: build\", events[0].Content)\n    82→\tassert.Equal(t, \"script\", events[1].Type)\n    83→\tassert.Equal(t, \"npm run build\", events[1].Content)\n    84→\tassert.Equal(t, \"llm\", events[2].Type)\n    85→\tassert.Equal(t, \"Claude: Starting analysis\", events[2].Content)\n    86→\n    87→\t// Should contain done event\n    88→\tassert.Contains(t, body, \"event: done\")\n    89→}\n    90→\n    91→func TestSSE_ActiveRun_StreamsLive(t *testing.T) {\n    92→\th, store, b := setupHandlerWithBroadcaster(t)\n    93→\n    94→\t// Create a running run\n    95→\tctx := context.Background()\n    96→\trun := domain.NewRun(\"sse-live-1\", \"develop\")\n    97→\trun.ProjectDir = t.TempDir()\n    98→\trun.Start()\n    99→\trun.ContainerID = \"abc123\"\n   100→\trequire.NoError(t, store.CreateRun(ctx, run))\n   101→\n   102→\t// Start a subscriber to simulate an active broadcast\n   103→\tb.Subscribe(\"sse-live-1\")\n   104→\n   105→\t// Use a real HTTP server for streaming\n   106→\tsrv := httptest.NewServer(h)\n   107→\tdefer srv.Close()\n   108→\n   109→\t// Publish some lines in a goroutine\n   110→\tgo func() {\n   111→\t\ttime.Sleep(50 * time.Millisecond)\n   112→\t\tb.Publish(\"sse-live-1\", logstream.LogLine{\n   113→\t\t\tTimestamp: \"2026-03-03T10:15:00Z\",\n   114→\t\t\tType:      \"status\",\n   115→\t\t\tContent:   \"step_started: build\",\n   116→\t\t})\n   117→\t\ttime.Sleep(50 * time.Millisecond)\n   118→\t\tb.Publish(\"sse-live-1\", logstream.LogLine{\n   119→\t\t\tTimestamp: \"2026-03-03T10:15:01Z\",\n   120→\t\t\tType:      \"script\",\n   121→\t\t\tContent:   \"compiling...\",\n   122→\t\t})\n   123→\t\ttime.Sleep(50 * time.Millisecond)\n   124→\t\tb.Finish(\"sse-live-1\")\n   125→\t}()\n   126→\n   127→\tresp, err := http.Get(srv.URL + \"/api/runs/sse-live-1/stream\")\n   128→\trequire.NoError(t, err)\n   129→\tdefer resp.Body.Close()\n   130→\n   131→\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n   132→\tassert.Equal(t, \"text/event-stream\", resp.Header.Get(\"Content-Type\"))\n   133→\n   134→\tvar events []logstream.LogLine\n   135→\tscanner := bufio.NewScanner(resp.Body)\n   136→\tfor scanner.Scan() {\n   137→\t\tline := scanner.Text()\n   138→\t\tif strings.HasPrefix(line, \"data: \") {\n   139→\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n   140→\t\t\tvar ll logstream.LogLine\n   141→\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n   142→\t\t\t\tevents = append(events, ll)\n   143→\t\t\t}\n   144→\t\t}\n   145→\t\tif strings.HasPrefix(line, \"event: done\") {\n   146→\t\t\tbreak\n   147→\t\t}\n   148→\t}\n   149→\n   150→\trequire.Len(t, events, 2)\n   151→\tassert.Equal(t, \"status\", events[0].Type)\n   152→\tassert.Equal(t, \"step_started: build\", events[0].Content)\n   153→\tassert.Equal(t, \"script\", events[1].Type)\n   154→\tassert.Equal(t, \"compiling...\", events[1].Content)\n   155→}\n   156→\n   157→func TestSSE_RunNotFound(t *testing.T) {\n   158→\th, _, _ := setupHandlerWithBroadcaster(t)\n   159→\n   160→\treq := httptest.NewRequest(\"GET\", \"/api/runs/nonexistent/stream\", nil)\n   161→\tw := httptest.NewRecorder()\n   162→\th.ServeHTTP(w, req)\n   163→\n   164→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   165→}\n   166→\n   167→func TestSSE_NoBroadcaster_ActiveRun(t *testing.T) {\n   168→\tstore, err := sqlite.NewStore(\":memory:\")\n   169→\trequire.NoError(t, err)\n   170→\tdefer store.Close()\n   171→\n   172→\t// Handler without broadcaster\n   173→\th, err := NewHandler(store, store)\n   174→\trequire.NoError(t, err)\n   175→\n   176→\tctx := context.Background()\n   177→\trun := domain.NewRun(\"no-bc-1\", \"develop\")\n   178→\trun.Start()\n   179→\trun.ContainerID = \"abc123\"\n   180→\trequire.NoError(t, store.CreateRun(ctx, run))\n   181→\n   182→\treq := httptest.NewRequest(\"GET\", \"/api/runs/no-bc-1/stream\", nil)\n   183→\tw := httptest.NewRecorder()\n   184→\th.ServeHTTP(w, req)\n   185→\n   186→\tassert.Equal(t, http.StatusServiceUnavailable, w.Code)\n   187→}\n   188→\n   189→func TestParseFullLogLine(t *testing.T) {\n   190→\ttests := []struct {\n   191→\t\tinput    string\n   192→\t\texpected logstream.LogLine\n   193→\t}{\n   194→\t\t{\n   195→\t\t\tinput: \"[2026-03-03T10:15:00Z] [status] step_started: build\",\n   196→\t\t\texpected: logstream.LogLine{\n   197→\t\t\t\tTimestamp: \"2026-03-03T10:15:00Z\",\n   198→\t\t\t\tType:      \"status\",\n   199→\t\t\t\tContent:   \"step_started: build\",\n   200→\t\t\t},\n   201→\t\t},\n   202→\t\t{\n   203→\t\t\tinput: \"[2026-03-03T10:15:01Z] [script] npm run build\",\n   204→\t\t\texpected: logstream.LogLine{\n   205→\t\t\t\tTimestamp: \"2026-03-03T10:15:01Z\",\n   206→\t\t\t\tType:      \"script\",\n   207→\t\t\t\tContent:   \"npm run build\",\n   208→\t\t\t},\n   209→\t\t},\n   210→\t\t{\n   211→\t\t\tinput: \"[2026-03-03T10:15:02Z] [llm] Claude: Reading files...\",\n   212→\t\t\texpected: logstream.LogLine{\n   213→\t\t\t\tTimestamp: \"2026-03-03T10:15:02Z\",\n   214→\t\t\t\tType:      \"llm\",\n   215→\t\t\t\tContent:   \"Claude: Reading files...\",\n   216→\t\t\t},\n   217→\t\t},\n   218→\t\t{\n   219→\t\t\tinput: \"unstructured line\",\n   220→\t\t\texpected: logstream.LogLine{\n   221→\t\t\t\tType:    \"script\",\n   222→\t\t\t\tContent: \"unstructured line\",\n   223→\t\t\t},\n   224→\t\t},\n   225→\t}\n   226→\n   227→\tfor _, tt := range tests {\n   228→\t\tt.Run(tt.input, func(t *testing.T) {\n   229→\t\t\tresult := parseFullLogLine(tt.input)\n   230→\t\t\tassert.Equal(t, tt.expected.Type, result.Type)\n   231→\t\t\tassert.Equal(t, tt.expected.Content, result.Content)\n   232→\t\t\tif tt.expected.Timestamp != \"\" {\n   233→\t\t\t\tassert.Equal(t, tt.expected.Timestamp, result.Timestamp)\n   234→\t\t\t}\n   235→\t\t})\n   236→\t}\n   237→}\n   238→\n   239→func TestSSE_CompletedRun_LargeJSONLines(t *testing.T) {\n   240→\th, store, _ := setupHandlerWithBroadcaster(t)\n   241→\n   242→\tdir := t.TempDir()\n   243→\n   244→\tctx := context.Background()\n   245→\trun := domain.NewRun(\"sse-large-1\", \"develop\")\n   246→\trun.ProjectDir = dir\n   247→\trun.Start()\n   248→\trun.ContainerID = \"abc123\"\n   249→\trun.Complete(domain.RunStateSucceeded)\n   250→\trequire.NoError(t, store.CreateRun(ctx, run))\n   251→\n   252→\t// Build a large assistant event (>64KB) to simulate real Claude Code output.\n   253→\t// Default bufio.Scanner buffer is 64KB; this verifies we handle larger lines.\n   254→\tlargeText := strings.Repeat(\"x\", 100*1024) // 100KB of text\n   255→\tassistantJSON := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"` + largeText + `\"}]}}`\n   256→\n   257→\toutputDir := filepath.Join(dir, \".cloche\", \"sse-large-1\", \"output\")\n   258→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   259→\tlogContent := \"[2026-03-03T10:15:00Z] [status] step_started: build\\n\" +\n   260→\t\t\"[2026-03-03T10:15:01Z] [llm] \" + assistantJSON + \"\\n\" +\n   261→\t\t\"[2026-03-03T10:15:02Z] [status] step_completed: build -> success\\n\"\n   262→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"full.log\"), []byte(logContent), 0644))\n   263→\n   264→\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-large-1/stream\", nil)\n   265→\tw := httptest.NewRecorder()\n   266→\th.ServeHTTP(w, req)\n   267→\n   268→\tassert.Equal(t, http.StatusOK, w.Code)\n   269→\n   270→\tbody := w.Body.String()\n   271→\tvar events []logstream.LogLine\n   272→\tfor _, line := range strings.Split(body, \"\\n\") {\n   273→\t\tif strings.HasPrefix(line, \"data: \") {\n   274→\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n   275→\t\t\tvar ll logstream.LogLine\n   276→\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n   277→\t\t\t\tevents = append(events, ll)\n   278→\t\t\t}\n   279→\t\t}\n   280→\t}\n   281→\n   282→\t// All three lines should be present: status, llm (parsed from large JSON), status\n   283→\trequire.Len(t, events, 3, \"expected all log lines including those after large JSON line\")\n   284→\tassert.Equal(t, \"status\", events[0].Type)\n   285→\tassert.Equal(t, \"step_started: build\", events[0].Content)\n   286→\tassert.Equal(t, \"llm\", events[1].Type)\n   287→\tassert.Contains(t, events[1].Content, largeText)\n   288→\tassert.Equal(t, \"status\", events[2].Type)\n   289→\tassert.Equal(t, \"step_completed: build -> success\", events[2].Content)\n   290→\n   291→\tassert.Contains(t, body, \"event: done\")\n   292→}\n   293→\n   294→func TestSSE_CompletedRun_NoFullLog(t *testing.T) {\n   295→\th, store, _ := setupHandlerWithBroadcaster(t)\n   296→\n   297→\t// Create a completed run with no full.log\n   298→\tctx := context.Background()\n   299→\trun := domain.NewRun(\"sse-nolog-1\", \"develop\")\n   300→\trun.ProjectDir = t.TempDir()\n   301→\trun.Start()\n   302→\trun.ContainerID = \"abc123\"\n   303→\trun.Complete(domain.RunStateSucceeded)\n   304→\trequire.NoError(t, store.CreateRun(ctx, run))\n   305→\n   306→\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-nolog-1/stream\", nil)\n   307→\tw := httptest.NewRecorder()\n   308→\th.ServeHTTP(w, req)\n   309→\n   310→\tassert.Equal(t, http.StatusOK, w.Code)\n   311→\tassert.Contains(t, w.Body.String(), \"event: done\")\n   312→}\n   313→\n   314→// writeNLogLines creates a full.log with n visible log lines.\n   315→func writeNLogLines(t *testing.T, dir, runID string, n int) {\n   316→\tt.Helper()\n   317→\toutputDir := filepath.Join(dir, \".cloche\", runID, \"output\")\n   318→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   319→\n   320→\tvar b strings.Builder\n   321→\tfor i := 0; i < n; i++ {\n   322→\t\tfmt.Fprintf(&b, \"[2026-03-03T10:15:%02dZ] [script] line %d\\n\", i%60, i)\n   323→\t}\n   324→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"full.log\"), []byte(b.String()), 0644))\n   325→}\n   326→\n   327→func TestSSE_CompletedRun_TailsLast1000(t *testing.T) {\n   328→\th, store, _ := setupHandlerWithBroadcaster(t)\n   329→\tdir := t.TempDir()\n   330→\n   331→\tctx := context.Background()\n   332→\trun := domain.NewRun(\"sse-tail-1\", \"develop\")\n   333→\trun.ProjectDir = dir\n   334→\trun.Start()\n   335→\trun.ContainerID = \"abc123\"\n   336→\trun.Complete(domain.RunStateSucceeded)\n   337→\trequire.NoError(t, store.CreateRun(ctx, run))\n   338→\n   339→\t// Write 1500 log lines\n   340→\twriteNLogLines(t, dir, \"sse-tail-1\", 1500)\n   341→\n   342→\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-tail-1/stream\", nil)\n   343→\tw := httptest.NewRecorder()\n   344→\th.ServeHTTP(w, req)\n   345→\n   346→\tassert.Equal(t, http.StatusOK, w.Code)\n   347→\tbody := w.Body.String()\n   348→\n   349→\t// Parse events\n   350→\tvar events []logstream.LogLine\n   351→\tvar metaEvent map[string]int\n   352→\tfor _, line := range strings.Split(body, \"\\n\") {\n   353→\t\tif strings.HasPrefix(line, \"data: \") {\n   354→\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n   355→\t\t\t// Try as meta event (follows \"event: meta\")\n   356→\t\t\tvar meta map[string]int\n   357→\t\t\tif json.Unmarshal([]byte(data), &meta) == nil {\n   358→\t\t\t\tif _, ok := meta[\"total_lines\"]; ok {\n   359→\t\t\t\t\tmetaEvent = meta\n   360→\t\t\t\t\tcontinue\n   361→\t\t\t\t}\n   362→\t\t\t}\n   363→\t\t\tvar ll logstream.LogLine\n   364→\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n   365→\t\t\t\tevents = append(events, ll)\n   366→\t\t\t}\n   367→\t\t}\n   368→\t}\n   369→\n   370→\t// Should have meta event indicating skipped lines\n   371→\trequire.NotNil(t, metaEvent, \"expected meta SSE event\")\n   372→\tassert.Equal(t, 1500, metaEvent[\"total_lines\"])\n   373→\tassert.Equal(t, 500, metaEvent[\"skipped\"])\n   374→\n   375→\t// Should only have 1000 log events (the last 1000 of 1500)\n   376→\trequire.Len(t, events, 1000)\n   377→\t// First event should be line 500 (0-indexed)\n   378→\tassert.Equal(t, \"line 500\", events[0].Content)\n   379→\t// Last event should be line 1499\n   380→\tassert.Equal(t, \"line 1499\", events[999].Content)\n   381→}\n   382→\n   383→func TestSSE_CompletedRun_NoMetaWhenUnderLimit(t *testing.T) {\n   384→\th, store, _ := setupHandlerWithBroadcaster(t)\n   385→\tdir := t.TempDir()\n   386→\n   387→\tctx := context.Background()\n   388→\trun := domain.NewRun(\"sse-small-1\", \"develop\")\n   389→\trun.ProjectDir = dir\n   390→\trun.Start()\n   391→\trun.ContainerID = \"abc123\"\n   392→\trun.Complete(domain.RunStateSucceeded)\n   393→\trequire.NoError(t, store.CreateRun(ctx, run))\n   394→\n   395→\t// Write only 50 log lines (under the 1000 limit)\n   396→\twriteNLogLines(t, dir, \"sse-small-1\", 50)\n   397→\n   398→\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-small-1/stream\", nil)\n   399→\tw := httptest.NewRecorder()\n   400→\th.ServeHTTP(w, req)\n   401→\n   402→\tassert.Equal(t, http.StatusOK, w.Code)\n   403→\tbody := w.Body.String()\n   404→\n   405→\t// Should NOT contain meta event\n   406→\tassert.NotContains(t, body, \"event: meta\")\n   407→\n   408→\t// Should have all 50 lines\n   409→\tvar events []logstream.LogLine\n   410→\tfor _, line := range strings.Split(body, \"\\n\") {\n   411→\t\tif strings.HasPrefix(line, \"data: \") {\n   412→\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n   413→\t\t\tvar ll logstream.LogLine\n   414→\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n   415→\t\t\t\tevents = append(events, ll)\n   416→\t\t\t}\n   417→\t\t}\n   418→\t}\n   419→\tassert.Len(t, events, 50)\n   420→}\n   421→\n   422→func TestAPILogs_Pagination(t *testing.T) {\n   423→\th, store, _ := setupHandlerWithBroadcaster(t)\n   424→\tdir := t.TempDir()\n   425→\n   426→\tctx := context.Background()\n   427→\trun := domain.NewRun(\"logs-page-1\", \"develop\")\n   428→\trun.ProjectDir = dir\n   429→\trun.Start()\n   430→\trun.ContainerID = \"abc123\"\n   431→\trun.Complete(domain.RunStateSucceeded)\n   432→\trequire.NoError(t, store.CreateRun(ctx, run))\n   433→\n   434→\t// Write 2500 log lines\n   435→\twriteNLogLines(t, dir, \"logs-page-1\", 2500)\n   436→\n   437→\t// Request last 1000 lines (default)\n   438→\treq := httptest.NewRequest(\"GET\", \"/api/runs/logs-page-1/logs\", nil)\n   439→\tw := httptest.NewRecorder()\n   440→\th.ServeHTTP(w, req)\n   441→\n   442→\tassert.Equal(t, http.StatusOK, w.Code)\n   443→\n   444→\tvar resp struct {\n   445→\t\tLines []logstream.LogLine `json:\"lines\"`\n   446→\t\tTotal int                 `json:\"total\"`\n   447→\t\tStart int                 `json:\"start\"`\n   448→\t\tEnd   int                 `json:\"end\"`\n   449→\t}\n   450→\trequire.NoError(t, json.NewDecoder(w.Body).Decode(&resp))\n   451→\n   452→\tassert.Equal(t, 2500, resp.Total)\n   453→\tassert.Equal(t, 1500, resp.Start)\n   454→\tassert.Equal(t, 2500, resp.End)\n   455→\tassert.Len(t, resp.Lines, 1000)\n   456→\tassert.Equal(t, \"line 1500\", resp.Lines[0].Content)\n   457→\tassert.Equal(t, \"line 2499\", resp.Lines[999].Content)\n   458→}\n   459→\n   460→func TestAPILogs_PaginateEarlier(t *testing.T) {\n   461→\th, store, _ := setupHandlerWithBroadcaster(t)\n   462→\tdir := t.TempDir()\n   463→\n   464→\tctx := context.Background()\n   465→\trun := domain.NewRun(\"logs-page-2\", \"develop\")\n   466→\trun.ProjectDir = dir\n   467→\trun.Start()\n   468→\trun.ContainerID = \"abc123\"\n   469→\trun.Complete(domain.RunStateSucceeded)\n   470→\trequire.NoError(t, store.CreateRun(ctx, run))\n   471→\n   472→\t// Write 2500 log lines\n   473→\twriteNLogLines(t, dir, \"logs-page-2\", 2500)\n   474→\n   475→\t// Request earlier page: lines before index 1500, limit 1000\n   476→\treq := httptest.NewRequest(\"GET\", \"/api/runs/logs-page-2/logs?end=1500&limit=1000\", nil)\n   477→\tw := httptest.NewRecorder()\n   478→\th.ServeHTTP(w, req)\n   479→\n   480→\tassert.Equal(t, http.StatusOK, w.Code)\n   481→\n   482→\tvar resp struct {\n   483→\t\tLines []logstream.LogLine `json:\"lines\"`\n   484→\t\tTotal int                 `json:\"total\"`\n   485→\t\tStart int                 `json:\"start\"`\n   486→\t\tEnd   int                 `json:\"end\"`\n   487→\t}\n   488→\trequire.NoError(t, json.NewDecoder(w.Body).Decode(&resp))\n   489→\n   490→\tassert.Equal(t, 2500, resp.Total)\n   491→\tassert.Equal(t, 500, resp.Start)\n   492→\tassert.Equal(t, 1500, resp.End)\n   493→\tassert.Len(t, resp.Lines, 1000)\n   494→\tassert.Equal(t, \"line 500\", resp.Lines[0].Content)\n   495→\tassert.Equal(t, \"line 1499\", resp.Lines[999].Content)\n   496→}\n   497→\n   498→func TestAPILogs_FirstPage(t *testing.T) {\n   499→\th, store, _ := setupHandlerWithBroadcaster(t)\n   500→\tdir := t.TempDir()\n   501→\n   502→\tctx := context.Background()\n   503→\trun := domain.NewRun(\"logs-page-3\", \"develop\")\n   504→\trun.ProjectDir = dir\n   505→\trun.Start()\n   506→\trun.ContainerID = \"abc123\"\n   507→\trun.Complete(domain.RunStateSucceeded)\n   508→\trequire.NoError(t, store.CreateRun(ctx, run))\n   509→\n   510→\t// Write 2500 log lines\n   511→\twriteNLogLines(t, dir, \"logs-page-3\", 2500)\n   512→\n   513→\t// Request the very first page: end=500, limit=1000 — should clamp start to 0\n   514→\treq := httptest.NewRequest(\"GET\", \"/api/runs/logs-page-3/logs?end=500&limit=1000\", nil)\n   515→\tw := httptest.NewRecorder()\n   516→\th.ServeHTTP(w, req)\n   517→\n   518→\tvar resp struct {\n   519→\t\tLines []logstream.LogLine `json:\"lines\"`\n   520→\t\tTotal int                 `json:\"total\"`\n   521→\t\tStart int                 `json:\"start\"`\n   522→\t\tEnd   int                 `json:\"end\"`\n   523→\t}\n   524→\trequire.NoError(t, json.NewDecoder(w.Body).Decode(&resp))\n   525→\n   526→\tassert.Equal(t, 2500, resp.Total)\n   527→\tassert.Equal(t, 0, resp.Start)\n   528→\tassert.Equal(t, 500, resp.End)\n   529→\tassert.Len(t, resp.Lines, 500)\n   530→\tassert.Equal(t, \"line 0\", resp.Lines[0].Content)\n   531→}\n   532→\n   533→func TestAPILogs_RunNotFound(t *testing.T) {\n   534→\th, _, _ := setupHandlerWithBroadcaster(t)\n   535→\n   536→\treq := httptest.NewRequest(\"GET\", \"/api/runs/nonexistent/logs\", nil)\n   537→\tw := httptest.NewRecorder()\n   538→\th.ServeHTTP(w, req)\n   539→\n   540→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   541→}\n   542→\n   543→func TestAPILogs_NoLogFile(t *testing.T) {\n   544→\th, store, _ := setupHandlerWithBroadcaster(t)\n   545→\n   546→\tctx := context.Background()\n   547→\trun := domain.NewRun(\"logs-nolog-1\", \"develop\")\n   548→\trun.ProjectDir = t.TempDir()\n   549→\trun.Start()\n   550→\trun.ContainerID = \"abc123\"\n   551→\trun.Complete(domain.RunStateSucceeded)\n   552→\trequire.NoError(t, store.CreateRun(ctx, run))\n   553→\n   554→\treq := httptest.NewRequest(\"GET\", \"/api/runs/logs-nolog-1/logs\", nil)\n   555→\tw := httptest.NewRecorder()\n   556→\th.ServeHTTP(w, req)\n   557→\n   558→\tassert.Equal(t, http.StatusOK, w.Code)\n   559→\n   560→\tvar resp struct {\n   561→\t\tLines []logstream.LogLine `json:\"lines\"`\n   562→\t\tTotal int                 `json:\"total\"`\n   563→\t}\n   564→\trequire.NoError(t, json.NewDecoder(w.Body).Decode(&resp))\n   565→\tassert.Equal(t, 0, resp.Total)\n   566→\tassert.Empty(t, resp.Lines)\n   567→}\n   568→"}]},"parent_tool_use_id":null,"session_id":"4544fa8d-d9f6-4e57-8374-6a5c036ca271","uuid":"c7c30842-e59b-4807-aabf-7a036b3868fd","timestamp":"2026-03-18T18:18:57.486Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler_stream_test.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc setupHandlerWithBroadcaster(t *testing.T) (*Handler, *sqlite.Store, *logstream.Broadcaster) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\tb := logstream.NewBroadcaster()\n\th, err := NewHandler(store, store, WithLogBroadcaster(b))\n\trequire.NoError(t, err)\n\treturn h, store, b\n}\n\nfunc TestSSE_CompletedRun_ServesFullLog(t *testing.T) {\n\th, store, _ := setupHandlerWithBroadcaster(t)\n\n\tdir := t.TempDir()\n\n\t// Create a completed run\n\tctx := context.Background()\n\trun := domain.NewRun(\"sse-test-1\", \"develop\")\n\trun.ProjectDir = dir\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\t// Write full.log\n\toutputDir := filepath.Join(dir, \".cloche\", \"sse-test-1\", \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\tlogContent := \"[2026-03-03T10:15:00Z] [status] step_started: build\\n\" +\n\t\t\"[2026-03-03T10:15:01Z] [script] npm run build\\n\" +\n\t\t\"[2026-03-03T10:15:02Z] [llm] Claude: Starting analysis\\n\"\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"full.log\"), []byte(logContent), 0644))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-test-1/stream\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Equal(t, \"text/event-stream\", w.Header().Get(\"Content-Type\"))\n\n\t// Parse SSE events\n\tbody := w.Body.String()\n\tlines := strings.Split(body, \"\\n\")\n\n\tvar events []logstream.LogLine\n\tfor _, line := range lines {\n\t\tif strings.HasPrefix(line, \"data: \") {\n\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n\t\t\tvar ll logstream.LogLine\n\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n\t\t\t\tevents = append(events, ll)\n\t\t\t}\n\t\t}\n\t}\n\n\trequire.Len(t, events, 3)\n\tassert.Equal(t, \"status\", events[0].Type)\n\tassert.Equal(t, \"step_started: build\", events[0].Content)\n\tassert.Equal(t, \"script\", events[1].Type)\n\tassert.Equal(t, \"npm run build\", events[1].Content)\n\tassert.Equal(t, \"llm\", events[2].Type)\n\tassert.Equal(t, \"Claude: Starting analysis\", events[2].Content)\n\n\t// Should contain done event\n\tassert.Contains(t, body, \"event: done\")\n}\n\nfunc TestSSE_ActiveRun_StreamsLive(t *testing.T) {\n\th, store, b := setupHandlerWithBroadcaster(t)\n\n\t// Create a running run\n\tctx := context.Background()\n\trun := domain.NewRun(\"sse-live-1\", \"develop\")\n\trun.ProjectDir = t.TempDir()\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\t// Start a subscriber to simulate an active broadcast\n\tb.Subscribe(\"sse-live-1\")\n\n\t// Use a real HTTP server for streaming\n\tsrv := httptest.NewServer(h)\n\tdefer srv.Close()\n\n\t// Publish some lines in a goroutine\n\tgo func() {\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\tb.Publish(\"sse-live-1\", logstream.LogLine{\n\t\t\tTimestamp: \"2026-03-03T10:15:00Z\",\n\t\t\tType:      \"status\",\n\t\t\tContent:   \"step_started: build\",\n\t\t})\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\tb.Publish(\"sse-live-1\", logstream.LogLine{\n\t\t\tTimestamp: \"2026-03-03T10:15:01Z\",\n\t\t\tType:      \"script\",\n\t\t\tContent:   \"compiling...\",\n\t\t})\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\tb.Finish(\"sse-live-1\")\n\t}()\n\n\tresp, err := http.Get(srv.URL + \"/api/runs/sse-live-1/stream\")\n\trequire.NoError(t, err)\n\tdefer resp.Body.Close()\n\n\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n\tassert.Equal(t, \"text/event-stream\", resp.Header.Get(\"Content-Type\"))\n\n\tvar events []logstream.LogLine\n\tscanner := bufio.NewScanner(resp.Body)\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"data: \") {\n\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n\t\t\tvar ll logstream.LogLine\n\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n\t\t\t\tevents = append(events, ll)\n\t\t\t}\n\t\t}\n\t\tif strings.HasPrefix(line, \"event: done\") {\n\t\t\tbreak\n\t\t}\n\t}\n\n\trequire.Len(t, events, 2)\n\tassert.Equal(t, \"status\", events[0].Type)\n\tassert.Equal(t, \"step_started: build\", events[0].Content)\n\tassert.Equal(t, \"script\", events[1].Type)\n\tassert.Equal(t, \"compiling...\", events[1].Content)\n}\n\nfunc TestSSE_RunNotFound(t *testing.T) {\n\th, _, _ := setupHandlerWithBroadcaster(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/nonexistent/stream\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestSSE_NoBroadcaster_ActiveRun(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\t// Handler without broadcaster\n\th, err := NewHandler(store, store)\n\trequire.NoError(t, err)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"no-bc-1\", \"develop\")\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/no-bc-1/stream\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusServiceUnavailable, w.Code)\n}\n\nfunc TestParseFullLogLine(t *testing.T) {\n\ttests := []struct {\n\t\tinput    string\n\t\texpected logstream.LogLine\n\t}{\n\t\t{\n\t\t\tinput: \"[2026-03-03T10:15:00Z] [status] step_started: build\",\n\t\t\texpected: logstream.LogLine{\n\t\t\t\tTimestamp: \"2026-03-03T10:15:00Z\",\n\t\t\t\tType:      \"status\",\n\t\t\t\tContent:   \"step_started: build\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tinput: \"[2026-03-03T10:15:01Z] [script] npm run build\",\n\t\t\texpected: logstream.LogLine{\n\t\t\t\tTimestamp: \"2026-03-03T10:15:01Z\",\n\t\t\t\tType:      \"script\",\n\t\t\t\tContent:   \"npm run build\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tinput: \"[2026-03-03T10:15:02Z] [llm] Claude: Reading files...\",\n\t\t\texpected: logstream.LogLine{\n\t\t\t\tTimestamp: \"2026-03-03T10:15:02Z\",\n\t\t\t\tType:      \"llm\",\n\t\t\t\tContent:   \"Claude: Reading files...\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tinput: \"unstructured line\",\n\t\t\texpected: logstream.LogLine{\n\t\t\t\tType:    \"script\",\n\t\t\t\tContent: \"unstructured line\",\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.input, func(t *testing.T) {\n\t\t\tresult := parseFullLogLine(tt.input)\n\t\t\tassert.Equal(t, tt.expected.Type, result.Type)\n\t\t\tassert.Equal(t, tt.expected.Content, result.Content)\n\t\t\tif tt.expected.Timestamp != \"\" {\n\t\t\t\tassert.Equal(t, tt.expected.Timestamp, result.Timestamp)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestSSE_CompletedRun_LargeJSONLines(t *testing.T) {\n\th, store, _ := setupHandlerWithBroadcaster(t)\n\n\tdir := t.TempDir()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"sse-large-1\", \"develop\")\n\trun.ProjectDir = dir\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\t// Build a large assistant event (>64KB) to simulate real Claude Code output.\n\t// Default bufio.Scanner buffer is 64KB; this verifies we handle larger lines.\n\tlargeText := strings.Repeat(\"x\", 100*1024) // 100KB of text\n\tassistantJSON := `{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"` + largeText + `\"}]}}`\n\n\toutputDir := filepath.Join(dir, \".cloche\", \"sse-large-1\", \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\tlogContent := \"[2026-03-03T10:15:00Z] [status] step_started: build\\n\" +\n\t\t\"[2026-03-03T10:15:01Z] [llm] \" + assistantJSON + \"\\n\" +\n\t\t\"[2026-03-03T10:15:02Z] [status] step_completed: build -> success\\n\"\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"full.log\"), []byte(logContent), 0644))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-large-1/stream\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tbody := w.Body.String()\n\tvar events []logstream.LogLine\n\tfor _, line := range strings.Split(body, \"\\n\") {\n\t\tif strings.HasPrefix(line, \"data: \") {\n\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n\t\t\tvar ll logstream.LogLine\n\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n\t\t\t\tevents = append(events, ll)\n\t\t\t}\n\t\t}\n\t}\n\n\t// All three lines should be present: status, llm (parsed from large JSON), status\n\trequire.Len(t, events, 3, \"expected all log lines including those after large JSON line\")\n\tassert.Equal(t, \"status\", events[0].Type)\n\tassert.Equal(t, \"step_started: build\", events[0].Content)\n\tassert.Equal(t, \"llm\", events[1].Type)\n\tassert.Contains(t, events[1].Content, largeText)\n\tassert.Equal(t, \"status\", events[2].Type)\n\tassert.Equal(t, \"step_completed: build -> success\", events[2].Content)\n\n\tassert.Contains(t, body, \"event: done\")\n}\n\nfunc TestSSE_CompletedRun_NoFullLog(t *testing.T) {\n\th, store, _ := setupHandlerWithBroadcaster(t)\n\n\t// Create a completed run with no full.log\n\tctx := context.Background()\n\trun := domain.NewRun(\"sse-nolog-1\", \"develop\")\n\trun.ProjectDir = t.TempDir()\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-nolog-1/stream\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"event: done\")\n}\n\n// writeNLogLines creates a full.log with n visible log lines.\nfunc writeNLogLines(t *testing.T, dir, runID string, n int) {\n\tt.Helper()\n\toutputDir := filepath.Join(dir, \".cloche\", runID, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\tvar b strings.Builder\n\tfor i := 0; i < n; i++ {\n\t\tfmt.Fprintf(&b, \"[2026-03-03T10:15:%02dZ] [script] line %d\\n\", i%60, i)\n\t}\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"full.log\"), []byte(b.String()), 0644))\n}\n\nfunc TestSSE_CompletedRun_TailsLast1000(t *testing.T) {\n\th, store, _ := setupHandlerWithBroadcaster(t)\n\tdir := t.TempDir()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"sse-tail-1\", \"develop\")\n\trun.ProjectDir = dir\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\t// Write 1500 log lines\n\twriteNLogLines(t, dir, \"sse-tail-1\", 1500)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-tail-1/stream\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\n\t// Parse events\n\tvar events []logstream.LogLine\n\tvar metaEvent map[string]int\n\tfor _, line := range strings.Split(body, \"\\n\") {\n\t\tif strings.HasPrefix(line, \"data: \") {\n\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n\t\t\t// Try as meta event (follows \"event: meta\")\n\t\t\tvar meta map[string]int\n\t\t\tif json.Unmarshal([]byte(data), &meta) == nil {\n\t\t\t\tif _, ok := meta[\"total_lines\"]; ok {\n\t\t\t\t\tmetaEvent = meta\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\t\t\tvar ll logstream.LogLine\n\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n\t\t\t\tevents = append(events, ll)\n\t\t\t}\n\t\t}\n\t}\n\n\t// Should have meta event indicating skipped lines\n\trequire.NotNil(t, metaEvent, \"expected meta SSE event\")\n\tassert.Equal(t, 1500, metaEvent[\"total_lines\"])\n\tassert.Equal(t, 500, metaEvent[\"skipped\"])\n\n\t// Should only have 1000 log events (the last 1000 of 1500)\n\trequire.Len(t, events, 1000)\n\t// First event should be line 500 (0-indexed)\n\tassert.Equal(t, \"line 500\", events[0].Content)\n\t// Last event should be line 1499\n\tassert.Equal(t, \"line 1499\", events[999].Content)\n}\n\nfunc TestSSE_CompletedRun_NoMetaWhenUnderLimit(t *testing.T) {\n\th, store, _ := setupHandlerWithBroadcaster(t)\n\tdir := t.TempDir()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"sse-small-1\", \"develop\")\n\trun.ProjectDir = dir\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\t// Write only 50 log lines (under the 1000 limit)\n\twriteNLogLines(t, dir, \"sse-small-1\", 50)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-small-1/stream\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\n\t// Should NOT contain meta event\n\tassert.NotContains(t, body, \"event: meta\")\n\n\t// Should have all 50 lines\n\tvar events []logstream.LogLine\n\tfor _, line := range strings.Split(body, \"\\n\") {\n\t\tif strings.HasPrefix(line, \"data: \") {\n\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n\t\t\tvar ll logstream.LogLine\n\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n\t\t\t\tevents = append(events, ll)\n\t\t\t}\n\t\t}\n\t}\n\tassert.Len(t, events, 50)\n}\n\nfunc TestAPILogs_Pagination(t *testing.T) {\n\th, store, _ := setupHandlerWithBroadcaster(t)\n\tdir := t.TempDir()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"logs-page-1\", \"develop\")\n\trun.ProjectDir = dir\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\t// Write 2500 log lines\n\twriteNLogLines(t, dir, \"logs-page-1\", 2500)\n\n\t// Request last 1000 lines (default)\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/logs-page-1/logs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp struct {\n\t\tLines []logstream.LogLine `json:\"lines\"`\n\t\tTotal int                 `json:\"total\"`\n\t\tStart int                 `json:\"start\"`\n\t\tEnd   int                 `json:\"end\"`\n\t}\n\trequire.NoError(t, json.NewDecoder(w.Body).Decode(&resp))\n\n\tassert.Equal(t, 2500, resp.Total)\n\tassert.Equal(t, 1500, resp.Start)\n\tassert.Equal(t, 2500, resp.End)\n\tassert.Len(t, resp.Lines, 1000)\n\tassert.Equal(t, \"line 1500\", resp.Lines[0].Content)\n\tassert.Equal(t, \"line 2499\", resp.Lines[999].Content)\n}\n\nfunc TestAPILogs_PaginateEarlier(t *testing.T) {\n\th, store, _ := setupHandlerWithBroadcaster(t)\n\tdir := t.TempDir()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"logs-page-2\", \"develop\")\n\trun.ProjectDir = dir\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\t// Write 2500 log lines\n\twriteNLogLines(t, dir, \"logs-page-2\", 2500)\n\n\t// Request earlier page: lines before index 1500, limit 1000\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/logs-page-2/logs?end=1500&limit=1000\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp struct {\n\t\tLines []logstream.LogLine `json:\"lines\"`\n\t\tTotal int                 `json:\"total\"`\n\t\tStart int                 `json:\"start\"`\n\t\tEnd   int                 `json:\"end\"`\n\t}\n\trequire.NoError(t, json.NewDecoder(w.Body).Decode(&resp))\n\n\tassert.Equal(t, 2500, resp.Total)\n\tassert.Equal(t, 500, resp.Start)\n\tassert.Equal(t, 1500, resp.End)\n\tassert.Len(t, resp.Lines, 1000)\n\tassert.Equal(t, \"line 500\", resp.Lines[0].Content)\n\tassert.Equal(t, \"line 1499\", resp.Lines[999].Content)\n}\n\nfunc TestAPILogs_FirstPage(t *testing.T) {\n\th, store, _ := setupHandlerWithBroadcaster(t)\n\tdir := t.TempDir()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"logs-page-3\", \"develop\")\n\trun.ProjectDir = dir\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\t// Write 2500 log lines\n\twriteNLogLines(t, dir, \"logs-page-3\", 2500)\n\n\t// Request the very first page: end=500, limit=1000 — should clamp start to 0\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/logs-page-3/logs?end=500&limit=1000\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tvar resp struct {\n\t\tLines []logstream.LogLine `json:\"lines\"`\n\t\tTotal int                 `json:\"total\"`\n\t\tStart int                 `json:\"start\"`\n\t\tEnd   int                 `json:\"end\"`\n\t}\n\trequire.NoError(t, json.NewDecoder(w.Body).Decode(&resp))\n\n\tassert.Equal(t, 2500, resp.Total)\n\tassert.Equal(t, 0, resp.Start)\n\tassert.Equal(t, 500, resp.End)\n\tassert.Len(t, resp.Lines, 500)\n\tassert.Equal(t, \"line 0\", resp.Lines[0].Content)\n}\n\nfunc TestAPILogs_RunNotFound(t *testing.T) {\n\th, _, _ := setupHandlerWithBroadcaster(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/nonexistent/logs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPILogs_NoLogFile(t *testing.T) {\n\th, store, _ := setupHandlerWithBroadcaster(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"logs-nolog-1\", \"develop\")\n\trun.ProjectDir = t.TempDir()\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/logs-nolog-1/logs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp struct {\n\t\tLines []logstream.LogLine `json:\"lines\"`\n\t\tTotal int                 `json:\"total\"`\n\t}\n\trequire.NoError(t, json.NewDecoder(w.Body).Decode(&resp))\n\tassert.Equal(t, 0, resp.Total)\n\tassert.Empty(t, resp.Lines)\n}\n","numLines":568,"startLine":1,"totalLines":568}}}
