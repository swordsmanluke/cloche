ath":"/workspace/internal/adapters/web/templates/projects.html","content":"{{define \"content\"}}\n<h1>Projects</h1>\n{{if .Projects}}\n<div class=\"project-cards\">\n    {{range .Projects}}\n    <div class=\"project-card\">\n        <div class=\"project-header\">\n            <span class=\"health-dot health-{{healthColor .Health.Status}}\" title=\"{{.Health.Status}}\"></span>\n            <a href=\"/projects/{{.Label}}\" class=\"project-name\">{{.Label}}</a>\n        </div>\n        <div class=\"project-stats\">\n            <div class=\"stat\">\n                <span class=\"stat-value\">{{.Health.Passed}}/{{.Health.Total}}</span>\n                <span class=\"stat-label\">recent passed</span>\n            </div>\n            <div class=\"stat\">\n                <span class=\"stat-value\">{{.ActiveCount}}</span>\n                <span class=\"stat-label\">active</span>\n            </div>\n        </div>\n        <div class=\"run-history\">\n            {{range .RecentRuns}}\n            <span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span>\n            {{end}}\n        </div>\n        <div class=\"project-actions\">\n            <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary\">View Runs</a>\n        </div>\n    </div>\n    {{end}}\n</div>\n{{else}}\n<p class=\"empty\">No projects yet. Start a workflow run to see projects here.</p>\n{{end}}\n{{end}}\n\n{{define \"scripts\"}}\n{{end}}\n","numLines":39,"startLine":1,"totalLines":39}}}
