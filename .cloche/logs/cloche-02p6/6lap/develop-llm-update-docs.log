{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RM8JVYegPirUNKFeAwi9Xp","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1>\n     3→    <a href=\"/runs\">Runs</a> /\n     4→    {{if .ParentRun}}<a href=\"/runs/{{.ParentRun.ID}}\" class=\"parent-run-link\">{{.ParentRun.ID}}</a> / {{end}}\n     5→    {{.Run.ID}}\n     6→    <span class=\"badge badge-{{stateColor .Run.State}}\">{{.Run.State}}</span>\n     7→    {{if or (eq .Run.State \"pending\") (eq .Run.State \"running\")}}\n     8→    <button class=\"btn btn-danger btn-sm\" id=\"cancel-run-btn\" onclick=\"cancelRun('{{.Run.ID}}')\" style=\"margin-left:0.5rem;\">Cancel</button>\n     9→    {{end}}\n    10→</h1>\n    11→\n    12→<div class=\"run-meta\">\n    13→    <dl>\n    14→        {{if .Run.Title}}<dt>Title</dt><dd>{{.Run.Title}}</dd>{{end}}\n    15→        {{if .ParentRun}}<dt>Parent Run</dt><dd><a href=\"/runs/{{.ParentRun.ID}}\">{{.ParentRun.ID}}</a> <span class=\"badge badge-{{stateColor .ParentRun.State}}\">{{.ParentRun.State}}</span></dd>{{end}}\n    16→        <dt>Workflow</dt><dd>{{.Run.WorkflowName}}</dd>\n    17→        <dt>Type</dt><dd>{{if .Run.IsHost}}host{{else}}container{{end}}</dd>\n    18→        <dt>Started</dt><dd>{{formatTime .Run.StartedAt}}</dd>\n    19→        <dt>Completed</dt><dd>{{formatTime .Run.CompletedAt}}</dd>\n    20→        <dt>Container</dt><dd class=\"mono\">{{.Run.ContainerID}}</dd>\n    21→        <dt>Container Status</dt>\n    22→        <dd id=\"container-status\">\n    23→            {{if eq .ContainerState \"running\"}}\n    24→                <span class=\"badge badge-running\">Container running</span>\n    25→            {{else if eq .ContainerState \"stopped\"}}\n    26→                <span class=\"badge badge-stopped\">Container stopped</span>\n    27→                {{if or (eq .Run.State \"succeeded\") (eq .Run.State \"failed\") (eq .Run.State \"cancelled\")}}\n    28→                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n    29→                {{end}}\n    30→            {{else if eq .ContainerState \"available\"}}\n    31→                <span class=\"badge badge-succeeded\">Container available</span>\n    32→                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n    33→            {{else}}\n    34→                <span class=\"badge badge-pending\">Container removed</span>\n    35→            {{end}}\n    36→        </dd>\n    37→    </dl>\n    38→</div>\n    39→\n    40→{{if .Run.ErrorMessage}}\n    41→<div class=\"error-box\">{{.Run.ErrorMessage}}</div>\n    42→{{end}}\n    43→\n    44→{{if .ChildRuns}}\n    45→<h2>Child Runs</h2>\n    46→<table class=\"runs-table\">\n    47→    <thead>\n    48→        <tr>\n    49→            <th>Run ID</th>\n    50→            <th>Title</th>\n    51→            <th>Workflow</th>\n    52→            <th>State</th>\n    53→            <th>Started</th>\n    54→            <th>Completed</th>\n    55→        </tr>\n    56→    </thead>\n    57→    <tbody>\n    58→        {{range .ChildRuns}}\n    59→        <tr>\n    60→            <td><a href=\"/runs/{{.ID}}\">{{.ID}}</a></td>\n    61→            <td>{{truncate .Title 50}}</td>\n    62→            <td>{{.WorkflowName}}</td>\n    63→            <td><span class=\"badge badge-{{stateColor .State}}\">{{.State}}</span></td>\n    64→            <td>{{formatTime .StartedAt}}</td>\n    65→            <td>{{formatTime .CompletedAt}}</td>\n    66→        </tr>\n    67→        {{end}}\n    68→    </tbody>\n    69→</table>\n    70→{{end}}\n    71→\n    72→<h2>Steps</h2>\n    73→<table class=\"runs-table\">\n    74→    <thead>\n    75→        <tr>\n    76→            <th>Step</th>\n    77→            <th>Result</th>\n    78→            <th>Started</th>\n    79→            <th>Duration</th>\n    80→        </tr>\n    81→    </thead>\n    82→    <tbody id=\"steps-body\">\n    83→    {{if .Steps}}\n    84→        {{range .Steps}}\n    85→        <tr class=\"step-row\" data-run-id=\"{{$.Run.ID}}\" data-step=\"{{.StepName}}\" data-index=\"{{.Index}}\">\n    86→            <td>{{.StepName}}</td>\n    87→            <td>{{if .Result}}<span class=\"badge badge-{{if eq .Result \"success\"}}succeeded{{else if eq .Result \"fail\"}}failed{{else}}pending{{end}}\">{{.Result}}</span>{{else}}<span class=\"badge badge-running\">running</span>{{end}}</td>\n    88→            <td>{{formatTime .StartedAt}}</td>\n    89→            <td>{{.Duration}}</td>\n    90→        </tr>\n    91→        <tr class=\"output-row\" id=\"output-{{.Index}}\" style=\"display:none\">\n    92→            <td colspan=\"4\"><div class=\"step-log-viewer\"><pre class=\"step-output\" data-step=\"{{.StepName}}\"></pre></div></td>\n    93→        </tr>\n    94→        {{end}}\n    95→    {{else}}\n    96→        <tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>\n    97→    {{end}}\n    98→    </tbody>\n    99→</table>\n   100→\n   101→<h2>\n   102→    Log\n   103→    <span id=\"log-status\" class=\"badge badge-running\" style=\"font-size:0.7rem; margin-left:0.5rem;\">Live</span>\n   104→</h2>\n   105→<div id=\"log-viewer\" class=\"log-viewer\">\n   106→    <button id=\"load-earlier-btn\" class=\"load-earlier-btn\" style=\"display:none\" onclick=\"loadEarlierLogs()\">Load earlier (<span id=\"load-earlier-count\">0</span> more lines)</button>\n   107→    <pre id=\"log-content\"></pre>\n   108→</div>\n   109→{{end}}\n   110→\n   111→{{define \"scripts\"}}\n   112→<script>\n   113→(function() {\n   114→    var runState = '{{.Run.State}}';\n   115→    var runID = '{{.Run.ID}}';\n   116→\n   117→    // --- Log Viewer ---\n   118→    var logContent = document.getElementById('log-content');\n   119→    var logViewer = document.getElementById('log-viewer');\n   120→    var logStatus = document.getElementById('log-status');\n   121→    var loadEarlierBtn = document.getElementById('load-earlier-btn');\n   122→    var loadEarlierCount = document.getElementById('load-earlier-count');\n   123→    var skippedLines = 0;\n   124→\n   125→    // Per-step log line buffers: stepName -> [line, ...]\n   126→    var stepLogBuffers = {};\n   127→\n   128→    function appendToElement(container, pre, line) {\n   129→        var span = document.createElement('span');\n   130→        span.className = 'log-line log-type-' + (line.type || 'script');\n   131→        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';\n   132→\n   133→        var savedScrollTop = container.scrollTop;\n   134→        var atBottom = container.scrollHeight - savedScrollTop - container.clientHeight < 40;\n   135→\n   136→        pre.appendChild(span);\n   137→\n   138→        if (atBottom) {\n   139→            container.scrollTop = container.scrollHeight;\n   140→        } else {\n   141→            container.scrollTop = savedScrollTop;\n   142→        }\n   143→    }\n   144→\n   145→    function appendLogLine(line) {\n   146→        appendToElement(logViewer, logContent, line);\n   147→\n   148→        // Buffer and route to per-step accordion\n   149→        if (line.step_name) {\n   150→            if (!stepLogBuffers[line.step_name]) {\n   151→                stepLogBuffers[line.step_name] = [];\n   152→            }\n   153→            stepLogBuffers[line.step_name].push(line);\n   154→\n   155→            // If the step's accordion pre is visible, append live\n   156→            var pres = document.querySelectorAll('.step-output[data-step=\"' + line.step_name + '\"]');\n   157→            for (var i = 0; i < pres.length; i++) {\n   158→                var pre = pres[i];\n   159→                var viewer = pre.closest('.step-log-viewer');\n   160→                if (viewer && pre.closest('.output-row').style.display !== 'none') {\n   161→                    appendToElement(viewer, pre, line);\n   162→                }\n   163→            }\n   164→        }\n   165→    }\n   166→\n   167→    function markComplete() {\n   168→        logStatus.textContent = 'Complete';\n   169→        logStatus.className = 'badge badge-succeeded';\n   170→    }\n   171→\n   172→    // Connect to SSE stream\n   173→    var source = new EventSource('/api/runs/' + runID + '/stream');\n   174→    source.onmessage = function(e) {\n   175→        try {\n   176→            var line = JSON.parse(e.data);\n   177→            appendLogLine(line);\n   178→        } catch(err) {}\n   179→    };\n   180→    source.addEventListener('meta', function(e) {\n   181→        try {\n   182→            var meta = JSON.parse(e.data);\n   183→            skippedLines = meta.skipped || 0;\n   184→            if (skippedLines > 0) {\n   185→                loadEarlierCount.textContent = skippedLines;\n   186→                loadEarlierBtn.style.display = '';\n   187→            }\n   188→        } catch(err) {}\n   189→    });\n   190→    source.addEventListener('done', function(e) {\n   191→        markComplete();\n   192→        source.close();\n   193→    });\n   194→    source.onerror = function() {\n   195→        markComplete();\n   196→        source.close();\n   197→    };\n   198→\n   199→    // If already complete, mark the badge immediately\n   200→    if (runState === 'succeeded' || runState === 'failed' || runState === 'cancelled') {\n   201→        logStatus.textContent = 'Complete';\n   202→        logStatus.className = 'badge badge-succeeded';\n   203→    }\n   204→\n   205→    // --- Steps Polling (for active runs) ---\n   206→    if (runState !== 'succeeded' && runState !== 'failed' && runState !== 'cancelled') {\n   207→        function poll() {\n   208→            fetch('/api/runs/' + runID)\n   209→                .then(function(r) { return r.json(); })\n   210→                .then(function(data) {\n   211→                    if (data.state !== runState) {\n   212→                        location.reload();\n   213→                        return;\n   214→                    }\n   215→                    // Update container status\n   216→                    var statusEl = document.getElementById('container-status');\n   217→                    if (statusEl && data.container_state) {\n   218→                        var cs = data.container_state;\n   219→                        if (cs === 'running') {\n   220→                            statusEl.innerHTML = '<span class=\"badge badge-running\">Container running</span>';\n   221→                        } else if (cs === 'stopped') {\n   222→                            var stoppedHtml = '<span class=\"badge badge-stopped\">Container stopped</span>';\n   223→                            if (data.state === 'succeeded' || data.state === 'failed' || data.state === 'cancelled') {\n   224→                                stoppedHtml += ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n   225→                            }\n   226→                            statusEl.innerHTML = stoppedHtml;\n   227→                        } else if (cs === 'available') {\n   228→                            statusEl.innerHTML = '<span class=\"badge badge-succeeded\">Container available</span>' +\n   229→                                ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n   230→                        } else {\n   231→                            statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n   232→                        }\n   233→                    }\n   234→                    var tbody = document.getElementById('steps-body');\n   235→                    if (!data.steps || data.steps.length === 0) {\n   236→                        tbody.innerHTML = '<tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>';\n   237→                        return;\n   238→                    }\n   239→\n   240→                    // Capture current accordion state before updating\n   241→                    var openAccordions = {};\n   242→                    var loadedOutputs = {};\n   243→                    var outputRows = tbody.querySelectorAll('.output-row');\n   244→                    for (var j = 0; j < outputRows.length; j++) {\n   245→                        var id = outputRows[j].id;\n   246→                        if (outputRows[j].style.display !== 'none') {\n   247→                            openAccordions[id] = true;\n   248→                        }\n   249→                        var pre = outputRows[j].querySelector('.step-output');\n   250→                        if (pre && pre.childNodes.length > 0) {\n   251→                            loadedOutputs[id] = pre.innerHTML;\n   252→                        }\n   253→                    }\n   254→\n   255→                    // Build updated step rows, preserving accordion state\n   256→                    var html = '';\n   257→                    for (var i = 0; i < data.steps.length; i++) {\n   258→                        var s = data.steps[i];\n   259→                        var badge = '';\n   260→                        if (s.result) {\n   261→                            var cls = s.result === 'success' ? 'succeeded' : s.result === 'fail' ? 'failed' : 'pending';\n   262→                            badge = '<span class=\"badge badge-' + cls + '\">' + escapeHtml(s.result) + '</span>';\n   263→                        } else {\n   264→                            badge = '<span class=\"badge badge-running\">running</span>';\n   265→                        }\n   266→                        var outputId = 'output-' + i;\n   267→                        var isOpen = openAccordions[outputId];\n   268→                        html += '<tr class=\"step-row\" data-run-id=\"' + escapeHtml(runID) + '\" data-step=\"' + escapeHtml(s.step_name) + '\" data-index=\"' + i + '\">' +\n   269→                            '<td>' + escapeHtml(s.step_name) + '</td>' +\n   270→                            '<td>' + badge + '</td>' +\n   271→                            '<td>' + s.started_at + '</td>' +\n   272→                            '<td>' + s.duration + '</td>' +\n   273→                            '</tr>' +\n   274→                            '<tr class=\"output-row\" id=\"' + outputId + '\"' + (isOpen ? '' : ' style=\"display:none\"') + '>' +\n   275→                            '<td colspan=\"4\"><div class=\"step-log-viewer\"><pre class=\"step-output\" data-step=\"' + escapeHtml(s.step_name) + '\"></pre></div></td>' +\n   276→                            '</tr>';\n   277→                    }\n   278→                    tbody.innerHTML = html;\n   279→\n   280→                    // Restore loaded output content for open accordions\n   281→                    for (var key in loadedOutputs) {\n   282→                        var row = document.getElementById(key);\n   283→                        if (row) {\n   284→                            var pre = row.querySelector('.step-output');\n   285→                            if (pre) {\n   286→                                pre.innerHTML = loadedOutputs[key];\n   287→                            }\n   288→                        }\n   289→                    }\n   290→\n   291→                    // Re-populate open accordions from step log buffers or fetch\n   292→                    for (var key in openAccordions) {\n   293→                        if (!loadedOutputs[key]) {\n   294→                            var row = document.getElementById(key);\n   295→                            if (row) {\n   296→                                var stepRow = row.previousElementSibling;\n   297→                                if (stepRow && stepRow.dataset.runId && stepRow.dataset.step) {\n   298→                                    (function(r, rid, sname) {\n   299→                                        var pre = r.querySelector('.step-output');\n   300→                                        var viewer = pre.closest('.step-log-viewer');\n   301→                                        var buf = stepLogBuffers[sname];\n   302→                                        if (buf && buf.length > 0) {\n   303→                                            for (var k = 0; k < buf.length; k++) {\n   304→                                                appendToElement(viewer, pre, buf[k]);\n   305→                                            }\n   306→                                        } else {\n   307→                                            fetch('/api/runs/' + rid + '/steps/' + sname + '/output')\n   308→                                                .then(function(resp) {\n   309→                                                    if (!resp.ok) return 'No output available.';\n   310→                                                    return resp.text();\n   311→                                                })\n   312→                                                .then(function(text) { pre.textContent = text; })\n   313→                                                .catch(function() { pre.textContent = 'Failed to load output.'; });\n   314→                                        }\n   315→                                    })(row, stepRow.dataset.runId, stepRow.dataset.step);\n   316→                                }\n   317→                            }\n   318→                        }\n   319→                    }\n   320→                })\n   321→                .catch(function() {});\n   322→        }\n   323→        setInterval(poll, 2000);\n   324→    }\n   325→\n   326→    function escapeHtml(s) {\n   327→        if (!s) return '';\n   328→        var d = document.createElement('div');\n   329→        d.appendChild(document.createTextNode(s));\n   330→        return d.innerHTML;\n   331→    }\n   332→})();\n   333→\n   334→// Load earlier log lines\n   335→    window.loadEarlierLogs = function() {\n   336→        var btn = document.getElementById('load-earlier-btn');\n   337→        var countEl = document.getElementById('load-earlier-count');\n   338→        btn.disabled = true;\n   339→        var prevText = btn.textContent;\n   340→        btn.textContent = 'Loading...';\n   341→\n   342→        var limit = 1000;\n   343→        var end = skippedLines;\n   344→\n   345→        fetch('/api/runs/' + runID + '/logs?end=' + end + '&limit=' + limit)\n   346→            .then(function(r) { return r.json(); })\n   347→            .then(function(data) {\n   348→                if (data.lines && data.lines.length > 0) {\n   349→                    var fragment = document.createDocumentFragment();\n   350→                    for (var i = 0; i < data.lines.length; i++) {\n   351→                        var line = data.lines[i];\n   352→                        var span = document.createElement('span');\n   353→                        span.className = 'log-line log-type-' + (line.type || 'script');\n   354→                        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';\n   355→                        fragment.appendChild(span);\n   356→                    }\n   357→                    // Preserve scroll position relative to existing content\n   358→                    var prevScrollHeight = logViewer.scrollHeight;\n   359→                    logContent.insertBefore(fragment, logContent.firstChild);\n   360→                    logViewer.scrollTop += logViewer.scrollHeight - prevScrollHeight;\n   361→                }\n   362→\n   363→                skippedLines = data.start || 0;\n   364→                if (skippedLines > 0) {\n   365→                    btn.disabled = false;\n   366→                    countEl.textContent = skippedLines;\n   367→                    btn.textContent = '';\n   368→                    btn.appendChild(document.createTextNode('Load earlier ('));\n   369→                    btn.appendChild(countEl);\n   370→                    btn.appendChild(document.createTextNode(' more lines)'));\n   371→                } else {\n   372→                    btn.style.display = 'none';\n   373→                }\n   374→            })\n   375→            .catch(function() {\n   376→                btn.disabled = false;\n   377→                btn.textContent = prevText;\n   378→            });\n   379→    };\n   380→\n   381→// Cancel run\n   382→    window.cancelRun = function(runID) {\n   383→        var btn = document.getElementById('cancel-run-btn');\n   384→        if (btn) btn.disabled = true;\n   385→        fetch('/api/runs/' + runID + '/stop', { method: 'POST' })\n   386→            .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })\n   387→            .then(function(res) {\n   388→                if (res.ok) {\n   389→                    location.reload();\n   390→                } else {\n   391→                    if (btn) btn.disabled = false;\n   392→                    alert('Failed to cancel run: ' + (res.data.error || 'unknown error'));\n   393→                }\n   394→            })\n   395→            .catch(function() {\n   396→                if (btn) btn.disabled = false;\n   397→                alert('Failed to cancel run');\n   398→            });\n   399→    };\n   400→\n   401→// Delete container\n   402→    window.deleteContainer = function(runID) {\n   403→        var btn = document.getElementById('delete-container-btn');\n   404→        if (btn) btn.disabled = true;\n   405→        fetch('/api/runs/' + runID + '/container', { method: 'DELETE' })\n   406→            .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })\n   407→            .then(function(res) {\n   408→                var statusEl = document.getElementById('container-status');\n   409→                if (res.ok) {\n   410→                    statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n   411→                } else {\n   412→                    if (btn) btn.disabled = false;\n   413→                    alert('Failed to delete container: ' + (res.data.error || 'unknown error'));\n   414→                }\n   415→            })\n   416→            .catch(function() {\n   417→                if (btn) btn.disabled = false;\n   418→                alert('Failed to delete container');\n   419→            });\n   420→    };\n   421→\n   422→    // Toggle step output rows\n   423→document.addEventListener('click', function(e) {\n   424→    var row = e.target.closest('.step-row');\n   425→    if (!row) return;\n   426→    var idx = row.dataset.index;\n   427→    var outputRow = document.getElementById('output-' + idx);\n   428→    if (!outputRow) return;\n   429→\n   430→    if (outputRow.style.display === 'none') {\n   431→        outputRow.style.display = '';\n   432→        var pre = outputRow.querySelector('.step-output');\n   433→        var stepName = row.dataset.step;\n   434→        var viewer = pre.closest('.step-log-viewer');\n   435→        if (pre.childNodes.length === 0) {\n   436→            // Populate from buffered live lines first\n   437→            var buf = stepLogBuffers[stepName];\n   438→            if (buf && buf.length > 0) {\n   439→                for (var k = 0; k < buf.length; k++) {\n   440→                    appendToElement(viewer, pre, buf[k]);\n   441→                }\n   442→            } else {\n   443→                // No live buffer — fetch from server (completed step)\n   444→                var runId = row.dataset.runId;\n   445→                fetch('/api/runs/' + runId + '/steps/' + stepName + '/output')\n   446→                    .then(function(r) {\n   447→                        if (!r.ok) return 'No output available.';\n   448→                        return r.text();\n   449→                    })\n   450→                    .then(function(text) { pre.textContent = text; })\n   451→                    .catch(function() { pre.textContent = 'Failed to load output.'; });\n   452→            }\n   453→        }\n   454→        if (viewer) viewer.scrollTop = viewer.scrollHeight;\n   455→    } else {\n   456→        outputRow.style.display = 'none';\n   457→    }\n   458→});\n   459→</script>\n   460→{{end}}\n   461→"}]},"parent_tool_use_id":null,"session_id":"c9422457-54f2-4814-b03e-0a0106badb69","uuid":"78074e52-a906-4c03-876a-bd00e348b9de","timestamp":"2026-03-18T19:07:37.114Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/run_detail.html","content":"{{define \"content\"}}\n<h1>\n    <a href=\"/runs\">Runs</a> /\n    {{if .ParentRun}}<a href=\"/runs/{{.ParentRun.ID}}\" class=\"parent-run-link\">{{.ParentRun.ID}}</a> / {{end}}\n    {{.Run.ID}}\n    <span class=\"badge badge-{{stateColor .Run.State}}\">{{.Run.State}}</span>\n    {{if or (eq .Run.State \"pending\") (eq .Run.State \"running\")}}\n    <button class=\"btn btn-danger btn-sm\" id=\"cancel-run-btn\" onclick=\"cancelRun('{{.Run.ID}}')\" style=\"margin-left:0.5rem;\">Cancel</button>\n    {{end}}\n</h1>\n\n<div class=\"run-meta\">\n    <dl>\n        {{if .Run.Title}}<dt>Title</dt><dd>{{.Run.Title}}</dd>{{end}}\n        {{if .ParentRun}}<dt>Parent Run</dt><dd><a href=\"/runs/{{.ParentRun.ID}}\">{{.ParentRun.ID}}</a> <span class=\"badge badge-{{stateColor .ParentRun.State}}\">{{.ParentRun.State}}</span></dd>{{end}}\n        <dt>Workflow</dt><dd>{{.Run.WorkflowName}}</dd>\n        <dt>Type</dt><dd>{{if .Run.IsHost}}host{{else}}container{{end}}</dd>\n        <dt>Started</dt><dd>{{formatTime .Run.StartedAt}}</dd>\n        <dt>Completed</dt><dd>{{formatTime .Run.CompletedAt}}</dd>\n        <dt>Container</dt><dd class=\"mono\">{{.Run.ContainerID}}</dd>\n        <dt>Container Status</dt>\n        <dd id=\"container-status\">\n            {{if eq .ContainerState \"running\"}}\n                <span class=\"badge badge-running\">Container running</span>\n            {{else if eq .ContainerState \"stopped\"}}\n                <span class=\"badge badge-stopped\">Container stopped</span>\n                {{if or (eq .Run.State \"succeeded\") (eq .Run.State \"failed\") (eq .Run.State \"cancelled\")}}\n                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n                {{end}}\n            {{else if eq .ContainerState \"available\"}}\n                <span class=\"badge badge-succeeded\">Container available</span>\n                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n            {{else}}\n                <span class=\"badge badge-pending\">Container removed</span>\n            {{end}}\n        </dd>\n    </dl>\n</div>\n\n{{if .Run.ErrorMessage}}\n<div class=\"error-box\">{{.Run.ErrorMessage}}</div>\n{{end}}\n\n{{if .ChildRuns}}\n<h2>Child Runs</h2>\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Run ID</th>\n            <th>Title</th>\n            <th>Workflow</th>\n            <th>State</th>\n            <th>Started</th>\n            <th>Completed</th>\n        </tr>\n    </thead>\n    <tbody>\n        {{range .ChildRuns}}\n        <tr>\n            <td><a href=\"/runs/{{.ID}}\">{{.ID}}</a></td>\n            <td>{{truncate .Title 50}}</td>\n            <td>{{.WorkflowName}}</td>\n            <td><span class=\"badge badge-{{stateColor .State}}\">{{.State}}</span></td>\n            <td>{{formatTime .StartedAt}}</td>\n            <td>{{formatTime .CompletedAt}}</td>\n        </tr>\n        {{end}}\n    </tbody>\n</table>\n{{end}}\n\n<h2>Steps</h2>\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Step</th>\n            <th>Result</th>\n            <th>Started</th>\n            <th>Duration</th>\n        </tr>\n    </thead>\n    <tbody id=\"steps-body\">\n    {{if .Steps}}\n        {{range .Steps}}\n        <tr class=\"step-row\" data-run-id=\"{{$.Run.ID}}\" data-step=\"{{.StepName}}\" data-index=\"{{.Index}}\">\n            <td>{{.StepName}}</td>\n            <td>{{if .Result}}<span class=\"badge badge-{{if eq .Result \"success\"}}succeeded{{else if eq .Result \"fail\"}}failed{{else}}pending{{end}}\">{{.Result}}</span>{{else}}<span class=\"badge badge-running\">running</span>{{end}}</td>\n            <td>{{formatTime .StartedAt}}</td>\n            <td>{{.Duration}}</td>\n        </tr>\n        <tr class=\"output-row\" id=\"output-{{.Index}}\" style=\"display:none\">\n            <td colspan=\"4\"><div class=\"step-log-viewer\"><pre class=\"step-output\" data-step=\"{{.StepName}}\"></pre></div></td>\n        </tr>\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n\n<h2>\n    Log\n    <span id=\"log-status\" class=\"badge badge-running\" style=\"font-size:0.7rem; margin-left:0.5rem;\">Live</span>\n</h2>\n<div id=\"log-viewer\" class=\"log-viewer\">\n    <button id=\"load-earlier-btn\" class=\"load-earlier-btn\" style=\"display:none\" onclick=\"loadEarlierLogs()\">Load earlier (<span id=\"load-earlier-count\">0</span> more lines)</button>\n    <pre id=\"log-content\"></pre>\n</div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var runState = '{{.Run.State}}';\n    var runID = '{{.Run.ID}}';\n\n    // --- Log Viewer ---\n    var logContent = document.getElementById('log-content');\n    var logViewer = document.getElementById('log-viewer');\n    var logStatus = document.getElementById('log-status');\n    var loadEarlierBtn = document.getElementById('load-earlier-btn');\n    var loadEarlierCount = document.getElementById('load-earlier-count');\n    var skippedLines = 0;\n\n    // Per-step log line buffers: stepName -> [line, ...]\n    var stepLogBuffers = {};\n\n    function appendToElement(container, pre, line) {\n        var span = document.createElement('span');\n        span.className = 'log-line log-type-' + (line.type || 'script');\n        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';\n\n        var savedScrollTop = container.scrollTop;\n        var atBottom = container.scrollHeight - savedScrollTop - container.clientHeight < 40;\n\n        pre.appendChild(span);\n\n        if (atBottom) {\n            container.scrollTop = container.scrollHeight;\n        } else {\n            container.scrollTop = savedScrollTop;\n        }\n    }\n\n    function appendLogLine(line) {\n        appendToElement(logViewer, logContent, line);\n\n        // Buffer and route to per-step accordion\n        if (line.step_name) {\n            if (!stepLogBuffers[line.step_name]) {\n                stepLogBuffers[line.step_name] = [];\n            }\n            stepLogBuffers[line.step_name].push(line);\n\n            // If the step's accordion pre is visible, append live\n            var pres = document.querySelectorAll('.step-output[data-step=\"' + line.step_name + '\"]');\n            for (var i = 0; i < pres.length; i++) {\n                var pre = pres[i];\n                var viewer = pre.closest('.step-log-viewer');\n                if (viewer && pre.closest('.output-row').style.display !== 'none') {\n                    appendToElement(viewer, pre, line);\n                }\n            }\n        }\n    }\n\n    function markComplete() {\n        logStatus.textContent = 'Complete';\n        logStatus.className = 'badge badge-succeeded';\n    }\n\n    // Connect to SSE stream\n    var source = new EventSource('/api/runs/' + runID + '/stream');\n    source.onmessage = function(e) {\n        try {\n            var line = JSON.parse(e.data);\n            appendLogLine(line);\n        } catch(err) {}\n    };\n    source.addEventListener('meta', function(e) {\n        try {\n            var meta = JSON.parse(e.data);\n            skippedLines = meta.skipped || 0;\n            if (skippedLines > 0) {\n                loadEarlierCount.textContent = skippedLines;\n                loadEarlierBtn.style.display = '';\n            }\n        } catch(err) {}\n    });\n    source.addEventListener('done', function(e) {\n        markComplete();\n        source.close();\n    });\n    source.onerror = function() {\n        markComplete();\n        source.close();\n    };\n\n    // If already complete, mark the badge immediately\n    if (runState === 'succeeded' || runState === 'failed' || runState === 'cancelled') {\n        logStatus.textContent = 'Complete';\n        logStatus.className = 'badge badge-succeeded';\n    }\n\n    // --- Steps Polling (for active runs) ---\n    if (runState !== 'succeeded' && runState !== 'failed' && runState !== 'cancelled') {\n        function poll() {\n            fetch('/api/runs/' + runID)\n                .then(function(r) { return r.json(); })\n                .then(function(data) {\n                    if (data.state !== runState) {\n                        location.reload();\n                        return;\n                    }\n                    // Update container status\n                    var statusEl = document.getElementById('container-status');\n                    if (statusEl && data.container_state) {\n                        var cs = data.container_state;\n                        if (cs === 'running') {\n                            statusEl.innerHTML = '<span class=\"badge badge-running\">Container running</span>';\n                        } else if (cs === 'stopped') {\n                            var stoppedHtml = '<span class=\"badge badge-stopped\">Container stopped</span>';\n                            if (data.state === 'succeeded' || data.state === 'failed' || data.state === 'cancelled') {\n                                stoppedHtml += ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n                            }\n                            statusEl.innerHTML = stoppedHtml;\n                        } else if (cs === 'available') {\n                            statusEl.innerHTML = '<span class=\"badge badge-succeeded\">Container available</span>' +\n                                ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n                        } else {\n                            statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n                        }\n                    }\n                    var tbody = document.getElementById('steps-body');\n                    if (!data.steps || data.steps.length === 0) {\n                        tbody.innerHTML = '<tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>';\n                        return;\n                    }\n\n                    // Capture current accordion state before updating\n                    var openAccordions = {};\n                    var loadedOutputs = {};\n                    var outputRows = tbody.querySelectorAll('.output-row');\n                    for (var j = 0; j < outputRows.length; j++) {\n                        var id = outputRows[j].id;\n                        if (outputRows[j].style.display !== 'none') {\n                            openAccordions[id] = true;\n                        }\n                        var pre = outputRows[j].querySelector('.step-output');\n                        if (pre && pre.childNodes.length > 0) {\n                            loadedOutputs[id] = pre.innerHTML;\n                        }\n                    }\n\n                    // Build updated step rows, preserving accordion state\n                    var html = '';\n                    for (var i = 0; i < data.steps.length; i++) {\n                        var s = data.steps[i];\n                        var badge = '';\n                        if (s.result) {\n                            var cls = s.result === 'success' ? 'succeeded' : s.result === 'fail' ? 'failed' : 'pending';\n                            badge = '<span class=\"badge badge-' + cls + '\">' + escapeHtml(s.result) + '</span>';\n                        } else {\n                            badge = '<span class=\"badge badge-running\">running</span>';\n                        }\n                        var outputId = 'output-' + i;\n                        var isOpen = openAccordions[outputId];\n                        html += '<tr class=\"step-row\" data-run-id=\"' + escapeHtml(runID) + '\" data-step=\"' + escapeHtml(s.step_name) + '\" data-index=\"' + i + '\">' +\n                            '<td>' + escapeHtml(s.step_name) + '</td>' +\n                            '<td>' + badge + '</td>' +\n                            '<td>' + s.started_at + '</td>' +\n                            '<td>' + s.duration + '</td>' +\n                            '</tr>' +\n                            '<tr class=\"output-row\" id=\"' + outputId + '\"' + (isOpen ? '' : ' style=\"display:none\"') + '>' +\n                            '<td colspan=\"4\"><div class=\"step-log-viewer\"><pre class=\"step-output\" data-step=\"' + escapeHtml(s.step_name) + '\"></pre></div></td>' +\n                            '</tr>';\n                    }\n                    tbody.innerHTML = html;\n\n                    // Restore loaded output content for open accordions\n                    for (var key in loadedOutputs) {\n                        var row = document.getElementById(key);\n                        if (row) {\n                            var pre = row.querySelector('.step-output');\n                            if (pre) {\n                                pre.innerHTML = loadedOutputs[key];\n                            }\n                        }\n                    }\n\n                    // Re-populate open accordions from step log buffers or fetch\n                    for (var key in openAccordions) {\n                        if (!loadedOutputs[key]) {\n                            var row = document.getElementById(key);\n                            if (row) {\n                                var stepRow = row.previousElementSibling;\n                                if (stepRow && stepRow.dataset.runId && stepRow.dataset.step) {\n                                    (function(r, rid, sname) {\n                                        var pre = r.querySelector('.step-output');\n                                        var viewer = pre.closest('.step-log-viewer');\n                                        var buf = stepLogBuffers[sname];\n                                        if (buf && buf.length > 0) {\n                                            for (var k = 0; k < buf.length; k++) {\n                                                appendToElement(viewer, pre, buf[k]);\n                                            }\n                                        } else {\n                                            fetch('/api/runs/' + rid + '/steps/' + sname + '/output')\n                                                .then(function(resp) {\n                                                    if (!resp.ok) return 'No output available.';\n                                                    return resp.text();\n                                                })\n                                                .then(function(text) { pre.textContent = text; })\n                                                .catch(function() { pre.textContent = 'Failed to load output.'; });\n                                        }\n                                    })(row, stepRow.dataset.runId, stepRow.dataset.step);\n                                }\n                            }\n                        }\n                    }\n                })\n                .catch(function() {});\n        }\n        setInterval(poll, 2000);\n    }\n\n    function escapeHtml(s) {\n        if (!s) return '';\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n})();\n\n// Load earlier log lines\n    window.loadEarlierLogs = function() {\n        var btn = document.getElementById('load-earlier-btn');\n        var countEl = document.getElementById('load-earlier-count');\n        btn.disabled = true;\n        var prevText = btn.textContent;\n        btn.textContent = 'Loading...';\n\n        var limit = 1000;\n        var end = skippedLines;\n\n        fetch('/api/runs/' + runID + '/logs?end=' + end + '&limit=' + limit)\n            .then(function(r) { return r.json(); })\n            .then(function(data) {\n                if (data.lines && data.lines.length > 0) {\n                    var fragment = document.createDocumentFragment();\n                    for (var i = 0; i < data.lines.length; i++) {\n                        var line = data.lines[i];\n                        var span = document.createElement('span');\n                        span.className = 'log-line log-type-' + (line.type || 'script');\n                        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';\n                        fragment.appendChild(span);\n                    }\n                    // Preserve scroll position relative to existing content\n                    var prevScrollHeight = logViewer.scrollHeight;\n                    logContent.insertBefore(fragment, logContent.firstChild);\n                    logViewer.scrollTop += logViewer.scrollHeight - prevScrollHeight;\n                }\n\n                skippedLines = data.start || 0;\n                if (skippedLines > 0) {\n                    btn.disabled = false;\n                    countEl.textContent = skippedLines;\n                    btn.textContent = '';\n                    btn.appendChild(document.createTextNode('Load earlier ('));\n                    btn.appendChild(countEl);\n                    btn.appendChild(document.createTextNode(' more lines)'));\n                } else {\n                    btn.style.display = 'none';\n                }\n            })\n            .catch(function() {\n                btn.disabled = false;\n                btn.textContent = prevText;\n            });\n    };\n\n// Cancel run\n    window.cancelRun = function(runID) {\n        var btn = document.getElementById('cancel-run-btn');\n        if (btn) btn.disabled = true;\n        fetch('/api/runs/' + runID + '/stop', { method: 'POST' })\n            .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })\n            .then(function(res) {\n                if (res.ok) {\n                    location.reload();\n                } else {\n                    if (btn) btn.disabled = false;\n                    alert('Failed to cancel run: ' + (res.data.error || 'unknown error'));\n                }\n            })\n            .catch(function() {\n                if (btn) btn.disabled = false;\n                alert('Failed to cancel run');\n            });\n    };\n\n// Delete container\n    window.deleteContainer = function(runID) {\n        var btn = document.getElementById('delete-container-btn');\n        if (btn) btn.disabled = true;\n        fetch('/api/runs/' + runID + '/container', { method: 'DELETE' })\n            .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })\n            .then(function(res) {\n                var statusEl = document.getElementById('container-status');\n                if (res.ok) {\n                    statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n                } else {\n                    if (btn) btn.disabled = false;\n                    alert('Failed to delete container: ' + (res.data.error || 'unknown error'));\n                }\n            })\n            .catch(function() {\n                if (btn) btn.disabled = false;\n                alert('Failed to delete container');\n            });\n    };\n\n    // Toggle step output rows\ndocument.addEventListener('click', function(e) {\n    var row = e.target.closest('.step-row');\n    if (!row) return;\n    var idx = row.dataset.index;\n    var outputRow = document.getElementById('output-' + idx);\n    if (!outputRow) return;\n\n    if (outputRow.style.display === 'none') {\n        outputRow.style.display = '';\n        var pre = outputRow.querySelector('.step-output');\n        var stepName = row.dataset.step;\n        var viewer = pre.closest('.step-log-viewer');\n        if (pre.childNodes.length === 0) {\n            // Populate from buffered live lines first\n            var buf = stepLogBuffers[stepName];\n            if (buf && buf.length > 0) {\n                for (var k = 0; k < buf.length; k++) {\n                    appendToElement(viewer, pre, buf[k]);\n                }\n            } else {\n                // No live buffer — fetch from server (completed step)\n                var runId = row.dataset.runId;\n                fetch('/api/runs/' + runId + '/steps/' + stepName + '/output')\n                    .then(function(r) {\n                        if (!r.ok) return 'No output available.';\n                        return r.text();\n                    })\n                    .then(function(text) { pre.textContent = text; })\n                    .catch(function() { pre.textContent = 'Failed to load output.'; });\n            }\n        }\n        if (viewer) viewer.scrollTop = viewer.scrollHeight;\n    } else {\n        outputRow.style.display = 'none';\n    }\n});\n</script>\n{{end}}\n","numLines":461,"startLine":1,"totalLines":461}}}
