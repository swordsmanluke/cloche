{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wvpb6dXkhGYwm51mQBdZSn","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"os/exec\"\n    14→\t\"path/filepath\"\n    15→\t\"regexp\"\n    16→\t\"sort\"\n    17→\t\"strconv\"\n    18→\t\"strings\"\n    19→\t\"time\"\n    20→\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→)\n    26→\n    27→// HandlerOption configures optional Handler dependencies.\n    28→type HandlerOption func(*Handler)\n    29→\n    30→// WithContainerLogger sets the container runtime for fetching live logs.\n    31→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32→\treturn func(h *Handler) { h.container = c }\n    33→}\n    34→\n    35→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36→func WithContainerManager(c ContainerManager) HandlerOption {\n    37→\treturn func(h *Handler) { h.container = c }\n    38→}\n    39→\n    40→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42→\treturn func(h *Handler) { h.logBroadcast = b }\n    43→}\n    44→\n    45→// WithLogStore sets the log store for indexed log file lookups.\n    46→func WithLogStore(ls ports.LogStore) HandlerOption {\n    47→\treturn func(h *Handler) { h.logStore = ls }\n    48→}\n    49→\n    50→// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    51→func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    52→\treturn func(h *Handler) { h.orchestrateFn = fn }\n    53→}\n    54→\n    55→// OrchestratorController provides per-project orchestrator control.\n    56→type OrchestratorController interface {\n    57→\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    58→\tSetEnabled(dir string, enabled bool)\n    59→\tSetConcurrency(dir string, concurrency int)\n    60→}\n    61→\n    62→// WithOrchestrator sets the orchestrator controller for project-level control.\n    63→func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    64→\treturn func(h *Handler) { h.orchestrator = oc }\n    65→}\n    66→\n    67→//go:embed templates/*.html static/*\n    68→var content embed.FS\n    69→\n    70→// Handler serves the web dashboard.\n    71→// ContainerLogger can retrieve logs from a container by ID.\n    72→type ContainerLogger interface {\n    73→\tLogs(ctx context.Context, containerID string) (string, error)\n    74→}\n    75→\n    76→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    77→type ContainerManager interface {\n    78→\tContainerLogger\n    79→\tRemove(ctx context.Context, containerID string) error\n    80→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    81→}\n    82→\n    83→type Handler struct {\n    84→\tstore         ports.RunStore\n    85→\tcaptures      ports.CaptureStore\n    86→\tlogStore      ports.LogStore\n    87→\tcontainer     ContainerLogger\n    88→\tlogBroadcast  *logstream.Broadcaster\n    89→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    90→\torchestrator  OrchestratorController\n    91→\tpages         map[string]*template.Template\n    92→\tmux           *http.ServeMux\n    93→}\n    94→\n    95→// NewHandler creates a web dashboard handler.\n    96→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    97→\tfuncMap := template.FuncMap{\n    98→\t\t\"stateColor\":       stateColor,\n    99→\t\t\"healthColor\":      healthColor,\n   100→\t\t\"formatTime\":       formatTime,\n   101→\t\t\"formatDuration\":   formatDuration,\n   102→\t\t\"truncate\":         truncate,\n   103→\t\t\"shortContainerID\": shortContainerID,\n   104→\t}\n   105→\n   106→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   107→\tif err != nil {\n   108→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   109→\t}\n   110→\n   111→\tpages := map[string]*template.Template{}\n   112→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   113→\t\tclone, err := base.Clone()\n   114→\t\tif err != nil {\n   115→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   116→\t\t}\n   117→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   118→\t\tif err != nil {\n   119→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   120→\t\t}\n   121→\t\tpages[page] = clone\n   122→\t}\n   123→\n   124→\th := &Handler{\n   125→\t\tstore:    store,\n   126→\t\tcaptures: captures,\n   127→\t\tpages:    pages,\n   128→\t\tmux:      http.NewServeMux(),\n   129→\t}\n   130→\tfor _, opt := range opts {\n   131→\t\topt(h)\n   132→\t}\n   133→\n   134→\tstaticFS, err := fs.Sub(content, \"static\")\n   135→\tif err != nil {\n   136→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   137→\t}\n   138→\n   139→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   140→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   141→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   142→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   143→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   144→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   145→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   146→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   147→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   148→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   149→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   150→\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   151→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   152→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   153→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   154→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   155→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   156→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   157→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   158→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   159→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   160→\n   161→\treturn h, nil\n   162→}\n   163→\n   164→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   165→\th.mux.ServeHTTP(w, r)\n   166→}\n   167→\n   168→// --- HTML handlers ---\n   169→\n   170→// projectOverviewEntry holds data for a single project card on the landing page.\n   171→type projectOverviewEntry struct {\n   172→\tDir         string\n   173→\tLabel       string\n   174→\tHealth      domain.HealthResult\n   175→\tRecentRuns  []recentRunDot\n   176→\tActiveCount int\n   177→}\n   178→\n   179→// recentRunDot is a minimal representation of a run for the mini history display.\n   180→type recentRunDot struct {\n   181→\tID    string\n   182→\tState string\n   183→}\n   184→\n   185→const healthWindowSize = 10\n   186→\n   187→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   188→\tprojects, _ := h.store.ListProjects(r.Context())\n   189→\tlabels := projectLabels(projects)\n   190→\n   191→\tvar entries []projectOverviewEntry\n   192→\tfor _, dir := range projects {\n   193→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   194→\t\tif err != nil {\n   195→\t\t\tcontinue\n   196→\t\t}\n   197→\n   198→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   199→\t\trunValues := make([]domain.Run, len(runs))\n   200→\t\tfor i, rr := range runs {\n   201→\t\t\trunValues[i] = *rr\n   202→\t\t}\n   203→\n   204→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   205→\n   206→\t\t// Take the last N runs for the mini history (most recent first).\n   207→\t\tn := healthWindowSize\n   208→\t\tif n > len(runs) {\n   209→\t\t\tn = len(runs)\n   210→\t\t}\n   211→\t\tdots := make([]recentRunDot, n)\n   212→\t\tfor i := 0; i < n; i++ {\n   213→\t\t\tdots[i] = recentRunDot{\n   214→\t\t\t\tID:    runs[i].ID,\n   215→\t\t\t\tState: string(runs[i].State),\n   216→\t\t\t}\n   217→\t\t}\n   218→\n   219→\t\tvar activeCount int\n   220→\t\tfor _, rr := range runs {\n   221→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   222→\t\t\t\tactiveCount++\n   223→\t\t\t}\n   224→\t\t}\n   225→\n   226→\t\tentries = append(entries, projectOverviewEntry{\n   227→\t\t\tDir:         dir,\n   228→\t\t\tLabel:       labels[dir],\n   229→\t\t\tHealth:      health,\n   230→\t\t\tRecentRuns:  dots,\n   231→\t\t\tActiveCount: activeCount,\n   232→\t\t})\n   233→\t}\n   234→\n   235→\tsort.Slice(entries, func(i, j int) bool {\n   236→\t\treturn entries[i].Label < entries[j].Label\n   237→\t})\n   238→\n   239→\tdata := map[string]any{\n   240→\t\t\"Title\":    \"Projects\",\n   241→\t\t\"Projects\": entries,\n   242→\t}\n   243→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   244→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   245→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   246→\t}\n   247→}\n   248→\n   249→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   250→\tprojectFilter := r.URL.Query().Get(\"project\")\n   251→\n   252→\tvar runs []*domain.Run\n   253→\tvar err error\n   254→\tif projectFilter != \"\" {\n   255→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   256→\t} else {\n   257→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   258→\t}\n   259→\tif err != nil {\n   260→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   261→\t\treturn\n   262→\t}\n   263→\n   264→\tprojects, _ := h.store.ListProjects(r.Context())\n   265→\tlabels := projectLabels(projects)\n   266→\n   267→\t// Count retained containers per project\n   268→\tcontainerCounts := map[string]int{}\n   269→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   270→\tfor _, run := range allRuns {\n   271→\t\tif run.ContainerKept {\n   272→\t\t\tcontainerCounts[run.ProjectDir]++\n   273→\t\t}\n   274→\t}\n   275→\n   276→\tvar projectList []projectEntry\n   277→\tfor _, dir := range projects {\n   278→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   279→\t}\n   280→\tsort.Slice(projectList, func(i, j int) bool {\n   281→\t\treturn projectList[i].Label < projectList[j].Label\n   282→\t})\n   283→\n   284→\tdata := map[string]any{\n   285→\t\t\"Title\":         \"Runs\",\n   286→\t\t\"Runs\":          runs,\n   287→\t\t\"Projects\":      projectList,\n   288→\t\t\"ProjectFilter\": projectFilter,\n   289→\t\t\"ProjectLabels\": labels,\n   290→\t}\n   291→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   292→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   293→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   294→\t}\n   295→}\n   296→\n   297→// stepEntry is a merged view of a step execution for the template.\n   298→type stepEntry struct {\n   299→\tIndex     int\n   300→\tStepName  string\n   301→\tResult    string\n   302→\tStartedAt time.Time\n   303→\tDuration  string\n   304→}\n   305→\n   306→// mergeCaptures collapses started/completed capture pairs into single entries.\n   307→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   308→\tvar entries []stepEntry\n   309→\t// Track pending started rows by step name (LIFO for retries)\n   310→\tpending := map[string]*domain.StepExecution{}\n   311→\n   312→\tfor _, c := range caps {\n   313→\t\tif c.Result == \"\" {\n   314→\t\t\t// step_started row\n   315→\t\t\tpending[c.StepName] = c\n   316→\t\t\tcontinue\n   317→\t\t}\n   318→\t\t// step_completed row — merge with pending started if available\n   319→\t\tstartedAt := c.StartedAt\n   320→\t\tif started := pending[c.StepName]; started != nil {\n   321→\t\t\tstartedAt = started.StartedAt\n   322→\t\t\tdelete(pending, c.StepName)\n   323→\t\t}\n   324→\t\tentries = append(entries, stepEntry{\n   325→\t\t\tIndex:     len(entries),\n   326→\t\t\tStepName:  c.StepName,\n   327→\t\t\tResult:    c.Result,\n   328→\t\t\tStartedAt: startedAt,\n   329→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   330→\t\t})\n   331→\t}\n   332→\n   333→\t// Append any started-but-not-completed steps (still running)\n   334→\tfor _, c := range caps {\n   335→\t\tif c.Result == \"\" {\n   336→\t\t\tif _, used := pending[c.StepName]; !used {\n   337→\t\t\t\tcontinue\n   338→\t\t\t}\n   339→\t\t\tentries = append(entries, stepEntry{\n   340→\t\t\t\tIndex:     len(entries),\n   341→\t\t\t\tStepName:  c.StepName,\n   342→\t\t\t\tStartedAt: c.StartedAt,\n   343→\t\t\t})\n   344→\t\t\tdelete(pending, c.StepName)\n   345→\t\t}\n   346→\t}\n   347→\n   348→\treturn entries\n   349→}\n   350→\n   351→// containerState inspects the container for a run and returns one of:\n   352→//   - \"running\"   – container exists and is running\n   353→//   - \"stopped\"   – container exists, not running, not kept\n   354→//   - \"available\" – container exists, not running, kept (can be deleted)\n   355→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   356→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   357→\tif run.ContainerID == \"\" {\n   358→\t\treturn \"removed\"\n   359→\t}\n   360→\tmgr, ok := h.container.(ContainerManager)\n   361→\tif !ok {\n   362→\t\treturn \"removed\"\n   363→\t}\n   364→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   365→\tif err != nil {\n   366→\t\treturn \"removed\"\n   367→\t}\n   368→\tif status.Running {\n   369→\t\treturn \"running\"\n   370→\t}\n   371→\tif run.ContainerKept {\n   372→\t\treturn \"available\"\n   373→\t}\n   374→\treturn \"stopped\"\n   375→}\n   376→\n   377→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   378→\tid := r.PathValue(\"id\")\n   379→\n   380→\trun, err := h.store.GetRun(r.Context(), id)\n   381→\tif err != nil {\n   382→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   383→\t\treturn\n   384→\t}\n   385→\n   386→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   387→\tif err != nil {\n   388→\t\tcaps = nil // non-fatal\n   389→\t}\n   390→\n   391→\tsteps := mergeCaptures(caps)\n   392→\n   393→\tdata := map[string]any{\n   394→\t\t\"Title\":          \"Run \" + run.ID,\n   395→\t\t\"Run\":            run,\n   396→\t\t\"Steps\":          steps,\n   397→\t\t\"Page\":           \"detail\",\n   398→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   399→\t}\n   400→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   401→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   402→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   403→\t}\n   404→}\n   405→\n   406→// --- JSON API handlers ---\n   407→\n   408→type apiRun struct {\n   409→\tID           string `json:\"id\"`\n   410→\tWorkflowName string `json:\"workflow_name\"`\n   411→\tProjectDir   string `json:\"project_dir\"`\n   412→\tProjectLabel string `json:\"project_label\"`\n   413→\tState        string `json:\"state\"`\n   414→\tStartedAt    string `json:\"started_at\"`\n   415→\tCompletedAt  string `json:\"completed_at\"`\n   416→\tContainerID  string `json:\"container_id\"`\n   417→\tErrorMessage string `json:\"error_message\"`\n   418→}\n   419→\n   420→type apiStep struct {\n   421→\tStepName    string `json:\"step_name\"`\n   422→\tResult      string `json:\"result\"`\n   423→\tStartedAt   string `json:\"started_at\"`\n   424→\tCompletedAt string `json:\"completed_at\"`\n   425→\tDuration    string `json:\"duration\"`\n   426→}\n   427→\n   428→type apiRunDetail struct {\n   429→\tapiRun\n   430→\tContainerState string    `json:\"container_state\"`\n   431→\tSteps          []apiStep `json:\"steps\"`\n   432→}\n   433→\n   434→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   435→\treturn apiRun{\n   436→\t\tID:           r.ID,\n   437→\t\tWorkflowName: r.WorkflowName,\n   438→\t\tProjectDir:   r.ProjectDir,\n   439→\t\tProjectLabel: labels[r.ProjectDir],\n   440→\t\tState:        string(r.State),\n   441→\t\tStartedAt:    formatTime(r.StartedAt),\n   442→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   443→\t\tContainerID:  r.ContainerID,\n   444→\t\tErrorMessage: r.ErrorMessage,\n   445→\t}\n   446→}\n   447→\n   448→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   449→\tprojectFilter := r.URL.Query().Get(\"project\")\n   450→\n   451→\tvar runs []*domain.Run\n   452→\tvar err error\n   453→\tif projectFilter != \"\" {\n   454→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   455→\t} else {\n   456→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   457→\t}\n   458→\tif err != nil {\n   459→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   460→\t\treturn\n   461→\t}\n   462→\n   463→\tprojects, _ := h.store.ListProjects(r.Context())\n   464→\tlabels := projectLabels(projects)\n   465→\n   466→\tresult := make([]apiRun, len(runs))\n   467→\tfor i, run := range runs {\n   468→\t\tresult[i] = toAPIRun(run, labels)\n   469→\t}\n   470→\n   471→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   472→\tjson.NewEncoder(w).Encode(result)\n   473→}\n   474→\n   475→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   476→\tprojects, err := h.store.ListProjects(r.Context())\n   477→\tif err != nil {\n   478→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   479→\t\treturn\n   480→\t}\n   481→\tlabels := projectLabels(projects)\n   482→\n   483→\ttype apiHealth struct {\n   484→\t\tStatus string `json:\"status\"`\n   485→\t\tPassed int    `json:\"passed\"`\n   486→\t\tFailed int    `json:\"failed\"`\n   487→\t\tTotal  int    `json:\"total\"`\n   488→\t}\n   489→\ttype apiProject struct {\n   490→\t\tDir         string    `json:\"dir\"`\n   491→\t\tLabel       string    `json:\"label\"`\n   492→\t\tHealth      apiHealth `json:\"health\"`\n   493→\t\tActiveCount int       `json:\"active_count\"`\n   494→\t}\n   495→\tresult := make([]apiProject, len(projects))\n   496→\tfor i, dir := range projects {\n   497→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   498→\t\trunValues := make([]domain.Run, len(runs))\n   499→\t\tfor j, rr := range runs {\n   500→\t\t\trunValues[j] = *rr\n   501→\t\t}\n   502→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   503→\t\tvar activeCount int\n   504→\t\tfor _, rr := range runs {\n   505→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   506→\t\t\t\tactiveCount++\n   507→\t\t\t}\n   508→\t\t}\n   509→\t\tresult[i] = apiProject{\n   510→\t\t\tDir:   dir,\n   511→\t\t\tLabel: labels[dir],\n   512→\t\t\tHealth: apiHealth{\n   513→\t\t\t\tStatus: string(health.Status),\n   514→\t\t\t\tPassed: health.Passed,\n   515→\t\t\t\tFailed: health.Failed,\n   516→\t\t\t\tTotal:  health.Total,\n   517→\t\t\t},\n   518→\t\t\tActiveCount: activeCount,\n   519→\t\t}\n   520→\t}\n   521→\n   522→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   523→\tjson.NewEncoder(w).Encode(result)\n   524→}\n   525→\n   526→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   527→\tid := r.PathValue(\"id\")\n   528→\n   529→\trun, err := h.store.GetRun(r.Context(), id)\n   530→\tif err != nil {\n   531→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   532→\t\treturn\n   533→\t}\n   534→\n   535→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   536→\tif err != nil {\n   537→\t\tcaps = nil\n   538→\t}\n   539→\n   540→\tprojects, _ := h.store.ListProjects(r.Context())\n   541→\tlabels := projectLabels(projects)\n   542→\n   543→\tmerged := mergeCaptures(caps)\n   544→\tsteps := make([]apiStep, len(merged))\n   545→\tfor i, e := range merged {\n   546→\t\tsteps[i] = apiStep{\n   547→\t\t\tStepName:  e.StepName,\n   548→\t\t\tResult:    e.Result,\n   549→\t\t\tStartedAt: formatTime(e.StartedAt),\n   550→\t\t\tDuration:  e.Duration,\n   551→\t\t}\n   552→\t}\n   553→\n   554→\tdetail := apiRunDetail{\n   555→\t\tapiRun:         toAPIRun(run, labels),\n   556→\t\tContainerState: h.containerState(r.Context(), run),\n   557→\t\tSteps:          steps,\n   558→\t}\n   559→\n   560→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   561→\tjson.NewEncoder(w).Encode(detail)\n   562→}\n   563→\n   564→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   565→\tid := r.PathValue(\"id\")\n   566→\tstep := r.PathValue(\"step\")\n   567→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   568→\n   569→\trun, err := h.store.GetRun(r.Context(), id)\n   570→\tif err != nil {\n   571→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   572→\t\treturn\n   573→\t}\n   574→\n   575→\t// Try log index first for fast lookup\n   576→\tif h.logStore != nil {\n   577→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   578→\t\tif err == nil && len(logFiles) > 0 {\n   579→\t\t\t// If type filter specified, narrow results\n   580→\t\t\tfor _, lf := range logFiles {\n   581→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   582→\t\t\t\t\tcontinue\n   583→\t\t\t\t}\n   584→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   585→\t\t\t\tif readErr == nil && len(data) > 0 {\n   586→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   587→\t\t\t\t\tw.Write(data)\n   588→\t\t\t\t\treturn\n   589→\t\t\t\t}\n   590→\t\t\t}\n   591→\t\t}\n   592→\t}\n   593→\n   594→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   595→\n   596→\t// Fall back to file path conventions\n   597→\t// If type is \"llm\", try llm-<step>.log\n   598→\tif logType == \"llm\" {\n   599→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   600→\t\tdata, err := os.ReadFile(llmPath)\n   601→\t\tif err == nil && len(data) > 0 {\n   602→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   603→\t\t\tw.Write(data)\n   604→\t\t\treturn\n   605→\t\t}\n   606→\t}\n   607→\n   608→\t// Try per-step output first, fall back to container.log, then live docker logs\n   609→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   610→\tdata, err := os.ReadFile(outputPath)\n   611→\tif err == nil && len(data) > 0 {\n   612→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   613→\t\tw.Write(data)\n   614→\t\treturn\n   615→\t}\n   616→\n   617→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   618→\tdata, err = os.ReadFile(containerLog)\n   619→\tif err == nil && len(data) > 0 {\n   620→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   621→\t\tw.Write(data)\n   622→\t\treturn\n   623→\t}\n   624→\n   625→\t// Last resort: try live docker logs from still-existing container\n   626→\tif h.container != nil && run.ContainerID != \"\" {\n   627→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   628→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   629→\t\t\tw.Write([]byte(logs))\n   630→\t\t\treturn\n   631→\t\t}\n   632→\t}\n   633→\n   634→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   635→}\n   636→\n   637→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   638→\tid := r.PathValue(\"id\")\n   639→\n   640→\trun, err := h.store.GetRun(r.Context(), id)\n   641→\tif err != nil {\n   642→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   643→\t\tw.WriteHeader(http.StatusNotFound)\n   644→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   645→\t\treturn\n   646→\t}\n   647→\n   648→\tmgr, ok := h.container.(ContainerManager)\n   649→\tif !ok || run.ContainerID == \"\" {\n   650→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   651→\t\tw.WriteHeader(http.StatusBadRequest)\n   652→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   653→\t\treturn\n   654→\t}\n   655→\n   656→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   657→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   658→\t\tw.WriteHeader(http.StatusInternalServerError)\n   659→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   660→\t\treturn\n   661→\t}\n   662→\n   663→\trun.ContainerKept = false\n   664→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   665→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   666→\t\tw.WriteHeader(http.StatusInternalServerError)\n   667→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   668→\t\treturn\n   669→\t}\n   670→\n   671→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   672→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   673→}\n   674→\n   675→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   676→\tlabel := r.PathValue(\"name\")\n   677→\n   678→\t// Resolve label back to project directory via the store.\n   679→\tprojects, _ := h.store.ListProjects(r.Context())\n   680→\tlabels := projectLabels(projects)\n   681→\tvar projectDir string\n   682→\tfor dir, l := range labels {\n   683→\t\tif l == label {\n   684→\t\t\tprojectDir = dir\n   685→\t\t\tbreak\n   686→\t\t}\n   687→\t}\n   688→\tif projectDir == \"\" {\n   689→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   690→\t\tw.WriteHeader(http.StatusNotFound)\n   691→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   692→\t\treturn\n   693→\t}\n   694→\n   695→\tif h.orchestrateFn == nil {\n   696→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   697→\t\tw.WriteHeader(http.StatusNotImplemented)\n   698→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   699→\t\treturn\n   700→\t}\n   701→\n   702→\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   703→\tif err != nil {\n   704→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   705→\t\tw.WriteHeader(http.StatusInternalServerError)\n   706→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   707→\t\treturn\n   708→\t}\n   709→\n   710→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   711→\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   712→}\n   713→\n   714→// handleAPIStream serves an SSE stream of log lines for a run.\n   715→// For active runs, it subscribes to the live broadcaster.\n   716→// For completed runs, it serves the archived full.log then closes.\n   717→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   718→\tid := r.PathValue(\"id\")\n   719→\n   720→\trun, err := h.store.GetRun(r.Context(), id)\n   721→\tif err != nil {\n   722→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   723→\t\treturn\n   724→\t}\n   725→\n   726→\tflusher, ok := w.(http.Flusher)\n   727→\tif !ok {\n   728→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   729→\t\treturn\n   730→\t}\n   731→\n   732→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   733→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   734→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   735→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   736→\n   737→\tisComplete := run.State == domain.RunStateSucceeded ||\n   738→\t\trun.State == domain.RunStateFailed ||\n   739→\t\trun.State == domain.RunStateCancelled\n   740→\n   741→\tif isComplete {\n   742→\t\t// Serve archived full.log\n   743→\t\th.streamFullLog(w, flusher, run)\n   744→\t\t// Send done event\n   745→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   746→\t\tflusher.Flush()\n   747→\t\treturn\n   748→\t}\n   749→\n   750→\t// Active run: subscribe to live broadcaster\n   751→\tif h.logBroadcast == nil {\n   752→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   753→\t\treturn\n   754→\t}\n   755→\n   756→\tsub := h.logBroadcast.Subscribe(id)\n   757→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   758→\n   759→\tctx := r.Context()\n   760→\tfor {\n   761→\t\tselect {\n   762→\t\tcase <-ctx.Done():\n   763→\t\t\treturn\n   764→\t\tcase line, ok := <-sub.C:\n   765→\t\t\tif !ok {\n   766→\t\t\t\t// Stream finished (run completed)\n   767→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   768→\t\t\t\tflusher.Flush()\n   769→\t\t\t\treturn\n   770→\t\t\t}\n   771→\t\t\tdata, _ := json.Marshal(line)\n   772→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   773→\t\t\tflusher.Flush()\n   774→\t\t}\n   775→\t}\n   776→}\n   777→\n   778→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   779→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   780→\n   781→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   782→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   783→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   784→\tf, err := os.Open(logPath)\n   785→\tif err != nil {\n   786→\t\treturn\n   787→\t}\n   788→\tdefer f.Close()\n   789→\n   790→\tscanner := bufio.NewScanner(f)\n   791→\tfor scanner.Scan() {\n   792→\t\ttext := scanner.Text()\n   793→\t\tline := parseFullLogLine(text)\n   794→\t\tdata, _ := json.Marshal(line)\n   795→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   796→\t\tflusher.Flush()\n   797→\t}\n   798→}\n   799→\n   800→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   801→func parseFullLogLine(text string) logstream.LogLine {\n   802→\tm := logLineRegex.FindStringSubmatch(text)\n   803→\tif m == nil {\n   804→\t\treturn logstream.LogLine{\n   805→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   806→\t\t\tType:      \"script\",\n   807→\t\t\tContent:   text,\n   808→\t\t}\n   809→\t}\n   810→\treturn logstream.LogLine{\n   811→\t\tTimestamp: m[1],\n   812→\t\tType:      m[2],\n   813→\t\tContent:   m[3],\n   814→\t}\n   815→}\n   816→\n   817→// --- Project detail handlers ---\n   818→\n   819→// resolveProjectDir resolves a project label from the URL to its directory path.\n   820→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   821→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   822→\tlabel := r.PathValue(\"name\")\n   823→\tprojects, _ := h.store.ListProjects(r.Context())\n   824→\tlabels := projectLabels(projects)\n   825→\tfor dir, l := range labels {\n   826→\t\tif l == label {\n   827→\t\t\treturn dir, label, true\n   828→\t\t}\n   829→\t}\n   830→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   831→\tw.WriteHeader(http.StatusNotFound)\n   832→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   833→\treturn \"\", \"\", false\n   834→}\n   835→\n   836→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   837→\tdir, label, ok := h.resolveProjectDir(w, r)\n   838→\tif !ok {\n   839→\t\treturn\n   840→\t}\n   841→\n   842→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   843→\tn := 10\n   844→\tif n > len(runs) {\n   845→\t\tn = len(runs)\n   846→\t}\n   847→\tdots := make([]recentRunDot, n)\n   848→\tfor i := 0; i < n; i++ {\n   849→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   850→\t}\n   851→\n   852→\tdata := map[string]any{\n   853→\t\t\"Title\":      label,\n   854→\t\t\"Label\":      label,\n   855→\t\t\"Dir\":        dir,\n   856→\t\t\"RecentRuns\": dots,\n   857→\t}\n   858→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   859→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   860→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   861→\t}\n   862→}\n   863→\n   864→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   865→\tdir, _, ok := h.resolveProjectDir(w, r)\n   866→\tif !ok {\n   867→\t\treturn\n   868→\t}\n   869→\n   870→\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   871→\tif err != nil {\n   872→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   873→\t\treturn\n   874→\t}\n   875→\n   876→\tprojects, _ := h.store.ListProjects(r.Context())\n   877→\tlabels := projectLabels(projects)\n   878→\n   879→\tcontainerCounts := map[string]int{}\n   880→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   881→\tfor _, run := range allRuns {\n   882→\t\tif run.ContainerKept {\n   883→\t\t\tcontainerCounts[run.ProjectDir]++\n   884→\t\t}\n   885→\t}\n   886→\n   887→\tvar projectList []projectEntry\n   888→\tfor _, d := range projects {\n   889→\t\tprojectList = append(projectList, projectEntry{Dir: d, Label: labels[d], ContainerCount: containerCounts[d]})\n   890→\t}\n   891→\tsort.Slice(projectList, func(i, j int) bool {\n   892→\t\treturn projectList[i].Label < projectList[j].Label\n   893→\t})\n   894→\n   895→\tdata := map[string]any{\n   896→\t\t\"Title\":         \"Runs\",\n   897→\t\t\"Runs\":          runs,\n   898→\t\t\"Projects\":      projectList,\n   899→\t\t\"ProjectFilter\": dir,\n   900→\t\t\"ProjectLabels\": labels,\n   901→\t}\n   902→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   903→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   904→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   905→\t}\n   906→}\n   907→\n   908→func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   909→\tdir, _, ok := h.resolveProjectDir(w, r)\n   910→\tif !ok {\n   911→\t\treturn\n   912→\t}\n   913→\tif h.orchestrator == nil {\n   914→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   915→\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   916→\t\treturn\n   917→\t}\n   918→\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   919→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   920→\tjson.NewEncoder(w).Encode(map[string]any{\n   921→\t\t\"enabled\":     enabled,\n   922→\t\t\"in_flight\":   inFlight,\n   923→\t\t\"concurrency\": concurrency,\n   924→\t})\n   925→}\n   926→\n   927→func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   928→\tdir, _, ok := h.resolveProjectDir(w, r)\n   929→\tif !ok {\n   930→\t\treturn\n   931→\t}\n   932→\tif h.orchestrator == nil {\n   933→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   934→\t\tw.WriteHeader(http.StatusNotImplemented)\n   935→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   936→\t\treturn\n   937→\t}\n   938→\th.orchestrator.SetEnabled(dir, true)\n   939→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   940→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   941→}\n   942→\n   943→func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   944→\tdir, _, ok := h.resolveProjectDir(w, r)\n   945→\tif !ok {\n   946→\t\treturn\n   947→\t}\n   948→\tif h.orchestrator == nil {\n   949→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   950→\t\tw.WriteHeader(http.StatusNotImplemented)\n   951→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   952→\t\treturn\n   953→\t}\n   954→\th.orchestrator.SetEnabled(dir, false)\n   955→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   956→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   957→}\n   958→\n   959→func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   960→\tdir, _, ok := h.resolveProjectDir(w, r)\n   961→\tif !ok {\n   962→\t\treturn\n   963→\t}\n   964→\tif h.orchestrator == nil {\n   965→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   966→\t\tw.WriteHeader(http.StatusNotImplemented)\n   967→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   968→\t\treturn\n   969→\t}\n   970→\tvar body struct {\n   971→\t\tConcurrency int `json:\"concurrency\"`\n   972→\t}\n   973→\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n   974→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   975→\t\tw.WriteHeader(http.StatusBadRequest)\n   976→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n   977→\t\treturn\n   978→\t}\n   979→\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n   980→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   981→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   982→}\n   983→\n   984→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   985→\tdir, _, ok := h.resolveProjectDir(w, r)\n   986→\tif !ok {\n   987→\t\treturn\n   988→\t}\n   989→\n   990→\t// Docker image: read FROM line from Dockerfile\n   991→\tdockerImage := \"\"\n   992→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   993→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   994→\t\t// Find the last FROM line (final stage)\n   995→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   996→\t\t\ttrimmed := strings.TrimSpace(line)\n   997→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   998→\t\t\t\tparts := strings.Fields(trimmed)\n   999→\t\t\t\tif len(parts) >= 2 {\n  1000→\t\t\t\t\tdockerImage = parts[1]\n  1001→\t\t\t\t}\n  1002→\t\t\t}\n  1003→\t\t}\n  1004→\t}\n  1005→\n  1006→\t// Version\n  1007→\tversion := 0\n  1008→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n  1009→\tif data, err := os.ReadFile(versionPath); err == nil {\n  1010→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n  1011→\t\t\tversion = v\n  1012→\t\t}\n  1013→\t}\n  1014→\n  1015→\t// Prompt files history\n  1016→\ttype commitEntry struct {\n  1017→\t\tSHA     string `json:\"sha\"`\n  1018→\t\tDate    string `json:\"date\"`\n  1019→\t\tMessage string `json:\"message\"`\n  1020→\t}\n  1021→\ttype promptFile struct {\n  1022→\t\tPath    string        `json:\"path\"`\n  1023→\t\tHistory []commitEntry `json:\"history\"`\n  1024→\t}\n  1025→\n  1026→\tvar promptFiles []promptFile\n  1027→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n  1028→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n  1029→\t\tfor _, e := range entries {\n  1030→\t\t\tif e.IsDir() {\n  1031→\t\t\t\tcontinue\n  1032→\t\t\t}\n  1033→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n  1034→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n  1035→\t\t\tcmd.Dir = dir\n  1036→\t\t\tout, err := cmd.Output()\n  1037→\t\t\tif err != nil {\n  1038→\t\t\t\tcontinue\n  1039→\t\t\t}\n  1040→\t\t\tvar history []commitEntry\n  1041→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n  1042→\t\t\t\tif line == \"\" {\n  1043→\t\t\t\t\tcontinue\n  1044→\t\t\t\t}\n  1045→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1046→\t\t\t\tif len(parts) < 3 {\n  1047→\t\t\t\t\tcontinue\n  1048→\t\t\t\t}\n  1049→\t\t\t\t// Parse date to short form\n  1050→\t\t\t\tdateStr := parts[1]\n  1051→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1052→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1053→\t\t\t\t}\n  1054→\t\t\t\thistory = append(history, commitEntry{\n  1055→\t\t\t\t\tSHA:     parts[0][:7],\n  1056→\t\t\t\t\tDate:    dateStr,\n  1057→\t\t\t\t\tMessage: parts[2],\n  1058→\t\t\t\t})\n  1059→\t\t\t}\n  1060→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1061→\t\t}\n  1062→\t}\n  1063→\n  1064→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1065→\tjson.NewEncoder(w).Encode(map[string]any{\n  1066→\t\t\"docker_image\": dockerImage,\n  1067→\t\t\"version\":      version,\n  1068→\t\t\"prompt_files\": promptFiles,\n  1069→\t})\n  1070→}\n  1071→\n  1072→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1073→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1074→\tif !ok {\n  1075→\t\treturn\n  1076→\t}\n  1077→\tfile := r.URL.Query().Get(\"file\")\n  1078→\tsha := r.URL.Query().Get(\"sha\")\n  1079→\tif file == \"\" || sha == \"\" {\n  1080→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1081→\t\treturn\n  1082→\t}\n  1083→\n  1084→\t// Validate sha is alphanumeric to prevent injection\n  1085→\tfor _, c := range sha {\n  1086→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1087→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1088→\t\t\treturn\n  1089→\t\t}\n  1090→\t}\n  1091→\n  1092→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1093→\tcmd.Dir = dir\n  1094→\tout, err := cmd.Output()\n  1095→\tif err != nil {\n  1096→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1097→\t\treturn\n  1098→\t}\n  1099→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1100→\tw.Write(out)\n  1101→}\n  1102→\n  1103→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1104→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1105→\tif !ok {\n  1106→\t\treturn\n  1107→\t}\n  1108→\n  1109→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1110→\tentries, err := os.ReadDir(clocheDir)\n  1111→\tif err != nil {\n  1112→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1113→\t\tjson.NewEncoder(w).Encode([]any{})\n  1114→\t\treturn\n  1115→\t}\n  1116→\n  1117→\ttype apiWire struct {\n  1118→\t\tFrom   string `json:\"from\"`\n  1119→\t\tResult string `json:\"result\"`\n  1120→\t\tTo     string `json:\"to\"`\n  1121→\t}\n  1122→\ttype apiStepDef struct {\n  1123→\t\tName    string            `json:\"name\"`\n  1124→\t\tType    string            `json:\"type\"`\n  1125→\t\tResults []string          `json:\"results\"`\n  1126→\t\tConfig  map[string]string `json:\"config\"`\n  1127→\t}\n  1128→\ttype apiWorkflow struct {\n  1129→\t\tName      string       `json:\"name\"`\n  1130→\t\tFile      string       `json:\"file\"`\n  1131→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1132→\t\tWires     []apiWire    `json:\"wires\"`\n  1133→\t\tEntryStep string       `json:\"entry_step\"`\n  1134→\t}\n  1135→\n  1136→\tvar workflows []apiWorkflow\n  1137→\tfor _, e := range entries {\n  1138→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1139→\t\t\tcontinue\n  1140→\t\t}\n  1141→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1142→\t\tif err != nil {\n  1143→\t\t\tcontinue\n  1144→\t\t}\n  1145→\t\twf, err := dsl.Parse(string(data))\n  1146→\t\tif err != nil {\n  1147→\t\t\tcontinue\n  1148→\t\t}\n  1149→\t\tvar steps []apiStepDef\n  1150→\t\tfor _, s := range wf.Steps {\n  1151→\t\t\tsteps = append(steps, apiStepDef{\n  1152→\t\t\t\tName:    s.Name,\n  1153→\t\t\t\tType:    string(s.Type),\n  1154→\t\t\t\tResults: s.Results,\n  1155→\t\t\t\tConfig:  s.Config,\n  1156→\t\t\t})\n  1157→\t\t}\n  1158→\t\t// Sort steps by name for consistent ordering\n  1159→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1160→\n  1161→\t\tvar wires []apiWire\n  1162→\t\tfor _, wire := range wf.Wiring {\n  1163→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1164→\t\t}\n  1165→\n  1166→\t\tworkflows = append(workflows, apiWorkflow{\n  1167→\t\t\tName:      wf.Name,\n  1168→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1169→\t\t\tSteps:     steps,\n  1170→\t\t\tWires:     wires,\n  1171→\t\t\tEntryStep: wf.EntryStep,\n  1172→\t\t})\n  1173→\t}\n  1174→\n  1175→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1176→\tjson.NewEncoder(w).Encode(workflows)\n  1177→}\n  1178→\n  1179→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1180→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1181→\tif !ok {\n  1182→\t\treturn\n  1183→\t}\n  1184→\tworkflowName := r.PathValue(\"workflow\")\n  1185→\tstepName := r.PathValue(\"step\")\n  1186→\n  1187→\t// Find the workflow file\n  1188→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1189→\tvar wf *domain.Workflow\n  1190→\tentries, _ := os.ReadDir(clocheDir)\n  1191→\tfor _, e := range entries {\n  1192→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1193→\t\t\tcontinue\n  1194→\t\t}\n  1195→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1196→\t\tif err != nil {\n  1197→\t\t\tcontinue\n  1198→\t\t}\n  1199→\t\tparsed, err := dsl.Parse(string(data))\n  1200→\t\tif err != nil {\n  1201→\t\t\tcontinue\n  1202→\t\t}\n  1203→\t\tif parsed.Name == workflowName {\n  1204→\t\t\twf = parsed\n  1205→\t\t\tbreak\n  1206→\t\t}\n  1207→\t}\n  1208→\tif wf == nil {\n  1209→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1210→\t\treturn\n  1211→\t}\n  1212→\n  1213→\tstep, ok := wf.Steps[stepName]\n  1214→\tif !ok {\n  1215→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1216→\t\treturn\n  1217→\t}\n  1218→\n  1219→\t// Try to read the referenced file from step config\n  1220→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1221→\n  1222→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1223→\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1224→\t\tif err == nil {\n  1225→\t\t\tw.Write(data)\n  1226→\t\t\treturn\n  1227→\t\t}\n  1228→\t}\n  1229→\tif script := step.Config[\"command\"]; script != \"\" {\n  1230→\t\tw.Write([]byte(script))\n  1231→\t\treturn\n  1232→\t}\n  1233→\tif script := step.Config[\"script\"]; script != \"\" {\n  1234→\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1235→\t\tif err == nil {\n  1236→\t\t\tw.Write(data)\n  1237→\t\t\treturn\n  1238→\t\t}\n  1239→\t\tw.Write([]byte(script))\n  1240→\t\treturn\n  1241→\t}\n  1242→\n  1243→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1244→}\n  1245→\n  1246→// --- Template helpers ---\n  1247→\n  1248→func stateColor(state domain.RunState) string {\n  1249→\tswitch state {\n  1250→\tcase domain.RunStatePending:\n  1251→\t\treturn \"pending\"\n  1252→\tcase domain.RunStateRunning:\n  1253→\t\treturn \"running\"\n  1254→\tcase domain.RunStateSucceeded:\n  1255→\t\treturn \"succeeded\"\n  1256→\tcase domain.RunStateFailed:\n  1257→\t\treturn \"failed\"\n  1258→\tcase domain.RunStateCancelled:\n  1259→\t\treturn \"cancelled\"\n  1260→\tdefault:\n  1261→\t\treturn \"pending\"\n  1262→\t}\n  1263→}\n  1264→\n  1265→func healthColor(status domain.HealthStatus) string {\n  1266→\tswitch status {\n  1267→\tcase domain.HealthGreen:\n  1268→\t\treturn \"green\"\n  1269→\tcase domain.HealthYellow:\n  1270→\t\treturn \"yellow\"\n  1271→\tcase domain.HealthRed:\n  1272→\t\treturn \"red\"\n  1273→\tcase domain.HealthBlue:\n  1274→\t\treturn \"blue\"\n  1275→\tdefault:\n  1276→\t\treturn \"grey\"\n  1277→\t}\n  1278→}\n  1279→\n  1280→func formatTime(t time.Time) string {\n  1281→\tif t.IsZero() {\n  1282→\t\treturn \"\"\n  1283→\t}\n  1284→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1285→}\n  1286→\n  1287→func formatDuration(start, end time.Time) string {\n  1288→\tif start.IsZero() || end.IsZero() {\n  1289→\t\treturn \"\"\n  1290→\t}\n  1291→\td := end.Sub(start)\n  1292→\tif d < time.Second {\n  1293→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1294→\t}\n  1295→\tif d < time.Minute {\n  1296→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1297→\t}\n  1298→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1299→}\n  1300→\n  1301→func truncate(s string, n int) string {\n  1302→\tif len(s) <= n {\n  1303→\t\treturn s\n  1304→\t}\n  1305→\treturn s[:n] + \"...\"\n  1306→}\n  1307→\n  1308→func shortContainerID(id string) string {\n  1309→\tif len(id) > 12 {\n  1310→\t\treturn id[:12]\n  1311→\t}\n  1312→\treturn id\n  1313→}\n  1314→\n  1315→// projectLabels builds a mapping from full project directory paths to short\n  1316→// display labels. Each label is the final directory component (e.g.\n  1317→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1318→// the same final name, the parent directory is prepended to disambiguate\n  1319→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1320→func projectLabels(dirs []string) map[string]string {\n  1321→\tlabels := make(map[string]string, len(dirs))\n  1322→\t// Group dirs by their base name to detect conflicts.\n  1323→\tbyBase := map[string][]string{}\n  1324→\tfor _, d := range dirs {\n  1325→\t\tbase := filepath.Base(d)\n  1326→\t\tbyBase[base] = append(byBase[base], d)\n  1327→\t}\n  1328→\tfor base, paths := range byBase {\n  1329→\t\tif len(paths) == 1 {\n  1330→\t\t\tlabels[paths[0]] = base\n  1331→\t\t} else {\n  1332→\t\t\tfor _, p := range paths {\n  1333→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1334→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1335→\t\t\t}\n  1336→\t\t}\n  1337→\t}\n  1338→\treturn labels\n  1339→}\n  1340→\n  1341→type projectEntry struct {\n  1342→\tDir            string\n  1343→\tLabel          string\n  1344→\tContainerCount int\n  1345→}\n  1346→"}]},"parent_tool_use_id":null,"session_id":"5a2f2d67-cd96-47e8-94d1-4bd9c3759ba4","uuid":"3bf7eb67-34f4-4b5d-a447-a1359672f559","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\nfunc WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n\treturn func(h *Handler) { h.orchestrateFn = fn }\n}\n\n// OrchestratorController provides per-project orchestrator control.\ntype OrchestratorController interface {\n\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n\tSetEnabled(dir string, enabled bool)\n\tSetConcurrency(dir string, concurrency int)\n}\n\n// WithOrchestrator sets the orchestrator controller for project-level control.\nfunc WithOrchestrator(oc OrchestratorController) HandlerOption {\n\treturn func(h *Handler) { h.orchestrator = oc }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore         ports.RunStore\n\tcaptures      ports.CaptureStore\n\tlogStore      ports.LogStore\n\tcontainer     ContainerLogger\n\tlogBroadcast  *logstream.Broadcaster\n\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n\torchestrator  OrchestratorController\n\tpages         map[string]*template.Template\n\tmux           *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\n\t// Resolve label back to project directory via the store.\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tvar projectDir string\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\tprojectDir = dir\n\t\t\tbreak\n\t\t}\n\t}\n\tif projectDir == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\t\treturn\n\t}\n\n\tif h.orchestrateFn == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\n\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, d := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: d, Label: labels[d], ContainerCount: containerCounts[d]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": dir,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n\t\treturn\n\t}\n\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"enabled\":     enabled,\n\t\t\"in_flight\":   inFlight,\n\t\t\"concurrency\": concurrency,\n\t})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, true)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, false)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\tvar body struct {\n\t\tConcurrency int `json:\"concurrency\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n\t\treturn\n\t}\n\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\tif script := step.Config[\"command\"]; script != \"\" {\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1346,"startLine":1,"totalLines":1346}}}
