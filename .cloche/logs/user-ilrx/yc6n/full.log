t_ref,'')\n   281→\t\t FROM step_executions WHERE run_id = ? ORDER BY id`, runID)\n   282→\tif err != nil {\n   283→\t\treturn nil, err\n   284→\t}\n   285→\tdefer rows.Close()\n   286→\n   287→\tvar execs []*domain.StepExecution\n   288→\tfor rows.Next() {\n   289→\t\te := &domain.StepExecution{}\n   290→\t\tvar startedAt, completedAt string\n   291→\t\tif err := rows.Scan(&e.StepName, &e.Result, &startedAt, &completedAt, &e.Logs, &e.GitRef); err != nil {\n   292→\t\t\treturn nil, err\n   293→\t\t}\n   294→\t\te.StartedAt = parseTime(startedAt)\n   295→\t\te.CompletedAt = parseTime(completedAt)\n   296→\t\texecs = append(execs, e)\n   297→\t}\n   298→\treturn execs, rows.Err()\n   299→}\n   300→\n   301→func (s *Store) SaveLogFile(ctx context.Context, entry *ports.LogFileEntry) error {\n   302→\t_, err := s.db.ExecContext(ctx,\n   303→\t\t`INSERT INTO log_files (run_id, step_name, file_type, file_path, file_size, created_at)\n   304→\t\t VALUES (?, ?, ?, ?, ?, ?)`,\n   305→\t\tentry.RunID, entry.StepName, entry.FileType, entry.FilePath, entry.FileSize,\n   306→\t\tformatTime(entry.CreatedAt),\n   307→\t)\n   308→\treturn err\n   309→}\n   310→\n   311→func (s *Store) GetLogFiles(ctx context.Context, runID string) ([]*ports.LogFileEntry, error) {\n   312→\trows, err := s.db.QueryContext(ctx,\n   313→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   314→\t\t FROM log_files WHERE run_id = ? ORDER BY id`, runID)\n   315→\tif err != nil {\n   316→\t\treturn nil, err\n   317→\t}\n   318→\tdefer rows.Close()\n   319→\treturn scanLogFiles(rows)\n   320→}\n   321→\n   322→func (s *Store) GetLogFilesByStep(ctx context.Context, runID, stepName string) ([]*ports.LogFileEntry, error) {\n   323→\trows, err := s.db.QueryContext(ctx,\n   324→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   325→\t\t FROM log_files WHERE run_id = ? AND step_name = ? ORDER BY id`, runI