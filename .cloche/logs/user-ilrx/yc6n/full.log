[2026-03-09T15:45:16Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01CWdMZDF1ZXW8NvPhzcCmwf","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01V7fUKbXCCTdrQxxBnbxZ8t","name":"Write","input":{"file_path":"/workspace/internal/protocol/streamformat.go","content":"package protocol\n\nimport (\n\t\"bytes\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"strings\"\n)\n\n// FormatStreamJSON converts raw Claude Code stream-json JSONL output into\n// human-readable text. It extracts assistant text messages, tool call summaries,\n// tool result snippets, and errors, discarding system events, thinking blocks,\n// and rate limit events.\nfunc FormatStreamJSON(raw []byte) []byte {\n\tvar out bytes.Buffer\n\tfor _, line := range bytes.Split(raw, []byte(\"\\n\")) {\n\t\tline = bytes.TrimSpace(line)\n\t\tif len(line) == 0 {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Quick check: must be JSON\n\t\tif line[0] != '{' {\n\t\t\t// Not JSON — pass through as-is (plain text output)\n\t\t\tout.Write(line)\n\t\t\tout.WriteByte('\\n')\n\t\t\tcontinue\n\t\t}\n\n\t\t// Parse the envelope\n\t\tvar envelope struct {\n\t\t\tType    string          `json:\"type\"`\n\t\t\tSubtype string          `json:\"subtype\"`\n\t\t\tMessage json.RawMessage `json:\"message\"`\n\t\t\tResult  string          `json:\"result\"`\n\t\t}\n\t\tif json.Unmarshal(line, &envelope) != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch envelope.Type {\n\t\tcase \"assistant\":\n\t\t\tformatAssistantEvent(&out, envelope.Message)\n\t\tcase \"user\":\n\t\t\tformatUserEvent(&out, envelope.Message)\n\t\tcase \"result\":\n\t\t\tif envelope.Result != \"\" {\n\t\t\t\tout.WriteString(envelope.Result)\n\t\t\t\tout.WriteByte('\\n')\n\t\t\t}\n\t\t// Skip: system, rate_limit_event, thinking-only blocks\n\t\t}\n\t}\n\treturn out.Bytes()\n}\n\n// IsStreamJSON checks whether data looks like Claude Code stream-json output\n// by examining the first non-empty line.\nfunc IsStreamJSON(data []byte) bool {\n\tfor _, line := range bytes.SplitN(data, []byte(\"\\n\"), 3) {\n\t\tline = bytes.TrimSpace(line)\n\t\tif len(line) == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tif line[0] != '{' {\n\t\t\treturn false\n\t\t}\n\t\tvar envelope struct {\n\t\t\tType string `json:\"type\"`\n\t\t}\n\t\tif json.Unmarshal(line, &envelope) != nil {\n\t\t\treturn false\n\t\t}\n\t\treturn envelope.Type == \"system\" || envelope.Type == \"assistant\" || envelope.Type == \"result\"\n\t}\n\treturn false\n}\n\nfunc formatAssistantEvent(out *bytes.Buffer, msgRaw json.RawMessage) {\n\tvar msg struct {\n\t\tContent []struct {\n\t\t\tType  string          `json:\"type\"`\n\t\t\tText  string          `json:\"text\"`\n\t\t\tName  string          `json:\"name\"`\n\t\t\tInput json.RawMessage `json:\"input\"`\n\t\t} `json:\"content\"`\n\t}\n\tif json.Unmarshal(msgRaw, &msg) != nil {\n\t\treturn\n\t}\n\tfor _, c := range msg.Content {\n\t\tswitch c.Type {\n\t\tcase \"text\":\n\t\t\ttext := strings.TrimSpace(c.Text)\n\t\t\tif text != \"\" {\n\t\t\t\tout.WriteString(text)\n\t\t\t\tout.WriteByte('\\n')\n\t\t\t}\n\t\tcase \"tool_use\":\n\t\t\tsummary := formatToolCall(c.Name, c.Input)\n\t\t\tout.WriteString(summary)\n\t\t\tout.WriteByte('\\n')\n\t\t// Skip \"thinking\" blocks\n\t\t}\n\t}\n}\n\nfunc formatToolCall(name string, inputRaw json.RawMessage) string {\n\tvar input map[string]any\n\tif json.Unmarshal(inputRaw, &input) != nil {\n\t\treturn fmt.Sprintf(\"→ %s\", name)\n\t}\n\n\tswitch name {\n\tcase \"Read\":\n\t\tif fp, ok := input[\"file_path\"].(string); ok {\n\t\t\treturn fmt.Sprintf(\"→ Read %s\", fp)\n\t\t}\n\tcase \"Write\":\n\t\tif fp, ok := input[\"file_path\"].(string); ok {\n\t\t\treturn fmt.Sprintf(\"→ Write %s\", fp)\n\t\t}\n\tcase \"Edit\":\n\t\tif fp, ok := input[\"file_path\"].(string); ok {\n\t\t\treturn fmt.Sprintf(\"→ Edit %s\", fp)\n\t\t}\n\tcase \"Bash\":\n\t\tif cmd, ok := input[\"command\"].(string); ok {\n\t\t\tif len(cmd) > 120 {\n\t\t\t\tcmd = cmd[:120] + \"...\"\n\t\t\t}\n\t\t\treturn fmt.Sprint