[2026-03-10T16:32:15Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BHP2m19EL4d893WRwz8DM2","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"net/http\"\n     8→\t\"net/http/httptest\"\n     9→\t\"os\"\n    10→\t\"path/filepath\"\n    11→\t\"strings\"\n    12→\t\"testing\"\n    13→\t\"time\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    16→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    17→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18→\t\"github.com/stretchr/testify/assert\"\n    19→\t\"github.com/stretchr/testify/require\"\n    20→)\n    21→\n    22→// mockContainerManager implements ContainerManager for testing.\n    23→type mockContainerManager struct {\n    24→\tcontainers map[string]bool // containerID -> exists\n    25→\trunning    map[string]bool // containerID -> running\n    26→\tremoved    []string\n    27→\tstopped    []string\n    28→}\n    29→\n    30→func newMockContainerManager() *mockContainerManager {\n    31→\treturn &mockContainerManager{\n    32→\t\tcontainers: map[string]bool{},\n    33→\t\trunning:    map[string]bool{},\n    34→\t}\n    35→}\n    36→\n    37→func (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n    38→\treturn \"mock logs\", nil\n    39→}\n    40→\n    41→func (m *mockContainerManager) Stop(_ context.Context, containerID string) error {\n    42→\tif !m.containers[containerID] {\n    43→\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n    44→\t}\n    45→\tm.running[containerID] = false\n    46→\tm.stopped = append(m.stopped, containerID)\n    47→\treturn nil\n    48→}\n    49→\n    50→func (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n    51→\tif !m.containers[containerID] {\n    52→\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n    53→\t}\n    54→\tdelete(m.containers, containerID)\n    55→\tm.removed = append(m.removed, containerID)\n    56→\treturn nil\n    57→}\n    58→\n    59→func (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n    60→\tif !m.containers[containerID] {\n    61→\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n    62→\t}\n    63→\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n    64→}\n    65→\n    66→func setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n    67→\tt.Helper()\n    68→\tstore, err := sqlite.NewStore(\":memory:\")\n    69→\trequire.NoError(t, err)\n    70→\tt.Cleanup(func() { store.Close() })\n    71→\n    72→\th, err := NewHandler(store, store)\n    73→\trequire.NoError(t, err)\n    74→\treturn h, store\n    75→}\n    76→\n    77→func seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n    78→\tt.Helper()\n    79→\tseedRunWithProject(t, store, id, workflow, state, \"\")\n    80→}\n    81→\n    82→func seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n    83→\tt.Helper()\n    84→\tctx := context.Background()\n    85→\trun := domain.NewRun(id, workflow)\n    86→\trun.ProjectDir = projectDir\n    87→\tif state != domain.RunStatePending {\n    88→\t\trun.Start()\n    89→\t\trun.ContainerID = \"abc123def456789\"\n    90→\t}\n    91→\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n    92→\t\trun.Complete(state)\n    93→\t}\n    94→\tif state == domain.RunStateFailed {\n    95→\t\trun.ErrorMessage = \"something went wrong\"\n    96→\t}\n    97→\trequire.NoError(t, store.CreateRun(ctx, run))\n    98→}\n    99→\n   100→func TestRunsList_WithRuns(t *testing.T) {\n   101→\th, store := setupHandler(t)\n   102→\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n   103→\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n   104→\n   105→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   106→\tw := httptest.NewRecorder()\n   107→\th.ServeHTTP(w, req)\n   108→\n   109→\tassert.Equal(t, http.StatusOK, w.Code)\n   110→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   111→\tbody := w.Body.String()\n   112→\tassert.Contains(t, body, \"test-run-1\")\n   113→\tassert.Contains(t, body, \"test-run-2\")\n   114→\tassert.Contains(t, body, \"badge-running\")\n   115→\tassert.Contains(t, body, \"badge-succeeded\")\n   116→\tassert.Contains(t, body, \"develop\")\n   117→\tassert.Contains(t, body, \"deploy\")\n   118→}\n   119→\n   120→func TestRunsList_Empty(t *testing.T) {\n   121→\th, _ := setupHandler(t)\n   122→\n   123→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   124→\tw := httptest.NewRecorder()\n   125→\th.ServeHTTP(w, req)\n   126→\n   127→\tassert.Equal(t, http.StatusOK, w.Code)\n   128→\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n   129→}\n   130→\n   131→func TestRunDetail_WithCaptures(t *testing.T) {\n   132→\th, store := setupHandler(t)\n   133→\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n   134→\n   135→\tctx := context.Background()\n   136→\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n   137→\t\tStepName:    \"implement\",\n   138→\t\tResult:      \"success\",\n   139→\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n   140→\t\tCompletedAt: time.Now(),\n   141→\t}))\n   142→\n   143→\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n   144→\tw := httptest.NewRecorder()\n   145→\th.ServeHTTP(w, req)\n   146→\n   147→\tassert.Equal(t, http.StatusOK, w.Code)\n   148→\tbody := w.Body.String()\n   149→\tassert.Contains(t, body, \"run-detail-1\")\n   150→\tassert.Contains(t, body, \"implement\")\n   151→}\n   152→\n   153→func TestRunDetail_AccordionStatePreserved(t *testing.T) {\n   154→\t// Verify the rendered page includes JavaScript that preserves accordion state\n   155→\t// during SSE polling updates (captures open/closed state before DOM rebuild).\n   156→\th, store := setupHandler(t)\n   157→\tseedRun(t, store, \"run-accordion-1\", \"develop\", domain.RunStateRunning)\n   158→\n   159→\tctx := context.Background()\n   160→\trequire.NoError(t, store.SaveCapture(ctx, \"run-accordion-1\", &domain.StepExecution{\n   161→\t\tStepName:    \"build\",\n   162→\t\tResult:      \"success\",\n   163→\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n   164→\t\tCompletedAt: time.Now(),\n   165→\t}))\n   166→\n   167→\treq := httptest.NewRequest(\"GET\", \"/runs/run-accordion-1\", nil)\n   168→\tw := httptest.NewRecorder()\n   169→\th.ServeHTTP(w, req)\n   170→\n   171→\tassert.Equal(t, http.StatusOK, w.Code)\n   172→\tbody := w.Body.String()\n   173→\n   174→\t// The poll function should capture accordion state before rebuilding the DOM\n   175→\tassert.Contains(t, body, \"openAccordions\")\n   176→\tassert.Contains(t, body, \"loadedOutputs\")\n   177→\t// Verify it restores loaded output content after DOM rebuild\n   178→\tassert.Contains(t, body, \"loadedOutputs[key]\")\n   179→}\n   180→\n   181→func TestRunDetail_NotFound(t *testing.T) {\n   182→\th, _ := setupHandler(t)\n   183→\n   184→\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n   185→\tw := httptest.NewRecorder()\n   186→\th.ServeHTTP(w, req)\n   187→\n   188→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   189→}\n   190→\n   191→func TestAPIRuns(t *testing.T) {\n   192→\th, store := setupHandler(t)\n   193→\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n   194→\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n   195→\n   196→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   197→\tw := httptest.NewRecorder()\n   198→\th.ServeHTTP(w, req)\n   199→\n   200→\tassert.Equal(t, http.StatusOK, w.Code)\n   201→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   202→\n   203→\tvar runs []apiRun\n   204→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n   205→\tassert.Len(t, runs, 2)\n   206→\n   207→\tids := map[string]bool{}\n   208→\tfor _, r := range runs {\n   209→\t\tids[r.ID] = true\n   210→\t}\n   211→\tassert.True(t, ids[\"api-run-1\"])\n   212→\tassert.True(t, ids[\"api-run-2\"])\n   213→}\n   214→\n   215→func TestAPIRunDetail(t *testing.T) {\n   216→\th, store := setupHandler(t)\n   217→\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n   218→\n   219→\tctx := context.Background()\n   220→\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n   221→\t\tStepName:    \"build\",\n   222→\t\tResult:      \"success\",\n   223→\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n   224→\t\tCompletedAt: time.Now(),\n   225→\t}))\n   226→\n   227→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n   228→\tw := httptest.NewRecorder()\n   229→\th.ServeHTTP(w, req)\n   230→\n   231→\tassert.Equal(t, http.StatusOK, w.Code)\n   232→\n   233→\tvar detail apiRunDetail\n   234→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   235→\tassert.Equal(t, \"api-detail-1\", detail.ID)\n   236→\tassert.Equal(t, \"running\", detail.State)\n   237→\tassert.Len(t, detail.Steps, 1)\n   238→\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n   239→\tassert.NotEmpty(t, detail.Steps[0].Duration)\n   240→}\n   241→\n   242→func TestStaticCSS(t *testing.T) {\n   243→\th, _ := setupHandler(t)\n   244→\n   245→\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n   246→\tw := httptest.NewRecorder()\n   247→\th.ServeHTTP(w, req)\n   248→\n   249→\tassert.Equal(t, http.StatusOK, w.Code)\n   250→\tassert.Contains(t, w.Body.String(), \":root\")\n   251→\tassert.Contains(t, w.Body.String(), \"badge-running\")\n   252→}\n   253→\n   254→func TestHelpers(t *testing.T) {\n   255→\tt.Run(\"stateColor\", func(t *testing.T) {\n   256→\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n   257→\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n   258→\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n   259→\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n   260→\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n   261→\t})\n   262→\n   263→\tt.Run(\"formatTime\", func(t *testing.T) {\n   264→\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n   265→\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n   266→\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n   267→\t})\n   268→\n   269→\tt.Run(\"formatDuration\", func(t *testing.T) {\n   270→\t\tnow := time.Now()\n   271→\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n   272→\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n   273→\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n   274→\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n   275→\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n   276→\t})\n   277→\n   278→\tt.Run(\"truncate\", func(t *testing.T) {\n   279→\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n   280→\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n   281→\t})\n   282→\n   283→\tt.Run(\"shortContainerID\", func(t *testing.T) {\n   284→\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n   285→\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n   286→\t})\n   287→\n   288→\tt.Run(\"projectLabels\", func(t *testing.T) {\n   289→\t\t// No conflict: show base name only\n   290→\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n   291→\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n   292→\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n   293→\n   294→\t\t// Conflict: two dirs share the same base name\n   295→\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n   296→\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n   297→\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n   298→\n   299→\t\t// Mixed: some conflict, some don't\n   300→\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n   301→\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n   302→\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n   303→\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n   304→\n   305→\t\t// Empty list\n   306→\t\tlabels = projectLabels(nil)\n   307→\t\tassert.Empty(t, labels)\n   308→\t})\n   309→}\n   310→\n   311→func TestRunsList_ProjectFilter(t *testing.T) {\n   312→\th, store := setupHandler(t)\n   313→\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   314→\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   315→\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   316→\n   317→\t// Without filter: all runs shown\n   318→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   319→\tw := httptest.NewRecorder()\n   320→\th.ServeHTTP(w, req)\n   321→\tassert.Equal(t, http.StatusOK, w.Code)\n   322→\tbody := w.Body.String()\n   323→\tassert.Contains(t, body, \"run-a1\")\n   324→\tassert.Contains(t, body, \"run-b1\")\n   325→\n   326→\t// With project filter: only matching runs\n   327→\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n   328→\tw = httptest.NewRecorder()\n   329→\th.ServeHTTP(w, req)\n   330→\tassert.Equal(t, http.StatusOK, w.Code)\n   331→\tbody = w.Body.String()\n   332→\tassert.Contains(t, body, \"run-a1\")\n   333→\tassert.Contains(t, body, \"run-a2\")\n   334→\tassert.NotContains(t, body, \"run-b1\")\n   335→}\n   336→\n   337→func TestRunsList_ProjectColumn(t *testing.T) {\n   338→\th, store := setupHandler(t)\n   339→\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n   340→\n   341→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   342→\tw := httptest.NewRecorder()\n   343→\th.ServeHTTP(w, req)\n   344→\tassert.Equal(t, http.StatusOK, w.Code)\n   345→\tbody := w.Body.String()\n   346→\tassert.Contains(t, body, \"myproject\")\n   347→\tassert.Contains(t, body, \"Project\")\n   348→}\n   349→\n   350→func TestAPIRuns_ProjectFilter(t *testing.T) {\n   351→\th, store := setupHandler(t)\n   352→\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   353→\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   354→\n   355→\t// Without filter: all runs\n   356→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   357→\tw := httptest.NewRecorder()\n   358→\th.ServeHTTP(w, req)\n   359→\tassert.Equal(t, http.StatusOK, w.Code)\n   360→\n   361→\tvar allRuns []apiRun\n   362→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n   363→\tassert.Len(t, allRuns, 2)\n   364→\n   365→\t// With filter: only matching\n   366→\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n   367→\tw = httptest.NewRecorder()\n   368→\th.ServeHTTP(w, req)\n   369→\tassert.Equal(t, http.StatusOK, w.Code)\n   370→\n   371→\tvar filtered []apiRun\n   372→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n   373→\tassert.Len(t, filtered, 1)\n   374→\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n   375→\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n   376→\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n   377→}\n   378→\n   379→func setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n   380→\tt.Helper()\n   381→\tstore, err := sqlite.NewStore(\":memory:\")\n   382→\trequire.NoError(t, err)\n   383→\tt.Cleanup(func() { store.Close() })\n   384→\n   385→\tmgr := newMockContainerManager()\n   386→\th, err := NewHandler(store, store, WithContainerManager(mgr))\n   387→\trequire.NoError(t, err)\n   388→\treturn h, store, mgr\n   389→}\n   390→\n   391→func seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n   392→\tt.Helper()\n   393→\tctx := context.Background()\n   394→\trun := domain.NewRun(id, workflow)\n   395→\trun.ProjectDir = projectDir\n   396→\trun.Start()\n   397→\trun.ContainerID = containerID\n   398→\trun.ContainerKept = kept\n   399→\trun.Complete(domain.RunStateSucceeded)\n   400→\trequire.NoError(t, store.CreateRun(ctx, run))\n   401→\tif kept {\n   402→\t\tmgr.containers[containerID] = true\n   403→\t}\n   404→}\n   405→\n   406→func TestRunDetail_ContainerRunning(t *testing.T) {\n   407→\th, store, mgr := setupHandlerWithContainerManager(t)\n   408→\n   409→\tctx := context.Background()\n   410→\trun := domain.NewRun(\"run-cr\", \"develop\")\n   411→\trun.ProjectDir = \"/proj\"\n   412→\trun.Start()\n   413→\trun.ContainerID = \"cid-running\"\n   414→\trequire.NoError(t, store.CreateRun(ctx, run))\n   415→\tmgr.containers[\"cid-running\"] = true\n   416→\tmgr.running[\"cid-running\"] = true\n   417→\n   418→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n   419→\tw := httptest.NewRecorder()\n   420→\th.ServeHTTP(w, req)\n   421→\n   422→\tassert.Equal(t, http.StatusOK, w.Code)\n   423→\tbody := w.Body.String()\n   424→\tassert.Contains(t, body, \"Container running\")\n   425→\tassert.Contains(t, body, `badge-running\">Container running`)\n   426→}\n   427→\n   428→func TestRunDetail_ContainerStopped(t *testing.T) {\n   429→\th, store, mgr := setupHandlerWithContainerManager(t)\n   430→\n   431→\tctx := context.Background()\n   432→\trun := domain.NewRun(\"run-cs\", \"develop\")\n   433→\trun.ProjectDir = \"/proj\"\n   434→\trun.Start()\n   435→\trun.ContainerID = \"cid-stopped\"\n   436→\trun.ContainerKept = false\n   437→\trun.Complete(domain.RunStateSucceeded)\n   438→\trequire.NoError(t, store.CreateRun(ctx, run))\n   439→\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n   440→\n   441→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n   442→\tw := httptest.NewRecorder()\n   443→\th.ServeHTTP(w, req)\n   444→\n   445→\tassert.Equal(t, http.StatusOK, w.Code)\n   446→\tbody := w.Body.String()\n   447→\tassert.Contains(t, body, \"Container stopped\")\n   448→\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n   449→}\n   450→\n   451→func TestRunDetail_ContainerStoppedTerminal_ShowsDeleteButton(t *testing.T) {\n   452→\th, store, mgr := setupHandlerWithContainerManager(t)\n   453→\n   454→\tfor _, state := range []domain.RunState{domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled} {\n   455→\t\tt.Run(string(state), func(t *testing.T) {\n   456→\t\t\tid := \"run-cst-\" + string(state)\n   457→\t\t\tctx := context.Background()\n   458→\t\t\trun := domain.NewRun(id, \"develop\")\n   459→\t\t\trun.ProjectDir = \"/proj\"\n   460→\t\t\trun.Start()\n   461→\t\t\trun.ContainerID = \"cid-stopped-\" + string(state)\n   462→\t\t\trun.ContainerKept = false\n   463→\t\t\trun.Complete(state)\n   464→\t\t\trequire.NoError(t, store.CreateRun(ctx, run))\n   465→\t\t\tmgr.containers[run.ContainerID] = true // container exists but not running, not kept\n   466→\n   467→\t\t\treq := httptest.NewRequest(\"GET\", \"/runs/\"+id, nil)\n   468→\t\t\tw := httptest.NewRecorder()\n   469→\t\t\th.ServeHTTP(w, req)\n   470→\n   471→\t\t\tassert.Equal(t, http.StatusOK, w.Code)\n   472→\t\t\tbody := w.Body.String()\n   473→\t\t\tassert.Contains(t, body, \"Container stopped\")\n   474→\t\t\tassert.Contains(t, body, `id=\"delete-container-btn\"`, \"should show delete button for terminal run with stopped container\")\n   475→\t\t})\n   476→\t}\n   477→}\n   478→\n   479→func TestRunDetail_ContainerStoppedRunning_NoDeleteButton(t *testing.T) {\n   480→\th, store, mgr := setupHandlerWithContainerManager(t)\n   481→\n   482→\tctx := context.Background()\n   483→\trun := domain.NewRun(\"run-csr\", \"develop\")\n   484→\trun.ProjectDir = \"/proj\"\n   485→\trun.Start()\n   486→\trun.ContainerID = \"cid-stopped-running\"\n   487→\trun.ContainerKept = false\n   488→\trequire.NoError(t, store.CreateRun(ctx, run))\n   489→\tmgr.containers[\"cid-stopped-running\"] = true\n   490→\t// container not running, but run state is still \"running\" (not terminal)\n   491→\t// containerState will return \"stopped\" since ContainerKept=false\n   492→\n   493→\treq := httptest.NewRequest(\"GET\", \"/runs/run-csr\", nil)\n   494→\tw := httptest.NewRecorder()\n   495→\th.ServeHTTP(w, req)\n   496→\n   497→\tassert.Equal(t, http.StatusOK, w.Code)\n   498→\tbody := w.Body.String()\n   499→\tassert.Contains(t, body, \"Container stopped\")\n   500→\t// The HTML container-status section should NOT have the delete button.\n   501→\t// We check the dd#container-status block specifically, not the full body\n   502→\t// (which includes JS that references the button ID as string literals).\n   503→\tstatusStart := \"container-status\"\n   504→\tstatusEnd := \"</dd>\"\n   505→\tidx := strings.Index(body, statusStart)\n   506→\trequire.NotEqual(t, -1, idx, \"container-status element must exist\")\n   507→\tendIdx := strings.Index(body[idx:], statusEnd)\n   508→\trequire.NotEqual(t, -1, endIdx, \"closing </dd> must exist\")\n   509→\tstatusSection := body[idx : idx+endIdx+len(statusEnd)]\n   510→\tassert.NotContains(t, statusSection, \"Delete Container\", \"should NOT show delete button for non-terminal run\")\n   511→}\n   512→\n   513→func TestRunDetail_ContainerAvailable(t *testing.T) {\n   514→\th, store, mgr := setupHandlerWithContainerManager(t)\n   515→\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n   516→\n   517→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n   518→\tw := httptest.NewRecorder()\n   519→\th.ServeHTTP(w, req)\n   520→\n   521→\tassert.Equal(t, http.StatusOK, w.Code)\n   522→\tbody := w.Body.String()\n   523→\tassert.Contains(t, body, \"Container available\")\n   524→\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n   525→\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n   526→}\n   527→\n   528→func TestRunDetail_ContainerRemoved(t *testing.T) {\n   529→\th, store, _ := setupHandlerWithContainerManager(t)\n   530→\n   531→\tctx := context.Background()\n   532→\trun := domain.NewRun(\"run-c2\", \"develop\")\n   533→\trun.ProjectDir = \"/proj\"\n   534→\trun.Start()\n   535→\trun.ContainerID = \"cid-gone\"\n   536→\trun.ContainerKept = false\n   537→\trun.Complete(domain.RunStateSucceeded)\n   538→\trequire.NoError(t, store.CreateRun(ctx, run))\n   539→\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n   540→\n   541→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n   542→\tw := httptest.NewRecorder()\n   543→\th.ServeHTTP(w, req)\n   544→\n   545→\tassert.Equal(t, http.StatusOK, w.Code)\n   546→\tbody := w.Body.String()\n   547→\tassert.Contains(t, body, \"Container removed\")\n   548→\tassert.Contains(t, body, `badge-pending\">Container removed`)\n   549→}\n   550→\n   551→func TestAPIDeleteContainer_Success(t *testing.T) {\n   552→\th, store, mgr := setupHandlerWithContainerManager(t)\n   553→\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n   554→\n   555→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n   556→\tw := httptest.NewRecorder()\n   557→\th.ServeHTTP(w, req)\n   558→\n   559→\tassert.Equal(t, http.StatusOK, w.Code)\n   560→\n   561→\tvar resp map[string]string\n   562→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n   563→\tassert.Equal(t, \"ok\", resp[\"status\"])\n   564→\n   565→\t// Verify container was removed\n   566→\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n   567→\n   568→\t// Verify run was updated\n   569→\trun, err := store.GetRun(context.Background(), \"run-del1\")\n   570→\trequire.NoError(t, err)\n   571→\tassert.False(t, run.ContainerKept)\n   572→}\n   573→\n   574→func TestAPIDeleteContainer_StoppedContainer(t *testing.T) {\n   575→\th, store, mgr := setupHandlerWithContainerManager(t)\n   576→\n   577→\tctx := context.Background()\n   578→\trun := domain.NewRun(\"run-del-stopped\", \"develop\")\n   579→\trun.ProjectDir = \"/proj\"\n   580→\trun.Start()\n   581→\trun.ContainerID = \"cid-stopped-del\"\n   582→\trun.ContainerKept = false\n   583→\trun.Complete(domain.RunStateFailed)\n   584→\trequire.NoError(t, store.CreateRun(ctx, run))\n   585→\tmgr.containers[\"cid-stopped-del\"] = true\n   586→\n   587→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del-stopped/container\", nil)\n   588→\tw := httptest.NewRecorder()\n   589→\th.ServeHTTP(w, req)\n   590→\n   591→\tassert.Equal(t, http.StatusOK, w.Code)\n   592→\n   593→\tvar resp map[string]string\n   594→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n   595→\tassert.Equal(t, \"ok\", resp[\"status\"])\n   596→\tassert.Contains(t, mgr.removed, \"cid-stopped-del\")\n   597→}\n   598→\n   599→func TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n   600→\th, _, _ := setupHandlerWithContainerManager(t)\n   601→\n   602→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n   603→\tw := httptest.NewRecorder()\n   604→\th.ServeHTTP(w, req)\n   605→\n   606→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   607→}\n   608→\n   609→func TestAPIDeleteContainer_NoManager(t *testing.T) {\n   610→\th, store := setupHandler(t) // no container manager\n   611→\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n   612→\n   613→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n   614→\tw := httptest.NewRecorder()\n   615→\th.ServeHTTP(w, req)\n   616→\n   617→\tassert.Equal(t, http.StatusBadRequest, w.Code)\n   618→}\n   619→\n   620→func TestAPIRunDetail_ContainerState(t *testing.T) {\n   621→\th, store, mgr := setupHandlerWithContainerManager(t)\n   622→\n   623→\t// Seed a running container\n   624→\tctx := context.Background()\n   625→\trun := domain.NewRun(\"api-cs1\", \"develop\")\n   626→\trun.ProjectDir = \"/proj\"\n   627→\trun.Start()\n   628→\trun.ContainerID = \"cid-api-running\"\n   629→\trequire.NoError(t, store.CreateRun(ctx, run))\n   630→\tmgr.containers[\"cid-api-running\"] = true\n   631→\tmgr.running[\"cid-api-running\"] = true\n   632→\n   633→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n   634→\tw := httptest.NewRecorder()\n   635→\th.ServeHTTP(w, req)\n   636→\n   637→\tassert.Equal(t, http.StatusOK, w.Code)\n   638→\n   639→\tvar detail apiRunDetail\n   640→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   641→\tassert.Equal(t, \"running\", detail.ContainerState)\n   642→\n   643→\t// Now stop it\n   644→\tmgr.running[\"cid-api-running\"] = false\n   645→\n   646→\tw = httptest.NewRecorder()\n   647→\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n   648→\n   649→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   650→\tassert.Equal(t, \"stopped\", detail.ContainerState)\n   651→}\n   652→\n   653→func TestRunsList_ContainerCount(t *testing.T) {\n   654→\th, store, mgr := setupHandlerWithContainerManager(t)\n   655→\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n   656→\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n   657→\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n   658→\n   659→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   660→\tw := httptest.NewRecorder()\n   661→\th.ServeHTTP(w, req)\n   662→\n   663→\tassert.Equal(t, http.StatusOK, w.Code)\n   664→\tbody := w.Body.String()\n   665→\t// alpha has 2 retained containers\n   666→\tassert.Contains(t, body, \"2 containers\")\n   667→\t// beta has 0, so no count should appear\n   668→\tassert.NotContains(t, body, \"0 container\")\n   669→}\n   670→\n   671→func TestAPIProjects(t *testing.T) {\n   672→\th, store := setupHandler(t)\n   673→\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   674→\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   675→\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   676→\n   677→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   678→\tw := httptest.NewRecorder()\n   679→\th.ServeHTTP(w, req)\n   680→\tassert.Equal(t, http.StatusOK, w.Code)\n   681→\n   682→\ttype apiHealth struct {\n   683→\t\tStatus string `json:\"status\"`\n   684→\t\tPassed int    `json:\"passed\"`\n   685→\t\tFailed int    `json:\"failed\"`\n   686→\t\tTotal  int    `json:\"total\"`\n   687→\t}\n   688→\ttype project struct {\n   689→\t\tDir         string    `json:\"dir\"`\n   690→\t\tLabel       string    `json:\"label\"`\n   691→\t\tHealth      apiHealth `json:\"health\"`\n   692→\t\tActiveCount int       `json:\"active_count\"`\n   693→\t}\n   694→\tvar projects []project\n   695→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   696→\tassert.Len(t, projects, 2)\n   697→\n   698→\tbyDir := map[string]project{}\n   699→\tfor _, p := range projects {\n   700→\t\tbyDir[p.Dir] = p\n   701→\t}\n   702→\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n   703→\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n   704→\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n   705→\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n   706→\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n   707→\t// beta has 1 running = blue (all in-progress), 1 active\n   708→\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n   709→\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n   710→}\n   711→\n   712→func TestProjectOverview_WithProjects(t *testing.T) {\n   713→\th, store := setupHandler(t)\n   714→\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   715→\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   716→\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   717→\n   718→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   719→\tw := httptest.NewRecorder()\n   720→\th.ServeHTTP(w, req)\n   721→\n   722→\tassert.Equal(t, http.StatusOK, w.Code)\n   723→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   724→\tbody := w.Body.String()\n   725→\t// Project cards should be present\n   726→\tassert.Contains(t, body, \"project-card\")\n   727→\tassert.Contains(t, body, \"alpha\")\n   728→\tassert.Contains(t, body, \"beta\")\n   729→\t// Health dots\n   730→\tassert.Contains(t, body, \"health-dot\")\n   731→\t// Run history dots\n   732→\tassert.Contains(t, body, \"run-dot\")\n   733→\t// Quick actions\n   734→\tassert.Contains(t, body, \"View Runs\")\n   735→}\n   736→\n   737→func TestProjectOverview_Empty(t *testing.T) {\n   738→\th, _ := setupHandler(t)\n   739→\n   740→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   741→\tw := httptest.NewRecorder()\n   742→\th.ServeHTTP(w, req)\n   743→\n   744→\tassert.Equal(t, http.StatusOK, w.Code)\n   745→\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n   746→}\n   747→\n   748→func TestHealthColor(t *testing.T) {\n   749→\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n   750→\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n   751→\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n   752→\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n   753→\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n   754→\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n   755→}\n   756→\n   757→func TestAPIProjects_HealthData(t *testing.T) {\n   758→\th, store := setupHandler(t)\n   759→\t// alpha: 3 succeeded, 1 failed → yellow\n   760→\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   761→\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   762→\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   763→\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   764→\n   765→\t// beta: all succeeded → green\n   766→\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   767→\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   768→\n   769→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   770→\tw := httptest.NewRecorder()\n   771→\th.ServeHTTP(w, req)\n   772→\tassert.Equal(t, http.StatusOK, w.Code)\n   773→\n   774→\ttype health struct {\n   775→\t\tStatus string `json:\"status\"`\n   776→\t\tPassed int    `json:\"passed\"`\n   777→\t\tFailed int    `json:\"failed\"`\n   778→\t\tTotal  int    `json:\"total\"`\n   779→\t}\n   780→\ttype project struct {\n   781→\t\tDir    string `json:\"dir\"`\n   782→\t\tLabel  string `json:\"label\"`\n   783→\t\tHealth health `json:\"health\"`\n   784→\t}\n   785→\tvar projects []project\n   786→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   787→\tassert.Len(t, projects, 2)\n   788→\n   789→\tbyDir := map[string]project{}\n   790→\tfor _, p := range projects {\n   791→\t\tbyDir[p.Dir] = p\n   792→\t}\n   793→\n   794→\talpha := byDir[\"/home/user/alpha\"]\n   795→\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n   796→\tassert.Equal(t, 3, alpha.Health.Passed)\n   797→\tassert.Equal(t, 1, alpha.Health.Failed)\n   798→\tassert.Equal(t, 4, alpha.Health.Total)\n   799→\n   800→\tbeta := byDir[\"/home/user/beta\"]\n   801→\tassert.Equal(t, \"green\", beta.Health.Status)\n   802→\tassert.Equal(t, 2, beta.Health.Passed)\n   803→\tassert.Equal(t, 0, beta.Health.Failed)\n   804→\tassert.Equal(t, 2, beta.Health.Total)\n   805→}\n   806→\n   807→func TestResolveFileRef(t *testing.T) {\n   808→\t// Create a temp directory with a test file\n   809→\tdir := t.TempDir()\n   810→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \"prompts\"), 0o755))\n   811→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \"prompts\", \"implement.md\"), []byte(\"# Implement\\nDo the thing.\"), 0o644))\n   812→\n   813→\tt.Run(\"file() reference resolves to contents\", func(t *testing.T) {\n   814→\t\tcontent, err := resolveFileRef(`file(\"prompts/implement.md\")`, dir)\n   815→\t\trequire.NoError(t, err)\n   816→\t\tassert.Equal(t, \"# Implement\\nDo the thing.\", content)\n   817→\t})\n   818→\n   819→\tt.Run(\"file() reference with missing file returns error\", func(t *testing.T) {\n   820→\t\t_, err := resolveFileRef(`file(\"prompts/nonexistent.md\")`, dir)\n   821→\t\tassert.Error(t, err)\n   822→\t})\n   823→\n   824→\tt.Run(\"plain string returned as-is\", func(t *testing.T) {\n   825→\t\tcontent, err := resolveFileRef(\"echo hello\", dir)\n   826→\t\trequire.NoError(t, err)\n   827→\t\tassert.Equal(t, \"echo hello\", content)\n   828→\t})\n   829→\n   830→\tt.Run(\"quoted string returned as-is\", func(t *testing.T) {\n   831→\t\tcontent, err := resolveFileRef(`\"some value\"`, dir)\n   832→\t\trequire.NoError(t, err)\n   833→\t\tassert.Equal(t, `\"some value\"`, content)\n   834→\t})\n   835→}\n   836→\n   837→func TestAPIStepContent_FileRef(t *testing.T) {\n   838→\th, store := setupHandler(t)\n   839→\n   840→\t// Create a temp project directory with a workflow and prompt file\n   841→\tdir := t.TempDir()\n   842→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0o755))\n   843→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"Build the feature.\"), 0o644))\n   844→\n   845→\tworkflowContent := `workflow \"develop\" {\n   846→    step implement {\n   847→        prompt = file(\".cloche/prompts/implement.md\")\n   848→        results = [success, fail]\n   849→    }\n   850→    implement:success -> done\n   851→    implement:fail -> abort\n   852→}\n   853→`\n   854→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"), []byte(workflowContent), 0o644))\n   855→\n   856→\t// Seed a run so the project is known\n   857→\tseedRunWithProject(t, store, \"sc-1\", \"develop\", domain.RunStateRunning, dir)\n   858→\n   859→\t// Request step content\n   860→\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+filepath.Base(dir)+\"/workflows/develop/steps/implement/content\", nil)\n   861→\tw := httptest.NewRecorder()\n   862→\th.ServeHTTP(w, req)\n   863→\n   864→\tassert.Equal(t, http.StatusOK, w.Code)\n   865→\tassert.Equal(t, \"Build the feature.\", w.Body.String())\n   866→}\n   867→\n   868→func TestAPIStopRun_Success(t *testing.T) {\n   869→\th, store, mgr := setupHandlerWithContainerManager(t)\n   870→\n   871→\tctx := context.Background()\n   872→\trun := domain.NewRun(\"run-stop-1\", \"develop\")\n   873→\trun.ProjectDir = \"/proj\"\n   874→\trun.Start()\n   875→\trun.ContainerID = \"cid-to-stop\"\n   876→\trequire.NoError(t, store.CreateRun(ctx, run))\n   877→\tmgr.containers[\"cid-to-stop\"] = true\n   878→\tmgr.running[\"cid-to-stop\"] = true\n   879→\n   880→\treq := httptest.NewRequest(\"POST\", \"/api/runs/run-stop-1/stop\", nil)\n   881→\tw := httptest.NewRecorder()\n   882→\th.ServeHTTP(w, req)\n   883→\n   884→\tassert.Equal(t, http.StatusOK, w.Code)\n   885→\n   886→\tvar resp map[string]string\n   887→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n   888→\tassert.Equal(t, \"ok\", resp[\"status\"])\n   889→\n   890→\t// Verify container was stopped\n   891→\tassert.Contains(t, mgr.stopped, \"cid-to-stop\")\n   892→\n   893→\t// Verify run state is cancelled\n   894→\tupdated, err := store.GetRun(ctx, \"run-stop-1\")\n   895→\trequire.NoError(t, err)\n   896→\tassert.Equal(t, domain.RunStateCancelled, updated.State)\n   897→}\n   898→\n   899→func TestAPIStopRun_NotActive(t *testing.T) {\n   900→\th, store, mgr := setupHandlerWithContainerManager(t)\n   901→\tseedRunWithContainer(t, store, mgr, \"run-stop-done\", \"develop\", \"/proj\", \"cid-done\", false)\n   902→\n   903→\treq := httptest.NewRequest(\"POST\", \"/api/runs/run-stop-done/stop\", nil)\n   904→\tw := httptest.NewRecorder()\n   905→\th.ServeHTTP(w, req)\n   906→\n   907→\tassert.Equal(t, http.StatusBadRequest, w.Code)\n   908→\n   909→\tvar resp map[string]string\n   910→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n   911→\tassert.Contains(t, resp[\"error\"], \"not active\")\n   912→}\n   913→\n   914→func TestAPIStopRun_NotFound(t *testing.T) {\n   915→\th, _, _ := setupHandlerWithContainerManager(t)\n   916→\n   917→\treq := httptest.NewRequest(\"POST\", \"/api/runs/nonexistent/stop\", nil)\n   918→\tw := httptest.NewRecorder()\n   919→\th.ServeHTTP(w, req)\n   920→\n   921→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   922→}\n   923→\n   924→func TestAPIStopRun_NoManager(t *testing.T) {\n   925→\th, store := setupHandler(t) // no container manager\n   926→\tseedRun(t, store, \"run-stop-noman\", \"develop\", domain.RunStateRunning)\n   927→\n   928→\treq := httptest.NewRequest(\"POST\", \"/api/runs/run-stop-noman/stop\", nil)\n   929→\tw := httptest.NewRecorder()\n   930→\th.ServeHTTP(w, req)\n   931→\n   932→\tassert.Equal(t, http.StatusBadRequest, w.Code)\n   933→}\n   934→\n   935→func TestRunDetail_CancelButton_ShownForActiveRuns(t *testing.T) {\n   936→\th, store, mgr := setupHandlerWithContainerManager(t)\n   937→\n   938→\tctx := context.Background()\n   939→\trun := domain.NewRun(\"run-cancel-btn\", \"develop\")\n   940→\trun.ProjectDir = \"/proj\"\n   941→\trun.Start()\n   942→\trun.ContainerID = \"cid-cancel\"\n   943→\trequire.NoError(t, store.CreateRun(ctx, run))\n   944→\tmgr.containers[\"cid-cancel\"] = true\n   945→\tmgr.running[\"cid-cancel\"] = true\n   946→\n   947→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cancel-btn\", nil)\n   948→\tw := httptest.NewRecorder()\n   949→\th.ServeHTTP(w, req)\n   950→\n   951→\tassert.Equal(t, http.StatusOK, w.Code)\n   952→\tbody := w.Body.String()\n   953→\tassert.Contains(t, body, `id=\"cancel-run-btn\"`)\n   954→\tassert.Contains(t, body, \"Cancel\")\n   955→}\n   956→\n   957→func TestRunDetail_CancelButton_HiddenForTerminalRuns(t *testing.T) {\n   958→\th, store, mgr := setupHandlerWithContainerManager(t)\n   959→\tseedRunWithContainer(t, store, mgr, \"run-no-cancel\", \"develop\", \"/proj\", \"cid-terminal\", false)\n   960→\n   961→\treq := httptest.NewRequest(\"GET\", \"/runs/run-no-cancel\", nil)\n   962→\tw := httptest.NewRecorder()\n   963→\th.ServeHTTP(w, req)\n   964→\n   965→\tassert.Equal(t, http.StatusOK, w.Code)\n   966→\tbody := w.Body.String()\n   967→\t// The cancel button ID should not appear in the HTML header section\n   968→\t// (it may appear in the JS as a string literal, so check the h1 area)\n   969→\th1Start := strings.Index(body, \"<h1>\")\n   970→\th1End := strings.Index(body, \"</h1>\")\n   971→\trequire.NotEqual(t, -1, h1Start)\n   972→\trequire.NotEqual(t, -1, h1End)\n   973→\th1Section := body[h1Start : h1End+len(\"</h1>\")]\n   974→\tassert.NotContains(t, h1Section, `id=\"cancel-run-btn\"`)\n   975→}\n   976→\n   977→func TestAPIProjects_HealthNoRuns(t *testing.T) {\n   978→\th, _ := setupHandler(t)\n   979→\n   980→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   981→\tw := httptest.NewRecorder()\n   982→\th.ServeHTTP(w, req)\n   983→\tassert.Equal(t, http.StatusOK, w.Code)\n   984→\n   985→\t// No projects means empty array\n   986→\ttype project struct {\n   987→\t\tDir   string `json:\"dir\"`\n   988→\t\tLabel string `json:\"label\"`\n   989→\t}\n   990→\tvar projects []project\n   991→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   992→\tassert.Empty(t, projects)\n   993→}\n   994→"}]},"parent_tool_use_id":null,"session_id":"88dee606-b80e-44b4-9205-0d160e19ebe3","uuid":"142dc0ec-bf50-493a-9c8a-1bee3431fc42","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler_test.go","content":"package web\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// mockContainerManager implements ContainerManager for testing.\ntype mockContainerManager struct {\n\tcontainers map[string]bool // containerID -> exists\n\trunning    map[string]bool // containerID -> running\n\tremoved    []string\n\tstopped    []string\n}\n\nfunc newMockContainerManager() *mockContainerManager {\n\treturn &mockContainerManager{\n\t\tcontainers: map[string]bool{},\n\t\trunning:    map[string]bool{},\n\t}\n}\n\nfunc (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n\treturn \"mock logs\", nil\n}\n\nfunc (m *mockContainerManager) Stop(_ context.Context, containerID string) error {\n\tif !m.containers[containerID] {\n\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\tm.running[containerID] = false\n\tm.stopped = append(m.stopped, containerID)\n\treturn nil\n}\n\nfunc (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n\tif !m.containers[containerID] {\n\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\tdelete(m.containers, containerID)\n\tm.removed = append(m.removed, containerID)\n\treturn nil\n}\n\nfunc (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n\tif !m.containers[containerID] {\n\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n}\n\nfunc setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store)\n\trequire.NoError(t, err)\n\treturn h, store\n}\n\nfunc seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n\tt.Helper()\n\tseedRunWithProject(t, store, id, workflow, state, \"\")\n}\n\nfunc seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\tif state != domain.RunStatePending {\n\t\trun.Start()\n\t\trun.ContainerID = \"abc123def456789\"\n\t}\n\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n\t\trun.Complete(state)\n\t}\n\tif state == domain.RunStateFailed {\n\t\trun.ErrorMessage = \"something went wrong\"\n\t}\n\trequire.NoError(t, store.CreateRun(ctx, run))\n}\n\nfunc TestRunsList_WithRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"test-run-1\")\n\tassert.Contains(t, body, \"test-run-2\")\n\tassert.Contains(t, body, \"badge-running\")\n\tassert.Contains(t, body, \"badge-succeeded\")\n\tassert.Contains(t, body, \"develop\")\n\tassert.Contains(t, body, \"deploy\")\n}\n\nfunc TestRunsList_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n}\n\nfunc TestRunDetail_WithCaptures(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"implement\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-detail-1\")\n\tassert.Contains(t, body, \"implement\")\n}\n\nfunc TestRunDetail_AccordionStatePreserved(t *testing.T) {\n\t// Verify the rendered page includes JavaScript that preserves accordion state\n\t// during SSE polling updates (captures open/closed state before DOM rebuild).\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"run-accordion-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"run-accordion-1\", &domain.StepExecution{\n\t\tStepName:    \"build\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-accordion-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\n\t// The poll function should capture accordion state before rebuilding the DOM\n\tassert.Contains(t, body, \"openAccordions\")\n\tassert.Contains(t, body, \"loadedOutputs\")\n\t// Verify it restores loaded output content after DOM rebuild\n\tassert.Contains(t, body, \"loadedOutputs[key]\")\n}\n\nfunc TestRunDetail_NotFound(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar runs []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n\tassert.Len(t, runs, 2)\n\n\tids := map[string]bool{}\n\tfor _, r := range runs {\n\t\tids[r.ID] = true\n\t}\n\tassert.True(t, ids[\"api-run-1\"])\n\tassert.True(t, ids[\"api-run-2\"])\n}\n\nfunc TestAPIRunDetail(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"build\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"api-detail-1\", detail.ID)\n\tassert.Equal(t, \"running\", detail.State)\n\tassert.Len(t, detail.Steps, 1)\n\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n\tassert.NotEmpty(t, detail.Steps[0].Duration)\n}\n\nfunc TestStaticCSS(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \":root\")\n\tassert.Contains(t, w.Body.String(), \"badge-running\")\n}\n\nfunc TestHelpers(t *testing.T) {\n\tt.Run(\"stateColor\", func(t *testing.T) {\n\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n\t})\n\n\tt.Run(\"formatTime\", func(t *testing.T) {\n\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n\t})\n\n\tt.Run(\"formatDuration\", func(t *testing.T) {\n\t\tnow := time.Now()\n\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n\t})\n\n\tt.Run(\"truncate\", func(t *testing.T) {\n\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n\t})\n\n\tt.Run(\"shortContainerID\", func(t *testing.T) {\n\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n\t})\n\n\tt.Run(\"projectLabels\", func(t *testing.T) {\n\t\t// No conflict: show base name only\n\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n\n\t\t// Conflict: two dirs share the same base name\n\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n\n\t\t// Mixed: some conflict, some don't\n\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n\n\t\t// Empty list\n\t\tlabels = projectLabels(nil)\n\t\tassert.Empty(t, labels)\n\t})\n}\n\nfunc TestRunsList_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs shown\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-b1\")\n\n\t// With project filter: only matching runs\n\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody = w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-a2\")\n\tassert.NotContains(t, body, \"run-b1\")\n}\n\nfunc TestRunsList_ProjectColumn(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"myproject\")\n\tassert.Contains(t, body, \"Project\")\n}\n\nfunc TestAPIRuns_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar allRuns []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n\tassert.Len(t, allRuns, 2)\n\n\t// With filter: only matching\n\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar filtered []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n\tassert.Len(t, filtered, 1)\n\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n}\n\nfunc setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\tmgr := newMockContainerManager()\n\th, err := NewHandler(store, store, WithContainerManager(mgr))\n\trequire.NoError(t, err)\n\treturn h, store, mgr\n}\n\nfunc seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\trun.Start()\n\trun.ContainerID = containerID\n\trun.ContainerKept = kept\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tif kept {\n\t\tmgr.containers[containerID] = true\n\t}\n}\n\nfunc TestRunDetail_ContainerRunning(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cr\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-running\"] = true\n\tmgr.running[\"cid-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container running\")\n\tassert.Contains(t, body, `badge-running\">Container running`)\n}\n\nfunc TestRunDetail_ContainerStopped(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cs\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-stopped\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container stopped\")\n\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n}\n\nfunc TestRunDetail_ContainerStoppedTerminal_ShowsDeleteButton(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tfor _, state := range []domain.RunState{domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled} {\n\t\tt.Run(string(state), func(t *testing.T) {\n\t\t\tid := \"run-cst-\" + string(state)\n\t\t\tctx := context.Background()\n\t\t\trun := domain.NewRun(id, \"develop\")\n\t\t\trun.ProjectDir = \"/proj\"\n\t\t\trun.Start()\n\t\t\trun.ContainerID = \"cid-stopped-\" + string(state)\n\t\t\trun.ContainerKept = false\n\t\t\trun.Complete(state)\n\t\t\trequire.NoError(t, store.CreateRun(ctx, run))\n\t\t\tmgr.containers[run.ContainerID] = true // container exists but not running, not kept\n\n\t\t\treq := httptest.NewRequest(\"GET\", \"/runs/\"+id, nil)\n\t\t\tw := httptest.NewRecorder()\n\t\t\th.ServeHTTP(w, req)\n\n\t\t\tassert.Equal(t, http.StatusOK, w.Code)\n\t\t\tbody := w.Body.String()\n\t\t\tassert.Contains(t, body, \"Container stopped\")\n\t\t\tassert.Contains(t, body, `id=\"delete-container-btn\"`, \"should show delete button for terminal run with stopped container\")\n\t\t})\n\t}\n}\n\nfunc TestRunDetail_ContainerStoppedRunning_NoDeleteButton(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-csr\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-stopped-running\"\n\trun.ContainerKept = false\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-stopped-running\"] = true\n\t// container not running, but run state is still \"running\" (not terminal)\n\t// containerState will return \"stopped\" since ContainerKept=false\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-csr\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container stopped\")\n\t// The HTML container-status section should NOT have the delete button.\n\t// We check the dd#container-status block specifically, not the full body\n\t// (which includes JS that references the button ID as string literals).\n\tstatusStart := \"container-status\"\n\tstatusEnd := \"</dd>\"\n\tidx := strings.Index(body, statusStart)\n\trequire.NotEqual(t, -1, idx, \"container-status element must exist\")\n\tendIdx := strings.Index(body[idx:], statusEnd)\n\trequire.NotEqual(t, -1, endIdx, \"closing </dd> must exist\")\n\tstatusSection := body[idx : idx+endIdx+len(statusEnd)]\n\tassert.NotContains(t, statusSection, \"Delete Container\", \"should NOT show delete button for non-terminal run\")\n}\n\nfunc TestRunDetail_ContainerAvailable(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container available\")\n\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n}\n\nfunc TestRunDetail_ContainerRemoved(t *testing.T) {\n\th, store, _ := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-c2\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-gone\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container removed\")\n\tassert.Contains(t, body, `badge-pending\">Container removed`)\n}\n\nfunc TestAPIDeleteContainer_Success(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"ok\", resp[\"status\"])\n\n\t// Verify container was removed\n\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n\n\t// Verify run was updated\n\trun, err := store.GetRun(context.Background(), \"run-del1\")\n\trequire.NoError(t, err)\n\tassert.False(t, run.ContainerKept)\n}\n\nfunc TestAPIDeleteContainer_StoppedContainer(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-del-stopped\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-stopped-del\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateFailed)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-stopped-del\"] = true\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del-stopped/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"ok\", resp[\"status\"])\n\tassert.Contains(t, mgr.removed, \"cid-stopped-del\")\n}\n\nfunc TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n\th, _, _ := setupHandlerWithContainerManager(t)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIDeleteContainer_NoManager(t *testing.T) {\n\th, store := setupHandler(t) // no container manager\n\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusBadRequest, w.Code)\n}\n\nfunc TestAPIRunDetail_ContainerState(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\t// Seed a running container\n\tctx := context.Background()\n\trun := domain.NewRun(\"api-cs1\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-api-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-api-running\"] = true\n\tmgr.running[\"cid-api-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"running\", detail.ContainerState)\n\n\t// Now stop it\n\tmgr.running[\"cid-api-running\"] = false\n\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"stopped\", detail.ContainerState)\n}\n\nfunc TestRunsList_ContainerCount(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\t// alpha has 2 retained containers\n\tassert.Contains(t, body, \"2 containers\")\n\t// beta has 0, so no count should appear\n\tassert.NotContains(t, body, \"0 container\")\n}\n\nfunc TestAPIProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n\t// beta has 1 running = blue (all in-progress), 1 active\n\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n}\n\nfunc TestProjectOverview_WithProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\t// Project cards should be present\n\tassert.Contains(t, body, \"project-card\")\n\tassert.Contains(t, body, \"alpha\")\n\tassert.Contains(t, body, \"beta\")\n\t// Health dots\n\tassert.Contains(t, body, \"health-dot\")\n\t// Run history dots\n\tassert.Contains(t, body, \"run-dot\")\n\t// Quick actions\n\tassert.Contains(t, body, \"View Runs\")\n}\n\nfunc TestProjectOverview_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n}\n\nfunc TestHealthColor(t *testing.T) {\n\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n}\n\nfunc TestAPIProjects_HealthData(t *testing.T) {\n\th, store := setupHandler(t)\n\t// alpha: 3 succeeded, 1 failed → yellow\n\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\t// beta: all succeeded → green\n\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype health struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir    string `json:\"dir\"`\n\t\tLabel  string `json:\"label\"`\n\t\tHealth health `json:\"health\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\n\talpha := byDir[\"/home/user/alpha\"]\n\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n\tassert.Equal(t, 3, alpha.Health.Passed)\n\tassert.Equal(t, 1, alpha.Health.Failed)\n\tassert.Equal(t, 4, alpha.Health.Total)\n\n\tbeta := byDir[\"/home/user/beta\"]\n\tassert.Equal(t, \"green\", beta.Health.Status)\n\tassert.Equal(t, 2, beta.Health.Passed)\n\tassert.Equal(t, 0, beta.Health.Failed)\n\tassert.Equal(t, 2, beta.Health.Total)\n}\n\nfunc TestResolveFileRef(t *testing.T) {\n\t// Create a temp directory with a test file\n\tdir := t.TempDir()\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \"prompts\"), 0o755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \"prompts\", \"implement.md\"), []byte(\"# Implement\\nDo the thing.\"), 0o644))\n\n\tt.Run(\"file() reference resolves to contents\", func(t *testing.T) {\n\t\tcontent, err := resolveFileRef(`file(\"prompts/implement.md\")`, dir)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, \"# Implement\\nDo the thing.\", content)\n\t})\n\n\tt.Run(\"file() reference with missing file returns error\", func(t *testing.T) {\n\t\t_, err := resolveFileRef(`file(\"prompts/nonexistent.md\")`, dir)\n\t\tassert.Error(t, err)\n\t})\n\n\tt.Run(\"plain string returned as-is\", func(t *testing.T) {\n\t\tcontent, err := resolveFileRef(\"echo hello\", dir)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, \"echo hello\", content)\n\t})\n\n\tt.Run(\"quoted string returned as-is\", func(t *testing.T) {\n\t\tcontent, err := resolveFileRef(`\"some value\"`, dir)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, `\"some value\"`, content)\n\t})\n}\n\nfunc TestAPIStepContent_FileRef(t *testing.T) {\n\th, store := setupHandler(t)\n\n\t// Create a temp project directory with a workflow and prompt file\n\tdir := t.TempDir()\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0o755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"Build the feature.\"), 0o644))\n\n\tworkflowContent := `workflow \"develop\" {\n    step implement {\n        prompt = file(\".cloche/prompts/implement.md\")\n        results = [success, fail]\n    }\n    implement:success -> done\n    implement:fail -> abort\n}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"), []byte(workflowContent), 0o644))\n\n\t// Seed a run so the project is known\n\tseedRunWithProject(t, store, \"sc-1\", \"develop\", domain.RunStateRunning, dir)\n\n\t// Request step content\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+filepath.Base(dir)+\"/workflows/develop/steps/implement/content\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Equal(t, \"Build the feature.\", w.Body.String())\n}\n\nfunc TestAPIStopRun_Success(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-stop-1\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-to-stop\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-to-stop\"] = true\n\tmgr.running[\"cid-to-stop\"] = true\n\n\treq := httptest.NewRequest(\"POST\", \"/api/runs/run-stop-1/stop\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"ok\", resp[\"status\"])\n\n\t// Verify container was stopped\n\tassert.Contains(t, mgr.stopped, \"cid-to-stop\")\n\n\t// Verify run state is cancelled\n\tupdated, err := store.GetRun(ctx, \"run-stop-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateCancelled, updated.State)\n}\n\nfunc TestAPIStopRun_NotActive(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-stop-done\", \"develop\", \"/proj\", \"cid-done\", false)\n\n\treq := httptest.NewRequest(\"POST\", \"/api/runs/run-stop-done/stop\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusBadRequest, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Contains(t, resp[\"error\"], \"not active\")\n}\n\nfunc TestAPIStopRun_NotFound(t *testing.T) {\n\th, _, _ := setupHandlerWithContainerManager(t)\n\n\treq := httptest.NewRequest(\"POST\", \"/api/runs/nonexistent/stop\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIStopRun_NoManager(t *testing.T) {\n\th, store := setupHandler(t) // no container manager\n\tseedRun(t, store, \"run-stop-noman\", \"develop\", domain.RunStateRunning)\n\n\treq := httptest.NewRequest(\"POST\", \"/api/runs/run-stop-noman/stop\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusBadRequest, w.Code)\n}\n\nfunc TestRunDetail_CancelButton_ShownForActiveRuns(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cancel-btn\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-cancel\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-cancel\"] = true\n\tmgr.running[\"cid-cancel\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cancel-btn\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, `id=\"cancel-run-btn\"`)\n\tassert.Contains(t, body, \"Cancel\")\n}\n\nfunc TestRunDetail_CancelButton_HiddenForTerminalRuns(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-no-cancel\", \"develop\", \"/proj\", \"cid-terminal\", false)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-no-cancel\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\t// The cancel button ID should not appear in the HTML header section\n\t// (it may appear in the JS as a string literal, so check the h1 area)\n\th1Start := strings.Index(body, \"<h1>\")\n\th1End := strings.Index(body, \"</h1>\")\n\trequire.NotEqual(t, -1, h1Start)\n\trequire.NotEqual(t, -1, h1End)\n\th1Section := body[h1Start : h1End+len(\"</h1>\")]\n\tassert.NotContains(t, h1Section, `id=\"cancel-run-btn\"`)\n}\n\nfunc TestAPIProjects_HealthNoRuns(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\t// No projects means empty array\n\ttype project struct {\n\t\tDir   string `json:\"dir\"`\n\t\tLabel string `json:\"label\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Empty(t, projects)\n}\n","numLines":994,"startLine":1,"totalLines":994}}}
