NULL,\n    59→\t\t\tstep_name TEXT NOT NULL,\n    60→\t\t\tresult TEXT,\n    61→\t\t\tstarted_at TEXT NOT NULL,\n    62→\t\t\tcompleted_at TEXT,\n    63→\t\t\tlogs TEXT,\n    64→\t\t\tgit_ref TEXT,\n    65→\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    66→\t\t);\n    67→\t`)\n    68→\tif err != nil {\n    69→\t\treturn err\n    70→\t}\n    71→\n    72→\t// Evolution schema additions (idempotent)\n    73→\talterStmts := []string{\n    74→\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n    75→\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n    76→\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n    77→\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n    78→\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n    79→\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n    80→\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n    81→\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n    82→\t\t`ALTER TABLE runs ADD COLUMN title TEXT NOT NULL DEFAULT ''`,\n    83→\t\t`ALTER TABLE runs ADD COLUMN is_host INTEGER NOT NULL DEFAULT 0`,\n    84→\t}\n    85→\tfor _, stmt := range alterStmts {\n    86→\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n    87→\t}\n    88→\n    89→\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n    90→\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    91→\t\trun_id TEXT NOT NULL,\n    92→\t\tstep_name TEXT,\n    93→\t\tfile_type TEXT NOT NULL,\n    94→\t\tfile_path TEXT NOT NULL,\n    95→\t\tfile_size INTEGER,\n    96→\t\tcreated_at TEXT NOT NULL,\n    97→\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    98→\t)`)\n    99→\tif errLog != nil {\n   100→\t\treturn errLog\n   101→\t}\n   102→\n   103→\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n   104→\t\trun_id TEXT PRIMARY KEY,\n   105→\t\tbranch TEXT NOT NULL,\n   106→\t\tproject TEXT NOT NULL,\n   107→\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n   108→\t\tenqueued_at TEXT NOT NULL,\n   109→\t\tcompleted_at TEXT\n   110→\t)`)\n   111→\tif errMQ != nil {\n   112→\t\treturn errMQ\n   113→\t}\n   114→\n   115→\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n   116→\t\tid TEXT PRIMARY KEY,\n   117→\t\tproject_dir TEXT NOT NULL,\n   118→\t\tworkflow_name TEXT NOT NULL,\n   119→\t\ttrigger_run_id TEXT NOT NULL,\n   120→\t\tcreated_at TEXT NOT NULL,\n   121→\t\tclassification TEXT,\n   122→\t\tchanges_json TEXT NOT NULL,\n   123→\t\tknowledge_delta TEXT\n   124→\t)`)\n   125→\tif err2 != nil {\n   126→\t\treturn err2\n   127→\t}\n   128→\n   129→\treturn nil\n   130→}\n   131→\n   132→func (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n   133→\t_, err := s.db.ExecContext(ctx,\n   134→\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept, title, is_host)\n   135→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   136→\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n   137→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, run.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost),\n   138→\t)\n   139→\treturn err\n   140→}\n   141→\n   142→// runSelectCols is the standard column list for scanning a Run row.\n   143→const runSelectCols = `id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,''), COALESCE(is_host,0)`\n   144→\n   145→// scanRun scans a single row into a *domain.Run.\n   146→func scanRun(scanner interface{ Scan(...any) error }) (*domain.Run, error) {\n   147→\trun := &domain.Run{}\n   148→\tvar activeSteps, startedAt, completedAt string\n   149→\tvar containerKept, isHost int\n   150→\terr := scanner.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title, &isHost)"}]},"parent_tool_use_id":"toolu_016jUx5DTeN7VJfgbeyCLgR1","session_id":"88dee606-b80e-44b4-9205-0d160e19ebe3","uuid":"0b972cf8-3fb9-4f63-b932-3f00f6b0502d"}
