[2026-03-10T16:32:15Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YHZyVTX3vxNNaNT3iez9op","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"net/url\"\n    13→\t\"os\"\n    14→\t\"os/exec\"\n    15→\t\"path/filepath\"\n    16→\t\"regexp\"\n    17→\t\"sort\"\n    18→\t\"strconv\"\n    19→\t\"strings\"\n    20→\t\"time\"\n    21→\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    24→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    25→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    26→)\n    27→\n    28→// HandlerOption configures optional Handler dependencies.\n    29→type HandlerOption func(*Handler)\n    30→\n    31→// WithContainerLogger sets the container runtime for fetching live logs.\n    32→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    33→\treturn func(h *Handler) { h.container = c }\n    34→}\n    35→\n    36→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    37→func WithContainerManager(c ContainerManager) HandlerOption {\n    38→\treturn func(h *Handler) { h.container = c }\n    39→}\n    40→\n    41→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    42→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    43→\treturn func(h *Handler) { h.logBroadcast = b }\n    44→}\n    45→\n    46→// WithLogStore sets the log store for indexed log file lookups.\n    47→func WithLogStore(ls ports.LogStore) HandlerOption {\n    48→\treturn func(h *Handler) { h.logStore = ls }\n    49→}\n    50→\n    51→//go:embed templates/*.html static/*\n    52→var content embed.FS\n    53→\n    54→// Handler serves the web dashboard.\n    55→// ContainerLogger can retrieve logs from a container by ID.\n    56→type ContainerLogger interface {\n    57→\tLogs(ctx context.Context, containerID string) (string, error)\n    58→}\n    59→\n    60→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    61→type ContainerManager interface {\n    62→\tContainerLogger\n    63→\tStop(ctx context.Context, containerID string) error\n    64→\tRemove(ctx context.Context, containerID string) error\n    65→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    66→}\n    67→\n    68→type Handler struct {\n    69→\tstore        ports.RunStore\n    70→\tcaptures     ports.CaptureStore\n    71→\tlogStore     ports.LogStore\n    72→\tcontainer    ContainerLogger\n    73→\tlogBroadcast *logstream.Broadcaster\n    74→\tpages        map[string]*template.Template\n    75→\tmux          *http.ServeMux\n    76→}\n    77→\n    78→// NewHandler creates a web dashboard handler.\n    79→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    80→\tfuncMap := template.FuncMap{\n    81→\t\t\"stateColor\":       stateColor,\n    82→\t\t\"healthColor\":      healthColor,\n    83→\t\t\"formatTime\":       formatTime,\n    84→\t\t\"formatDuration\":   formatDuration,\n    85→\t\t\"truncate\":         truncate,\n    86→\t\t\"shortContainerID\": shortContainerID,\n    87→\t}\n    88→\n    89→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n    90→\tif err != nil {\n    91→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n    92→\t}\n    93→\n    94→\tpages := map[string]*template.Template{}\n    95→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n    96→\t\tclone, err := base.Clone()\n    97→\t\tif err != nil {\n    98→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n    99→\t\t}\n   100→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   101→\t\tif err != nil {\n   102→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   103→\t\t}\n   104→\t\tpages[page] = clone\n   105→\t}\n   106→\n   107→\th := &Handler{\n   108→\t\tstore:    store,\n   109→\t\tcaptures: captures,\n   110→\t\tpages:    pages,\n   111→\t\tmux:      http.NewServeMux(),\n   112→\t}\n   113→\tfor _, opt := range opts {\n   114→\t\topt(h)\n   115→\t}\n   116→\n   117→\tstaticFS, err := fs.Sub(content, \"static\")\n   118→\tif err != nil {\n   119→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   120→\t}\n   121→\n   122→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   123→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   124→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   125→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   126→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   127→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   128→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   129→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   130→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   131→\th.mux.HandleFunc(\"POST /api/runs/{id}/stop\", h.handleAPIStopRun)\n   132→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   133→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   134→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   135→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   136→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   137→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   138→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   139→\n   140→\treturn h, nil\n   141→}\n   142→\n   143→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   144→\th.mux.ServeHTTP(w, r)\n   145→}\n   146→\n   147→// --- HTML handlers ---\n   148→\n   149→// projectOverviewEntry holds data for a single project card on the landing page.\n   150→type projectOverviewEntry struct {\n   151→\tDir         string\n   152→\tLabel       string\n   153→\tHealth      domain.HealthResult\n   154→\tRecentRuns  []recentRunDot\n   155→\tActiveCount int\n   156→}\n   157→\n   158→// recentRunDot is a minimal representation of a run for the mini history display.\n   159→type recentRunDot struct {\n   160→\tID    string\n   161→\tState string\n   162→}\n   163→\n   164→const healthWindowSize = 10\n   165→\n   166→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   167→\tprojects, _ := h.store.ListProjects(r.Context())\n   168→\tlabels := projectLabels(projects)\n   169→\n   170→\tvar entries []projectOverviewEntry\n   171→\tfor _, dir := range projects {\n   172→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   173→\t\tif err != nil {\n   174→\t\t\tcontinue\n   175→\t\t}\n   176→\n   177→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   178→\t\trunValues := make([]domain.Run, len(runs))\n   179→\t\tfor i, rr := range runs {\n   180→\t\t\trunValues[i] = *rr\n   181→\t\t}\n   182→\n   183→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   184→\n   185→\t\t// Take the last N runs for the mini history (most recent first).\n   186→\t\tn := healthWindowSize\n   187→\t\tif n > len(runs) {\n   188→\t\t\tn = len(runs)\n   189→\t\t}\n   190→\t\tdots := make([]recentRunDot, n)\n   191→\t\tfor i := 0; i < n; i++ {\n   192→\t\t\tdots[i] = recentRunDot{\n   193→\t\t\t\tID:    runs[i].ID,\n   194→\t\t\t\tState: string(runs[i].State),\n   195→\t\t\t}\n   196→\t\t}\n   197→\n   198→\t\tvar activeCount int\n   199→\t\tfor _, rr := range runs {\n   200→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   201→\t\t\t\tactiveCount++\n   202→\t\t\t}\n   203→\t\t}\n   204→\n   205→\t\tentries = append(entries, projectOverviewEntry{\n   206→\t\t\tDir:         dir,\n   207→\t\t\tLabel:       labels[dir],\n   208→\t\t\tHealth:      health,\n   209→\t\t\tRecentRuns:  dots,\n   210→\t\t\tActiveCount: activeCount,\n   211→\t\t})\n   212→\t}\n   213→\n   214→\tsort.Slice(entries, func(i, j int) bool {\n   215→\t\treturn entries[i].Label < entries[j].Label\n   216→\t})\n   217→\n   218→\tdata := map[string]any{\n   219→\t\t\"Title\":    \"Projects\",\n   220→\t\t\"Projects\": entries,\n   221→\t}\n   222→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   223→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   224→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   225→\t}\n   226→}\n   227→\n   228→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   229→\tprojectFilter := r.URL.Query().Get(\"project\")\n   230→\n   231→\tvar runs []*domain.Run\n   232→\tvar err error\n   233→\tif projectFilter != \"\" {\n   234→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   235→\t} else {\n   236→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   237→\t}\n   238→\tif err != nil {\n   239→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   240→\t\treturn\n   241→\t}\n   242→\n   243→\tprojects, _ := h.store.ListProjects(r.Context())\n   244→\tlabels := projectLabels(projects)\n   245→\n   246→\t// Count retained containers per project\n   247→\tcontainerCounts := map[string]int{}\n   248→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   249→\tfor _, run := range allRuns {\n   250→\t\tif run.ContainerKept {\n   251→\t\t\tcontainerCounts[run.ProjectDir]++\n   252→\t\t}\n   253→\t}\n   254→\n   255→\tvar projectList []projectEntry\n   256→\tfor _, dir := range projects {\n   257→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   258→\t}\n   259→\tsort.Slice(projectList, func(i, j int) bool {\n   260→\t\treturn projectList[i].Label < projectList[j].Label\n   261→\t})\n   262→\n   263→\tdata := map[string]any{\n   264→\t\t\"Title\":         \"Runs\",\n   265→\t\t\"Runs\":          runs,\n   266→\t\t\"Projects\":      projectList,\n   267→\t\t\"ProjectFilter\": projectFilter,\n   268→\t\t\"ProjectLabels\": labels,\n   269→\t}\n   270→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   271→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   272→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   273→\t}\n   274→}\n   275→\n   276→// handleProjectRuns redirects /projects/{name}/runs to /runs?project=<dir>.\n   277→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   278→\tdir, _, ok := h.resolveProjectDir(w, r)\n   279→\tif !ok {\n   280→\t\treturn\n   281→\t}\n   282→\thttp.Redirect(w, r, \"/runs?project=\"+url.QueryEscape(dir), http.StatusFound)\n   283→}\n   284→\n   285→// stepEntry is a merged view of a step execution for the template.\n   286→type stepEntry struct {\n   287→\tIndex     int\n   288→\tStepName  string\n   289→\tResult    string\n   290→\tStartedAt time.Time\n   291→\tDuration  string\n   292→}\n   293→\n   294→// mergeCaptures collapses started/completed capture pairs into single entries.\n   295→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   296→\tvar entries []stepEntry\n   297→\t// Track pending started rows by step name (LIFO for retries)\n   298→\tpending := map[string]*domain.StepExecution{}\n   299→\n   300→\tfor _, c := range caps {\n   301→\t\tif c.Result == \"\" {\n   302→\t\t\t// step_started row\n   303→\t\t\tpending[c.StepName] = c\n   304→\t\t\tcontinue\n   305→\t\t}\n   306→\t\t// step_completed row — merge with pending started if available\n   307→\t\tstartedAt := c.StartedAt\n   308→\t\tif started := pending[c.StepName]; started != nil {\n   309→\t\t\tstartedAt = started.StartedAt\n   310→\t\t\tdelete(pending, c.StepName)\n   311→\t\t}\n   312→\t\tentries = append(entries, stepEntry{\n   313→\t\t\tIndex:     len(entries),\n   314→\t\t\tStepName:  c.StepName,\n   315→\t\t\tResult:    c.Result,\n   316→\t\t\tStartedAt: startedAt,\n   317→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   318→\t\t})\n   319→\t}\n   320→\n   321→\t// Append any started-but-not-completed steps (still running)\n   322→\tfor _, c := range caps {\n   323→\t\tif c.Result == \"\" {\n   324→\t\t\tif _, used := pending[c.StepName]; !used {\n   325→\t\t\t\tcontinue\n   326→\t\t\t}\n   327→\t\t\tentries = append(entries, stepEntry{\n   328→\t\t\t\tIndex:     len(entries),\n   329→\t\t\t\tStepName:  c.StepName,\n   330→\t\t\t\tStartedAt: c.StartedAt,\n   331→\t\t\t})\n   332→\t\t\tdelete(pending, c.StepName)\n   333→\t\t}\n   334→\t}\n   335→\n   336→\treturn entries\n   337→}\n   338→\n   339→// containerState inspects the container for a run and returns one of:\n   340→//   - \"running\"   – container exists and is running\n   341→//   - \"stopped\"   – container exists, not running, not kept\n   342→//   - \"available\" – container exists, not running, kept (can be deleted)\n   343→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   344→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   345→\tif run.ContainerID == \"\" {\n   346→\t\treturn \"removed\"\n   347→\t}\n   348→\tmgr, ok := h.container.(ContainerManager)\n   349→\tif !ok {\n   350→\t\treturn \"removed\"\n   351→\t}\n   352→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   353→\tif err != nil {\n   354→\t\treturn \"removed\"\n   355→\t}\n   356→\tif status.Running {\n   357→\t\treturn \"running\"\n   358→\t}\n   359→\tif run.ContainerKept {\n   360→\t\treturn \"available\"\n   361→\t}\n   362→\treturn \"stopped\"\n   363→}\n   364→\n   365→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   366→\tid := r.PathValue(\"id\")\n   367→\n   368→\trun, err := h.store.GetRun(r.Context(), id)\n   369→\tif err != nil {\n   370→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   371→\t\treturn\n   372→\t}\n   373→\n   374→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   375→\tif err != nil {\n   376→\t\tcaps = nil // non-fatal\n   377→\t}\n   378→\n   379→\tsteps := mergeCaptures(caps)\n   380→\n   381→\tdata := map[string]any{\n   382→\t\t\"Title\":          \"Run \" + run.ID,\n   383→\t\t\"Run\":            run,\n   384→\t\t\"Steps\":          steps,\n   385→\t\t\"Page\":           \"detail\",\n   386→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   387→\t}\n   388→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   389→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   390→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   391→\t}\n   392→}\n   393→\n   394→// --- JSON API handlers ---\n   395→\n   396→type apiRun struct {\n   397→\tID           string `json:\"id\"`\n   398→\tWorkflowName string `json:\"workflow_name\"`\n   399→\tProjectDir   string `json:\"project_dir\"`\n   400→\tProjectLabel string `json:\"project_label\"`\n   401→\tState        string `json:\"state\"`\n   402→\tStartedAt    string `json:\"started_at\"`\n   403→\tCompletedAt  string `json:\"completed_at\"`\n   404→\tContainerID  string `json:\"container_id\"`\n   405→\tErrorMessage string `json:\"error_message\"`\n   406→\tTitle        string `json:\"title\"`\n   407→\tIsHost       bool   `json:\"is_host\"`\n   408→}\n   409→\n   410→type apiStep struct {\n   411→\tStepName    string `json:\"step_name\"`\n   412→\tResult      string `json:\"result\"`\n   413→\tStartedAt   string `json:\"started_at\"`\n   414→\tCompletedAt string `json:\"completed_at\"`\n   415→\tDuration    string `json:\"duration\"`\n   416→}\n   417→\n   418→type apiRunDetail struct {\n   419→\tapiRun\n   420→\tContainerState string    `json:\"container_state\"`\n   421→\tSteps          []apiStep `json:\"steps\"`\n   422→}\n   423→\n   424→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   425→\treturn apiRun{\n   426→\t\tID:           r.ID,\n   427→\t\tWorkflowName: r.WorkflowName,\n   428→\t\tProjectDir:   r.ProjectDir,\n   429→\t\tProjectLabel: labels[r.ProjectDir],\n   430→\t\tState:        string(r.State),\n   431→\t\tStartedAt:    formatTime(r.StartedAt),\n   432→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   433→\t\tContainerID:  r.ContainerID,\n   434→\t\tErrorMessage: r.ErrorMessage,\n   435→\t\tTitle:        r.Title,\n   436→\t\tIsHost:       r.IsHost,\n   437→\t}\n   438→}\n   439→\n   440→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   441→\tprojectFilter := r.URL.Query().Get(\"project\")\n   442→\n   443→\tvar runs []*domain.Run\n   444→\tvar err error\n   445→\tif projectFilter != \"\" {\n   446→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   447→\t} else {\n   448→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   449→\t}\n   450→\tif err != nil {\n   451→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   452→\t\treturn\n   453→\t}\n   454→\n   455→\tprojects, _ := h.store.ListProjects(r.Context())\n   456→\tlabels := projectLabels(projects)\n   457→\n   458→\tresult := make([]apiRun, len(runs))\n   459→\tfor i, run := range runs {\n   460→\t\tresult[i] = toAPIRun(run, labels)\n   461→\t}\n   462→\n   463→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   464→\tjson.NewEncoder(w).Encode(result)\n   465→}\n   466→\n   467→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   468→\tprojects, err := h.store.ListProjects(r.Context())\n   469→\tif err != nil {\n   470→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   471→\t\treturn\n   472→\t}\n   473→\tlabels := projectLabels(projects)\n   474→\n   475→\ttype apiHealth struct {\n   476→\t\tStatus string `json:\"status\"`\n   477→\t\tPassed int    `json:\"passed\"`\n   478→\t\tFailed int    `json:\"failed\"`\n   479→\t\tTotal  int    `json:\"total\"`\n   480→\t}\n   481→\ttype apiProject struct {\n   482→\t\tDir         string    `json:\"dir\"`\n   483→\t\tLabel       string    `json:\"label\"`\n   484→\t\tHealth      apiHealth `json:\"health\"`\n   485→\t\tActiveCount int       `json:\"active_count\"`\n   486→\t}\n   487→\tresult := make([]apiProject, len(projects))\n   488→\tfor i, dir := range projects {\n   489→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   490→\t\trunValues := make([]domain.Run, len(runs))\n   491→\t\tfor j, rr := range runs {\n   492→\t\t\trunValues[j] = *rr\n   493→\t\t}\n   494→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   495→\t\tvar activeCount int\n   496→\t\tfor _, rr := range runs {\n   497→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   498→\t\t\t\tactiveCount++\n   499→\t\t\t}\n   500→\t\t}\n   501→\t\tresult[i] = apiProject{\n   502→\t\t\tDir:   dir,\n   503→\t\t\tLabel: labels[dir],\n   504→\t\t\tHealth: apiHealth{\n   505→\t\t\t\tStatus: string(health.Status),\n   506→\t\t\t\tPassed: health.Passed,\n   507→\t\t\t\tFailed: health.Failed,\n   508→\t\t\t\tTotal:  health.Total,\n   509→\t\t\t},\n   510→\t\t\tActiveCount: activeCount,\n   511→\t\t}\n   512→\t}\n   513→\n   514→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   515→\tjson.NewEncoder(w).Encode(result)\n   516→}\n   517→\n   518→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   519→\tid := r.PathValue(\"id\")\n   520→\n   521→\trun, err := h.store.GetRun(r.Context(), id)\n   522→\tif err != nil {\n   523→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   524→\t\treturn\n   525→\t}\n   526→\n   527→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   528→\tif err != nil {\n   529→\t\tcaps = nil\n   530→\t}\n   531→\n   532→\tprojects, _ := h.store.ListProjects(r.Context())\n   533→\tlabels := projectLabels(projects)\n   534→\n   535→\tmerged := mergeCaptures(caps)\n   536→\tsteps := make([]apiStep, len(merged))\n   537→\tfor i, e := range merged {\n   538→\t\tsteps[i] = apiStep{\n   539→\t\t\tStepName:  e.StepName,\n   540→\t\t\tResult:    e.Result,\n   541→\t\t\tStartedAt: formatTime(e.StartedAt),\n   542→\t\t\tDuration:  e.Duration,\n   543→\t\t}\n   544→\t}\n   545→\n   546→\tdetail := apiRunDetail{\n   547→\t\tapiRun:         toAPIRun(run, labels),\n   548→\t\tContainerState: h.containerState(r.Context(), run),\n   549→\t\tSteps:          steps,\n   550→\t}\n   551→\n   552→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   553→\tjson.NewEncoder(w).Encode(detail)\n   554→}\n   555→\n   556→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   557→\tid := r.PathValue(\"id\")\n   558→\tstep := r.PathValue(\"step\")\n   559→\tlogType := r.URL.Query().Get(\"type\")   // optional: \"script\", \"llm\"\n   560→\tformat := r.URL.Query().Get(\"format\")  // optional: \"raw\" to skip parsing\n   561→\n   562→\trun, err := h.store.GetRun(r.Context(), id)\n   563→\tif err != nil {\n   564→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   565→\t\treturn\n   566→\t}\n   567→\n   568→\twriteOutput := func(data []byte) {\n   569→\t\tif format != \"raw\" {\n   570→\t\t\tdata = logstream.ParseClaudeStream(data)\n   571→\t\t}\n   572→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   573→\t\tw.Write(data)\n   574→\t}\n   575→\n   576→\t// Try log index first for fast lookup\n   577→\tif h.logStore != nil {\n   578→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   579→\t\tif err == nil && len(logFiles) > 0 {\n   580→\t\t\t// If type filter specified, narrow results\n   581→\t\t\tfor _, lf := range logFiles {\n   582→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   583→\t\t\t\t\tcontinue\n   584→\t\t\t\t}\n   585→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   586→\t\t\t\tif readErr == nil && len(data) > 0 {\n   587→\t\t\t\t\twriteOutput(data)\n   588→\t\t\t\t\treturn\n   589→\t\t\t\t}\n   590→\t\t\t}\n   591→\t\t}\n   592→\t}\n   593→\n   594→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   595→\n   596→\t// Fall back to file path conventions\n   597→\t// If type is \"llm\", try llm-<step>.log\n   598→\tif logType == \"llm\" {\n   599→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   600→\t\tdata, err := os.ReadFile(llmPath)\n   601→\t\tif err == nil && len(data) > 0 {\n   602→\t\t\twriteOutput(data)\n   603→\t\t\treturn\n   604→\t\t}\n   605→\t}\n   606→\n   607→\t// Try per-step output first, fall back to container.log, then live docker logs\n   608→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   609→\tdata, err := os.ReadFile(outputPath)\n   610→\tif err == nil && len(data) > 0 {\n   611→\t\twriteOutput(data)\n   612→\t\treturn\n   613→\t}\n   614→\n   615→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   616→\tdata, err = os.ReadFile(containerLog)\n   617→\tif err == nil && len(data) > 0 {\n   618→\t\twriteOutput(data)\n   619→\t\treturn\n   620→\t}\n   621→\n   622→\t// Last resort: try live docker logs from still-existing container\n   623→\tif h.container != nil && run.ContainerID != \"\" {\n   624→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   625→\t\t\twriteOutput([]byte(logs))\n   626→\t\t\treturn\n   627→\t\t}\n   628→\t}\n   629→\n   630→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   631→}\n   632→\n   633→func (h *Handler) handleAPIStopRun(w http.ResponseWriter, r *http.Request) {\n   634→\tid := r.PathValue(\"id\")\n   635→\n   636→\trun, err := h.store.GetRun(r.Context(), id)\n   637→\tif err != nil {\n   638→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   639→\t\tw.WriteHeader(http.StatusNotFound)\n   640→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   641→\t\treturn\n   642→\t}\n   643→\n   644→\t// Only allow stopping active runs\n   645→\tif run.State != domain.RunStatePending && run.State != domain.RunStateRunning {\n   646→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   647→\t\tw.WriteHeader(http.StatusBadRequest)\n   648→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run is not active\"})\n   649→\t\treturn\n   650→\t}\n   651→\n   652→\tmgr, ok := h.container.(ContainerManager)\n   653→\tif !ok || run.ContainerID == \"\" {\n   654→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   655→\t\tw.WriteHeader(http.StatusBadRequest)\n   656→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   657→\t\treturn\n   658→\t}\n   659→\n   660→\tif err := mgr.Stop(r.Context(), run.ContainerID); err != nil {\n   661→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   662→\t\tw.WriteHeader(http.StatusInternalServerError)\n   663→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to stop run: %v\", err)})\n   664→\t\treturn\n   665→\t}\n   666→\n   667→\trun.Complete(domain.RunStateCancelled)\n   668→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   669→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   670→\t\tw.WriteHeader(http.StatusInternalServerError)\n   671→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   672→\t\treturn\n   673→\t}\n   674→\n   675→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   676→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   677→}\n   678→\n   679→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   680→\tid := r.PathValue(\"id\")\n   681→\n   682→\trun, err := h.store.GetRun(r.Context(), id)\n   683→\tif err != nil {\n   684→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   685→\t\tw.WriteHeader(http.StatusNotFound)\n   686→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   687→\t\treturn\n   688→\t}\n   689→\n   690→\tmgr, ok := h.container.(ContainerManager)\n   691→\tif !ok || run.ContainerID == \"\" {\n   692→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   693→\t\tw.WriteHeader(http.StatusBadRequest)\n   694→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   695→\t\treturn\n   696→\t}\n   697→\n   698→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   699→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   700→\t\tw.WriteHeader(http.StatusInternalServerError)\n   701→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   702→\t\treturn\n   703→\t}\n   704→\n   705→\trun.ContainerKept = false\n   706→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   707→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   708→\t\tw.WriteHeader(http.StatusInternalServerError)\n   709→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   710→\t\treturn\n   711→\t}\n   712→\n   713→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   714→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   715→}\n   716→\n   717→// handleAPIStream serves an SSE stream of log lines for a run.\n   718→// For active runs, it subscribes to the live broadcaster.\n   719→// For completed runs, it serves the archived full.log then closes.\n   720→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   721→\tid := r.PathValue(\"id\")\n   722→\n   723→\trun, err := h.store.GetRun(r.Context(), id)\n   724→\tif err != nil {\n   725→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   726→\t\treturn\n   727→\t}\n   728→\n   729→\tflusher, ok := w.(http.Flusher)\n   730→\tif !ok {\n   731→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   732→\t\treturn\n   733→\t}\n   734→\n   735→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   736→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   737→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   738→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   739→\n   740→\tisComplete := run.State == domain.RunStateSucceeded ||\n   741→\t\trun.State == domain.RunStateFailed ||\n   742→\t\trun.State == domain.RunStateCancelled\n   743→\n   744→\tif isComplete {\n   745→\t\t// Serve archived full.log\n   746→\t\th.streamFullLog(w, flusher, run)\n   747→\t\t// Send done event\n   748→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   749→\t\tflusher.Flush()\n   750→\t\treturn\n   751→\t}\n   752→\n   753→\t// Active run: subscribe to live broadcaster\n   754→\tif h.logBroadcast == nil {\n   755→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   756→\t\treturn\n   757→\t}\n   758→\n   759→\tsub := h.logBroadcast.Subscribe(id)\n   760→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   761→\n   762→\tctx := r.Context()\n   763→\tfor {\n   764→\t\tselect {\n   765→\t\tcase <-ctx.Done():\n   766→\t\t\treturn\n   767→\t\tcase line, ok := <-sub.C:\n   768→\t\t\tif !ok {\n   769→\t\t\t\t// Stream finished (run completed)\n   770→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   771→\t\t\t\tflusher.Flush()\n   772→\t\t\t\treturn\n   773→\t\t\t}\n   774→\t\t\tline = parseLLMLogLine(line)\n   775→\t\t\tif line.Type == \"\" {\n   776→\t\t\t\tcontinue // skip protocol-only llm lines\n   777→\t\t\t}\n   778→\t\t\tdata, _ := json.Marshal(line)\n   779→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   780→\t\t\tflusher.Flush()\n   781→\t\t}\n   782→\t}\n   783→}\n   784→\n   785→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   786→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   787→\n   788→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   789→// LLM-type lines are parsed from raw Claude JSON into human-readable text.\n   790→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   791→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   792→\tf, err := os.Open(logPath)\n   793→\tif err != nil {\n   794→\t\treturn\n   795→\t}\n   796→\tdefer f.Close()\n   797→\n   798→\tscanner := bufio.NewScanner(f)\n   799→\tfor scanner.Scan() {\n   800→\t\ttext := scanner.Text()\n   801→\t\tline := parseFullLogLine(text)\n   802→\t\tline = parseLLMLogLine(line)\n   803→\t\tif line.Type == \"\" {\n   804→\t\t\tcontinue // skip protocol-only llm lines\n   805→\t\t}\n   806→\t\tdata, _ := json.Marshal(line)\n   807→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   808→\t\tflusher.Flush()\n   809→\t}\n   810→}\n   811→\n   812→// parseLLMLogLine parses a LogLine whose type is \"llm\". If the content is\n   813→// Claude stream JSON, it extracts the human-readable text. Protocol-only\n   814→// events return a LogLine with an empty Type (caller should skip it).\n   815→// Non-llm lines are returned unchanged.\n   816→func parseLLMLogLine(line logstream.LogLine) logstream.LogLine {\n   817→\tif line.Type != \"llm\" {\n   818→\t\treturn line\n   819→\t}\n   820→\ttext, ok := logstream.ParseClaudeLine([]byte(line.Content))\n   821→\tif !ok {\n   822→\t\treturn logstream.LogLine{} // signal to skip\n   823→\t}\n   824→\tline.Content = text\n   825→\treturn line\n   826→}\n   827→\n   828→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   829→func parseFullLogLine(text string) logstream.LogLine {\n   830→\tm := logLineRegex.FindStringSubmatch(text)\n   831→\tif m == nil {\n   832→\t\treturn logstream.LogLine{\n   833→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   834→\t\t\tType:      \"script\",\n   835→\t\t\tContent:   text,\n   836→\t\t}\n   837→\t}\n   838→\treturn logstream.LogLine{\n   839→\t\tTimestamp: m[1],\n   840→\t\tType:      m[2],\n   841→\t\tContent:   m[3],\n   842→\t}\n   843→}\n   844→\n   845→// --- Project detail handlers ---\n   846→\n   847→// resolveProjectDir resolves a project label from the URL to its directory path.\n   848→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   849→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   850→\tlabel := r.PathValue(\"name\")\n   851→\tprojects, _ := h.store.ListProjects(r.Context())\n   852→\tlabels := projectLabels(projects)\n   853→\tfor dir, l := range labels {\n   854→\t\tif l == label {\n   855→\t\t\treturn dir, label, true\n   856→\t\t}\n   857→\t}\n   858→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   859→\tw.WriteHeader(http.StatusNotFound)\n   860→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   861→\treturn \"\", \"\", false\n   862→}\n   863→\n   864→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   865→\tdir, label, ok := h.resolveProjectDir(w, r)\n   866→\tif !ok {\n   867→\t\treturn\n   868→\t}\n   869→\n   870→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   871→\tn := 10\n   872→\tif n > len(runs) {\n   873→\t\tn = len(runs)\n   874→\t}\n   875→\tdots := make([]recentRunDot, n)\n   876→\tfor i := 0; i < n; i++ {\n   877→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   878→\t}\n   879→\n   880→\tdata := map[string]any{\n   881→\t\t\"Title\":      label,\n   882→\t\t\"Label\":      label,\n   883→\t\t\"Dir\":        dir,\n   884→\t\t\"RecentRuns\": dots,\n   885→\t}\n   886→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   887→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   888→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   889→\t}\n   890→}\n   891→\n   892→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   893→\tdir, _, ok := h.resolveProjectDir(w, r)\n   894→\tif !ok {\n   895→\t\treturn\n   896→\t}\n   897→\n   898→\t// Docker image: read FROM line from Dockerfile\n   899→\tdockerImage := \"\"\n   900→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   901→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   902→\t\t// Find the last FROM line (final stage)\n   903→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   904→\t\t\ttrimmed := strings.TrimSpace(line)\n   905→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   906→\t\t\t\tparts := strings.Fields(trimmed)\n   907→\t\t\t\tif len(parts) >= 2 {\n   908→\t\t\t\t\tdockerImage = parts[1]\n   909→\t\t\t\t}\n   910→\t\t\t}\n   911→\t\t}\n   912→\t}\n   913→\n   914→\t// Version\n   915→\tversion := 0\n   916→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   917→\tif data, err := os.ReadFile(versionPath); err == nil {\n   918→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   919→\t\t\tversion = v\n   920→\t\t}\n   921→\t}\n   922→\n   923→\t// Prompt files history\n   924→\ttype commitEntry struct {\n   925→\t\tSHA     string `json:\"sha\"`\n   926→\t\tDate    string `json:\"date\"`\n   927→\t\tMessage string `json:\"message\"`\n   928→\t}\n   929→\ttype promptFile struct {\n   930→\t\tPath    string        `json:\"path\"`\n   931→\t\tHistory []commitEntry `json:\"history\"`\n   932→\t}\n   933→\n   934→\tvar promptFiles []promptFile\n   935→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   936→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n   937→\t\tfor _, e := range entries {\n   938→\t\t\tif e.IsDir() {\n   939→\t\t\t\tcontinue\n   940→\t\t\t}\n   941→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n   942→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n   943→\t\t\tcmd.Dir = dir\n   944→\t\t\tout, err := cmd.Output()\n   945→\t\t\tif err != nil {\n   946→\t\t\t\tcontinue\n   947→\t\t\t}\n   948→\t\t\tvar history []commitEntry\n   949→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n   950→\t\t\t\tif line == \"\" {\n   951→\t\t\t\t\tcontinue\n   952→\t\t\t\t}\n   953→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n   954→\t\t\t\tif len(parts) < 3 {\n   955→\t\t\t\t\tcontinue\n   956→\t\t\t\t}\n   957→\t\t\t\t// Parse date to short form\n   958→\t\t\t\tdateStr := parts[1]\n   959→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n   960→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n   961→\t\t\t\t}\n   962→\t\t\t\thistory = append(history, commitEntry{\n   963→\t\t\t\t\tSHA:     parts[0][:7],\n   964→\t\t\t\t\tDate:    dateStr,\n   965→\t\t\t\t\tMessage: parts[2],\n   966→\t\t\t\t})\n   967→\t\t\t}\n   968→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n   969→\t\t}\n   970→\t}\n   971→\n   972→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   973→\tjson.NewEncoder(w).Encode(map[string]any{\n   974→\t\t\"docker_image\": dockerImage,\n   975→\t\t\"version\":      version,\n   976→\t\t\"prompt_files\": promptFiles,\n   977→\t})\n   978→}\n   979→\n   980→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n   981→\tdir, _, ok := h.resolveProjectDir(w, r)\n   982→\tif !ok {\n   983→\t\treturn\n   984→\t}\n   985→\tfile := r.URL.Query().Get(\"file\")\n   986→\tsha := r.URL.Query().Get(\"sha\")\n   987→\tif file == \"\" || sha == \"\" {\n   988→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n   989→\t\treturn\n   990→\t}\n   991→\n   992→\t// Validate sha is alphanumeric to prevent injection\n   993→\tfor _, c := range sha {\n   994→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n   995→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n   996→\t\t\treturn\n   997→\t\t}\n   998→\t}\n   999→\n  1000→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1001→\tcmd.Dir = dir\n  1002→\tout, err := cmd.Output()\n  1003→\tif err != nil {\n  1004→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1005→\t\treturn\n  1006→\t}\n  1007→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1008→\tw.Write(out)\n  1009→}\n  1010→\n  1011→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1012→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1013→\tif !ok {\n  1014→\t\treturn\n  1015→\t}\n  1016→\n  1017→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1018→\tentries, err := os.ReadDir(clocheDir)\n  1019→\tif err != nil {\n  1020→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1021→\t\tjson.NewEncoder(w).Encode([]any{})\n  1022→\t\treturn\n  1023→\t}\n  1024→\n  1025→\ttype apiWire struct {\n  1026→\t\tFrom   string `json:\"from\"`\n  1027→\t\tResult string `json:\"result\"`\n  1028→\t\tTo     string `json:\"to\"`\n  1029→\t}\n  1030→\ttype apiStepDef struct {\n  1031→\t\tName    string            `json:\"name\"`\n  1032→\t\tType    string            `json:\"type\"`\n  1033→\t\tResults []string          `json:\"results\"`\n  1034→\t\tConfig  map[string]string `json:\"config\"`\n  1035→\t}\n  1036→\ttype apiWorkflow struct {\n  1037→\t\tName      string       `json:\"name\"`\n  1038→\t\tFile      string       `json:\"file\"`\n  1039→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1040→\t\tWires     []apiWire    `json:\"wires\"`\n  1041→\t\tEntryStep string       `json:\"entry_step\"`\n  1042→\t}\n  1043→\n  1044→\tvar workflows []apiWorkflow\n  1045→\tfor _, e := range entries {\n  1046→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1047→\t\t\tcontinue\n  1048→\t\t}\n  1049→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1050→\t\tif err != nil {\n  1051→\t\t\tcontinue\n  1052→\t\t}\n  1053→\t\twf, err := dsl.ParseForContainer(string(data))\n  1054→\t\tif err != nil {\n  1055→\t\t\tcontinue\n  1056→\t\t}\n  1057→\t\tvar steps []apiStepDef\n  1058→\t\tfor _, s := range wf.Steps {\n  1059→\t\t\tsteps = append(steps, apiStepDef{\n  1060→\t\t\t\tName:    s.Name,\n  1061→\t\t\t\tType:    string(s.Type),\n  1062→\t\t\t\tResults: s.Results,\n  1063→\t\t\t\tConfig:  s.Config,\n  1064→\t\t\t})\n  1065→\t\t}\n  1066→\t\t// Sort steps by name for consistent ordering\n  1067→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1068→\n  1069→\t\tvar wires []apiWire\n  1070→\t\tfor _, wire := range wf.Wiring {\n  1071→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1072→\t\t}\n  1073→\n  1074→\t\tworkflows = append(workflows, apiWorkflow{\n  1075→\t\t\tName:      wf.Name,\n  1076→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1077→\t\t\tSteps:     steps,\n  1078→\t\t\tWires:     wires,\n  1079→\t\t\tEntryStep: wf.EntryStep,\n  1080→\t\t})\n  1081→\t}\n  1082→\n  1083→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1084→\tjson.NewEncoder(w).Encode(workflows)\n  1085→}\n  1086→\n  1087→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1088→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1089→\tif !ok {\n  1090→\t\treturn\n  1091→\t}\n  1092→\tworkflowName := r.PathValue(\"workflow\")\n  1093→\tstepName := r.PathValue(\"step\")\n  1094→\n  1095→\t// Find the workflow file\n  1096→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1097→\tvar wf *domain.Workflow\n  1098→\tentries, _ := os.ReadDir(clocheDir)\n  1099→\tfor _, e := range entries {\n  1100→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1101→\t\t\tcontinue\n  1102→\t\t}\n  1103→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1104→\t\tif err != nil {\n  1105→\t\t\tcontinue\n  1106→\t\t}\n  1107→\t\tparsed, err := dsl.ParseForContainer(string(data))\n  1108→\t\tif err != nil {\n  1109→\t\t\tcontinue\n  1110→\t\t}\n  1111→\t\tif parsed.Name == workflowName {\n  1112→\t\t\twf = parsed\n  1113→\t\t\tbreak\n  1114→\t\t}\n  1115→\t}\n  1116→\tif wf == nil {\n  1117→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1118→\t\treturn\n  1119→\t}\n  1120→\n  1121→\tstep, ok := wf.Steps[stepName]\n  1122→\tif !ok {\n  1123→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1124→\t\treturn\n  1125→\t}\n  1126→\n  1127→\t// Try to read the referenced file from step config\n  1128→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1129→\n  1130→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1131→\t\tcontent, err := resolveFileRef(prompt, dir)\n  1132→\t\tif err == nil {\n  1133→\t\t\tw.Write([]byte(content))\n  1134→\t\t\treturn\n  1135→\t\t}\n  1136→\t}\n  1137→\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n  1138→\t\tcontent, _ := resolveFileRef(cmd, dir)\n  1139→\t\tw.Write([]byte(content))\n  1140→\t\treturn\n  1141→\t}\n  1142→\tif script := step.Config[\"script\"]; script != \"\" {\n  1143→\t\tcontent, _ := resolveFileRef(script, dir)\n  1144→\t\tw.Write([]byte(content))\n  1145→\t\treturn\n  1146→\t}\n  1147→\n  1148→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1149→}\n  1150→\n  1151→// --- Template helpers ---\n  1152→\n  1153→// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n  1154→// If the value uses file() syntax, the referenced file is read from disk.\n  1155→// Otherwise the value is returned as-is.\n  1156→func resolveFileRef(value, baseDir string) (string, error) {\n  1157→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n  1158→\t\tpath := value[6 : len(value)-2]\n  1159→\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n  1160→\t\tif err != nil {\n  1161→\t\t\treturn \"\", err\n  1162→\t\t}\n  1163→\t\treturn string(data), nil\n  1164→\t}\n  1165→\treturn value, nil\n  1166→}\n  1167→\n  1168→func stateColor(state domain.RunState) string {\n  1169→\tswitch state {\n  1170→\tcase domain.RunStatePending:\n  1171→\t\treturn \"pending\"\n  1172→\tcase domain.RunStateRunning:\n  1173→\t\treturn \"running\"\n  1174→\tcase domain.RunStateSucceeded:\n  1175→\t\treturn \"succeeded\"\n  1176→\tcase domain.RunStateFailed:\n  1177→\t\treturn \"failed\"\n  1178→\tcase domain.RunStateCancelled:\n  1179→\t\treturn \"cancelled\"\n  1180→\tdefault:\n  1181→\t\treturn \"pending\"\n  1182→\t}\n  1183→}\n  1184→\n  1185→func healthColor(status domain.HealthStatus) string {\n  1186→\tswitch status {\n  1187→\tcase domain.HealthGreen:\n  1188→\t\treturn \"green\"\n  1189→\tcase domain.HealthYellow:\n  1190→\t\treturn \"yellow\"\n  1191→\tcase domain.HealthRed:\n  1192→\t\treturn \"red\"\n  1193→\tcase domain.HealthBlue:\n  1194→\t\treturn \"blue\"\n  1195→\tdefault:\n  1196→\t\treturn \"grey\"\n  1197→\t}\n  1198→}\n  1199→\n  1200→func formatTime(t time.Time) string {\n  1201→\tif t.IsZero() {\n  1202→\t\treturn \"\"\n  1203→\t}\n  1204→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1205→}\n  1206→\n  1207→func formatDuration(start, end time.Time) string {\n  1208→\tif start.IsZero() || end.IsZero() {\n  1209→\t\treturn \"\"\n  1210→\t}\n  1211→\td := end.Sub(start)\n  1212→\tif d < time.Second {\n  1213→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1214→\t}\n  1215→\tif d < time.Minute {\n  1216→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1217→\t}\n  1218→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1219→}\n  1220→\n  1221→func truncate(s string, n int) string {\n  1222→\tif len(s) <= n {\n  1223→\t\treturn s\n  1224→\t}\n  1225→\treturn s[:n] + \"...\"\n  1226→}\n  1227→\n  1228→func shortContainerID(id string) string {\n  1229→\tif len(id) > 12 {\n  1230→\t\treturn id[:12]\n  1231→\t}\n  1232→\treturn id\n  1233→}\n  1234→\n  1235→// projectLabels builds a mapping from full project directory paths to short\n  1236→// display labels. Each label is the final directory component (e.g.\n  1237→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1238→// the same final name, the parent directory is prepended to disambiguate\n  1239→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1240→func projectLabels(dirs []string) map[string]string {\n  1241→\tlabels := make(map[string]string, len(dirs))\n  1242→\t// Group dirs by their base name to detect conflicts.\n  1243→\tbyBase := map[string][]string{}\n  1244→\tfor _, d := range dirs {\n  1245→\t\tbase := filepath.Base(d)\n  1246→\t\tbyBase[base] = append(byBase[base], d)\n  1247→\t}\n  1248→\tfor base, paths := range byBase {\n  1249→\t\tif len(paths) == 1 {\n  1250→\t\t\tlabels[paths[0]] = base\n  1251→\t\t} else {\n  1252→\t\t\tfor _, p := range paths {\n  1253→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1254→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1255→\t\t\t}\n  1256→\t\t}\n  1257→\t}\n  1258→\treturn labels\n  1259→}\n  1260→\n  1261→type projectEntry struct {\n  1262→\tDir            string\n  1263→\tLabel          string\n  1264→\tContainerCount int\n  1265→}\n  1266→"}]},"parent_tool_use_id":null,"session_id":"88dee606-b80e-44b4-9205-0d160e19ebe3","uuid":"8f00d780-21b9-4b55-92d1-0d1c4d7e6d4d","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"net/url\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tStop(ctx context.Context, containerID string) error\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogStore     ports.LogStore\n\tcontainer    ContainerLogger\n\tlogBroadcast *logstream.Broadcaster\n\tpages        map[string]*template.Template\n\tmux          *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"POST /api/runs/{id}/stop\", h.handleAPIStopRun)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// handleProjectRuns redirects /projects/{name}/runs to /runs?project=<dir>.\nfunc (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\thttp.Redirect(w, r, \"/runs?project=\"+url.QueryEscape(dir), http.StatusFound)\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n\tTitle        string `json:\"title\"`\n\tIsHost       bool   `json:\"is_host\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t\tTitle:        r.Title,\n\t\tIsHost:       r.IsHost,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\")   // optional: \"script\", \"llm\"\n\tformat := r.URL.Query().Get(\"format\")  // optional: \"raw\" to skip parsing\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\twriteOutput := func(data []byte) {\n\t\tif format != \"raw\" {\n\t\t\tdata = logstream.ParseClaudeStream(data)\n\t\t}\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\twriteOutput(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\twriteOutput(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\twriteOutput(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\twriteOutput(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\twriteOutput([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIStopRun(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\t// Only allow stopping active runs\n\tif run.State != domain.RunStatePending && run.State != domain.RunStateRunning {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run is not active\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Stop(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to stop run: %v\", err)})\n\t\treturn\n\t}\n\n\trun.Complete(domain.RunStateCancelled)\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tline = parseLLMLogLine(line)\n\t\t\tif line.Type == \"\" {\n\t\t\t\tcontinue // skip protocol-only llm lines\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n// LLM-type lines are parsed from raw Claude JSON into human-readable text.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tline = parseLLMLogLine(line)\n\t\tif line.Type == \"\" {\n\t\t\tcontinue // skip protocol-only llm lines\n\t\t}\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseLLMLogLine parses a LogLine whose type is \"llm\". If the content is\n// Claude stream JSON, it extracts the human-readable text. Protocol-only\n// events return a LogLine with an empty Type (caller should skip it).\n// Non-llm lines are returned unchanged.\nfunc parseLLMLogLine(line logstream.LogLine) logstream.LogLine {\n\tif line.Type != \"llm\" {\n\t\treturn line\n\t}\n\ttext, ok := logstream.ParseClaudeLine([]byte(line.Content))\n\tif !ok {\n\t\treturn logstream.LogLine{} // signal to skip\n\t}\n\tline.Content = text\n\treturn line\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.ParseForContainer(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.ParseForContainer(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tcontent, err := resolveFileRef(prompt, dir)\n\t\tif err == nil {\n\t\t\tw.Write([]byte(content))\n\t\t\treturn\n\t\t}\n\t}\n\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n\t\tcontent, _ := resolveFileRef(cmd, dir)\n\t\tw.Write([]byte(content))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tcontent, _ := resolveFileRef(script, dir)\n\t\tw.Write([]byte(content))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\n// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n// If the value uses file() syntax, the referenced file is read from disk.\n// Otherwise the value is returned as-is.\nfunc resolveFileRef(value, baseDir string) (string, error) {\n\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n\t\tpath := value[6 : len(value)-2]\n\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n\t\tif err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\treturn string(data), nil\n\t}\n\treturn value, nil\n}\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1266,"startLine":1,"totalLines":1266}}}
