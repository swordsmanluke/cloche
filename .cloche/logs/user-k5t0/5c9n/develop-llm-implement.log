{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PbGQbdFxcTHAtBiTXNPbsy","type":"tool_result","content":"     1→package grpc_test\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"sync/atomic\"\n    10→\t\"testing\"\n    11→\t\"time\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\tserver \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    15→\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    16→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    17→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    18→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    19→\t\"github.com/stretchr/testify/assert\"\n    20→\t\"github.com/stretchr/testify/require\"\n    21→\tgrpclib \"google.golang.org/grpc\"\n    22→)\n    23→\n    24→func TestServer_ListRuns_Empty(t *testing.T) {\n    25→\tstore, err := sqlite.NewStore(\":memory:\")\n    26→\trequire.NoError(t, err)\n    27→\tdefer store.Close()\n    28→\n    29→\tsrv := server.NewClocheServer(store, nil)\n    30→\tresp, err := srv.ListRuns(context.Background(), &pb.ListRunsRequest{All: true})\n    31→\trequire.NoError(t, err)\n    32→\tassert.Empty(t, resp.Runs)\n    33→}\n    34→\n    35→func TestServer_GetStatus_NotFound(t *testing.T) {\n    36→\tstore, err := sqlite.NewStore(\":memory:\")\n    37→\trequire.NoError(t, err)\n    38→\tdefer store.Close()\n    39→\n    40→\tsrv := server.NewClocheServer(store, nil)\n    41→\t_, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: \"nonexistent\"})\n    42→\tassert.Error(t, err)\n    43→}\n    44→\n    45→func TestServer_RunWorkflow(t *testing.T) {\n    46→\tstore, err := sqlite.NewStore(\":memory:\")\n    47→\trequire.NoError(t, err)\n    48→\tdefer store.Close()\n    49→\n    50→\tdir := t.TempDir()\n    51→\n    52→\t// Create a mock \"agent\" shell script at test.cloche that outputs JSON status lines.\n    53→\t// The local runtime runs: sh <projectDir>/test.cloche\n    54→\tmsgs := []protocol.StatusMessage{\n    55→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n    56→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n    57→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n    58→\t}\n    59→\tscript := \"#!/bin/sh\\n\"\n    60→\tfor _, msg := range msgs {\n    61→\t\tdata, _ := json.Marshal(msg)\n    62→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n    63→\t}\n    64→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n    65→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n    66→\n    67→\t// Use \"sh\" as the agent binary so it runs: sh test.cloche\n    68→\trt := local.NewRuntime(\"sh\")\n    69→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n    70→\n    71→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n    72→\t\tWorkflowName: \"test\",\n    73→\t\tProjectDir:   dir,\n    74→\t\tPrompt:       \"hello world\",\n    75→\t})\n    76→\trequire.NoError(t, err)\n    77→\tassert.NotEmpty(t, resp.RunId)\n    78→\n    79→\t// Verify prompt was written to run-specific path\n    80→\tpromptData, err := os.ReadFile(filepath.Join(dir, \".cloche\", resp.RunId, \"prompt.txt\"))\n    81→\trequire.NoError(t, err)\n    82→\tassert.Equal(t, \"hello world\", string(promptData))\n    83→\n    84→\t// Poll until the background goroutine finishes processing (up to 5s)\n    85→\tvar status *pb.GetStatusResponse\n    86→\tdeadline := time.Now().Add(5 * time.Second)\n    87→\tfor time.Now().Before(deadline) {\n    88→\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n    89→\t\trequire.NoError(t, err)\n    90→\t\tif status.State == \"succeeded\" && len(status.StepExecutions) >= 1 {\n    91→\t\t\tbreak\n    92→\t\t}\n    93→\t\ttime.Sleep(50 * time.Millisecond)\n    94→\t}\n    95→\n    96→\t// Check that the run was tracked and completed\n    97→\trequire.NotNil(t, status)\n    98→\tassert.Equal(t, resp.RunId, status.RunId)\n    99→\tassert.Equal(t, \"succeeded\", status.State)\n   100→\tassert.GreaterOrEqual(t, len(status.StepExecutions), 1)\n   101→}\n   102→\n   103→func TestServer_RunWorkflow_WithTitle(t *testing.T) {\n   104→\tstore, err := sqlite.NewStore(\":memory:\")\n   105→\trequire.NoError(t, err)\n   106→\tdefer store.Close()\n   107→\n   108→\tdir := t.TempDir()\n   109→\n   110→\tmsgs := []protocol.StatusMessage{\n   111→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   112→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   113→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   114→\t}\n   115→\tscript := \"#!/bin/sh\\n\"\n   116→\tfor _, msg := range msgs {\n   117→\t\tdata, _ := json.Marshal(msg)\n   118→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   119→\t}\n   120→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   121→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   122→\n   123→\trt := local.NewRuntime(\"sh\")\n   124→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   125→\n   126→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   127→\t\tWorkflowName: \"test\",\n   128→\t\tProjectDir:   dir,\n   129→\t\tPrompt:       \"do something\",\n   130→\t\tTitle:        \"Add dark mode toggle\",\n   131→\t})\n   132→\trequire.NoError(t, err)\n   133→\tassert.NotEmpty(t, resp.RunId)\n   134→\n   135→\t// Poll until the background goroutine finishes\n   136→\tdeadline := time.Now().Add(5 * time.Second)\n   137→\tvar status *pb.GetStatusResponse\n   138→\tfor time.Now().Before(deadline) {\n   139→\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   140→\t\trequire.NoError(t, err)\n   141→\t\tif status.State == \"succeeded\" {\n   142→\t\t\tbreak\n   143→\t\t}\n   144→\t\ttime.Sleep(50 * time.Millisecond)\n   145→\t}\n   146→\n   147→\trequire.NotNil(t, status)\n   148→\tassert.Equal(t, \"Add dark mode toggle\", status.Title)\n   149→}\n   150→\n   151→func TestServer_RunWorkflow_AgentGeneratesTitle(t *testing.T) {\n   152→\tstore, err := sqlite.NewStore(\":memory:\")\n   153→\trequire.NoError(t, err)\n   154→\tdefer store.Close()\n   155→\n   156→\tdir := t.TempDir()\n   157→\n   158→\t// Mock agent outputs a run_title message (simulating agent-generated title)\n   159→\tmsgs := []protocol.StatusMessage{\n   160→\t\t{Type: protocol.MsgRunTitle, Message: \"Agent generated title\"},\n   161→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   162→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   163→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   164→\t}\n   165→\tscript := \"#!/bin/sh\\n\"\n   166→\tfor _, msg := range msgs {\n   167→\t\tdata, _ := json.Marshal(msg)\n   168→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   169→\t}\n   170→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   171→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   172→\n   173→\trt := local.NewRuntime(\"sh\")\n   174→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   175→\n   176→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   177→\t\tWorkflowName: \"test\",\n   178→\t\tProjectDir:   dir,\n   179→\t})\n   180→\trequire.NoError(t, err)\n   181→\n   182→\t// Poll until complete\n   183→\tdeadline := time.Now().Add(5 * time.Second)\n   184→\tvar status *pb.GetStatusResponse\n   185→\tfor time.Now().Before(deadline) {\n   186→\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   187→\t\trequire.NoError(t, err)\n   188→\t\tif status.State == \"succeeded\" {\n   189→\t\t\tbreak\n   190→\t\t}\n   191→\t\ttime.Sleep(50 * time.Millisecond)\n   192→\t}\n   193→\n   194→\trequire.NotNil(t, status)\n   195→\tassert.Equal(t, \"Agent generated title\", status.Title)\n   196→}\n   197→\n   198→func TestServer_RunWorkflow_ExplicitTitleNotOverriddenByAgent(t *testing.T) {\n   199→\tstore, err := sqlite.NewStore(\":memory:\")\n   200→\trequire.NoError(t, err)\n   201→\tdefer store.Close()\n   202→\n   203→\tdir := t.TempDir()\n   204→\n   205→\t// Mock agent also outputs a run_title message, but explicit title should win\n   206→\tmsgs := []protocol.StatusMessage{\n   207→\t\t{Type: protocol.MsgRunTitle, Message: \"Agent title\"},\n   208→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   209→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   210→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   211→\t}\n   212→\tscript := \"#!/bin/sh\\n\"\n   213→\tfor _, msg := range msgs {\n   214→\t\tdata, _ := json.Marshal(msg)\n   215→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   216→\t}\n   217→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   218→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   219→\n   220→\trt := local.NewRuntime(\"sh\")\n   221→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   222→\n   223→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   224→\t\tWorkflowName: \"test\",\n   225→\t\tProjectDir:   dir,\n   226→\t\tTitle:        \"Explicit user title\",\n   227→\t})\n   228→\trequire.NoError(t, err)\n   229→\n   230→\t// Poll until complete\n   231→\tdeadline := time.Now().Add(5 * time.Second)\n   232→\tvar status *pb.GetStatusResponse\n   233→\tfor time.Now().Before(deadline) {\n   234→\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   235→\t\trequire.NoError(t, err)\n   236→\t\tif status.State == \"succeeded\" {\n   237→\t\t\tbreak\n   238→\t\t}\n   239→\t\ttime.Sleep(50 * time.Millisecond)\n   240→\t}\n   241→\n   242→\trequire.NotNil(t, status)\n   243→\tassert.Equal(t, \"Explicit user title\", status.Title, \"explicit title should not be overridden by agent\")\n   244→}\n   245→\n   246→func TestServer_ListRuns_IncludesTitle(t *testing.T) {\n   247→\tstore, err := sqlite.NewStore(\":memory:\")\n   248→\trequire.NoError(t, err)\n   249→\tdefer store.Close()\n   250→\n   251→\tctx := context.Background()\n   252→\trun := domain.NewRun(\"title-list-1\", \"develop\")\n   253→\trun.Start()\n   254→\trun.Title = \"Fix the login bug\"\n   255→\trequire.NoError(t, store.CreateRun(ctx, run))\n   256→\n   257→\tsrv := server.NewClocheServer(store, nil)\n   258→\tresp, err := srv.ListRuns(ctx, &pb.ListRunsRequest{All: true})\n   259→\trequire.NoError(t, err)\n   260→\trequire.Len(t, resp.Runs, 1)\n   261→\tassert.Equal(t, \"Fix the login bug\", resp.Runs[0].Title)\n   262→}\n   263→\n   264→func TestServer_RunWorkflow_CapturesStepMetadata(t *testing.T) {\n   265→\tstore, err := sqlite.NewStore(\":memory:\")\n   266→\trequire.NoError(t, err)\n   267→\tdefer store.Close()\n   268→\n   269→\tdir := t.TempDir()\n   270→\n   271→\t// Mock agent outputs status messages\n   272→\tmsgs := []protocol.StatusMessage{\n   273→\t\t{Type: protocol.MsgStepStarted, StepName: \"implement\"},\n   274→\t\t{Type: protocol.MsgStepCompleted, StepName: \"implement\", Result: \"success\"},\n   275→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   276→\t}\n   277→\tscript := \"#!/bin/sh\\n\"\n   278→\tfor _, msg := range msgs {\n   279→\t\tdata, _ := json.Marshal(msg)\n   280→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   281→\t}\n   282→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   283→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"capture.cloche\"), []byte(script), 0755))\n   284→\n   285→\trt := local.NewRuntime(\"sh\")\n   286→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   287→\n   288→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   289→\t\tWorkflowName: \"capture\",\n   290→\t\tProjectDir:   dir,\n   291→\t})\n   292→\trequire.NoError(t, err)\n   293→\n   294→\t// Poll until complete and captures are stored\n   295→\tvar captures []*domain.StepExecution\n   296→\tdeadline := time.Now().Add(5 * time.Second)\n   297→\tfor time.Now().Before(deadline) {\n   298→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   299→\t\trequire.NoError(t, err)\n   300→\t\tif status.State == \"succeeded\" {\n   301→\t\t\tcaptures, err = store.GetCaptures(context.Background(), resp.RunId)\n   302→\t\t\trequire.NoError(t, err)\n   303→\t\t\tif len(captures) >= 2 {\n   304→\t\t\t\tbreak\n   305→\t\t\t}\n   306→\t\t}\n   307→\t\ttime.Sleep(50 * time.Millisecond)\n   308→\t}\n   309→\n   310→\t// Should have 2 captures: one for step_started, one for step_completed\n   311→\trequire.GreaterOrEqual(t, len(captures), 2)\n   312→\n   313→\t// Check captures directly - one for step_started, one for step_completed\n   314→\tvar foundStarted, foundCompleted bool\n   315→\tfor _, c := range captures {\n   316→\t\tif c.StepName == \"implement\" && c.Result == \"\" {\n   317→\t\t\tfoundStarted = true\n   318→\t\t}\n   319→\t\tif c.StepName == \"implement\" && c.Result == \"success\" {\n   320→\t\t\tfoundCompleted = true\n   321→\t\t}\n   322→\t}\n   323→\tassert.True(t, foundStarted, \"should find capture for step started\")\n   324→\tassert.True(t, foundCompleted, \"should find capture for step completed\")\n   325→}\n   326→\n   327→func TestServer_StreamLogs(t *testing.T) {\n   328→\tstore, err := sqlite.NewStore(\":memory:\")\n   329→\trequire.NoError(t, err)\n   330→\tdefer store.Close()\n   331→\n   332→\tdir := t.TempDir()\n   333→\n   334→\t// Mock agent outputs status messages\n   335→\tmsgs := []protocol.StatusMessage{\n   336→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   337→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   338→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   339→\t}\n   340→\tscript := \"#!/bin/sh\\n\"\n   341→\tfor _, msg := range msgs {\n   342→\t\tdata, _ := json.Marshal(msg)\n   343→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   344→\t}\n   345→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   346→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   347→\n   348→\trt := local.NewRuntime(\"sh\")\n   349→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   350→\n   351→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   352→\t\tWorkflowName: \"test\",\n   353→\t\tProjectDir:   dir,\n   354→\t})\n   355→\trequire.NoError(t, err)\n   356→\n   357→\t// Poll until the run completes and captures are stored\n   358→\tdeadline := time.Now().Add(5 * time.Second)\n   359→\tfor time.Now().Before(deadline) {\n   360→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   361→\t\trequire.NoError(t, err)\n   362→\t\tif status.State == \"succeeded\" {\n   363→\t\t\tcaptures, _ := store.GetCaptures(context.Background(), resp.RunId)\n   364→\t\t\tif len(captures) >= 2 {\n   365→\t\t\t\tbreak\n   366→\t\t\t}\n   367→\t\t}\n   368→\t\ttime.Sleep(50 * time.Millisecond)\n   369→\t}\n   370→\n   371→\t// Use a mock stream to collect LogEntry messages\n   372→\tmock := &mockLogStream{ctx: context.Background()}\n   373→\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n   374→\trequire.NoError(t, err)\n   375→\n   376→\t// Should have entries: step_started, step_completed, run_completed\n   377→\trequire.GreaterOrEqual(t, len(mock.entries), 3)\n   378→\n   379→\t// Find step_started and step_completed entries\n   380→\tvar foundStarted, foundCompleted, foundRun bool\n   381→\tfor _, e := range mock.entries {\n   382→\t\tswitch e.Type {\n   383→\t\tcase \"step_started\":\n   384→\t\t\tif e.StepName == \"build\" {\n   385→\t\t\t\tfoundStarted = true\n   386→\t\t\t}\n   387→\t\tcase \"step_completed\":\n   388→\t\t\tif e.StepName == \"build\" {\n   389→\t\t\t\tfoundCompleted = true\n   390→\t\t\t\tassert.Equal(t, \"success\", e.Result)\n   391→\t\t\t}\n   392→\t\tcase \"run_completed\":\n   393→\t\t\tfoundRun = true\n   394→\t\t\tassert.Equal(t, \"succeeded\", e.Result)\n   395→\t\t}\n   396→\t}\n   397→\tassert.True(t, foundStarted, \"should find step_started for build\")\n   398→\tassert.True(t, foundCompleted, \"should find step_completed for build\")\n   399→\tassert.True(t, foundRun, \"should find run_completed\")\n   400→}\n   401→\n   402→// mockLogStream implements grpc.ServerStreamingServer[pb.LogEntry] for testing.\n   403→type mockLogStream struct {\n   404→\tgrpclib.ServerStream\n   405→\tctx     context.Context\n   406→\tentries []*pb.LogEntry\n   407→}\n   408→\n   409→func (m *mockLogStream) Send(entry *pb.LogEntry) error {\n   410→\tm.entries = append(m.entries, entry)\n   411→\treturn nil\n   412→}\n   413→\n   414→func (m *mockLogStream) Context() context.Context {\n   415→\treturn m.ctx\n   416→}\n   417→\n   418→func TestServer_StreamLogs_FallsBackToContainerLog(t *testing.T) {\n   419→\tstore, err := sqlite.NewStore(\":memory:\")\n   420→\trequire.NoError(t, err)\n   421→\tdefer store.Close()\n   422→\n   423→\tdir := t.TempDir()\n   424→\n   425→\t// Mock agent outputs a step that fails — no per-step output file will exist\n   426→\tmsgs := []protocol.StatusMessage{\n   427→\t\t{Type: protocol.MsgStepStarted, StepName: \"implement\"},\n   428→\t\t{Type: protocol.MsgStepCompleted, StepName: \"implement\", Result: \"fail\"},\n   429→\t\t{Type: protocol.MsgRunCompleted, Result: \"failed\"},\n   430→\t}\n   431→\tscript := \"#!/bin/sh\\n\"\n   432→\tfor _, msg := range msgs {\n   433→\t\tdata, _ := json.Marshal(msg)\n   434→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   435→\t}\n   436→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   437→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   438→\n   439→\trt := local.NewRuntime(\"sh\")\n   440→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   441→\n   442→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   443→\t\tWorkflowName: \"test\",\n   444→\t\tProjectDir:   dir,\n   445→\t})\n   446→\trequire.NoError(t, err)\n   447→\n   448→\t// Poll until run completes\n   449→\tdeadline := time.Now().Add(5 * time.Second)\n   450→\tfor time.Now().Before(deadline) {\n   451→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   452→\t\trequire.NoError(t, err)\n   453→\t\tif status.State != \"running\" && status.State != \"pending\" {\n   454→\t\t\tcaptures, _ := store.GetCaptures(context.Background(), resp.RunId)\n   455→\t\t\tif len(captures) >= 2 {\n   456→\t\t\t\tbreak\n   457→\t\t\t}\n   458→\t\t}\n   459→\t\ttime.Sleep(50 * time.Millisecond)\n   460→\t}\n   461→\n   462→\t// Simulate container.log being written (local runtime Logs() returns empty,\n   463→\t// so write it manually to test the StreamLogs fallback path)\n   464→\toutputDir := filepath.Join(dir, \".cloche\", resp.RunId, \"output\")\n   465→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   466→\trequire.NoError(t, os.WriteFile(\n   467→\t\tfilepath.Join(outputDir, \"container.log\"),\n   468→\t\t[]byte(\"error: compilation failed\\ndetailed stack trace here\"),\n   469→\t\t0644,\n   470→\t))\n   471→\n   472→\t// Stream logs and verify the step_completed entry falls back to container.log\n   473→\tmock := &mockLogStream{ctx: context.Background()}\n   474→\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n   475→\trequire.NoError(t, err)\n   476→\n   477→\tvar foundCompleted bool\n   478→\tfor _, e := range mock.entries {\n   479→\t\tif e.Type == \"step_completed\" && e.StepName == \"implement\" {\n   480→\t\t\tfoundCompleted = true\n   481→\t\t\tassert.Equal(t, \"fail\", e.Result)\n   482→\t\t\tassert.Contains(t, e.Message, \"error: compilation failed\")\n   483→\t\t\tassert.Contains(t, e.Message, \"detailed stack trace here\")\n   484→\t\t}\n   485→\t}\n   486→\tassert.True(t, foundCompleted, \"should find step_completed with container.log fallback content\")\n   487→}\n   488→\n   489→func TestServer_StreamLogs_PrefersStepOutput(t *testing.T) {\n   490→\tstore, err := sqlite.NewStore(\":memory:\")\n   491→\trequire.NoError(t, err)\n   492→\tdefer store.Close()\n   493→\n   494→\tdir := t.TempDir()\n   495→\n   496→\tmsgs := []protocol.StatusMessage{\n   497→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   498→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   499→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   500→\t}\n   501→\tscript := \"#!/bin/sh\\n\"\n   502→\tfor _, msg := range msgs {\n   503→\t\tdata, _ := json.Marshal(msg)\n   504→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   505→\t}\n   506→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   507→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   508→\n   509→\trt := local.NewRuntime(\"sh\")\n   510→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   511→\n   512→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   513→\t\tWorkflowName: \"test\",\n   514→\t\tProjectDir:   dir,\n   515→\t})\n   516→\trequire.NoError(t, err)\n   517→\n   518→\t// Poll until complete\n   519→\tdeadline := time.Now().Add(5 * time.Second)\n   520→\tfor time.Now().Before(deadline) {\n   521→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   522→\t\trequire.NoError(t, err)\n   523→\t\tif status.State == \"succeeded\" {\n   524→\t\t\tcaptures, _ := store.GetCaptures(context.Background(), resp.RunId)\n   525→\t\t\tif len(captures) >= 2 {\n   526→\t\t\t\tbreak\n   527→\t\t\t}\n   528→\t\t}\n   529→\t\ttime.Sleep(50 * time.Millisecond)\n   530→\t}\n   531→\n   532→\t// Write both per-step output AND container.log — per-step should win\n   533→\toutputDir := filepath.Join(dir, \".cloche\", resp.RunId, \"output\")\n   534→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   535→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"build.log\"), []byte(\"step-specific output\"), 0644))\n   536→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"container.log\"), []byte(\"full container output\"), 0644))\n   537→\n   538→\tmock := &mockLogStream{ctx: context.Background()}\n   539→\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n   540→\trequire.NoError(t, err)\n   541→\n   542→\tvar foundCompleted bool\n   543→\tfor _, e := range mock.entries {\n   544→\t\tif e.Type == \"step_completed\" && e.StepName == \"build\" {\n   545→\t\t\tfoundCompleted = true\n   546→\t\t\tassert.Equal(t, \"step-specific output\", e.Message, \"should prefer per-step output over container.log\")\n   547→\t\t}\n   548→\t}\n   549→\tassert.True(t, foundCompleted, \"should find step_completed entry\")\n   550→}\n   551→\n   552→func TestServer_GetStatus_ContainerID(t *testing.T) {\n   553→\tstore, err := sqlite.NewStore(\":memory:\")\n   554→\trequire.NoError(t, err)\n   555→\tdefer store.Close()\n   556→\n   557→\tctx := context.Background()\n   558→\trun := domain.NewRun(\"cid-test\", \"develop\")\n   559→\trun.Start()\n   560→\trun.ContainerID = \"4647e7e70e3fabc123def456\"\n   561→\trequire.NoError(t, store.CreateRun(ctx, run))\n   562→\n   563→\tsrv := server.NewClocheServer(store, nil)\n   564→\tresp, err := srv.GetStatus(ctx, &pb.GetStatusRequest{RunId: \"cid-test\"})\n   565→\trequire.NoError(t, err)\n   566→\tassert.Equal(t, \"4647e7e70e3fabc123def456\", resp.ContainerId)\n   567→}\n   568→\n   569→func TestServer_Shutdown(t *testing.T) {\n   570→\tstore, err := sqlite.NewStore(\":memory:\")\n   571→\trequire.NoError(t, err)\n   572→\tdefer store.Close()\n   573→\n   574→\tsrv := server.NewClocheServer(store, nil)\n   575→\n   576→\tcalled := make(chan struct{}, 1)\n   577→\tsrv.SetShutdownFunc(func() { called <- struct{}{} })\n   578→\n   579→\tresp, err := srv.Shutdown(context.Background(), &pb.ShutdownRequest{})\n   580→\trequire.NoError(t, err)\n   581→\tassert.NotNil(t, resp)\n   582→\n   583→\tselect {\n   584→\tcase <-called:\n   585→\tcase <-time.After(time.Second):\n   586→\t\tt.Fatal(\"shutdown callback was not called\")\n   587→\t}\n   588→}\n   589→\n   590→func TestServer_Shutdown_NotConfigured(t *testing.T) {\n   591→\tstore, err := sqlite.NewStore(\":memory:\")\n   592→\trequire.NoError(t, err)\n   593→\tdefer store.Close()\n   594→\n   595→\tsrv := server.NewClocheServer(store, nil)\n   596→\n   597→\t_, err = srv.Shutdown(context.Background(), &pb.ShutdownRequest{})\n   598→\tassert.Error(t, err)\n   599→\tassert.Contains(t, err.Error(), \"shutdown not configured\")\n   600→}\n   601→\n   602→func TestServer_RunWorkflow_NoRuntime(t *testing.T) {\n   603→\tstore, err := sqlite.NewStore(\":memory:\")\n   604→\trequire.NoError(t, err)\n   605→\tdefer store.Close()\n   606→\n   607→\tsrv := server.NewClocheServer(store, nil)\n   608→\t_, err = srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   609→\t\tWorkflowName: \"test\",\n   610→\t\tProjectDir:   t.TempDir(),\n   611→\t})\n   612→\tassert.Error(t, err)\n   613→\tassert.Contains(t, err.Error(), \"no container runtime configured\")\n   614→}\n   615→\n   616→// trackingRuntime wraps a local.Runtime and tracks Remove calls.\n   617→type trackingRuntime struct {\n   618→\t*local.Runtime\n   619→\tremoveCalled atomic.Int32\n   620→}\n   621→\n   622→func (tr *trackingRuntime) Remove(ctx context.Context, containerID string) error {\n   623→\ttr.removeCalled.Add(1)\n   624→\treturn tr.Runtime.Remove(ctx, containerID)\n   625→}\n   626→\n   627→// ensuringRuntime wraps a local.Runtime and implements ImageEnsurer to track calls.\n   628→type ensuringRuntime struct {\n   629→\t*local.Runtime\n   630→\tensureCalled atomic.Int32\n   631→\tensureErr    error\n   632→}\n   633→\n   634→func (e *ensuringRuntime) EnsureImage(ctx context.Context, projectDir, image string) error {\n   635→\te.ensureCalled.Add(1)\n   636→\treturn e.ensureErr\n   637→}\n   638→\n   639→func TestServer_RunWorkflow_CallsEnsureImage(t *testing.T) {\n   640→\tstore, err := sqlite.NewStore(\":memory:\")\n   641→\trequire.NoError(t, err)\n   642→\tdefer store.Close()\n   643→\n   644→\tdir := t.TempDir()\n   645→\n   646→\tmsgs := []protocol.StatusMessage{\n   647→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   648→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   649→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   650→\t}\n   651→\tscript := \"#!/bin/sh\\n\"\n   652→\tfor _, msg := range msgs {\n   653→\t\tdata, _ := json.Marshal(msg)\n   654→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   655→\t}\n   656→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   657→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   658→\n   659→\trt := &ensuringRuntime{Runtime: local.NewRuntime(\"sh\")}\n   660→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"test-image:latest\")\n   661→\n   662→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   663→\t\tWorkflowName: \"test\",\n   664→\t\tProjectDir:   dir,\n   665→\t})\n   666→\trequire.NoError(t, err)\n   667→\n   668→\t// Wait for run to complete\n   669→\tdeadline := time.Now().Add(5 * time.Second)\n   670→\tfor time.Now().Before(deadline) {\n   671→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   672→\t\trequire.NoError(t, err)\n   673→\t\tif status.State == \"succeeded\" {\n   674→\t\t\tbreak\n   675→\t\t}\n   676→\t\ttime.Sleep(50 * time.Millisecond)\n   677→\t}\n   678→\n   679→\tassert.Equal(t, int32(1), rt.ensureCalled.Load(), \"EnsureImage should be called once\")\n   680→}\n   681→\n   682→func TestServer_RunWorkflow_FailedRunKeepsContainer(t *testing.T) {\n   683→\tstore, err := sqlite.NewStore(\":memory:\")\n   684→\trequire.NoError(t, err)\n   685→\tdefer store.Close()\n   686→\n   687→\tdir := t.TempDir()\n   688→\n   689→\t// Mock agent outputs a failed run and exits with non-zero code\n   690→\tmsgs := []protocol.StatusMessage{\n   691→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   692→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"fail\"},\n   693→\t\t{Type: protocol.MsgRunCompleted, Result: \"failed\"},\n   694→\t}\n   695→\tscript := \"#!/bin/sh\\n\"\n   696→\tfor _, msg := range msgs {\n   697→\t\tdata, _ := json.Marshal(msg)\n   698→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   699→\t}\n   700→\tscript += \"exit 1\\n\"\n   701→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   702→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   703→\n   704→\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n   705→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   706→\n   707→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   708→\t\tWorkflowName:  \"test\",\n   709→\t\tProjectDir:    dir,\n   710→\t\tKeepContainer: false, // NOT requesting keep, but should still keep on failure\n   711→\t})\n   712→\trequire.NoError(t, err)\n   713→\n   714→\t// Poll until the run completes (failed state)\n   715→\tdeadline := time.Now().Add(5 * time.Second)\n   716→\tfor time.Now().Before(deadline) {\n   717→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   718→\t\trequire.NoError(t, err)\n   719→\t\tif status.State == \"failed\" {\n   720→\t\t\tbreak\n   721→\t\t}\n   722→\t\ttime.Sleep(50 * time.Millisecond)\n   723→\t}\n   724→\n   725→\t// Wait for post-completion cleanup (container retention logic) to finish\n   726→\ttime.Sleep(500 * time.Millisecond)\n   727→\n   728→\t// Container should NOT have been removed\n   729→\tassert.Equal(t, int32(0), rt.removeCalled.Load(), \"Remove should not be called for failed runs\")\n   730→\n   731→\t// ContainerKept should be true in the store\n   732→\trun, err := store.GetRun(context.Background(), resp.RunId)\n   733→\trequire.NoError(t, err)\n   734→\tassert.Equal(t, domain.RunStateFailed, run.State)\n   735→\tassert.True(t, run.ContainerKept, \"ContainerKept should be true for failed runs\")\n   736→}\n   737→\n   738→func TestServer_RunWorkflow_SucceededRunRemovesContainer(t *testing.T) {\n   739→\tstore, err := sqlite.NewStore(\":memory:\")\n   740→\trequire.NoError(t, err)\n   741→\tdefer store.Close()\n   742→\n   743→\tdir := t.TempDir()\n   744→\n   745→\t// Mock agent outputs a successful run\n   746→\tmsgs := []protocol.StatusMessage{\n   747→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   748→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   749→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   750→\t}\n   751→\tscript := \"#!/bin/sh\\n\"\n   752→\tfor _, msg := range msgs {\n   753→\t\tdata, _ := json.Marshal(msg)\n   754→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   755→\t}\n   756→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   757→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   758→\n   759→\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n   760→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   761→\n   762→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   763→\t\tWorkflowName:  \"test\",\n   764→\t\tProjectDir:    dir,\n   765→\t\tKeepContainer: false,\n   766→\t})\n   767→\trequire.NoError(t, err)\n   768→\n   769→\t// Poll until the run completes\n   770→\tdeadline := time.Now().Add(5 * time.Second)\n   771→\tfor time.Now().Before(deadline) {\n   772→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   773→\t\trequire.NoError(t, err)\n   774→\t\tif status.State == \"succeeded\" {\n   775→\t\t\tbreak\n   776→\t\t}\n   777→\t\ttime.Sleep(50 * time.Millisecond)\n   778→\t}\n   779→\n   780→\t// Wait a bit more for the post-completion cleanup to run\n   781→\ttime.Sleep(200 * time.Millisecond)\n   782→\n   783→\t// Container should have been removed\n   784→\tassert.Equal(t, int32(1), rt.removeCalled.Load(), \"Remove should be called for succeeded runs without --keep-container\")\n   785→\n   786→\t// ContainerKept should be false\n   787→\trun, err := store.GetRun(context.Background(), resp.RunId)\n   788→\trequire.NoError(t, err)\n   789→\tassert.False(t, run.ContainerKept, \"ContainerKept should be false for succeeded runs\")\n   790→}\n   791→\n   792→func TestServer_RunWorkflow_KeepContainerOnSuccess(t *testing.T) {\n   793→\tstore, err := sqlite.NewStore(\":memory:\")\n   794→\trequire.NoError(t, err)\n   795→\tdefer store.Close()\n   796→\n   797→\tdir := t.TempDir()\n   798→\n   799→\t// Mock agent outputs a successful run\n   800→\tmsgs := []protocol.StatusMessage{\n   801→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   802→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   803→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   804→\t}\n   805→\tscript := \"#!/bin/sh\\n\"\n   806→\tfor _, msg := range msgs {\n   807→\t\tdata, _ := json.Marshal(msg)\n   808→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   809→\t}\n   810→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   811→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   812→\n   813→\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n   814→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   815→\n   816→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   817→\t\tWorkflowName:  \"test\",\n   818→\t\tProjectDir:    dir,\n   819→\t\tKeepContainer: true, // --keep-container flag set\n   820→\t})\n   821→\trequire.NoError(t, err)\n   822→\n   823→\t// Poll until the run completes\n   824→\tdeadline := time.Now().Add(5 * time.Second)\n   825→\tfor time.Now().Before(deadline) {\n   826→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   827→\t\trequire.NoError(t, err)\n   828→\t\tif status.State == \"succeeded\" {\n   829→\t\t\tbreak\n   830→\t\t}\n   831→\t\ttime.Sleep(50 * time.Millisecond)\n   832→\t}\n   833→\n   834→\t// Wait a bit more for the post-completion cleanup to run\n   835→\ttime.Sleep(200 * time.Millisecond)\n   836→\n   837→\t// Container should NOT have been removed (--keep-container)\n   838→\tassert.Equal(t, int32(0), rt.removeCalled.Load(), \"Remove should not be called when --keep-container is set\")\n   839→\n   840→\t// ContainerKept should be true\n   841→\trun, err := store.GetRun(context.Background(), resp.RunId)\n   842→\trequire.NoError(t, err)\n   843→\tassert.True(t, run.ContainerKept, \"ContainerKept should be true with --keep-container\")\n   844→}\n   845→\n   846→func TestServer_DeleteContainer_ByRunID(t *testing.T) {\n   847→\tstore, err := sqlite.NewStore(\":memory:\")\n   848→\trequire.NoError(t, err)\n   849→\tdefer store.Close()\n   850→\n   851→\tctx := context.Background()\n   852→\n   853→\t// Create a run with a container ID and container_kept=true\n   854→\trun := domain.NewRun(\"delete-test-run\", \"develop\")\n   855→\trun.Start()\n   856→\trun.ContainerID = \"abc123def456\"\n   857→\trun.ContainerKept = true\n   858→\trun.Complete(domain.RunStateFailed)\n   859→\trequire.NoError(t, store.CreateRun(ctx, run))\n   860→\n   861→\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n   862→\tsrv := server.NewClocheServer(store, rt)\n   863→\n   864→\tresp, err := srv.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: \"delete-test-run\"})\n   865→\trequire.NoError(t, err)\n   866→\tassert.NotNil(t, resp)\n   867→\n   868→\t// Verify Remove was called\n   869→\tassert.Equal(t, int32(1), rt.removeCalled.Load())\n   870→\n   871→\t// Verify container_kept was cleared\n   872→\tupdated, err := store.GetRun(ctx, \"delete-test-run\")\n   873→\trequire.NoError(t, err)\n   874→\tassert.False(t, updated.ContainerKept)\n   875→}\n   876→\n   877→func TestServer_DeleteContainer_ByContainerID(t *testing.T) {\n   878→\tstore, err := sqlite.NewStore(\":memory:\")\n   879→\trequire.NoError(t, err)\n   880→\tdefer store.Close()\n   881→\n   882→\tctx := context.Background()\n   883→\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n   884→\tsrv := server.NewClocheServer(store, rt)\n   885→\n   886→\t// Pass a raw container ID (not a run ID)\n   887→\tresp, err := srv.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: \"some-docker-container-id\"})\n   888→\trequire.NoError(t, err)\n   889→\tassert.NotNil(t, resp)\n   890→\n   891→\t// Remove should still be called with the container ID\n   892→\tassert.Equal(t, int32(1), rt.removeCalled.Load())\n   893→}\n   894→\n   895→func TestServer_DeleteContainer_EmptyID(t *testing.T) {\n   896→\tstore, err := sqlite.NewStore(\":memory:\")\n   897→\trequire.NoError(t, err)\n   898→\tdefer store.Close()\n   899→\n   900→\tsrv := server.NewClocheServer(store, &trackingRuntime{Runtime: local.NewRuntime(\"sh\")})\n   901→\t_, err = srv.DeleteContainer(context.Background(), &pb.DeleteContainerRequest{Id: \"\"})\n   902→\tassert.Error(t, err)\n   903→\tassert.Contains(t, err.Error(), \"id is required\")\n   904→}\n   905→\n   906→func TestServer_DeleteContainer_NoRuntime(t *testing.T) {\n   907→\tstore, err := sqlite.NewStore(\":memory:\")\n   908→\trequire.NoError(t, err)\n   909→\tdefer store.Close()\n   910→\n   911→\tsrv := server.NewClocheServer(store, nil)\n   912→\t_, err = srv.DeleteContainer(context.Background(), &pb.DeleteContainerRequest{Id: \"some-id\"})\n   913→\tassert.Error(t, err)\n   914→\tassert.Contains(t, err.Error(), \"no container runtime configured\")\n   915→}\n   916→\n   917→func TestServer_DeleteContainer_RunWithNoContainer(t *testing.T) {\n   918→\tstore, err := sqlite.NewStore(\":memory:\")\n   919→\trequire.NoError(t, err)\n   920→\tdefer store.Close()\n   921→\n   922→\tctx := context.Background()\n   923→\n   924→\t// Create a run without a container ID\n   925→\trun := domain.NewRun(\"no-container-run\", \"develop\")\n   926→\trun.Start()\n   927→\trequire.NoError(t, store.CreateRun(ctx, run))\n   928→\n   929→\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n   930→\tsrv := server.NewClocheServer(store, rt)\n   931→\n   932→\t_, err = srv.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: \"no-container-run\"})\n   933→\tassert.Error(t, err)\n   934→\tassert.Contains(t, err.Error(), \"no associated container\")\n   935→}\n   936→\n   937→func TestServer_RunWorkflow_EnsureImageFailure(t *testing.T) {\n   938→\tstore, err := sqlite.NewStore(\":memory:\")\n   939→\trequire.NoError(t, err)\n   940→\tdefer store.Close()\n   941→\n   942→\tdir := t.TempDir()\n   943→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   944→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(\"#!/bin/sh\\necho ok\\n\"), 0755))\n   945→\n   946→\trt := &ensuringRuntime{\n   947→\t\tRuntime:   local.NewRuntime(\"sh\"),\n   948→\t\tensureErr: fmt.Errorf(\"build failed: Dockerfile syntax error\"),\n   949→\t}\n   950→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"test-image:latest\")\n   951→\n   952→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   953→\t\tWorkflowName: \"test\",\n   954→\t\tProjectDir:   dir,\n   955→\t})\n   956→\trequire.NoError(t, err) // RPC returns immediately\n   957→\n   958→\t// Wait for the background goroutine to mark the run as failed\n   959→\tdeadline := time.Now().Add(5 * time.Second)\n   960→\tvar status *pb.GetStatusResponse\n   961→\tfor time.Now().Before(deadline) {\n   962→\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   963→\t\trequire.NoError(t, err)\n   964→\t\tif status.State == \"failed\" {\n   965→\t\t\tbreak\n   966→\t\t}\n   967→\t\ttime.Sleep(50 * time.Millisecond)\n   968→\t}\n   969→\n   970→\tassert.Equal(t, \"failed\", status.State)\n   971→\tassert.Contains(t, status.ErrorMessage, \"failed to ensure image\")\n   972→}\n   973→\n   974→func TestServer_LogIndexing(t *testing.T) {\n   975→\tstore, err := sqlite.NewStore(\":memory:\")\n   976→\trequire.NoError(t, err)\n   977→\tdefer store.Close()\n   978→\n   979→\tdir := t.TempDir()\n   980→\n   981→\t// Mock agent that outputs status messages and creates output files\n   982→\tmsgs := []protocol.StatusMessage{\n   983→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   984→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   985→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   986→\t}\n   987→\tscript := \"#!/bin/sh\\n\"\n   988→\t// Create output directory and files from within the script\n   989→\t// Local runtime sets working dir to projectDir, so use relative paths\n   990→\tscript += \"mkdir -p .cloche/output\\n\"\n   991→\tscript += \"echo 'build script output' > .cloche/output/build.log\\n\"\n   992→\tscript += \"echo 'build llm output' > .cloche/output/llm-build.log\\n\"\n   993→\tscript += \"echo 'full unified log' > .cloche/output/full.log\\n\"\n   994→\tfor _, msg := range msgs {\n   995→\t\tdata, _ := json.Marshal(msg)\n   996→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   997→\t}\n   998→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   999→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n  1000→\n  1001→\trt := local.NewRuntime(\"sh\")\n  1002→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n  1003→\tsrv.SetLogStore(store)\n  1004→\n  1005→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n  1006→\t\tWorkflowName: \"test\",\n  1007→\t\tProjectDir:   dir,\n  1008→\t})\n  1009→\trequire.NoError(t, err)\n  1010→\n  1011→\t// Poll until complete\n  1012→\tdeadline := time.Now().Add(5 * time.Second)\n  1013→\tfor time.Now().Before(deadline) {\n  1014→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n  1015→\t\trequire.NoError(t, err)\n  1016→\t\tif status.State == \"succeeded\" {\n  1017→\t\t\tbreak\n  1018→\t\t}\n  1019→\t\ttime.Sleep(50 * time.Millisecond)\n  1020→\t}\n  1021→\n  1022→\t// Wait for post-completion processing (log indexing happens after run completes)\n  1023→\ttime.Sleep(500 * time.Millisecond)\n  1024→\n  1025→\t// Verify log files were indexed in the store\n  1026→\tlogFiles, err := store.GetLogFiles(context.Background(), resp.RunId)\n  1027→\trequire.NoError(t, err)\n  1028→\tassert.GreaterOrEqual(t, len(logFiles), 3, \"should have indexed at least full.log, build.log, llm-build.log\")\n  1029→\n  1030→\t// Check that we can find by step name\n  1031→\tbuildLogs, err := store.GetLogFilesByStep(context.Background(), resp.RunId, \"build\")\n  1032→\trequire.NoError(t, err)\n  1033→\tassert.GreaterOrEqual(t, len(buildLogs), 2, \"should have script and llm logs for build step\")\n  1034→\n  1035→\t// Check file types\n  1036→\tvar hasScript, hasLLM, hasFull bool\n  1037→\tfor _, lf := range logFiles {\n  1038→\t\tswitch lf.FileType {\n  1039→\t\tcase \"script\":\n  1040→\t\t\thasScript = true\n  1041→\t\tcase \"llm\":\n  1042→\t\t\thasLLM = true\n  1043→\t\tcase \"full\":\n  1044→\t\t\thasFull = true\n  1045→\t\t}\n  1046→\t}\n  1047→\tassert.True(t, hasScript, \"should have script log\")\n  1048→\tassert.True(t, hasLLM, \"should have llm log\")\n  1049→\tassert.True(t, hasFull, \"should have full log\")\n  1050→}\n  1051→\n  1052→func TestServer_StreamLogs_StepFilter(t *testing.T) {\n  1053→\tstore, err := sqlite.NewStore(\":memory:\")\n  1054→\trequire.NoError(t, err)\n  1055→\tdefer store.Close()\n  1056→\n  1057→\tdir := t.TempDir()\n  1058→\n  1059→\t// Mock agent outputs status messages for two steps\n  1060→\tmsgs := []protocol.StatusMessage{\n  1061→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n  1062→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n  1063→\t\t{Type: protocol.MsgStepStarted, StepName: \"test\"},\n  1064→\t\t{Type: protocol.MsgStepCompleted, StepName: \"test\", Result: \"success\"},\n  1065→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n  1066→\t}\n  1067→\tscript := \"#!/bin/sh\\n\"\n  1068→\tscript += \"mkdir -p .cloche/output\\n\"\n  1069→\tscript += \"echo 'build step output' > .cloche/output/build.log\\n\"\n  1070→\tscript += \"echo 'test step output' > .cloche/output/test.log\\n\"\n  1071→\tscript += \"echo 'build llm conversation' > .cloche/output/llm-build.log\\n\"\n  1072→\tfor _, msg := range msgs {\n  1073→\t\tdata, _ := json.Marshal(msg)\n  1074→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n  1075→\t}\n  1076→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n  1077→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n  1078→\n  1079→\trt := local.NewRuntime(\"sh\")\n  1080→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n  1081→\tsrv.SetLogStore(store)\n  1082→\n  1083→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n  1084→\t\tWorkflowName: \"test\",\n  1085→\t\tProjectDir:   dir,\n  1086→\t})\n  1087→\trequire.NoError(t, err)\n  1088→\n  1089→\t// Poll until complete\n  1090→\tdeadline := time.Now().Add(5 * time.Second)\n  1091→\tfor time.Now().Before(deadline) {\n  1092→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n  1093→\t\trequire.NoError(t, err)\n  1094→\t\tif status.State == \"succeeded\" {\n  1095→\t\t\tbreak\n  1096→\t\t}\n  1097→\t\ttime.Sleep(50 * time.Millisecond)\n  1098→\t}\n  1099→\ttime.Sleep(500 * time.Millisecond)\n  1100→\n  1101→\t// StreamLogs with step filter should return only that step's logs\n  1102→\tmock := &mockLogStream{ctx: context.Background()}\n  1103→\terr = srv.StreamLogs(&pb.StreamLogsRequest{\n  1104→\t\tRunId:    resp.RunId,\n  1105→\t\tStepName: \"build\",\n  1106→\t}, mock)\n  1107→\trequire.NoError(t, err)\n  1108→\tassert.GreaterOrEqual(t, len(mock.entries), 1, \"should have at least one entry for build step\")\n  1109→\n  1110→\t// All entries should be about the build step\n  1111→\tfor _, e := range mock.entries {\n  1112→\t\tif e.StepName != \"\" {\n  1113→\t\t\tassert.Equal(t, \"build\", e.StepName, \"filtered output should only contain build step\")\n  1114→\t\t}\n  1115→\t}\n  1116→\n  1117→\t// StreamLogs with type filter\n  1118→\tmock2 := &mockLogStream{ctx: context.Background()}\n  1119→\terr = srv.StreamLogs(&pb.StreamLogsRequest{\n  1120→\t\tRunId:    resp.RunId,\n  1121→\t\tStepName: \"build\",\n  1122→\t\tLogType:  \"llm\",\n  1123→\t}, mock2)\n  1124→\trequire.NoError(t, err)\n  1125→\tassert.GreaterOrEqual(t, len(mock2.entries), 1, \"should have at least one LLM log entry\")\n  1126→\n  1127→\tfor _, e := range mock2.entries {\n  1128→\t\tif e.Message != \"\" {\n  1129→\t\t\tassert.Contains(t, e.Message, \"llm conversation\", \"should contain LLM output\")\n  1130→\t\t}\n  1131→\t}\n  1132→}\n  1133→\n  1134→func TestServer_StreamLogs_FullLog(t *testing.T) {\n  1135→\tstore, err := sqlite.NewStore(\":memory:\")\n  1136→\trequire.NoError(t, err)\n  1137→\tdefer store.Close()\n  1138→\n  1139→\tdir := t.TempDir()\n  1140→\n  1141→\tmsgs := []protocol.StatusMessage{\n  1142→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n  1143→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n  1144→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n  1145→\t}\n  1146→\tscript := \"#!/bin/sh\\n\"\n  1147→\tscript += \"mkdir -p .cloche/output\\n\"\n  1148→\tscript += \"echo 'unified log content here' > .cloche/output/full.log\\n\"\n  1149→\tfor _, msg := range msgs {\n  1150→\t\tdata, _ := json.Marshal(msg)\n  1151→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n  1152→\t}\n  1153→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n  1154→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n  1155→\n  1156→\trt := local.NewRuntime(\"sh\")\n  1157→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n  1158→\n  1159→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n  1160→\t\tWorkflowName: \"test\",\n  1161→\t\tProjectDir:   dir,\n  1162→\t})\n  1163→\trequire.NoError(t, err)\n  1164→\n  1165→\t// Poll until complete\n  1166→\tdeadline := time.Now().Add(5 * time.Second)\n  1167→\tfor time.Now().Before(deadline) {\n  1168→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n  1169→\t\trequire.NoError(t, err)\n  1170→\t\tif status.State == \"succeeded\" {\n  1171→\t\t\tbreak\n  1172→\t\t}\n  1173→\t\ttime.Sleep(50 * time.Millisecond)\n  1174→\t}\n  1175→\ttime.Sleep(500 * time.Millisecond)\n  1176→\n  1177→\t// StreamLogs with no filters should serve full.log content\n  1178→\tmock := &mockLogStream{ctx: context.Background()}\n  1179→\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n  1180→\trequire.NoError(t, err)\n  1181→\n  1182→\t// Should have a full_log entry\n  1183→\tvar foundFullLog bool\n  1184→\tfor _, e := range mock.entries {\n  1185→\t\tif e.Type == \"full_log\" {\n  1186→\t\t\tfoundFullLog = true\n  1187→\t\t\tassert.Contains(t, e.Message, \"unified log content here\")\n  1188→\t\t}\n  1189→\t}\n  1190→\tassert.True(t, foundFullLog, \"should serve full.log as unified log when available\")\n  1191→}\n  1192→\n  1193→"}]},"parent_tool_use_id":null,"session_id":"e86d396b-c477-4111-8724-c79fdb5bf532","uuid":"2158d33b-dda5-4af5-9396-d7db837a7cb4","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server_test.go","content":"package grpc_test\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sync/atomic\"\n\t\"testing\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\tserver \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\tgrpclib \"google.golang.org/grpc\"\n)\n\nfunc TestServer_ListRuns_Empty(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\tresp, err := srv.ListRuns(context.Background(), &pb.ListRunsRequest{All: true})\n\trequire.NoError(t, err)\n\tassert.Empty(t, resp.Runs)\n}\n\nfunc TestServer_GetStatus_NotFound(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\t_, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: \"nonexistent\"})\n\tassert.Error(t, err)\n}\n\nfunc TestServer_RunWorkflow(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Create a mock \"agent\" shell script at test.cloche that outputs JSON status lines.\n\t// The local runtime runs: sh <projectDir>/test.cloche\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\t// Use \"sh\" as the agent binary so it runs: sh test.cloche\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t\tPrompt:       \"hello world\",\n\t})\n\trequire.NoError(t, err)\n\tassert.NotEmpty(t, resp.RunId)\n\n\t// Verify prompt was written to run-specific path\n\tpromptData, err := os.ReadFile(filepath.Join(dir, \".cloche\", resp.RunId, \"prompt.txt\"))\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"hello world\", string(promptData))\n\n\t// Poll until the background goroutine finishes processing (up to 5s)\n\tvar status *pb.GetStatusResponse\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" && len(status.StepExecutions) >= 1 {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Check that the run was tracked and completed\n\trequire.NotNil(t, status)\n\tassert.Equal(t, resp.RunId, status.RunId)\n\tassert.Equal(t, \"succeeded\", status.State)\n\tassert.GreaterOrEqual(t, len(status.StepExecutions), 1)\n}\n\nfunc TestServer_RunWorkflow_WithTitle(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t\tPrompt:       \"do something\",\n\t\tTitle:        \"Add dark mode toggle\",\n\t})\n\trequire.NoError(t, err)\n\tassert.NotEmpty(t, resp.RunId)\n\n\t// Poll until the background goroutine finishes\n\tdeadline := time.Now().Add(5 * time.Second)\n\tvar status *pb.GetStatusResponse\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\trequire.NotNil(t, status)\n\tassert.Equal(t, \"Add dark mode toggle\", status.Title)\n}\n\nfunc TestServer_RunWorkflow_AgentGeneratesTitle(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent outputs a run_title message (simulating agent-generated title)\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgRunTitle, Message: \"Agent generated title\"},\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until complete\n\tdeadline := time.Now().Add(5 * time.Second)\n\tvar status *pb.GetStatusResponse\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\trequire.NotNil(t, status)\n\tassert.Equal(t, \"Agent generated title\", status.Title)\n}\n\nfunc TestServer_RunWorkflow_ExplicitTitleNotOverriddenByAgent(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent also outputs a run_title message, but explicit title should win\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgRunTitle, Message: \"Agent title\"},\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t\tTitle:        \"Explicit user title\",\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until complete\n\tdeadline := time.Now().Add(5 * time.Second)\n\tvar status *pb.GetStatusResponse\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\trequire.NotNil(t, status)\n\tassert.Equal(t, \"Explicit user title\", status.Title, \"explicit title should not be overridden by agent\")\n}\n\nfunc TestServer_ListRuns_IncludesTitle(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"title-list-1\", \"develop\")\n\trun.Start()\n\trun.Title = \"Fix the login bug\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tsrv := server.NewClocheServer(store, nil)\n\tresp, err := srv.ListRuns(ctx, &pb.ListRunsRequest{All: true})\n\trequire.NoError(t, err)\n\trequire.Len(t, resp.Runs, 1)\n\tassert.Equal(t, \"Fix the login bug\", resp.Runs[0].Title)\n}\n\nfunc TestServer_RunWorkflow_CapturesStepMetadata(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent outputs status messages\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"implement\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"implement\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"capture.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"capture\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until complete and captures are stored\n\tvar captures []*domain.StepExecution\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tcaptures, err = store.GetCaptures(context.Background(), resp.RunId)\n\t\t\trequire.NoError(t, err)\n\t\t\tif len(captures) >= 2 {\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Should have 2 captures: one for step_started, one for step_completed\n\trequire.GreaterOrEqual(t, len(captures), 2)\n\n\t// Check captures directly - one for step_started, one for step_completed\n\tvar foundStarted, foundCompleted bool\n\tfor _, c := range captures {\n\t\tif c.StepName == \"implement\" && c.Result == \"\" {\n\t\t\tfoundStarted = true\n\t\t}\n\t\tif c.StepName == \"implement\" && c.Result == \"success\" {\n\t\t\tfoundCompleted = true\n\t\t}\n\t}\n\tassert.True(t, foundStarted, \"should find capture for step started\")\n\tassert.True(t, foundCompleted, \"should find capture for step completed\")\n}\n\nfunc TestServer_StreamLogs(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent outputs status messages\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until the run completes and captures are stored\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tcaptures, _ := store.GetCaptures(context.Background(), resp.RunId)\n\t\t\tif len(captures) >= 2 {\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Use a mock stream to collect LogEntry messages\n\tmock := &mockLogStream{ctx: context.Background()}\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n\trequire.NoError(t, err)\n\n\t// Should have entries: step_started, step_completed, run_completed\n\trequire.GreaterOrEqual(t, len(mock.entries), 3)\n\n\t// Find step_started and step_completed entries\n\tvar foundStarted, foundCompleted, foundRun bool\n\tfor _, e := range mock.entries {\n\t\tswitch e.Type {\n\t\tcase \"step_started\":\n\t\t\tif e.StepName == \"build\" {\n\t\t\t\tfoundStarted = true\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tif e.StepName == \"build\" {\n\t\t\t\tfoundCompleted = true\n\t\t\t\tassert.Equal(t, \"success\", e.Result)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfoundRun = true\n\t\t\tassert.Equal(t, \"succeeded\", e.Result)\n\t\t}\n\t}\n\tassert.True(t, foundStarted, \"should find step_started for build\")\n\tassert.True(t, foundCompleted, \"should find step_completed for build\")\n\tassert.True(t, foundRun, \"should find run_completed\")\n}\n\n// mockLogStream implements grpc.ServerStreamingServer[pb.LogEntry] for testing.\ntype mockLogStream struct {\n\tgrpclib.ServerStream\n\tctx     context.Context\n\tentries []*pb.LogEntry\n}\n\nfunc (m *mockLogStream) Send(entry *pb.LogEntry) error {\n\tm.entries = append(m.entries, entry)\n\treturn nil\n}\n\nfunc (m *mockLogStream) Context() context.Context {\n\treturn m.ctx\n}\n\nfunc TestServer_StreamLogs_FallsBackToContainerLog(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent outputs a step that fails — no per-step output file will exist\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"implement\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"implement\", Result: \"fail\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"failed\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until run completes\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State != \"running\" && status.State != \"pending\" {\n\t\t\tcaptures, _ := store.GetCaptures(context.Background(), resp.RunId)\n\t\t\tif len(captures) >= 2 {\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Simulate container.log being written (local runtime Logs() returns empty,\n\t// so write it manually to test the StreamLogs fallback path)\n\toutputDir := filepath.Join(dir, \".cloche\", resp.RunId, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\trequire.NoError(t, os.WriteFile(\n\t\tfilepath.Join(outputDir, \"container.log\"),\n\t\t[]byte(\"error: compilation failed\\ndetailed stack trace here\"),\n\t\t0644,\n\t))\n\n\t// Stream logs and verify the step_completed entry falls back to container.log\n\tmock := &mockLogStream{ctx: context.Background()}\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n\trequire.NoError(t, err)\n\n\tvar foundCompleted bool\n\tfor _, e := range mock.entries {\n\t\tif e.Type == \"step_completed\" && e.StepName == \"implement\" {\n\t\t\tfoundCompleted = true\n\t\t\tassert.Equal(t, \"fail\", e.Result)\n\t\t\tassert.Contains(t, e.Message, \"error: compilation failed\")\n\t\t\tassert.Contains(t, e.Message, \"detailed stack trace here\")\n\t\t}\n\t}\n\tassert.True(t, foundCompleted, \"should find step_completed with container.log fallback content\")\n}\n\nfunc TestServer_StreamLogs_PrefersStepOutput(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until complete\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tcaptures, _ := store.GetCaptures(context.Background(), resp.RunId)\n\t\t\tif len(captures) >= 2 {\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Write both per-step output AND container.log — per-step should win\n\toutputDir := filepath.Join(dir, \".cloche\", resp.RunId, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"build.log\"), []byte(\"step-specific output\"), 0644))\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"container.log\"), []byte(\"full container output\"), 0644))\n\n\tmock := &mockLogStream{ctx: context.Background()}\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n\trequire.NoError(t, err)\n\n\tvar foundCompleted bool\n\tfor _, e := range mock.entries {\n\t\tif e.Type == \"step_completed\" && e.StepName == \"build\" {\n\t\t\tfoundCompleted = true\n\t\t\tassert.Equal(t, \"step-specific output\", e.Message, \"should prefer per-step output over container.log\")\n\t\t}\n\t}\n\tassert.True(t, foundCompleted, \"should find step_completed entry\")\n}\n\nfunc TestServer_GetStatus_ContainerID(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"cid-test\", \"develop\")\n\trun.Start()\n\trun.ContainerID = \"4647e7e70e3fabc123def456\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tsrv := server.NewClocheServer(store, nil)\n\tresp, err := srv.GetStatus(ctx, &pb.GetStatusRequest{RunId: \"cid-test\"})\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"4647e7e70e3fabc123def456\", resp.ContainerId)\n}\n\nfunc TestServer_Shutdown(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\n\tcalled := make(chan struct{}, 1)\n\tsrv.SetShutdownFunc(func() { called <- struct{}{} })\n\n\tresp, err := srv.Shutdown(context.Background(), &pb.ShutdownRequest{})\n\trequire.NoError(t, err)\n\tassert.NotNil(t, resp)\n\n\tselect {\n\tcase <-called:\n\tcase <-time.After(time.Second):\n\t\tt.Fatal(\"shutdown callback was not called\")\n\t}\n}\n\nfunc TestServer_Shutdown_NotConfigured(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\n\t_, err = srv.Shutdown(context.Background(), &pb.ShutdownRequest{})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"shutdown not configured\")\n}\n\nfunc TestServer_RunWorkflow_NoRuntime(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\t_, err = srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   t.TempDir(),\n\t})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"no container runtime configured\")\n}\n\n// trackingRuntime wraps a local.Runtime and tracks Remove calls.\ntype trackingRuntime struct {\n\t*local.Runtime\n\tremoveCalled atomic.Int32\n}\n\nfunc (tr *trackingRuntime) Remove(ctx context.Context, containerID string) error {\n\ttr.removeCalled.Add(1)\n\treturn tr.Runtime.Remove(ctx, containerID)\n}\n\n// ensuringRuntime wraps a local.Runtime and implements ImageEnsurer to track calls.\ntype ensuringRuntime struct {\n\t*local.Runtime\n\tensureCalled atomic.Int32\n\tensureErr    error\n}\n\nfunc (e *ensuringRuntime) EnsureImage(ctx context.Context, projectDir, image string) error {\n\te.ensureCalled.Add(1)\n\treturn e.ensureErr\n}\n\nfunc TestServer_RunWorkflow_CallsEnsureImage(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := &ensuringRuntime{Runtime: local.NewRuntime(\"sh\")}\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"test-image:latest\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Wait for run to complete\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\tassert.Equal(t, int32(1), rt.ensureCalled.Load(), \"EnsureImage should be called once\")\n}\n\nfunc TestServer_RunWorkflow_FailedRunKeepsContainer(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent outputs a failed run and exits with non-zero code\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"fail\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"failed\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\tscript += \"exit 1\\n\"\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName:  \"test\",\n\t\tProjectDir:    dir,\n\t\tKeepContainer: false, // NOT requesting keep, but should still keep on failure\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until the run completes (failed state)\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"failed\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Wait for post-completion cleanup (container retention logic) to finish\n\ttime.Sleep(500 * time.Millisecond)\n\n\t// Container should NOT have been removed\n\tassert.Equal(t, int32(0), rt.removeCalled.Load(), \"Remove should not be called for failed runs\")\n\n\t// ContainerKept should be true in the store\n\trun, err := store.GetRun(context.Background(), resp.RunId)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n\tassert.True(t, run.ContainerKept, \"ContainerKept should be true for failed runs\")\n}\n\nfunc TestServer_RunWorkflow_SucceededRunRemovesContainer(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent outputs a successful run\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName:  \"test\",\n\t\tProjectDir:    dir,\n\t\tKeepContainer: false,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until the run completes\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Wait a bit more for the post-completion cleanup to run\n\ttime.Sleep(200 * time.Millisecond)\n\n\t// Container should have been removed\n\tassert.Equal(t, int32(1), rt.removeCalled.Load(), \"Remove should be called for succeeded runs without --keep-container\")\n\n\t// ContainerKept should be false\n\trun, err := store.GetRun(context.Background(), resp.RunId)\n\trequire.NoError(t, err)\n\tassert.False(t, run.ContainerKept, \"ContainerKept should be false for succeeded runs\")\n}\n\nfunc TestServer_RunWorkflow_KeepContainerOnSuccess(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent outputs a successful run\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName:  \"test\",\n\t\tProjectDir:    dir,\n\t\tKeepContainer: true, // --keep-container flag set\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until the run completes\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Wait a bit more for the post-completion cleanup to run\n\ttime.Sleep(200 * time.Millisecond)\n\n\t// Container should NOT have been removed (--keep-container)\n\tassert.Equal(t, int32(0), rt.removeCalled.Load(), \"Remove should not be called when --keep-container is set\")\n\n\t// ContainerKept should be true\n\trun, err := store.GetRun(context.Background(), resp.RunId)\n\trequire.NoError(t, err)\n\tassert.True(t, run.ContainerKept, \"ContainerKept should be true with --keep-container\")\n}\n\nfunc TestServer_DeleteContainer_ByRunID(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run with a container ID and container_kept=true\n\trun := domain.NewRun(\"delete-test-run\", \"develop\")\n\trun.Start()\n\trun.ContainerID = \"abc123def456\"\n\trun.ContainerKept = true\n\trun.Complete(domain.RunStateFailed)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n\tsrv := server.NewClocheServer(store, rt)\n\n\tresp, err := srv.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: \"delete-test-run\"})\n\trequire.NoError(t, err)\n\tassert.NotNil(t, resp)\n\n\t// Verify Remove was called\n\tassert.Equal(t, int32(1), rt.removeCalled.Load())\n\n\t// Verify container_kept was cleared\n\tupdated, err := store.GetRun(ctx, \"delete-test-run\")\n\trequire.NoError(t, err)\n\tassert.False(t, updated.ContainerKept)\n}\n\nfunc TestServer_DeleteContainer_ByContainerID(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n\tsrv := server.NewClocheServer(store, rt)\n\n\t// Pass a raw container ID (not a run ID)\n\tresp, err := srv.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: \"some-docker-container-id\"})\n\trequire.NoError(t, err)\n\tassert.NotNil(t, resp)\n\n\t// Remove should still be called with the container ID\n\tassert.Equal(t, int32(1), rt.removeCalled.Load())\n}\n\nfunc TestServer_DeleteContainer_EmptyID(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, &trackingRuntime{Runtime: local.NewRuntime(\"sh\")})\n\t_, err = srv.DeleteContainer(context.Background(), &pb.DeleteContainerRequest{Id: \"\"})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"id is required\")\n}\n\nfunc TestServer_DeleteContainer_NoRuntime(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\t_, err = srv.DeleteContainer(context.Background(), &pb.DeleteContainerRequest{Id: \"some-id\"})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"no container runtime configured\")\n}\n\nfunc TestServer_DeleteContainer_RunWithNoContainer(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run without a container ID\n\trun := domain.NewRun(\"no-container-run\", \"develop\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n\tsrv := server.NewClocheServer(store, rt)\n\n\t_, err = srv.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: \"no-container-run\"})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"no associated container\")\n}\n\nfunc TestServer_RunWorkflow_EnsureImageFailure(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(\"#!/bin/sh\\necho ok\\n\"), 0755))\n\n\trt := &ensuringRuntime{\n\t\tRuntime:   local.NewRuntime(\"sh\"),\n\t\tensureErr: fmt.Errorf(\"build failed: Dockerfile syntax error\"),\n\t}\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"test-image:latest\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err) // RPC returns immediately\n\n\t// Wait for the background goroutine to mark the run as failed\n\tdeadline := time.Now().Add(5 * time.Second)\n\tvar status *pb.GetStatusResponse\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"failed\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\tassert.Equal(t, \"failed\", status.State)\n\tassert.Contains(t, status.ErrorMessage, \"failed to ensure image\")\n}\n\nfunc TestServer_LogIndexing(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent that outputs status messages and creates output files\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\t// Create output directory and files from within the script\n\t// Local runtime sets working dir to projectDir, so use relative paths\n\tscript += \"mkdir -p .cloche/output\\n\"\n\tscript += \"echo 'build script output' > .cloche/output/build.log\\n\"\n\tscript += \"echo 'build llm output' > .cloche/output/llm-build.log\\n\"\n\tscript += \"echo 'full unified log' > .cloche/output/full.log\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\tsrv.SetLogStore(store)\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until complete\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Wait for post-completion processing (log indexing happens after run completes)\n\ttime.Sleep(500 * time.Millisecond)\n\n\t// Verify log files were indexed in the store\n\tlogFiles, err := store.GetLogFiles(context.Background(), resp.RunId)\n\trequire.NoError(t, err)\n\tassert.GreaterOrEqual(t, len(logFiles), 3, \"should have indexed at least full.log, build.log, llm-build.log\")\n\n\t// Check that we can find by step name\n\tbuildLogs, err := store.GetLogFilesByStep(context.Background(), resp.RunId, \"build\")\n\trequire.NoError(t, err)\n\tassert.GreaterOrEqual(t, len(buildLogs), 2, \"should have script and llm logs for build step\")\n\n\t// Check file types\n\tvar hasScript, hasLLM, hasFull bool\n\tfor _, lf := range logFiles {\n\t\tswitch lf.FileType {\n\t\tcase \"script\":\n\t\t\thasScript = true\n\t\tcase \"llm\":\n\t\t\thasLLM = true\n\t\tcase \"full\":\n\t\t\thasFull = true\n\t\t}\n\t}\n\tassert.True(t, hasScript, \"should have script log\")\n\tassert.True(t, hasLLM, \"should have llm log\")\n\tassert.True(t, hasFull, \"should have full log\")\n}\n\nfunc TestServer_StreamLogs_StepFilter(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent outputs status messages for two steps\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgStepStarted, StepName: \"test\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"test\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tscript += \"mkdir -p .cloche/output\\n\"\n\tscript += \"echo 'build step output' > .cloche/output/build.log\\n\"\n\tscript += \"echo 'test step output' > .cloche/output/test.log\\n\"\n\tscript += \"echo 'build llm conversation' > .cloche/output/llm-build.log\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\tsrv.SetLogStore(store)\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until complete\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\ttime.Sleep(500 * time.Millisecond)\n\n\t// StreamLogs with step filter should return only that step's logs\n\tmock := &mockLogStream{ctx: context.Background()}\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{\n\t\tRunId:    resp.RunId,\n\t\tStepName: \"build\",\n\t}, mock)\n\trequire.NoError(t, err)\n\tassert.GreaterOrEqual(t, len(mock.entries), 1, \"should have at least one entry for build step\")\n\n\t// All entries should be about the build step\n\tfor _, e := range mock.entries {\n\t\tif e.StepName != \"\" {\n\t\t\tassert.Equal(t, \"build\", e.StepName, \"filtered output should only contain build step\")\n\t\t}\n\t}\n\n\t// StreamLogs with type filter\n\tmock2 := &mockLogStream{ctx: context.Background()}\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{\n\t\tRunId:    resp.RunId,\n\t\tStepName: \"build\",\n\t\tLogType:  \"llm\",\n\t}, mock2)\n\trequire.NoError(t, err)\n\tassert.GreaterOrEqual(t, len(mock2.entries), 1, \"should have at least one LLM log entry\")\n\n\tfor _, e := range mock2.entries {\n\t\tif e.Message != \"\" {\n\t\t\tassert.Contains(t, e.Message, \"llm conversation\", \"should contain LLM output\")\n\t\t}\n\t}\n}\n\nfunc TestServer_StreamLogs_FullLog(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tscript += \"mkdir -p .cloche/output\\n\"\n\tscript += \"echo 'unified log content here' > .cloche/output/full.log\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until complete\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\ttime.Sleep(500 * time.Millisecond)\n\n\t// StreamLogs with no filters should serve full.log content\n\tmock := &mockLogStream{ctx: context.Background()}\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n\trequire.NoError(t, err)\n\n\t// Should have a full_log entry\n\tvar foundFullLog bool\n\tfor _, e := range mock.entries {\n\t\tif e.Type == \"full_log\" {\n\t\t\tfoundFullLog = true\n\t\t\tassert.Contains(t, e.Message, \"unified log content here\")\n\t\t}\n\t}\n\tassert.True(t, foundFullLog, \"should serve full.log as unified log when available\")\n}\n\n","numLines":1193,"startLine":1,"totalLines":1193}}}
