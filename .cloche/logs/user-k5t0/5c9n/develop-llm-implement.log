{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018aDyGAqHW86DDXNuXQRsQ9","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"encoding/json\"\n     5→\t\"fmt\"\n     6→\t\"net/http\"\n     7→\t\"os\"\n     8→\t\"text/tabwriter\"\n     9→)\n    10→\n    11→type healthData struct {\n    12→\tStatus string `json:\"status\"`\n    13→\tPassed int    `json:\"passed\"`\n    14→\tFailed int    `json:\"failed\"`\n    15→\tTotal  int    `json:\"total\"`\n    16→}\n    17→\n    18→type projectHealth struct {\n    19→\tDir    string     `json:\"dir\"`\n    20→\tLabel  string     `json:\"label\"`\n    21→\tHealth healthData `json:\"health\"`\n    22→}\n    23→\n    24→func cmdHealth(args []string) {\n    25→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n    26→\tif httpAddr == \"\" {\n    27→\t\tfmt.Fprintf(os.Stderr, \"error: CLOCHE_HTTP not set (e.g. export CLOCHE_HTTP=localhost:8080)\\n\")\n    28→\t\tos.Exit(1)\n    29→\t}\n    30→\n    31→\turl := \"http://\" + httpAddr + \"/api/projects\"\n    32→\tresp, err := http.Get(url)\n    33→\tif err != nil {\n    34→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    35→\t\tos.Exit(1)\n    36→\t}\n    37→\tdefer resp.Body.Close()\n    38→\n    39→\tif resp.StatusCode != http.StatusOK {\n    40→\t\tfmt.Fprintf(os.Stderr, \"error: server returned %s\\n\", resp.Status)\n    41→\t\tos.Exit(1)\n    42→\t}\n    43→\n    44→\tvar projects []projectHealth\n    45→\tif err := json.NewDecoder(resp.Body).Decode(&projects); err != nil {\n    46→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    47→\t\tos.Exit(1)\n    48→\t}\n    49→\n    50→\tif len(projects) == 0 {\n    51→\t\tfmt.Println(\"No projects found.\")\n    52→\t\treturn\n    53→\t}\n    54→\n    55→\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n    56→\tfmt.Fprintln(w, \"PROJECT\\tSTATUS\\tPASSED\\tFAILED\\tTOTAL\")\n    57→\tfor _, p := range projects {\n    58→\t\tname := p.Label\n    59→\t\tif name == \"\" {\n    60→\t\t\tname = p.Dir\n    61→\t\t}\n    62→\t\tstatus := colorStatus(p.Health.Status)\n    63→\t\tfmt.Fprintf(w, \"%s\\t%s\\t%d\\t%d\\t%d\\n\",\n    64→\t\t\tname, status, p.Health.Passed, p.Health.Failed, p.Health.Total)\n    65→\t}\n    66→\tw.Flush()\n    67→}\n    68→\n    69→func colorStatus(status string) string {\n    70→\tif !isTTY() {\n    71→\t\treturn status\n    72→\t}\n    73→\tswitch status {\n    74→\tcase \"green\":\n    75→\t\treturn \"\\033[32m\" + status + \"\\033[0m\"\n    76→\tcase \"yellow\":\n    77→\t\treturn \"\\033[33m\" + status + \"\\033[0m\"\n    78→\tcase \"red\":\n    79→\t\treturn \"\\033[31m\" + status + \"\\033[0m\"\n    80→\tdefault:\n    81→\t\treturn status\n    82→\t}\n    83→}\n    84→\n    85→func isTTY() bool {\n    86→\tfi, err := os.Stdout.Stat()\n    87→\tif err != nil {\n    88→\t\treturn false\n    89→\t}\n    90→\treturn fi.Mode()&os.ModeCharDevice != 0\n    91→}\n    92→"}]},"parent_tool_use_id":"toolu_01EW9TAVMApisb7g7B1neB6C","session_id":"e86d396b-c477-4111-8724-c79fdb5bf532","uuid":"9a815388-2722-4b61-a64f-718cafa452d8"}
