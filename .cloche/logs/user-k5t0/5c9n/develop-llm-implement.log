{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BSbYHjCFSYFXxoXA4hZGub","type":"tool_result","content":"     1→syntax = \"proto3\";\n     2→\n     3→package cloche.v1;\n     4→\n     5→option go_package = \"github.com/cloche-dev/cloche/api/clochepb\";\n     6→\n     7→service ClocheService {\n     8→  rpc RunWorkflow(RunWorkflowRequest) returns (RunWorkflowResponse);\n     9→  rpc GetStatus(GetStatusRequest) returns (GetStatusResponse);\n    10→  rpc StreamLogs(StreamLogsRequest) returns (stream LogEntry);\n    11→  rpc StopRun(StopRunRequest) returns (StopRunResponse);\n    12→  rpc ListRuns(ListRunsRequest) returns (ListRunsResponse);\n    13→  rpc Shutdown(ShutdownRequest) returns (ShutdownResponse);\n    14→  rpc DeleteContainer(DeleteContainerRequest) returns (DeleteContainerResponse);\n    15→}\n    16→\n    17→message RunWorkflowRequest {\n    18→  string workflow_name = 1;\n    19→  string project_dir = 2;\n    20→  string image = 3;\n    21→  string prompt = 4;\n    22→  bool keep_container = 5;\n    23→  string title = 6;\n    24→}\n    25→\n    26→message RunWorkflowResponse {\n    27→  string run_id = 1;\n    28→}\n    29→\n    30→message GetStatusRequest {\n    31→  string run_id = 1;\n    32→}\n    33→\n    34→message GetStatusResponse {\n    35→  string run_id = 1;\n    36→  string workflow_name = 2;\n    37→  string state = 3;\n    38→  string current_step = 4;\n    39→  repeated StepExecutionStatus step_executions = 5;\n    40→  string error_message = 6;\n    41→  string container_id = 7;\n    42→  bool container_alive = 8;\n    43→  string container_dead_since = 9;\n    44→  string title = 10;\n    45→  bool is_host = 11;\n    46→}\n    47→\n    48→message StepExecutionStatus {\n    49→  string step_name = 1;\n    50→  string result = 2;\n    51→  string started_at = 3;\n    52→  string completed_at = 4;\n    53→}\n    54→\n    55→message StreamLogsRequest {\n    56→  string run_id = 1;\n    57→  string step_name = 2;\n    58→  string log_type = 3;\n    59→}\n    60→\n    61→message LogEntry {\n    62→  string type = 1;\n    63→  string step_name = 2;\n    64→  string result = 3;\n    65→  string message = 4;\n    66→  string timestamp = 5;\n    67→}\n    68→\n    69→message StopRunRequest {\n    70→  string run_id = 1;\n    71→}\n    72→\n    73→message StopRunResponse {}\n    74→\n    75→message ShutdownRequest {}\n    76→\n    77→message ShutdownResponse {}\n    78→\n    79→message DeleteContainerRequest {\n    80→  string id = 1;\n    81→}\n    82→\n    83→message DeleteContainerResponse {}\n    84→\n    85→message ListRunsRequest {\n    86→  bool all = 1;\n    87→}\n    88→\n    89→message ListRunsResponse {\n    90→  repeated RunSummary runs = 1;\n    91→}\n    92→\n    93→message RunSummary {\n    94→  string run_id = 1;\n    95→  string workflow_name = 2;\n    96→  string state = 3;\n    97→  string started_at = 4;\n    98→  string error_message = 5;\n    99→  string container_id = 6;\n   100→  string title = 7;\n   101→  bool is_host = 8;\n   102→}\n   103→"}]},"parent_tool_use_id":"toolu_01EW9TAVMApisb7g7B1neB6C","session_id":"e86d396b-c477-4111-8724-c79fdb5bf532","uuid":"feb64004-51a6-4de8-84f9-d21c2843545c"}
