64→\t\tcmdPoll(client, os.Args[2:])\n    65→\tcase \"list\":\n    66→\t\tcmdList(ctx, client, os.Args[2:])\n    67→\tcase \"stop\":\n    68→\t\tcmdStop(ctx, client, os.Args[2:])\n    69→\tcase \"delete\":\n    70→\t\tcmdDelete(ctx, client, os.Args[2:])\n    71→\tcase \"orchestrate\":\n    72→\t\tcmdOrchestrate(ctx, client)\n    73→\tcase \"shutdown\":\n    74→\t\tcmdShutdown(ctx, client)\n    75→\tdefault:\n    76→\t\tusage()\n    77→\t\tos.Exit(1)\n    78→\t}\n    79→}\n    80→\n    81→func usage() {\n    82→\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n    83→\n    84→Commands:\n    85→  init [--workflow <name>] [--base-image <image>]\n    86→                                             Initialize a Cloche project\n    87→  health                                   Show project health summary\n    88→  run --workflow <name> [--prompt \"...\"] [--title \"...\"] [--keep-container]\n    89→                                             Launch a workflow run\n    90→  status <run-id>                            Check run status\n    91→  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n    92→                                             Show logs for a run\n    93→  poll <run-id>                              Wait for a run to finish\n    94→  list [--all]                                List runs (last hour by default)\n    95→  stop <run-id>                              Stop a running workflow\n    96→  delete <container-or-run-id>               Delete a retained container\n    97→  orchestrate                                Dispatch ready workflow runs\n    98→  shutdown                                   Shut down the daemon\n    99→`)\n   100→}\n   101→\n   102→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   103→\tvar workflow, prompt, title string\n   104→\tvar keepContainer bool\n   105→\n   106→\tfor i := 0; i < len(args); i++ {\n   107→\t\tswitch args[i] {\n   108→\t\tcase \"--workflow\":\n   109→\t\t\tif i+1 < len(args) {\n   110→\t\t\t\ti++\n   111→\t\t\t\tworkflow = args[i]\n   112→\t\t\t}\n   113→\t\tcase \"--prompt\", \"-p\":\n   114→\t\t\tif i+1 < len(args) {\n   115→\t\t\t\ti++\n   116→\t\t\t\tprompt = args[i]\n   117→\t\t\t}\n   118→\t\tcase \"--title\":\n   119→\t\t\tif i+1 < len(args) {\n   120→\t\t\t\ti++\n   121→\t\t\t\ttitle = args[i]\n   122→\t\t\t}\n   123→\t\tcase \"--keep-container\":\n   124→\t\t\tkeepContainer = true\n   125→\t\tdefault:\n   126→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   127→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   128→\t\t\t\tworkflow = args[i]\n   129→\t\t\t}\n   130→\t\t}\n   131→\t}\n   132→\n   133→\tif workflow == \"\" {\n   134→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   135→\t\tos.Exit(1)\n   136→\t}\n   137→\n   138→\tcwd, _ := os.Getwd()\n   139→\n   140→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   141→\tvar image string\n   142→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   143→\tif data, err := os.ReadFile(wfPath); err == nil {\n   144→\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   145→\t\t\timage = wf.Config[\"container.image\"]\n   146→\t\t}\n   147→\t}\n   148→\n   149→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   150→\t\tWorkflowName:  workflow,\n   151→\t\tProjectDir:    cwd,\n   152→\t\tImage:         image,\n   153→\t\tPrompt:        prompt,\n   154→\t\tKeepContainer: keepContainer,\n   155→\t\tTitle:         title,\n   156→\t})\n   157→\tif err != nil {\n   158→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   159→\t\tos.Exit(1)\n   160→\t}\n   161→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   162→}\n   163→\n   164→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   165→\tif len(args) < 1 {\n   166→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   167→\t\tos.Exit(1)\n   168→\t}\n   169→\n   170→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   171→\tif err != nil {\n   172→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   173→\t\tos.Exit(1)\n   174→\t}\n   175→\n   176→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   177→\tif resp.Title != \"\" {\n   178→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   179→\t}\n   180→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   181→\tif resp.IsHost {\n   182→\t\tfmt.Printf(\"Type:      host\\n\")\n   183→\t} else {\n   184→\t\tfmt.Printf(\"Type:      container\\n\")\n   185→\t}\n   186→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   187→\tif resp.ContainerId != \"\" {\n   188→\t\tcid := resp.ContainerId\n   189→\t\tif len(cid) > 12 {\n   190→\t\t\tcid = cid[:12]\n   191→\t\t}\n   192→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   193→\t}\n   194→\tif resp.ErrorMessage != \"\" {\n   195→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   196→\t}\n   197→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   198→\tfor _, exec := range resp.StepExecutions {\n   199→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   200→\t}\n   201→}\n   202→\n   203→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   204→\tvar all bool\n   205→\tfor _, arg := range args {\n   206→\t\tif arg == \"--all\" {\n   207→\t\t\tall = true\n   208→\t\t}\n   209→\t}\n   210→\n   211→\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n   212→\tif err != nil {\n   213→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   214→\t\tos.Exit(1)\n   215→\t}\n   216→\n   217→\tif len(resp.Runs) == 0 {\n   218→\t\tfmt.Println(\"No runs found.\")\n   219→\t\treturn\n   220→\t}\n   221→\n   222→\tfor _, run := range resp.Runs {\n   223→\t\trunType := \"container\"\n   224→\t\tif run.IsHost {\n   225→\t\t\trunType = \"host\"\n   226→\t\t}\n   227→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   228→\t\tif run.Title != \"\" {\n   229→\t\t\tt := run.Title\n   230→\t\t\tif len(t) > 40 {\n   231→\t\t\t\tt = t[:37] + \"...\"\n   232→\t\t\t}\n   233→\t\t\tline += \"  \" + t\n   234→\t\t}\n   235→\t\tif run.ContainerId != \"\" {\n   236→\t\t\tline += \"  \" + run.ContainerId\n   237→\t\t}\n   238→\t\tif run.ErrorMessage != \"\" {\n   239→\t\t\terrMsg := run.ErrorMessage\n   240→\t\t\tif len(errMsg) > 60 {\n   241→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   242→\t\t\t}\n   243→\t\t\tline += \"  \" + errMsg\n   244→\t\t}\n   245→\t\tfmt.Println(line)\n   246→\t}\n   247→}\n   248→\n   249→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   250→\tif len(args) < 1 {\n   251→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n   252→\t\tos.Exit(1)\n   253→\t}\n   254→\n   255→\tvar stepFilter, typeFilter string\n   256→\tvar follow bool\n   257→\trunID := args[0]\n   258→\n   259→\tfor i := 1; i < len(args); i++ {\n   260→\t\tswitch args[i] {\n   261→\t\tcase \"--step\":\n   262→\t\t\tif i+1 < len(args) {\n   263→\t\t\t\ti++\n   264→\t\t\t\tstepFilter = args[i]\n   265→\t\t\t}\n   266→\t\tcase \"--type\":\n   267→\t\t\tif i+1 < len(args) {\n   268→\t\t\t\ti++\n   269→\t\t\t\ttypeFilter = args[i]\n   270→\t\t\t}\n   271→\t\tcase \"--follow\", \"-f\":\n   272→\t\t\tfollow = true\n   273→\t\t}\n   274→\t}\n   275→\n   276→\tif follow {\n   277→\t\tcmdLogsFollow(runID)\n   278→\t\treturn\n   279→\t}\n   280→\n   281→\t// Use background context — log output can be large\n   282→\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n   283→\t\tRunId:    runID,\n   284→\t\tStepName: stepFilter,\n   285→\t\tLogType:  typeFilter,\n   286→\t})\n   287→\tif err != nil {\n   288→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   289→\t\tos.Exit(1)\n   290→\t}\n   291→\n   292→\tfor {\n   293→\t\tentry, err := stream.Recv()\n   294→\t\tif err != nil {\n   295→\t\t\tif errors.Is(err, io.EOF) {\n   296→\t\t\t\tbreak\n   297→\t\t\t}\n   298→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   299→\t\t\tos.Exit(1)\n   300→\t\t}\n   301→\n   302→\t\tswitch entry.Type {\n   303→\t\tcase \"step_started\":\n   304→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   305→\t\t\tif entry.Message != \"\" {\n   306→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   307→\t\t\t}\n   308→\t\tcase \"step_completed\":\n   309→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   310→\t\t\tif entry.Message != \"\" {\n   311→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   312→\t\t\t}\n   313→\t\tcase \"run_completed\":\n   314→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   315→\t\t\tif entry.Message != \"\" {\n   316→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   317→\t\t\t}\n   318→\t\tcase \"full_log\":\n   319→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   320→\t\tdefault:\n   321→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   322→\t\t\tif entry.StepName != \"\" {\n   323→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   324→\t\t\t}\n   325→\t\t\tif entry.Message != \"\" {\n   326→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   327→\t\t\t}\n   328→\t\t}\n   329→\t}\n   330→}\n   331→\n   332→func cmdLogsFollow(runID string) {\n   333→\t// Determine HTTP address from env\n   334→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   335→\tif httpAddr == \"\" {\n   336→\t\thttpAddr = \"localhost:8080\"\n   337→\t}\n   338→\t// Strip protocol prefix if present\n   339→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   340→\n   341→\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n   342→\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n   343→\tif err != nil {\n   344→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   345→\t\tos.Exit(1)\n   346→\t}\n   347→\treq.Header.Set(\"Accept\", \"text/event-stream\")\n   348→\n   349→\tresp, err := http.DefaultClient.Do(req)\n   350→\tif err != nil {\n   351→\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n   352→\t\tos.Exit(1)\n   353→\t}\n   354→\tdefer resp.Body.Close()\n   355→\n   356→\tif resp.StatusCode != 200 {\n   357→\t\tbody, _ := io.ReadAll(resp.Body)\n   358→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   359→\t\tos.Exit(1)\n   360→\t}\n   361→\n   362→\tscanner := bufio.NewScanner(resp.Body)\n   363→\tfor scanner.Scan() {\n   364→\t\tline := scanner.Text()\n   365→\t\tif strings.HasPrefix(line, \"event: done\") {\n   366→\t\t\tbreak\n   367→\t\t}\n   368→\t\tif !strings.HasPrefix(line, \"data: \") {\n   369→\t\t\tcontinue\n   370→\t\t}\n   371→\t\tdata := strings.TrimPrefix(line, \"data: \")\n   372→\n   373→\t\tvar entry struct {\n   374→\t\t\tTimestamp string `json:\"timestamp\"`\n   375→\t\t\tType      string `json:\"type\"`\n   376→\t\t\tContent   string `json:\"content\"`\n   377→\t\t}\n   378→\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n   379→\t\t\tcontinue\n   380→\t\t}\n   381→\n   382→\t\t// Color-code by type\n   383→\t\tswitch entry.Type {\n   384→\t\tcase \"status\":\n   385→\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   386→\t\tcase \"llm\":\n   387→\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   388→\t\tdefault:\n   389→\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n   390→\t\t}\n   391→\t}\n   392→}\n   393→\n   394→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   395→\tif len(args) < 1 {\n   396→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   397→\t\tos.Exit(1)\n   398→\t}\n   399→\n   400→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   401→\tif err != nil {\n   402→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   403→\t\tos.Exit(1)\n   404→\t}\n   405→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   406→}\n   407→\n   408→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   409→\tif len(args) < 1 {\n   410→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   411→\t\tos.Exit(1)\n   412→\t}\n   413→\n   414→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   415→\tif err != nil {\n   416→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   417→\t\tos.Exit(1)\n   418→\t}\n   419→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   420→}\n   421→\n   422→func cmdOrchestrate(ctx context.Context, client pb.ClocheServiceClient) {\n   423→\tcwd, _ := os.Getwd()\n   424→\tresp, err := client.Orchestrate(ctx, &pb.OrchestrateRequest{ProjectDir: cwd})\n   425→\tif err != nil {\n   426→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   427→\t\tos.Exit(1)\n   428→\t}\n   429→\tif resp.Dispatched == 0 {\n   430→\t\tfmt.Println(\"No ready work found.\")\n   431→\t} else {\n   432→\t\tfmt.Printf(\"Dispatched %d run(s).\\n\", resp.Dispatched)\n   433→\t}\n   434→}\n   435→\n   436→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   437→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   438→\tif err != nil {\n   439→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   440→\t\tos.Exit(1)\n   441→\t}\n   442→\tfmt.Println(\"Daemon shutting down.\")\n   443→}\n   444→"}]},"parent_tool_use_id":null,"session_id":"e86d396b-c477-4111-8724-c79fdb5bf532","uuid":"6bce5d3b-0391-460c-ab37-e635235b2764","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"orchestrate\":\n\t\tcmdOrchestrate(ctx, client)\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client)\n\tdefault:\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n}\n\nfunc usage() {\n\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n\nCommands:\n  init [--workflow <name>] [--base-image <image>]\n                                             Initialize a Cloche project\n  health                                   Show project health summary\n  run --workflow <name> [--prompt \"...\"] [--title \"...\"] [--keep-container]\n                                             Launch a workflow run\n  status <run-id>                            Check run status\n  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n                                             Show logs for a run\n  poll <run-id>                              Wait for a run to finish\n  list [--all]                                List runs (last hour by default)\n  stop <run-id>                              Stop a running workflow\n  delete <container-or-run-id>               Delete a retained container\n  orchestrate                                Dispatch ready workflow runs\n  shutdown                                   Shut down the daemon\n`)\n}\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n\tvar image string\n\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n\tif data, err := os.ReadFile(wfPath); err == nil {\n\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n\t\t\timage = wf.Config[\"container.image\"]\n\t\t}\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t}\n\t}\n\n\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n\t\tif run.Title != \"\" {\n\t\t\tt := run.Title\n\t\t\tif len(t) > 40 {\n\t\t\t\tt = t[:37] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + t\n\t\t}\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\t}\n\t}\n\n\tif follow {\n\t\tcmdLogsFollow(runID)\n\t\treturn\n\t}\n\n\t// Use background context — log output can be large\n\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdLogsFollow(runID string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\t// Strip protocol prefix if present\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\treq.Header.Set(\"Accept\", \"text/event-stream\")\n\n\tresp, err := http.DefaultClient.Do(req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\tscanner := bufio.NewScanner(resp.Body)\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"event: done\") {\n\t\t\tbreak\n\t\t}\n\t\tif !strings.HasPrefix(line, \"data: \") {\n\t\t\tcontinue\n\t\t}\n\t\tdata := strings.TrimPrefix(line, \"data: \")\n\n\t\tvar entry struct {\n\t\t\tTimestamp string `json:\"timestamp\"`\n\t\t\tType      string `json:\"type\"`\n\t\t\tContent   string `json:\"content\"`\n\t\t}\n\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Color-code by type\n\t\tswitch entry.Type {\n\t\tcase \"status\":\n\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tcase \"llm\":\n\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tdefault:\n\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdOrchestrate(ctx context.Context, client pb.ClocheServiceClient) {\n\tcwd, _ := os.Getwd()\n\tresp, err := client.Orchestrate(ctx, &pb.OrchestrateRequest{ProjectDir: cwd})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif resp.Dispatched == 0 {\n\t\tfmt.Println(\"No ready work found.\")\n\t} else {\n\t\tfmt.Printf(\"Dispatched %d run(s).\\n\", resp.Dispatched)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n","numLines":444,"startLine":1,"totalLines":444}}}
