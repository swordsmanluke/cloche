kground(), &pb.OrchestrateRequest{ProjectDir: dir})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"host.cloche not found\")\n}\n\nfunc TestServer_Orchestrate_EmptyProjectDir(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\n\t_, err = srv.Orchestrate(context.Background(), &pb.OrchestrateRequest{ProjectDir: \"\"})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"project_dir is required\")\n}\n\nfunc TestServer_StreamLogs_FullLog(t *testing.T) {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":18741,"cache_read_input_tokens":55506,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":18741},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e86d396b-c477-4111-8724-c79fdb5bf532","uuid":"94e0b7f8-de24-48c3-907c-5fe23f132fd9"}
