{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K5ZpXotsGxcW72uSHXAoxo","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"os/exec\"\n    14→\t\"path/filepath\"\n    15→\t\"regexp\"\n    16→\t\"sort\"\n    17→\t\"strconv\"\n    18→\t\"strings\"\n    19→\t\"time\"\n    20→\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→)\n    26→\n    27→// HandlerOption configures optional Handler dependencies.\n    28→type HandlerOption func(*Handler)\n    29→\n    30→// WithContainerLogger sets the container runtime for fetching live logs.\n    31→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32→\treturn func(h *Handler) { h.container = c }\n    33→}\n    34→\n    35→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36→func WithContainerManager(c ContainerManager) HandlerOption {\n    37→\treturn func(h *Handler) { h.container = c }\n    38→}\n    39→\n    40→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42→\treturn func(h *Handler) { h.logBroadcast = b }\n    43→}\n    44→\n    45→// WithLogStore sets the log store for indexed log file lookups.\n    46→func WithLogStore(ls ports.LogStore) HandlerOption {\n    47→\treturn func(h *Handler) { h.logStore = ls }\n    48→}\n    49→\n    50→// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    51→func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    52→\treturn func(h *Handler) { h.orchestrateFn = fn }\n    53→}\n    54→\n    55→// OrchestratorController provides per-project orchestrator control.\n    56→type OrchestratorController interface {\n    57→\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    58→\tSetEnabled(dir string, enabled bool)\n    59→\tSetConcurrency(dir string, concurrency int)\n    60→}\n    61→\n    62→// WithOrchestrator sets the orchestrator controller for project-level control.\n    63→func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    64→\treturn func(h *Handler) { h.orchestrator = oc }\n    65→}\n    66→\n    67→//go:embed templates/*.html static/*\n    68→var content embed.FS\n    69→\n    70→// Handler serves the web dashboard.\n    71→// ContainerLogger can retrieve logs from a container by ID.\n    72→type ContainerLogger interface {\n    73→\tLogs(ctx context.Context, containerID string) (string, error)\n    74→}\n    75→\n    76→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    77→type ContainerManager interface {\n    78→\tContainerLogger\n    79→\tRemove(ctx context.Context, containerID string) error\n    80→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    81→}\n    82→\n    83→type Handler struct {\n    84→\tstore         ports.RunStore\n    85→\tcaptures      ports.CaptureStore\n    86→\tlogStore      ports.LogStore\n    87→\tcontainer     ContainerLogger\n    88→\tlogBroadcast  *logstream.Broadcaster\n    89→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    90→\torchestrator  OrchestratorController\n    91→\tpages         map[string]*template.Template\n    92→\tmux           *http.ServeMux\n    93→}\n    94→\n    95→// NewHandler creates a web dashboard handler.\n    96→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    97→\tfuncMap := template.FuncMap{\n    98→\t\t\"stateColor\":       stateColor,\n    99→\t\t\"healthColor\":      healthColor,\n   100→\t\t\"formatTime\":       formatTime,\n   101→\t\t\"formatDuration\":   formatDuration,\n   102→\t\t\"truncate\":         truncate,\n   103→\t\t\"shortContainerID\": shortContainerID,\n   104→\t}\n   105→\n   106→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   107→\tif err != nil {\n   108→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   109→\t}\n   110→\n   111→\tpages := map[string]*template.Template{}\n   112→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   113→\t\tclone, err := base.Clone()\n   114→\t\tif err != nil {\n   115→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   116→\t\t}\n   117→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   118→\t\tif err != nil {\n   119→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   120→\t\t}\n   121→\t\tpages[page] = clone\n   122→\t}\n   123→\n   124→\th := &Handler{\n   125→\t\tstore:    store,\n   126→\t\tcaptures: captures,\n   127→\t\tpages:    pages,\n   128→\t\tmux:      http.NewServeMux(),\n   129→\t}\n   130→\tfor _, opt := range opts {\n   131→\t\topt(h)\n   132→\t}\n   133→\n   134→\tstaticFS, err := fs.Sub(content, \"static\")\n   135→\tif err != nil {\n   136→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   137→\t}\n   138→\n   139→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   140→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   141→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleRunsList)\n   142→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   143→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   144→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   145→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   146→\th.mux.HandleFunc(\"GET /api/projects/{name}/runs\", h.handleAPIRuns)\n   147→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   148→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   149→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   150→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   151→\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   152→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   153→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   154→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   155→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   156→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   157→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   158→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   159→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   160→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   161→\n   162→\treturn h, nil\n   163→}\n   164→\n   165→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   166→\th.mux.ServeHTTP(w, r)\n   167→}\n   168→\n   169→// --- HTML handlers ---\n   170→\n   171→// projectOverviewEntry holds data for a single project card on the landing page.\n   172→type projectOverviewEntry struct {\n   173→\tDir         string\n   174→\tLabel       string\n   175→\tHealth      domain.HealthResult\n   176→\tRecentRuns  []recentRunDot\n   177→\tActiveCount int\n   178→}\n   179→\n   180→// recentRunDot is a minimal representation of a run for the mini history display.\n   181→type recentRunDot struct {\n   182→\tID    string\n   183→\tState string\n   184→}\n   185→\n   186→const healthWindowSize = 10\n   187→\n   188→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   189→\tprojects, _ := h.store.ListProjects(r.Context())\n   190→\tlabels := projectLabels(projects)\n   191→\n   192→\tvar entries []projectOverviewEntry\n   193→\tfor _, dir := range projects {\n   194→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   195→\t\tif err != nil {\n   196→\t\t\tcontinue\n   197→\t\t}\n   198→\n   199→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   200→\t\trunValues := make([]domain.Run, len(runs))\n   201→\t\tfor i, rr := range runs {\n   202→\t\t\trunValues[i] = *rr\n   203→\t\t}\n   204→\n   205→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   206→\n   207→\t\t// Take the last N runs for the mini history (most recent first).\n   208→\t\tn := healthWindowSize\n   209→\t\tif n > len(runs) {\n   210→\t\t\tn = len(runs)\n   211→\t\t}\n   212→\t\tdots := make([]recentRunDot, n)\n   213→\t\tfor i := 0; i < n; i++ {\n   214→\t\t\tdots[i] = recentRunDot{\n   215→\t\t\t\tID:    runs[i].ID,\n   216→\t\t\t\tState: string(runs[i].State),\n   217→\t\t\t}\n   218→\t\t}\n   219→\n   220→\t\tvar activeCount int\n   221→\t\tfor _, rr := range runs {\n   222→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   223→\t\t\t\tactiveCount++\n   224→\t\t\t}\n   225→\t\t}\n   226→\n   227→\t\tentries = append(entries, projectOverviewEntry{\n   228→\t\t\tDir:         dir,\n   229→\t\t\tLabel:       labels[dir],\n   230→\t\t\tHealth:      health,\n   231→\t\t\tRecentRuns:  dots,\n   232→\t\t\tActiveCount: activeCount,\n   233→\t\t})\n   234→\t}\n   235→\n   236→\tsort.Slice(entries, func(i, j int) bool {\n   237→\t\treturn entries[i].Label < entries[j].Label\n   238→\t})\n   239→\n   240→\tdata := map[string]any{\n   241→\t\t\"Title\":    \"Projects\",\n   242→\t\t\"Projects\": entries,\n   243→\t}\n   244→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   245→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   246→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   247→\t}\n   248→}\n   249→\n   250→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   251→\tprojects, _ := h.store.ListProjects(r.Context())\n   252→\tlabels := projectLabels(projects)\n   253→\n   254→\tvar projectFilter string\n   255→\tvar projectLabel string\n   256→\n   257→\t// Resolve project from path parameter (new URL) or query param (backward compat).\n   258→\tif name := r.PathValue(\"name\"); name != \"\" {\n   259→\t\tfor dir, l := range labels {\n   260→\t\t\tif l == name {\n   261→\t\t\t\tprojectFilter = dir\n   262→\t\t\t\tprojectLabel = name\n   263→\t\t\t\tbreak\n   264→\t\t\t}\n   265→\t\t}\n   266→\t\tif projectFilter == \"\" {\n   267→\t\t\thttp.Error(w, \"project not found\", http.StatusNotFound)\n   268→\t\t\treturn\n   269→\t\t}\n   270→\t} else if qp := r.URL.Query().Get(\"project\"); qp != \"\" {\n   271→\t\tprojectFilter = qp\n   272→\t\tprojectLabel = labels[qp]\n   273→\t}\n   274→\n   275→\tvar runs []*domain.Run\n   276→\tvar err error\n   277→\tif projectFilter != \"\" {\n   278→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   279→\t} else {\n   280→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   281→\t}\n   282→\tif err != nil {\n   283→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   284→\t\treturn\n   285→\t}\n   286→\n   287→\t// Count retained containers per project\n   288→\tcontainerCounts := map[string]int{}\n   289→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   290→\tfor _, run := range allRuns {\n   291→\t\tif run.ContainerKept {\n   292→\t\t\tcontainerCounts[run.ProjectDir]++\n   293→\t\t}\n   294→\t}\n   295→\n   296→\tvar projectList []projectEntry\n   297→\tfor _, dir := range projects {\n   298→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   299→\t}\n   300→\tsort.Slice(projectList, func(i, j int) bool {\n   301→\t\treturn projectList[i].Label < projectList[j].Label\n   302→\t})\n   303→\n   304→\tdata := map[string]any{\n   305→\t\t\"Title\":         \"Runs\",\n   306→\t\t\"Runs\":          runs,\n   307→\t\t\"Projects\":      projectList,\n   308→\t\t\"ProjectFilter\": projectFilter,\n   309→\t\t\"ProjectLabel\":  projectLabel,\n   310→\t\t\"ProjectLabels\": labels,\n   311→\t}\n   312→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   313→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   314→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   315→\t}\n   316→}\n   317→\n   318→// stepEntry is a merged view of a step execution for the template.\n   319→type stepEntry struct {\n   320→\tIndex     int\n   321→\tStepName  string\n   322→\tResult    string\n   323→\tStartedAt time.Time\n   324→\tDuration  string\n   325→}\n   326→\n   327→// mergeCaptures collapses started/completed capture pairs into single entries.\n   328→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   329→\tvar entries []stepEntry\n   330→\t// Track pending started rows by step name (LIFO for retries)\n   331→\tpending := map[string]*domain.StepExecution{}\n   332→\n   333→\tfor _, c := range caps {\n   334→\t\tif c.Result == \"\" {\n   335→\t\t\t// step_started row\n   336→\t\t\tpending[c.StepName] = c\n   337→\t\t\tcontinue\n   338→\t\t}\n   339→\t\t// step_completed row — merge with pending started if available\n   340→\t\tstartedAt := c.StartedAt\n   341→\t\tif started := pending[c.StepName]; started != nil {\n   342→\t\t\tstartedAt = started.StartedAt\n   343→\t\t\tdelete(pending, c.StepName)\n   344→\t\t}\n   345→\t\tentries = append(entries, stepEntry{\n   346→\t\t\tIndex:     len(entries),\n   347→\t\t\tStepName:  c.StepName,\n   348→\t\t\tResult:    c.Result,\n   349→\t\t\tStartedAt: startedAt,\n   350→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   351→\t\t})\n   352→\t}\n   353→\n   354→\t// Append any started-but-not-completed steps (still running)\n   355→\tfor _, c := range caps {\n   356→\t\tif c.Result == \"\" {\n   357→\t\t\tif _, used := pending[c.StepName]; !used {\n   358→\t\t\t\tcontinue\n   359→\t\t\t}\n   360→\t\t\tentries = append(entries, stepEntry{\n   361→\t\t\t\tIndex:     len(entries),\n   362→\t\t\t\tStepName:  c.StepName,\n   363→\t\t\t\tStartedAt: c.StartedAt,\n   364→\t\t\t})\n   365→\t\t\tdelete(pending, c.StepName)\n   366→\t\t}\n   367→\t}\n   368→\n   369→\treturn entries\n   370→}\n   371→\n   372→// containerState inspects the container for a run and returns one of:\n   373→//   - \"running\"   – container exists and is running\n   374→//   - \"stopped\"   – container exists, not running, not kept\n   375→//   - \"available\" – container exists, not running, kept (can be deleted)\n   376→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   377→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   378→\tif run.ContainerID == \"\" {\n   379→\t\treturn \"removed\"\n   380→\t}\n   381→\tmgr, ok := h.container.(ContainerManager)\n   382→\tif !ok {\n   383→\t\treturn \"removed\"\n   384→\t}\n   385→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   386→\tif err != nil {\n   387→\t\treturn \"removed\"\n   388→\t}\n   389→\tif status.Running {\n   390→\t\treturn \"running\"\n   391→\t}\n   392→\tif run.ContainerKept {\n   393→\t\treturn \"available\"\n   394→\t}\n   395→\treturn \"stopped\"\n   396→}\n   397→\n   398→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   399→\tid := r.PathValue(\"id\")\n   400→\n   401→\trun, err := h.store.GetRun(r.Context(), id)\n   402→\tif err != nil {\n   403→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   404→\t\treturn\n   405→\t}\n   406→\n   407→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   408→\tif err != nil {\n   409→\t\tcaps = nil // non-fatal\n   410→\t}\n   411→\n   412→\tsteps := mergeCaptures(caps)\n   413→\n   414→\tdata := map[string]any{\n   415→\t\t\"Title\":          \"Run \" + run.ID,\n   416→\t\t\"Run\":            run,\n   417→\t\t\"Steps\":          steps,\n   418→\t\t\"Page\":           \"detail\",\n   419→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   420→\t}\n   421→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   422→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   423→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   424→\t}\n   425→}\n   426→\n   427→// --- JSON API handlers ---\n   428→\n   429→type apiRun struct {\n   430→\tID           string `json:\"id\"`\n   431→\tWorkflowName string `json:\"workflow_name\"`\n   432→\tProjectDir   string `json:\"project_dir\"`\n   433→\tProjectLabel string `json:\"project_label\"`\n   434→\tState        string `json:\"state\"`\n   435→\tStartedAt    string `json:\"started_at\"`\n   436→\tCompletedAt  string `json:\"completed_at\"`\n   437→\tContainerID  string `json:\"container_id\"`\n   438→\tErrorMessage string `json:\"error_message\"`\n   439→}\n   440→\n   441→type apiStep struct {\n   442→\tStepName    string `json:\"step_name\"`\n   443→\tResult      string `json:\"result\"`\n   444→\tStartedAt   string `json:\"started_at\"`\n   445→\tCompletedAt string `json:\"completed_at\"`\n   446→\tDuration    string `json:\"duration\"`\n   447→}\n   448→\n   449→type apiRunDetail struct {\n   450→\tapiRun\n   451→\tContainerState string    `json:\"container_state\"`\n   452→\tSteps          []apiStep `json:\"steps\"`\n   453→}\n   454→\n   455→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   456→\treturn apiRun{\n   457→\t\tID:           r.ID,\n   458→\t\tWorkflowName: r.WorkflowName,\n   459→\t\tProjectDir:   r.ProjectDir,\n   460→\t\tProjectLabel: labels[r.ProjectDir],\n   461→\t\tState:        string(r.State),\n   462→\t\tStartedAt:    formatTime(r.StartedAt),\n   463→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   464→\t\tContainerID:  r.ContainerID,\n   465→\t\tErrorMessage: r.ErrorMessage,\n   466→\t}\n   467→}\n   468→\n   469→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   470→\tprojects, _ := h.store.ListProjects(r.Context())\n   471→\tlabels := projectLabels(projects)\n   472→\n   473→\tvar projectFilter string\n   474→\n   475→\t// Resolve project from path parameter (new URL) or query param (backward compat).\n   476→\tif name := r.PathValue(\"name\"); name != \"\" {\n   477→\t\tfor dir, l := range labels {\n   478→\t\t\tif l == name {\n   479→\t\t\t\tprojectFilter = dir\n   480→\t\t\t\tbreak\n   481→\t\t\t}\n   482→\t\t}\n   483→\t\tif projectFilter == \"\" {\n   484→\t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   485→\t\t\tw.WriteHeader(http.StatusNotFound)\n   486→\t\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   487→\t\t\treturn\n   488→\t\t}\n   489→\t} else {\n   490→\t\tprojectFilter = r.URL.Query().Get(\"project\")\n   491→\t}\n   492→\n   493→\tvar runs []*domain.Run\n   494→\tvar err error\n   495→\tif projectFilter != \"\" {\n   496→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   497→\t} else {\n   498→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   499→\t}\n   500→\tif err != nil {\n   501→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   502→\t\treturn\n   503→\t}\n   504→\n   505→\tresult := make([]apiRun, len(runs))\n   506→\tfor i, run := range runs {\n   507→\t\tresult[i] = toAPIRun(run, labels)\n   508→\t}\n   509→\n   510→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   511→\tjson.NewEncoder(w).Encode(result)\n   512→}\n   513→\n   514→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   515→\tprojects, err := h.store.ListProjects(r.Context())\n   516→\tif err != nil {\n   517→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   518→\t\treturn\n   519→\t}\n   520→\tlabels := projectLabels(projects)\n   521→\n   522→\ttype apiHealth struct {\n   523→\t\tStatus string `json:\"status\"`\n   524→\t\tPassed int    `json:\"passed\"`\n   525→\t\tFailed int    `json:\"failed\"`\n   526→\t\tTotal  int    `json:\"total\"`\n   527→\t}\n   528→\ttype apiProject struct {\n   529→\t\tDir         string    `json:\"dir\"`\n   530→\t\tLabel       string    `json:\"label\"`\n   531→\t\tHealth      apiHealth `json:\"health\"`\n   532→\t\tActiveCount int       `json:\"active_count\"`\n   533→\t}\n   534→\tresult := make([]apiProject, len(projects))\n   535→\tfor i, dir := range projects {\n   536→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   537→\t\trunValues := make([]domain.Run, len(runs))\n   538→\t\tfor j, rr := range runs {\n   539→\t\t\trunValues[j] = *rr\n   540→\t\t}\n   541→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   542→\t\tvar activeCount int\n   543→\t\tfor _, rr := range runs {\n   544→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   545→\t\t\t\tactiveCount++\n   546→\t\t\t}\n   547→\t\t}\n   548→\t\tresult[i] = apiProject{\n   549→\t\t\tDir:   dir,\n   550→\t\t\tLabel: labels[dir],\n   551→\t\t\tHealth: apiHealth{\n   552→\t\t\t\tStatus: string(health.Status),\n   553→\t\t\t\tPassed: health.Passed,\n   554→\t\t\t\tFailed: health.Failed,\n   555→\t\t\t\tTotal:  health.Total,\n   556→\t\t\t},\n   557→\t\t\tActiveCount: activeCount,\n   558→\t\t}\n   559→\t}\n   560→\n   561→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   562→\tjson.NewEncoder(w).Encode(result)\n   563→}\n   564→\n   565→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   566→\tid := r.PathValue(\"id\")\n   567→\n   568→\trun, err := h.store.GetRun(r.Context(), id)\n   569→\tif err != nil {\n   570→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   571→\t\treturn\n   572→\t}\n   573→\n   574→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   575→\tif err != nil {\n   576→\t\tcaps = nil\n   577→\t}\n   578→\n   579→\tprojects, _ := h.store.ListProjects(r.Context())\n   580→\tlabels := projectLabels(projects)\n   581→\n   582→\tmerged := mergeCaptures(caps)\n   583→\tsteps := make([]apiStep, len(merged))\n   584→\tfor i, e := range merged {\n   585→\t\tsteps[i] = apiStep{\n   586→\t\t\tStepName:  e.StepName,\n   587→\t\t\tResult:    e.Result,\n   588→\t\t\tStartedAt: formatTime(e.StartedAt),\n   589→\t\t\tDuration:  e.Duration,\n   590→\t\t}\n   591→\t}\n   592→\n   593→\tdetail := apiRunDetail{\n   594→\t\tapiRun:         toAPIRun(run, labels),\n   595→\t\tContainerState: h.containerState(r.Context(), run),\n   596→\t\tSteps:          steps,\n   597→\t}\n   598→\n   599→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   600→\tjson.NewEncoder(w).Encode(detail)\n   601→}\n   602→\n   603→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   604→\tid := r.PathValue(\"id\")\n   605→\tstep := r.PathValue(\"step\")\n   606→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   607→\n   608→\trun, err := h.store.GetRun(r.Context(), id)\n   609→\tif err != nil {\n   610→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   611→\t\treturn\n   612→\t}\n   613→\n   614→\t// Try log index first for fast lookup\n   615→\tif h.logStore != nil {\n   616→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   617→\t\tif err == nil && len(logFiles) > 0 {\n   618→\t\t\t// If type filter specified, narrow results\n   619→\t\t\tfor _, lf := range logFiles {\n   620→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   621→\t\t\t\t\tcontinue\n   622→\t\t\t\t}\n   623→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   624→\t\t\t\tif readErr == nil && len(data) > 0 {\n   625→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   626→\t\t\t\t\tw.Write(data)\n   627→\t\t\t\t\treturn\n   628→\t\t\t\t}\n   629→\t\t\t}\n   630→\t\t}\n   631→\t}\n   632→\n   633→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   634→\n   635→\t// Fall back to file path conventions\n   636→\t// If type is \"llm\", try llm-<step>.log\n   637→\tif logType == \"llm\" {\n   638→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   639→\t\tdata, err := os.ReadFile(llmPath)\n   640→\t\tif err == nil && len(data) > 0 {\n   641→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   642→\t\t\tw.Write(data)\n   643→\t\t\treturn\n   644→\t\t}\n   645→\t}\n   646→\n   647→\t// Try per-step output first, fall back to container.log, then live docker logs\n   648→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   649→\tdata, err := os.ReadFile(outputPath)\n   650→\tif err == nil && len(data) > 0 {\n   651→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   652→\t\tw.Write(data)\n   653→\t\treturn\n   654→\t}\n   655→\n   656→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   657→\tdata, err = os.ReadFile(containerLog)\n   658→\tif err == nil && len(data) > 0 {\n   659→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   660→\t\tw.Write(data)\n   661→\t\treturn\n   662→\t}\n   663→\n   664→\t// Last resort: try live docker logs from still-existing container\n   665→\tif h.container != nil && run.ContainerID != \"\" {\n   666→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   667→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   668→\t\t\tw.Write([]byte(logs))\n   669→\t\t\treturn\n   670→\t\t}\n   671→\t}\n   672→\n   673→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   674→}\n   675→\n   676→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   677→\tid := r.PathValue(\"id\")\n   678→\n   679→\trun, err := h.store.GetRun(r.Context(), id)\n   680→\tif err != nil {\n   681→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   682→\t\tw.WriteHeader(http.StatusNotFound)\n   683→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   684→\t\treturn\n   685→\t}\n   686→\n   687→\tmgr, ok := h.container.(ContainerManager)\n   688→\tif !ok || run.ContainerID == \"\" {\n   689→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   690→\t\tw.WriteHeader(http.StatusBadRequest)\n   691→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   692→\t\treturn\n   693→\t}\n   694→\n   695→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   696→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   697→\t\tw.WriteHeader(http.StatusInternalServerError)\n   698→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   699→\t\treturn\n   700→\t}\n   701→\n   702→\trun.ContainerKept = false\n   703→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   704→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   705→\t\tw.WriteHeader(http.StatusInternalServerError)\n   706→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   707→\t\treturn\n   708→\t}\n   709→\n   710→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   711→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   712→}\n   713→\n   714→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   715→\tlabel := r.PathValue(\"name\")\n   716→\n   717→\t// Resolve label back to project directory via the store.\n   718→\tprojects, _ := h.store.ListProjects(r.Context())\n   719→\tlabels := projectLabels(projects)\n   720→\tvar projectDir string\n   721→\tfor dir, l := range labels {\n   722→\t\tif l == label {\n   723→\t\t\tprojectDir = dir\n   724→\t\t\tbreak\n   725→\t\t}\n   726→\t}\n   727→\tif projectDir == \"\" {\n   728→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   729→\t\tw.WriteHeader(http.StatusNotFound)\n   730→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   731→\t\treturn\n   732→\t}\n   733→\n   734→\tif h.orchestrateFn == nil {\n   735→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   736→\t\tw.WriteHeader(http.StatusNotImplemented)\n   737→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   738→\t\treturn\n   739→\t}\n   740→\n   741→\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   742→\tif err != nil {\n   743→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   744→\t\tw.WriteHeader(http.StatusInternalServerError)\n   745→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   746→\t\treturn\n   747→\t}\n   748→\n   749→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   750→\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   751→}\n   752→\n   753→// handleAPIStream serves an SSE stream of log lines for a run.\n   754→// For active runs, it subscribes to the live broadcaster.\n   755→// For completed runs, it serves the archived full.log then closes.\n   756→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   757→\tid := r.PathValue(\"id\")\n   758→\n   759→\trun, err := h.store.GetRun(r.Context(), id)\n   760→\tif err != nil {\n   761→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   762→\t\treturn\n   763→\t}\n   764→\n   765→\tflusher, ok := w.(http.Flusher)\n   766→\tif !ok {\n   767→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   768→\t\treturn\n   769→\t}\n   770→\n   771→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   772→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   773→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   774→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   775→\n   776→\tisComplete := run.State == domain.RunStateSucceeded ||\n   777→\t\trun.State == domain.RunStateFailed ||\n   778→\t\trun.State == domain.RunStateCancelled\n   779→\n   780→\tif isComplete {\n   781→\t\t// Serve archived full.log\n   782→\t\th.streamFullLog(w, flusher, run)\n   783→\t\t// Send done event\n   784→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   785→\t\tflusher.Flush()\n   786→\t\treturn\n   787→\t}\n   788→\n   789→\t// Active run: subscribe to live broadcaster\n   790→\tif h.logBroadcast == nil {\n   791→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   792→\t\treturn\n   793→\t}\n   794→\n   795→\tsub := h.logBroadcast.Subscribe(id)\n   796→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   797→\n   798→\tctx := r.Context()\n   799→\tfor {\n   800→\t\tselect {\n   801→\t\tcase <-ctx.Done():\n   802→\t\t\treturn\n   803→\t\tcase line, ok := <-sub.C:\n   804→\t\t\tif !ok {\n   805→\t\t\t\t// Stream finished (run completed)\n   806→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   807→\t\t\t\tflusher.Flush()\n   808→\t\t\t\treturn\n   809→\t\t\t}\n   810→\t\t\tdata, _ := json.Marshal(line)\n   811→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   812→\t\t\tflusher.Flush()\n   813→\t\t}\n   814→\t}\n   815→}\n   816→\n   817→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   818→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   819→\n   820→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   821→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   822→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   823→\tf, err := os.Open(logPath)\n   824→\tif err != nil {\n   825→\t\treturn\n   826→\t}\n   827→\tdefer f.Close()\n   828→\n   829→\tscanner := bufio.NewScanner(f)\n   830→\tfor scanner.Scan() {\n   831→\t\ttext := scanner.Text()\n   832→\t\tline := parseFullLogLine(text)\n   833→\t\tdata, _ := json.Marshal(line)\n   834→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   835→\t\tflusher.Flush()\n   836→\t}\n   837→}\n   838→\n   839→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   840→func parseFullLogLine(text string) logstream.LogLine {\n   841→\tm := logLineRegex.FindStringSubmatch(text)\n   842→\tif m == nil {\n   843→\t\treturn logstream.LogLine{\n   844→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   845→\t\t\tType:      \"script\",\n   846→\t\t\tContent:   text,\n   847→\t\t}\n   848→\t}\n   849→\treturn logstream.LogLine{\n   850→\t\tTimestamp: m[1],\n   851→\t\tType:      m[2],\n   852→\t\tContent:   m[3],\n   853→\t}\n   854→}\n   855→\n   856→// --- Project detail handlers ---\n   857→\n   858→// resolveProjectDir resolves a project label from the URL to its directory path.\n   859→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   860→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   861→\tlabel := r.PathValue(\"name\")\n   862→\tprojects, _ := h.store.ListProjects(r.Context())\n   863→\tlabels := projectLabels(projects)\n   864→\tfor dir, l := range labels {\n   865→\t\tif l == label {\n   866→\t\t\treturn dir, label, true\n   867→\t\t}\n   868→\t}\n   869→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   870→\tw.WriteHeader(http.StatusNotFound)\n   871→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   872→\treturn \"\", \"\", false\n   873→}\n   874→\n   875→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   876→\tdir, label, ok := h.resolveProjectDir(w, r)\n   877→\tif !ok {\n   878→\t\treturn\n   879→\t}\n   880→\n   881→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   882→\tn := 10\n   883→\tif n > len(runs) {\n   884→\t\tn = len(runs)\n   885→\t}\n   886→\tdots := make([]recentRunDot, n)\n   887→\tfor i := 0; i < n; i++ {\n   888→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   889→\t}\n   890→\n   891→\tdata := map[string]any{\n   892→\t\t\"Title\":      label,\n   893→\t\t\"Label\":      label,\n   894→\t\t\"Dir\":        dir,\n   895→\t\t\"RecentRuns\": dots,\n   896→\t}\n   897→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   898→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   899→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   900→\t}\n   901→}\n   902→\n   903→func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   904→\tdir, _, ok := h.resolveProjectDir(w, r)\n   905→\tif !ok {\n   906→\t\treturn\n   907→\t}\n   908→\tif h.orchestrator == nil {\n   909→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   910→\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   911→\t\treturn\n   912→\t}\n   913→\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   914→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   915→\tjson.NewEncoder(w).Encode(map[string]any{\n   916→\t\t\"enabled\":     enabled,\n   917→\t\t\"in_flight\":   inFlight,\n   918→\t\t\"concurrency\": concurrency,\n   919→\t})\n   920→}\n   921→\n   922→func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   923→\tdir, _, ok := h.resolveProjectDir(w, r)\n   924→\tif !ok {\n   925→\t\treturn\n   926→\t}\n   927→\tif h.orchestrator == nil {\n   928→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   929→\t\tw.WriteHeader(http.StatusNotImplemented)\n   930→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   931→\t\treturn\n   932→\t}\n   933→\th.orchestrator.SetEnabled(dir, true)\n   934→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   935→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   936→}\n   937→\n   938→func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   939→\tdir, _, ok := h.resolveProjectDir(w, r)\n   940→\tif !ok {\n   941→\t\treturn\n   942→\t}\n   943→\tif h.orchestrator == nil {\n   944→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   945→\t\tw.WriteHeader(http.StatusNotImplemented)\n   946→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   947→\t\treturn\n   948→\t}\n   949→\th.orchestrator.SetEnabled(dir, false)\n   950→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   951→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   952→}\n   953→\n   954→func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   955→\tdir, _, ok := h.resolveProjectDir(w, r)\n   956→\tif !ok {\n   957→\t\treturn\n   958→\t}\n   959→\tif h.orchestrator == nil {\n   960→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   961→\t\tw.WriteHeader(http.StatusNotImplemented)\n   962→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   963→\t\treturn\n   964→\t}\n   965→\tvar body struct {\n   966→\t\tConcurrency int `json:\"concurrency\"`\n   967→\t}\n   968→\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n   969→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   970→\t\tw.WriteHeader(http.StatusBadRequest)\n   971→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n   972→\t\treturn\n   973→\t}\n   974→\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n   975→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   976→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   977→}\n   978→\n   979→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   980→\tdir, _, ok := h.resolveProjectDir(w, r)\n   981→\tif !ok {\n   982→\t\treturn\n   983→\t}\n   984→\n   985→\t// Docker image: read FROM line from Dockerfile\n   986→\tdockerImage := \"\"\n   987→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   988→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   989→\t\t// Find the last FROM line (final stage)\n   990→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   991→\t\t\ttrimmed := strings.TrimSpace(line)\n   992→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   993→\t\t\t\tparts := strings.Fields(trimmed)\n   994→\t\t\t\tif len(parts) >= 2 {\n   995→\t\t\t\t\tdockerImage = parts[1]\n   996→\t\t\t\t}\n   997→\t\t\t}\n   998→\t\t}\n   999→\t}\n  1000→\n  1001→\t// Version\n  1002→\tversion := 0\n  1003→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n  1004→\tif data, err := os.ReadFile(versionPath); err == nil {\n  1005→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n  1006→\t\t\tversion = v\n  1007→\t\t}\n  1008→\t}\n  1009→\n  1010→\t// Prompt files history\n  1011→\ttype commitEntry struct {\n  1012→\t\tSHA     string `json:\"sha\"`\n  1013→\t\tDate    string `json:\"date\"`\n  1014→\t\tMessage string `json:\"message\"`\n  1015→\t}\n  1016→\ttype promptFile struct {\n  1017→\t\tPath    string        `json:\"path\"`\n  1018→\t\tHistory []commitEntry `json:\"history\"`\n  1019→\t}\n  1020→\n  1021→\tvar promptFiles []promptFile\n  1022→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n  1023→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n  1024→\t\tfor _, e := range entries {\n  1025→\t\t\tif e.IsDir() {\n  1026→\t\t\t\tcontinue\n  1027→\t\t\t}\n  1028→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n  1029→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n  1030→\t\t\tcmd.Dir = dir\n  1031→\t\t\tout, err := cmd.Output()\n  1032→\t\t\tif err != nil {\n  1033→\t\t\t\tcontinue\n  1034→\t\t\t}\n  1035→\t\t\tvar history []commitEntry\n  1036→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n  1037→\t\t\t\tif line == \"\" {\n  1038→\t\t\t\t\tcontinue\n  1039→\t\t\t\t}\n  1040→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1041→\t\t\t\tif len(parts) < 3 {\n  1042→\t\t\t\t\tcontinue\n  1043→\t\t\t\t}\n  1044→\t\t\t\t// Parse date to short form\n  1045→\t\t\t\tdateStr := parts[1]\n  1046→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1047→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1048→\t\t\t\t}\n  1049→\t\t\t\thistory = append(history, commitEntry{\n  1050→\t\t\t\t\tSHA:     parts[0][:7],\n  1051→\t\t\t\t\tDate:    dateStr,\n  1052→\t\t\t\t\tMessage: parts[2],\n  1053→\t\t\t\t})\n  1054→\t\t\t}\n  1055→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1056→\t\t}\n  1057→\t}\n  1058→\n  1059→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1060→\tjson.NewEncoder(w).Encode(map[string]any{\n  1061→\t\t\"docker_image\": dockerImage,\n  1062→\t\t\"version\":      version,\n  1063→\t\t\"prompt_files\": promptFiles,\n  1064→\t})\n  1065→}\n  1066→\n  1067→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1068→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1069→\tif !ok {\n  1070→\t\treturn\n  1071→\t}\n  1072→\tfile := r.URL.Query().Get(\"file\")\n  1073→\tsha := r.URL.Query().Get(\"sha\")\n  1074→\tif file == \"\" || sha == \"\" {\n  1075→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1076→\t\treturn\n  1077→\t}\n  1078→\n  1079→\t// Validate sha is alphanumeric to prevent injection\n  1080→\tfor _, c := range sha {\n  1081→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1082→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1083→\t\t\treturn\n  1084→\t\t}\n  1085→\t}\n  1086→\n  1087→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1088→\tcmd.Dir = dir\n  1089→\tout, err := cmd.Output()\n  1090→\tif err != nil {\n  1091→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1092→\t\treturn\n  1093→\t}\n  1094→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1095→\tw.Write(out)\n  1096→}\n  1097→\n  1098→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1099→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1100→\tif !ok {\n  1101→\t\treturn\n  1102→\t}\n  1103→\n  1104→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1105→\tentries, err := os.ReadDir(clocheDir)\n  1106→\tif err != nil {\n  1107→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1108→\t\tjson.NewEncoder(w).Encode([]any{})\n  1109→\t\treturn\n  1110→\t}\n  1111→\n  1112→\ttype apiWire struct {\n  1113→\t\tFrom   string `json:\"from\"`\n  1114→\t\tResult string `json:\"result\"`\n  1115→\t\tTo     string `json:\"to\"`\n  1116→\t}\n  1117→\ttype apiStepDef struct {\n  1118→\t\tName    string            `json:\"name\"`\n  1119→\t\tType    string            `json:\"type\"`\n  1120→\t\tResults []string          `json:\"results\"`\n  1121→\t\tConfig  map[string]string `json:\"config\"`\n  1122→\t}\n  1123→\ttype apiWorkflow struct {\n  1124→\t\tName      string       `json:\"name\"`\n  1125→\t\tFile      string       `json:\"file\"`\n  1126→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1127→\t\tWires     []apiWire    `json:\"wires\"`\n  1128→\t\tEntryStep string       `json:\"entry_step\"`\n  1129→\t}\n  1130→\n  1131→\tvar workflows []apiWorkflow\n  1132→\tfor _, e := range entries {\n  1133→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1134→\t\t\tcontinue\n  1135→\t\t}\n  1136→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1137→\t\tif err != nil {\n  1138→\t\t\tcontinue\n  1139→\t\t}\n  1140→\t\twf, err := dsl.Parse(string(data))\n  1141→\t\tif err != nil {\n  1142→\t\t\tcontinue\n  1143→\t\t}\n  1144→\t\tvar steps []apiStepDef\n  1145→\t\tfor _, s := range wf.Steps {\n  1146→\t\t\tsteps = append(steps, apiStepDef{\n  1147→\t\t\t\tName:    s.Name,\n  1148→\t\t\t\tType:    string(s.Type),\n  1149→\t\t\t\tResults: s.Results,\n  1150→\t\t\t\tConfig:  s.Config,\n  1151→\t\t\t})\n  1152→\t\t}\n  1153→\t\t// Sort steps by name for consistent ordering\n  1154→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1155→\n  1156→\t\tvar wires []apiWire\n  1157→\t\tfor _, wire := range wf.Wiring {\n  1158→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1159→\t\t}\n  1160→\n  1161→\t\tworkflows = append(workflows, apiWorkflow{\n  1162→\t\t\tName:      wf.Name,\n  1163→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1164→\t\t\tSteps:     steps,\n  1165→\t\t\tWires:     wires,\n  1166→\t\t\tEntryStep: wf.EntryStep,\n  1167→\t\t})\n  1168→\t}\n  1169→\n  1170→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1171→\tjson.NewEncoder(w).Encode(workflows)\n  1172→}\n  1173→\n  1174→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1175→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1176→\tif !ok {\n  1177→\t\treturn\n  1178→\t}\n  1179→\tworkflowName := r.PathValue(\"workflow\")\n  1180→\tstepName := r.PathValue(\"step\")\n  1181→\n  1182→\t// Find the workflow file\n  1183→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1184→\tvar wf *domain.Workflow\n  1185→\tentries, _ := os.ReadDir(clocheDir)\n  1186→\tfor _, e := range entries {\n  1187→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1188→\t\t\tcontinue\n  1189→\t\t}\n  1190→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1191→\t\tif err != nil {\n  1192→\t\t\tcontinue\n  1193→\t\t}\n  1194→\t\tparsed, err := dsl.Parse(string(data))\n  1195→\t\tif err != nil {\n  1196→\t\t\tcontinue\n  1197→\t\t}\n  1198→\t\tif parsed.Name == workflowName {\n  1199→\t\t\twf = parsed\n  1200→\t\t\tbreak\n  1201→\t\t}\n  1202→\t}\n  1203→\tif wf == nil {\n  1204→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1205→\t\treturn\n  1206→\t}\n  1207→\n  1208→\tstep, ok := wf.Steps[stepName]\n  1209→\tif !ok {\n  1210→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1211→\t\treturn\n  1212→\t}\n  1213→\n  1214→\t// Try to read the referenced file from step config\n  1215→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1216→\n  1217→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1218→\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1219→\t\tif err == nil {\n  1220→\t\t\tw.Write(data)\n  1221→\t\t\treturn\n  1222→\t\t}\n  1223→\t}\n  1224→\tif script := step.Config[\"command\"]; script != \"\" {\n  1225→\t\tw.Write([]byte(script))\n  1226→\t\treturn\n  1227→\t}\n  1228→\tif script := step.Config[\"script\"]; script != \"\" {\n  1229→\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1230→\t\tif err == nil {\n  1231→\t\t\tw.Write(data)\n  1232→\t\t\treturn\n  1233→\t\t}\n  1234→\t\tw.Write([]byte(script))\n  1235→\t\treturn\n  1236→\t}\n  1237→\n  1238→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1239→}\n  1240→\n  1241→// --- Template helpers ---\n  1242→\n  1243→func stateColor(state domain.RunState) string {\n  1244→\tswitch state {\n  1245→\tcase domain.RunStatePending:\n  1246→\t\treturn \"pending\"\n  1247→\tcase domain.RunStateRunning:\n  1248→\t\treturn \"running\"\n  1249→\tcase domain.RunStateSucceeded:\n  1250→\t\treturn \"succeeded\"\n  1251→\tcase domain.RunStateFailed:\n  1252→\t\treturn \"failed\"\n  1253→\tcase domain.RunStateCancelled:\n  1254→\t\treturn \"cancelled\"\n  1255→\tdefault:\n  1256→\t\treturn \"pending\"\n  1257→\t}\n  1258→}\n  1259→\n  1260→func healthColor(status domain.HealthStatus) string {\n  1261→\tswitch status {\n  1262→\tcase domain.HealthGreen:\n  1263→\t\treturn \"green\"\n  1264→\tcase domain.HealthYellow:\n  1265→\t\treturn \"yellow\"\n  1266→\tcase domain.HealthRed:\n  1267→\t\treturn \"red\"\n  1268→\tcase domain.HealthBlue:\n  1269→\t\treturn \"blue\"\n  1270→\tdefault:\n  1271→\t\treturn \"grey\"\n  1272→\t}\n  1273→}\n  1274→\n  1275→func formatTime(t time.Time) string {\n  1276→\tif t.IsZero() {\n  1277→\t\treturn \"\"\n  1278→\t}\n  1279→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1280→}\n  1281→\n  1282→func formatDuration(start, end time.Time) string {\n  1283→\tif start.IsZero() || end.IsZero() {\n  1284→\t\treturn \"\"\n  1285→\t}\n  1286→\td := end.Sub(start)\n  1287→\tif d < time.Second {\n  1288→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1289→\t}\n  1290→\tif d < time.Minute {\n  1291→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1292→\t}\n  1293→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1294→}\n  1295→\n  1296→func truncate(s string, n int) string {\n  1297→\tif len(s) <= n {\n  1298→\t\treturn s\n  1299→\t}\n  1300→\treturn s[:n] + \"...\"\n  1301→}\n  1302→\n  1303→func shortContainerID(id string) string {\n  1304→\tif len(id) > 12 {\n  1305→\t\treturn id[:12]\n  1306→\t}\n  1307→\treturn id\n  1308→}\n  1309→\n  1310→// projectLabels builds a mapping from full project directory paths to short\n  1311→// display labels. Each label is the final directory component (e.g.\n  1312→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1313→// the same final name, the parent directory is prepended to disambiguate\n  1314→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1315→func projectLabels(dirs []string) map[string]string {\n  1316→\tlabels := make(map[string]string, len(dirs))\n  1317→\t// Group dirs by their base name to detect conflicts.\n  1318→\tbyBase := map[string][]string{}\n  1319→\tfor _, d := range dirs {\n  1320→\t\tbase := filepath.Base(d)\n  1321→\t\tbyBase[base] = append(byBase[base], d)\n  1322→\t}\n  1323→\tfor base, paths := range byBase {\n  1324→\t\tif len(paths) == 1 {\n  1325→\t\t\tlabels[paths[0]] = base\n  1326→\t\t} else {\n  1327→\t\t\tfor _, p := range paths {\n  1328→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1329→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1330→\t\t\t}\n  1331→\t\t}\n  1332→\t}\n  1333→\treturn labels\n  1334→}\n  1335→\n  1336→type projectEntry struct {\n  1337→\tDir            string\n  1338→\tLabel          string\n  1339→\tContainerCount int\n  1340→}\n  1341→"}]},"parent_tool_use_id":null,"session_id":"f56f513b-6df1-4b82-93e1-87d3a5a45d09","uuid":"dd61d80f-09fe-4de8-9dc2-de1dabad873b","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\nfunc WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n\treturn func(h *Handler) { h.orchestrateFn = fn }\n}\n\n// OrchestratorController provides per-project orchestrator control.\ntype OrchestratorController interface {\n\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n\tSetEnabled(dir string, enabled bool)\n\tSetConcurrency(dir string, concurrency int)\n}\n\n// WithOrchestrator sets the orchestrator controller for project-level control.\nfunc WithOrchestrator(oc OrchestratorController) HandlerOption {\n\treturn func(h *Handler) { h.orchestrator = oc }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore         ports.RunStore\n\tcaptures      ports.CaptureStore\n\tlogStore      ports.LogStore\n\tcontainer     ContainerLogger\n\tlogBroadcast  *logstream.Broadcaster\n\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n\torchestrator  OrchestratorController\n\tpages         map[string]*template.Template\n\tmux           *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar projectFilter string\n\tvar projectLabel string\n\n\t// Resolve project from path parameter (new URL) or query param (backward compat).\n\tif name := r.PathValue(\"name\"); name != \"\" {\n\t\tfor dir, l := range labels {\n\t\t\tif l == name {\n\t\t\t\tprojectFilter = dir\n\t\t\t\tprojectLabel = name\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif projectFilter == \"\" {\n\t\t\thttp.Error(w, \"project not found\", http.StatusNotFound)\n\t\t\treturn\n\t\t}\n\t} else if qp := r.URL.Query().Get(\"project\"); qp != \"\" {\n\t\tprojectFilter = qp\n\t\tprojectLabel = labels[qp]\n\t}\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabel\":  projectLabel,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar projectFilter string\n\n\t// Resolve project from path parameter (new URL) or query param (backward compat).\n\tif name := r.PathValue(\"name\"); name != \"\" {\n\t\tfor dir, l := range labels {\n\t\t\tif l == name {\n\t\t\t\tprojectFilter = dir\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif projectFilter == \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\t\tw.WriteHeader(http.StatusNotFound)\n\t\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\t\t\treturn\n\t\t}\n\t} else {\n\t\tprojectFilter = r.URL.Query().Get(\"project\")\n\t}\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\n\t// Resolve label back to project directory via the store.\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tvar projectDir string\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\tprojectDir = dir\n\t\t\tbreak\n\t\t}\n\t}\n\tif projectDir == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\t\treturn\n\t}\n\n\tif h.orchestrateFn == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\n\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n\t\treturn\n\t}\n\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"enabled\":     enabled,\n\t\t\"in_flight\":   inFlight,\n\t\t\"concurrency\": concurrency,\n\t})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, true)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, false)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\tvar body struct {\n\t\tConcurrency int `json:\"concurrency\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n\t\treturn\n\t}\n\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\tif script := step.Config[\"command\"]; script != \"\" {\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1341,"startLine":1,"totalLines":1341}}}
