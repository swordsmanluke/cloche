 return;\n                }\n                var html = '';\n                for (var i = 0; i < runs.length; i++) {\n                    var r = runs[i];\n                    var cid = r.container_id || '';\n                    if (cid.length > 12) cid = cid.substring(0, 12);\n                    var err = r.error_message || '';\n                    if (err.length > 80) err = err.substring(0, 80) + '...';\n                    var proj = r.project_label || '';\n                    html += '<tr>' +\n                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n                        '<td>' + escapeHtml(proj) + '</td>' +\n                        '<td>' + r.workflow_name + '</td>' +\n                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n                        '<td>' + r.started_at + '</td>' +\n                        '<td>' + r.completed_at + '</td>' +\n                        '<td class=\"mono\">' + cid + '</td>' +\n                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                        '</tr>';\n                }\n                tbody.innerHTML = html;\n            })\n            .catch(function() {});\n    }\n    function escapeHtml(s) {\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n    setInterval(poll, 3000);\n})();\n</script>\n{{end}}\n","structuredPatch":[{"oldStart":48,"oldLines":11,"newStart":48,"newLines":11,"lines":[" {{define \"scripts\"}}"," <script>"," (function() {","-    var currentProject = '{{.ProjectFilter}}';","+    var currentProject = '{{.ProjectLabel}}';"," ","-    function filterByProject(dir) {","-        if (dir) {","-            window.location.href = '/runs?project=' + encodeURIComponent(dir);","+    function filterByProject(label) {","+        if (label) {","+            window.location.href = '/projects/' + encodeURIComponent(label) + '/runs';","         } else {","             window.location.href = '/runs';","         }"]},{"oldStart":62,"oldLines":7,"newStart":62,"newLines":7,"lines":["     function poll() {","         var url = '/api/runs';","         if (currentProject) {","-            url += '?project=' + encodeURIComponent(currentProject);","+            url = '/api/projects/' + encodeURIComponent(currentProject) + '/runs';","         }","         fetch(url)","             .then(function(r) { return r.json(); })"]}],"userModified":false,"replaceAll":false}}
