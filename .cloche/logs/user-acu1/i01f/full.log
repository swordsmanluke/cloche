erverError)\n\t\treturn\n\t}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":287,"cache_read_input_tokens":60116,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":287},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"2ca48579-25a2-4d0a-bd77-fa02a187fbcd","uuid":"631c3912-dc63-451c-ac83-4c3e7e8cea71"}
