→\t}\n    46→\tdefer store.Close()\n    47→\n    48→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    49→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    50→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    51→\t} else if n > 0 {\n    52→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    53→\t}\n    54→\n    55→\truntime, err := initRuntime(globalCfg)\n    56→\tif err != nil {\n    57→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    58→\t\tos.Exit(1)\n    59→\t}\n    60→\n    61→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    62→\n    63→\tbroadcaster := logstream.NewBroadcaster()\n    64→\n    65→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    66→\tsrv.SetLogStore(store)\n    67→\tsrv.SetLogBroadcaster(broadcaster)\n    68→\n    69→\t// Set up evolution trigger\n    70→\tevoTrigger := initEvolution(globalCfg, store, store)\n    71→\tif evoTrigger != nil {\n    72→\t\tsrv.SetEvolution(evoTrigger)\n    73→\t}\n    74→\n    75→\t// Set up merge agent\n    76→\tsrv.SetMergeQueue(store)\n    77→\tmergeAgent := initMergeAgent(globalCfg, store)\n    78→\tif mergeAgent != nil {\n    79→\t\tsrv.SetOnMergeReady(func(ctx context.Context, projectDir string) {\n    80→\t\t\tmergeAgent.ProcessQueue(ctx, projectDir)\n    81→\t\t})\n    82→\t}\n    83→\n    84→\t// Set up orchestrator\n    85→\torch := initOrchestrator(globalCfg, store, srv)\n    86→\tif orch != nil {\n    87→\t\tsrv.SetOnRunComplete(func(ctx context.Context, projectDir string, state domain.RunState) {\n    88→\t\t\torch.OnRunComplete(ctx, projectDir)\n    89→\t\t})\n    90→\t\tsrv.SetOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n    91→\t\t\tif projectDir != \"\" {\n    92→\t\t\t\treturn orch.Run(ctx, projectDir)\n    93→\t\t\t}\n    94→\t\t\treturn orch.TriggerAll(ctx), nil\n    95→\t\t})\n    96→\t}\n    97→\n    98→\tgrpcServer := grpc.NewServer()\n    99→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n   100→\n   101→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n   102→\n   103→\tlis, err := listen(listenAddr)\n   104→\tif err != nil {\n   105→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n   106→\t\tos.Exit(1)\n   107→\t}\n   108→\n   109→\tvar httpServer *http.Server\n   110→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n   111→\t\twebOpts := []web.HandlerOption{\n   112→\t\t\tweb.WithContainerLogger(runtime),\n   113→\t\t\tweb.WithLogStore(store),\n   114→\t\t\tweb.WithLogBroadcaster(broadcaster),\n   115→\t\t}\n   116→\t\tif orch != nil {\n   117→\t\t\twebOpts = append(webOpts, web.WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   118→\t\t\t\treturn orch.Run(ctx, projectDir)\n   119→\t\t\t}))\n   120→\t\t}\n   121→\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n   122→\t\tif err != nil {\n   123→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n   124→\t\t\tos.Exit(1)\n   125→\t\t}\n   126→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n   127→\t\tgo func() {\n   128→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   129→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   130→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   131→\t\t\t}\n   132→\t\t}()\n   133→\t}\n   134→\n   135→\tsigCh := make(chan os.Signal, 1)\n   136→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   137→\tgo func() {\n   138→\t\t<-sigCh\n   139→\t\tif httpServer != nil {\n   140→\t\t\thttpServer.Close()\n   141→\t\t}\n   142→\t\tgrpcServer.GracefulStop()\n   143→\t}()\n   144→\n   145→\t// Trigger orchestration on startup\n   146→\tif orch != nil {\n   147→\t\tgo func() {\n   148→\t\t\tn := orch.TriggerAll(context.Background())\n   149→\t\t\tif n > 0 {\n   150→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: orchestrator dispatched %d run(s)\\n\", n)\n   151→\t\t\t}\n   152→\t\t}()\n   153→\t}\n   154→\n   155→\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   156→\tif err := grpcServer.Serve(lis); err != nil {\n   157→\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   158→\t\tos.Exit(1)\n   159→\t}\n   160→}\n   161→\n   162→func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   163→\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   164→\n   165→\tswitch runtimeType {\n   166→\tcase \"local\":\n   167→\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   168→\t\tif agentPath == \"\" {\n   169→\t\t\t// Look for cloche-agent next to this binary\n   170→\t\t\texe, err := os.Executable()\n   171→\t\t\tif err == nil {\n   172→\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   173→\t\t\t} else {\n   174→\t\t\t\tagentPath = \"cloche-agent\"\n   175→\t\t\t}\n   176→\t\t}\n   177→\t\treturn local.NewRuntime(agentPath), nil\n   178→\tcase \"docker\":\n   179→\t\treturn docker.NewRuntime()\n   180→\tdefault:\n   181→\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   182→\t}\n   183→}\n   184→\n   185→func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   186→\t// Load config from working directory (daemon-level defaults)\n   187→\tcfg, err := config.Load(\".\")\n   188→\tif err != nil || !cfg.Evolution.Enabled {\n   189→\t\treturn nil\n   190→\t}\n   191→\n   192→\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   193→\tif llmCmd == \"\" {\n   194→\t\treturn nil\n   195→\t}\n   196→\n   197→\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   198→\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   199→\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   200→\t\t\t// Load per-project config for confidence threshold\n   201→\t\t\tprojCfg, err := config.Load(projectDir)\n   202→\t\t\tif err != nil {\n   203→\t\t\t\tprojCfg = cfg // fall back to daemon config\n   204→\t\t\t}\n   205→\n   206→\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   207→\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   208→\t\t\t\tProjectDir:    projectDir,\n   209→\t\t\t\tWorkflowName:  workflowName,\n   210→\t\t\t\tLLM:           llm,\n   211→\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   212→\t\t\t})\n   213→\n   214→\t\t\tctx := context.Background()\n   215→\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   216→\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   217→\t\t\t}\n   218→\t\t},\n   219→\t})\n   220→\n   221→\treturn trigger\n   222→}\n   223→\n   224→func listen(addr string) (net.Listener, error) {\n   225→\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   226→\t\tsockPath := addr[7:]\n   227→\t\tos.Remove(sockPath)\n   228→\t\treturn net.Listen(\"unix\", sockPath)\n   229→\t}\n   230→\treturn net.Listen(\"tcp\", addr)\n   231→}\n   232→\n   233→func initOrchestrator(globalCfg *config.Config, store ports.RunStore, srv *adaptgrpc.ClocheServer) *orchestrator.Orchestrator {\n   234→\tllmClient := orchestrator.NewCommandLLMClientFromEnv()\n   235→\tpromptGen := &orchestrator.LLMPromptGenerator{LLM: llmClient}\n   236→\n   237→\tdispatch := func(ctx context.Context, workflowName, projectDir, prompt string) (string, error) {\n   238→\t\tresp, err := srv.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   239→\t\t\tWorkflowName: workflowName,\n   240→\t\t\tProjectDir:   projectDir,\n   241→\t\t\tPrompt:       prompt,\n   242→\t\t})\n   243→\t\tif err != nil {