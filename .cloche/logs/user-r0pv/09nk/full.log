[2026-03-06T20:55:16Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016a5GEvyd1yjWyfQqnZTDsy","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"errors\"\n     8→\t\"fmt\"\n     9→\t\"io\"\n    10→\t\"net/http\"\n    11→\t\"os\"\n    12→\t\"path/filepath\"\n    13→\t\"strings\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    18→\t\"google.golang.org/grpc\"\n    19→\t\"google.golang.org/grpc/credentials/insecure\"\n    20→)\n    21→\n    22→func main() {\n    23→\tif len(os.Args) < 2 {\n    24→\t\tusage()\n    25→\t\tos.Exit(1)\n    26→\t}\n    27→\n    28→\t// Commands that don't need a daemon connection\n    29→\tswitch os.Args[1] {\n    30→\tcase \"init\":\n    31→\t\tcmdInit(os.Args[2:])\n    32→\t\treturn\n    33→\tcase \"health\":\n    34→\t\tcmdHealth(os.Args[2:])\n    35→\t\treturn\n    36→\t}\n    37→\n    38→\t// Commands that need a daemon connection\n    39→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    40→\tif addr == \"\" {\n    41→\t\taddr = \"unix:///tmp/cloche.sock\"\n    42→\t}\n    43→\n    44→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n    45→\tif err != nil {\n    46→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n    47→\t\tos.Exit(1)\n    48→\t}\n    49→\tdefer conn.Close()\n    50→\n    51→\tclient := pb.NewClocheServiceClient(conn)\n    52→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n    53→\tdefer cancel()\n    54→\n    55→\tswitch os.Args[1] {\n    56→\tcase \"run\":\n    57→\t\tcmdRun(ctx, client, os.Args[2:])\n    58→\tcase \"status\":\n    59→\t\tcmdStatus(ctx, client, os.Args[2:])\n    60→\tcase \"logs\":\n    61→\t\tcmdLogs(client, os.Args[2:])\n    62→\tcase \"poll\":\n    63→\t\tcmdPoll(client, os.Args[2:])\n    64→\tcase \"list\":\n    65→\t\tcmdList(ctx, client, os.Args[2:])\n    66→\tcase \"stop\":\n    67→\t\tcmdStop(ctx, client, os.Args[2:])\n    68→\tcase \"delete\":\n    69→\t\tcmdDelete(ctx, client, os.Args[2:])\n    70→\tcase \"orchestrate\":\n    71→\t\tcmdOrchestrate(ctx, client)\n    72→\tcase \"shutdown\":\n    73→\t\tcmdShutdown(ctx, client)\n    74→\tdefault:\n    75→\t\tusage()\n    76→\t\tos.Exit(1)\n    77→\t}\n    78→}\n    79→\n    80→func usage() {\n    81→\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n    82→\n    83→Commands:\n    84→  init [--workflow <name>] [--image <base>]  Initialize a Cloche project\n    85→  health                                   Show project health summary\n    86→  run --workflow <name> [--prompt \"...\"] [--keep-container]\n    87→                                             Launch a workflow run\n    88→  status <run-id>                            Check run status\n    89→  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n    90→                                             Show logs for a run\n    91→  poll <run-id>                              Wait for a run to finish\n    92→  list [--all]                                List runs (last hour by default)\n    93→  stop <run-id>                              Stop a running workflow\n    94→  delete <container-or-run-id>               Delete a retained container\n    95→  orchestrate                                Dispatch ready workflow runs\n    96→  shutdown                                   Shut down the daemon\n    97→`)\n    98→}\n    99→\n   100→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   101→\tvar workflow, prompt string\n   102→\tvar keepContainer bool\n   103→\n   104→\tfor i := 0; i < len(args); i++ {\n   105→\t\tswitch args[i] {\n   106→\t\tcase \"--workflow\":\n   107→\t\t\tif i+1 < len(args) {\n   108→\t\t\t\ti++\n   109→\t\t\t\tworkflow = args[i]\n   110→\t\t\t}\n   111→\t\tcase \"--prompt\", \"-p\":\n   112→\t\t\tif i+1 < len(args) {\n   113→\t\t\t\ti++\n   114→\t\t\t\tprompt = args[i]\n   115→\t\t\t}\n   116→\t\tcase \"--keep-container\":\n   117→\t\t\tkeepContainer = true\n   118→\t\tdefault:\n   119→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   120→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   121→\t\t\t\tworkflow = args[i]\n   122→\t\t\t}\n   123→\t\t}\n   124→\t}\n   125→\n   126→\tif workflow == \"\" {\n   127→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"]\\n\")\n   128→\t\tos.Exit(1)\n   129→\t}\n   130→\n   131→\tcwd, _ := os.Getwd()\n   132→\n   133→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   134→\tvar image string\n   135→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   136→\tif data, err := os.ReadFile(wfPath); err == nil {\n   137→\t\tif wf, err := dsl.Parse(string(data)); err == nil {\n   138→\t\t\timage = wf.Config[\"container.image\"]\n   139→\t\t}\n   140→\t}\n   141→\n   142→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   143→\t\tWorkflowName:  workflow,\n   144→\t\tProjectDir:    cwd,\n   145→\t\tImage:         image,\n   146→\t\tPrompt:        prompt,\n   147→\t\tKeepContainer: keepContainer,\n   148→\t})\n   149→\tif err != nil {\n   150→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   151→\t\tos.Exit(1)\n   152→\t}\n   153→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   154→}\n   155→\n   156→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   157→\tif len(args) < 1 {\n   158→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   159→\t\tos.Exit(1)\n   160→\t}\n   161→\n   162→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   163→\tif err != nil {\n   164→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   165→\t\tos.Exit(1)\n   166→\t}\n   167→\n   168→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   169→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   170→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   171→\tif resp.ContainerId != \"\" {\n   172→\t\tcid := resp.ContainerId\n   173→\t\tif len(cid) > 12 {\n   174→\t\t\tcid = cid[:12]\n   175→\t\t}\n   176→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   177→\t}\n   178→\tif resp.ErrorMessage != \"\" {\n   179→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   180→\t}\n   181→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   182→\tfor _, exec := range resp.StepExecutions {\n   183→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   184→\t}\n   185→}\n   186→\n   187→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   188→\tvar all bool\n   189→\tfor _, arg := range args {\n   190→\t\tif arg == \"--all\" {\n   191→\t\t\tall = true\n   192→\t\t}\n   193→\t}\n   194→\n   195→\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n   196→\tif err != nil {\n   197→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   198→\t\tos.Exit(1)\n   199→\t}\n   200→\n   201→\tif len(resp.Runs) == 0 {\n   202→\t\tfmt.Println(\"No runs found.\")\n   203→\t\treturn\n   204→\t}\n   205→\n   206→\tfor _, run := range resp.Runs {\n   207→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s\", run.RunId, run.WorkflowName, run.State)\n   208→\t\tif run.ContainerId != \"\" {\n   209→\t\t\tline += \"  \" + run.ContainerId\n   210→\t\t}\n   211→\t\tif run.ErrorMessage != \"\" {\n   212→\t\t\terrMsg := run.ErrorMessage\n   213→\t\t\tif len(errMsg) > 60 {\n   214→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   215→\t\t\t}\n   216→\t\t\tline += \"  \" + errMsg\n   217→\t\t}\n   218→\t\tfmt.Println(line)\n   219→\t}\n   220→}\n   221→\n   222→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   223→\tif len(args) < 1 {\n   224→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n   225→\t\tos.Exit(1)\n   226→\t}\n   227→\n   228→\tvar stepFilter, typeFilter string\n   229→\tvar follow bool\n   230→\trunID := args[0]\n   231→\n   232→\tfor i := 1; i < len(args); i++ {\n   233→\t\tswitch args[i] {\n   234→\t\tcase \"--step\":\n   235→\t\t\tif i+1 < len(args) {\n   236→\t\t\t\ti++\n   237→\t\t\t\tstepFilter = args[i]\n   238→\t\t\t}\n   239→\t\tcase \"--type\":\n   240→\t\t\tif i+1 < len(args) {\n   241→\t\t\t\ti++\n   242→\t\t\t\ttypeFilter = args[i]\n   243→\t\t\t}\n   244→\t\tcase \"--follow\", \"-f\":\n   245→\t\t\tfollow = true\n   246→\t\t}\n   247→\t}\n   248→\n   249→\tif follow {\n   250→\t\tcmdLogsFollow(runID)\n   251→\t\treturn\n   252→\t}\n   253→\n   254→\t// Use background context — log output can be large\n   255→\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n   256→\t\tRunId:    runID,\n   257→\t\tStepName: stepFilter,\n   258→\t\tLogType:  typeFilter,\n   259→\t})\n   260→\tif err != nil {\n   261→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   262→\t\tos.Exit(1)\n   263→\t}\n   264→\n   265→\tfor {\n   266→\t\tentry, err := stream.Recv()\n   267→\t\tif err != nil {\n   268→\t\t\tif errors.Is(err, io.EOF) {\n   269→\t\t\t\tbreak\n   270→\t\t\t}\n   271→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   272→\t\t\tos.Exit(1)\n   273→\t\t}\n   274→\n   275→\t\tswitch entry.Type {\n   276→\t\tcase \"step_started\":\n   277→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   278→\t\t\tif entry.Message != \"\" {\n   279→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   280→\t\t\t}\n   281→\t\tcase \"step_completed\":\n   282→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   283→\t\t\tif entry.Message != \"\" {\n   284→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   285→\t\t\t}\n   286→\t\tcase \"run_completed\":\n   287→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   288→\t\t\tif entry.Message != \"\" {\n   289→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   290→\t\t\t}\n   291→\t\tcase \"full_log\":\n   292→\t\t\tfmt.Print(entry.Message)\n   293→\t\tdefault:\n   294→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   295→\t\t\tif entry.StepName != \"\" {\n   296→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   297→\t\t\t}\n   298→\t\t\tif entry.Message != \"\" {\n   299→\t\t\t\tfmt.Print(entry.Message)\n   300→\t\t\t}\n   301→\t\t}\n   302→\t}\n   303→}\n   304→\n   305→func cmdLogsFollow(runID string) {\n   306→\t// Determine HTTP address from env\n   307→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   308→\tif httpAddr == \"\" {\n   309→\t\thttpAddr = \"localhost:8080\"\n   310→\t}\n   311→\t// Strip protocol prefix if present\n   312→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   313→\n   314→\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n   315→\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n   316→\tif err != nil {\n   317→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   318→\t\tos.Exit(1)\n   319→\t}\n   320→\treq.Header.Set(\"Accept\", \"text/event-stream\")\n   321→\n   322→\tresp, err := http.DefaultClient.Do(req)\n   323→\tif err != nil {\n   324→\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n   325→\t\tos.Exit(1)\n   326→\t}\n   327→\tdefer resp.Body.Close()\n   328→\n   329→\tif resp.StatusCode != 200 {\n   330→\t\tbody, _ := io.ReadAll(resp.Body)\n   331→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   332→\t\tos.Exit(1)\n   333→\t}\n   334→\n   335→\tscanner := bufio.NewScanner(resp.Body)\n   336→\tfor scanner.Scan() {\n   337→\t\tline := scanner.Text()\n   338→\t\tif strings.HasPrefix(line, \"event: done\") {\n   339→\t\t\tbreak\n   340→\t\t}\n   341→\t\tif !strings.HasPrefix(line, \"data: \") {\n   342→\t\t\tcontinue\n   343→\t\t}\n   344→\t\tdata := strings.TrimPrefix(line, \"data: \")\n   345→\n   346→\t\tvar entry struct {\n   347→\t\t\tTimestamp string `json:\"timestamp\"`\n   348→\t\t\tType      string `json:\"type\"`\n   349→\t\t\tContent   string `json:\"content\"`\n   350→\t\t}\n   351→\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n   352→\t\t\tcontinue\n   353→\t\t}\n   354→\n   355→\t\t// Color-code by type\n   356→\t\tswitch entry.Type {\n   357→\t\tcase \"status\":\n   358→\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   359→\t\tcase \"llm\":\n   360→\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   361→\t\tdefault:\n   362→\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n   363→\t\t}\n   364→\t}\n   365→}\n   366→\n   367→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   368→\tif len(args) < 1 {\n   369→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   370→\t\tos.Exit(1)\n   371→\t}\n   372→\n   373→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   374→\tif err != nil {\n   375→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   376→\t\tos.Exit(1)\n   377→\t}\n   378→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   379→}\n   380→\n   381→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   382→\tif len(args) < 1 {\n   383→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   384→\t\tos.Exit(1)\n   385→\t}\n   386→\n   387→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   388→\tif err != nil {\n   389→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   390→\t\tos.Exit(1)\n   391→\t}\n   392→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   393→}\n   394→\n   395→func cmdOrchestrate(ctx context.Context, client pb.ClocheServiceClient) {\n   396→\tcwd, _ := os.Getwd()\n   397→\tresp, err := client.Orchestrate(ctx, &pb.OrchestrateRequest{ProjectDir: cwd})\n   398→\tif err != nil {\n   399→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   400→\t\tos.Exit(1)\n   401→\t}\n   402→\tif resp.Dispatched == 0 {\n   403→\t\tfmt.Println(\"No ready work found.\")\n   404→\t} else {\n   405→\t\tfmt.Printf(\"Dispatched %d run(s).\\n\", resp.Dispatched)\n   406→\t}\n   407→}\n   408→\n   409→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   410→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   411→\tif err != nil {\n   412→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   413→\t\tos.Exit(1)\n   414→\t}\n   415→\tfmt.Println(\"Daemon shutting down.\")\n   416→}\n   417→"}]},"parent_tool_use_id":null,"session_id":"00046cdc-8067-47b0-8e48-fe5bf1935362","uuid":"6ed352de-682e-4315-b3f6-13b0ec1eb8e7","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"orchestrate\":\n\t\tcmdOrchestrate(ctx, client)\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client)\n\tdefault:\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n}\n\nfunc usage() {\n\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n\nCommands:\n  init [--workflow <name>] [--image <base>]  Initialize a Cloche project\n  health                                   Show project health summary\n  run --workflow <name> [--prompt \"...\"] [--keep-container]\n                                             Launch a workflow run\n  status <run-id>                            Check run status\n  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n                                             Show logs for a run\n  poll <run-id>                              Wait for a run to finish\n  list [--all]                                List runs (last hour by default)\n  stop <run-id>                              Stop a running workflow\n  delete <container-or-run-id>               Delete a retained container\n  orchestrate                                Dispatch ready workflow runs\n  shutdown                                   Shut down the daemon\n`)\n}\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n\tvar image string\n\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n\tif data, err := os.ReadFile(wfPath); err == nil {\n\t\tif wf, err := dsl.Parse(string(data)); err == nil {\n\t\t\timage = wf.Config[\"container.image\"]\n\t\t}\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t}\n\t}\n\n\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s\", run.RunId, run.WorkflowName, run.State)\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\t}\n\t}\n\n\tif follow {\n\t\tcmdLogsFollow(runID)\n\t\treturn\n\t}\n\n\t// Use background context — log output can be large\n\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(entry.Message)\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdLogsFollow(runID string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\t// Strip protocol prefix if present\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\treq.Header.Set(\"Accept\", \"text/event-stream\")\n\n\tresp, err := http.DefaultClient.Do(req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\tscanner := bufio.NewScanner(resp.Body)\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"event: done\") {\n\t\t\tbreak\n\t\t}\n\t\tif !strings.HasPrefix(line, \"data: \") {\n\t\t\tcontinue\n\t\t}\n\t\tdata := strings.TrimPrefix(line, \"data: \")\n\n\t\tvar entry struct {\n\t\t\tTimestamp string `json:\"timestamp\"`\n\t\t\tType      string `json:\"type\"`\n\t\t\tContent   string `json:\"content\"`\n\t\t}\n\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Color-code by type\n\t\tswitch entry.Type {\n\t\tcase \"status\":\n\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tcase \"llm\":\n\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tdefault:\n\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdOrchestrate(ctx context.Context, client pb.ClocheServiceClient) {\n\tcwd, _ := os.Getwd()\n\tresp, err := client.Orchestrate(ctx, &pb.OrchestrateRequest{ProjectDir: cwd})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif resp.Dispatched == 0 {\n\t\tfmt.Println(\"No ready work found.\")\n\t} else {\n\t\tfmt.Printf(\"Dispatched %d run(s).\\n\", resp.Dispatched)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n","numLines":417,"startLine":1,"totalLines":417}}}
