{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016a5GEvyd1yjWyfQqnZTDsy","type":"tool_result","content":"     1‚Üípackage main\n     2‚Üí\n     3‚Üíimport (\n     4‚Üí\t\"bufio\"\n     5‚Üí\t\"context\"\n     6‚Üí\t\"encoding/json\"\n     7‚Üí\t\"errors\"\n     8‚Üí\t\"fmt\"\n     9‚Üí\t\"io\"\n    10‚Üí\t\"net/http\"\n    11‚Üí\t\"os\"\n    12‚Üí\t\"path/filepath\"\n    13‚Üí\t\"strings\"\n    14‚Üí\t\"time\"\n    15‚Üí\n    16‚Üí\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17‚Üí\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    18‚Üí\t\"google.golang.org/grpc\"\n    19‚Üí\t\"google.golang.org/grpc/credentials/insecure\"\n    20‚Üí)\n    21‚Üí\n    22‚Üífunc main() {\n    23‚Üí\tif len(os.Args) < 2 {\n    24‚Üí\t\tusage()\n    25‚Üí\t\tos.Exit(1)\n    26‚Üí\t}\n    27‚Üí\n    28‚Üí\t// Commands that don't need a daemon connection\n    29‚Üí\tswitch os.Args[1] {\n    30‚Üí\tcase \"init\":\n    31‚Üí\t\tcmdInit(os.Args[2:])\n    32‚Üí\t\treturn\n    33‚Üí\tcase \"health\":\n    34‚Üí\t\tcmdHealth(os.Args[2:])\n    35‚Üí\t\treturn\n    36‚Üí\t}\n    37‚Üí\n    38‚Üí\t// Commands that need a daemon connection\n    39‚Üí\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    40‚Üí\tif addr == \"\" {\n    41‚Üí\t\taddr = \"unix:///tmp/cloche.sock\"\n    42‚Üí\t}\n    43‚Üí\n    44‚Üí\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n    45‚Üí\tif err != nil {\n    46‚Üí\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n    47‚Üí\t\tos.Exit(1)\n    48‚Üí\t}\n    49‚Üí\tdefer conn.Close()\n    50‚Üí\n    51‚Üí\tclient := pb.NewClocheServiceClient(conn)\n    52‚Üí\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n    53‚Üí\tdefer cancel()\n    54‚Üí\n    55‚Üí\tswitch os.Args[1] {\n    56‚Üí\tcase \"run\":\n    57‚Üí\t\tcmdRun(ctx, client, os.Args[2:])\n    58‚Üí\tcase \"status\":\n    59‚Üí\t\tcmdStatus(ctx, client, os.Args[2:])\n    60‚Üí\tcase \"logs\":\n    61‚Üí\t\tcmdLogs(client, os.Args[2:])\n    62‚Üí\tcase \"poll\":\n    63‚Üí\t\tcmdPoll(client, os.Args[2:])\n    64‚Üí\tcase \"list\":\n    65‚Üí\t\tcmdList(ctx, client, os.Args[2:])\n    66‚Üí\tcase \"stop\":\n    67‚Üí\t\tcmdStop(ctx, client, os.Args[2:])\n    68‚Üí\tcase \"delete\":\n    69‚Üí\t\tcmdDelete(ctx, client, os.Args[2:])\n    70‚Üí\tcase \"orchestrate\":\n    71‚Üí\t\tcmdOrchestrate(ctx, client)\n    72‚Üí\tcase \"shutdown\":\n    73‚Üí\t\tcmdShutdown(ctx, client)\n    74‚Üí\tdefault:\n    75‚Üí\t\tusage()\n    76‚Üí\t\tos.Exit(1)\n    77‚Üí\t}\n    78‚Üí}\n    79‚Üí\n    80‚Üífunc usage() {\n    81‚Üí\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n    82‚Üí\n    83‚ÜíCommands:\n    84‚Üí  init [--workflow <name>] [--image <base>]  Initialize a Cloche project\n    85‚Üí  health                                   Show project health summary\n    86‚Üí  run --workflow <name> [--prompt \"...\"] [--keep-container]\n    87‚Üí                                             Launch a workflow run\n    88‚Üí  status <run-id>                            Check run status\n    89‚Üí  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n    90‚Üí                                             Show logs for a run\n    91‚Üí  poll <run-id>                              Wait for a run to finish\n    92‚Üí  list [--all]                                List runs (last hour by default)\n    93‚Üí  stop <run-id>                              Stop a running workflow\n    94‚Üí  delete <container-or-run-id>               Delete a retained container\n    95‚Üí  orchestrate                                Dispatch ready workflow runs\n    96‚Üí  shutdown                                   Shut down the daemon\n    97‚Üí`)\n    98‚Üí}\n    99‚Üí\n   100‚Üífunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   101‚Üí\tvar workflow, prompt string\n   102‚Üí\tvar keepContainer bool\n   103‚Üí\n   104‚Üí\tfor i := 0; i < len(args); i++ {\n   105‚Üí\t\tswitch args[i] {\n   106‚Üí\t\tcase \"--workflow\":\n   107‚Üí\t\t\tif i+1 < len(args) {\n   108‚Üí\t\t\t\ti++\n   109‚Üí\t\t\t\tworkflow = args[i]\n   110‚Üí\t\t\t}\n   111‚Üí\t\tcase \"--prompt\", \"-p\":\n   112‚Üí\t\t\tif i+1 < len(args) {\n   113‚Üí\t\t\t\ti++\n   114‚Üí\t\t\t\tprompt = args[i]\n   115‚Üí\t\t\t}\n   116‚Üí\t\tcase \"--keep-container\":\n   117‚Üí\t\t\tkeepContainer = true\n   118‚Üí\t\tdefault:\n   119‚Üí\t\t\t// Support bare positional arg as workflow name for backwards compat\n   120‚Üí\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   121‚Üí\t\t\t\tworkflow = args[i]\n   122‚Üí\t\t\t}\n   123‚Üí\t\t}\n   124‚Üí\t}\n   125‚Üí\n   126‚Üí\tif workflow == \"\" {\n   127‚Üí\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"]\\n\")\n   128‚Üí\t\tos.Exit(1)\n   129‚Üí\t}\n   130‚Üí\n   131‚Üí\tcwd, _ := os.Getwd()\n   132‚Üí\n   133‚Üí\t// Resolve image from workflow file (soft failure ‚Äî fall back to daemon default)\n   134‚Üí\tvar image string\n   135‚Üí\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   136‚Üí\tif data, err := os.ReadFile(wfPath); err == nil {\n   137‚Üí\t\tif wf, err := dsl.Parse(string(data)); err == nil {\n   138‚Üí\t\t\timage = wf.Config[\"container.image\"]\n   139‚Üí\t\t}\n   140‚Üí\t}\n   141‚Üí\n   142‚Üí\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   143‚Üí\t\tWorkflowName:  workflow,\n   144‚Üí\t\tProjectDir:    cwd,\n   145‚Üí\t\tImage:         image,\n   146‚Üí\t\tPrompt:        prompt,\n   147‚Üí\t\tKeepContainer: keepContainer,\n   148‚Üí\t})\n   149‚Üí\tif err != nil {\n   150‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   151‚Üí\t\tos.Exit(1)\n   152‚Üí\t}\n   153‚Üí\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   154‚Üí}\n   155‚Üí\n   156‚Üífunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   157‚Üí\tif len(args) < 1 {\n   158‚Üí\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   159‚Üí\t\tos.Exit(1)\n   160‚Üí\t}\n   161‚Üí\n   162‚Üí\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   163‚Üí\tif err != nil {\n   164‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   165‚Üí\t\tos.Exit(1)\n   166‚Üí\t}\n   167‚Üí\n   168‚Üí\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   169‚Üí\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   170‚Üí\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   171‚Üí\tif resp.ContainerId != \"\" {\n   172‚Üí\t\tcid := resp.ContainerId\n   173‚Üí\t\tif len(cid) > 12 {\n   174‚Üí\t\t\tcid = cid[:12]\n   175‚Üí\t\t}\n   176‚Üí\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   177‚Üí\t}\n   178‚Üí\tif resp.ErrorMessage != \"\" {\n   179‚Üí\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   180‚Üí\t}\n   181‚Üí\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   182‚Üí\tfor _, exec := range resp.StepExecutions {\n   183‚Üí\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   184‚Üí\t}\n   185‚Üí}\n   186‚Üí\n   187‚Üífunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   188‚Üí\tvar all bool\n   189‚Üí\tfor _, arg := range args {\n   190‚Üí\t\tif arg == \"--all\" {\n   191‚Üí\t\t\tall = true\n   192‚Üí\t\t}\n   193‚Üí\t}\n   194‚Üí\n   195‚Üí\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n   196‚Üí\tif err != nil {\n   197‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   198‚Üí\t\tos.Exit(1)\n   199‚Üí\t}\n   200‚Üí\n   201‚Üí\tif len(resp.Runs) == 0 {\n   202‚Üí\t\tfmt.Println(\"No runs found.\")\n   203‚Üí\t\treturn\n   204‚Üí\t}\n   205‚Üí\n   206‚Üí\tfor _, run := range resp.Runs {\n   207‚Üí\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s\", run.RunId, run.WorkflowName, run.State)\n   208‚Üí\t\tif run.ContainerId != \"\" {\n   209‚Üí\t\t\tline += \"  \" + run.ContainerId\n   210‚Üí\t\t}\n   211‚Üí\t\tif run.ErrorMessage != \"\" {\n   212‚Üí\t\t\terrMsg := run.ErrorMessage\n   213‚Üí\t\t\tif len(errMsg) > 60 {\n   214‚Üí\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   215‚Üí\t\t\t}\n   216‚Üí\t\t\tline += \"  \" + errMsg\n   217‚Üí\t\t}\n   218‚Üí\t\tfmt.Println(line)\n   219‚Üí\t}\n   220‚Üí}\n   221‚Üí\n   222‚Üífunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n   223‚Üí\tif len(args) < 1 {\n   224‚Üí\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n   225‚Üí\t\tos.Exit(1)\n   226‚Üí\t}\n   227‚Üí\n   228‚Üí\tvar stepFilter, typeFilter string\n   229‚Üí\tvar follow bool\n   230‚Üí\trunID := args[0]\n   231‚Üí\n   232‚Üí\tfor i := 1; i < len(args); i++ {\n   233‚Üí\t\tswitch args[i] {\n   234‚Üí\t\tcase \"--step\":\n   235‚Üí\t\t\tif i+1 < len(args) {\n   236‚Üí\t\t\t\ti++\n   237‚Üí\t\t\t\tstepFilter = args[i]\n   238‚Üí\t\t\t}\n   239‚Üí\t\tcase \"--type\":\n   240‚Üí\t\t\tif i+1 < len(args) {\n   241‚Üí\t\t\t\ti++\n   242‚Üí\t\t\t\ttypeFilter = args[i]\n   243‚Üí\t\t\t}\n   244‚Üí\t\tcase \"--follow\", \"-f\":\n   245‚Üí\t\t\tfollow = true\n   246‚Üí\t\t}\n   247‚Üí\t}\n   248‚Üí\n   249‚Üí\tif follow {\n   250‚Üí\t\tcmdLogsFollow(runID)\n   251‚Üí\t\treturn\n   252‚Üí\t}\n   253‚Üí\n   254‚Üí\t// Use background context ‚Äî log output can be large\n   255‚Üí\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n   256‚Üí\t\tRunId:    runID,\n   257‚Üí\t\tStepName: stepFilter,\n   258‚Üí\t\tLogType:  typeFilter,\n   259‚Üí\t})\n   260‚Üí\tif err != nil {\n   261‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   262‚Üí\t\tos.Exit(1)\n   263‚Üí\t}\n   264‚Üí\n   265‚Üí\tfor {\n   266‚Üí\t\tentry, err := stream.Recv()\n   267‚Üí\t\tif err != nil {\n   268‚Üí\t\t\tif errors.Is(err, io.EOF) {\n   269‚Üí\t\t\t\tbreak\n   270‚Üí\t\t\t}\n   271‚Üí\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   272‚Üí\t\t\tos.Exit(1)\n   273‚Üí\t\t}\n   274‚Üí\n   275‚Üí\t\tswitch entry.Type {\n   276‚Üí\t\tcase \"step_started\":\n   277‚Üí\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   278‚Üí\t\t\tif entry.Message != \"\" {\n   279‚Üí\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   280‚Üí\t\t\t}\n   281‚Üí\t\tcase \"step_completed\":\n   282‚Üí\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   283‚Üí\t\t\tif entry.Message != \"\" {\n   284‚Üí\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   285‚Üí\t\t\t}\n   286‚Üí\t\tcase \"run_completed\":\n   287‚Üí\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   288‚Üí\t\t\tif entry.Message != \"\" {\n   289‚Üí\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   290‚Üí\t\t\t}\n   291‚Üí\t\tcase \"full_log\":\n   292‚Üí\t\t\tfmt.Print(entry.Message)\n   293‚Üí\t\tdefault:\n   294‚Üí\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   295‚Üí\t\t\tif entry.StepName != \"\" {\n   296‚Üí\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   297‚Üí\t\t\t}\n   298‚Üí\t\t\tif entry.Message != \"\" {\n   299‚Üí\t\t\t\tfmt.Print(entry.Message)\n   300‚Üí\t\t\t}\n   301‚Üí\t\t}\n   302‚Üí\t}\n   303‚Üí}\n   304‚Üí\n   305‚Üífunc cmdLogsFollow(runID string) {\n   306‚Üí\t// Determine HTTP address from env\n   307‚Üí\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   308‚Üí\tif httpAddr == \"\" {\n   309‚Üí\t\thttpAddr = \"localhost:8080\"\n   310‚Üí\t}\n   311‚Üí\t// Strip protocol prefix if present\n   312‚Üí\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   313‚Üí\n   314‚Üí\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n   315‚Üí\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n   316‚Üí\tif err != nil {\n   317‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   318‚Üí\t\tos.Exit(1)\n   319‚Üí\t}\n   320‚Üí\treq.Header.Set(\"Accept\", \"text/event-stream\")\n   321‚Üí\n   322‚Üí\tresp, err := http.DefaultClient.Do(req)\n   323‚Üí\tif err != nil {\n   324‚Üí\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n   325‚Üí\t\tos.Exit(1)\n   326‚Üí\t}\n   327‚Üí\tdefer resp.Body.Close()\n   328‚Üí\n   329‚Üí\tif resp.StatusCode != 200 {\n   330‚Üí\t\tbody, _ := io.ReadAll(resp.Body)\n   331‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   332‚Üí\t\tos.Exit(1)\n   333‚Üí\t}\n   334‚Üí\n   335‚Üí\tscanner := bufio.NewScanner(resp.Body)\n   336‚Üí\tfor scanner.Scan() {\n   337‚Üí\t\tline := scanner.Text()\n   338‚Üí\t\tif strings.HasPrefix(line, \"event: done\") {\n   339‚Üí\t\t\tbreak\n   340‚Üí\t\t}\n   341‚Üí\t\tif !strings.HasPrefix(line, \"data: \") {\n   342‚Üí\t\t\tcontinue\n   343‚Üí\t\t}\n   344‚Üí\t\tdata := strings.TrimPrefix(line, \"data: \")\n   345‚Üí\n   346‚Üí\t\tvar entry struct {\n   347‚Üí\t\t\tTimestamp string `json:\"timestamp\"`\n   348‚Üí\t\t\tType      string `json:\"type\"`\n   349‚Üí\t\t\tContent   string `json:\"content\"`\n   350‚Üí\t\t}\n   351‚Üí\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n   352‚Üí\t\t\tcontinue\n   353‚Üí\t\t}\n   354‚Üí\n   355‚Üí\t\t// Color-code by type\n   356‚Üí\t\tswitch entry.Type {\n   357‚Üí\t\tcase \"status\":\n   358‚Üí\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   359‚Üí\t\tcase \"llm\":\n   360‚Üí\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   361‚Üí\t\tdefault:\n   362‚Üí\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n   363‚Üí\t\t}\n   364‚Üí\t}\n   365‚Üí}\n   366‚Üí\n   367‚Üífunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   368‚Üí\tif len(args) < 1 {\n   369‚Üí\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   370‚Üí\t\tos.Exit(1)\n   371‚Üí\t}\n   372‚Üí\n   373‚Üí\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   374‚Üí\tif err != nil {\n   375‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   376‚Üí\t\tos.Exit(1)\n   377‚Üí\t}\n   378‚Üí\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   379‚Üí}\n   380‚Üí\n   381‚Üífunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   382‚Üí\tif len(args) < 1 {\n   383‚Üí\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   384‚Üí\t\tos.Exit(1)\n   385‚Üí\t}\n   386‚Üí\n   387‚Üí\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   388‚Üí\tif err != nil {\n   389‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   390‚Üí\t\tos.Exit(1)\n   391‚Üí\t}\n   392‚Üí\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   393‚Üí}\n   394‚Üí\n   395‚Üífunc cmdOrchestrate(ctx context.Context, client pb.ClocheServiceClient) {\n   396‚Üí\tcwd, _ := os.Getwd()\n   397‚Üí\tresp, err := client.Orchestrate(ctx, &pb.OrchestrateRequest{ProjectDir: cwd})\n   398‚Üí\tif err != nil {\n   399‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   400‚Üí\t\tos.Exit(1)\n   401‚Üí\t}\n   402‚Üí\tif resp.Dispatched == 0 {\n   403‚Üí\t\tfmt.Println(\"No ready work found.\")\n   404‚Üí\t} else {\n   405‚Üí\t\tfmt.Printf(\"Dispatched %d run(s).\\n\", resp.Dispatched)\n   406‚Üí\t}\n   407‚Üí}\n   408‚Üí\n   409‚Üífunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   410‚Üí\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   411‚Üí\tif err != nil {\n   412‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   413‚Üí\t\tos.Exit(1)\n   414‚Üí\t}\n   415‚Üí\tfmt.Println(\"Daemon shutting down.\")\n   416‚Üí}\n   417‚Üí"}]},"parent_tool_use_id":null,"session_id":"00046cdc-8067-47b0-8e48-fe5bf1935362","uuid":"6ed352de-682e-4315-b3f6-13b0ec1eb8e7","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"orchestrate\":\n\t\tcmdOrchestrate(ctx, client)\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client)\n\tdefault:\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n}\n\nfunc usage() {\n\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n\nCommands:\n  init [--workflow <name>] [--image <base>]  Initialize a Cloche project\n  health                                   Show project health summary\n  run --workflow <name> [--prompt \"...\"] [--keep-container]\n                                             Launch a workflow run\n  status <run-id>                            Check run status\n  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n                                             Show logs for a run\n  poll <run-id>                              Wait for a run to finish\n  list [--all]                                List runs (last hour by default)\n  stop <run-id>                              Stop a running workflow\n  delete <container-or-run-id>               Delete a retained container\n  orchestrate                                Dispatch ready workflow runs\n  shutdown                                   Shut down the daemon\n`)\n}\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure ‚Äî fall back to daemon default)\n\tvar image string\n\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n\tif data, err := os.ReadFile(wfPath); err == nil {\n\t\tif wf, err := dsl.Parse(string(data)); err == nil {\n\t\t\timage = wf.Config[\"container.image\"]\n\t\t}\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t}\n\t}\n\n\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s\", run.RunId, run.WorkflowName, run.State)\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\t}\n\t}\n\n\tif follow {\n\t\tcmdLogsFollow(runID)\n\t\treturn\n\t}\n\n\t// Use background context ‚Äî log output can be large\n\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(entry.Message)\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdLogsFollow(runID string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\t// Strip protocol prefix if present\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\treq.Header.Set(\"Accept\", \"text/event-stream\")\n\n\tresp, err := http.DefaultClient.Do(req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\tscanner := bufio.NewScanner(resp.Body)\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"event: done\") {\n\t\t\tbreak\n\t\t}\n\t\tif !strings.HasPrefix(line, \"data: \") {\n\t\t\tcontinue\n\t\t}\n\t\tdata := strings.TrimPrefix(line, \"data: \")\n\n\t\tvar entry struct {\n\t\t\tTimestamp string `json:\"timestamp\"`\n\t\t\tType      string `json:\"type\"`\n\t\t\tContent   string `json:\"content\"`\n\t\t}\n\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Color-code by type\n\t\tswitch entry.Type {\n\t\tcase \"status\":\n\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tcase \"llm\":\n\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tdefault:\n\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdOrchestrate(ctx context.Context, client pb.ClocheServiceClient) {\n\tcwd, _ := os.Getwd()\n\tresp, err := client.Orchestrate(ctx, &pb.OrchestrateRequest{ProjectDir: cwd})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif resp.Dispatched == 0 {\n\t\tfmt.Println(\"No ready work found.\")\n\t} else {\n\t\tfmt.Printf(\"Dispatched %d run(s).\\n\", resp.Dispatched)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n","numLines":417,"startLine":1,"totalLines":417}}}
