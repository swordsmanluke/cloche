{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KNrx53RKh7isdXqvoeJ4ii","type":"tool_result","content":"     1‚Üípackage main\n     2‚Üí\n     3‚Üíimport (\n     4‚Üí\t\"context\"\n     5‚Üí\t\"fmt\"\n     6‚Üí\t\"os\"\n     7‚Üí\t\"time\"\n     8‚Üí\n     9‚Üí\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    10‚Üí)\n    11‚Üí\n    12‚Üífunc cmdPoll(client pb.ClocheServiceClient, args []string) {\n    13‚Üí\tif len(args) < 1 {\n    14‚Üí\t\tfmt.Fprintf(os.Stderr, \"usage: cloche poll <run-id>\\n\")\n    15‚Üí\t\tos.Exit(1)\n    16‚Üí\t}\n    17‚Üí\n    18‚Üí\trunID := args[0]\n    19‚Üí\tpollInterval := 2 * time.Second\n    20‚Üí\tcontainerDeadThreshold := 1 * time.Minute\n    21‚Üí\n    22‚Üí\tvar lastStepCount int\n    23‚Üí\tvar lastState string\n    24‚Üí\n    25‚Üí\tfor {\n    26‚Üí\t\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n    27‚Üí\t\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: runID})\n    28‚Üí\t\tcancel()\n    29‚Üí\n    30‚Üí\t\tif err != nil {\n    31‚Üí\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    32‚Üí\t\t\tos.Exit(1)\n    33‚Üí\t\t}\n    34‚Üí\n    35‚Üí\t\t// Print new step events\n    36‚Üí\t\tfor i := lastStepCount; i < len(resp.StepExecutions); i++ {\n    37‚Üí\t\t\texec := resp.StepExecutions[i]\n    38‚Üí\t\t\tts := time.Now().Format(\"15:04:05\")\n    39‚Üí\t\t\tif exec.Result == \"\" {\n    40‚Üí\t\t\t\tfmt.Printf(\"[%s] Step %q started\\n\", ts, exec.StepName)\n    41‚Üí\t\t\t} else {\n    42‚Üí\t\t\t\tfmt.Printf(\"[%s] Step %q completed: %s\\n\", ts, exec.StepName, exec.Result)\n    43‚Üí\t\t\t}\n    44‚Üí\t\t}\n    45‚Üí\t\tlastStepCount = len(resp.StepExecutions)\n    46‚Üí\n    47‚Üí\t\t// Print state changes\n    48‚Üí\t\tif resp.State != lastState {\n    49‚Üí\t\t\tts := time.Now().Format(\"15:04:05\")\n    50‚Üí\t\t\tfmt.Printf(\"[%s] Run %s is %s\\n\", ts, runID, resp.State)\n    51‚Üí\t\t\tlastState = resp.State\n    52‚Üí\t\t}\n    53‚Ü