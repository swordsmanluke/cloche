{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ED1wJdPsyB4AkdPKDiDMwD","type":"tool_result","content":"     1‚Üípackage main\n     2‚Üí\n     3‚Üíimport (\n     4‚Üí\t\"encoding/json\"\n     5‚Üí\t\"fmt\"\n     6‚Üí\t\"net/http\"\n     7‚Üí\t\"os\"\n     8‚Üí\t\"text/tabwriter\"\n     9‚Üí)\n    10‚Üí\n    11‚Üítype healthData struct {\n    12‚Üí\tStatus string `json:\"status\"`\n    13‚Üí\tPassed int    `json:\"passed\"`\n    14‚Üí\tFailed int    `json:\"failed\"`\n    15‚Üí\tTotal  int    `json:\"total\"`\n    16‚Üí}\n    17‚Üí\n    18‚Üítype projectHealth struct {\n    19‚Üí\tDir    string     `json:\"dir\"`\n    20‚Üí\tLabel  string     `json:\"label\"`\n    21‚Üí\tHealth healthData `json:\"health\"`\n    22‚Üí}\n    23‚Üí\n    24‚Üífunc cmdHealth(args []string) {\n    25‚Üí\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n    26‚Üí\tif httpAddr == \"\" {\n    27‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: CLOCHE_HTTP not set (e.g. export CLOCHE_HTTP=localhost:8080)\\n\")\n    28‚Üí\t\tos.Exit(1)\n    29‚Üí\t}\n    30‚Üí\n    31‚Üí\turl := \"http://\" + httpAddr + \"/api/projects\"\n    32‚Üí\tresp, err := http.Get(url)\n    33‚Üí\tif err != nil {\n    34‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    35‚Üí\t\tos.Exit(1)\n    36‚Üí\t}\n    37‚Üí\tdefer resp.Body.Close()\n    38‚Üí\n    39‚Üí\tif resp.StatusCode != http.StatusOK {\n    40‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: server returned %s\\n\", resp.Status)\n    41‚Üí\t\tos.Exit(1)\n    42‚Üí\t}\n    43‚Üí\n    44‚Üí\tvar projects []projectHealth\n    45‚Üí\tif err := json.NewDecoder(resp.Body).Decode(&projects); err != nil {\n    46‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    47‚Üí\t\tos.Exit(1)\n    48‚Üí\t}\n    49‚Üí\n    50‚Üí\tif len(projects) == 0 {\n    51‚Üí\t\tfmt.Println(\"No projects found.\")\n    52‚Üí\t\treturn\n    53‚Üí\t}\n    54‚Üí\n    55‚Üí\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n    56‚Üí\tfmt.Fprintln(w, \"PROJECT\\tSTATUS\\tPASSED\\tFAILED\\tTOTAL\")\n    57‚Üí\tfor _, p := range projects {\n    58‚Üí\t\tname := p.Label\n    59‚Üí\t\tif name == \"\" {\n    60‚Üí\t\t\tname = p.Dir\n    61‚Üí\t\t}\n    62‚Üí\t\tstatus := colorStatus(p.Health.Status)\n    63‚Üí\t\tfmt.Fprintf(w, \"%s\\t%s\\t%d\\t%d\\t%d\\n\",\n    64‚Üí\t\t\tname, status, p.Health.Passed, p.Health.Failed, p.Health.Total)\n    65‚Üí\t}\n    66‚Üí\tw.Flush()\n    67‚Üí}\n    68‚Üí\n    69‚Üífunc colorStatus(status string) string {\n    70‚Üí\tif !isTTY() {\n    71‚Üí\t\treturn status\n    72‚Üí\t}\n    73‚Üí\tswitch status {\n    74‚Üí\tcase \"green\":\n    75‚Üí\t\treturn \"\\033[32m\" + status + \"\\033[0m\"\n    76‚Üí\tcase \"yellow\":\n    77‚Üí\t\treturn \"\\033[33m\" + status + \"\\033[0m\"\n    78‚Üí\tcase \"red\":\n    79‚Üí\t\treturn \"\\033[31m\" + status + \"\\033[0m\"\n    80‚Üí\tdefault:\n    81‚Üí\t\treturn status\n    82‚Üí\t}\n    83‚Üí}\n    84‚Üí\n    85‚Üífunc isTTY() bool {\n    86‚Üí\tfi, err := os.Stdout.Stat()\n    87‚Üí\tif err != nil {\n    88‚Üí\t\treturn false\n    89‚Üí\t}\n    90‚Üí\treturn fi.Mode()&os.ModeCharDevice != 0\n    91‚Üí}\n    92‚Üí"}]},"parent_tool_use_id":null,"session_id":"00046cdc-8067-47b0-8e48-fe5bf1935362","uuid":"0d228b0c-eee0-4446-abb6-033fe9b20ab2","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/health.go","content":"package main\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"text/tabwriter\"\n)\n\ntype healthData struct {\n\tStatus string `json:\"status\"`\n\tPassed int    `json:\"passed\"`\n\tFailed int    `json:\"failed\"`\n\tTotal  int    `json:\"total\"`\n}\n\ntype projectHealth struct {\n\tDir    string     `json:\"dir\"`\n\tLabel  string     `json:\"label\"`\n\tHealth healthData `json:\"health\"`\n}\n\nfunc cmdHealth(args []string) {\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"error: CLOCHE_HTTP not set (e.g. export CLOCHE_HTTP=localhost:8080)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\turl := \"http://\" + httpAddr + \"/api/projects\"\n\tresp, err := http.Get(url)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\tfmt.Fprintf(os.Stderr, \"error: server returned %s\\n\", resp.Status)\n\t\tos.Exit(1)\n\t}\n\n\tvar projects []projectHealth\n\tif err := json.NewDecoder(resp.Body).Decode(&projects); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(projects) == 0 {\n\t\tfmt.Println(\"No projects found.\")\n\t\treturn\n\t}\n\n\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n\tfmt.Fprintln(w, \"PROJECT\\tSTATUS\\tPASSED\\tFAILED\\tTOTAL\")\n\tfor _, p := range projects {\n\t\tname := p.Label\n\t\tif name == \"\" {\n\t\t\tname = p.Dir\n\t\t}\n\t\tstatus := colorStatus(p.Health.Status)\n\t\tfmt.Fprintf(w, \"%s\\t%s\\t%d\\t%d\\t%d\\n\",\n\t\t\tname, status, p.Health.Passed, p.Health.Failed, p.Health.Total)\n\t}\n\tw.Flush()\n}\n\nfunc colorStatus(status string) string {\n\tif !isTTY() {\n\t\treturn status\n\t}\n\tswitch status {\n\tcase \"green\":\n\t\treturn \"\\033[32m\" + status + \"\\033[0m\"\n\tcase \"yellow\":\n\t\treturn \"\\033[33m\" + status + \"\\033[0m\"\n\tcase \"red\":\n\t\treturn \"\\033[31m\" + status + \"\\033[0m\"\n\tdefault:\n\t\treturn status\n\t}\n}\n\nfunc isTTY() bool {\n\tfi, err := os.Stdout.Stat()\n\tif err != nil {\n\t\treturn false\n\t}\n\treturn fi.Mode()&os.ModeCharDevice != 0\n}\n","numLines":92,"startLine":1,"totalLines":92}}}
