{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TXaxyyZiQT8jsSMdyFPC8R","type":"tool_result","content":"     1‚Üípackage main\n     2‚Üí\n     3‚Üíimport (\n     4‚Üí\t\"context\"\n     5‚Üí\t\"fmt\"\n     6‚Üí\t\"net\"\n     7‚Üí\t\"net/http\"\n     8‚Üí\t\"os\"\n     9‚Üí\t\"os/signal\"\n    10‚Üí\t\"path/filepath\"\n    11‚Üí\t\"syscall\"\n    12‚Üí\n    13‚Üí\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14‚Üí\t\"github.com/cloche-dev/cloche/internal/adapters/beads\"\n    15‚Üí\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    16‚Üí\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    17‚Üí\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    18‚Üí\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    19‚Üí\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    20‚Üí\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    21‚Üí\t\"github.com/cloche-dev/cloche/internal/config\"\n    22‚Üí\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23‚Üí\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    24‚Üí\t\"github.com/cloche-dev/cloche/internal/orchestrator\"\n    25‚Üí\t\"github.com/cloche-dev/cloche/internal/ports\"\n    26‚Üí\t\"google.golang.org/grpc\"\n    27‚Üí)\n    28‚Üí\n    29‚Üífunc main() {\n    30‚Üí\t// Load global config file (~/.config/cloche/config)\n    31‚Üí\tglobalCfg, err := config.LoadGlobal()\n    32‚Üí\tif err != nil {\n    33‚Üí\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n    34‚Üí\t\tdefaults := config.Config{}\n    35‚Üí\t\tglobalCfg = &defaults\n    36‚Üí\t}\n    37‚Üí\n    38‚Üí\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, \"cloche.db\")\n    39‚Üí\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, \"unix:///tmp/cloche.sock\")\n    40‚Üí\n    41‚Üí\tstore, err := sqlite.NewStore(dbPath)\n    42‚Üí\tif err != nil {\n    43‚Üí\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    44‚Üí\t\tos.Exit(1)\n    45‚Üí\t}\n    46‚Üí\tdefer store.Close()\n    47‚Üí\n    48‚Üí\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    49‚Üí\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    50‚Üí\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    51‚Üí\t} else if n > 0 {\n    52‚Üí\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    53‚Üí\t}\n    54‚Üí\n    55‚Üí\truntime, err := initRuntime(globalCfg)\n    56‚Üí\tif err != nil {\n    57‚Üí\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    58‚Üí\t\tos.Exit(1)\n    59‚Üí\t}\n    60‚Üí\n    61‚Üí\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    62‚Üí\n    63‚Üí\tbroadcaster := logstream.NewBroadcaster()\n    64‚Üí\n    65‚Üí\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    66‚Üí\tsrv.SetLogStore(store)\n    67‚Üí\tsrv.SetLogBroadcaster(broadcaster)\n    68‚Üí\n    69‚Üí\t// Set up evolution trigger\n    70‚Üí\tevoTrigger := initEvolution(globalCfg, store, store)\n    71‚Üí\tif evoTrigger != nil {\n    72‚Üí\t\tsrv.SetEvolution(evoTrigger)\n    73‚Üí\t}\n    74‚Üí\n    75‚Üí\t// Set up merge agent\n    76‚Üí\tsrv.SetMergeQueue(store)\n    77‚Üí\tmergeAgent := initMergeAgent(globalCfg, store)\n    78‚Üí\tif mergeAgent != nil {\n    79‚Üí\t\tsrv.SetOnMergeReady(func(ctx context.Context, projectDir string) {\n    80‚Üí\t\t\tmergeAgent.ProcessQueue(ctx, projectDir)\n    81‚Üí\t\t})\n    82‚Üí\t}\n    83‚Üí\n    84‚Üí\t// Set up orchestrator\n    85‚Üí\torch := initOrchestrator(globalCfg, store, srv)\n    86‚Üí\tif orch != nil {\n    87‚Üí\t\tsrv.SetOnRunComplete(func(ctx context.Context, projectDir string, state domain.RunState) {\n    88‚Üí\t\t\torch.OnRunComplete(ctx, projectDir)\n    89‚Üí\t\t})\n    90‚Üí\t\tsrv.SetOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n    91‚Üí\t\t\tif projectDir != \"\" {\n    92‚Üí\t\t\t\treturn orch.Run(ctx, projectDir)\n    93‚Üí\t\t\t}\n    94‚Üí\t\t\treturn orch.TriggerAll(ctx), nil\n    95‚Üí\t\t})\n    96‚Üí\t}\n    97‚Üí\n    98‚Üí\tgrpcServer := grpc.NewServer()\n    99‚Üí\tpb.RegisterClocheServiceServer(grpcServer, srv)\n   100‚Üí\n   101‚Üí\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n   102‚Üí\n   103‚Üí\tlis, err := listen(listenAddr)\n   104‚Üí\tif err != nil {\n   105‚Üí\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n   106‚Üí\t\tos.Exit(1)\n   107‚Üí\t}\n   108‚Üí\n   109‚Üí\tvar httpServer *http.Server\n   110‚Üí\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n   111‚Üí\t\twebOpts := []web.HandlerOption{\n   112‚Üí\t\t\tweb.WithContainerLogger(runtime),\n   113‚Üí\t\t\tweb.WithLogStore(store),\n   114‚Üí\t\t\tweb.WithLogBroadcaster(broadcaster),\n   115‚Üí\t\t}\n   116‚Üí\t\tif orch != nil {\n   117‚Üí\t\t\twebOpts = append(webOpts, web.WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   118‚Üí\t\t\t\treturn orch.Run(ctx, projectDir)\n   119‚Üí\t\t\t}))\n   120‚Üí\t\t}\n   121‚Üí\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n   122‚Üí\t\tif err != nil {\n   123‚Üí\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n   124‚Üí\t\t\tos.Exit(1)\n   125‚Üí\t\t}\n   126‚Üí\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n   127‚Üí\t\tgo func() {\n   128‚Üí\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   129‚Üí\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   130‚Üí\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   131‚Üí\t\t\t}\n   132‚Üí\t\t}()\n   133‚Üí\t}\n   134‚Üí\n   135‚Üí\tsigCh := make(chan os.Signal, 1)\n   136‚Üí\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   137‚Üí\tgo func() {\n   138‚Üí\t\t<-sigCh\n   139‚Üí\t\tif httpServer != nil {\n   140‚Üí\t\t\thttpServer.Close()\n   141‚Üí\t\t}\n   142‚Üí\t\tgrpcServer.GracefulStop()\n   143‚Üí\t}()\n   144‚Üí\n   145‚Üí\t// Trigger orchestration on startup\n   146‚Üí\tif orch != nil {\n   147‚Üí\t\tgo func() {\n   148‚Üí\t\t\tn := orch.TriggerAll(context.Background())\n   149‚Üí\t\t\tif n > 0 {\n   150‚Üí\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: orchestrator dispatched %d run(s)\\n\", n)\n   151‚Üí\t\t\t}\n   152‚Üí\t\t}()\n   153‚Üí\t}\n   154‚Üí\n   155‚Üí\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   156‚Üí\tif err := grpcServer.Serve(lis); err != nil {\n   157‚Üí\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   158‚Üí\t\tos.Exit(1)\n   159‚Üí\t}\n   160‚Üí}\n   161‚Üí\n   162‚Üífunc initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   163‚Üí\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   164‚Üí\n   165‚Üí\tswitch runtimeType {\n   166‚Üí\tcase \"local\":\n   167‚Üí\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   168‚Üí\t\tif agentPath == \"\" {\n   169‚Üí\t\t\t// Look for cloche-agent next to this binary\n   170‚Üí\t\t\texe, err := os.Executable()\n   171‚Üí\t\t\tif err == nil {\n   172‚Üí\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   173‚Üí\t\t\t} else {\n   174‚Üí\t\t\t\tagentPath = \"cloche-agent\"\n   175‚Üí\t\t\t}\n   176‚Üí\t\t}\n   177‚Üí\t\treturn local.NewRuntime(agentPath), nil\n   178‚Üí\tcase \"docker\":\n   179‚Üí\t\treturn docker.NewRuntime()\n   180‚Üí\tdefault:\n   181‚Üí\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   182‚Üí\t}\n   183‚Üí}\n   184‚Üí\n   185‚Üífunc initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   186‚Üí\t// Load config from working directory (daemon-level defaults)\n   187‚Üí\tcfg, err := config.Load(\".\")\n   188‚Üí\tif err != nil || !cfg.Evolution.Enabled {\n   189‚Üí\t\treturn nil\n   190‚Üí\t}\n   191‚Üí\n   192‚Üí\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   193‚Üí\tif llmCmd == \"\" {\n   194‚Üí\t\treturn nil\n   195‚Üí\t}\n   196‚Üí\n   197‚Üí\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   198‚Üí\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   199‚Üí\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   200‚Üí\t\t\t// Load per-project config for confidence threshold\n   201‚Üí\t\t\tprojCfg, err := config.Load(projectDir)\n   202‚Üí\t\t\tif err != nil {\n   203‚Üí\t\t\t\tprojCfg = cfg // fall back to daemon config\n   204‚Üí\t\t\t}\n   205‚Üí\n   206‚Üí\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   207‚Üí\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   208‚Üí\t\t\t\tProjectDir:    projectDir,\n   209‚Üí\t\t\t\tWorkflowName:  workflowName,\n   210‚Üí\t\t\t\tLLM:           llm,\n   211‚Üí\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   212‚Üí\t\t\t})\n   213‚Üí\n   214‚Üí\t\t\tctx := context.Background()\n   215‚Üí\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   216‚Üí\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   217‚Üí\t\t\t}\n   218‚Üí\t\t},\n   219‚Üí\t})\n   220‚Üí\n   221‚Üí\treturn trigger\n   222‚Üí}\n   223‚Üí\n   224‚Üífunc listen(addr string) (net.Listener, error) {\n   225‚Üí\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   226‚Üí\t\tsockPath := addr[7:]\n   227‚Üí\t\tos.Remove(sockPath)\n   228‚Üí\t\treturn net.Listen(\"unix\", sockPath)\n   229‚Üí\t}\n   230‚Üí\treturn net.Listen(\"tcp\", addr)\n   231‚Üí}\n   232‚Üí\n   233‚Üífunc initOrchestrator(globalCfg *config.Config, store ports.RunStore, srv *adaptgrpc.ClocheServer) *orchestrator.Orchestrator {\n   234‚Üí\tllmClient := orchestrator.NewCommandLLMClientFromEnv()\n   235‚Üí\tpromptGen := &orchestrator.LLMPromptGenerator{LLM: llmClient}\n   236‚Üí\n   237‚Üí\tdispatch := func(ctx context.Context, workflowName, projectDir, prompt string) (string, error) {\n   238‚Üí\t\tresp, err := srv.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   239‚Üí\t\t\tWorkflowName: workflowName,\n   240‚Üí\t\t\tProjectDir:   projectDir,\n   241‚Üí\t\t\tPrompt:       prompt,\n   242‚Üí\t\t})\n   243‚Üí\t\tif err != nil {\n   244‚Üí\t\t\treturn \"\", err\n   245‚Üí\t\t}\n   246‚Üí\t\treturn resp.RunId, nil\n   247‚Üí\t}\n   248‚Üí\n   249‚Üí\torch := orchestrator.New(promptGen, dispatch)\n   250‚Üí\n   251‚Üí\t// Collect candidate project directories: cwd + all known projects from the store.\n   252‚Üí\tcandidates := map[string]bool{}\n   253‚Üí\tif cwd, err := os.Getwd(); err == nil {\n   254‚Üí\t\tcandidates[cwd] = true\n   255‚Üí\t}\n   256‚Üí\tif projects, err := store.ListProjects(context.Background()); err == nil {\n   257‚Üí\t\tfor _, dir := range projects {\n   258‚Üí\t\t\tcandidates[dir] = true\n   259‚Üí\t\t}\n   260‚Üí\t}\n   261‚Üí\n   262‚Üí\t// Register every project that has orchestration enabled.\n   263‚Üí\tregistered := 0\n   264‚Üí\tfor dir := range candidates {\n   265‚Üí\t\tcfg, err := config.Load(dir)\n   266‚Üí\t\tif err != nil || !cfg.Orchestration.Enabled {\n   267‚Üí\t\t\tcontinue\n   268‚Üí\t\t}\n   269‚Üí\t\ttracker := beads.NewTracker(dir)\n   270‚Üí\t\torch.Register(&orchestrator.ProjectConfig{\n   271‚Üí\t\t\tDir:         dir,\n   272‚Üí\t\t\tWorkflow:    cfg.Orchestration.Workflow,\n   273‚Üí\t\t\tConcurrency: cfg.Orchestration.Concurrency,\n   274‚Üí\t\t\tTracker:     tracker,\n   275‚Üí\t\t})\n   276‚Üí\t\tregistered++\n   277‚Üí\t}\n   278‚Üí\n   279‚Üí\tif registered == 0 {\n   280‚Üí\t\treturn nil\n   281‚Üí\t}\n   282‚Üí\treturn orch\n   283‚Üí}\n   284‚Üí\n   285‚Üífunc initMergeAgent(globalCfg *config.Config, store ports.MergeQueueStore) *orchestrator.MergeAgent {\n   286‚Üí\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   287‚Üí\n   288‚Üí\tvar llm orchestrator.LLMClient\n   289‚Üí\tif llmCmd != \"\" {\n   290‚Üí\t\tllm = &orchestrator.CommandLLMClient{Command: llmCmd}\n   291‚Üí\t}\n   292‚Üí\n   293‚Üí\treturn &orchestrator.MergeAgent{\n   294‚Üí\t\tLLM:        llm,\n   295‚Üí\t\tMergeQueue: store,\n   296‚Üí\t}\n   297‚Üí}\n   298‚Üí\n   299‚Üí// envOrConfig returns the env var value if set, otherwise the config file\n   300‚Üí// value if non-empty, otherwise the fallback default.\n   301‚Üífunc envOrConfig(envKey, configVal, fallback string) string {\n   302‚Üí\tif v := os.Getenv(envKey); v != \"\" {\n   303‚Üí\t\treturn v\n   304‚Üí\t}\n   305‚Üí\tif configVal != \"\" {\n   306‚Üí\t\treturn configVal\n   307‚Üí\t}\n   308‚Üí\treturn fallback\n   309‚Üí}\n   310‚Üí"}]},"parent_tool_use_id":null,"session_id":"00046cdc-8067-47b0-8e48-fe5bf1935362","uuid":"af666889-67c4-481e-b834-bc740e5c4101","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloched/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"path/filepath\"\n\t\"syscall\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/beads\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\t\"github.com/cloche-dev/cloche/internal/orchestrator\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"google.golang.org/grpc\"\n)\n\nfunc main() {\n\t// Load global config file (~/.config/cloche/config)\n\tglobalCfg, err := config.LoadGlobal()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n\t\tdefaults := config.Config{}\n\t\tglobalCfg = &defaults\n\t}\n\n\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, \"cloche.db\")\n\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, \"unix:///tmp/cloche.sock\")\n\n\tstore, err := sqlite.NewStore(dbPath)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer store.Close()\n\n\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n\t} else if n > 0 {\n\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n\t}\n\n\truntime, err := initRuntime(globalCfg)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n\n\tbroadcaster := logstream.NewBroadcaster()\n\n\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n\tsrv.SetLogStore(store)\n\tsrv.SetLogBroadcaster(broadcaster)\n\n\t// Set up evolution trigger\n\tevoTrigger := initEvolution(globalCfg, store, store)\n\tif evoTrigger != nil {\n\t\tsrv.SetEvolution(evoTrigger)\n\t}\n\n\t// Set up merge agent\n\tsrv.SetMergeQueue(store)\n\tmergeAgent := initMergeAgent(globalCfg, store)\n\tif mergeAgent != nil {\n\t\tsrv.SetOnMergeReady(func(ctx context.Context, projectDir string) {\n\t\t\tmergeAgent.ProcessQueue(ctx, projectDir)\n\t\t})\n\t}\n\n\t// Set up orchestrator\n\torch := initOrchestrator(globalCfg, store, srv)\n\tif orch != nil {\n\t\tsrv.SetOnRunComplete(func(ctx context.Context, projectDir string, state domain.RunState) {\n\t\t\torch.OnRunComplete(ctx, projectDir)\n\t\t})\n\t\tsrv.SetOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\t\tif projectDir != \"\" {\n\t\t\t\treturn orch.Run(ctx, projectDir)\n\t\t\t}\n\t\t\treturn orch.TriggerAll(ctx), nil\n\t\t})\n\t}\n\n\tgrpcServer := grpc.NewServer()\n\tpb.RegisterClocheServiceServer(grpcServer, srv)\n\n\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n\n\tlis, err := listen(listenAddr)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n\t\tos.Exit(1)\n\t}\n\n\tvar httpServer *http.Server\n\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n\t\twebOpts := []web.HandlerOption{\n\t\t\tweb.WithContainerLogger(runtime),\n\t\t\tweb.WithLogStore(store),\n\t\t\tweb.WithLogBroadcaster(broadcaster),\n\t\t}\n\t\tif orch != nil {\n\t\t\twebOpts = append(webOpts, web.WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\t\t\treturn orch.Run(ctx, projectDir)\n\t\t\t}))\n\t\t}\n\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n\t\tgo func() {\n\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n\t\t\t}\n\t\t}()\n\t}\n\n\tsigCh := make(chan os.Signal, 1)\n\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n\tgo func() {\n\t\t<-sigCh\n\t\tif httpServer != nil {\n\t\t\thttpServer.Close()\n\t\t}\n\t\tgrpcServer.GracefulStop()\n\t}()\n\n\t// Trigger orchestration on startup\n\tif orch != nil {\n\t\tgo func() {\n\t\t\tn := orch.TriggerAll(context.Background())\n\t\t\tif n > 0 {\n\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: orchestrator dispatched %d run(s)\\n\", n)\n\t\t\t}\n\t\t}()\n\t}\n\n\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n\tif err := grpcServer.Serve(lis); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n\nfunc initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n\n\tswitch runtimeType {\n\tcase \"local\":\n\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n\t\tif agentPath == \"\" {\n\t\t\t// Look for cloche-agent next to this binary\n\t\t\texe, err := os.Executable()\n\t\t\tif err == nil {\n\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n\t\t\t} else {\n\t\t\t\tagentPath = \"cloche-agent\"\n\t\t\t}\n\t\t}\n\t\treturn local.NewRuntime(agentPath), nil\n\tcase \"docker\":\n\t\treturn docker.NewRuntime()\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n\t}\n}\n\nfunc initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n\t// Load config from working directory (daemon-level defaults)\n\tcfg, err := config.Load(\".\")\n\tif err != nil || !cfg.Evolution.Enabled {\n\t\treturn nil\n\t}\n\n\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n\tif llmCmd == \"\" {\n\t\treturn nil\n\t}\n\n\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n\t\tRunFunc: func(projectDir, workflowName, runID string) {\n\t\t\t// Load per-project config for confidence threshold\n\t\t\tprojCfg, err := config.Load(projectDir)\n\t\t\tif err != nil {\n\t\t\t\tprojCfg = cfg // fall back to daemon config\n\t\t\t}\n\n\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n\t\t\t\tProjectDir:    projectDir,\n\t\t\t\tWorkflowName:  workflowName,\n\t\t\t\tLLM:           llm,\n\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n\t\t\t})\n\n\t\t\tctx := context.Background()\n\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n\t\t\t}\n\t\t},\n\t})\n\n\treturn trigger\n}\n\nfunc listen(addr string) (net.Listener, error) {\n\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n\t\tsockPath := addr[7:]\n\t\tos.Remove(sockPath)\n\t\treturn net.Listen(\"unix\", sockPath)\n\t}\n\treturn net.Listen(\"tcp\", addr)\n}\n\nfunc initOrchestrator(globalCfg *config.Config, store ports.RunStore, srv *adaptgrpc.ClocheServer) *orchestrator.Orchestrator {\n\tllmClient := orchestrator.NewCommandLLMClientFromEnv()\n\tpromptGen := &orchestrator.LLMPromptGenerator{LLM: llmClient}\n\n\tdispatch := func(ctx context.Context, workflowName, projectDir, prompt string) (string, error) {\n\t\tresp, err := srv.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\t\tWorkflowName: workflowName,\n\t\t\tProjectDir:   projectDir,\n\t\t\tPrompt:       prompt,\n\t\t})\n\t\tif err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\treturn resp.RunId, nil\n\t}\n\n\torch := orchestrator.New(promptGen, dispatch)\n\n\t// Collect candidate project directories: cwd + all known projects from the store.\n\tcandidates := map[string]bool{}\n\tif cwd, err := os.Getwd(); err == nil {\n\t\tcandidates[cwd] = true\n\t}\n\tif projects, err := store.ListProjects(context.Background()); err == nil {\n\t\tfor _, dir := range projects {\n\t\t\tcandidates[dir] = true\n\t\t}\n\t}\n\n\t// Register every project that has orchestration enabled.\n\tregistered := 0\n\tfor dir := range candidates {\n\t\tcfg, err := config.Load(dir)\n\t\tif err != nil || !cfg.Orchestration.Enabled {\n\t\t\tcontinue\n\t\t}\n\t\ttracker := beads.NewTracker(dir)\n\t\torch.Register(&orchestrator.ProjectConfig{\n\t\t\tDir:         dir,\n\t\t\tWorkflow:    cfg.Orchestration.Workflow,\n\t\t\tConcurrency: cfg.Orchestration.Concurrency,\n\t\t\tTracker:     tracker,\n\t\t})\n\t\tregistered++\n\t}\n\n\tif registered == 0 {\n\t\treturn nil\n\t}\n\treturn orch\n}\n\nfunc initMergeAgent(globalCfg *config.Config, store ports.MergeQueueStore) *orchestrator.MergeAgent {\n\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n\n\tvar llm orchestrator.LLMClient\n\tif llmCmd != \"\" {\n\t\tllm = &orchestrator.CommandLLMClient{Command: llmCmd}\n\t}\n\n\treturn &orchestrator.MergeAgent{\n\t\tLLM:        llm,\n\t\tMergeQueue: store,\n\t}\n}\n\n// envOrConfig returns the env var value if set, otherwise the config file\n// value if non-empty, otherwise the fallback default.\nfunc envOrConfig(envKey, configVal, fallback string) string {\n\tif v := os.Getenv(envKey); v != \"\" {\n\t\treturn v\n\t}\n\tif configVal != \"\" {\n\t\treturn configVal\n\t}\n\treturn fallback\n}\n","numLines":310,"startLine":1,"totalLines":310}}}
