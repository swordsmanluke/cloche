[2026-03-09T15:31:25Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016B5H4a7RQJmEFcQFqxYxPT","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n     3→\n     4→<div class=\"run-history\" style=\"margin-bottom:1rem\">\n     5→    {{range .RecentRuns}}\n     6→    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n     7→    {{end}}\n     8→    <a href=\"/runs?project={{.Dir}}\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n     9→</div>\n    10→\n    11→<!-- Panel 1: Orchestrator Control -->\n    12→<div class=\"panel\" id=\"orchestrator-panel\">\n    13→    <div class=\"panel-header\">Orchestrator Control</div>\n    14→    <div class=\"panel-body\">\n    15→        <div id=\"orch-status\" class=\"orch-status\">Loading...</div>\n    16→        <div class=\"orch-controls\" style=\"margin-top:0.75rem;display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap\">\n    17→            <button id=\"orch-toggle\" class=\"btn btn-primary btn-sm\" onclick=\"toggleOrchestrator()\">Enable</button>\n    18→            <span style=\"margin-left:1rem;color:var(--text-muted);font-size:0.85rem\">Concurrency:</span>\n    19→            <input type=\"number\" id=\"orch-concurrency\" min=\"1\" max=\"20\" value=\"1\" style=\"width:60px;padding:0.2em 0.4em;border:1px solid var(--border);border-radius:var(--radius);background:var(--bg);color:var(--text);font-size:0.85rem\">\n    20→            <button class=\"btn btn-secondary btn-sm\" onclick=\"applyConcurrency()\">Apply</button>\n    21→        </div>\n    22→    </div>\n    23→</div>\n    24→\n    25→<!-- Panel 2: Project Info -->\n    26→<div class=\"panel\" id=\"info-panel\">\n    27→    <div class=\"panel-header\">Project Info</div>\n    28→    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n    29→</div>\n    30→\n    31→<!-- Panel 3: Workflow View -->\n    32→<div class=\"panel\" id=\"workflow-panel\">\n    33→    <div class=\"panel-header\">Workflows</div>\n    34→    <div class=\"panel-body\">\n    35→        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n    36→        <div id=\"workflow-dag\"></div>\n    37→    </div>\n    38→</div>\n    39→\n    40→<!-- Step Drawer -->\n    41→<div class=\"drawer\" id=\"step-drawer\">\n    42→    <div class=\"drawer-header\">\n    43→        <span id=\"drawer-title\"></span>\n    44→        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    45→    </div>\n    46→    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n    47→</div>\n    48→{{end}}\n    49→\n    50→{{define \"scripts\"}}\n    51→<script>\n    52→var projectLabel = {{.Label}};\n    53→var orchEnabled = false;\n    54→\n    55→function loadOrchestratorStatus() {\n    56→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/orchestrator')\n    57→        .then(function(r) { return r.json(); })\n    58→        .then(function(data) {\n    59→            orchEnabled = data.enabled;\n    60→            var statusEl = document.getElementById('orch-status');\n    61→            var toggleBtn = document.getElementById('orch-toggle');\n    62→            var concInput = document.getElementById('orch-concurrency');\n    63→            statusEl.innerHTML = '<span class=\"badge ' + (data.enabled ? 'badge-succeeded' : 'badge-stopped') + '\">' +\n    64→                (data.enabled ? 'Enabled' : 'Disabled') + '</span>' +\n    65→                '&nbsp; In-flight: <strong>' + data.in_flight + '</strong>' +\n    66→                '&nbsp; Concurrency: <strong>' + data.concurrency + '</strong>';\n    67→            toggleBtn.textContent = data.enabled ? 'Disable' : 'Enable';\n    68→            toggleBtn.className = 'btn btn-sm ' + (data.enabled ? 'btn-danger' : 'btn-primary');\n    69→            concInput.value = data.concurrency;\n    70→        });\n    71→}\n    72→\n    73→function toggleOrchestrator() {\n    74→    var action = orchEnabled ? 'stop' : 'start';\n    75→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/orchestrator/' + action, {method: 'POST'})\n    76→        .then(function() { loadOrchestratorStatus(); });\n    77→}\n    78→\n    79→function applyConcurrency() {\n    80→    var val = parseInt(document.getElementById('orch-concurrency').value, 10);\n    81→    if (val < 1) return;\n    82→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/orchestrator/concurrency', {\n    83→        method: 'POST',\n    84→        headers: {'Content-Type': 'application/json'},\n    85→        body: JSON.stringify({concurrency: val})\n    86→    }).then(function() { loadOrchestratorStatus(); });\n    87→}\n    88→\n    89→function loadProjectInfo() {\n    90→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n    91→        .then(function(r) { return r.json(); })\n    92→        .then(function(data) {\n    93→            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n    94→            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n    95→            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n    96→            html += '</dl>';\n    97→\n    98→            if (data.prompt_files && data.prompt_files.length > 0) {\n    99→                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n   100→                data.prompt_files.forEach(function(pf) {\n   101→                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n   102→                    if (pf.history && pf.history.length > 0) {\n   103→                        html += '<div style=\"margin:0.5rem 0\">';\n   104→                        pf.history.forEach(function(h) {\n   105→                            html += '<div class=\"prompt-commit\" data-file=\"' + pf.path + '\" data-sha=\"' + h.sha + '\" onclick=\"toggleDiff(this)\" style=\"cursor:pointer;padding:0.25rem 0;font-size:0.85rem\">';\n   106→                            html += '<span class=\"mono\" style=\"color:var(--link)\">' + h.sha + '</span> ';\n   107→                            html += '<span style=\"color:var(--text-muted)\">' + h.date + '</span> ';\n   108→                            html += h.message;\n   109→                            html += '</div>';\n   110→                        });\n   111→                        html += '</div>';\n   112→                    } else {\n   113→                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">No history</p>';\n   114→                    }\n   115→                    html += '</details>';\n   116→                });\n   117→            }\n   118→\n   119→            document.getElementById('project-info').innerHTML = html;\n   120→        });\n   121→}\n   122→\n   123→function toggleDiff(el) {\n   124→    var existing = el.nextElementSibling;\n   125→    if (existing && existing.classList.contains('diff-block')) {\n   126→        existing.remove();\n   127→        return;\n   128→    }\n   129→    var file = el.getAttribute('data-file');\n   130→    var sha = el.getAttribute('data-sha');\n   131→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n   132→        .then(function(r) { return r.text(); })\n   133→        .then(function(text) {\n   134→            var pre = document.createElement('pre');\n   135→            pre.className = 'diff-block';\n   136→            pre.textContent = text || '(no diff available)';\n   137→            el.parentNode.insertBefore(pre, el.nextSibling);\n   138→        });\n   139→}\n   140→\n   141→var workflowsData = [];\n   142→function loadWorkflows() {\n   143→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n   144→        .then(function(r) { return r.json(); })\n   145→        .then(function(data) {\n   146→            workflowsData = data || [];\n   147→            if (workflowsData.length === 0) {\n   148→                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n   149→                return;\n   150→            }\n   151→            var tabs = document.getElementById('workflow-tabs');\n   152→            if (workflowsData.length > 1) {\n   153→                var html = '';\n   154→                workflowsData.forEach(function(wf, i) {\n   155→                    html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showWorkflow(' + i + ')\">' + wf.name + '</button>';\n   156→                });\n   157→                tabs.innerHTML = html;\n   158→            }\n   159→            showWorkflow(0);\n   160→        });\n   161→}\n   162→\n   163→function showWorkflow(idx) {\n   164→    var btns = document.querySelectorAll('.tab-btn');\n   165→    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n   166→\n   167→    var wf = workflowsData[idx];\n   168→    var dagEl = document.getElementById('workflow-dag');\n   169→\n   170→    // Build step order via topological sort from entry\n   171→    var ordered = [];\n   172→    var visited = {};\n   173→    function visit(name) {\n   174→        if (visited[name] || name === 'done' || name === 'abort') return;\n   175→        visited[name] = true;\n   176→        ordered.push(name);\n   177→        wf.wires.forEach(function(wire) {\n   178→            if (wire.from === name) visit(wire.to);\n   179→        });\n   180→    }\n   181→    if (wf.entry_step) visit(wf.entry_step);\n   182→    // Add any unvisited steps\n   183→    wf.steps.forEach(function(s) { if (!visited[s.name]) { ordered.push(s.name); visited[s.name] = true; } });\n   184→\n   185→    // Collect terminal targets\n   186→    var terminals = {};\n   187→    wf.wires.forEach(function(wire) {\n   188→        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n   189→    });\n   190→\n   191→    var stepMap = {};\n   192→    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n   193→\n   194→    var nodeH = 48, nodeW = 180, gapY = 24, gapX = 40, padTop = 20, padLeft = 30;\n   195→\n   196→    // Assign positions\n   197→    var positions = {};\n   198→    ordered.forEach(function(name, i) {\n   199→        positions[name] = {x: padLeft, y: padTop + i * (nodeH + gapY)};\n   200→    });\n   201→    var termIdx = ordered.length;\n   202→    for (var t in terminals) {\n   203→        positions[t] = {x: padLeft, y: padTop + termIdx * (nodeH + gapY)};\n   204→        termIdx++;\n   205→    }\n   206→\n   207→    var totalH = padTop + termIdx * (nodeH + gapY) + 10;\n   208→    var totalW = padLeft + nodeW + gapX + 80;\n   209→\n   210→    var html = '<svg class=\"dag-svg\" width=\"' + totalW + '\" height=\"' + totalH + '\">';\n   211→    html += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n   212→\n   213→    // Draw wires\n   214→    wf.wires.forEach(function(wire) {\n   215→        var from = positions[wire.from];\n   216→        var to = positions[wire.to];\n   217→        if (!from || !to) return;\n   218→        var x1 = from.x + nodeW;\n   219→        var y1 = from.y + nodeH / 2;\n   220→        var x2 = to.x;\n   221→        var y2 = to.y + nodeH / 2;\n   222→        var cx = x1 + gapX / 2;\n   223→        html += '<path d=\"M' + x1 + ' ' + y1 + ' C' + cx + ' ' + y1 + ' ' + cx + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n   224→        var lx = (x1 + x2) / 2, ly = (y1 + y2) / 2 - 6;\n   225→        html += '<text x=\"' + lx + '\" y=\"' + ly + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n   226→    });\n   227→\n   228→    // Draw step nodes\n   229→    ordered.forEach(function(name) {\n   230→        var pos = positions[name];\n   231→        var s = stepMap[name];\n   232→        var icon = s && s.type === 'agent' ? '\\u{1F916}' : '\\u{1F4DC}';\n   233→        html += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + name + '\\')\" style=\"cursor:pointer\">';\n   234→        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n   235→        html += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + name + '</text>';\n   236→        html += '</g>';\n   237→    });\n   238→\n   239→    // Draw terminal nodes\n   240→    for (var t in terminals) {\n   241→        var pos = positions[t];\n   242→        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n   243→        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n   244→        html += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n   245→    }\n   246→\n   247→    html += '</svg>';\n   248→    dagEl.innerHTML = html;\n   249→}\n   250→\n   251→function openDrawer(workflowName, stepName) {\n   252→    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n   253→    if (!wf) return;\n   254→    var step = wf.steps.find(function(s) { return s.name === stepName; });\n   255→    if (!step) return;\n   256→\n   257→    document.getElementById('drawer-title').textContent = stepName;\n   258→    var body = '<dl class=\"run-meta\">';\n   259→    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n   260→    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n   261→    if (step.config) {\n   262→        for (var k in step.config) {\n   263→            if (k === 'max_attempts' || k === 'prompt' || k === 'run') {\n   264→                var val = step.config[k];\n   265→                var m = val.match(/^file\\(\"(.+)\"\\)$/);\n   266→                if (m) val = m[1];\n   267→                body += '<dt>' + k + '</dt><dd class=\"mono\">' + val + '</dd>';\n   268→            }\n   269→        }\n   270→    }\n   271→    body += '</dl>';\n   272→    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n   273→\n   274→    document.getElementById('drawer-body').innerHTML = body;\n   275→    document.getElementById('step-drawer').classList.add('drawer-open');\n   276→\n   277→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n   278→        .then(function(r) { if (r.ok) return r.text(); return ''; })\n   279→        .then(function(text) {\n   280→            var el = document.getElementById('drawer-content');\n   281→            if (text) {\n   282→                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n   283→            } else {\n   284→                el.innerHTML = '<p style=\"color:var(--text-muted)\">No content available</p>';\n   285→            }\n   286→        });\n   287→}\n   288→\n   289→function closeDrawer() {\n   290→    document.getElementById('step-drawer').classList.remove('drawer-open');\n   291→}\n   292→\n   293→document.addEventListener('keydown', function(e) {\n   294→    if (e.key === 'Escape') closeDrawer();\n   295→});\n   296→\n   297→// Load all panels\n   298→loadOrchestratorStatus();\n   299→loadProjectInfo();\n   300→loadWorkflows();\n   301→</script>\n   302→{{end}}\n   303→"}]},"parent_tool_use_id":null,"session_id":"8ab10257-6440-4162-a68d-565a278d4809","uuid":"a611001a-a5b3-47a0-9ef6-566f4d3645f6","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/project_detail.html","content":"{{define \"content\"}}\n<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n\n<div class=\"run-history\" style=\"margin-bottom:1rem\">\n    {{range .RecentRuns}}\n    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n    {{end}}\n    <a href=\"/runs?project={{.Dir}}\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n</div>\n\n<!-- Panel 1: Orchestrator Control -->\n<div class=\"panel\" id=\"orchestrator-panel\">\n    <div class=\"panel-header\">Orchestrator Control</div>\n    <div class=\"panel-body\">\n        <div id=\"orch-status\" class=\"orch-status\">Loading...</div>\n        <div class=\"orch-controls\" style=\"margin-top:0.75rem;display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap\">\n            <button id=\"orch-toggle\" class=\"btn btn-primary btn-sm\" onclick=\"toggleOrchestrator()\">Enable</button>\n            <span style=\"margin-left:1rem;color:var(--text-muted);font-size:0.85rem\">Concurrency:</span>\n            <input type=\"number\" id=\"orch-concurrency\" min=\"1\" max=\"20\" value=\"1\" style=\"width:60px;padding:0.2em 0.4em;border:1px solid var(--border);border-radius:var(--radius);background:var(--bg);color:var(--text);font-size:0.85rem\">\n            <button class=\"btn btn-secondary btn-sm\" onclick=\"applyConcurrency()\">Apply</button>\n        </div>\n    </div>\n</div>\n\n<!-- Panel 2: Project Info -->\n<div class=\"panel\" id=\"info-panel\">\n    <div class=\"panel-header\">Project Info</div>\n    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n</div>\n\n<!-- Panel 3: Workflow View -->\n<div class=\"panel\" id=\"workflow-panel\">\n    <div class=\"panel-header\">Workflows</div>\n    <div class=\"panel-body\">\n        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-dag\"></div>\n    </div>\n</div>\n\n<!-- Step Drawer -->\n<div class=\"drawer\" id=\"step-drawer\">\n    <div class=\"drawer-header\">\n        <span id=\"drawer-title\"></span>\n        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    </div>\n    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n</div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\nvar projectLabel = {{.Label}};\nvar orchEnabled = false;\n\nfunction loadOrchestratorStatus() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/orchestrator')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            orchEnabled = data.enabled;\n            var statusEl = document.getElementById('orch-status');\n            var toggleBtn = document.getElementById('orch-toggle');\n            var concInput = document.getElementById('orch-concurrency');\n            statusEl.innerHTML = '<span class=\"badge ' + (data.enabled ? 'badge-succeeded' : 'badge-stopped') + '\">' +\n                (data.enabled ? 'Enabled' : 'Disabled') + '</span>' +\n                '&nbsp; In-flight: <strong>' + data.in_flight + '</strong>' +\n                '&nbsp; Concurrency: <strong>' + data.concurrency + '</strong>';\n            toggleBtn.textContent = data.enabled ? 'Disable' : 'Enable';\n            toggleBtn.className = 'btn btn-sm ' + (data.enabled ? 'btn-danger' : 'btn-primary');\n            concInput.value = data.concurrency;\n        });\n}\n\nfunction toggleOrchestrator() {\n    var action = orchEnabled ? 'stop' : 'start';\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/orchestrator/' + action, {method: 'POST'})\n        .then(function() { loadOrchestratorStatus(); });\n}\n\nfunction applyConcurrency() {\n    var val = parseInt(document.getElementById('orch-concurrency').value, 10);\n    if (val < 1) return;\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/orchestrator/concurrency', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({concurrency: val})\n    }).then(function() { loadOrchestratorStatus(); });\n}\n\nfunction loadProjectInfo() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n            html += '</dl>';\n\n            if (data.prompt_files && data.prompt_files.length > 0) {\n                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n                data.prompt_files.forEach(function(pf) {\n                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n                    if (pf.history && pf.history.length > 0) {\n                        html += '<div style=\"margin:0.5rem 0\">';\n                        pf.history.forEach(function(h) {\n                            html += '<div class=\"prompt-commit\" data-file=\"' + pf.path + '\" data-sha=\"' + h.sha + '\" onclick=\"toggleDiff(this)\" style=\"cursor:pointer;padding:0.25rem 0;font-size:0.85rem\">';\n                            html += '<span class=\"mono\" style=\"color:var(--link)\">' + h.sha + '</span> ';\n                            html += '<span style=\"color:var(--text-muted)\">' + h.date + '</span> ';\n                            html += h.message;\n                            html += '</div>';\n                        });\n                        html += '</div>';\n                    } else {\n                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">No history</p>';\n                    }\n                    html += '</details>';\n                });\n            }\n\n            document.getElementById('project-info').innerHTML = html;\n        });\n}\n\nfunction toggleDiff(el) {\n    var existing = el.nextElementSibling;\n    if (existing && existing.classList.contains('diff-block')) {\n        existing.remove();\n        return;\n    }\n    var file = el.getAttribute('data-file');\n    var sha = el.getAttribute('data-sha');\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n        .then(function(r) { return r.text(); })\n        .then(function(text) {\n            var pre = document.createElement('pre');\n            pre.className = 'diff-block';\n            pre.textContent = text || '(no diff available)';\n            el.parentNode.insertBefore(pre, el.nextSibling);\n        });\n}\n\nvar workflowsData = [];\nfunction loadWorkflows() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            workflowsData = data || [];\n            if (workflowsData.length === 0) {\n                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n                return;\n            }\n            var tabs = document.getElementById('workflow-tabs');\n            if (workflowsData.length > 1) {\n                var html = '';\n                workflowsData.forEach(function(wf, i) {\n                    html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showWorkflow(' + i + ')\">' + wf.name + '</button>';\n                });\n                tabs.innerHTML = html;\n            }\n            showWorkflow(0);\n        });\n}\n\nfunction showWorkflow(idx) {\n    var btns = document.querySelectorAll('.tab-btn');\n    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n\n    var wf = workflowsData[idx];\n    var dagEl = document.getElementById('workflow-dag');\n\n    // Build step order via topological sort from entry\n    var ordered = [];\n    var visited = {};\n    function visit(name) {\n        if (visited[name] || name === 'done' || name === 'abort') return;\n        visited[name] = true;\n        ordered.push(name);\n        wf.wires.forEach(function(wire) {\n            if (wire.from === name) visit(wire.to);\n        });\n    }\n    if (wf.entry_step) visit(wf.entry_step);\n    // Add any unvisited steps\n    wf.steps.forEach(function(s) { if (!visited[s.name]) { ordered.push(s.name); visited[s.name] = true; } });\n\n    // Collect terminal targets\n    var terminals = {};\n    wf.wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n    });\n\n    var stepMap = {};\n    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n\n    var nodeH = 48, nodeW = 180, gapY = 24, gapX = 40, padTop = 20, padLeft = 30;\n\n    // Assign positions\n    var positions = {};\n    ordered.forEach(function(name, i) {\n        positions[name] = {x: padLeft, y: padTop + i * (nodeH + gapY)};\n    });\n    var termIdx = ordered.length;\n    for (var t in terminals) {\n        positions[t] = {x: padLeft, y: padTop + termIdx * (nodeH + gapY)};\n        termIdx++;\n    }\n\n    var totalH = padTop + termIdx * (nodeH + gapY) + 10;\n    var totalW = padLeft + nodeW + gapX + 80;\n\n    var html = '<svg class=\"dag-svg\" width=\"' + totalW + '\" height=\"' + totalH + '\">';\n    html += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n\n    // Draw wires\n    wf.wires.forEach(function(wire) {\n        var from = positions[wire.from];\n        var to = positions[wire.to];\n        if (!from || !to) return;\n        var x1 = from.x + nodeW;\n        var y1 = from.y + nodeH / 2;\n        var x2 = to.x;\n        var y2 = to.y + nodeH / 2;\n        var cx = x1 + gapX / 2;\n        html += '<path d=\"M' + x1 + ' ' + y1 + ' C' + cx + ' ' + y1 + ' ' + cx + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n        var lx = (x1 + x2) / 2, ly = (y1 + y2) / 2 - 6;\n        html += '<text x=\"' + lx + '\" y=\"' + ly + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n    });\n\n    // Draw step nodes\n    ordered.forEach(function(name) {\n        var pos = positions[name];\n        var s = stepMap[name];\n        var icon = s && s.type === 'agent' ? '\\u{1F916}' : '\\u{1F4DC}';\n        html += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + name + '\\')\" style=\"cursor:pointer\">';\n        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n        html += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + name + '</text>';\n        html += '</g>';\n    });\n\n    // Draw terminal nodes\n    for (var t in terminals) {\n        var pos = positions[t];\n        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n        html += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n    }\n\n    html += '</svg>';\n    dagEl.innerHTML = html;\n}\n\nfunction openDrawer(workflowName, stepName) {\n    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n    if (!wf) return;\n    var step = wf.steps.find(function(s) { return s.name === stepName; });\n    if (!step) return;\n\n    document.getElementById('drawer-title').textContent = stepName;\n    var body = '<dl class=\"run-meta\">';\n    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n    if (step.config) {\n        for (var k in step.config) {\n            if (k === 'max_attempts' || k === 'prompt' || k === 'run') {\n                var val = step.config[k];\n                var m = val.match(/^file\\(\"(.+)\"\\)$/);\n                if (m) val = m[1];\n                body += '<dt>' + k + '</dt><dd class=\"mono\">' + val + '</dd>';\n            }\n        }\n    }\n    body += '</dl>';\n    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n\n    document.getElementById('drawer-body').innerHTML = body;\n    document.getElementById('step-drawer').classList.add('drawer-open');\n\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n        .then(function(r) { if (r.ok) return r.text(); return ''; })\n        .then(function(text) {\n            var el = document.getElementById('drawer-content');\n            if (text) {\n                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n            } else {\n                el.innerHTML = '<p style=\"color:var(--text-muted)\">No content available</p>';\n            }\n        });\n}\n\nfunction closeDrawer() {\n    document.getElementById('step-drawer').classList.remove('drawer-open');\n}\n\ndocument.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') closeDrawer();\n});\n\n// Load all panels\nloadOrchestratorStatus();\nloadProjectInfo();\nloadWorkflows();\n</script>\n{{end}}\n","numLines":303,"startLine":1,"totalLines":303}}}
