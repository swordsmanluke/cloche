ontainerId:  run.ContainerID,\n   207→+\t\tTitle:        run.Title,\n   208→ \t}\n   209→ \n   210→ \t// Check container liveness\n   211→diff --git a/internal/adapters/grpc/server_test.go b/internal/adapters/grpc/server_test.go\n   212→index bbcc9ea..2968d2c 100644\n   213→--- a/internal/adapters/grpc/server_test.go\n   214→+++ b/internal/adapters/grpc/server_test.go\n   215→@@ -100,6 +100,167 @@ func TestServer_RunWorkflow(t *testing.T) {\n   216→ \tassert.GreaterOrEqual(t, len(status.StepExecutions), 1)\n   217→ }\n   218→ \n   219→+func TestServer_RunWorkflow_WithTitle(t *testing.T) {\n   220→+\tstore, err := sqlite.NewStore(\":memory:\")\n   221→+\trequire.NoError(t, err)\n   222→+\tdefer store.Close()\n   223→+\n   224→+\tdir := t.TempDir()\n   225→+\n   226→+\tmsgs := []protocol.StatusMessage{\n   227→+\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   228→+\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   229→+\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   230→+\t}\n   231→+\tscript := \"#!/bin/sh\\n\"\n   232→+\tfor _, msg := range msgs {\n   233→+\t\tdata, _ := json.Marshal(msg)\n   234→+\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   235→+\t}\n   236→+\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   237→+\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   238→+\n   239→+\trt := local.NewRuntime(\"sh\")\n   240→+\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   241→+\n   242→+\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   243→+\t\tWorkflowName: \"test\",\n   244→+\t\tProjectDir:   dir,\n   245→+\t\tPrompt:       \"do something\",\n   246→+\t\tTitle:        \"Add dark mode toggle\",\n   247→+\t})\n   248→+\trequire.NoError(t, err)\n   249→+\tassert.NotEmpty(t, resp.RunId)\n   250→+\n   251→+\t// Poll until the background goroutine finishes\n   252→+\tdeadline := time.Now().Add(5 * time.Second)\n   253→+\tvar status *pb.GetStatusResponse\n   254→+\tfor time.Now().Before(deadline) {\n   255→+\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   256→+\t\trequire.NoError(t, err)\n   257→+\t\tif status.State == \"succeeded\" {\n   258→+\t\t\tbreak\n   259→+\t\t}\n   260→+\t\ttime.Sleep(50 * time.Millisecond)\n   261→+\t}\n   262→+\n   263→+\trequire.NotNil(t, status)\n   264→+\tassert.Equal(t, \"Add dark mode toggle\", status.Title)\n   265→+}\n   266→+\n   267→+func TestServer_RunWorkflow_AgentGeneratesTitle(t *testing.T) {\n   268→+\tstore, err := sqlite.NewStore(\":memory:\")\n   269→+\trequire.NoError(t, err)\n   270→+\tdefer store.Close()\n   271→+\n   272→+\tdir := t.TempDir()\n   273→+\n   274→+\t// Mock agent outputs a run_title message (simulating agent-generated title)\n   275→+\tmsgs := []protocol.StatusMessage{\n   276→+\t\t{Type: protocol.MsgRunTitle, Message: \"Agent generated title\"},\n   277→+\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   278→+\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   279→+\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   280→+\t}\n   281→+\tscript := \"#!/bin/sh\\n\"\n   282→+\tfor _, msg := range msgs {\n   283→+\t\tdata, _ := json.Marshal(msg)\n   284→+\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   285→+\t}\n   286→+\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   287→+\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   288→+\n   289→+\trt := local.NewRuntime(\"sh\")\n   290→+\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   291→+\n   292→+\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   293→+\t\tWorkflowName: \"test\",\n   294→+\t\tProjectDir:   dir,\n   295→+\t})\n   296→+\trequire.NoError(t, err)\n   297→+\n   298→+\t// Poll until complete\n   299→+\tdeadline := time.Now().Add(5 * time.Second)\n   300→+\tvar status *pb.GetStatusResponse\n   301→+\tfor time.Now().Before(deadline) {\n   302→+\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   303→+\t\trequire.NoError(t, err)\n   304→+\t\tif status.State == \"succeeded\" {\n   305→+\t\t\tbreak\n   306→+\t\t}\n   307→+\t\ttime.Sleep(50 * time.Millisecond)\n   308→+\t}\n   309→+\n   310→+\trequire.NotNil(t, status)\n   311→+\tassert.Equal(t, \"Agent generated title\", status.Title)\n   312→+}\n   313→+\n   314→+func TestServer_RunWorkflow_ExplicitTitleNotOverriddenByAgent(t *testing.T) {\n   315→+\tstore, err := sqlite.NewStore(\":memory:\")\n   316→+\trequire.NoError(t, err)\n   317→+\tdefer store.Close()\n   318→+\n   319→+\tdir := t.TempDir()\n   320→+\n   321→+\t// Mock agent also outputs a run_title message, but explicit title should win\n   322→+\tmsgs := []protocol.StatusMessage{\n   323→+\t\t{Type: protocol.MsgRunTitle, Message: \"Agent title\"},\n   324→+\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   325→+\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   326→+\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   327→+\t}\n   328→+\tscript := \"#!/bin/sh\\n\"\n   329→+\tfor _, msg := range msgs {\n   330→+\t\tdata, _ := json.Marshal(msg)\n   331→+\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   332→+\t}\n   333→+\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   334→+\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   335→+\n   336→+\trt := local.NewRuntime(\"sh\")\n   337→+\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   338→+\n   339→+\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   340→+\t\tWorkflowName: \"test\",\n   341→+\t\tProjectDir:   dir,\n   342→+\t\tTitle:        \"Explicit user title\",\n   343→+\t})\n   344→+\trequire.NoError(t, err)\n   345→+\n   346→+\t// Poll until complete\n   347→+\tdeadline := time.Now().Add(5 * time.Second)\n   348→+\tvar status *pb.GetStatusResponse\n   349→+\tfor time.Now().Before(deadline) {\n   350→+\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   351→+\t\trequire.NoError(t, err)\n   352→+\t\tif status.State == \"succeeded\" {\n   353→+\t\t\tbreak\n   354→+\t\t}\n   355→+\t\ttime.Sleep(50 * time.Millisecond)\n   356→+\t}\n   357→+\n   358→+\trequire.NotNil(t, status)\n   359→+\tassert.Equal(t, \"Explicit user title\", status.Title, \"explicit title should not be overridden by agent\")\n   360→+}\n   361→+\n   362→+func TestServer_ListRuns_IncludesTitle(t *testing.T) {\n   363→+\tstore, err := sqlite.NewStore(\":memory:\")\n   364→+\trequire.NoError(t, err)\n   365→+\tdefer store.Close()\n   366→+\n   367→+\tctx := context.Background()\n   368→+\trun := domain.NewRun(\"title-list-1\", \"develop\")\n   369→+\trun.Start()\n   370→+\trun.Title = \"Fix the login bug\"\n   371→+\trequire.NoError(t, store.CreateRun(ctx, run))\n   372→+\n   373→+\tsrv := server.NewClocheServer(store, nil)\n   374→+\tresp, err := srv.ListRuns(ctx, &pb.ListRunsRequest{All: true})\n   375→+\trequire.NoError(t, err)\n   376→+\trequire.Len(t, resp.Runs, 1)\n   377→+\tassert.Equal(t, \"Fix the login bug\", resp.Runs[0].Title)\n   378→+}\n   379→+\n   380→ func TestServer_RunWorkflow_CapturesStepMetadata(t *testing.T) {\n   381→ \tstore, err := sqlite.NewStore(\":memory:\")\n   382→ \trequire.NoError(t, err)\n   383→diff --git a/internal/adapters/sqlite/store.go b/internal/adapters/sqlite/store.go\n   384→index 9a9c986..bb32aff 100644\n   385→--- a/internal/adapters/sqlite/store.go\n   386→+++ b/internal/adapters/sqlite/store.go\n   387→@@ -79,6 +79,7 @@ func migrate(db *sql.DB) error {\n   388→ \t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n   389→ \t\t`ALTER TABLE