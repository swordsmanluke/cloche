               }\n   634→                 var html = '';\n   635→@@ -80,8 +82,11 @@\n   636→                     var err = r.error_message || '';\n   637→                     if (err.length > 80) err = err.substring(0, 80) + '...';\n   638→                     var proj = r.project_label || '';\n   639→+                    var title = r.title || '';\n   640→+                    if (title.length > 50) title = title.substring(0, 47) + '...';\n   641→                     html += '<tr>' +\n   642→                         '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n   643→+                        '<td>' + escapeHtml(title) + '</td>' +\n   644→                         '<td>' + escapeHtml(proj) + '</td>' +\n   645→                         '<td>' + r.workflow_name + '</td>' +\n   646→                         '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n   647→diff --git a/internal/agent/runner.go b/internal/agent/runner.go\n   648→index f305f13..e98c93e 100644\n   649→--- a/internal/agent/runner.go\n   650→+++ b/internal/agent/runner.go\n   651→@@ -81,6 +81,12 @@ func (r *Runner) Run(ctx context.Context) error {\n   652→ \teng := engine.New(executor)\n   653→ \teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n   654→ \n   655→+\t// Generate a run title from the prompt if one was not provided by the caller.\n   656→+\t// The daemon sets title from --title; if empty, the agent extracts from prompt.\n   657→+\tif title := extractTitle(r.cfg.WorkDir, r.cfg.RunID); title != \"\" {\n   658→+\t\tstatusWriter.RunTitle(title)\n   659→+\t}\n   660→+\n   661→ \tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n   662→ \n   663→ \trun, runErr := eng.Run(ctx, wf)\n   664→@@ -174,3 +180,44 @@ func (s *statusReporter) OnStepComplete(_ *domain.Run, step *domain.Step, result\n   665→ }\n   666→ \n   667→ func (s *statusReporter) OnRunComplete(_ *domain.Run) {}\n   668→+\n   669→+// extractTitle tries to derive a one-line summary from the run's prompt content.\n   670→+// It reads the per-run prompt.txt file (written by the daemon before container start),\n   671→+// then returns the first non-empty line, truncated to 100 characters.\n   672→+func extractTitle(workDir string, runID string) string {\n   673→+\t// Try the per-run prompt file\n   674→+\tpromptPath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   675→+\tif _, err := os.Stat(promptPath); err != nil {\n   676→+\t\t// Fall back to legacy path\n   677→+\t\tpromptPath = filepath.Join(workDir, \".cloche\", \"prompt.txt\")\n   678→+\t}\n   679→+\tdata, err := os.ReadFile(promptPath)\n   680→+\tif err != nil || len(data) == 0 {\n   681→+\t\treturn \"\"\n   682→+\t}\n   683→+\n   684→+\ttext := strings.TrimSpace(string(data))\n   685→+\tif text == \"\" {\n   686→+\t\treturn \"\"\n   687→+\t}\n   688→+\n   689→+\t// Take first non-empty line as the title\n   690→+\tfor _, line := range strings.Split(text, \"\\n\") {\n   691→+\t\tline = strings.TrimSpace(line)\n   692→+\t\t// Skip markdown headers, comment markers, and blank lines\n   693→+\t\tif line == \"\" || line == \"---\" || line == \"```\" {\n   694→+\t\t\tcontinue\n   695→+\t\t}\n   696→+\t\t// Strip leading markdown header markers\n   697→+\t\tline = strings.TrimLeft(line, \"# \")\n   698→+\t\tline = strings.TrimSpace(line)\n   699→+\t\tif line == \"\" {\n   700→+\t\t\tcontinue\n   701→+\t\t}\n   702→+\t\tif len(line) > 100 {\n   703→+\t\t\tline = line[:97] + \"...\"\n   704→+\t\t}\n   705→+\t\treturn line\n   706→+\t}\n   707→+\treturn \"\"\n   708→+}\n   709→diff --git a/internal/agent/runner_test.go b/internal/agent/runner_test.go\n   710→index c0b92b7..55dfe98 100644\n   711→--- a/internal/agent/runner_test.go\n   712→+++ b/internal/agent/runner_test.go\n   713→@@ -496,6 +496,94 @@ func TestRunner_UnifiedLogMixedSteps(t *testing.T) {\n   714→ \tassert.NoError(t, err, \"llm-implement.log should exist\")\n   715→ }\n   716→ \n   717→+func TestRunner_ExtractsTitle(t *testing.T) {\n   718→+\tdir := t.TempDir()\n   719→+\n   720→+\t// Write user prompt under run ID\n   721→+\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"title-run\"), 0755))\n   722→+\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"title-run\", \"prompt.txt\"), []byte(\"Add dark mode toggle to the settings page\"), 0644))\n   723→+\n   724→+\tworkflowContent := `workflow \"title-test\" {\n   725→+  step build {\n   726→+    run = \"echo building\"\n   727→+    results = [success, fail]\n   728→+  }\n   729→+\n   730→+  build:success -> done\n   731→+  build:fail -> abort\n   732→+}`\n   733→+\tworkflowPath := filepath.Join(dir, \"title.cloche\")\n   734→+\trequire.NoError(t, os.WriteFile(workflowPath, []byte(workflowContent), 0644))\n   735→+\n   736→+\tvar statusBuf bytes.Buffer\n   737→+\trunner := agent.NewRunner(agent.RunnerConfig{\n   738→+\t\tWorkflowPath: workflowPath,\n   739→+\t\tWorkDir:      dir,\n   740→+\t\tStatusOutput: &statusBuf,\n   741→+\t\tRunID:        \"title-run\",\n   742→+\t})\n   743→+\n   744→+\terr := runner.Run(context.Background())\n   745→+\trequire.NoError(t, err)\n   746→+\n   747→+\tmsgs, err := protocol.ParseStatusStream(statusBuf.Bytes())\n   748→+\trequire.NoError(t, err)\n   749→+\n   750→+\t// Find the run_title message\n   751→+\tvar foundTitle bool\n   752→+\tfor _, msg := range msgs {\n   753→+\t\tif msg.Type == protocol.MsgRunTitle {\n   754→+\t\t\tfoundTitle = true\n   755→+\t\t\tassert.Equal(t, \"Add dark mode toggle to the settings page\", msg.Message)\n   756→+\t\t\tbreak\n   757→+\t\t}\n   758→+\t}\n   759→+\tassert.True(t, foundTitle, \"should have run_title message extracted from prompt\")\n   760→+}\n   761→+\n   762→+func TestRunner_TitleTruncation(t *testing.T) {\n   763→+\tdir := t.TempDir()\n   764→+\n   765→+\t// Write a very long prompt\n   766→+\tlongLine := strings.Repeat(\"x\", 200)\n   767→+\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"long-run\"), 0755))\n   768→+\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"long-run\", \"prompt.txt\"), []byte(longLine), 0644))\n   769→+\n   770→+\tworkflowContent := `workflow \"truncate-test\" {\n   771→+  step build {\n   772→+    run = \"echo building\"\n   773→+    results = [success, fail]\n   774→+  }\n   775→+\n   776→+  build:success -> done\n   777→+  build:fail -> abort\n   778→+}`\n   779→+\tworkflowPath := filepath.Join(dir, \"truncate.cloche\")\n   780→+\trequire.NoError(t, os.WriteFile(workflowPath, []byte(workflowContent), 0644))\n   781→+\n   782→+\tvar statusBuf bytes.Buffer\n   783→+\trunner := agent.NewRunner(agent.RunnerConfig{\n   784→+\t\tWorkflowPath: workflowPath,\n   785→+\t\tWorkDir:      dir,\n   786→+\t\tStatusOutput: &statusBuf,\n   787→+\t\tRunID:        \"long-run\",\n   788→+\t})\n   789→+\n   790→+\terr := runner.Run(context.Background())\n   791→+\trequire.NoError(t, err)\n   792→+\n   793→+\tmsgs, err := protocol.ParseStatusStream(statusBuf.Bytes())\n   794→+\trequire.NoError(t, err)\n   795→+\n   796→+\tfor _, msg := range msgs {\n   797→+\t\tif msg.Type == protocol.MsgRunTitle {\n   798→+\t\t\tassert.LessOrEqual(t, len(msg.Message), 100, \"title should be truncated to 100 chars\")\n   799→+\t\t\tassert.True(t, strings.HasSuffix(msg.Message, \"...\"), \"truncated title should end with ...\")\n   800→+\t\t\tbreak\n   801→+\t\t}\n   802→+\t}\n   803→+}\n   804→+\n   805→ func TestRunner_ExecutesWorkflowFile(t *testing.T) {\n   806→ \tdir := t.TempDir()\n   807→ \tworkflowContent := `workflow \"simple-build\" {\n   808→diff --git a/internal/domain/run.go b/internal/domain/run.go\n   809→index 0674549..7902bf9 100644\n   810→--- a/internal/domain/run.go\n   811→+++ b/internal/domain/run.go\n   812→@@ -41,6 +41,7 @@ type Run struct {\n   813→ \tContainerID    string\n   814→ \tBaseSHA        string // Git HEAD at run start, for result branch creation\n   815→ \tContainerKept  bool   // true when the container was retained after run completion\n   816→+\tTitle          string // One-line summary of the work being done\n   817→ }\n   818→ \n   819→ func NewRun(id, workflowName string) *Run {\n   820→diff --git a/internal/domain/run_test.go b/internal/domain/run_test.go\n   821→index 8a12d4c..fe39f6c 100644\n   822→--- a/internal/domain/run_test.go\n   823→+++ b/internal/domain/run_test.go\n   824→@@ -36,6 +36,12 @@ func TestRunProjectDir(t *testing.T) {\n   825→ \tassert.Equal(t, \"/home/user/project\", r.ProjectDir)\n   826→ }\n   827→ \n   828→+func TestRunTitle(t *testing.T) {\n   829→+\tr := domain.NewRun(\"test-1\", \"develop\")\n   830→+\tr.Title = \"Add dark mode toggle\"\n   831→+\tassert.Equal(t, \"Add dark mode toggle\", r.Title)\n   832→+}\n   833→+\n   834→ func TestStepExecutionFields(t *testing.T) {\n   835→ \texec := &domain.StepExecution{\n   836→ \t\tStepName: \"implement\",\n   837→diff --git a/internal/protocol/status.go b/internal/protocol/status.go\n   838→index fbc499e..b7358e8 100644\n   839→--- a/internal/protocol/status.go\n   840→+++ b/internal/protocol/status.go\n   841→@@ -14,6 +14,7 @@ const (\n   842→ \tMsgStepStarted  MessageType = \"step_started\"\n   843→ \tMsgStepCompleted MessageType = \"step_completed\"\n   844→ \tMsgRunCompleted  MessageType = \"run_completed\"\n   845→+\tMsgRunTitle      MessageType = \"run_title\"\n   846→ \tMsgLog           MessageType = \"log\"\n   847→ \tMsgError         MessageType = \"error\"\n   848→ )\n   849→@@ -47,6 +48,10 @@ func (s *StatusWriter) RunCompleted(result string) {\n   850→ \ts.write(StatusMessage{Type: MsgRunCompleted, Result: result})\n   851→ }\n   852→ \n   853→+func (s *StatusWriter) RunTitle(title string) {\n   854→+\ts.write(StatusMessage{Type: MsgRunTitle, Message: title})\n   855→+}\n   856→+\n   857→ func (s *StatusWriter) Log(stepName, message string) {\n   858→ \ts.write(StatusMessage{Type: MsgLog, StepName: stepName, Message: message})\n   859→ }\n   860→diff --git a/internal/protocol/status_test.go b/internal/protocol/status_test.go\n   861→index 5bde460..933f1a3 100644\n   862→--- a/internal/protocol/status_test.go\n   863→+++ b/internal/protocol/status_test.go\n   864→@@ -31,6 +31,20 @@ func TestStatusWriter_WritesJSONLines(t *testing.T) {\n   865→ \tassert.Equal(t, \"succeeded\", msgs[2].Result)\n   866→ }\n   867→ \n   868→+func TestStatusWriter_RunTitle(t *testing.T) {\n   869→+\tvar buf bytes.Buffer\n   870→+\tw := protocol.NewStatusWriter(&buf)\n   871→+\n   872→+\tw.RunTitle(\"Add dark mode toggle\")\n   873→+\n   874→+\tmsgs, err := protocol.ParseStatusStream(buf.Bytes())\n   875→+\trequire.NoError(t, err)\n   876→+\trequire.Len(t, msgs, 1)\n   877→+\n   878→+\tassert.Equal(t, protocol.MsgRunTitle, msgs[0].Type)\n   879→+\tassert.Equal(t, \"Add dark mode toggle\", msgs[0].Message)\n   880→+}\n   881→+\n   882→ func TestStatusWriter_LogMessage(t *testing.T) {\n   883→ \tvar buf bytes.Buffer\n   884→ \tw := protocol.NewStatusWriter(&buf)\n   885→"}]},"parent_tool_use_id":"toolu_01E9J2aeGH9x54inw4dTVi64","session_id":"843502bc-3d5c-43fd-9244-ee919bbc5a7b","uuid":"6efd3f08-8665-481c-a0ce-0855b828418b"}
