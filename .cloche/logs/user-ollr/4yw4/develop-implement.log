{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019TUZMsHvqy4bSoR22WD7mY","type":"tool_result","content":"     1→package sqlite_test\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"path/filepath\"\n     7→\t\"sync\"\n     8→\t\"testing\"\n     9→\t\"time\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14→\t\"github.com/stretchr/testify/assert\"\n    15→\t\"github.com/stretchr/testify/require\"\n    16→)\n    17→\n    18→func TestRunStore_CreateAndGet(t *testing.T) {\n    19→\tstore, err := sqlite.NewStore(\":memory:\")\n    20→\trequire.NoError(t, err)\n    21→\tdefer store.Close()\n    22→\n    23→\tctx := context.Background()\n    24→\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n    25→\trun.Start()\n    26→\n    27→\terr = store.CreateRun(ctx, run)\n    28→\trequire.NoError(t, err)\n    29→\n    30→\tgot, err := store.GetRun(ctx, \"run-1\")\n    31→\trequire.NoError(t, err)\n    32→\tassert.Equal(t, \"run-1\", got.ID)\n    33→\tassert.Equal(t, \"test-workflow\", got.WorkflowName)\n    34→\tassert.Equal(t, domain.RunStateRunning, got.State)\n    35→}\n    36→\n    37→func TestRunStore_Update(t *testing.T) {\n    38→\tstore, err := sqlite.NewStore(\":memory:\")\n    39→\trequire.NoError(t, err)\n    40→\tdefer store.Close()\n    41→\n    42→\tctx := context.Background()\n    43→\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n    44→\trun.Start()\n    45→\trequire.NoError(t, store.CreateRun(ctx, run))\n    46→\n    47→\trun.Complete(domain.RunStateSucceeded)\n    48→\trequire.NoError(t, store.UpdateRun(ctx, run))\n    49→\n    50→\tgot, err := store.GetRun(ctx, \"run-1\")\n    51→\trequire.NoError(t, err)\n    52→\tassert.Equal(t, domain.RunStateSucceeded, got.State)\n    53→}\n    54→\n    55→func TestRunStore_List(t *testing.T) {\n    56→\tstore, err := sqlite.NewStore(\":memory:\")\n    57→\trequire.NoError(t, err)\n    58→\tdefer store.Close()\n    59→\n    60→\tctx := context.Background()\n    61→\trun1 := domain.NewRun(\"run-1\", \"wf-a\")\n    62→\trun2 := domain.NewRun(\"run-2\", \"wf-b\")\n    63→\trequire.NoError(t, store.CreateRun(ctx, run1))\n    64→\trequire.NoError(t, store.CreateRun(ctx, run2))\n    65→\n    66→\truns, err := store.ListRuns(ctx, time.Time{})\n    67→\trequire.NoError(t, err)\n    68→\tassert.Len(t, runs, 2)\n    69→}\n    70→\n    71→func TestRunStore_GetNotFound(t *testing.T) {\n    72→\tstore, err := sqlite.NewStore(\":memory:\")\n    73→\trequire.NoError(t, err)\n    74→\tdefer store.Close()\n    75→\n    76→\t_, err = store.GetRun(context.Background(), \"nonexistent\")\n    77→\tassert.Error(t, err)\n    78→}\n    79→\n    80→func TestStore_DeleteRun(t *testing.T) {\n    81→\tstore, err := sqlite.NewStore(\":memory:\")\n    82→\trequire.NoError(t, err)\n    83→\tdefer store.Close()\n    84→\n    85→\tctx := context.Background()\n    86→\n    87→\t// Create a run and save a capture for it\n    88→\trun := domain.NewRun(\"del-1\", \"test-workflow\")\n    89→\trun.Start()\n    90→\trequire.NoError(t, store.CreateRun(ctx, run))\n    91→\trequire.NoError(t, store.SaveCapture(ctx, \"del-1\", &domain.StepExecution{\n    92→\t\tStepName:  \"step1\",\n    93→\t\tStartedAt: time.Now(),\n    94→\t}))\n    95→\n    96→\t// Delete the run\n    97→\terr = store.DeleteRun(ctx, \"del-1\")\n    98→\trequire.NoError(t, err)\n    99→\n   100→\t// Verify run is gone\n   101→\t_, err = store.GetRun(ctx, \"del-1\")\n   102→\tassert.Error(t, err)\n   103→\n   104→\t// Verify captures are gone\n   105→\tcaps, err := store.GetCaptures(ctx, \"del-1\")\n   106→\trequire.NoError(t, err)\n   107→\tassert.Empty(t, caps)\n   108→}\n   109→\n   110→func TestRunProjectDir(t *testing.T) {\n   111→\tstore, err := sqlite.NewStore(\":memory:\")\n   112→\trequire.NoError(t, err)\n   113→\tdefer store.Close()\n   114→\n   115→\tctx := context.Background()\n   116→\trun := domain.NewRun(\"test-1\", \"develop\")\n   117→\trun.ProjectDir = \"/home/user/project\"\n   118→\trun.Start()\n   119→\n   120→\terr = store.CreateRun(ctx, run)\n   121→\trequire.NoError(t, err)\n   122→\n   123→\tgot, err := store.GetRun(ctx, \"test-1\")\n   124→\trequire.NoError(t, err)\n   125→\tassert.Equal(t, \"/home/user/project\", got.ProjectDir)\n   126→}\n   127→\n   128→func TestCaptureStepMetadata(t *testing.T) {\n   129→\tstore, err := sqlite.NewStore(\":memory:\")\n   130→\trequire.NoError(t, err)\n   131→\tdefer store.Close()\n   132→\n   133→\tctx := context.Background()\n   134→\trun := domain.NewRun(\"test-1\", \"develop\")\n   135→\trun.Start()\n   136→\tstore.CreateRun(ctx, run)\n   137→\n   138→\texec := &domain.StepExecution{\n   139→\t\tStepName:  \"implement\",\n   140→\t\tResult:    \"success\",\n   141→\t\tStartedAt: time.Now(),\n   142→\t}\n   143→\terr = store.SaveCapture(ctx, \"test-1\", exec)\n   144→\trequire.NoError(t, err)\n   145→\n   146→\tcaps, err := store.GetCaptures(ctx, \"test-1\")\n   147→\trequire.NoError(t, err)\n   148→\trequire.Len(t, caps, 1)\n   149→\tassert.Equal(t, \"implement\", caps[0].StepName)\n   150→\tassert.Equal(t, \"success\", caps[0].Result)\n   151→}\n   152→\n   153→func TestListRunsSince(t *testing.T) {\n   154→\tstore, err := sqlite.NewStore(\":memory:\")\n   155→\trequire.NoError(t, err)\n   156→\tdefer store.Close()\n   157→\n   158→\tctx := context.Background()\n   159→\tfor i, id := range []string{\"run-1\", \"run-2\", \"run-3\"} {\n   160→\t\tr := domain.NewRun(id, \"develop\")\n   161→\t\tr.ProjectDir = \"/project\"\n   162→\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n   163→\t\tr.State = domain.RunStateRunning\n   164→\t\trequire.NoError(t, store.CreateRun(ctx, r))\n   165→\t}\n   166→\n   167→\truns, err := store.ListRunsSince(ctx, \"/project\", \"develop\", \"run-1\")\n   168→\trequire.NoError(t, err)\n   169→\tassert.Len(t, runs, 2)\n   170→\tassert.Equal(t, \"run-2\", runs[0].ID)\n   171→\tassert.Equal(t, \"run-3\", runs[1].ID)\n   172→}\n   173→\n   174→func TestListRunsSinceEmpty(t *testing.T) {\n   175→\tstore, err := sqlite.NewStore(\":memory:\")\n   176→\trequire.NoError(t, err)\n   177→\tdefer store.Close()\n   178→\n   179→\tctx := context.Background()\n   180→\tfor i, id := range []string{\"run-1\", \"run-2\"} {\n   181→\t\tr := domain.NewRun(id, \"develop\")\n   182→\t\tr.ProjectDir = \"/project\"\n   183→\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n   184→\t\tr.State = domain.RunStateRunning\n   185→\t\trequire.NoError(t, store.CreateRun(ctx, r))\n   186→\t}\n   187→\n   188→\t// Empty sinceRunID returns all\n   189→\truns, err := store.ListRunsSince(ctx, \"/project\", \"develop\", \"\")\n   190→\trequire.NoError(t, err)\n   191→\tassert.Len(t, runs, 2)\n   192→}\n   193→\n   194→func TestGetLastEvolution(t *testing.T) {\n   195→\tstore, err := sqlite.NewStore(\":memory:\")\n   196→\trequire.NoError(t, err)\n   197→\tdefer store.Close()\n   198→\n   199→\tctx := context.Background()\n   200→\n   201→\t// No evolution yet\n   202→\tentry, err := store.GetLastEvolution(ctx, \"/project\", \"develop\")\n   203→\trequire.NoError(t, err)\n   204→\tassert.Nil(t, entry)\n   205→\n   206→\t// Save one\n   207→\trequire.NoError(t, store.SaveEvolution(ctx, &ports.EvolutionEntry{\n   208→\t\tID:           \"evo-1\",\n   209→\t\tProjectDir:   \"/project\",\n   210→\t\tWorkflowName: \"develop\",\n   211→\t\tTriggerRunID: \"run-1\",\n   212→\t\tCreatedAt:    time.Now(),\n   213→\t\tChangesJSON:  \"[]\",\n   214→\t}))\n   215→\n   216→\tentry, err = store.GetLastEvolution(ctx, \"/project\", \"develop\")\n   217→\trequire.NoError(t, err)\n   218→\trequire.NotNil(t, entry)\n   219→\tassert.Equal(t, \"evo-1\", entry.ID)\n   220→}\n   221→\n   222→func TestRunContainerID(t *testing.T) {\n   223→\tstore, err := sqlite.NewStore(\":memory:\")\n   224→\trequire.NoError(t, err)\n   225→\tdefer store.Close()\n   226→\n   227→\tctx := context.Background()\n   228→\trun := domain.NewRun(\"cid-1\", \"develop\")\n   229→\trun.Start()\n   230→\trun.ContainerID = \"4647e7e70e3fabc123def456\"\n   231→\n   232→\terr = store.CreateRun(ctx, run)\n   233→\trequire.NoError(t, err)\n   234→\n   235→\tgot, err := store.GetRun(ctx, \"cid-1\")\n   236→\trequire.NoError(t, err)\n   237→\tassert.Equal(t, \"4647e7e70e3fabc123def456\", got.ContainerID)\n   238→\n   239→\t// Test update preserves container ID\n   240→\tgot.ContainerID = \"new-container-id\"\n   241→\trequire.NoError(t, store.UpdateRun(ctx, got))\n   242→\n   243→\tgot2, err := store.GetRun(ctx, \"cid-1\")\n   244→\trequire.NoError(t, err)\n   245→\tassert.Equal(t, \"new-container-id\", got2.ContainerID)\n   246→\n   247→\t// Test ListRuns includes container ID\n   248→\truns, err := store.ListRuns(ctx, time.Time{})\n   249→\trequire.NoError(t, err)\n   250→\trequire.Len(t, runs, 1)\n   251→\tassert.Equal(t, \"new-container-id\", runs[0].ContainerID)\n   252→}\n   253→\n   254→func TestRunContainerID_BackwardCompat(t *testing.T) {\n   255→\tstore, err := sqlite.NewStore(\":memory:\")\n   256→\trequire.NoError(t, err)\n   257→\tdefer store.Close()\n   258→\n   259→\tctx := context.Background()\n   260→\t// Create a run without setting ContainerID — simulates pre-migration rows\n   261→\trun := domain.NewRun(\"old-1\", \"develop\")\n   262→\trun.Start()\n   263→\trequire.NoError(t, store.CreateRun(ctx, run))\n   264→\n   265→\tgot, err := store.GetRun(ctx, \"old-1\")\n   266→\trequire.NoError(t, err)\n   267→\tassert.Equal(t, \"\", got.ContainerID)\n   268→}\n   269→\n   270→func TestRunErrorMessage(t *testing.T) {\n   271→\tstore, err := sqlite.NewStore(\":memory:\")\n   272→\trequire.NoError(t, err)\n   273→\tdefer store.Close()\n   274→\n   275→\tctx := context.Background()\n   276→\trun := domain.NewRun(\"err-1\", \"develop\")\n   277→\trun.Start()\n   278→\trun.Fail(\"failed to start container: image not found\")\n   279→\n   280→\terr = store.CreateRun(ctx, run)\n   281→\trequire.NoError(t, err)\n   282→\n   283→\tgot, err := store.GetRun(ctx, \"err-1\")\n   284→\trequire.NoError(t, err)\n   285→\tassert.Equal(t, domain.RunStateFailed, got.State)\n   286→\tassert.Equal(t, \"failed to start container: image not found\", got.ErrorMessage)\n   287→\n   288→\t// Test update preserves error message\n   289→\tgot.ErrorMessage = \"updated error\"\n   290→\trequire.NoError(t, store.UpdateRun(ctx, got))\n   291→\n   292→\tgot2, err := store.GetRun(ctx, \"err-1\")\n   293→\trequire.NoError(t, err)\n   294→\tassert.Equal(t, \"updated error\", got2.ErrorMessage)\n   295→}\n   296→\n   297→func TestRunErrorMessageInList(t *testing.T) {\n   298→\tstore, err := sqlite.NewStore(\":memory:\")\n   299→\trequire.NoError(t, err)\n   300→\tdefer store.Close()\n   301→\n   302→\tctx := context.Background()\n   303→\trun := domain.NewRun(\"err-list-1\", \"develop\")\n   304→\trun.Start()\n   305→\trun.Fail(\"container crashed\")\n   306→\trequire.NoError(t, store.CreateRun(ctx, run))\n   307→\n   308→\truns, err := store.ListRuns(ctx, time.Time{})\n   309→\trequire.NoError(t, err)\n   310→\trequire.Len(t, runs, 1)\n   311→\tassert.Equal(t, \"container crashed\", runs[0].ErrorMessage)\n   312→}\n   313→\n   314→func TestStore_ConcurrentWrites(t *testing.T) {\n   315→\tdbPath := filepath.Join(t.TempDir(), \"concurrent.db\")\n   316→\tstore, err := sqlite.NewStore(dbPath)\n   317→\trequire.NoError(t, err)\n   318→\tdefer store.Close()\n   319→\n   320→\tconst n = 10\n   321→\tctx := context.Background()\n   322→\terrs := make([]error, n)\n   323→\n   324→\tvar wg sync.WaitGroup\n   325→\twg.Add(n)\n   326→\tfor i := 0; i < n; i++ {\n   327→\t\tgo func(i int) {\n   328→\t\t\tdefer wg.Done()\n   329→\t\t\tid := fmt.Sprintf(\"run-%d\", i)\n   330→\t\t\trun := domain.NewRun(id, \"test-workflow\")\n   331→\t\t\trun.Start()\n   332→\t\t\tif err := store.CreateRun(ctx, run); err != nil {\n   333→\t\t\t\terrs[i] = err\n   334→\t\t\t\treturn\n   335→\t\t\t}\n   336→\t\t\terrs[i] = store.SaveCapture(ctx, id, &domain.StepExecution{\n   337→\t\t\t\tStepName:  fmt.Sprintf(\"step-%d\", i),\n   338→\t\t\t\tStartedAt: time.Now(),\n   339→\t\t\t})\n   340→\t\t}(i)\n   341→\t}\n   342→\twg.Wait()\n   343→\n   344→\tfor i, err := range errs {\n   345→\t\tassert.NoError(t, err, \"goroutine %d failed\", i)\n   346→\t}\n   347→\n   348→\truns, err := store.ListRuns(ctx, time.Time{})\n   349→\trequire.NoError(t, err)\n   350→\tassert.Len(t, runs, n)\n   351→}\n   352→\n   353→func TestListRunsByProject(t *testing.T) {\n   354→\tstore, err := sqlite.NewStore(\":memory:\")\n   355→\trequire.NoError(t, err)\n   356→\tdefer store.Close()\n   357→\n   358→\tctx := context.Background()\n   359→\n   360→\t// Create runs for two different projects\n   361→\tfor i, id := range []string{\"proj-a-1\", \"proj-a-2\"} {\n   362→\t\tr := domain.NewRun(id, \"develop\")\n   363→\t\tr.ProjectDir = \"/home/user/project-a\"\n   364→\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n   365→\t\tr.State = domain.RunStateRunning\n   366→\t\trequire.NoError(t, store.CreateRun(ctx, r))\n   367→\t}\n   368→\trB := domain.NewRun(\"proj-b-1\", \"develop\")\n   369→\trB.ProjectDir = \"/home/user/project-b\"\n   370→\trB.StartedAt = time.Now()\n   371→\trB.State = domain.RunStateRunning\n   372→\trequire.NoError(t, store.CreateRun(ctx, rB))\n   373→\n   374→\t// Filter by project-a\n   375→\truns, err := store.ListRunsByProject(ctx, \"/home/user/project-a\", time.Time{})\n   376→\trequire.NoError(t, err)\n   377→\tassert.Len(t, runs, 2)\n   378→\tfor _, r := range runs {\n   379→\t\tassert.Equal(t, \"/home/user/project-a\", r.ProjectDir)\n   380→\t}\n   381→\n   382→\t// Filter by project-b\n   383→\truns, err = store.ListRunsByProject(ctx, \"/home/user/project-b\", time.Time{})\n   384→\trequire.NoError(t, err)\n   385→\tassert.Len(t, runs, 1)\n   386→\tassert.Equal(t, \"proj-b-1\", runs[0].ID)\n   387→\n   388→\t// Filter by nonexistent project\n   389→\truns, err = store.ListRunsByProject(ctx, \"/nonexistent\", time.Time{})\n   390→\trequire.NoError(t, err)\n   391→\tassert.Empty(t, runs)\n   392→}\n   393→\n   394→func TestListProjects(t *testing.T) {\n   395→\tstore, err := sqlite.NewStore(\":memory:\")\n   396→\trequire.NoError(t, err)\n   397→\tdefer store.Close()\n   398→\n   399→\tctx := context.Background()\n   400→\n   401→\t// Empty store returns no projects\n   402→\tprojects, err := store.ListProjects(ctx)\n   403→\trequire.NoError(t, err)\n   404→\tassert.Empty(t, projects)\n   405→\n   406→\t// Create runs for different projects\n   407→\tfor _, tc := range []struct {\n   408→\t\tid, project string\n   409→\t}{\n   410→\t\t{\"r1\", \"/home/user/alpha\"},\n   411→\t\t{\"r2\", \"/home/user/alpha\"},\n   412→\t\t{\"r3\", \"/home/user/beta\"},\n   413→\t\t{\"r4\", \"\"},\n   414→\t} {\n   415→\t\tr := domain.NewRun(tc.id, \"develop\")\n   416→\t\tr.ProjectDir = tc.project\n   417→\t\tr.State = domain.RunStatePending\n   418→\t\trequire.NoError(t, store.CreateRun(ctx, r))\n   419→\t}\n   420→\n   421→\tprojects, err = store.ListProjects(ctx)\n   422→\trequire.NoError(t, err)\n   423→\tassert.Equal(t, []string{\"/home/user/alpha\", \"/home/user/beta\"}, projects)\n   424→}\n   425→\n   426→func TestRunContainerKept(t *testing.T) {\n   427→\tstore, err := sqlite.NewStore(\":memory:\")\n   428→\trequire.NoError(t, err)\n   429→\tdefer store.Close()\n   430→\n   431→\tctx := context.Background()\n   432→\n   433→\t// Create a run with ContainerKept = false (default)\n   434→\trun := domain.NewRun(\"kept-1\", \"develop\")\n   435→\trun.Start()\n   436→\trun.ContainerID = \"abc123\"\n   437→\trequire.NoError(t, store.CreateRun(ctx, run))\n   438→\n   439→\tgot, err := store.GetRun(ctx, \"kept-1\")\n   440→\trequire.NoError(t, err)\n   441→\tassert.False(t, got.ContainerKept)\n   442→\n   443→\t// Update to mark container as kept\n   444→\tgot.ContainerKept = true\n   445→\trequire.NoError(t, store.UpdateRun(ctx, got))\n   446→\n   447→\tgot2, err := store.GetRun(ctx, \"kept-1\")\n   448→\trequire.NoError(t, err)\n   449→\tassert.True(t, got2.ContainerKept)\n   450→\n   451→\t// Verify ListRuns includes ContainerKept\n   452→\truns, err := store.ListRuns(ctx, time.Time{})\n   453→\trequire.NoError(t, err)\n   454→\trequire.Len(t, runs, 1)\n   455→\tassert.True(t, runs[0].ContainerKept)\n   456→}\n   457→\n   458→func TestStore_FailStaleRuns(t *testing.T) {\n   459→\tstore, err := sqlite.NewStore(\":memory:\")\n   460→\trequire.NoError(t, err)\n   461→\tdefer store.Close()\n   462→\n   463→\tctx := context.Background()\n   464→\n   465→\t// Create runs in different states.\n   466→\tpending := domain.NewRun(\"pending-1\", \"wf\")\n   467→\trequire.NoError(t, store.CreateRun(ctx, pending))\n   468→\n   469→\trunning := domain.NewRun(\"running-1\", \"wf\")\n   470→\trunning.Start()\n   471→\trequire.NoError(t, store.CreateRun(ctx, running))\n   472→\n   473→\tsucceeded := domain.NewRun(\"succeeded-1\", \"wf\")\n   474→\tsucceeded.Start()\n   475→\tsucceeded.Complete(domain.RunStateSucceeded)\n   476→\trequire.NoError(t, store.CreateRun(ctx, succeeded))\n   477→\n   478→\tn, err := store.FailStaleRuns(ctx)\n   479→\trequire.NoError(t, err)\n   480→\tassert.Equal(t, int64(2), n) // both pending and running\n   481→\n   482→\tgot, err := store.GetRun(ctx, \"pending-1\")\n   483→\trequire.NoError(t, err)\n   484→\tassert.Equal(t, domain.RunStateFailed, got.State)\n   485→\tassert.False(t, got.CompletedAt.IsZero(), \"completed_at should be set\")\n   486→\tassert.Equal(t, \"daemon restarted while run was active\", got.ErrorMessage)\n   487→\n   488→\tgotRunning, err := store.GetRun(ctx, \"running-1\")\n   489→\trequire.NoError(t, err)\n   490→\tassert.Equal(t, domain.RunStateFailed, gotRunning.State)\n   491→\tassert.False(t, gotRunning.CompletedAt.IsZero(), \"completed_at should be set\")\n   492→\tassert.Equal(t, \"daemon restarted while run was active\", gotRunning.ErrorMessage)\n   493→\n   494→\t// Succeeded runs should be untouched.\n   495→\tgotSucceeded, err := store.GetRun(ctx, \"succeeded-1\")\n   496→\trequire.NoError(t, err)\n   497→\tassert.Equal(t, domain.RunStateSucceeded, gotSucceeded.State)\n   498→}\n   499→\n   500→func TestLogFiles_SaveAndGet(t *testing.T) {\n   501→\tstore, err := sqlite.NewStore(\":memory:\")\n   502→\trequire.NoError(t, err)\n   503→\tdefer store.Close()\n   504→\n   505→\tctx := context.Background()\n   506→\n   507→\t// Create a run first (foreign key)\n   508→\trun := domain.NewRun(\"log-run-1\", \"develop\")\n   509→\trun.Start()\n   510→\trequire.NoError(t, store.CreateRun(ctx, run))\n   511→\n   512→\tnow := time.Now().Truncate(time.Second)\n   513→\n   514→\t// Save log file entries\n   515→\tentries := []*ports.LogFileEntry{\n   516→\t\t{RunID: \"log-run-1\", FileType: \"full\", FilePath: \"/tmp/output/full.log\", FileSize: 1024, CreatedAt: now},\n   517→\t\t{RunID: \"log-run-1\", StepName: \"build\", FileType: \"script\", FilePath: \"/tmp/output/build.log\", FileSize: 512, CreatedAt: now},\n   518→\t\t{RunID: \"log-run-1\", StepName: \"build\", FileType: \"llm\", FilePath: \"/tmp/output/llm-build.log\", FileSize: 2048, CreatedAt: now},\n   519→\t\t{RunID: \"log-run-1\", StepName: \"test\", FileType: \"script\", FilePath: \"/tmp/output/test.log\", FileSize: 256, CreatedAt: now},\n   520→\t}\n   521→\tfor _, e := range entries {\n   522→\t\trequire.NoError(t, store.SaveLogFile(ctx, e))\n   523→\t}\n   524→\n   525→\t// GetLogFiles returns all entries for a run\n   526→\tall, err := store.GetLogFiles(ctx, \"log-run-1\")\n   527→\trequire.NoError(t, err)\n   528→\tassert.Len(t, all, 4)\n   529→\n   530→\t// GetLogFilesByStep returns entries for a specific step\n   531→\tbuildLogs, err := store.GetLogFilesByStep(ctx, \"log-run-1\", \"build\")\n   532→\trequire.NoError(t, err)\n   533→\tassert.Len(t, buildLogs, 2)\n   534→\tfor _, lf := range buildLogs {\n   535→\t\tassert.Equal(t, \"build\", lf.StepName)\n   536→\t}\n   537→\n   538→\t// GetLogFileByType returns entries of a specific type\n   539→\tllmLogs, err := store.GetLogFileByType(ctx, \"log-run-1\", \"llm\")\n   540→\trequire.NoError(t, err)\n   541→\tassert.Len(t, llmLogs, 1)\n   542→\tassert.Equal(t, \"llm\", llmLogs[0].FileType)\n   543→\tassert.Equal(t, \"build\", llmLogs[0].StepName)\n   544→\n   545→\t// GetLogFileByType for \"full\"\n   546→\tfullLogs, err := store.GetLogFileByType(ctx, \"log-run-1\", \"full\")\n   547→\trequire.NoError(t, err)\n   548→\tassert.Len(t, fullLogs, 1)\n   549→\tassert.Equal(t, \"full\", fullLogs[0].FileType)\n   550→\tassert.Equal(t, int64(1024), fullLogs[0].FileSize)\n   551→}\n   552→\n   553→func TestLogFiles_EmptyResults(t *testing.T) {\n   554→\tstore, err := sqlite.NewStore(\":memory:\")\n   555→\trequire.NoError(t, err)\n   556→\tdefer store.Close()\n   557→\n   558→\tctx := context.Background()\n   559→\n   560→\t// No entries yet\n   561→\tfiles, err := store.GetLogFiles(ctx, \"nonexistent\")\n   562→\trequire.NoError(t, err)\n   563→\tassert.Empty(t, files)\n   564→\n   565→\tfiles, err = store.GetLogFilesByStep(ctx, \"nonexistent\", \"build\")\n   566→\trequire.NoError(t, err)\n   567→\tassert.Empty(t, files)\n   568→\n   569→\tfiles, err = store.GetLogFileByType(ctx, \"nonexistent\", \"llm\")\n   570→\trequire.NoError(t, err)\n   571→\tassert.Empty(t, files)\n   572→}\n   573→"}]},"parent_tool_use_id":null,"session_id":"4396f712-f062-4883-ba52-ad58e85081ed","uuid":"f4ba7cab-c294-4864-b9f2-10c955af34df","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/sqlite/store_test.go","content":"package sqlite_test\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"path/filepath\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestRunStore_CreateAndGet(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n\trun.Start()\n\n\terr = store.CreateRun(ctx, run)\n\trequire.NoError(t, err)\n\n\tgot, err := store.GetRun(ctx, \"run-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"run-1\", got.ID)\n\tassert.Equal(t, \"test-workflow\", got.WorkflowName)\n\tassert.Equal(t, domain.RunStateRunning, got.State)\n}\n\nfunc TestRunStore_Update(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.UpdateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"run-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, got.State)\n}\n\nfunc TestRunStore_List(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun1 := domain.NewRun(\"run-1\", \"wf-a\")\n\trun2 := domain.NewRun(\"run-2\", \"wf-b\")\n\trequire.NoError(t, store.CreateRun(ctx, run1))\n\trequire.NoError(t, store.CreateRun(ctx, run2))\n\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, 2)\n}\n\nfunc TestRunStore_GetNotFound(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\t_, err = store.GetRun(context.Background(), \"nonexistent\")\n\tassert.Error(t, err)\n}\n\nfunc TestStore_DeleteRun(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run and save a capture for it\n\trun := domain.NewRun(\"del-1\", \"test-workflow\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\trequire.NoError(t, store.SaveCapture(ctx, \"del-1\", &domain.StepExecution{\n\t\tStepName:  \"step1\",\n\t\tStartedAt: time.Now(),\n\t}))\n\n\t// Delete the run\n\terr = store.DeleteRun(ctx, \"del-1\")\n\trequire.NoError(t, err)\n\n\t// Verify run is gone\n\t_, err = store.GetRun(ctx, \"del-1\")\n\tassert.Error(t, err)\n\n\t// Verify captures are gone\n\tcaps, err := store.GetCaptures(ctx, \"del-1\")\n\trequire.NoError(t, err)\n\tassert.Empty(t, caps)\n}\n\nfunc TestRunProjectDir(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"test-1\", \"develop\")\n\trun.ProjectDir = \"/home/user/project\"\n\trun.Start()\n\n\terr = store.CreateRun(ctx, run)\n\trequire.NoError(t, err)\n\n\tgot, err := store.GetRun(ctx, \"test-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"/home/user/project\", got.ProjectDir)\n}\n\nfunc TestCaptureStepMetadata(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"test-1\", \"develop\")\n\trun.Start()\n\tstore.CreateRun(ctx, run)\n\n\texec := &domain.StepExecution{\n\t\tStepName:  \"implement\",\n\t\tResult:    \"success\",\n\t\tStartedAt: time.Now(),\n\t}\n\terr = store.SaveCapture(ctx, \"test-1\", exec)\n\trequire.NoError(t, err)\n\n\tcaps, err := store.GetCaptures(ctx, \"test-1\")\n\trequire.NoError(t, err)\n\trequire.Len(t, caps, 1)\n\tassert.Equal(t, \"implement\", caps[0].StepName)\n\tassert.Equal(t, \"success\", caps[0].Result)\n}\n\nfunc TestListRunsSince(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\tfor i, id := range []string{\"run-1\", \"run-2\", \"run-3\"} {\n\t\tr := domain.NewRun(id, \"develop\")\n\t\tr.ProjectDir = \"/project\"\n\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n\t\tr.State = domain.RunStateRunning\n\t\trequire.NoError(t, store.CreateRun(ctx, r))\n\t}\n\n\truns, err := store.ListRunsSince(ctx, \"/project\", \"develop\", \"run-1\")\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, 2)\n\tassert.Equal(t, \"run-2\", runs[0].ID)\n\tassert.Equal(t, \"run-3\", runs[1].ID)\n}\n\nfunc TestListRunsSinceEmpty(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\tfor i, id := range []string{\"run-1\", \"run-2\"} {\n\t\tr := domain.NewRun(id, \"develop\")\n\t\tr.ProjectDir = \"/project\"\n\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n\t\tr.State = domain.RunStateRunning\n\t\trequire.NoError(t, store.CreateRun(ctx, r))\n\t}\n\n\t// Empty sinceRunID returns all\n\truns, err := store.ListRunsSince(ctx, \"/project\", \"develop\", \"\")\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, 2)\n}\n\nfunc TestGetLastEvolution(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// No evolution yet\n\tentry, err := store.GetLastEvolution(ctx, \"/project\", \"develop\")\n\trequire.NoError(t, err)\n\tassert.Nil(t, entry)\n\n\t// Save one\n\trequire.NoError(t, store.SaveEvolution(ctx, &ports.EvolutionEntry{\n\t\tID:           \"evo-1\",\n\t\tProjectDir:   \"/project\",\n\t\tWorkflowName: \"develop\",\n\t\tTriggerRunID: \"run-1\",\n\t\tCreatedAt:    time.Now(),\n\t\tChangesJSON:  \"[]\",\n\t}))\n\n\tentry, err = store.GetLastEvolution(ctx, \"/project\", \"develop\")\n\trequire.NoError(t, err)\n\trequire.NotNil(t, entry)\n\tassert.Equal(t, \"evo-1\", entry.ID)\n}\n\nfunc TestRunContainerID(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"cid-1\", \"develop\")\n\trun.Start()\n\trun.ContainerID = \"4647e7e70e3fabc123def456\"\n\n\terr = store.CreateRun(ctx, run)\n\trequire.NoError(t, err)\n\n\tgot, err := store.GetRun(ctx, \"cid-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"4647e7e70e3fabc123def456\", got.ContainerID)\n\n\t// Test update preserves container ID\n\tgot.ContainerID = \"new-container-id\"\n\trequire.NoError(t, store.UpdateRun(ctx, got))\n\n\tgot2, err := store.GetRun(ctx, \"cid-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"new-container-id\", got2.ContainerID)\n\n\t// Test ListRuns includes container ID\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, runs, 1)\n\tassert.Equal(t, \"new-container-id\", runs[0].ContainerID)\n}\n\nfunc TestRunContainerID_BackwardCompat(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\t// Create a run without setting ContainerID — simulates pre-migration rows\n\trun := domain.NewRun(\"old-1\", \"develop\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"old-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"\", got.ContainerID)\n}\n\nfunc TestRunErrorMessage(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"err-1\", \"develop\")\n\trun.Start()\n\trun.Fail(\"failed to start container: image not found\")\n\n\terr = store.CreateRun(ctx, run)\n\trequire.NoError(t, err)\n\n\tgot, err := store.GetRun(ctx, \"err-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, got.State)\n\tassert.Equal(t, \"failed to start container: image not found\", got.ErrorMessage)\n\n\t// Test update preserves error message\n\tgot.ErrorMessage = \"updated error\"\n\trequire.NoError(t, store.UpdateRun(ctx, got))\n\n\tgot2, err := store.GetRun(ctx, \"err-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"updated error\", got2.ErrorMessage)\n}\n\nfunc TestRunErrorMessageInList(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"err-list-1\", \"develop\")\n\trun.Start()\n\trun.Fail(\"container crashed\")\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, runs, 1)\n\tassert.Equal(t, \"container crashed\", runs[0].ErrorMessage)\n}\n\nfunc TestStore_ConcurrentWrites(t *testing.T) {\n\tdbPath := filepath.Join(t.TempDir(), \"concurrent.db\")\n\tstore, err := sqlite.NewStore(dbPath)\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tconst n = 10\n\tctx := context.Background()\n\terrs := make([]error, n)\n\n\tvar wg sync.WaitGroup\n\twg.Add(n)\n\tfor i := 0; i < n; i++ {\n\t\tgo func(i int) {\n\t\t\tdefer wg.Done()\n\t\t\tid := fmt.Sprintf(\"run-%d\", i)\n\t\t\trun := domain.NewRun(id, \"test-workflow\")\n\t\t\trun.Start()\n\t\t\tif err := store.CreateRun(ctx, run); err != nil {\n\t\t\t\terrs[i] = err\n\t\t\t\treturn\n\t\t\t}\n\t\t\terrs[i] = store.SaveCapture(ctx, id, &domain.StepExecution{\n\t\t\t\tStepName:  fmt.Sprintf(\"step-%d\", i),\n\t\t\t\tStartedAt: time.Now(),\n\t\t\t})\n\t\t}(i)\n\t}\n\twg.Wait()\n\n\tfor i, err := range errs {\n\t\tassert.NoError(t, err, \"goroutine %d failed\", i)\n\t}\n\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, n)\n}\n\nfunc TestListRunsByProject(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create runs for two different projects\n\tfor i, id := range []string{\"proj-a-1\", \"proj-a-2\"} {\n\t\tr := domain.NewRun(id, \"develop\")\n\t\tr.ProjectDir = \"/home/user/project-a\"\n\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n\t\tr.State = domain.RunStateRunning\n\t\trequire.NoError(t, store.CreateRun(ctx, r))\n\t}\n\trB := domain.NewRun(\"proj-b-1\", \"develop\")\n\trB.ProjectDir = \"/home/user/project-b\"\n\trB.StartedAt = time.Now()\n\trB.State = domain.RunStateRunning\n\trequire.NoError(t, store.CreateRun(ctx, rB))\n\n\t// Filter by project-a\n\truns, err := store.ListRunsByProject(ctx, \"/home/user/project-a\", time.Time{})\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, 2)\n\tfor _, r := range runs {\n\t\tassert.Equal(t, \"/home/user/project-a\", r.ProjectDir)\n\t}\n\n\t// Filter by project-b\n\truns, err = store.ListRunsByProject(ctx, \"/home/user/project-b\", time.Time{})\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, 1)\n\tassert.Equal(t, \"proj-b-1\", runs[0].ID)\n\n\t// Filter by nonexistent project\n\truns, err = store.ListRunsByProject(ctx, \"/nonexistent\", time.Time{})\n\trequire.NoError(t, err)\n\tassert.Empty(t, runs)\n}\n\nfunc TestListProjects(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Empty store returns no projects\n\tprojects, err := store.ListProjects(ctx)\n\trequire.NoError(t, err)\n\tassert.Empty(t, projects)\n\n\t// Create runs for different projects\n\tfor _, tc := range []struct {\n\t\tid, project string\n\t}{\n\t\t{\"r1\", \"/home/user/alpha\"},\n\t\t{\"r2\", \"/home/user/alpha\"},\n\t\t{\"r3\", \"/home/user/beta\"},\n\t\t{\"r4\", \"\"},\n\t} {\n\t\tr := domain.NewRun(tc.id, \"develop\")\n\t\tr.ProjectDir = tc.project\n\t\tr.State = domain.RunStatePending\n\t\trequire.NoError(t, store.CreateRun(ctx, r))\n\t}\n\n\tprojects, err = store.ListProjects(ctx)\n\trequire.NoError(t, err)\n\tassert.Equal(t, []string{\"/home/user/alpha\", \"/home/user/beta\"}, projects)\n}\n\nfunc TestRunContainerKept(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run with ContainerKept = false (default)\n\trun := domain.NewRun(\"kept-1\", \"develop\")\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"kept-1\")\n\trequire.NoError(t, err)\n\tassert.False(t, got.ContainerKept)\n\n\t// Update to mark container as kept\n\tgot.ContainerKept = true\n\trequire.NoError(t, store.UpdateRun(ctx, got))\n\n\tgot2, err := store.GetRun(ctx, \"kept-1\")\n\trequire.NoError(t, err)\n\tassert.True(t, got2.ContainerKept)\n\n\t// Verify ListRuns includes ContainerKept\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, runs, 1)\n\tassert.True(t, runs[0].ContainerKept)\n}\n\nfunc TestStore_FailStaleRuns(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create runs in different states.\n\tpending := domain.NewRun(\"pending-1\", \"wf\")\n\trequire.NoError(t, store.CreateRun(ctx, pending))\n\n\trunning := domain.NewRun(\"running-1\", \"wf\")\n\trunning.Start()\n\trequire.NoError(t, store.CreateRun(ctx, running))\n\n\tsucceeded := domain.NewRun(\"succeeded-1\", \"wf\")\n\tsucceeded.Start()\n\tsucceeded.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, succeeded))\n\n\tn, err := store.FailStaleRuns(ctx)\n\trequire.NoError(t, err)\n\tassert.Equal(t, int64(2), n) // both pending and running\n\n\tgot, err := store.GetRun(ctx, \"pending-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, got.State)\n\tassert.False(t, got.CompletedAt.IsZero(), \"completed_at should be set\")\n\tassert.Equal(t, \"daemon restarted while run was active\", got.ErrorMessage)\n\n\tgotRunning, err := store.GetRun(ctx, \"running-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, gotRunning.State)\n\tassert.False(t, gotRunning.CompletedAt.IsZero(), \"completed_at should be set\")\n\tassert.Equal(t, \"daemon restarted while run was active\", gotRunning.ErrorMessage)\n\n\t// Succeeded runs should be untouched.\n\tgotSucceeded, err := store.GetRun(ctx, \"succeeded-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, gotSucceeded.State)\n}\n\nfunc TestLogFiles_SaveAndGet(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run first (foreign key)\n\trun := domain.NewRun(\"log-run-1\", \"develop\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tnow := time.Now().Truncate(time.Second)\n\n\t// Save log file entries\n\tentries := []*ports.LogFileEntry{\n\t\t{RunID: \"log-run-1\", FileType: \"full\", FilePath: \"/tmp/output/full.log\", FileSize: 1024, CreatedAt: now},\n\t\t{RunID: \"log-run-1\", StepName: \"build\", FileType: \"script\", FilePath: \"/tmp/output/build.log\", FileSize: 512, CreatedAt: now},\n\t\t{RunID: \"log-run-1\", StepName: \"build\", FileType: \"llm\", FilePath: \"/tmp/output/llm-build.log\", FileSize: 2048, CreatedAt: now},\n\t\t{RunID: \"log-run-1\", StepName: \"test\", FileType: \"script\", FilePath: \"/tmp/output/test.log\", FileSize: 256, CreatedAt: now},\n\t}\n\tfor _, e := range entries {\n\t\trequire.NoError(t, store.SaveLogFile(ctx, e))\n\t}\n\n\t// GetLogFiles returns all entries for a run\n\tall, err := store.GetLogFiles(ctx, \"log-run-1\")\n\trequire.NoError(t, err)\n\tassert.Len(t, all, 4)\n\n\t// GetLogFilesByStep returns entries for a specific step\n\tbuildLogs, err := store.GetLogFilesByStep(ctx, \"log-run-1\", \"build\")\n\trequire.NoError(t, err)\n\tassert.Len(t, buildLogs, 2)\n\tfor _, lf := range buildLogs {\n\t\tassert.Equal(t, \"build\", lf.StepName)\n\t}\n\n\t// GetLogFileByType returns entries of a specific type\n\tllmLogs, err := store.GetLogFileByType(ctx, \"log-run-1\", \"llm\")\n\trequire.NoError(t, err)\n\tassert.Len(t, llmLogs, 1)\n\tassert.Equal(t, \"llm\", llmLogs[0].FileType)\n\tassert.Equal(t, \"build\", llmLogs[0].StepName)\n\n\t// GetLogFileByType for \"full\"\n\tfullLogs, err := store.GetLogFileByType(ctx, \"log-run-1\", \"full\")\n\trequire.NoError(t, err)\n\tassert.Len(t, fullLogs, 1)\n\tassert.Equal(t, \"full\", fullLogs[0].FileType)\n\tassert.Equal(t, int64(1024), fullLogs[0].FileSize)\n}\n\nfunc TestLogFiles_EmptyResults(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// No entries yet\n\tfiles, err := store.GetLogFiles(ctx, \"nonexistent\")\n\trequire.NoError(t, err)\n\tassert.Empty(t, files)\n\n\tfiles, err = store.GetLogFilesByStep(ctx, \"nonexistent\", \"build\")\n\trequire.NoError(t, err)\n\tassert.Empty(t, files)\n\n\tfiles, err = store.GetLogFileByType(ctx, \"nonexistent\", \"llm\")\n\trequire.NoError(t, err)\n\tassert.Empty(t, files)\n}\n","numLines":573,"startLine":1,"totalLines":573}}}
