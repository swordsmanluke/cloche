mes, trimming whitespace from each entry.\nfunc ParseCommands(s string) []string {\n\tparts := strings.Split(s, \",\")\n\tvar cmds []string\n\tfor _, p := range parts {\n\t\tp = strings.TrimSpace(p)","numLines":60,"startLine":1,"totalLines":389}}}
