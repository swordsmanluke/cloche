{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LjBBNescnseFRjN7eocwxh","type":"tool_result","content":"     1→package sqlite\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"database/sql\"\n     6→\t\"fmt\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11→\t_ \"modernc.org/sqlite\"\n    12→)\n    13→\n    14→type Store struct {\n    15→\tdb *sql.DB\n    16→}\n    17→\n    18→func NewStore(dsn string) (*Store, error) {\n    19→\tdb, err := sql.Open(\"sqlite\", dsn)\n    20→\tif err != nil {\n    21→\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n    22→\t}\n    23→\n    24→\t// Enable WAL mode for concurrent read/write access\n    25→\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n    26→\n    27→\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n    28→\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n    29→\n    30→\t// Serialize all Go-side access through a single connection so SQLite\n    31→\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n    32→\tdb.SetMaxOpenConns(1)\n    33→\n    34→\tif err := migrate(db); err != nil {\n    35→\t\tdb.Close()\n    36→\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n    37→\t}\n    38→\n    39→\treturn &Store{db: db}, nil\n    40→}\n    41→\n    42→func (s *Store) Close() error {\n    43→\treturn s.db.Close()\n    44→}\n    45→\n    46→func migrate(db *sql.DB) error {\n    47→\t_, err := db.Exec(`\n    48→\t\tCREATE TABLE IF NOT EXISTS runs (\n    49→\t\t\tid TEXT PRIMARY KEY,\n    50→\t\t\tworkflow_name TEXT NOT NULL,\n    51→\t\t\tstate TEXT NOT NULL,\n    52→\t\t\tactive_steps TEXT,\n    53→\t\t\tstarted_at TEXT,\n    54→\t\t\tcompleted_at TEXT\n    55→\t\t);\n    56→\t\tCREATE TABLE IF NOT EXISTS step_executions (\n    57→\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    58→\t\t\trun_id TEXT NOT NULL,\n    59→\t\t\tstep_name TEXT NOT NULL,\n    60→\t\t\tresult TEXT,\n    61→\t\t\tstarted_at TEXT NOT NULL,\n    62→\t\t\tcompleted_at TEXT,\n    63→\t\t\tlogs TEXT,\n    64→\t\t\tgit_ref TEXT,\n    65→\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    66→\t\t);\n    67→\t`)\n    68→\tif err != nil {\n    69→\t\treturn err\n    70→\t}\n    71→\n    72→\t// Evolution schema additions (idempotent)\n    73→\talterStmts := []string{\n    74→\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n    75→\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n    76→\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n    77→\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n    78→\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n    79→\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n    80→\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n    81→\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n    82→\t}\n    83→\tfor _, stmt := range alterStmts {\n    84→\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n    85→\t}\n    86→\n    87→\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n    88→\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    89→\t\trun_id TEXT NOT NULL,\n    90→\t\tstep_name TEXT,\n    91→\t\tfile_type TEXT NOT NULL,\n    92→\t\tfile_path TEXT NOT NULL,\n    93→\t\tfile_size INTEGER,\n    94→\t\tcreated_at TEXT NOT NULL,\n    95→\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    96→\t)`)\n    97→\tif errLog != nil {\n    98→\t\treturn errLog\n    99→\t}\n   100→\n   101→\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n   102→\t\trun_id TEXT PRIMARY KEY,\n   103→\t\tbranch TEXT NOT NULL,\n   104→\t\tproject TEXT NOT NULL,\n   105→\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n   106→\t\tenqueued_at TEXT NOT NULL,\n   107→\t\tcompleted_at TEXT\n   108→\t)`)\n   109→\tif errMQ != nil {\n   110→\t\treturn errMQ\n   111→\t}\n   112→\n   113→\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n   114→\t\tid TEXT PRIMARY KEY,\n   115→\t\tproject_dir TEXT NOT NULL,\n   116→\t\tworkflow_name TEXT NOT NULL,\n   117→\t\ttrigger_run_id TEXT NOT NULL,\n   118→\t\tcreated_at TEXT NOT NULL,\n   119→\t\tclassification TEXT,\n   120→\t\tchanges_json TEXT NOT NULL,\n   121→\t\tknowledge_delta TEXT\n   122→\t)`)\n   123→\tif err2 != nil {\n   124→\t\treturn err2\n   125→\t}\n   126→\n   127→\treturn nil\n   128→}\n   129→\n   130→func (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n   131→\t_, err := s.db.ExecContext(ctx,\n   132→\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept)\n   133→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   134→\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n   135→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, run.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept),\n   136→\t)\n   137→\treturn err\n   138→}\n   139→\n   140→func (s *Store) GetRun(ctx context.Context, id string) (*domain.Run, error) {\n   141→\trow := s.db.QueryRowContext(ctx,\n   142→\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0) FROM runs WHERE id = ?`, id)\n   143→\n   144→\trun := &domain.Run{}\n   145→\tvar activeSteps, startedAt, completedAt string\n   146→\tvar containerKept int\n   147→\terr := row.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept)\n   148→\tif err == sql.ErrNoRows {\n   149→\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n   150→\t}\n   151→\tif err != nil {\n   152→\t\treturn nil, err\n   153→\t}\n   154→\n   155→\trun.SetActiveStepsFromString(activeSteps)\n   156→\trun.StartedAt = parseTime(startedAt)\n   157→\trun.CompletedAt = parseTime(completedAt)\n   158→\trun.ContainerKept = containerKept != 0\n   159→\treturn run, nil\n   160→}\n   161→\n   162→func (s *Store) UpdateRun(ctx context.Context, run *domain.Run) error {\n   163→\t_, err := s.db.ExecContext(ctx,\n   164→\t\t`UPDATE runs SET state = ?, active_steps = ?, started_at = ?, completed_at = ?, error_message = ?, container_id = ?, base_sha = ?, container_kept = ? WHERE id = ?`,\n   165→\t\tstring(run.State), run.ActiveStepsString(),\n   166→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt),\n   167→\t\trun.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.ID,\n   168→\t)\n   169→\treturn err\n   170→}\n   171→\n   172→func (s *Store) DeleteRun(ctx context.Context, id string) error {\n   173→\t_, err := s.db.ExecContext(ctx, `DELETE FROM step_executions WHERE run_id = ?`, id)\n   174→\tif err != nil {\n   175→\t\treturn err\n   176→\t}\n   177→\t_, err = s.db.ExecContext(ctx, `DELETE FROM runs WHERE id = ?`, id)\n   178→\treturn err\n   179→}\n   180→\n   181→func (s *Store) ListRuns(ctx context.Context, since time.Time) ([]*domain.Run, error) {\n   182→\tvar rows *sql.Rows\n   183→\tvar err error\n   184→\tif since.IsZero() {\n   185→\t\trows, err = s.db.QueryContext(ctx,\n   186→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0) FROM runs ORDER BY started_at DESC`)\n   187→\t} else {\n   188→\t\trows, err = s.db.QueryContext(ctx,\n   189→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0) FROM runs WHERE started_at >= ? ORDER BY started_at DESC`,\n   190→\t\t\tformatTime(since))\n   191→\t}\n   192→\tif err != nil {\n   193→\t\treturn nil, err\n   194→\t}\n   195→\tdefer rows.Close()\n   196→\n   197→\tvar runs []*domain.Run\n   198→\tfor rows.Next() {\n   199→\t\trun := &domain.Run{}\n   200→\t\tvar activeSteps, startedAt, completedAt string\n   201→\t\tvar containerKept int\n   202→\t\tif err := rows.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept); err != nil {\n   203→\t\t\treturn nil, err\n   204→\t\t}\n   205→\t\trun.SetActiveStepsFromString(activeSteps)\n   206→\t\trun.StartedAt = parseTime(startedAt)\n   207→\t\trun.CompletedAt = parseTime(completedAt)\n   208→\t\trun.ContainerKept = containerKept != 0\n   209→\t\truns = append(runs, run)\n   210→\t}\n   211→\treturn runs, rows.Err()\n   212→}\n   213→\n   214→func (s *Store) ListRunsByProject(ctx context.Context, projectDir string, since time.Time) ([]*domain.Run, error) {\n   215→\tvar rows *sql.Rows\n   216→\tvar err error\n   217→\tif since.IsZero() {\n   218→\t\trows, err = s.db.QueryContext(ctx,\n   219→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0) FROM runs WHERE project_dir = ? ORDER BY started_at DESC`,\n   220→\t\t\tprojectDir)\n   221→\t} else {\n   222→\t\trows, err = s.db.QueryContext(ctx,\n   223→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0) FROM runs WHERE project_dir = ? AND started_at >= ? ORDER BY started_at DESC`,\n   224→\t\t\tprojectDir, formatTime(since))\n   225→\t}\n   226→\tif err != nil {\n   227→\t\treturn nil, err\n   228→\t}\n   229→\tdefer rows.Close()\n   230→\n   231→\tvar runs []*domain.Run\n   232→\tfor rows.Next() {\n   233→\t\trun := &domain.Run{}\n   234→\t\tvar activeSteps, startedAt, completedAt string\n   235→\t\tvar containerKept int\n   236→\t\tif err := rows.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept); err != nil {\n   237→\t\t\treturn nil, err\n   238→\t\t}\n   239→\t\trun.SetActiveStepsFromString(activeSteps)\n   240→\t\trun.StartedAt = parseTime(startedAt)\n   241→\t\trun.CompletedAt = parseTime(completedAt)\n   242→\t\trun.ContainerKept = containerKept != 0\n   243→\t\truns = append(runs, run)\n   244→\t}\n   245→\treturn runs, rows.Err()\n   246→}\n   247→\n   248→func (s *Store) ListProjects(ctx context.Context) ([]string, error) {\n   249→\trows, err := s.db.QueryContext(ctx,\n   250→\t\t`SELECT DISTINCT project_dir FROM runs WHERE project_dir != '' ORDER BY project_dir`)\n   251→\tif err != nil {\n   252→\t\treturn nil, err\n   253→\t}\n   254→\tdefer rows.Close()\n   255→\n   256→\tvar projects []string\n   257→\tfor rows.Next() {\n   258→\t\tvar dir string\n   259→\t\tif err := rows.Scan(&dir); err != nil {\n   260→\t\t\treturn nil, err\n   261→\t\t}\n   262→\t\tprojects = append(projects, dir)\n   263→\t}\n   264→\treturn projects, rows.Err()\n   265→}\n   266→\n   267→func (s *Store) SaveCapture(ctx context.Context, runID string, exec *domain.StepExecution) error {\n   268→\t_, err := s.db.ExecContext(ctx,\n   269→\t\t`INSERT INTO step_executions (run_id, step_name, result, started_at, completed_at, logs, git_ref)\n   270→\t\t VALUES (?, ?, ?, ?, ?, ?, ?)`,\n   271→\t\trunID, exec.StepName, exec.Result,\n   272→\t\tformatTime(exec.StartedAt), formatTime(exec.CompletedAt),\n   273→\t\texec.Logs, exec.GitRef,\n   274→\t)\n   275→\treturn err\n   276→}\n   277→\n   278→func (s *Store) GetCaptures(ctx context.Context, runID string) ([]*domain.StepExecution, error) {\n   279→\trows, err := s.db.QueryContext(ctx,\n   280→\t\t`SELECT step_name, result, started_at, completed_at, COALESCE(logs,''), COALESCE(git_ref,'')\n   281→\t\t FROM step_executions WHERE run_id = ? ORDER BY id`, runID)\n   282→\tif err != nil {\n   283→\t\treturn nil, err\n   284→\t}\n   285→\tdefer rows.Close()\n   286→\n   287→\tvar execs []*domain.StepExecution\n   288→\tfor rows.Next() {\n   289→\t\te := &domain.StepExecution{}\n   290→\t\tvar startedAt, completedAt string\n   291→\t\tif err := rows.Scan(&e.StepName, &e.Result, &startedAt, &completedAt, &e.Logs, &e.GitRef); err != nil {\n   292→\t\t\treturn nil, err\n   293→\t\t}\n   294→\t\te.StartedAt = parseTime(startedAt)\n   295→\t\te.CompletedAt = parseTime(completedAt)\n   296→\t\texecs = append(execs, e)\n   297→\t}\n   298→\treturn execs, rows.Err()\n   299→}\n   300→\n   301→func (s *Store) SaveLogFile(ctx context.Context, entry *ports.LogFileEntry) error {\n   302→\t_, err := s.db.ExecContext(ctx,\n   303→\t\t`INSERT INTO log_files (run_id, step_name, file_type, file_path, file_size, created_at)\n   304→\t\t VALUES (?, ?, ?, ?, ?, ?)`,\n   305→\t\tentry.RunID, entry.StepName, entry.FileType, entry.FilePath, entry.FileSize,\n   306→\t\tformatTime(entry.CreatedAt),\n   307→\t)\n   308→\treturn err\n   309→}\n   310→\n   311→func (s *Store) GetLogFiles(ctx context.Context, runID string) ([]*ports.LogFileEntry, error) {\n   312→\trows, err := s.db.QueryContext(ctx,\n   313→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   314→\t\t FROM log_files WHERE run_id = ? ORDER BY id`, runID)\n   315→\tif err != nil {\n   316→\t\treturn nil, err\n   317→\t}\n   318→\tdefer rows.Close()\n   319→\treturn scanLogFiles(rows)\n   320→}\n   321→\n   322→func (s *Store) GetLogFilesByStep(ctx context.Context, runID, stepName string) ([]*ports.LogFileEntry, error) {\n   323→\trows, err := s.db.QueryContext(ctx,\n   324→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   325→\t\t FROM log_files WHERE run_id = ? AND step_name = ? ORDER BY id`, runID, stepName)\n   326→\tif err != nil {\n   327→\t\treturn nil, err\n   328→\t}\n   329→\tdefer rows.Close()\n   330→\treturn scanLogFiles(rows)\n   331→}\n   332→\n   333→func (s *Store) GetLogFileByType(ctx context.Context, runID, fileType string) ([]*ports.LogFileEntry, error) {\n   334→\trows, err := s.db.QueryContext(ctx,\n   335→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   336→\t\t FROM log_files WHERE run_id = ? AND file_type = ? ORDER BY id`, runID, fileType)\n   337→\tif err != nil {\n   338→\t\treturn nil, err\n   339→\t}\n   340→\tdefer rows.Close()\n   341→\treturn scanLogFiles(rows)\n   342→}\n   343→\n   344→func scanLogFiles(rows *sql.Rows) ([]*ports.LogFileEntry, error) {\n   345→\tvar entries []*ports.LogFileEntry\n   346→\tfor rows.Next() {\n   347→\t\te := &ports.LogFileEntry{}\n   348→\t\tvar createdAt string\n   349→\t\tif err := rows.Scan(&e.ID, &e.RunID, &e.StepName, &e.FileType, &e.FilePath, &e.FileSize, &createdAt); err != nil {\n   350→\t\t\treturn nil, err\n   351→\t\t}\n   352→\t\te.CreatedAt = parseTime(createdAt)\n   353→\t\tentries = append(entries, e)\n   354→\t}\n   355→\treturn entries, rows.Err()\n   356→}\n   357→\n   358→func (s *Store) SaveEvolution(ctx context.Context, entry *ports.EvolutionEntry) error {\n   359→\t_, err := s.db.ExecContext(ctx,\n   360→\t\t`INSERT INTO evolution_log (id, project_dir, workflow_name, trigger_run_id, created_at, classification, changes_json, knowledge_delta)\n   361→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,\n   362→\t\tentry.ID, entry.ProjectDir, entry.WorkflowName, entry.TriggerRunID,\n   363→\t\tformatTime(entry.CreatedAt), entry.Classification, entry.ChangesJSON, entry.KnowledgeDelta,\n   364→\t)\n   365→\treturn err\n   366→}\n   367→\n   368→func (s *Store) GetLastEvolution(ctx context.Context, projectDir, workflowName string) (*ports.EvolutionEntry, error) {\n   369→\trow := s.db.QueryRowContext(ctx,\n   370→\t\t`SELECT id, project_dir, workflow_name, trigger_run_id, created_at, COALESCE(classification,''), changes_json, COALESCE(knowledge_delta,'')\n   371→\t\t FROM evolution_log WHERE project_dir = ? AND workflow_name = ? ORDER BY created_at DESC LIMIT 1`,\n   372→\t\tprojectDir, workflowName)\n   373→\n   374→\tentry := &ports.EvolutionEntry{}\n   375→\tvar createdAt string\n   376→\terr := row.Scan(&entry.ID, &entry.ProjectDir, &entry.WorkflowName, &entry.TriggerRunID,\n   377→\t\t&createdAt, &entry.Classification, &entry.ChangesJSON, &entry.KnowledgeDelta)\n   378→\tif err == sql.ErrNoRows {\n   379→\t\treturn nil, nil\n   380→\t}\n   381→\tif err != nil {\n   382→\t\treturn nil, err\n   383→\t}\n   384→\tentry.CreatedAt = parseTime(createdAt)\n   385→\treturn entry, nil\n   386→}\n   387→\n   388→func (s *Store) ListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error) {\n   389→\tvar rows *sql.Rows\n   390→\tvar err error\n   391→\n   392→\tif sinceRunID == \"\" {\n   393→\t\trows, err = s.db.QueryContext(ctx,\n   394→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0)\n   395→\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? ORDER BY started_at ASC`,\n   396→\t\t\tprojectDir, workflowName)\n   397→\t} else {\n   398→\t\trows, err = s.db.QueryContext(ctx,\n   399→\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0)\n   400→\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? AND started_at > (SELECT started_at FROM runs WHERE id = ?)\n   401→\t\t\t ORDER BY started_at ASC`,\n   402→\t\t\tprojectDir, workflowName, sinceRunID)\n   403→\t}\n   404→\tif err != nil {\n   405→\t\treturn nil, err\n   406→\t}\n   407→\tdefer rows.Close()\n   408→\n   409→\tvar runs []*domain.Run\n   410→\tfor rows.Next() {\n   411→\t\trun := &domain.Run{}\n   412→\t\tvar activeSteps, startedAt, completedAt string\n   413→\t\tvar containerKept int\n   414→\t\tif err := rows.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept); err != nil {\n   415→\t\t\treturn nil, err\n   416→\t\t}\n   417→\t\trun.SetActiveStepsFromString(activeSteps)\n   418→\t\trun.StartedAt = parseTime(startedAt)\n   419→\t\trun.CompletedAt = parseTime(completedAt)\n   420→\t\trun.ContainerKept = containerKept != 0\n   421→\t\truns = append(runs, run)\n   422→\t}\n   423→\treturn runs, rows.Err()\n   424→}\n   425→\n   426→\n   427→func (s *Store) FailStaleRuns(ctx context.Context) (int64, error) {\n   428→\tnow := formatTime(time.Now())\n   429→\tres, err := s.db.ExecContext(ctx,\n   430→\t\t`UPDATE runs SET state = 'failed', completed_at = ?, error_message = 'daemon restarted while run was active'\n   431→\t\t WHERE state IN ('pending', 'running')`,\n   432→\t\tnow,\n   433→\t)\n   434→\tif err != nil {\n   435→\t\treturn 0, err\n   436→\t}\n   437→\treturn res.RowsAffected()\n   438→}\n   439→\n   440→func formatTime(t time.Time) string {\n   441→\tif t.IsZero() {\n   442→\t\treturn \"\"\n   443→\t}\n   444→\treturn t.Format(time.RFC3339Nano)\n   445→}\n   446→\n   447→func parseTime(s string) time.Time {\n   448→\tif s == \"\" {\n   449→\t\treturn time.Time{}\n   450→\t}\n   451→\tt, _ := time.Parse(time.RFC3339Nano, s)\n   452→\treturn t\n   453→}\n   454→\n   455→func boolToInt(b bool) int {\n   456→\tif b {\n   457→\t\treturn 1\n   458→\t}\n   459→\treturn 0\n   460→}\n   461→"}]},"parent_tool_use_id":null,"session_id":"4396f712-f062-4883-ba52-ad58e85081ed","uuid":"a87b36c3-8bfd-4ef3-97f6-2ec7f82be0df","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/sqlite/store.go","content":"package sqlite\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t_ \"modernc.org/sqlite\"\n)\n\ntype Store struct {\n\tdb *sql.DB\n}\n\nfunc NewStore(dsn string) (*Store, error) {\n\tdb, err := sql.Open(\"sqlite\", dsn)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n\t}\n\n\t// Enable WAL mode for concurrent read/write access\n\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n\n\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n\n\t// Serialize all Go-side access through a single connection so SQLite\n\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n\tdb.SetMaxOpenConns(1)\n\n\tif err := migrate(db); err != nil {\n\t\tdb.Close()\n\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n\t}\n\n\treturn &Store{db: db}, nil\n}\n\nfunc (s *Store) Close() error {\n\treturn s.db.Close()\n}\n\nfunc migrate(db *sql.DB) error {\n\t_, err := db.Exec(`\n\t\tCREATE TABLE IF NOT EXISTS runs (\n\t\t\tid TEXT PRIMARY KEY,\n\t\t\tworkflow_name TEXT NOT NULL,\n\t\t\tstate TEXT NOT NULL,\n\t\t\tactive_steps TEXT,\n\t\t\tstarted_at TEXT,\n\t\t\tcompleted_at TEXT\n\t\t);\n\t\tCREATE TABLE IF NOT EXISTS step_executions (\n\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n\t\t\trun_id TEXT NOT NULL,\n\t\t\tstep_name TEXT NOT NULL,\n\t\t\tresult TEXT,\n\t\t\tstarted_at TEXT NOT NULL,\n\t\t\tcompleted_at TEXT,\n\t\t\tlogs TEXT,\n\t\t\tgit_ref TEXT,\n\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n\t\t);\n\t`)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// Evolution schema additions (idempotent)\n\talterStmts := []string{\n\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n\t}\n\tfor _, stmt := range alterStmts {\n\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n\t}\n\n\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n\t\trun_id TEXT NOT NULL,\n\t\tstep_name TEXT,\n\t\tfile_type TEXT NOT NULL,\n\t\tfile_path TEXT NOT NULL,\n\t\tfile_size INTEGER,\n\t\tcreated_at TEXT NOT NULL,\n\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n\t)`)\n\tif errLog != nil {\n\t\treturn errLog\n\t}\n\n\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n\t\trun_id TEXT PRIMARY KEY,\n\t\tbranch TEXT NOT NULL,\n\t\tproject TEXT NOT NULL,\n\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n\t\tenqueued_at TEXT NOT NULL,\n\t\tcompleted_at TEXT\n\t)`)\n\tif errMQ != nil {\n\t\treturn errMQ\n\t}\n\n\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n\t\tid TEXT PRIMARY KEY,\n\t\tproject_dir TEXT NOT NULL,\n\t\tworkflow_name TEXT NOT NULL,\n\t\ttrigger_run_id TEXT NOT NULL,\n\t\tcreated_at TEXT NOT NULL,\n\t\tclassification TEXT,\n\t\tchanges_json TEXT NOT NULL,\n\t\tknowledge_delta TEXT\n\t)`)\n\tif err2 != nil {\n\t\treturn err2\n\t}\n\n\treturn nil\n}\n\nfunc (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n\t_, err := s.db.ExecContext(ctx,\n\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept)\n\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, run.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept),\n\t)\n\treturn err\n}\n\nfunc (s *Store) GetRun(ctx context.Context, id string) (*domain.Run, error) {\n\trow := s.db.QueryRowContext(ctx,\n\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0) FROM runs WHERE id = ?`, id)\n\n\trun := &domain.Run{}\n\tvar activeSteps, startedAt, completedAt string\n\tvar containerKept int\n\terr := row.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept)\n\tif err == sql.ErrNoRows {\n\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\trun.SetActiveStepsFromString(activeSteps)\n\trun.StartedAt = parseTime(startedAt)\n\trun.CompletedAt = parseTime(completedAt)\n\trun.ContainerKept = containerKept != 0\n\treturn run, nil\n}\n\nfunc (s *Store) UpdateRun(ctx context.Context, run *domain.Run) error {\n\t_, err := s.db.ExecContext(ctx,\n\t\t`UPDATE runs SET state = ?, active_steps = ?, started_at = ?, completed_at = ?, error_message = ?, container_id = ?, base_sha = ?, container_kept = ? WHERE id = ?`,\n\t\tstring(run.State), run.ActiveStepsString(),\n\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt),\n\t\trun.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.ID,\n\t)\n\treturn err\n}\n\nfunc (s *Store) DeleteRun(ctx context.Context, id string) error {\n\t_, err := s.db.ExecContext(ctx, `DELETE FROM step_executions WHERE run_id = ?`, id)\n\tif err != nil {\n\t\treturn err\n\t}\n\t_, err = s.db.ExecContext(ctx, `DELETE FROM runs WHERE id = ?`, id)\n\treturn err\n}\n\nfunc (s *Store) ListRuns(ctx context.Context, since time.Time) ([]*domain.Run, error) {\n\tvar rows *sql.Rows\n\tvar err error\n\tif since.IsZero() {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0) FROM runs ORDER BY started_at DESC`)\n\t} else {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0) FROM runs WHERE started_at >= ? ORDER BY started_at DESC`,\n\t\t\tformatTime(since))\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\n\tvar runs []*domain.Run\n\tfor rows.Next() {\n\t\trun := &domain.Run{}\n\t\tvar activeSteps, startedAt, completedAt string\n\t\tvar containerKept int\n\t\tif err := rows.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\trun.SetActiveStepsFromString(activeSteps)\n\t\trun.StartedAt = parseTime(startedAt)\n\t\trun.CompletedAt = parseTime(completedAt)\n\t\trun.ContainerKept = containerKept != 0\n\t\truns = append(runs, run)\n\t}\n\treturn runs, rows.Err()\n}\n\nfunc (s *Store) ListRunsByProject(ctx context.Context, projectDir string, since time.Time) ([]*domain.Run, error) {\n\tvar rows *sql.Rows\n\tvar err error\n\tif since.IsZero() {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0) FROM runs WHERE project_dir = ? ORDER BY started_at DESC`,\n\t\t\tprojectDir)\n\t} else {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0) FROM runs WHERE project_dir = ? AND started_at >= ? ORDER BY started_at DESC`,\n\t\t\tprojectDir, formatTime(since))\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\n\tvar runs []*domain.Run\n\tfor rows.Next() {\n\t\trun := &domain.Run{}\n\t\tvar activeSteps, startedAt, completedAt string\n\t\tvar containerKept int\n\t\tif err := rows.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\trun.SetActiveStepsFromString(activeSteps)\n\t\trun.StartedAt = parseTime(startedAt)\n\t\trun.CompletedAt = parseTime(completedAt)\n\t\trun.ContainerKept = containerKept != 0\n\t\truns = append(runs, run)\n\t}\n\treturn runs, rows.Err()\n}\n\nfunc (s *Store) ListProjects(ctx context.Context) ([]string, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT DISTINCT project_dir FROM runs WHERE project_dir != '' ORDER BY project_dir`)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\n\tvar projects []string\n\tfor rows.Next() {\n\t\tvar dir string\n\t\tif err := rows.Scan(&dir); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tprojects = append(projects, dir)\n\t}\n\treturn projects, rows.Err()\n}\n\nfunc (s *Store) SaveCapture(ctx context.Context, runID string, exec *domain.StepExecution) error {\n\t_, err := s.db.ExecContext(ctx,\n\t\t`INSERT INTO step_executions (run_id, step_name, result, started_at, completed_at, logs, git_ref)\n\t\t VALUES (?, ?, ?, ?, ?, ?, ?)`,\n\t\trunID, exec.StepName, exec.Result,\n\t\tformatTime(exec.StartedAt), formatTime(exec.CompletedAt),\n\t\texec.Logs, exec.GitRef,\n\t)\n\treturn err\n}\n\nfunc (s *Store) GetCaptures(ctx context.Context, runID string) ([]*domain.StepExecution, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT step_name, result, started_at, completed_at, COALESCE(logs,''), COALESCE(git_ref,'')\n\t\t FROM step_executions WHERE run_id = ? ORDER BY id`, runID)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\n\tvar execs []*domain.StepExecution\n\tfor rows.Next() {\n\t\te := &domain.StepExecution{}\n\t\tvar startedAt, completedAt string\n\t\tif err := rows.Scan(&e.StepName, &e.Result, &startedAt, &completedAt, &e.Logs, &e.GitRef); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\te.StartedAt = parseTime(startedAt)\n\t\te.CompletedAt = parseTime(completedAt)\n\t\texecs = append(execs, e)\n\t}\n\treturn execs, rows.Err()\n}\n\nfunc (s *Store) SaveLogFile(ctx context.Context, entry *ports.LogFileEntry) error {\n\t_, err := s.db.ExecContext(ctx,\n\t\t`INSERT INTO log_files (run_id, step_name, file_type, file_path, file_size, created_at)\n\t\t VALUES (?, ?, ?, ?, ?, ?)`,\n\t\tentry.RunID, entry.StepName, entry.FileType, entry.FilePath, entry.FileSize,\n\t\tformatTime(entry.CreatedAt),\n\t)\n\treturn err\n}\n\nfunc (s *Store) GetLogFiles(ctx context.Context, runID string) ([]*ports.LogFileEntry, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n\t\t FROM log_files WHERE run_id = ? ORDER BY id`, runID)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanLogFiles(rows)\n}\n\nfunc (s *Store) GetLogFilesByStep(ctx context.Context, runID, stepName string) ([]*ports.LogFileEntry, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n\t\t FROM log_files WHERE run_id = ? AND step_name = ? ORDER BY id`, runID, stepName)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanLogFiles(rows)\n}\n\nfunc (s *Store) GetLogFileByType(ctx context.Context, runID, fileType string) ([]*ports.LogFileEntry, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n\t\t FROM log_files WHERE run_id = ? AND file_type = ? ORDER BY id`, runID, fileType)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanLogFiles(rows)\n}\n\nfunc scanLogFiles(rows *sql.Rows) ([]*ports.LogFileEntry, error) {\n\tvar entries []*ports.LogFileEntry\n\tfor rows.Next() {\n\t\te := &ports.LogFileEntry{}\n\t\tvar createdAt string\n\t\tif err := rows.Scan(&e.ID, &e.RunID, &e.StepName, &e.FileType, &e.FilePath, &e.FileSize, &createdAt); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\te.CreatedAt = parseTime(createdAt)\n\t\tentries = append(entries, e)\n\t}\n\treturn entries, rows.Err()\n}\n\nfunc (s *Store) SaveEvolution(ctx context.Context, entry *ports.EvolutionEntry) error {\n\t_, err := s.db.ExecContext(ctx,\n\t\t`INSERT INTO evolution_log (id, project_dir, workflow_name, trigger_run_id, created_at, classification, changes_json, knowledge_delta)\n\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,\n\t\tentry.ID, entry.ProjectDir, entry.WorkflowName, entry.TriggerRunID,\n\t\tformatTime(entry.CreatedAt), entry.Classification, entry.ChangesJSON, entry.KnowledgeDelta,\n\t)\n\treturn err\n}\n\nfunc (s *Store) GetLastEvolution(ctx context.Context, projectDir, workflowName string) (*ports.EvolutionEntry, error) {\n\trow := s.db.QueryRowContext(ctx,\n\t\t`SELECT id, project_dir, workflow_name, trigger_run_id, created_at, COALESCE(classification,''), changes_json, COALESCE(knowledge_delta,'')\n\t\t FROM evolution_log WHERE project_dir = ? AND workflow_name = ? ORDER BY created_at DESC LIMIT 1`,\n\t\tprojectDir, workflowName)\n\n\tentry := &ports.EvolutionEntry{}\n\tvar createdAt string\n\terr := row.Scan(&entry.ID, &entry.ProjectDir, &entry.WorkflowName, &entry.TriggerRunID,\n\t\t&createdAt, &entry.Classification, &entry.ChangesJSON, &entry.KnowledgeDelta)\n\tif err == sql.ErrNoRows {\n\t\treturn nil, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tentry.CreatedAt = parseTime(createdAt)\n\treturn entry, nil\n}\n\nfunc (s *Store) ListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error) {\n\tvar rows *sql.Rows\n\tvar err error\n\n\tif sinceRunID == \"\" {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0)\n\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? ORDER BY started_at ASC`,\n\t\t\tprojectDir, workflowName)\n\t} else {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0)\n\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? AND started_at > (SELECT started_at FROM runs WHERE id = ?)\n\t\t\t ORDER BY started_at ASC`,\n\t\t\tprojectDir, workflowName, sinceRunID)\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\n\tvar runs []*domain.Run\n\tfor rows.Next() {\n\t\trun := &domain.Run{}\n\t\tvar activeSteps, startedAt, completedAt string\n\t\tvar containerKept int\n\t\tif err := rows.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\trun.SetActiveStepsFromString(activeSteps)\n\t\trun.StartedAt = parseTime(startedAt)\n\t\trun.CompletedAt = parseTime(completedAt)\n\t\trun.ContainerKept = containerKept != 0\n\t\truns = append(runs, run)\n\t}\n\treturn runs, rows.Err()\n}\n\n\nfunc (s *Store) FailStaleRuns(ctx context.Context) (int64, error) {\n\tnow := formatTime(time.Now())\n\tres, err := s.db.ExecContext(ctx,\n\t\t`UPDATE runs SET state = 'failed', completed_at = ?, error_message = 'daemon restarted while run was active'\n\t\t WHERE state IN ('pending', 'running')`,\n\t\tnow,\n\t)\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\treturn res.RowsAffected()\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(time.RFC3339Nano)\n}\n\nfunc parseTime(s string) time.Time {\n\tif s == \"\" {\n\t\treturn time.Time{}\n\t}\n\tt, _ := time.Parse(time.RFC3339Nano, s)\n\treturn t\n}\n\nfunc boolToInt(b bool) int {\n\tif b {\n\t\treturn 1\n\t}\n\treturn 0\n}\n","numLines":461,"startLine":1,"totalLines":461}}}
