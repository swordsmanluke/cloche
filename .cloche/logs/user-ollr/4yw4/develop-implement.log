{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KjCwNbb51xpR9fvPaZwViK","type":"tool_result","content":"   381→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   382→\trun, err := s.store.GetRun(ctx, req.RunId)\n   383→\tif err != nil {\n   384→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   385→\t}\n   386→\n   387→\tresp := &pb.GetStatusResponse{\n   388→\t\tRunId:        run.ID,\n   389→\t\tWorkflowName: run.WorkflowName,\n   390→\t\tState:        string(run.State),\n   391→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   392→\t\tErrorMessage: run.ErrorMessage,\n   393→\t\tContainerId:  run.ContainerID,\n   394→\t}\n   395→\n   396→\t// Check container liveness\n   397→\tif run.ContainerID != \"\" && s.container != nil {\n   398→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   399→\t\t\tresp.ContainerAlive = cs.Running\n   400→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   401→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   402→\t\t\t}\n   403→\t\t}\n   404→\t}\n   405→\n   406→\t// Load step executions from captures store if available\n   407→\tif s.captures != nil {\n   408→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   409→\t\tif err == nil {\n   410→\t\t\tfor _, exec := range captures {\n   411→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   412→\t\t\t\t\tStepName:    exec.StepName,\n   413→\t\t\t\t\tResult:      exec.Result,\n   414→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   415→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   416→\t\t\t\t})\n   417→\t\t\t}\n   418→\t\t}\n   419→\t} else {\n   420→\t\tfor _, exec := range run.StepExecutions {\n   421→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   422→\t\t\t\tStepName:    exec.StepName,\n   423→\t\t\t\tResult:      exec.Result,\n   424→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   425→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   426→\t\t\t})\n   427→\t\t}\n   428→\t}\n   429→\n   430→\treturn resp, nil\n   431→}\n   432→\n   433→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   434→\tctx := stream.Context()\n   435→\n   436→\t// Verify run exists\n   437→\trun, err := s.store.GetRun(ctx, req.RunId)\n   438→\tif err != nil {\n   439→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   440→\t}\n   441→\n   442→\t// If step_name or log_type filter is set, serve content directly from the log index\n   443→\tif req.StepName != \"\" || req.LogType != \"\" {\n   444→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   445→\t}\n   446→\n   447→\tif s.captures == nil {\n   448→\t\treturn fmt.Errorf(\"captures store not configured\")\n   449→\t}\n   450→\n   451→\t// Check for full.log first — if it exists, serve it as the unified log\n   452→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   453→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   454→\t\tif err := stream.Send(&pb.LogEntry{\n   455→\t\t\tType:    \"full_log\",\n   456→\t\t\tMessage: string(data),\n   457→\t\t}); err != nil {\n   458→\t\t\treturn err\n   459→\t\t}\n   460→\t\t// Still send run completion entry\n   461→\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   462→\t\t\tif err := stream.Send(&pb.LogEntry{\n   463→\t\t\t\tType:      \"run_completed\",\n   464→\t\t\t\tResult:    string(run.State),\n   465→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   466→\t\t\t\tMessage:   run.ErrorMessage,\n   467→\t\t\t}); err != nil {\n   468→\t\t\t\treturn err\n   469→\t\t\t}\n   470→\t\t}\n   471→\t\treturn nil\n   472→\t}\n   473→\n   474→\t// Fall back to capture-based streaming\n   475→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   476→\tif err != nil {\n   477→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   478→\t}\n   479→\n   480→\tfor _, exec := range captures {"}]},"parent_tool_use_id":"toolu_018WtRq7zeWYM3FtLD39VQkt","session_id":"4396f712-f062-4883-ba52-ad58e85081ed","uuid":"4d2f6ad3-03cc-472e-9605-b859119fa89a"}
