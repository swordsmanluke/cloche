{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TPspGgupu8XbktBfmUH6Q2","type":"tool_result","content":"    50→\tProjectDir string\n    51→\tDispatcher RunDispatcher\n    52→\tStore      ports.RunStore\n    53→\tOutputDir  string         // directory for step output files\n    54→\tWires      []domain.Wire  // workflow wiring (for output mappings)\n    55→}\n    56→\n    57→var _ engine.StepExecutor = (*Executor)(nil)\n    58→\n    59→// Execute runs a single host workflow step.\n    60→func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    61→\tswitch step.Type {\n    62→\tcase domain.StepTypeScript:\n    63→\t\treturn e.executeScript(ctx, step)\n    64→\tcase domain.StepTypeWorkflow:\n    65→\t\treturn e.executeWorkflow(ctx, step)\n    66→\tdefault:\n    67→\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    68→\t}\n    69→}\n    70→\n    71→// executeScript runs a shell command on the host.\n    72→func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    73→\tcmdStr := step.Config[\"run\"]\n    74→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    75→\tcmd.Dir = e.ProjectDir\n    76→\tcmd.Env = append(os.Environ(),\n    77→\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    78→\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    79→\t)\n    80→\n    81→\t// Pass previous step output if available\n    82→\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n    83→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n    84→\t}\n    85→\n    86→\t// Resolve output mappings from wires and add as env vars\n    87→\tif len(e.Wires) > 0 {\n    88→\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n    89→\t\tif err != nil {\n    90→\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n    91→\t\t}\n    92→\t\tcmd.Env = append(cmd.Env, mapped...)\n    93→\t}\n    94→\n    95→\toutput, err := cmd.CombinedOutput()\n    96→\n    97→\t// Extract result marker\n    98→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n    99→\n   100→\t// Write output to file\n   101→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   102→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   103→\t}\n   104→\n   105→\tif err != nil {\n   106→\t\tif _, ok := err.(*exec.ExitError); ok {\n   107→\t\t\tresult := \"fail\"\n   108→\t\t\tif found {\n   109→\t\t\t\tresult = markerResult\n   110→\t\t\t}\n   111→\t\t\treturn result, nil\n   112→\t\t}\n   113→\t\treturn \"\", err\n   114→\t}\n   115→\n   116→\tresult := \"success\"\n   117→\tif found {\n   118→\t\tresult = markerResult\n   119→\t}\n   120→\treturn result, nil\n   121→}\n   122→\n   123→// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   124→func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   125→\tworkflowName := step.Config[\"workflow_name\"]\n   126→\tif workflowName == \"\" {\n   127→\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   128→\t}\n   129→\n   130→\t// Read prompt from previous step output or prompt_step override\n   131→\tvar promptContent string\n   132→\tpromptSource := step.Config[\"prompt_step\"]\n   133→\tif promptSource != \"\" {\n   134→\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   135→\t\tif err == nil {\n   136→\t\t\tpromptContent = string(data)\n   137→\t\t}\n   138→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   139→\t\tdata, err := os.ReadFile(prev)\n   140→\t\tif err == nil {\n   141→\t\t\tpromptContent = string(data)\n   142→\t\t}\n   143→\t}\n   144→\n   145→\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   146→\t\tWorkflowName: workflowName,\n   147→\t\tProjectDir:   e.ProjectDir,\n   148→\t\tPrompt:       promptContent,\n   149→\t})\n   150→\tif err != nil {\n   151→\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   152→\t}\n   153→\n   154→\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   155→\n   156→\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n   157→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   158→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n   159→\t}\n   160→\n   161→\t// Poll until the run reaches a terminal state\n   162→\tstate, err := e.waitForRun(ctx, resp.RunId)\n   163→\tif err != nil {\n   164→\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   165→\t}\n   166→\n   167→\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   168→\n   169→\t// Map run state to step result\n   170→\tif state == domain.RunStateSucceeded {\n   171→\t\treturn \"success\", nil\n   172→\t}\n   173→\treturn \"fail\", nil\n   174→}\n   175→\n   176→// waitForRun polls the store until the run reaches a terminal state.\n   177→func (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   178→\tticker := time.NewTicker(2 * time.Second)\n   179→\tdefer ticker.Stop()\n   180→\n   181→\tfor {\n   182→\t\tselect {\n   183→\t\tcase <-ctx.Done():\n   184→\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   185→\t\tcase <-ticker.C:\n   186→\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   187→\t\t\tif err != nil {\n   188→\t\t\t\tcontinue // transient error, retry\n   189→\t\t\t}\n   190→\t\t\tswitch run.State {\n   191→\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   192→\t\t\t\treturn run.State, nil\n   193→\t\t\t}\n   194→\t\t\t// Still pending or running, continue polling\n   195→\t\t}\n   196→\t}\n   197→}\n   198→\n   199→// stepOutputPath returns the path for a step's output file.\n   200→func (e *Executor) stepOutputPath(stepName string) string {\n   201→\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   202→}\n   203→\n   204→// findPrevOutput finds the output file from the step that wires into this one.\n   205→// It checks prompt_step config first, then walks the wiring graph to find the\n   206→// source step.\n   207→func (e *Executor) findPrevOutput(step *domain.Step) string {\n   208→\t// Explicit prompt_step config takes priority\n   209→\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   210→\t\tpath := e.stepOutputPath(ps)\n   211→\t\tif _, err := os.Stat(path); err == nil {\n   212→\t\t\treturn path\n   213→\t\t}\n   214→\t}\n   215→\n   216→\t// Walk wiring to find the step that feeds into this one\n   217→\tfor _, w := range e.Wires {\n   218→\t\tif w.To == step.Name {\n   219→\t\t\tpath := e.stepOutputPath(w.From)\n   220→\t\t\tif _, err := os.Stat(path); err == nil {\n   221→\t\t\t\treturn path\n   222→\t\t\t}\n   223→\t\t}\n   224→\t}\n   225→\treturn \"\"\n   226→}\n   227→"}]},"parent_tool_use_id":null,"session_id":"4396f712-f062-4883-ba52-ad58e85081ed","uuid":"d64b4a20-ecf2-422d-b5aa-3b638a072278","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor.go","content":"\tProjectDir string\n\tDispatcher RunDispatcher\n\tStore      ports.RunStore\n\tOutputDir  string         // directory for step output files\n\tWires      []domain.Wire  // workflow wiring (for output mappings)\n}\n\nvar _ engine.StepExecutor = (*Executor)(nil)\n\n// Execute runs a single host workflow step.\nfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\treturn e.executeScript(ctx, step)\n\tcase domain.StepTypeWorkflow:\n\t\treturn e.executeWorkflow(ctx, step)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n\t}\n}\n\n// executeScript runs a shell command on the host.\nfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n\tcmdStr := step.Config[\"run\"]\n\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n\tcmd.Dir = e.ProjectDir\n\tcmd.Env = append(os.Environ(),\n\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n\t)\n\n\t// Pass previous step output if available\n\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n\t}\n\n\t// Resolve output mappings from wires and add as env vars\n\tif len(e.Wires) > 0 {\n\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n\t\t}\n\t\tcmd.Env = append(cmd.Env, mapped...)\n\t}\n\n\toutput, err := cmd.CombinedOutput()\n\n\t// Extract result marker\n\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n\n\t// Write output to file\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n\t}\n\n\tif err != nil {\n\t\tif _, ok := err.(*exec.ExitError); ok {\n\t\t\tresult := \"fail\"\n\t\t\tif found {\n\t\t\t\tresult = markerResult\n\t\t\t}\n\t\t\treturn result, nil\n\t\t}\n\t\treturn \"\", err\n\t}\n\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, nil\n}\n\n// executeWorkflow dispatches a container workflow run and blocks until it completes.\nfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n\tworkflowName := step.Config[\"workflow_name\"]\n\tif workflowName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n\t}\n\n\t// Read prompt from previous step output or prompt_step override\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tdata, err := os.ReadFile(prev)\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName: workflowName,\n\t\tProjectDir:   e.ProjectDir,\n\t\tPrompt:       promptContent,\n\t})\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n\t}\n\n\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n\n\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n\t}\n\n\t// Poll until the run reaches a terminal state\n\tstate, err := e.waitForRun(ctx, resp.RunId)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n\t}\n\n\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n\n\t// Map run state to step result\n\tif state == domain.RunStateSucceeded {\n\t\treturn \"success\", nil\n\t}\n\treturn \"fail\", nil\n}\n\n// waitForRun polls the store until the run reaches a terminal state.\nfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n\tticker := time.NewTicker(2 * time.Second)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n\t\tcase <-ticker.C:\n\t\t\trun, err := e.Store.GetRun(ctx, runID)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // transient error, retry\n\t\t\t}\n\t\t\tswitch run.State {\n\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n\t\t\t\treturn run.State, nil\n\t\t\t}\n\t\t\t// Still pending or running, continue polling\n\t\t}\n\t}\n}\n\n// stepOutputPath returns the path for a step's output file.\nfunc (e *Executor) stepOutputPath(stepName string) string {\n\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n}\n\n// findPrevOutput finds the output file from the step that wires into this one.\n// It checks prompt_step config first, then walks the wiring graph to find the\n// source step.\nfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n\t// Explicit prompt_step config takes priority\n\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n\t\tpath := e.stepOutputPath(ps)\n\t\tif _, err := os.Stat(path); err == nil {\n\t\t\treturn path\n\t\t}\n\t}\n\n\t// Walk wiring to find the step that feeds into this one\n\tfor _, w := range e.Wires {\n\t\tif w.To == step.Name {\n\t\t\tpath := e.stepOutputPath(w.From)\n\t\t\tif _, err := os.Stat(path); err == nil {\n\t\t\t\treturn path\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n","numLines":178,"startLine":50,"totalLines":227}}}
