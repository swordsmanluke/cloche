{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EkqaQB3BNqCct6bAVMCqtg","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    19→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    20→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    21→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    22→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    23→\trpcgrpc \"google.golang.org/grpc\"\n    24→)\n    25→\n    26→type ClocheServer struct {\n    27→\tpb.UnimplementedClocheServiceServer\n    28→\tstore        ports.RunStore\n    29→\tcaptures     ports.CaptureStore\n    30→\tlogStore     ports.LogStore\n    31→\tcontainer    ports.ContainerRuntime\n    32→\tdefaultImage string\n    33→\tevolution    *evolution.Trigger\n    34→\tlogBroadcast *logstream.Broadcaster\n    35→\tshutdownFn   func()\n    36→\tmu           sync.Mutex\n    37→\trunIDs       map[string]string // run_id -> container_id\n    38→}\n    39→\n    40→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    41→\treturn &ClocheServer{\n    42→\t\tstore:     store,\n    43→\t\tcontainer: container,\n    44→\t\trunIDs:    make(map[string]string),\n    45→\t}\n    46→}\n    47→\n    48→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    49→\treturn &ClocheServer{\n    50→\t\tstore:        store,\n    51→\t\tcaptures:     captures,\n    52→\t\tcontainer:    container,\n    53→\t\tdefaultImage: defaultImage,\n    54→\t\trunIDs:       make(map[string]string),\n    55→\t}\n    56→}\n    57→\n    58→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    59→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    60→\ts.logStore = ls\n    61→}\n    62→\n    63→\n    64→// SetEvolution attaches an evolution trigger to the server.\n    65→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    66→\ts.evolution = trigger\n    67→}\n    68→\n    69→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    70→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    71→\ts.logBroadcast = b\n    72→}\n    73→\n    74→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    75→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    76→\ts.shutdownFn = fn\n    77→}\n    78→\n    79→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    80→\tif s.container == nil {\n    81→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    82→\t}\n    83→\n    84→\t// Generate a unique run ID, retrying on collision\n    85→\tvar runID string\n    86→\tfor attempts := 0; attempts < 10; attempts++ {\n    87→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    88→\t\texisting, err := s.store.GetRun(ctx, runID)\n    89→\t\tif err != nil {\n    90→\t\t\tbreak // ID is free\n    91→\t\t}\n    92→\t\t// Reuse if completed more than 1 hour ago\n    93→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n    94→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n    95→\t\t\tbreak\n    96→\t\t}\n    97→\t}\n    98→\n    99→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   100→\tif req.Prompt != \"\" {\n   101→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   102→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   103→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   104→\t\t}\n   105→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   106→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   107→\t\t}\n   108→\t}\n   109→\trun := domain.NewRun(runID, req.WorkflowName)\n   110→\trun.ProjectDir = req.ProjectDir\n   111→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   112→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   113→\t}\n   114→\n   115→\t// Resolve image: request-level override, then server default\n   116→\timage := req.Image\n   117→\tif image == \"\" {\n   118→\t\timage = s.defaultImage\n   119→\t}\n   120→\n   121→\t// Launch container start + tracking in background so the RPC returns immediately.\n   122→\t// The run stays in \"pending\" state until the container is up.\n   123→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   124→\n   125→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   126→}\n   127→\n   128→// launchAndTrack starts the container and then tracks it to completion.\n   129→// It runs in a background goroutine with its own context, independent of the\n   130→// RPC context which may be cancelled after RunWorkflow returns.\n   131→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   132→\tctx := context.Background()\n   133→\n   134→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   135→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   136→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   137→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   138→\t\t\tif run != nil {\n   139→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   140→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   141→\t\t\t}\n   142→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   143→\t\t\t\treturn\n   144→\t\t}\n   145→\t}\n   146→\n   147→\tbaseSHA := gitHEAD(req.ProjectDir)\n   148→\n   149→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   150→\t\tImage:        image,\n   151→\t\tWorkflowName: req.WorkflowName,\n   152→\t\tProjectDir:   req.ProjectDir,\n   153→\t\tRunID:        runID,\n   154→\t\tNetworkAllow: []string{\"*\"},\n   155→\t})\n   156→\tif err != nil {\n   157→\t\trun, _ := s.store.GetRun(ctx, runID)\n   158→\t\tif run != nil {\n   159→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   160→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   161→\t\t}\n   162→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   163→\t\treturn\n   164→\t}\n   165→\n   166→\ts.mu.Lock()\n   167→\ts.runIDs[runID] = containerID\n   168→\ts.mu.Unlock()\n   169→\n   170→\trun, _ := s.store.GetRun(ctx, runID)\n   171→\tif run != nil {\n   172→\t\trun.Start()\n   173→\t\trun.ContainerID = containerID\n   174→\t\trun.BaseSHA = baseSHA\n   175→\t\t_ = s.store.UpdateRun(ctx, run)\n   176→\t}\n   177→\n   178→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   179→}\n   180→\n   181→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   182→\tctx := context.Background()\n   183→\n   184→\t// Attach to agent output\n   185→\treader, err := s.container.AttachOutput(ctx, containerID)\n   186→\tif err != nil {\n   187→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   188→\t\t\treturn\n   189→\t}\n   190→\n   191→\t// Parse JSON-lines status messages\n   192→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   193→\tscanner := bufio.NewScanner(reader)\n   194→\tfor scanner.Scan() {\n   195→\t\tvar msg protocol.StatusMessage\n   196→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   197→\t\t\tcontinue\n   198→\t\t}\n   199→\n   200→\t\t// Fast path: log messages don't need store interaction."}]},"parent_tool_use_id":"toolu_018WtRq7zeWYM3FtLD39VQkt","session_id":"4396f712-f062-4883-ba52-ad58e85081ed","uuid":"da7365fa-ccd0-41b4-b107-7c10d8d28ccf"}
