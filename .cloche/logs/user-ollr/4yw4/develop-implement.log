{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H5Q32U5Q69RB3kQvssKHva","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1>\n     3→    <a href=\"/runs\">Runs</a> / {{.Run.ID}}\n     4→    <span class=\"badge badge-{{stateColor .Run.State}}\">{{.Run.State}}</span>\n     5→</h1>\n     6→\n     7→<div class=\"run-meta\">\n     8→    <dl>\n     9→        <dt>Workflow</dt><dd>{{.Run.WorkflowName}}</dd>\n    10→        <dt>Started</dt><dd>{{formatTime .Run.StartedAt}}</dd>\n    11→        <dt>Completed</dt><dd>{{formatTime .Run.CompletedAt}}</dd>\n    12→        <dt>Container</dt><dd class=\"mono\">{{.Run.ContainerID}}</dd>\n    13→        <dt>Container Status</dt>\n    14→        <dd id=\"container-status\">\n    15→            {{if eq .ContainerState \"running\"}}\n    16→                <span class=\"badge badge-running\">Container running</span>\n    17→            {{else if eq .ContainerState \"stopped\"}}\n    18→                <span class=\"badge badge-stopped\">Container stopped</span>\n    19→                {{if or (eq .Run.State \"succeeded\") (eq .Run.State \"failed\") (eq .Run.State \"cancelled\")}}\n    20→                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n    21→                {{end}}\n    22→            {{else if eq .ContainerState \"available\"}}\n    23→                <span class=\"badge badge-succeeded\">Container available</span>\n    24→                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n    25→            {{else}}\n    26→                <span class=\"badge badge-pending\">Container removed</span>\n    27→            {{end}}\n    28→        </dd>\n    29→    </dl>\n    30→</div>\n    31→\n    32→{{if .Run.ErrorMessage}}\n    33→<div class=\"error-box\">{{.Run.ErrorMessage}}</div>\n    34→{{end}}\n    35→\n    36→<h2>Steps</h2>\n    37→<table class=\"runs-table\">\n    38→    <thead>\n    39→        <tr>\n    40→            <th>Step</th>\n    41→            <th>Result</th>\n    42→            <th>Started</th>\n    43→            <th>Duration</th>\n    44→        </tr>\n    45→    </thead>\n    46→    <tbody id=\"steps-body\">\n    47→    {{if .Steps}}\n    48→        {{range .Steps}}\n    49→        <tr class=\"step-row\" data-run-id=\"{{$.Run.ID}}\" data-step=\"{{.StepName}}\" data-index=\"{{.Index}}\">\n    50→            <td>{{.StepName}}</td>\n    51→            <td>{{if .Result}}<span class=\"badge badge-{{if eq .Result \"success\"}}succeeded{{else if eq .Result \"fail\"}}failed{{else}}pending{{end}}\">{{.Result}}</span>{{else}}<span class=\"badge badge-running\">running</span>{{end}}</td>\n    52→            <td>{{formatTime .StartedAt}}</td>\n    53→            <td>{{.Duration}}</td>\n    54→        </tr>\n    55→        <tr class=\"output-row\" id=\"output-{{.Index}}\" style=\"display:none\">\n    56→            <td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>\n    57→        </tr>\n    58→        {{end}}\n    59→    {{else}}\n    60→        <tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>\n    61→    {{end}}\n    62→    </tbody>\n    63→</table>\n    64→\n    65→<h2>\n    66→    Log\n    67→    <span id=\"log-status\" class=\"badge badge-running\" style=\"font-size:0.7rem; margin-left:0.5rem;\">Live</span>\n    68→</h2>\n    69→<div id=\"log-viewer\" class=\"log-viewer\"><pre id=\"log-content\"></pre></div>\n    70→{{end}}\n    71→\n    72→{{define \"scripts\"}}\n    73→<script>\n    74→(function() {\n    75→    var runState = '{{.Run.State}}';\n    76→    var runID = '{{.Run.ID}}';\n    77→\n    78→    // --- Log Viewer ---\n    79→    var logContent = document.getElementById('log-content');\n    80→    var logViewer = document.getElementById('log-viewer');\n    81→    var logStatus = document.getElementById('log-status');\n    82→    var autoScroll = true;\n    83→\n    84→    // Track scroll position to enable/disable auto-scroll\n    85→    logViewer.addEventListener('scroll', function() {\n    86→        var atBottom = logViewer.scrollHeight - logViewer.scrollTop - logViewer.clientHeight < 40;\n    87→        autoScroll = atBottom;\n    88→    });\n    89→\n    90→    function appendLogLine(line) {\n    91→        var span = document.createElement('span');\n    92→        span.className = 'log-line log-type-' + (line.type || 'script');\n    93→        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';\n    94→        logContent.appendChild(span);\n    95→        if (autoScroll) {\n    96→            logViewer.scrollTop = logViewer.scrollHeight;\n    97→        }\n    98→    }\n    99→\n   100→    function markComplete() {\n   101→        logStatus.textContent = 'Complete';\n   102→        logStatus.className = 'badge badge-succeeded';\n   103→    }\n   104→\n   105→    // Connect to SSE stream\n   106→    var source = new EventSource('/api/runs/' + runID + '/stream');\n   107→    source.onmessage = function(e) {\n   108→        try {\n   109→            var line = JSON.parse(e.data);\n   110→            appendLogLine(line);\n   111→        } catch(err) {}\n   112→    };\n   113→    source.addEventListener('done', function(e) {\n   114→        markComplete();\n   115→        source.close();\n   116→    });\n   117→    source.onerror = function() {\n   118→        markComplete();\n   119→        source.close();\n   120→    };\n   121→\n   122→    // If already complete, mark the badge immediately\n   123→    if (runState === 'succeeded' || runState === 'failed' || runState === 'cancelled') {\n   124→        logStatus.textContent = 'Complete';\n   125→        logStatus.className = 'badge badge-succeeded';\n   126→    }\n   127→\n   128→    // --- Steps Polling (for active runs) ---\n   129→    if (runState !== 'succeeded' && runState !== 'failed' && runState !== 'cancelled') {\n   130→        function poll() {\n   131→            fetch('/api/runs/' + runID)\n   132→                .then(function(r) { return r.json(); })\n   133→                .then(function(data) {\n   134→                    if (data.state !== runState) {\n   135→                        location.reload();\n   136→                        return;\n   137→                    }\n   138→                    // Update container status\n   139→                    var statusEl = document.getElementById('container-status');\n   140→                    if (statusEl && data.container_state) {\n   141→                        var cs = data.container_state;\n   142→                        if (cs === 'running') {\n   143→                            statusEl.innerHTML = '<span class=\"badge badge-running\">Container running</span>';\n   144→                        } else if (cs === 'stopped') {\n   145→                            var stoppedHtml = '<span class=\"badge badge-stopped\">Container stopped</span>';\n   146→                            if (data.state === 'succeeded' || data.state === 'failed' || data.state === 'cancelled') {\n   147→                                stoppedHtml += ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n   148→                            }\n   149→                            statusEl.innerHTML = stoppedHtml;\n   150→                        } else if (cs === 'available') {\n   151→                            statusEl.innerHTML = '<span class=\"badge badge-succeeded\">Container available</span>' +\n   152→                                ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n   153→                        } else {\n   154→                            statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n   155→                        }\n   156→                    }\n   157→                    var tbody = document.getElementById('steps-body');\n   158→                    if (!data.steps || data.steps.length === 0) {\n   159→                        tbody.innerHTML = '<tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>';\n   160→                        return;\n   161→                    }\n   162→\n   163→                    // Capture current accordion state before updating\n   164→                    var openAccordions = {};\n   165→                    var loadedOutputs = {};\n   166→                    var outputRows = tbody.querySelectorAll('.output-row');\n   167→                    for (var j = 0; j < outputRows.length; j++) {\n   168→                        var id = outputRows[j].id;\n   169→                        if (outputRows[j].style.display !== 'none') {\n   170→                            openAccordions[id] = true;\n   171→                        }\n   172→                        var pre = outputRows[j].querySelector('.step-output');\n   173→                        if (pre && pre.textContent !== 'Loading...') {\n   174→                            loadedOutputs[id] = pre.textContent;\n   175→                        }\n   176→                    }\n   177→\n   178→                    // Build updated step rows, preserving accordion state\n   179→                    var html = '';\n   180→                    for (var i = 0; i < data.steps.length; i++) {\n   181→                        var s = data.steps[i];\n   182→                        var badge = '';\n   183→                        if (s.result) {\n   184→                            var cls = s.result === 'success' ? 'succeeded' : s.result === 'fail' ? 'failed' : 'pending';\n   185→                            badge = '<span class=\"badge badge-' + cls + '\">' + escapeHtml(s.result) + '</span>';\n   186→                        } else {\n   187→                            badge = '<span class=\"badge badge-running\">running</span>';\n   188→                        }\n   189→                        var outputId = 'output-' + i;\n   190→                        var isOpen = openAccordions[outputId];\n   191→                        html += '<tr class=\"step-row\" data-run-id=\"' + escapeHtml(runID) + '\" data-step=\"' + escapeHtml(s.step_name) + '\" data-index=\"' + i + '\">' +\n   192→                            '<td>' + escapeHtml(s.step_name) + '</td>' +\n   193→                            '<td>' + badge + '</td>' +\n   194→                            '<td>' + s.started_at + '</td>' +\n   195→                            '<td>' + s.duration + '</td>' +\n   196→                            '</tr>' +\n   197→                            '<tr class=\"output-row\" id=\"' + outputId + '\"' + (isOpen ? '' : ' style=\"display:none\"') + '>' +\n   198→                            '<td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>' +\n   199→                            '</tr>';\n   200→                    }\n   201→                    tbody.innerHTML = html;\n   202→\n   203→                    // Restore loaded output content for open accordions\n   204→                    for (var key in loadedOutputs) {\n   205→                        var row = document.getElementById(key);\n   206→                        if (row) {\n   207→                            var pre = row.querySelector('.step-output');\n   208→                            if (pre) {\n   209→                                pre.textContent = loadedOutputs[key];\n   210→                            }\n   211→                        }\n   212→                    }\n   213→\n   214→                    // Re-fetch output for accordions that were open but had no cached content\n   215→                    for (var key in openAccordions) {\n   216→                        if (!loadedOutputs[key]) {\n   217→                            var row = document.getElementById(key);\n   218→                            if (row) {\n   219→                                var stepRow = row.previousElementSibling;\n   220→                                if (stepRow && stepRow.dataset.runId && stepRow.dataset.step) {\n   221→                                    (function(r, rid, sname) {\n   222→                                        var pre = r.querySelector('.step-output');\n   223→                                        fetch('/api/runs/' + rid + '/steps/' + sname + '/output')\n   224→                                            .then(function(resp) {\n   225→                                                if (!resp.ok) return 'No output available.';\n   226→                                                return resp.text();\n   227→                                            })\n   228→                                            .then(function(text) { pre.textContent = text; })\n   229→                                            .catch(function() { pre.textContent = 'Failed to load output.'; });\n   230→                                    })(row, stepRow.dataset.runId, stepRow.dataset.step);\n   231→                                }\n   232→                            }\n   233→                        }\n   234→                    }\n   235→                })\n   236→                .catch(function() {});\n   237→        }\n   238→        setInterval(poll, 2000);\n   239→    }\n   240→\n   241→    function escapeHtml(s) {\n   242→        if (!s) return '';\n   243→        var d = document.createElement('div');\n   244→        d.appendChild(document.createTextNode(s));\n   245→        return d.innerHTML;\n   246→    }\n   247→})();\n   248→\n   249→// Delete container\n   250→    window.deleteContainer = function(runID) {\n   251→        var btn = document.getElementById('delete-container-btn');\n   252→        if (btn) btn.disabled = true;\n   253→        fetch('/api/runs/' + runID + '/container', { method: 'DELETE' })\n   254→            .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })\n   255→            .then(function(res) {\n   256→                var statusEl = document.getElementById('container-status');\n   257→                if (res.ok) {\n   258→                    statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n   259→                } else {\n   260→                    if (btn) btn.disabled = false;\n   261→                    alert('Failed to delete container: ' + (res.data.error || 'unknown error'));\n   262→                }\n   263→            })\n   264→            .catch(function() {\n   265→                if (btn) btn.disabled = false;\n   266→                alert('Failed to delete container');\n   267→            });\n   268→    };\n   269→\n   270→    // Toggle step output rows\n   271→document.addEventListener('click', function(e) {\n   272→    var row = e.target.closest('.step-row');\n   273→    if (!row) return;\n   274→    var idx = row.dataset.index;\n   275→    var outputRow = document.getElementById('output-' + idx);\n   276→    if (!outputRow) return;\n   277→\n   278→    if (outputRow.style.display === 'none') {\n   279→        outputRow.style.display = '';\n   280→        var pre = outputRow.querySelector('.step-output');\n   281→        if (pre.textContent === 'Loading...') {\n   282→            var runId = row.dataset.runId;\n   283→            var step = row.dataset.step;\n   284→            fetch('/api/runs/' + runId + '/steps/' + step + '/output')\n   285→                .then(function(r) {\n   286→                    if (!r.ok) return 'No output available.';\n   287→                    return r.text();\n   288→                })\n   289→                .then(function(text) { pre.textContent = text; })\n   290→                .catch(function() { pre.textContent = 'Failed to load output.'; });\n   291→        }\n   292→    } else {\n   293→        outputRow.style.display = 'none';\n   294→    }\n   295→});\n   296→</script>\n   297→{{end}}\n   298→"}]},"parent_tool_use_id":null,"session_id":"4396f712-f062-4883-ba52-ad58e85081ed","uuid":"9848efd4-80cf-40f8-bfc4-cae44fb707af","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/run_detail.html","content":"{{define \"content\"}}\n<h1>\n    <a href=\"/runs\">Runs</a> / {{.Run.ID}}\n    <span class=\"badge badge-{{stateColor .Run.State}}\">{{.Run.State}}</span>\n</h1>\n\n<div class=\"run-meta\">\n    <dl>\n        <dt>Workflow</dt><dd>{{.Run.WorkflowName}}</dd>\n        <dt>Started</dt><dd>{{formatTime .Run.StartedAt}}</dd>\n        <dt>Completed</dt><dd>{{formatTime .Run.CompletedAt}}</dd>\n        <dt>Container</dt><dd class=\"mono\">{{.Run.ContainerID}}</dd>\n        <dt>Container Status</dt>\n        <dd id=\"container-status\">\n            {{if eq .ContainerState \"running\"}}\n                <span class=\"badge badge-running\">Container running</span>\n            {{else if eq .ContainerState \"stopped\"}}\n                <span class=\"badge badge-stopped\">Container stopped</span>\n                {{if or (eq .Run.State \"succeeded\") (eq .Run.State \"failed\") (eq .Run.State \"cancelled\")}}\n                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n                {{end}}\n            {{else if eq .ContainerState \"available\"}}\n                <span class=\"badge badge-succeeded\">Container available</span>\n                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n            {{else}}\n                <span class=\"badge badge-pending\">Container removed</span>\n            {{end}}\n        </dd>\n    </dl>\n</div>\n\n{{if .Run.ErrorMessage}}\n<div class=\"error-box\">{{.Run.ErrorMessage}}</div>\n{{end}}\n\n<h2>Steps</h2>\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Step</th>\n            <th>Result</th>\n            <th>Started</th>\n            <th>Duration</th>\n        </tr>\n    </thead>\n    <tbody id=\"steps-body\">\n    {{if .Steps}}\n        {{range .Steps}}\n        <tr class=\"step-row\" data-run-id=\"{{$.Run.ID}}\" data-step=\"{{.StepName}}\" data-index=\"{{.Index}}\">\n            <td>{{.StepName}}</td>\n            <td>{{if .Result}}<span class=\"badge badge-{{if eq .Result \"success\"}}succeeded{{else if eq .Result \"fail\"}}failed{{else}}pending{{end}}\">{{.Result}}</span>{{else}}<span class=\"badge badge-running\">running</span>{{end}}</td>\n            <td>{{formatTime .StartedAt}}</td>\n            <td>{{.Duration}}</td>\n        </tr>\n        <tr class=\"output-row\" id=\"output-{{.Index}}\" style=\"display:none\">\n            <td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>\n        </tr>\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n\n<h2>\n    Log\n    <span id=\"log-status\" class=\"badge badge-running\" style=\"font-size:0.7rem; margin-left:0.5rem;\">Live</span>\n</h2>\n<div id=\"log-viewer\" class=\"log-viewer\"><pre id=\"log-content\"></pre></div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var runState = '{{.Run.State}}';\n    var runID = '{{.Run.ID}}';\n\n    // --- Log Viewer ---\n    var logContent = document.getElementById('log-content');\n    var logViewer = document.getElementById('log-viewer');\n    var logStatus = document.getElementById('log-status');\n    var autoScroll = true;\n\n    // Track scroll position to enable/disable auto-scroll\n    logViewer.addEventListener('scroll', function() {\n        var atBottom = logViewer.scrollHeight - logViewer.scrollTop - logViewer.clientHeight < 40;\n        autoScroll = atBottom;\n    });\n\n    function appendLogLine(line) {\n        var span = document.createElement('span');\n        span.className = 'log-line log-type-' + (line.type || 'script');\n        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';\n        logContent.appendChild(span);\n        if (autoScroll) {\n            logViewer.scrollTop = logViewer.scrollHeight;\n        }\n    }\n\n    function markComplete() {\n        logStatus.textContent = 'Complete';\n        logStatus.className = 'badge badge-succeeded';\n    }\n\n    // Connect to SSE stream\n    var source = new EventSource('/api/runs/' + runID + '/stream');\n    source.onmessage = function(e) {\n        try {\n            var line = JSON.parse(e.data);\n            appendLogLine(line);\n        } catch(err) {}\n    };\n    source.addEventListener('done', function(e) {\n        markComplete();\n        source.close();\n    });\n    source.onerror = function() {\n        markComplete();\n        source.close();\n    };\n\n    // If already complete, mark the badge immediately\n    if (runState === 'succeeded' || runState === 'failed' || runState === 'cancelled') {\n        logStatus.textContent = 'Complete';\n        logStatus.className = 'badge badge-succeeded';\n    }\n\n    // --- Steps Polling (for active runs) ---\n    if (runState !== 'succeeded' && runState !== 'failed' && runState !== 'cancelled') {\n        function poll() {\n            fetch('/api/runs/' + runID)\n                .then(function(r) { return r.json(); })\n                .then(function(data) {\n                    if (data.state !== runState) {\n                        location.reload();\n                        return;\n                    }\n                    // Update container status\n                    var statusEl = document.getElementById('container-status');\n                    if (statusEl && data.container_state) {\n                        var cs = data.container_state;\n                        if (cs === 'running') {\n                            statusEl.innerHTML = '<span class=\"badge badge-running\">Container running</span>';\n                        } else if (cs === 'stopped') {\n                            var stoppedHtml = '<span class=\"badge badge-stopped\">Container stopped</span>';\n                            if (data.state === 'succeeded' || data.state === 'failed' || data.state === 'cancelled') {\n                                stoppedHtml += ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n                            }\n                            statusEl.innerHTML = stoppedHtml;\n                        } else if (cs === 'available') {\n                            statusEl.innerHTML = '<span class=\"badge badge-succeeded\">Container available</span>' +\n                                ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n                        } else {\n                            statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n                        }\n                    }\n                    var tbody = document.getElementById('steps-body');\n                    if (!data.steps || data.steps.length === 0) {\n                        tbody.innerHTML = '<tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>';\n                        return;\n                    }\n\n                    // Capture current accordion state before updating\n                    var openAccordions = {};\n                    var loadedOutputs = {};\n                    var outputRows = tbody.querySelectorAll('.output-row');\n                    for (var j = 0; j < outputRows.length; j++) {\n                        var id = outputRows[j].id;\n                        if (outputRows[j].style.display !== 'none') {\n                            openAccordions[id] = true;\n                        }\n                        var pre = outputRows[j].querySelector('.step-output');\n                        if (pre && pre.textContent !== 'Loading...') {\n                            loadedOutputs[id] = pre.textContent;\n                        }\n                    }\n\n                    // Build updated step rows, preserving accordion state\n                    var html = '';\n                    for (var i = 0; i < data.steps.length; i++) {\n                        var s = data.steps[i];\n                        var badge = '';\n                        if (s.result) {\n                            var cls = s.result === 'success' ? 'succeeded' : s.result === 'fail' ? 'failed' : 'pending';\n                            badge = '<span class=\"badge badge-' + cls + '\">' + escapeHtml(s.result) + '</span>';\n                        } else {\n                            badge = '<span class=\"badge badge-running\">running</span>';\n                        }\n                        var outputId = 'output-' + i;\n                        var isOpen = openAccordions[outputId];\n                        html += '<tr class=\"step-row\" data-run-id=\"' + escapeHtml(runID) + '\" data-step=\"' + escapeHtml(s.step_name) + '\" data-index=\"' + i + '\">' +\n                            '<td>' + escapeHtml(s.step_name) + '</td>' +\n                            '<td>' + badge + '</td>' +\n                            '<td>' + s.started_at + '</td>' +\n                            '<td>' + s.duration + '</td>' +\n                            '</tr>' +\n                            '<tr class=\"output-row\" id=\"' + outputId + '\"' + (isOpen ? '' : ' style=\"display:none\"') + '>' +\n                            '<td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>' +\n                            '</tr>';\n                    }\n                    tbody.innerHTML = html;\n\n                    // Restore loaded output content for open accordions\n                    for (var key in loadedOutputs) {\n                        var row = document.getElementById(key);\n                        if (row) {\n                            var pre = row.querySelector('.step-output');\n                            if (pre) {\n                                pre.textContent = loadedOutputs[key];\n                            }\n                        }\n                    }\n\n                    // Re-fetch output for accordions that were open but had no cached content\n                    for (var key in openAccordions) {\n                        if (!loadedOutputs[key]) {\n                            var row = document.getElementById(key);\n                            if (row) {\n                                var stepRow = row.previousElementSibling;\n                                if (stepRow && stepRow.dataset.runId && stepRow.dataset.step) {\n                                    (function(r, rid, sname) {\n                                        var pre = r.querySelector('.step-output');\n                                        fetch('/api/runs/' + rid + '/steps/' + sname + '/output')\n                                            .then(function(resp) {\n                                                if (!resp.ok) return 'No output available.';\n                                                return resp.text();\n                                            })\n                                            .then(function(text) { pre.textContent = text; })\n                                            .catch(function() { pre.textContent = 'Failed to load output.'; });\n                                    })(row, stepRow.dataset.runId, stepRow.dataset.step);\n                                }\n                            }\n                        }\n                    }\n                })\n                .catch(function() {});\n        }\n        setInterval(poll, 2000);\n    }\n\n    function escapeHtml(s) {\n        if (!s) return '';\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n})();\n\n// Delete container\n    window.deleteContainer = function(runID) {\n        var btn = document.getElementById('delete-container-btn');\n        if (btn) btn.disabled = true;\n        fetch('/api/runs/' + runID + '/container', { method: 'DELETE' })\n            .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })\n            .then(function(res) {\n                var statusEl = document.getElementById('container-status');\n                if (res.ok) {\n                    statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n                } else {\n                    if (btn) btn.disabled = false;\n                    alert('Failed to delete container: ' + (res.data.error || 'unknown error'));\n                }\n            })\n            .catch(function() {\n                if (btn) btn.disabled = false;\n                alert('Failed to delete container');\n            });\n    };\n\n    // Toggle step output rows\ndocument.addEventListener('click', function(e) {\n    var row = e.target.closest('.step-row');\n    if (!row) return;\n    var idx = row.dataset.index;\n    var outputRow = document.getElementById('output-' + idx);\n    if (!outputRow) return;\n\n    if (outputRow.style.display === 'none') {\n        outputRow.style.display = '';\n        var pre = outputRow.querySelector('.step-output');\n        if (pre.textContent === 'Loading...') {\n            var runId = row.dataset.runId;\n            var step = row.dataset.step;\n            fetch('/api/runs/' + runId + '/steps/' + step + '/output')\n                .then(function(r) {\n                    if (!r.ok) return 'No output available.';\n                    return r.text();\n                })\n                .then(function(text) { pre.textContent = text; })\n                .catch(function() { pre.textContent = 'Failed to load output.'; });\n        }\n    } else {\n        outputRow.style.display = 'none';\n    }\n});\n</script>\n{{end}}\n","numLines":298,"startLine":1,"totalLines":298}}}
