 535→}\n   536→\n   537→.drawer-body pre {\n   538→    background: var(--bg);\n   539→    border: 1px solid var(--border);\n   540→    border-radius: var(--radius);\n   541→    padding: 0.75rem;\n   542→    font-family: var(--mono);\n   543→    font-size: 0.8rem;\n   544→    max-height: 400px;\n   545→    overflow: auto;\n   546→    white-space: pre-wrap;\n   547→    word-break: break-word;\n   548→}\n   549→\n   550→/* Diff block */\n   551→.diff-block {\n   552→    background: var(--bg);\n   553→    border: 1px solid var(--border);\n   554→    border-radius: var(--radius);\n   555→    padding: 0.5rem;\n   556→    font-family: var(--mono);\n   557→    font-size: 0.75rem;\n   558→    max-height: 300px;\n   559→    overflow: auto;\n   560→    white-space: pre-wrap;\n   561→    word-break: break-word;\n   562→    margin: 0.25rem 0 0.5rem;\n   563→}\n   564→\n   565→/* Orchestrator status */\n   566→.orch-status { font-size: 0.9rem; }\n   567→\n   568→/* Responsive */\n   569→@media (max-width: 768px) {\n   570→    .runs-table { font-size: 0.8rem; }\n   571→    .runs-table th, .runs-table td { padding: 0.4rem 0.5rem; }\n   572→    .run-meta dl { grid-template-columns: 1fr; }\n   573→    .project-cards { grid-template-columns: 1fr; }\n   574→    .log-viewer { max-height: 400px; }\n   575→    .drawer { width: 100%; right: -100%; }\n   576→}\n   577→"}]},"parent_tool_use_id":"toolu_01L8HuAFH84UiejecX1Ag1xY","session_id":"c346fded-e5bd-469d-af11-5003ae2a312d","uuid":"3b721908-b9fc-4818-9437-eaadec6c6d6d"}
