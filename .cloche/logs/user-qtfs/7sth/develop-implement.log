{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EoLD8nEbkFcCxZ7U5SG6Tx","type":"tool_result","content":"     1→package agent\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"io\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n    12→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    15→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    17→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    18→)\n    19→\n    20→type RunnerConfig struct {\n    21→\tWorkflowPath string\n    22→\tWorkDir      string\n    23→\tStatusOutput io.Writer\n    24→\tRunID        string\n    25→}\n    26→\n    27→type Runner struct {\n    28→\tcfg RunnerConfig\n    29→}\n    30→\n    31→func NewRunner(cfg RunnerConfig) *Runner {\n    32→\treturn &Runner{\n    33→\t\tcfg: cfg,\n    34→\t}\n    35→}\n    36→\n    37→func (r *Runner) Run(ctx context.Context) error {\n    38→\tdata, err := os.ReadFile(r.cfg.WorkflowPath)\n    39→\tif err != nil {\n    40→\t\treturn fmt.Errorf(\"reading workflow file: %w\", err)\n    41→\t}\n    42→\n    43→\twf, err := dsl.ParseForContainer(string(data))\n    44→\tif err != nil {\n    45→\t\treturn fmt.Errorf(\"parsing workflow: %w\", err)\n    46→\t}\n    47→\n    48→\tstatusWriter := protocol.NewStatusWriter(r.cfg.StatusOutput)\n    49→\tgenericAdapter := generic.New()\n    50→\tpromptAdapter := prompt.New()\n    51→\tpromptAdapter.RunID = r.cfg.RunID\n    52→\tpromptAdapter.StatusWriter = statusWriter\n    53→\tif cmd, ok := os.LookupEnv(\"CLOCHE_AGENT_COMMAND\"); ok {\n    54→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    55→\t}\n    56→\tif cmd := wf.Config[\"container.agent_command\"]; cmd != \"\" {\n    57→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    58→\t}\n    59→\tif args := wf.Config[\"container.agent_args\"]; args != \"\" {\n    60→\t\tpromptAdapter.ExplicitArgs = strings.Fields(args)\n    61→\t}\n    62→\n    63→\t// Reset per-run state from any previous run\n    64→\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"attempt_count\"))\n    65→\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"output\"))\n    66→\n    67→\t// Create unified log writer\n    68→\tulog, err := logstream.New(r.cfg.WorkDir)\n    69→\tif err != nil {\n    70→\t\treturn fmt.Errorf(\"creating unified log: %w\", err)\n    71→\t}\n    72→\tdefer ulog.Close()\n    73→\n    74→\texecutor := &stepExecutor{\n    75→\t\tworkDir:   r.cfg.WorkDir,\n    76→\t\tgeneric:   genericAdapter,\n    77→\t\tprompt:    promptAdapter,\n    78→\t\tlogStream: ulog,\n    79→\t}\n    80→\n    81→\teng := engine.New(executor)\n    82→\teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n    83→\n    84→\t// Generate a run title from the prompt if one was not provided by the caller.\n    85→\t// The daemon sets title from --title; if empty, the agent extracts from prompt.\n    86→\tif title := extractTitle(r.cfg.WorkDir, r.cfg.RunID); title != \"\" {\n    87→\t\tstatusWriter.RunTitle(title)\n    88→\t}\n    89→\n    90→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n    91→\n    92→\trun, runErr := eng.Run(ctx, wf)\n    93→\tif runErr != nil {\n    94→\t\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:failed\")\n    95→\t\tulog.Log(logstream.TypeStatus, \"error: \"+runErr.Error())\n    96→\t\tulog.Log(logstream.TypeStatus, \"run_completed: failed\")\n    97→\t\tstatusWriter.Error(\"\", runErr.Error())\n    98→\t\tstatusWriter.RunCompleted(\"failed\")\n    99→\t\treturn runErr\n   100→\t}\n   101→\n   102→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:\"+string(run.State))\n   103→\n   104→\tulog.Log(logstream.TypeStatus, \"run_completed: \"+string(run.State))\n   105→\tstatusWriter.RunCompleted(string(run.State))\n   106→\treturn nil\n   107→}\n   108→\n   109→type stepExecutor struct {\n   110→\tworkDir   string\n   111→\tgeneric   *generic.Adapter\n   112→\tprompt    *prompt.Adapter\n   113→\tlogStream *logstream.Writer\n   114→}\n   115→\n   116→func (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n   117→\tswitch step.Type {\n   118→\tcase domain.StepTypeScript:\n   119→\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   120→\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   121→\t\treturn result, err\n   122→\tcase domain.StepTypeAgent:\n   123→\t\tif _, ok := step.Config[\"run\"]; ok {\n   124→\t\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   125→\t\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   126→\t\t\treturn result, err\n   127→\t\t}\n   128→\t\tif _, ok := step.Config[\"prompt\"]; ok {\n   129→\t\t\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   130→\t\t\t\te.prompt.Commands = prompt.ParseCommands(cmd)\n   131→\t\t\t}\n   132→\t\t\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   133→\t\t\t\te.prompt.ExplicitArgs = strings.Fields(args)\n   134→\t\t\t}\n   135→\t\t\tresult, err := e.prompt.Execute(ctx, step, e.workDir)\n   136→\t\t\te.copyToLLMLog(step.Name)\n   137→\t\t\te.logStepOutput(step.Name, logstream.TypeLLM)\n   138→\t\t\treturn result, err\n   139→\t\t}\n   140→\t\treturn \"\", fmt.Errorf(\"agent step %q requires either 'run' or 'prompt' config\", step.Name)\n   141→\tdefault:\n   142→\t\treturn \"\", fmt.Errorf(\"unknown step type: %s\", step.Type)\n   143→\t}\n   144→}\n   145→\n   146→// logStepOutput reads the per-step log file and writes its contents to the unified log.\n   147→func (e *stepExecutor) logStepOutput(stepName string, typ logstream.EntryType) {\n   148→\tpath := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   149→\tdata, err := os.ReadFile(path)\n   150→\tif err != nil || len(data) == 0 {\n   151→\t\treturn\n   152→\t}\n   153→\te.logStream.Log(typ, string(data))\n   154→}\n   155→\n   156→// copyToLLMLog copies <step>.log to llm-<step>.log for agent prompt steps.\n   157→func (e *stepExecutor) copyToLLMLog(stepName string) {\n   158→\tsrc := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   159→\tdst := filepath.Join(e.workDir, \".cloche\", \"output\", \"llm-\"+stepName+\".log\")\n   160→\tdata, err := os.ReadFile(src)\n   161→\tif err != nil {\n   162→\t\treturn\n   163→\t}\n   164→\t_ = os.WriteFile(dst, data, 0644)\n   165→}\n   166→\n   167→type statusReporter struct {\n   168→\twriter    *protocol.StatusWriter\n   169→\tlogStream *logstream.Writer\n   170→}\n   171→\n   172→func (s *statusReporter) OnStepStart(_ *domain.Run, step *domain.Step) {\n   173→\ts.writer.StepStarted(step.Name)\n   174→\ts.logStream.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n   175→}\n   176→\n   177→func (s *statusReporter) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   178→\ts.writer.StepCompleted(step.Name, result)\n   179→\ts.logStream.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n   180→}\n   181→\n   182→func (s *statusReporter) OnRunComplete(_ *domain.Run) {}\n   183→\n   184→// extractTitle tries to derive a one-line summary from the run's prompt content.\n   185→// It reads the per-run prompt.txt file (written by the daemon before container start),\n   186→// then returns the first non-empty line, truncated to 100 characters.\n   187→func extractTitle(workDir string, runID string) string {\n   188→\t// Try the per-run prompt file\n   189→\tpromptPath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   190→\tif _, err := os.Stat(promptPath); err != nil {\n   191→\t\t// Fall back to legacy path\n   192→\t\tpromptPath = filepath.Join(workDir, \".cloche\", \"prompt.txt\")\n   193→\t}\n   194→\tdata, err := os.ReadFile(promptPath)\n   195→\tif err != nil || len(data) == 0 {\n   196→\t\treturn \"\"\n   197→\t}\n   198→\n   199→\ttext := strings.TrimSpace(string(data))\n   200→\tif text == \"\" {\n   201→\t\treturn \"\"\n   202→\t}\n   203→\n   204→\t// Take first non-empty line as the title\n   205→\tfor _, line := range strings.Split(text, \"\\n\") {\n   206→\t\tline = strings.TrimSpace(line)\n   207→\t\t// Skip markdown headers, comment markers, and blank lines\n   208→\t\tif line == \"\" || line == \"---\" || line == \"```\" {\n   209→\t\t\tcontinue\n   210→\t\t}\n   211→\t\t// Strip leading markdown header markers\n   212→\t\tline = strings.TrimLeft(line, \"# \")\n   213→\t\tline = strings.TrimSpace(line)\n   214→\t\tif line == \"\" {\n   215→\t\t\tcontinue\n   216→\t\t}\n   217→\t\tif len(line) > 100 {\n   218→\t\t\tline = line[:97] + \"...\"\n   219→\t\t}\n   220→\t\treturn line\n   221→\t}\n   222→\treturn \"\"\n   223→}\n   224→"}]},"parent_tool_use_id":"toolu_01CnzPH3TfTkngibK1zZgL3t","session_id":"b192fff1-2075-40cb-b513-cbbf26873af4","uuid":"bd367337-0e5d-4c2f-a27f-44209f7d91b3"}
