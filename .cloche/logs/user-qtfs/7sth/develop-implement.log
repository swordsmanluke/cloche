{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P2vYk7csaf1z6hMM24YASD","type":"tool_result","content":"     1→package protocol\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"io\"\n     8→\t\"time\"\n     9→)\n    10→\n    11→type MessageType string\n    12→\n    13→const (\n    14→\tMsgStepStarted  MessageType = \"step_started\"\n    15→\tMsgStepCompleted MessageType = \"step_completed\"\n    16→\tMsgRunCompleted  MessageType = \"run_completed\"\n    17→\tMsgRunTitle      MessageType = \"run_title\"\n    18→\tMsgLog           MessageType = \"log\"\n    19→\tMsgError         MessageType = \"error\"\n    20→)\n    21→\n    22→type StatusMessage struct {\n    23→\tType      MessageType `json:\"type\"`\n    24→\tStepName  string      `json:\"step_name,omitempty\"`\n    25→\tResult    string      `json:\"result,omitempty\"`\n    26→\tMessage   string      `json:\"message,omitempty\"`\n    27→\tTimestamp time.Time   `json:\"timestamp\"`\n    28→}\n    29→\n    30→type StatusWriter struct {\n    31→\tw   io.Writer\n    32→\tenc *json.Encoder\n    33→}\n    34→\n    35→func NewStatusWriter(w io.Writer) *StatusWriter {\n    36→\treturn &StatusWriter{w: w, enc: json.NewEncoder(w)}\n    37→}\n    38→\n    39→func (s *StatusWriter) StepStarted(stepName string) {\n    40→\ts.write(StatusMessage{Type: MsgStepStarted, StepName: stepName})\n    41→}\n    42→\n    43→func (s *StatusWriter) StepCompleted(stepName, result string) {\n    44→\ts.write(StatusMessage{Type: MsgStepCompleted, StepName: stepName, Result: result})\n    45→}\n    46→\n    47→func (s *StatusWriter) RunCompleted(result string) {\n    48→\ts.write(StatusMessage{Type: MsgRunCompleted, Result: result})\n    49→}\n    50→\n    51→func (s *StatusWriter) RunTitle(title string) {\n    52→\ts.write(StatusMessage{Type: MsgRunTitle, Message: title})\n    53→}\n    54→\n    55→func (s *StatusWriter) Log(stepName, message string) {\n    56→\ts.write(StatusMessage{Type: MsgLog, StepName: stepName, Message: message})\n    57→}\n    58→\n    59→func (s *StatusWriter) Error(stepName, message string) {\n    60→\ts.write(StatusMessage{Type: MsgError, StepName: stepName, Message: message})\n    61→}\n    62→\n    63→func (s *StatusWriter) write(msg StatusMessage) {\n    64→\tmsg.Timestamp = time.Now()\n    65→\t_ = s.enc.Encode(msg)\n    66→}\n    67→\n    68→func ParseStatusStream(data []byte) ([]StatusMessage, error) {\n    69→\tvar msgs []StatusMessage\n    70→\tdec := json.NewDecoder(bytes.NewReader(data))\n    71→\tfor dec.More() {\n    72→\t\tvar msg StatusMessage\n    73→\t\tif err := dec.Decode(&msg); err != nil {\n    74→\t\t\treturn msgs, fmt.Errorf(\"failed to decode status message: %w\", err)\n    75→\t\t}\n    76→\t\tmsgs = append(msgs, msg)\n    77→\t}\n    78→\treturn msgs, nil\n    79→}\n    80→"}]},"parent_tool_use_id":"toolu_01CnzPH3TfTkngibK1zZgL3t","session_id":"b192fff1-2075-40cb-b513-cbbf26873af4","uuid":"8cf8841e-a962-4941-9063-14eb8cc252d6"}
