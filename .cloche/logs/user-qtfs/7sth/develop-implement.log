{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HPs1b1N2k1ANA91NkimWmD","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"os/signal\"\n     8→\t\"syscall\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/agent\"\n    11→)\n    12→\n    13→func main() {\n    14→\tif len(os.Args) < 2 {\n    15→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche-agent <workflow-file>\\n\")\n    16→\t\tos.Exit(1)\n    17→\t}\n    18→\n    19→\tworkflowPath := os.Args[1]\n    20→\tworkDir, _ := os.Getwd()\n    21→\n    22→\tctx, cancel := context.WithCancel(context.Background())\n    23→\tdefer cancel()\n    24→\n    25→\tsigCh := make(chan os.Signal, 1)\n    26→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n    27→\tgo func() {\n    28→\t\t<-sigCh\n    29→\t\tcancel()\n    30→\t}()\n    31→\n    32→\trunID := os.Getenv(\"CLOCHE_RUN_ID\")\n    33→\tos.Unsetenv(\"CLOCHE_RUN_ID\")\n    34→\n    35→\trunner := agent.NewRunner(agent.RunnerConfig{\n    36→\t\tWorkflowPath: workflowPath,\n    37→\t\tWorkDir:      workDir,\n    38→\t\tStatusOutput: os.Stdout,\n    39→\t\tRunID:        runID,\n    40→\t})\n    41→\n    42→\tif err := runner.Run(ctx); err != nil {\n    43→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    44→\t\tos.Exit(1)\n    45→\t}\n    46→}\n    47→"}]},"parent_tool_use_id":"toolu_01CnzPH3TfTkngibK1zZgL3t","session_id":"b192fff1-2075-40cb-b513-cbbf26873af4","uuid":"3be2b99d-a941-45f7-8451-5d6a6326f8e6"}
