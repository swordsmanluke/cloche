{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016AYChJ6cJ7f4QpT2JVUuMV","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"net/url\"\n    13→\t\"os\"\n    14→\t\"os/exec\"\n    15→\t\"path/filepath\"\n    16→\t\"regexp\"\n    17→\t\"sort\"\n    18→\t\"strconv\"\n    19→\t\"strings\"\n    20→\t\"time\"\n    21→\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    24→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    25→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    26→)\n    27→\n    28→// HandlerOption configures optional Handler dependencies.\n    29→type HandlerOption func(*Handler)\n    30→\n    31→// WithContainerLogger sets the container runtime for fetching live logs.\n    32→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    33→\treturn func(h *Handler) { h.container = c }\n    34→}\n    35→\n    36→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    37→func WithContainerManager(c ContainerManager) HandlerOption {\n    38→\treturn func(h *Handler) { h.container = c }\n    39→}\n    40→\n    41→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    42→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    43→\treturn func(h *Handler) { h.logBroadcast = b }\n    44→}\n    45→\n    46→// WithLogStore sets the log store for indexed log file lookups.\n    47→func WithLogStore(ls ports.LogStore) HandlerOption {\n    48→\treturn func(h *Handler) { h.logStore = ls }\n    49→}\n    50→\n    51→//go:embed templates/*.html static/*\n    52→var content embed.FS\n    53→\n    54→// Handler serves the web dashboard.\n    55→// ContainerLogger can retrieve logs from a container by ID.\n    56→type ContainerLogger interface {\n    57→\tLogs(ctx context.Context, containerID string) (string, error)\n    58→}\n    59→\n    60→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    61→type ContainerManager interface {\n    62→\tContainerLogger\n    63→\tRemove(ctx context.Context, containerID string) error\n    64→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    65→}\n    66→\n    67→type Handler struct {\n    68→\tstore        ports.RunStore\n    69→\tcaptures     ports.CaptureStore\n    70→\tlogStore     ports.LogStore\n    71→\tcontainer    ContainerLogger\n    72→\tlogBroadcast *logstream.Broadcaster\n    73→\tpages        map[string]*template.Template\n    74→\tmux          *http.ServeMux\n    75→}\n    76→\n    77→// NewHandler creates a web dashboard handler.\n    78→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    79→\tfuncMap := template.FuncMap{\n    80→\t\t\"stateColor\":       stateColor,\n    81→\t\t\"healthColor\":      healthColor,\n    82→\t\t\"formatTime\":       formatTime,\n    83→\t\t\"formatDuration\":   formatDuration,\n    84→\t\t\"truncate\":         truncate,\n    85→\t\t\"shortContainerID\": shortContainerID,\n    86→\t}\n    87→\n    88→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n    89→\tif err != nil {\n    90→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n    91→\t}\n    92→\n    93→\tpages := map[string]*template.Template{}\n    94→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n    95→\t\tclone, err := base.Clone()\n    96→\t\tif err != nil {\n    97→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n    98→\t\t}\n    99→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   100→\t\tif err != nil {\n   101→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   102→\t\t}\n   103→\t\tpages[page] = clone\n   104→\t}\n   105→\n   106→\th := &Handler{\n   107→\t\tstore:    store,\n   108→\t\tcaptures: captures,\n   109→\t\tpages:    pages,\n   110→\t\tmux:      http.NewServeMux(),\n   111→\t}\n   112→\tfor _, opt := range opts {\n   113→\t\topt(h)\n   114→\t}\n   115→\n   116→\tstaticFS, err := fs.Sub(content, \"static\")\n   117→\tif err != nil {\n   118→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   119→\t}\n   120→\n   121→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   122→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   123→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   124→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   125→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   126→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   127→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   128→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   129→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   130→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   131→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   132→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   133→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   134→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   135→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   136→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   137→\n   138→\treturn h, nil\n   139→}\n   140→\n   141→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   142→\th.mux.ServeHTTP(w, r)\n   143→}\n   144→\n   145→// --- HTML handlers ---\n   146→\n   147→// projectOverviewEntry holds data for a single project card on the landing page.\n   148→type projectOverviewEntry struct {\n   149→\tDir         string\n   150→\tLabel       string\n   151→\tHealth      domain.HealthResult\n   152→\tRecentRuns  []recentRunDot\n   153→\tActiveCount int\n   154→}\n   155→\n   156→// recentRunDot is a minimal representation of a run for the mini history display.\n   157→type recentRunDot struct {\n   158→\tID    string\n   159→\tState string\n   160→}\n   161→\n   162→const healthWindowSize = 10\n   163→\n   164→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   165→\tprojects, _ := h.store.ListProjects(r.Context())\n   166→\tlabels := projectLabels(projects)\n   167→\n   168→\tvar entries []projectOverviewEntry\n   169→\tfor _, dir := range projects {\n   170→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   171→\t\tif err != nil {\n   172→\t\t\tcontinue\n   173→\t\t}\n   174→\n   175→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   176→\t\trunValues := make([]domain.Run, len(runs))\n   177→\t\tfor i, rr := range runs {\n   178→\t\t\trunValues[i] = *rr\n   179→\t\t}\n   180→\n   181→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   182→\n   183→\t\t// Take the last N runs for the mini history (most recent first).\n   184→\t\tn := healthWindowSize\n   185→\t\tif n > len(runs) {\n   186→\t\t\tn = len(runs)\n   187→\t\t}\n   188→\t\tdots := make([]recentRunDot, n)\n   189→\t\tfor i := 0; i < n; i++ {\n   190→\t\t\tdots[i] = recentRunDot{\n   191→\t\t\t\tID:    runs[i].ID,\n   192→\t\t\t\tState: string(runs[i].State),\n   193→\t\t\t}\n   194→\t\t}\n   195→\n   196→\t\tvar activeCount int\n   197→\t\tfor _, rr := range runs {\n   198→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   199→\t\t\t\tactiveCount++\n   200→\t\t\t}\n   201→\t\t}\n   202→\n   203→\t\tentries = append(entries, projectOverviewEntry{\n   204→\t\t\tDir:         dir,\n   205→\t\t\tLabel:       labels[dir],\n   206→\t\t\tHealth:      health,\n   207→\t\t\tRecentRuns:  dots,\n   208→\t\t\tActiveCount: activeCount,\n   209→\t\t})\n   210→\t}\n   211→\n   212→\tsort.Slice(entries, func(i, j int) bool {\n   213→\t\treturn entries[i].Label < entries[j].Label\n   214→\t})\n   215→\n   216→\tdata := map[string]any{\n   217→\t\t\"Title\":    \"Projects\",\n   218→\t\t\"Projects\": entries,\n   219→\t}\n   220→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   221→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   222→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   223→\t}\n   224→}\n   225→\n   226→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   227→\tprojectFilter := r.URL.Query().Get(\"project\")\n   228→\n   229→\tvar runs []*domain.Run\n   230→\tvar err error\n   231→\tif projectFilter != \"\" {\n   232→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   233→\t} else {\n   234→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   235→\t}\n   236→\tif err != nil {\n   237→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   238→\t\treturn\n   239→\t}\n   240→\n   241→\tprojects, _ := h.store.ListProjects(r.Context())\n   242→\tlabels := projectLabels(projects)\n   243→\n   244→\t// Count retained containers per project\n   245→\tcontainerCounts := map[string]int{}\n   246→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   247→\tfor _, run := range allRuns {\n   248→\t\tif run.ContainerKept {\n   249→\t\t\tcontainerCounts[run.ProjectDir]++\n   250→\t\t}\n   251→\t}\n   252→\n   253→\tvar projectList []projectEntry\n   254→\tfor _, dir := range projects {\n   255→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   256→\t}\n   257→\tsort.Slice(projectList, func(i, j int) bool {\n   258→\t\treturn projectList[i].Label < projectList[j].Label\n   259→\t})\n   260→\n   261→\tdata := map[string]any{\n   262→\t\t\"Title\":         \"Runs\",\n   263→\t\t\"Runs\":          runs,\n   264→\t\t\"Projects\":      projectList,\n   265→\t\t\"ProjectFilter\": projectFilter,\n   266→\t\t\"ProjectLabels\": labels,\n   267→\t}\n   268→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   269→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   270→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   271→\t}\n   272→}\n   273→\n   274→// handleProjectRuns redirects /projects/{name}/runs to /runs?project=<dir>.\n   275→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   276→\tdir, _, ok := h.resolveProjectDir(w, r)\n   277→\tif !ok {\n   278→\t\treturn\n   279→\t}\n   280→\thttp.Redirect(w, r, \"/runs?project=\"+url.QueryEscape(dir), http.StatusFound)\n   281→}\n   282→\n   283→// stepEntry is a merged view of a step execution for the template.\n   284→type stepEntry struct {\n   285→\tIndex     int\n   286→\tStepName  string\n   287→\tResult    string\n   288→\tStartedAt time.Time\n   289→\tDuration  string\n   290→}\n   291→\n   292→// mergeCaptures collapses started/completed capture pairs into single entries.\n   293→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   294→\tvar entries []stepEntry\n   295→\t// Track pending started rows by step name (LIFO for retries)\n   296→\tpending := map[string]*domain.StepExecution{}\n   297→\n   298→\tfor _, c := range caps {\n   299→\t\tif c.Result == \"\" {\n   300→\t\t\t// step_started row\n   301→\t\t\tpending[c.StepName] = c\n   302→\t\t\tcontinue\n   303→\t\t}\n   304→\t\t// step_completed row — merge with pending started if available\n   305→\t\tstartedAt := c.StartedAt\n   306→\t\tif started := pending[c.StepName]; started != nil {\n   307→\t\t\tstartedAt = started.StartedAt\n   308→\t\t\tdelete(pending, c.StepName)\n   309→\t\t}\n   310→\t\tentries = append(entries, stepEntry{\n   311→\t\t\tIndex:     len(entries),\n   312→\t\t\tStepName:  c.StepName,\n   313→\t\t\tResult:    c.Result,\n   314→\t\t\tStartedAt: startedAt,\n   315→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   316→\t\t})\n   317→\t}\n   318→\n   319→\t// Append any started-but-not-completed steps (still running)\n   320→\tfor _, c := range caps {\n   321→\t\tif c.Result == \"\" {\n   322→\t\t\tif _, used := pending[c.StepName]; !used {\n   323→\t\t\t\tcontinue\n   324→\t\t\t}\n   325→\t\t\tentries = append(entries, stepEntry{\n   326→\t\t\t\tIndex:     len(entries),\n   327→\t\t\t\tStepName:  c.StepName,\n   328→\t\t\t\tStartedAt: c.StartedAt,\n   329→\t\t\t})\n   330→\t\t\tdelete(pending, c.StepName)\n   331→\t\t}\n   332→\t}\n   333→\n   334→\treturn entries\n   335→}\n   336→\n   337→// containerState inspects the container for a run and returns one of:\n   338→//   - \"running\"   – container exists and is running\n   339→//   - \"stopped\"   – container exists, not running, not kept\n   340→//   - \"available\" – container exists, not running, kept (can be deleted)\n   341→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   342→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   343→\tif run.ContainerID == \"\" {\n   344→\t\treturn \"removed\"\n   345→\t}\n   346→\tmgr, ok := h.container.(ContainerManager)\n   347→\tif !ok {\n   348→\t\treturn \"removed\"\n   349→\t}\n   350→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   351→\tif err != nil {\n   352→\t\treturn \"removed\"\n   353→\t}\n   354→\tif status.Running {\n   355→\t\treturn \"running\"\n   356→\t}\n   357→\tif run.ContainerKept {\n   358→\t\treturn \"available\"\n   359→\t}\n   360→\treturn \"stopped\"\n   361→}\n   362→\n   363→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   364→\tid := r.PathValue(\"id\")\n   365→\n   366→\trun, err := h.store.GetRun(r.Context(), id)\n   367→\tif err != nil {\n   368→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   369→\t\treturn\n   370→\t}\n   371→\n   372→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   373→\tif err != nil {\n   374→\t\tcaps = nil // non-fatal\n   375→\t}\n   376→\n   377→\tsteps := mergeCaptures(caps)\n   378→\n   379→\tdata := map[string]any{\n   380→\t\t\"Title\":          \"Run \" + run.ID,\n   381→\t\t\"Run\":            run,\n   382→\t\t\"Steps\":          steps,\n   383→\t\t\"Page\":           \"detail\",\n   384→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   385→\t}\n   386→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   387→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   388→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   389→\t}\n   390→}\n   391→\n   392→// --- JSON API handlers ---\n   393→\n   394→type apiRun struct {\n   395→\tID           string `json:\"id\"`\n   396→\tWorkflowName string `json:\"workflow_name\"`\n   397→\tProjectDir   string `json:\"project_dir\"`\n   398→\tProjectLabel string `json:\"project_label\"`\n   399→\tState        string `json:\"state\"`\n   400→\tStartedAt    string `json:\"started_at\"`\n   401→\tCompletedAt  string `json:\"completed_at\"`\n   402→\tContainerID  string `json:\"container_id\"`\n   403→\tErrorMessage string `json:\"error_message\"`\n   404→\tTitle        string `json:\"title\"`\n   405→\tIsHost       bool   `json:\"is_host\"`\n   406→}\n   407→\n   408→type apiStep struct {\n   409→\tStepName    string `json:\"step_name\"`\n   410→\tResult      string `json:\"result\"`\n   411→\tStartedAt   string `json:\"started_at\"`\n   412→\tCompletedAt string `json:\"completed_at\"`\n   413→\tDuration    string `json:\"duration\"`\n   414→}\n   415→\n   416→type apiRunDetail struct {\n   417→\tapiRun\n   418→\tContainerState string    `json:\"container_state\"`\n   419→\tSteps          []apiStep `json:\"steps\"`\n   420→}\n   421→\n   422→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   423→\treturn apiRun{\n   424→\t\tID:           r.ID,\n   425→\t\tWorkflowName: r.WorkflowName,\n   426→\t\tProjectDir:   r.ProjectDir,\n   427→\t\tProjectLabel: labels[r.ProjectDir],\n   428→\t\tState:        string(r.State),\n   429→\t\tStartedAt:    formatTime(r.StartedAt),\n   430→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   431→\t\tContainerID:  r.ContainerID,\n   432→\t\tErrorMessage: r.ErrorMessage,\n   433→\t\tTitle:        r.Title,\n   434→\t\tIsHost:       r.IsHost,\n   435→\t}\n   436→}\n   437→\n   438→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   439→\tprojectFilter := r.URL.Query().Get(\"project\")\n   440→\n   441→\tvar runs []*domain.Run\n   442→\tvar err error\n   443→\tif projectFilter != \"\" {\n   444→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   445→\t} else {\n   446→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   447→\t}\n   448→\tif err != nil {\n   449→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   450→\t\treturn\n   451→\t}\n   452→\n   453→\tprojects, _ := h.store.ListProjects(r.Context())\n   454→\tlabels := projectLabels(projects)\n   455→\n   456→\tresult := make([]apiRun, len(runs))\n   457→\tfor i, run := range runs {\n   458→\t\tresult[i] = toAPIRun(run, labels)\n   459→\t}\n   460→\n   461→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   462→\tjson.NewEncoder(w).Encode(result)\n   463→}\n   464→\n   465→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   466→\tprojects, err := h.store.ListProjects(r.Context())\n   467→\tif err != nil {\n   468→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   469→\t\treturn\n   470→\t}\n   471→\tlabels := projectLabels(projects)\n   472→\n   473→\ttype apiHealth struct {\n   474→\t\tStatus string `json:\"status\"`\n   475→\t\tPassed int    `json:\"passed\"`\n   476→\t\tFailed int    `json:\"failed\"`\n   477→\t\tTotal  int    `json:\"total\"`\n   478→\t}\n   479→\ttype apiProject struct {\n   480→\t\tDir         string    `json:\"dir\"`\n   481→\t\tLabel       string    `json:\"label\"`\n   482→\t\tHealth      apiHealth `json:\"health\"`\n   483→\t\tActiveCount int       `json:\"active_count\"`\n   484→\t}\n   485→\tresult := make([]apiProject, len(projects))\n   486→\tfor i, dir := range projects {\n   487→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   488→\t\trunValues := make([]domain.Run, len(runs))\n   489→\t\tfor j, rr := range runs {\n   490→\t\t\trunValues[j] = *rr\n   491→\t\t}\n   492→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   493→\t\tvar activeCount int\n   494→\t\tfor _, rr := range runs {\n   495→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   496→\t\t\t\tactiveCount++\n   497→\t\t\t}\n   498→\t\t}\n   499→\t\tresult[i] = apiProject{\n   500→\t\t\tDir:   dir,\n   501→\t\t\tLabel: labels[dir],\n   502→\t\t\tHealth: apiHealth{\n   503→\t\t\t\tStatus: string(health.Status),\n   504→\t\t\t\tPassed: health.Passed,\n   505→\t\t\t\tFailed: health.Failed,\n   506→\t\t\t\tTotal:  health.Total,\n   507→\t\t\t},\n   508→\t\t\tActiveCount: activeCount,\n   509→\t\t}\n   510→\t}\n   511→\n   512→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   513→\tjson.NewEncoder(w).Encode(result)\n   514→}\n   515→\n   516→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   517→\tid := r.PathValue(\"id\")\n   518→\n   519→\trun, err := h.store.GetRun(r.Context(), id)\n   520→\tif err != nil {\n   521→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   522→\t\treturn\n   523→\t}\n   524→\n   525→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   526→\tif err != nil {\n   527→\t\tcaps = nil\n   528→\t}\n   529→\n   530→\tprojects, _ := h.store.ListProjects(r.Context())\n   531→\tlabels := projectLabels(projects)\n   532→\n   533→\tmerged := mergeCaptures(caps)\n   534→\tsteps := make([]apiStep, len(merged))\n   535→\tfor i, e := range merged {\n   536→\t\tsteps[i] = apiStep{\n   537→\t\t\tStepName:  e.StepName,\n   538→\t\t\tResult:    e.Result,\n   539→\t\t\tStartedAt: formatTime(e.StartedAt),\n   540→\t\t\tDuration:  e.Duration,\n   541→\t\t}\n   542→\t}\n   543→\n   544→\tdetail := apiRunDetail{\n   545→\t\tapiRun:         toAPIRun(run, labels),\n   546→\t\tContainerState: h.containerState(r.Context(), run),\n   547→\t\tSteps:          steps,\n   548→\t}\n   549→\n   550→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   551→\tjson.NewEncoder(w).Encode(detail)\n   552→}\n   553→\n   554→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   555→\tid := r.PathValue(\"id\")\n   556→\tstep := r.PathValue(\"step\")\n   557→\tlogType := r.URL.Query().Get(\"type\")   // optional: \"script\", \"llm\"\n   558→\tformat := r.URL.Query().Get(\"format\")  // optional: \"raw\" to skip parsing\n   559→\n   560→\trun, err := h.store.GetRun(r.Context(), id)\n   561→\tif err != nil {\n   562→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   563→\t\treturn\n   564→\t}\n   565→\n   566→\twriteOutput := func(data []byte) {\n   567→\t\tif format != \"raw\" {\n   568→\t\t\tdata = logstream.ParseClaudeStream(data)\n   569→\t\t}\n   570→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   571→\t\tw.Write(data)\n   572→\t}\n   573→\n   574→\t// Try log index first for fast lookup\n   575→\tif h.logStore != nil {\n   576→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   577→\t\tif err == nil && len(logFiles) > 0 {\n   578→\t\t\t// If type filter specified, narrow results\n   579→\t\t\tfor _, lf := range logFiles {\n   580→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   581→\t\t\t\t\tcontinue\n   582→\t\t\t\t}\n   583→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   584→\t\t\t\tif readErr == nil && len(data) > 0 {\n   585→\t\t\t\t\twriteOutput(data)\n   586→\t\t\t\t\treturn\n   587→\t\t\t\t}\n   588→\t\t\t}\n   589→\t\t}\n   590→\t}\n   591→\n   592→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   593→\n   594→\t// Fall back to file path conventions\n   595→\t// If type is \"llm\", try llm-<step>.log\n   596→\tif logType == \"llm\" {\n   597→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   598→\t\tdata, err := os.ReadFile(llmPath)\n   599→\t\tif err == nil && len(data) > 0 {\n   600→\t\t\twriteOutput(data)\n   601→\t\t\treturn\n   602→\t\t}\n   603→\t}\n   604→\n   605→\t// Try per-step output first, fall back to container.log, then live docker logs\n   606→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   607→\tdata, err := os.ReadFile(outputPath)\n   608→\tif err == nil && len(data) > 0 {\n   609→\t\twriteOutput(data)\n   610→\t\treturn\n   611→\t}\n   612→\n   613→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   614→\tdata, err = os.ReadFile(containerLog)\n   615→\tif err == nil && len(data) > 0 {\n   616→\t\twriteOutput(data)\n   617→\t\treturn\n   618→\t}\n   619→\n   620→\t// Last resort: try live docker logs from still-existing container\n   621→\tif h.container != nil && run.ContainerID != \"\" {\n   622→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   623→\t\t\twriteOutput([]byte(logs))\n   624→\t\t\treturn\n   625→\t\t}\n   626→\t}\n   627→\n   628→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   629→}\n   630→\n   631→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   632→\tid := r.PathValue(\"id\")\n   633→\n   634→\trun, err := h.store.GetRun(r.Context(), id)\n   635→\tif err != nil {\n   636→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   637→\t\tw.WriteHeader(http.StatusNotFound)\n   638→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   639→\t\treturn\n   640→\t}\n   641→\n   642→\tmgr, ok := h.container.(ContainerManager)\n   643→\tif !ok || run.ContainerID == \"\" {\n   644→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   645→\t\tw.WriteHeader(http.StatusBadRequest)\n   646→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   647→\t\treturn\n   648→\t}\n   649→\n   650→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   651→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   652→\t\tw.WriteHeader(http.StatusInternalServerError)\n   653→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   654→\t\treturn\n   655→\t}\n   656→\n   657→\trun.ContainerKept = false\n   658→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   659→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   660→\t\tw.WriteHeader(http.StatusInternalServerError)\n   661→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   662→\t\treturn\n   663→\t}\n   664→\n   665→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   666→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   667→}\n   668→\n   669→// handleAPIStream serves an SSE stream of log lines for a run.\n   670→// For active runs, it subscribes to the live broadcaster.\n   671→// For completed runs, it serves the archived full.log then closes.\n   672→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   673→\tid := r.PathValue(\"id\")\n   674→\n   675→\trun, err := h.store.GetRun(r.Context(), id)\n   676→\tif err != nil {\n   677→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   678→\t\treturn\n   679→\t}\n   680→\n   681→\tflusher, ok := w.(http.Flusher)\n   682→\tif !ok {\n   683→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   684→\t\treturn\n   685→\t}\n   686→\n   687→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   688→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   689→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   690→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   691→\n   692→\tisComplete := run.State == domain.RunStateSucceeded ||\n   693→\t\trun.State == domain.RunStateFailed ||\n   694→\t\trun.State == domain.RunStateCancelled\n   695→\n   696→\tif isComplete {\n   697→\t\t// Serve archived full.log\n   698→\t\th.streamFullLog(w, flusher, run)\n   699→\t\t// Send done event\n   700→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   701→\t\tflusher.Flush()\n   702→\t\treturn\n   703→\t}\n   704→\n   705→\t// Active run: subscribe to live broadcaster\n   706→\tif h.logBroadcast == nil {\n   707→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   708→\t\treturn\n   709→\t}\n   710→\n   711→\tsub := h.logBroadcast.Subscribe(id)\n   712→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   713→\n   714→\tctx := r.Context()\n   715→\tfor {\n   716→\t\tselect {\n   717→\t\tcase <-ctx.Done():\n   718→\t\t\treturn\n   719→\t\tcase line, ok := <-sub.C:\n   720→\t\t\tif !ok {\n   721→\t\t\t\t// Stream finished (run completed)\n   722→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   723→\t\t\t\tflusher.Flush()\n   724→\t\t\t\treturn\n   725→\t\t\t}\n   726→\t\t\tline = parseLLMLogLine(line)\n   727→\t\t\tif line.Type == \"\" {\n   728→\t\t\t\tcontinue // skip protocol-only llm lines\n   729→\t\t\t}\n   730→\t\t\tdata, _ := json.Marshal(line)\n   731→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   732→\t\t\tflusher.Flush()\n   733→\t\t}\n   734→\t}\n   735→}\n   736→\n   737→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   738→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   739→\n   740→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   741→// LLM-type lines are parsed from raw Claude JSON into human-readable text.\n   742→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   743→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   744→\tf, err := os.Open(logPath)\n   745→\tif err != nil {\n   746→\t\treturn\n   747→\t}\n   748→\tdefer f.Close()\n   749→\n   750→\tscanner := bufio.NewScanner(f)\n   751→\tfor scanner.Scan() {\n   752→\t\ttext := scanner.Text()\n   753→\t\tline := parseFullLogLine(text)\n   754→\t\tline = parseLLMLogLine(line)\n   755→\t\tif line.Type == \"\" {\n   756→\t\t\tcontinue // skip protocol-only llm lines\n   757→\t\t}\n   758→\t\tdata, _ := json.Marshal(line)\n   759→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   760→\t\tflusher.Flush()\n   761→\t}\n   762→}\n   763→\n   764→// parseLLMLogLine parses a LogLine whose type is \"llm\". If the content is\n   765→// Claude stream JSON, it extracts the human-readable text. Protocol-only\n   766→// events return a LogLine with an empty Type (caller should skip it).\n   767→// Non-llm lines are returned unchanged.\n   768→func parseLLMLogLine(line logstream.LogLine) logstream.LogLine {\n   769→\tif line.Type != \"llm\" {\n   770→\t\treturn line\n   771→\t}\n   772→\ttext, ok := logstream.ParseClaudeLine([]byte(line.Content))\n   773→\tif !ok {\n   774→\t\treturn logstream.LogLine{} // signal to skip\n   775→\t}\n   776→\tline.Content = text\n   777→\treturn line\n   778→}\n   779→\n   780→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   781→func parseFullLogLine(text string) logstream.LogLine {\n   782→\tm := logLineRegex.FindStringSubmatch(text)\n   783→\tif m == nil {\n   784→\t\treturn logstream.LogLine{\n   785→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   786→\t\t\tType:      \"script\",\n   787→\t\t\tContent:   text,\n   788→\t\t}\n   789→\t}\n   790→\treturn logstream.LogLine{\n   791→\t\tTimestamp: m[1],\n   792→\t\tType:      m[2],\n   793→\t\tContent:   m[3],\n   794→\t}\n   795→}\n   796→\n   797→// --- Project detail handlers ---\n   798→\n   799→// resolveProjectDir resolves a project label from the URL to its directory path.\n   800→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   801→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   802→\tlabel := r.PathValue(\"name\")\n   803→\tprojects, _ := h.store.ListProjects(r.Context())\n   804→\tlabels := projectLabels(projects)\n   805→\tfor dir, l := range labels {\n   806→\t\tif l == label {\n   807→\t\t\treturn dir, label, true\n   808→\t\t}\n   809→\t}\n   810→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   811→\tw.WriteHeader(http.StatusNotFound)\n   812→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   813→\treturn \"\", \"\", false\n   814→}\n   815→\n   816→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   817→\tdir, label, ok := h.resolveProjectDir(w, r)\n   818→\tif !ok {\n   819→\t\treturn\n   820→\t}\n   821→\n   822→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   823→\tn := 10\n   824→\tif n > len(runs) {\n   825→\t\tn = len(runs)\n   826→\t}\n   827→\tdots := make([]recentRunDot, n)\n   828→\tfor i := 0; i < n; i++ {\n   829→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   830→\t}\n   831→\n   832→\tdata := map[string]any{\n   833→\t\t\"Title\":      label,\n   834→\t\t\"Label\":      label,\n   835→\t\t\"Dir\":        dir,\n   836→\t\t\"RecentRuns\": dots,\n   837→\t}\n   838→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   839→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   840→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   841→\t}\n   842→}\n   843→\n   844→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   845→\tdir, _, ok := h.resolveProjectDir(w, r)\n   846→\tif !ok {\n   847→\t\treturn\n   848→\t}\n   849→\n   850→\t// Docker image: read FROM line from Dockerfile\n   851→\tdockerImage := \"\"\n   852→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   853→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   854→\t\t// Find the last FROM line (final stage)\n   855→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   856→\t\t\ttrimmed := strings.TrimSpace(line)\n   857→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   858→\t\t\t\tparts := strings.Fields(trimmed)\n   859→\t\t\t\tif len(parts) >= 2 {\n   860→\t\t\t\t\tdockerImage = parts[1]\n   861→\t\t\t\t}\n   862→\t\t\t}\n   863→\t\t}\n   864→\t}\n   865→\n   866→\t// Version\n   867→\tversion := 0\n   868→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   869→\tif data, err := os.ReadFile(versionPath); err == nil {\n   870→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   871→\t\t\tversion = v\n   872→\t\t}\n   873→\t}\n   874→\n   875→\t// Prompt files history\n   876→\ttype commitEntry struct {\n   877→\t\tSHA     string `json:\"sha\"`\n   878→\t\tDate    string `json:\"date\"`\n   879→\t\tMessage string `json:\"message\"`\n   880→\t}\n   881→\ttype promptFile struct {\n   882→\t\tPath    string        `json:\"path\"`\n   883→\t\tHistory []commitEntry `json:\"history\"`\n   884→\t}\n   885→\n   886→\tvar promptFiles []promptFile\n   887→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   888→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n   889→\t\tfor _, e := range entries {\n   890→\t\t\tif e.IsDir() {\n   891→\t\t\t\tcontinue\n   892→\t\t\t}\n   893→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n   894→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n   895→\t\t\tcmd.Dir = dir\n   896→\t\t\tout, err := cmd.Output()\n   897→\t\t\tif err != nil {\n   898→\t\t\t\tcontinue\n   899→\t\t\t}\n   900→\t\t\tvar history []commitEntry\n   901→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n   902→\t\t\t\tif line == \"\" {\n   903→\t\t\t\t\tcontinue\n   904→\t\t\t\t}\n   905→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n   906→\t\t\t\tif len(parts) < 3 {\n   907→\t\t\t\t\tcontinue\n   908→\t\t\t\t}\n   909→\t\t\t\t// Parse date to short form\n   910→\t\t\t\tdateStr := parts[1]\n   911→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n   912→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n   913→\t\t\t\t}\n   914→\t\t\t\thistory = append(history, commitEntry{\n   915→\t\t\t\t\tSHA:     parts[0][:7],\n   916→\t\t\t\t\tDate:    dateStr,\n   917→\t\t\t\t\tMessage: parts[2],\n   918→\t\t\t\t})\n   919→\t\t\t}\n   920→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n   921→\t\t}\n   922→\t}\n   923→\n   924→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   925→\tjson.NewEncoder(w).Encode(map[string]any{\n   926→\t\t\"docker_image\": dockerImage,\n   927→\t\t\"version\":      version,\n   928→\t\t\"prompt_files\": promptFiles,\n   929→\t})\n   930→}\n   931→\n   932→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n   933→\tdir, _, ok := h.resolveProjectDir(w, r)\n   934→\tif !ok {\n   935→\t\treturn\n   936→\t}\n   937→\tfile := r.URL.Query().Get(\"file\")\n   938→\tsha := r.URL.Query().Get(\"sha\")\n   939→\tif file == \"\" || sha == \"\" {\n   940→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n   941→\t\treturn\n   942→\t}\n   943→\n   944→\t// Validate sha is alphanumeric to prevent injection\n   945→\tfor _, c := range sha {\n   946→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n   947→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n   948→\t\t\treturn\n   949→\t\t}\n   950→\t}\n   951→\n   952→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n   953→\tcmd.Dir = dir\n   954→\tout, err := cmd.Output()\n   955→\tif err != nil {\n   956→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n   957→\t\treturn\n   958→\t}\n   959→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   960→\tw.Write(out)\n   961→}\n   962→\n   963→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n   964→\tdir, _, ok := h.resolveProjectDir(w, r)\n   965→\tif !ok {\n   966→\t\treturn\n   967→\t}\n   968→\n   969→\tclocheDir := filepath.Join(dir, \".cloche\")\n   970→\tentries, err := os.ReadDir(clocheDir)\n   971→\tif err != nil {\n   972→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   973→\t\tjson.NewEncoder(w).Encode([]any{})\n   974→\t\treturn\n   975→\t}\n   976→\n   977→\ttype apiWire struct {\n   978→\t\tFrom   string `json:\"from\"`\n   979→\t\tResult string `json:\"result\"`\n   980→\t\tTo     string `json:\"to\"`\n   981→\t}\n   982→\ttype apiStepDef struct {\n   983→\t\tName    string            `json:\"name\"`\n   984→\t\tType    string            `json:\"type\"`\n   985→\t\tResults []string          `json:\"results\"`\n   986→\t\tConfig  map[string]string `json:\"config\"`\n   987→\t}\n   988→\ttype apiWorkflow struct {\n   989→\t\tName      string       `json:\"name\"`\n   990→\t\tFile      string       `json:\"file\"`\n   991→\t\tSteps     []apiStepDef `json:\"steps\"`\n   992→\t\tWires     []apiWire    `json:\"wires\"`\n   993→\t\tEntryStep string       `json:\"entry_step\"`\n   994→\t}\n   995→\n   996→\tvar workflows []apiWorkflow\n   997→\tfor _, e := range entries {\n   998→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n   999→\t\t\tcontinue\n  1000→\t\t}\n  1001→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1002→\t\tif err != nil {\n  1003→\t\t\tcontinue\n  1004→\t\t}\n  1005→\t\twf, err := dsl.ParseForContainer(string(data))\n  1006→\t\tif err != nil {\n  1007→\t\t\tcontinue\n  1008→\t\t}\n  1009→\t\tvar steps []apiStepDef\n  1010→\t\tfor _, s := range wf.Steps {\n  1011→\t\t\tsteps = append(steps, apiStepDef{\n  1012→\t\t\t\tName:    s.Name,\n  1013→\t\t\t\tType:    string(s.Type),\n  1014→\t\t\t\tResults: s.Results,\n  1015→\t\t\t\tConfig:  s.Config,\n  1016→\t\t\t})\n  1017→\t\t}\n  1018→\t\t// Sort steps by name for consistent ordering\n  1019→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1020→\n  1021→\t\tvar wires []apiWire\n  1022→\t\tfor _, wire := range wf.Wiring {\n  1023→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1024→\t\t}\n  1025→\n  1026→\t\tworkflows = append(workflows, apiWorkflow{\n  1027→\t\t\tName:      wf.Name,\n  1028→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1029→\t\t\tSteps:     steps,\n  1030→\t\t\tWires:     wires,\n  1031→\t\t\tEntryStep: wf.EntryStep,\n  1032→\t\t})\n  1033→\t}\n  1034→\n  1035→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1036→\tjson.NewEncoder(w).Encode(workflows)\n  1037→}\n  1038→\n  1039→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1040→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1041→\tif !ok {\n  1042→\t\treturn\n  1043→\t}\n  1044→\tworkflowName := r.PathValue(\"workflow\")\n  1045→\tstepName := r.PathValue(\"step\")\n  1046→\n  1047→\t// Find the workflow file\n  1048→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1049→\tvar wf *domain.Workflow\n  1050→\tentries, _ := os.ReadDir(cl