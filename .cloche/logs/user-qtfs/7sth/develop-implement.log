{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K5xZ159DYTuJ3fzzMZ6oj3","type":"tool_result","content":"     1→package protocol\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"io\"\n     8→\t\"time\"\n     9→)\n    10→\n    11→type MessageType string\n    12→\n    13→const (\n    14→\tMsgStepStarted  MessageType = \"step_started\"\n    15→\tMsgStepCompleted MessageType = \"step_completed\"\n    16→\tMsgRunCompleted  MessageType = \"run_completed\"\n    17→\tMsgRunTitle      MessageType = \"run_title\"\n    18→\tMsgLog           MessageType = \"log\"\n    19→\tMsgError         MessageType = \"error\"\n    20→)\n    21→\n    22→type StatusMessage struct {\n    23→\tType      MessageType `json:\"type\"`\n    24→\tStepName  string      `json:\"step_name,omitempty\"`\n    25→\tResult    string      `json:\"result,omitempty\"`\n    26→\tMessage   string      `json:\"message,omitempty\"`\n    27→\tTimestamp time.Time   `json:\"timestamp\"`\n    28→}\n    29→\n    30→type StatusWriter struct {\n    31→\tw   io.Writer\n    32→\tenc *json.Encoder\n    33→}\n    34→\n    35→func NewStatusWriter(w io.Writer) *StatusWriter {\n    36→\treturn &StatusWriter{w: w, enc: json.NewEncoder(w)}\n    37→}\n    38→\n    39→func (s *StatusWriter) StepStarted(stepName string) {\n    40→\ts.write(StatusMessage{Type: MsgStepStarted, StepName: stepName})\n    41→}\n    42→\n    43→func (s *StatusWriter) StepCompleted(stepName, result string) {\n    44→\ts.write(StatusMessage{Type: MsgStepCompleted, StepName: stepName, Result: result})\n    45→}\n    46→\n    47→func (s *StatusWriter) RunCompleted(result string) {\n    48→\ts.write(StatusMessage{Type: MsgRunCompleted, Result: result})\n    49→}\n    50→\n    51→func (s *StatusWriter) RunTitle(title string) {\n    52→\ts.write(StatusMessage{Type: MsgRunTitle, Message: title})\n    53→}\n    54→\n    55→func (s *StatusWriter) Log(stepName, message string) {\n    56→\ts.write(StatusMessage{Type: MsgLog, StepName: stepName, Message: message})\n    57→}\n    58→\n    59→func (s *StatusWriter) Error(stepName, message string) {\n    60→\ts.write(StatusMessage{Type: MsgError, StepName: stepName, Message: message})\n    61→}\n    62→\n    63→func (s *StatusWriter) write(msg StatusMessage) {\n    64→\tmsg.Timestamp = time.Now()\n    65→\t_ = s.enc.Encode(msg)\n    66→}\n    67→\n    68→func ParseStatusStream(data []byte) ([]StatusMessage, error) {\n    69→\tvar msgs []StatusMessage\n    70→\tdec := json.NewDecoder(bytes.NewReader(data))\n    71→\tfor dec.More() {\n    72→\t\tvar msg StatusMessage\n    73→\t\tif err := dec.Decode(&msg); err != nil {\n    74→\t\t\treturn msgs, fmt.Errorf(\"failed to decode status message: %w\", err)\n    75→\t\t}\n    76→\t\tmsgs = append(msgs, msg)\n    77→\t}\n    78→\treturn msgs, nil\n    79→}\n    80→"}]},"parent_tool_use_id":null,"session_id":"b192fff1-2075-40cb-b513-cbbf26873af4","uuid":"d69e668a-129c-424d-9055-fc36a9f58c19","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/protocol/status.go","content":"package protocol\n\nimport (\n\t\"bytes\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"time\"\n)\n\ntype MessageType string\n\nconst (\n\tMsgStepStarted  MessageType = \"step_started\"\n\tMsgStepCompleted MessageType = \"step_completed\"\n\tMsgRunCompleted  MessageType = \"run_completed\"\n\tMsgRunTitle      MessageType = \"run_title\"\n\tMsgLog           MessageType = \"log\"\n\tMsgError         MessageType = \"error\"\n)\n\ntype StatusMessage struct {\n\tType      MessageType `json:\"type\"`\n\tStepName  string      `json:\"step_name,omitempty\"`\n\tResult    string      `json:\"result,omitempty\"`\n\tMessage   string      `json:\"message,omitempty\"`\n\tTimestamp time.Time   `json:\"timestamp\"`\n}\n\ntype StatusWriter struct {\n\tw   io.Writer\n\tenc *json.Encoder\n}\n\nfunc NewStatusWriter(w io.Writer) *StatusWriter {\n\treturn &StatusWriter{w: w, enc: json.NewEncoder(w)}\n}\n\nfunc (s *StatusWriter) StepStarted(stepName string) {\n\ts.write(StatusMessage{Type: MsgStepStarted, StepName: stepName})\n}\n\nfunc (s *StatusWriter) StepCompleted(stepName, result string) {\n\ts.write(StatusMessage{Type: MsgStepCompleted, StepName: stepName, Result: result})\n}\n\nfunc (s *StatusWriter) RunCompleted(result string) {\n\ts.write(StatusMessage{Type: MsgRunCompleted, Result: result})\n}\n\nfunc (s *StatusWriter) RunTitle(title string) {\n\ts.write(StatusMessage{Type: MsgRunTitle, Message: title})\n}\n\nfunc (s *StatusWriter) Log(stepName, message string) {\n\ts.write(StatusMessage{Type: MsgLog, StepName: stepName, Message: message})\n}\n\nfunc (s *StatusWriter) Error(stepName, message string) {\n\ts.write(StatusMessage{Type: MsgError, StepName: stepName, Message: message})\n}\n\nfunc (s *StatusWriter) write(msg StatusMessage) {\n\tmsg.Timestamp = time.Now()\n\t_ = s.enc.Encode(msg)\n}\n\nfunc ParseStatusStream(data []byte) ([]StatusMessage, error) {\n\tvar msgs []StatusMessage\n\tdec := json.NewDecoder(bytes.NewReader(data))\n\tfor dec.More() {\n\t\tvar msg StatusMessage\n\t\tif err := dec.Decode(&msg); err != nil {\n\t\t\treturn msgs, fmt.Errorf(\"failed to decode status message: %w\", err)\n\t\t}\n\t\tmsgs = append(msgs, msg)\n\t}\n\treturn msgs, nil\n}\n","numLines":80,"startLine":1,"totalLines":80}}}
