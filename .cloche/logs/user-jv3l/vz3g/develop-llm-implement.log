"error-cell\">{{truncate .ErrorMessage 80}}</td>\n    41→        </tr>\n    42→        {{end}}\n    43→    {{else}}\n    44→        <tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>\n    45→    {{end}}\n    46→    </tbody>\n    47→</table>\n    48→{{end}}\n    49→\n    50→{{define \"scripts\"}}\n    51→<script>\n    52→(function() {\n    53→    var currentProject = '{{.ProjectFilter}}';\n    54→\n    55→    function filterByProject(dir) {\n    56→        if (dir) {\n    57→            window.location.href = '/runs?project=' + encodeURIComponent(dir);\n    58→        } else {\n    59→            window.location.href = '/runs';\n    60→        }\n    61→    }\n    62→    window.filterByProject = filterByProject;\n    63→\n    64→    // groupRuns arranges runs so children appear directly after their parent.\n    65→    // Parents are de-emphasized; children (where active work happens) are prominent.\n    66→    function groupRuns(runs) {\n    67→        var parentMap = {};  // parent_run_id -> [children]\n    68→        var topLevel = [];\n    69→        var byId = {};\n    70→\n    71→        for (var i = 0; i < runs.length; i++) {\n    72→            byId[runs[i].id] = runs[i];\n    73→        }\n    74→\n    75→        for (var i = 0; i < runs.length; i++) {\n    76→            var r = runs[i];\n    77→            if (r.parent_run_id && byId[r.parent_run_id]) {\n    78→                if (!parentMap[r.parent_run_id]) parentMap[r.parent_run_id] = [];\n    79→                parentMap[r.parent_run_id].push(r);\n    80→            } else {\n    81→                topLevel.push(r);\n    82→            }\n    83→        }\n    84→\n    85→        var result = [];\n    86→        for (var i = 0; i < topLevel.length; i++) {\n    87→            var r = topLevel[i];\n    88→            var children = parentMap[r.id];\n    89→            var isParent = children && children.length > 0;\n    90→            result.push({ run: r, isParent: isParent, isChild: false });\n    91→            if (children) {\n    92→                for (var j = 0; j < children.length; j++) {\n    93→                    result.push({ run: children[j], isParent: false, isChild: true });\n    94→                }\n    95→            }\n    96→        }\n    97→\n    98→        // Add orphaned children (parent not in current view)\n    99→        for (var i = 0; i < runs.length; i++) {\n   100→            var r = runs[i];\n   101→            if (r.parent_run_id && !byId[r.parent_run_id]) {\n   102→                result.push({ run: r, isParent: false, isChild: true });\n   103→            }\n   104→        }\n   105→\n   106→        return result;\n   107→    }\n   108→\n   109→    function poll() {\n   110→        var url = '/api/runs';\n   111→        if (currentProject) {\n   112→            url += '?project=' + encodeURIComponent(currentProject);\n   113→        }\n   114→        fetch(url)\n   115→            .then(function(r) { return r.json(); })\n   116→            .then(function(runs) {\n   117→                var tbody = document.getElementById('runs-body');\n   118→                if (!runs || runs.length === 0) {\n   119→                    tbody.innerHTML = '<tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>';\n   120→                    return;\n   121→                }\n   122→\n   123→                var grouped = groupRuns(runs);\n   124→                var html = '';\n   125→                for (var i = 0; i < grouped.length; i++) {\n   126→                    var entry = grouped[i];\n   127→                    var r = entry.run;\n   128→                    var cid = r.container_id || '';\n   129→                    if (cid.length > 12) cid = cid.substring(0, 12);\n   130→                    var err = r.error_message || '';\n   131→                    if (err.length > 80) err = err.substring(0, 80) + '...';\n   132→                    var proj = r.project_label || '';\n   133→                    var title = r.title || '';\n   134→                    if (title.length > 50) title = title.substring(0, 47) + '...';\n   135→                    var runType = r.is_host ? 'host' : 'container';\n   136→                    var rowClass = entry.isChild ? 'run-child-row' : (entry.isParent ? 'run-parent-row' : '');\n   137→                    var timing = r.timing || '';\n   138→                    html += '<tr class=\"' + rowClass + '\">' +\n   139→                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n   140→                        '<td>' + escapeHtml(title) + '</td>' +\n   141→                        '<td>' + escapeHtml(proj) + '</td>' +\n   142→                        '<td>' + r.workflow_name + '</td>' +\n   143→                        '<td>' + runType + '</td>' +\n   144→                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n   145→                        '<td>' + escapeHtml(timing) + '</td>' +\n   146→                        '<td class=\"mono\">' + cid + '</td>' +\n   147→                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n   148→                        '</tr>';\n   149→                }\n   150→                tbody.innerHTML = html;\n   151→            })\n   152→            .catch(function() {});\n   153→    }\n   154→    function escapeHtml(s) {\n   155→        var d = document.createElement('div');\n   156→        d.appendChild(document.createTextNode(s));\n   157→        return d.innerHTML;\n   158→    }\n   159→    setInterval(poll, 3000);\n   160→})();\n   161→</script>\n   162→{{end}}\n   163→"}]},"parent_tool_use_id":null,"session_id":"3e7ed9f0-b7c4-40c4-97b1-03db40146cc3","uuid":"9aff8306-695b-4d12-ad85-909bbb1c235a","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/runs.html","content":"{{define \"content\"}}\n<h1>Runs</h1>\n{{if .Projects}}\n<div class=\"project-filter\">\n    <label for=\"project-select\">Project:</label>\n    <select id=\"project-select\" onchange=\"filterByProject(this.value)\">\n        <option value=\"\">All projects</option>\n        {{range .Projects}}\n        <option value=\"{{.Dir}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>\n        {{end}}\n    </select>\n</div>\n{{end}}\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Run ID</th>\n            <th>Title</th>\n            <th>Project</th>\n            <th>Workflow</th>\n            <th>Type</th>\n            <th>State</th>\n            <th>Timing</th>\n            <th>Container</th>\n            <th>Error</th>\n        </tr>\n    </thead>\n    <tbody id=\"runs-body\">\n    {{if .Runs}}\n        {{range .Runs}}\n        <tr class=\"{{if .ParentRunID}}run-child-row{{else if .IsHost}}run-parent-row{{end}}\">\n            <td><a href=\"/runs/{{.ID}}\">{{.ID}}</a></td>\n            <td>{{truncate .Title 50}}</td>\n            <td>{{index $.ProjectLabels .ProjectDir}}</td>\n            <td>{{.WorkflowName}}</td>\n            <td>{{if .IsHost}}host{{else}}container{{end}}</td>\n            <td><span class=\"badge badge-{{stateColor .State}}\">{{.State}}</span></td>\n            <td>{{formatRunTiming .State .StartedAt .CompletedAt}}</td>\n            <td class=\"mono\">{{shortContainerID .ContainerID}}</td>\n            <td class=\"error-cell\">{{truncate .ErrorMessage 80}}</td>\n        </tr>\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var currentProject = '{{.ProjectFilter}}';\n\n    function filterByProject(dir) {\n        if (dir) {\n            window.location.href = '/runs?project=' + encodeURIComponent(dir);\n        } else {\n            window.location.href = '/runs';\n        }\n    }\n    window.filterByProject = filterByProject;\n\n    // groupRuns arranges runs so children appear directly after their parent.\n    // Parents are de-emphasized; children (where active work happens) are prominent.\n    function groupRuns(runs) {\n        var parentMap = {};  // parent_run_id -> [children]\n        var topLevel = [];\n        var byId = {};\n\n        for (var i = 0; i < runs.length; i++) {\n            byId[runs[i].id] = runs[i];\n        }\n\n        for (var i = 0; i < runs.length; i++) {\n            var r = runs[i];\n            if (r.parent_run_id && byId[r.parent_run_id]) {\n                if (!parentMap[r.parent_run_id]) parentMap[r.parent_run_id] = [];\n                parentMap[r.parent_run_id].push(r);\n            } else {\n                topLevel.push(r);\n            }\n        }\n\n        var result = [];\n        for (var i = 0; i < topLevel.length; i++) {\n            var r = topLevel[i];\n            var children = parentMap[r.id];\n            var isParent = children && children.length > 0;\n            result.push({ run: r, isParent: isParent, isChild: false });\n            if (children) {\n                for (var j = 0; j < children.length; j++) {\n                    result.push({ run: children[j], isParent: false, isChild: true });\n                }\n            }\n        }\n\n        // Add orphaned children (parent not in current view)\n        for (var i = 0; i < runs.length; i++) {\n            var r = runs[i];\n            if (r.parent_run_id && !byId[r.parent_run_id]) {\n                result.push({ run: r, isParent: false, isChild: true });\n            }\n        }\n\n        return result;\n    }\n\n    function poll() {\n        var url = '/api/runs';\n        if (currentProject) {\n            url += '?project=' + encodeURIComponent(currentProject);\n        }\n        fetch(url)\n            .then(function(r) { return r.json(); })\n            .then(function(runs) {\n                var tbody = document.getElementById('runs-body');\n                if (!runs || runs.length === 0) {\n                    tbody.innerHTML = '<tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>';\n                    return;\n                }\n\n                var grouped = groupRuns(runs);\n                var html = '';\n                for (var i = 0; i < grouped.length; i++) {\n                    var entry = grouped[i];\n                    var r = entry.run;\n                    var cid = r.container_id || '';\n                    if (cid.length > 12) cid = cid.substring(0, 12);\n                    var err = r.error_message || '';\n                    if (err.length > 80) err = err.substring(0, 80) + '...';\n                    var proj = r.project_label || '';\n                    var title = r.title || '';\n                    if (title.length > 50) title = title.substring(0, 47) + '...';\n                    var runType = r.is_host ? 'host' : 'container';\n                    var rowClass = entry.isChild ? 'run-child-row' : (entry.isParent ? 'run-parent-row' : '');\n                    var timing = r.timing || '';\n                    html += '<tr class=\"' + rowClass + '\">' +\n                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n                        '<td>' + escapeHtml(title) + '</td>' +\n                        '<td>' + escapeHtml(proj) + '</td>' +\n                        '<td>' + r.workflow_name + '</td>' +\n                        '<td>' + runType + '</td>' +\n                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n                        '<td>' + escapeHtml(timing) + '</td>' +\n                        '<td class=\"mono\">' + cid + '</td>' +\n                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                        '</tr>';\n                }\n                tbody.innerHTML = html;\n            })\n            .catch(function() {});\n    }\n    function escapeHtml(s) {\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n    setInterval(poll, 3000);\n})();\n</script>\n{{end}}\n","numLines":163,"startLine":1,"totalLines":163}}}
