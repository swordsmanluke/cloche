old-running\", listed[1].ID)\n+\tassert.Equal(t, \"new-failed\", listed[2].ID)\n+\tassert.Equal(t, \"mid-succeeded\", listed[3].ID)\n+\n+\t// ListRuns with since filter: same ordering\n+\tlisted, err = store.ListRuns(ctx, now.Add(-6*time.Minute))\n+\trequire.NoError(t, err)\n+\trequire.Len(t, listed, 3) // excludes old-running (started 10min ago)\n+\tassert.Equal(t, \"new-running\", listed[0].ID)\n+\tassert.Equal(t, \"new-failed\", listed[1].ID)\n+\tassert.Equal(t, \"mid-succeeded\", listed[2].ID)\n+}\ndiff --git a/internal/adapters/web/templates/runs.html b/internal/adapters/web/templates/runs.html\nindex a24940d..ac62f1f 100644\n--- a/internal/adapters/web/templates/runs.html\n+++ b/internal/adapters/web/templates/runs.html\n@@ -82,6 +82,14 @@\n             }\n         }\n \n+        // Sort top-level: running first, then by started_at descending\n+        topLevel.sort(function(a, b) {\n+            var aRunning = a.state === 'running' ? 0 : 1;\n+            var bRunning = b.state === 'running' ? 0 : 1;\n+            if (aRunning !== bRunning) return aRunning - bRunning;\n+            return (b.started_at || '').localeCompare(a.started_at || '');\n+        });\n+\n         var result = [];\n         for (var i = 0; i < topLevel.length; i++) {\n             var r = topLevel[i];","is_error":false}]},"parent_tool_use_id":null,"session_id":"3e7ed9f0-b7c4-40c4-97b1-03db40146cc3","uuid":"29bc86f0-3e65-4a51-8b4d-7914bd5f439e","tool_use_result":{"stdout":"diff --git a/internal/adapters/sqlite/store.go b/internal/adapters/sqlite/store.go\nindex 2b1805c..43aa26f 100644\n--- a/internal/adapters/sqlite/store.go\n+++ b/internal/adapters/sqlite/store.go\n@@ -195,10 +195,10 @@ func (s *Store) ListRuns(ctx context.Context, since time.Time) ([]*domain.Run, e\n \tvar err error\n \tif since.IsZero() {\n \t\trows, err = s.db.QueryContext(ctx,\n-\t\t\t`SELECT `+runSelectCols+` FROM runs ORDER BY started_at DESC`)\n+\t\t\t`SELECT `+runSelectCols+` FROM runs ORDER BY CASE WHEN state = 