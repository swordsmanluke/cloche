{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012tjoHRSMZnWy35ocTqfde6","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1>Runs</h1>\n     3→{{if .Projects}}\n     4→<div class=\"project-filter\">\n     5→    <label for=\"project-select\">Project:</label>\n     6→    <select id=\"project-select\" onchange=\"filterByProject(this.value)\">\n     7→        <option value=\"\">All projects</option>\n     8→        {{range .Projects}}\n     9→        <option value=\"{{.Dir}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>\n    10→        {{end}}\n    11→    </select>\n    12→</div>\n    13→{{end}}\n    14→<table class=\"runs-table\">\n    15→    <thead>\n    16→        <tr>\n    17→            <th>Run ID</th>\n    18→            <th>Title</th>\n    19→            <th>Project</th>\n    20→            <th>Workflow</th>\n    21→            <th>Type</th>\n    22→            <th>State</th>\n    23→            <th>Timing</th>\n    24→            <th>Container</th>\n    25→            <th>Error</th>\n    26→        </tr>\n    27→    </thead>\n    28→    <tbody id=\"runs-body\">\n    29→    {{if .Runs}}\n    30→        {{range .Runs}}\n    31→        <tr class=\"{{if .ParentRunID}}run-child-row{{else if .IsHost}}run-parent-row{{end}}\">\n    32→            <td><a href=\"/runs/{{.ID}}\">{{.ID}}</a></td>\n    33→            <td>{{truncate .Title 50}}</td>\n    34→            <td>{{index $.ProjectLabels .ProjectDir}}</td>\n    35→            <td>{{.WorkflowName}}</td>\n    36→            <td>{{if .IsHost}}host{{else}}container{{end}}</td>\n    37→            <td><span class=\"badge badge-{{stateColor .State}}\">{{.State}}</span></td>\n    38→            <td>{{formatRunTiming .State .StartedAt .CompletedAt}}</td>\n    39→            <td class=\"mono\">{{shortContainerID .ContainerID}}</td>\n    40→            <td class=\"error-cell\">{{truncate .ErrorMessage 80}}</td>\n    41→        </tr>\n    42→        {{end}}\n    43→    {{else}}\n    44→        <tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>\n    45→    {{end}}\n    46→    </tbody>\n    47→</table>\n    48→{{end}}\n    49→\n    50→{{define \"scripts\"}}\n    51→<script>\n    52→(function() {\n    53→    var currentProject = '{{.ProjectFilter}}';\n    54→\n    55→    function filterByProject(dir) {\n    56→        if (dir) {\n    57→            window.location.href = '/runs?project=' + encodeURIComponent(dir);\n    58→        } else {\n    59→            window.location.href = '/runs';\n    60→        }\n    61→    }\n    62→    window.filterByProject = filterByProject;\n    63→\n    64→    // groupRuns arranges runs so children appear directly after their parent.\n    65→    // Parents are de-emphasized; children (where active work happens) are prominent.\n    66→    function groupRuns(runs) {\n    67→        var parentMap = {};  // parent_run_id -> [children]\n    68→        var topLevel = [];\n    69→        var byId = {};\n    70→\n    71→        for (var i = 0; i < runs.length; i++) {\n    72→            byId[runs[i].id] = runs[i];\n    73→        }\n    74→\n    75→        for (var i = 0; i < runs.length; i++) {\n    76→            var r = runs[i];\n    77→            if (r.parent_run_id && byId[r.parent_run_id]) {\n    78→                if (!parentMap[r.parent_run_id]) parentMap[r.parent_run_id] = [];\n    79→                parentMap[r.parent_run_id].push(r);\n    80→            } else {\n    81→                topLevel.push(r);\n    82→            }\n    83→        }\n    84→\n    85→        var result = [];\n    86→        for (var i = 0; i < topLevel.length; i++) {\n    87→            var r = topLevel[i];\n    88→            var children = parentMap[r.id];\n    89→            var isParent = children && children.length > 0;\n    90→            result.push({ run: r, isParent: isParent, isChild: false });\n    91→            if (children) {\n    92→                for (var j = 0; j < children.length; j++) {\n    93→                    result.push({ run: children[j], isParent: false, isChild: true });\n    94→                }\n    95→            }\n    96→        }\n    97→\n    98→        // Add orphaned children (parent not in current view)\n    99→        for (var i = 0; i < runs.length; i++) {\n   100→            var r = runs[i];\n   101→            if (r.parent_run_id && !byId[r.parent_run_id]) {\n   102→                result.push({ run: r, isParent: false, isChild: true });\n   103→            }\n   104→        }\n   105→\n   106→        return result;\n   107→    }\n   108→\n   109→    function poll() {\n   110→        var url = '/api/runs';\n   111→        if (currentProject) {\n   112→            url += '?project=' + encodeURIComponent(currentProject);\n   113→        }\n   114→        fetch(url)\n   115→            .then(function(r) { return r.json(); })\n   116→            .then(function(runs) {\n   117→                var tbody = document.getElementById('runs-body');\n   118→                if (!runs || runs.length === 0) {\n   119→                    tbody.innerHTML = '<tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>';\n   120→                    return;\n   121→                }\n   122→\n   123→                var grouped = groupRuns(runs);\n   124→                var html = '';\n   125→                for (var i = 0; i < grouped.length; i++) {\n   126→                    var entry = grouped[i];\n   127→                    var r = entry.run;\n   128→                    var cid = r.container_id || '';\n   129→                    if (cid.length > 12) cid = cid.substring(0, 12);\n   130→                    var err = r.error_message || '';\n   131→                    if (err.length > 80) err = err.substring(0, 80) + '...';\n   132→                    var proj = r.project_label || '';\n   133→                    var title = r.title || '';\n   134→                    if (title.length > 50) title = title.substring(0, 47) + '...';\n   135→                    var runType = r.is_host ? 'host' : 'container';\n   136→                    var rowClass = entry.isChild ? 'run-child-row' : (entry.isParent ? 'run-parent-row' : '');\n   137→                    var timing = r.timing || '';\n   138→                    html += '<tr class=\"' + rowClass + '\">' +\n   139→                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n   140→                        '<td>' + escapeHtml(title) + '</td>' +\n   141→                        '<td>' + escapeHtml(proj) + '</td>' +\n   142→                        '<td>' + r.workflow_name + '</td>' +\n   143→                        '<td>' + runType + '</td>' +\n   144→                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n   145→                        '<td>' + escapeHtml(timing) + '</td>' +\n   146→                        '<td class=\"mono\">' + cid + '</td>' +\n   147→                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n   148→                        '</tr>';\n   149→                }\n   150→                tbody.innerHTML = html;\n   151→            })\n   152→            .catch(function() {});\n   153→    }\n   154→    function escapeHtml(s) {\n   155→        var d = document.createElement('div');\n   156→        d.appendChild(document.createTextNode(s));\n   157→        return d.innerHTML;\n   158→    }\n   159→    setInterval(poll, 3000);\n   160→})();\n   161→</script>\n   162→{{end}}\n   163→"}]},"parent_tool_use_id":"toolu_01ApnVmEDSi88AA7Rq7LGZza","session_id":"3e7ed9f0-b7c4-40c4-97b1-03db40146cc3","uuid":"3e792044-60b5-4b3a-ba3f-611749b3d8b1"}
