{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018vLTdTg6soz9Sp6fXspAKg","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"strings\"\n     9→)\n    10→\n    11→// Curator merges lessons into prompt files using ACE-style curation.\n    12→type Curator struct {\n    13→\tLLM   LLMClient\n    14→\tAudit *AuditLogger\n    15→}\n    16→\n    17→// Apply curates a lesson into the target prompt file.\n    18→// After writing, it validates the output. If the content looks corrupted,\n    19→// it restores the pre-write snapshot and reports the rollback.\n    20→func (c *Curator) Apply(ctx context.Context, projectDir string, lesson *Lesson) (*Change, error) {\n    21→\ttargetPath := filepath.Join(projectDir, lesson.Target)\n    22→\tcurrent, err := os.ReadFile(targetPath)\n    23→\tif err != nil {\n    24→\t\treturn nil, fmt.Errorf(\"reading target prompt %s: %w\", lesson.Target, err)\n    25→\t}\n    26→\n    27→\tsystemPrompt := `You are a prompt curator using ACE (Agentic Context Engineering) principles.\n    28→Your job is to merge a new lesson into an existing prompt document.\n    29→\n    30→Rules:\n    31→- Append the lesson as a structured bullet/rule in a \"## Learned Rules\" section\n    32→- If a \"## Learned Rules\" section already exists, add to it\n    33→- If the lesson refines or duplicates an existing rule, update in place rather than appending\n    34→- Preserve ALL existing content exactly as-is\n    35→- Keep rules concise and actionable\n    36→- Do not add commentary — return only the updated prompt content`\n    37→\n    38→\tuserPrompt := fmt.Sprintf(\"## Current Prompt Content\\n```\\n%s\\n```\\n\\n## Lesson to Merge\\nInsight: %s\\nSuggested Action: %s\",\n    39→\t\tstring(current), lesson.Insight, lesson.SuggestedAction)\n    40→\n    41→\traw, err := c.LLM.Complete(ctx, systemPrompt, userPrompt)\n    42→\tif err != nil {\n    43→\t\treturn nil, fmt.Errorf(\"curator LLM call: %w\", err)\n    44→\t}\n    45→\n    46→\tupdated := stripCodeFences(raw)\n    47→\n    48→\t// Snapshot before writing\n    49→\tvar snapName string\n    50→\tif c.Audit != nil {\n    51→\t\tsnapName, _ = c.Audit.Snapshot(lesson.Target)\n    52→\t}\n    53→\n    54→\tif err := os.WriteFile(targetPath, []byte(updated), 0644); err != nil {\n    55→\t\treturn nil, fmt.Errorf(\"writing updated prompt: %w\", err)\n    56→\t}\n    57→\n    58→\t// Validate the written content; rollback if corrupted\n    59→\tif !validatePromptContent(updated) {\n    60→\t\t// Restore from snapshot\n    61→\t\tif snapName != \"\" && c.Audit != nil {\n    62→\t\t\tsnapPath := filepath.Join(c.Audit.ProjectDir, \".cloche\", \"evolution\", \"snapshots\", snapName)\n    63→\t\t\tsnapData, readErr := os.ReadFile(snapPath)\n    64→\t\t\tif readErr == nil {\n    65→\t\t\t\t_ = os.WriteFile(targetPath, snapData, 0644)\n    66→\t\t\t}\n    67→\t\t} else {\n    68→\t\t\t// No snapshot available; restore from in-memory original\n    69→\t\t\t_ = os.WriteFile(targetPath, current, 0644)\n    70→\t\t}\n    71→\n    72→\t\treturn &Change{\n    73→\t\t\tType:     \"prompt_update_rollback\",\n    74→\t\t\tFile:     lesson.Target,\n    75→\t\t\tReason:   fmt.Sprintf(\"curation rolled back: LLM output failed sanity check for lesson %q\", lesson.Insight),\n    76→\t\t\tSnapshot: snapName,\n    77→\t\t}, nil\n    78→\t}\n    79→\n    80→\treturn &Change{\n    81→\t\tType:     \"prompt_update\",\n    82→\t\tFile:     lesson.Target,\n    83→\t\tReason:   lesson.Insight,\n    84→\t\tSnapshot: snapName,\n    85→\t}, nil\n    86→}\n    87→\n    88→// conversationalPrefixes are phrases that indicate LLM commentary leaked into output.\n    89→var conversationalPrefixes = []string{\n    90→\t\"here is\",\n    91→\t\"here's\",\n    92→\t\"sure,\",\n    93→\t\"sure!\",\n    94→\t\"of course\",\n    95→\t\"i've \",\n    96→\t\"i have \",\n    97→\t\"certainly\",\n    98→\t\"absolutely\",\n    99→\t\"let me\",\n   100→\t\"no problem\",\n   101→}\n   102→\n   103→// validatePromptContent checks that content looks like a valid prompt file,\n   104→// not corrupted LLM output or conversational garbage.\n   105→func validatePromptContent(content string) bool {\n   106→\ttrimmed := strings.TrimSpace(content)\n   107→\tif trimmed == \"\" {\n   108→\t\treturn false\n   109→\t}\n   110→\n   111→\t// Must start with a markdown heading\n   112→\tif !strings.HasPrefix(trimmed, \"#\") {\n   113→\t\treturn false\n   114→\t}\n   115→\n   116→\t// Must contain at least one section header (line starting with #)\n   117→\thasHeader := false\n   118→\tfor _, line := range strings.Split(trimmed, \"\\n\") {\n   119→\t\tif strings.HasPrefix(strings.TrimSpace(line), \"#\") {\n   120→\t\t\thasHeader = true\n   121→\t\t\tbreak\n   122→\t\t}\n   123→\t}\n   124→\tif !hasHeader {\n   125→\t\treturn false\n   126→\t}\n   127→\n   128→\t// Must not start with conversational phrases (case-insensitive)\n   129→\tlower := strings.ToLower(trimmed)\n   130→\tfor _, prefix := range conversationalPrefixes {\n   131→\t\tif strings.HasPrefix(lower, prefix) {\n   132→\t\t\treturn false\n   133→\t\t}\n   134→\t}\n   135→\n   136→\treturn true\n   137→}\n   138→\n   139→// stripCodeFences removes markdown code fences from an LLM response,\n   140→// extracting just the content between them. If no fences are found,\n   141→// the input is returned unchanged (trimmed).\n   142→func stripCodeFences(s string) string {\n   143→\ts = strings.TrimSpace(s)\n   144→\n   145→\topenIdx := strings.Index(s, \"```\")\n   146→\tif openIdx == -1 {\n   147→\t\treturn s\n   148→\t}\n   149→\n   150→\t// Skip the opening fence line (may include language hint like ```markdown)\n   151→\tafterOpen := s[openIdx+3:]\n   152→\tnewlineIdx := strings.Index(afterOpen, \"\\n\")\n   153→\tif newlineIdx == -1 {\n   154→\t\treturn s\n   155→\t}\n   156→\tcontentStart := openIdx + 3 + newlineIdx + 1\n   157→\n   158→\t// Find the closing fence (last ``` in the string)\n   159→\tcloseIdx := strings.LastIndex(s, \"```\")\n   160→\tif closeIdx <= openIdx {\n   161→\t\treturn s\n   162→\t}\n   163→\n   164→\treturn s[contentStart:closeIdx]\n   165→}\n   166→"}]},"parent_tool_use_id":null,"session_id":"1dfc0695-6634-43c9-8fed-44daebf0ccee","uuid":"40b27602-b08d-49fa-8bea-fcc87efed214","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/curator.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n)\n\n// Curator merges lessons into prompt files using ACE-style curation.\ntype Curator struct {\n\tLLM   LLMClient\n\tAudit *AuditLogger\n}\n\n// Apply curates a lesson into the target prompt file.\n// After writing, it validates the output. If the content looks corrupted,\n// it restores the pre-write snapshot and reports the rollback.\nfunc (c *Curator) Apply(ctx context.Context, projectDir string, lesson *Lesson) (*Change, error) {\n\ttargetPath := filepath.Join(projectDir, lesson.Target)\n\tcurrent, err := os.ReadFile(targetPath)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading target prompt %s: %w\", lesson.Target, err)\n\t}\n\n\tsystemPrompt := `You are a prompt curator using ACE (Agentic Context Engineering) principles.\nYour job is to merge a new lesson into an existing prompt document.\n\nRules:\n- Append the lesson as a structured bullet/rule in a \"## Learned Rules\" section\n- If a \"## Learned Rules\" section already exists, add to it\n- If the lesson refines or duplicates an existing rule, update in place rather than appending\n- Preserve ALL existing content exactly as-is\n- Keep rules concise and actionable\n- Do not add commentary — return only the updated prompt content`\n\n\tuserPrompt := fmt.Sprintf(\"## Current Prompt Content\\n```\\n%s\\n```\\n\\n## Lesson to Merge\\nInsight: %s\\nSuggested Action: %s\",\n\t\tstring(current), lesson.Insight, lesson.SuggestedAction)\n\n\traw, err := c.LLM.Complete(ctx, systemPrompt, userPrompt)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"curator LLM call: %w\", err)\n\t}\n\n\tupdated := stripCodeFences(raw)\n\n\t// Snapshot before writing\n\tvar snapName string\n\tif c.Audit != nil {\n\t\tsnapName, _ = c.Audit.Snapshot(lesson.Target)\n\t}\n\n\tif err := os.WriteFile(targetPath, []byte(updated), 0644); err != nil {\n\t\treturn nil, fmt.Errorf(\"writing updated prompt: %w\", err)\n\t}\n\n\t// Validate the written content; rollback if corrupted\n\tif !validatePromptContent(updated) {\n\t\t// Restore from snapshot\n\t\tif snapName != \"\" && c.Audit != nil {\n\t\t\tsnapPath := filepath.Join(c.Audit.ProjectDir, \".cloche\", \"evolution\", \"snapshots\", snapName)\n\t\t\tsnapData, readErr := os.ReadFile(snapPath)\n\t\t\tif readErr == nil {\n\t\t\t\t_ = os.WriteFile(targetPath, snapData, 0644)\n\t\t\t}\n\t\t} else {\n\t\t\t// No snapshot available; restore from in-memory original\n\t\t\t_ = os.WriteFile(targetPath, current, 0644)\n\t\t}\n\n\t\treturn &Change{\n\t\t\tType:     \"prompt_update_rollback\",\n\t\t\tFile:     lesson.Target,\n\t\t\tReason:   fmt.Sprintf(\"curation rolled back: LLM output failed sanity check for lesson %q\", lesson.Insight),\n\t\t\tSnapshot: snapName,\n\t\t}, nil\n\t}\n\n\treturn &Change{\n\t\tType:     \"prompt_update\",\n\t\tFile:     lesson.Target,\n\t\tReason:   lesson.Insight,\n\t\tSnapshot: snapName,\n\t}, nil\n}\n\n// conversationalPrefixes are phrases that indicate LLM commentary leaked into output.\nvar conversationalPrefixes = []string{\n\t\"here is\",\n\t\"here's\",\n\t\"sure,\",\n\t\"sure!\",\n\t\"of course\",\n\t\"i've \",\n\t\"i have \",\n\t\"certainly\",\n\t\"absolutely\",\n\t\"let me\",\n\t\"no problem\",\n}\n\n// validatePromptContent checks that content looks like a valid prompt file,\n// not corrupted LLM output or conversational garbage.\nfunc validatePromptContent(content string) bool {\n\ttrimmed := strings.TrimSpace(content)\n\tif trimmed == \"\" {\n\t\treturn false\n\t}\n\n\t// Must start with a markdown heading\n\tif !strings.HasPrefix(trimmed, \"#\") {\n\t\treturn false\n\t}\n\n\t// Must contain at least one section header (line starting with #)\n\thasHeader := false\n\tfor _, line := range strings.Split(trimmed, \"\\n\") {\n\t\tif strings.HasPrefix(strings.TrimSpace(line), \"#\") {\n\t\t\thasHeader = true\n\t\t\tbreak\n\t\t}\n\t}\n\tif !hasHeader {\n\t\treturn false\n\t}\n\n\t// Must not start with conversational phrases (case-insensitive)\n\tlower := strings.ToLower(trimmed)\n\tfor _, prefix := range conversationalPrefixes {\n\t\tif strings.HasPrefix(lower, prefix) {\n\t\t\treturn false\n\t\t}\n\t}\n\n\treturn true\n}\n\n// stripCodeFences removes markdown code fences from an LLM response,\n// extracting just the content between them. If no fences are found,\n// the input is returned unchanged (trimmed).\nfunc stripCodeFences(s string) string {\n\ts = strings.TrimSpace(s)\n\n\topenIdx := strings.Index(s, \"```\")\n\tif openIdx == -1 {\n\t\treturn s\n\t}\n\n\t// Skip the opening fence line (may include language hint like ```markdown)\n\tafterOpen := s[openIdx+3:]\n\tnewlineIdx := strings.Index(afterOpen, \"\\n\")\n\tif newlineIdx == -1 {\n\t\treturn s\n\t}\n\tcontentStart := openIdx + 3 + newlineIdx + 1\n\n\t// Find the closing fence (last ``` in the string)\n\tcloseIdx := strings.LastIndex(s, \"```\")\n\tif closeIdx <= openIdx {\n\t\treturn s\n\t}\n\n\treturn s[contentStart:closeIdx]\n}\n","numLines":166,"startLine":1,"totalLines":166}}}
