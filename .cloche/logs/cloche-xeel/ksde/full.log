[2026-03-15T16:10:51Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0146kcPaacfxgEfWWTyBPkqe","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"strings\"\n     9→\t\"testing\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    12→\t\"github.com/stretchr/testify/assert\"\n    13→\t\"github.com/stretchr/testify/require\"\n    14→)\n    15→\n    16→// fakeLLM returns a fixed response for testing.\n    17→type fakeLLM struct {\n    18→\tresponse string\n    19→}\n    20→\n    21→func (f *fakeLLM) Complete(ctx context.Context, system, user string) (string, error) {\n    22→\treturn f.response, nil\n    23→}\n    24→\n    25→// --- Collector tests ---\n    26→\n    27→func TestCollectorGathersData(t *testing.T) {\n    28→\tdir := t.TempDir()\n    29→\n    30→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n    31→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n    32→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n    33→\t\t[]byte(\"# Knowledge Base\\n\"), 0644)\n    34→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n    35→\t\t[]byte(\"Write good code\"), 0644)\n    36→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n    37→\t\t[]byte(`workflow \"develop\" {\n    38→  step impl {\n    39→    prompt = file(\".cloche/prompts/implement.md\")\n    40→    results = [success]\n    41→  }\n    42→  impl:success -> done\n    43→}`), 0644)\n    44→\n    45→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n    46→\tdata, err := c.Collect(context.Background(), nil, nil)\n    47→\trequire.NoError(t, err)\n    48→\n    49→\tassert.Equal(t, \"# Knowledge Base\\n\", data.KnowledgeBase)\n    50→\tassert.Contains(t, data.CurrentPrompts, \".cloche/prompts/implement.md\")\n    51→\tassert.Equal(t, \"Write good code\", data.CurrentPrompts[\".cloche/prompts/implement.md\"])\n    52→\tassert.NotEmpty(t, data.CurrentWorkflow)\n    53→\tassert.Equal(t, dir, data.ProjectDir)\n    54→\tassert.Equal(t, \"develop\", data.WorkflowName)\n    55→}\n    56→\n    57→func TestCollectorNoKnowledgeBase(t *testing.T) {\n    58→\tdir := t.TempDir()\n    59→\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n    60→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n    61→\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n    62→\n    63→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n    64→\tdata, err := c.Collect(context.Background(), nil, nil)\n    65→\trequire.NoError(t, err)\n    66→\tassert.Empty(t, data.KnowledgeBase)\n    67→}\n    68→\n    69→func TestExtractPromptFiles(t *testing.T) {\n    70→\tworkflow := `step impl { prompt = file(\".cloche/prompts/implement.md\") }\n    71→step fix { prompt = file(\".cloche/prompts/fix.md\") }\n    72→step test { run = \"make test\" }`\n    73→\n    74→\tfiles := extractPromptFiles(workflow)\n    75→\tassert.Len(t, files, 2)\n    76→\tassert.Contains(t, files, \".cloche/prompts/implement.md\")\n    77→\tassert.Contains(t, files, \".cloche/prompts/fix.md\")\n    78→}\n    79→\n    80→// --- Classifier tests ---\n    81→\n    82→func TestClassifierCategorizesRun(t *testing.T) {\n    83→\ttests := []struct {\n    84→\t\tname     string\n    85→\t\tresponse string\n    86→\t\texpected string\n    87→\t}{\n    88→\t\t{\"bug\", `{\"classification\": \"bug\"}`, \"bug\"},\n    89→\t\t{\"feature\", `{\"classification\": \"feature\"}`, \"feature\"},\n    90→\t\t{\"feedback\", `{\"classification\": \"feedback\"}`, \"feedback\"},\n    91→\t\t{\"enhancement\", `{\"classification\": \"enhancement\"}`, \"enhancement\"},\n    92→\t\t{\"chore\", `{\"classification\": \"chore\"}`, \"chore\"},\n    93→\t\t{\"invalid defaults to feature\", `{\"classification\": \"unknown\"}`, \"feature\"},\n    94→\t\t{\"malformed JSON defaults to feature\", `not json`, \"feature\"},\n    95→\t}\n    96→\n    97→\tfor _, tt := range tests {\n    98→\t\tt.Run(tt.name, func(t *testing.T) {\n    99→\t\t\tllm := &fakeLLM{response: tt.response}\n   100→\t\t\tc := &Classifier{LLM: llm}\n   101→\t\t\tresult, err := c.Classify(context.Background(), \"some prompt\")\n   102→\t\t\trequire.NoError(t, err)\n   103→\t\t\tassert.Equal(t, tt.expected, result)\n   104→\t\t})\n   105→\t}\n   106→}\n   107→\n   108→// --- Reflector tests ---\n   109→\n   110→func TestReflectorExtractsLessons(t *testing.T) {\n   111→\tlessonsJSON, _ := json.Marshal(map[string]any{\n   112→\t\t\"lessons\": []map[string]any{\n   113→\t\t\t{\n   114→\t\t\t\t\"id\":               \"lesson-001\",\n   115→\t\t\t\t\"category\":         \"prompt_improvement\",\n   116→\t\t\t\t\"target\":           \".cloche/prompts/implement.md\",\n   117→\t\t\t\t\"insight\":          \"Agent produces unsanitized HTML\",\n   118→\t\t\t\t\"suggested_action\": \"Add sanitization rule\",\n   119→\t\t\t\t\"evidence\":         []string{\"run-1\", \"run-2\"},\n   120→\t\t\t\t\"confidence\":       \"high\",\n   121→\t\t\t},\n   122→\t\t},\n   123→\t})\n   124→\n   125→\tllm := &fakeLLM{response: string(lessonsJSON)}\n   126→\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n   127→\n   128→\tdata := &CollectedData{WorkflowName: \"develop\", KnowledgeBase: \"# KB\\n\"}\n   129→\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n   130→\trequire.NoError(t, err)\n   131→\trequire.Len(t, lessons, 1)\n   132→\tassert.Equal(t, \"prompt_improvement\", lessons[0].Category)\n   133→\tassert.Equal(t, \"high\", lessons[0].Confidence)\n   134→}\n   135→\n   136→func TestReflectorFiltersLowConfidence(t *testing.T) {\n   137→\tlessonsJSON, _ := json.Marshal(map[string]any{\n   138→\t\t\"lessons\": []map[string]any{\n   139→\t\t\t{\"id\": \"L1\", \"category\": \"new_step\", \"confidence\": \"low\"},\n   140→\t\t\t{\"id\": \"L2\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n   141→\t\t},\n   142→\t})\n   143→\n   144→\tllm := &fakeLLM{response: string(lessonsJSON)}\n   145→\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n   146→\n   147→\tlessons, err := r.Reflect(context.Background(), &CollectedData{}, \"bug\")\n   148→\trequire.NoError(t, err)\n   149→\tassert.Len(t, lessons, 1)\n   150→\tassert.Equal(t, \"L2\", lessons[0].ID)\n   151→}\n   152→\n   153→func TestConfidenceLevel(t *testing.T) {\n   154→\tassert.Equal(t, 3, confidenceLevel(\"high\"))\n   155→\tassert.Equal(t, 2, confidenceLevel(\"medium\"))\n   156→\tassert.Equal(t, 1, confidenceLevel(\"low\"))\n   157→\tassert.Equal(t, 0, confidenceLevel(\"\"))\n   158→}\n   159→\n   160→// --- Audit Logger tests ---\n   161→\n   162→func TestAuditLoggerAppendsJSONL(t *testing.T) {\n   163→\tdir := t.TempDir()\n   164→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\"), 0755)\n   165→\n   166→\tlogger := &AuditLogger{ProjectDir: dir}\n   167→\n   168→\tresult1 := &EvolutionResult{\n   169→\t\tID:           \"evo-1\",\n   170→\t\tWorkflowName: \"develop\",\n   171→\t\tChanges:      []Change{{Type: \"prompt_update\", File: \".cloche/prompts/impl.md\"}},\n   172→\t}\n   173→\trequire.NoError(t, logger.Log(result1))\n   174→\n   175→\tresult2 := &EvolutionResult{\n   176→\t\tID:           \"evo-2\",\n   177→\t\tWorkflowName: \"develop\",\n   178→\t\tChanges:      []Change{{Type: \"add_step\", File: \".cloche/develop.cloche\"}},\n   179→\t}\n   180→\trequire.NoError(t, logger.Log(result2))\n   181→\n   182→\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n   183→\trequire.NoError(t, err)\n   184→\n   185→\tlines := strings.Split(strings.TrimSpace(string(content)), \"\\n\")\n   186→\tassert.Len(t, lines, 2)\n   187→\n   188→\tvar entry1 EvolutionResult\n   189→\trequire.NoError(t, json.Unmarshal([]byte(lines[0]), &entry1))\n   190→\tassert.Equal(t, \"evo-1\", entry1.ID)\n   191→}\n   192→\n   193→func TestAuditLoggerSnapshot(t *testing.T) {\n   194→\tdir := t.TempDir()\n   195→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   196→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   197→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"original content\"), 0644)\n   198→\n   199→\tlogger := &AuditLogger{ProjectDir: dir}\n   200→\tsnapName, err := logger.Snapshot(\".cloche/prompts/implement.md\")\n   201→\trequire.NoError(t, err)\n   202→\tassert.NotEmpty(t, snapName)\n   203→\n   204→\tsnapPath := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\", snapName)\n   205→\tcontent, err := os.ReadFile(snapPath)\n   206→\trequire.NoError(t, err)\n   207→\tassert.Equal(t, \"original content\", string(content))\n   208→}\n   209→\n   210→func TestAuditLoggerUpdatesKnowledge(t *testing.T) {\n   211→\tdir := t.TempDir()\n   212→\tkbDir := filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\")\n   213→\tos.MkdirAll(kbDir, 0755)\n   214→\tos.WriteFile(filepath.Join(kbDir, \"develop.md\"), []byte(\"# Knowledge Base: develop workflow\\n\"), 0644)\n   215→\n   216→\tlogger := &AuditLogger{ProjectDir: dir}\n   217→\tlessons := []Lesson{\n   218→\t\t{\n   219→\t\t\tID:              \"P001\",\n   220→\t\t\tCategory:        \"prompt_improvement\",\n   221→\t\t\tConfidence:      \"high\",\n   222→\t\t\tInsight:         \"Always sanitize HTML inputs\",\n   223→\t\t\tSuggestedAction: \"Add rule to implement prompt\",\n   224→\t\t\tEvidence:        []string{\"run-1\", \"run-2\"},\n   225→\t\t},\n   226→\t}\n   227→\n   228→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", lessons))\n   229→\n   230→\tcontent, err := os.ReadFile(filepath.Join(kbDir, \"develop.md\"))\n   231→\trequire.NoError(t, err)\n   232→\tassert.Contains(t, string(content), \"[P001]\")\n   233→\tassert.Contains(t, string(content), \"sanitize HTML\")\n   234→\tassert.Contains(t, string(content), \"run-1, run-2\")\n   235→}\n   236→\n   237→// --- LLM Client tests ---\n   238→\n   239→// --- Curator tests ---\n   240→\n   241→func TestCuratorUpdatesPrompt(t *testing.T) {\n   242→\tdir := t.TempDir()\n   243→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   244→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   245→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   246→\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   247→\n   248→\tupdatedContent := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"\n   249→\tllm := &fakeLLM{response: updatedContent}\n   250→\n   251→\taudit := &AuditLogger{ProjectDir: dir}\n   252→\tc := &Curator{LLM: llm, Audit: audit}\n   253→\tlesson := &Lesson{\n   254→\t\tID:              \"lesson-001\",\n   255→\t\tCategory:        \"prompt_improvement\",\n   256→\t\tTarget:          \".cloche/prompts/implement.md\",\n   257→\t\tInsight:         \"XSS vulnerabilities in form handlers\",\n   258→\t\tSuggestedAction: \"Add sanitization rule\",\n   259→\t}\n   260→\n   261→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   262→\trequire.NoError(t, err)\n   263→\tassert.Equal(t, \"prompt_update\", change.Type)\n   264→\tassert.Equal(t, \".cloche/prompts/implement.md\", change.File)\n   265→\tassert.NotEmpty(t, change.Snapshot)\n   266→\n   267→\tcontent, err := os.ReadFile(promptPath)\n   268→\trequire.NoError(t, err)\n   269→\tassert.Contains(t, string(content), \"sanitize user inputs\")\n   270→}\n   271→\n   272→// --- stripCodeFences tests ---\n   273→\n   274→func TestStripCodeFences(t *testing.T) {\n   275→\ttests := []struct {\n   276→\t\tname     string\n   277→\t\tinput    string\n   278→\t\texpected string\n   279→\t}{\n   280→\t\t{\n   281→\t\t\tname:     \"no fences returns as-is\",\n   282→\t\t\tinput:    \"# Prompt\\n\\nDo good work.\\n\",\n   283→\t\t\texpected: \"# Prompt\\n\\nDo good work.\",\n   284→\t\t},\n   285→\t\t{\n   286→\t\t\tname:     \"plain code fence\",\n   287→\t\t\tinput:    \"```\\n# Prompt\\n\\nDo good work.\\n```\",\n   288→\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   289→\t\t},\n   290→\t\t{\n   291→\t\t\tname:     \"code fence with language hint\",\n   292→\t\t\tinput:    \"```markdown\\n# Prompt\\n\\nDo good work.\\n```\",\n   293→\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   294→\t\t},\n   295→\t\t{\n   296→\t\t\tname:     \"commentary before and after fence\",\n   297→\t\t\tinput:    \"Here's the updated prompt:\\n\\n```markdown\\n# Prompt\\n\\nDo good work.\\n```\\n\\nI've added the rule as requested.\",\n   298→\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   299→\t\t},\n   300→\t\t{\n   301→\t\t\tname:     \"no closing fence returns as-is\",\n   302→\t\t\tinput:    \"```markdown\\n# Prompt\\n\",\n   303→\t\t\texpected: \"```markdown\\n# Prompt\",\n   304→\t\t},\n   305→\t}\n   306→\n   307→\tfor _, tt := range tests {\n   308→\t\tt.Run(tt.name, func(t *testing.T) {\n   309→\t\t\tassert.Equal(t, tt.expected, stripCodeFences(tt.input))\n   310→\t\t})\n   311→\t}\n   312→}\n   313→\n   314→func TestCuratorStripsCodeFencesFromResponse(t *testing.T) {\n   315→\tdir := t.TempDir()\n   316→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   317→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   318→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   319→\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   320→\n   321→\t// LLM returns content wrapped in code fences with commentary\n   322→\tfencedResponse := \"Here is the updated prompt:\\n\\n```markdown\\n# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n```\\n\\nI added the validation rule.\"\n   323→\tllm := &fakeLLM{response: fencedResponse}\n   324→\n   325→\taudit := &AuditLogger{ProjectDir: dir}\n   326→\tc := &Curator{LLM: llm, Audit: audit}\n   327→\tlesson := &Lesson{\n   328→\t\tTarget:          \".cloche/prompts/implement.md\",\n   329→\t\tInsight:         \"Missing input validation\",\n   330→\t\tSuggestedAction: \"Add validation rule\",\n   331→\t}\n   332→\n   333→\t_, err := c.Apply(context.Background(), dir, lesson)\n   334→\trequire.NoError(t, err)\n   335→\n   336→\tcontent, err := os.ReadFile(promptPath)\n   337→\trequire.NoError(t, err)\n   338→\n   339→\t// Should contain the actual prompt content, not the commentary\n   340→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   341→\tassert.Contains(t, string(content), \"Always validate inputs\")\n   342→\tassert.NotContains(t, string(content), \"Here is the updated prompt\")\n   343→\tassert.NotContains(t, string(content), \"I added the validation rule\")\n   344→\tassert.NotContains(t, string(content), \"```\")\n   345→}\n   346→\n   347→// --- Script Generator tests ---\n   348→\n   349→func TestScriptGeneratorCreatesScript(t *testing.T) {\n   350→\tdir := t.TempDir()\n   351→\n   352→\tllm := &fakeLLM{response: `{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`}\n   353→\tg := &ScriptGenerator{LLM: llm}\n   354→\n   355→\tlesson := &Lesson{\n   356→\t\tID:              \"lesson-001\",\n   357→\t\tCategory:        \"new_step\",\n   358→\t\tStepType:        \"script\",\n   359→\t\tInsight:         \"No security scanning\",\n   360→\t\tSuggestedAction: \"Add gosec security scan\",\n   361→\t}\n   362→\n   363→\tresult, err := g.Generate(context.Background(), dir, lesson)\n   364→\trequire.NoError(t, err)\n   365→\tassert.Equal(t, \"scripts/security-scan.sh\", result.Path)\n   366→\n   367→\tcontent, err := os.ReadFile(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n   368→\trequire.NoError(t, err)\n   369→\tassert.Contains(t, string(content), \"gosec\")\n   370→\n   371→\tinfo, err := os.Stat(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n   372→\trequire.NoError(t, err)\n   373→\tassert.NotZero(t, info.Mode()&0111) // executable\n   374→}\n   375→\n   376→// --- LLM Client tests ---\n   377→\n   378→func TestCommandLLMClient(t *testing.T) {\n   379→\tc := &CommandLLMClient{Command: \"cat\", Args: []string{}}\n   380→\tresult, err := c.Complete(context.Background(), \"system\", \"user prompt\")\n   381→\trequire.NoError(t, err)\n   382→\tassert.Contains(t, result, \"user prompt\")\n   383→\tassert.Contains(t, result, \"system\")\n   384→}\n   385→\n   386→// --- Orchestrator tests ---\n   387→\n   388→// scriptedLLM returns responses in order.\n   389→type scriptedLLM struct {\n   390→\tresponses []string\n   391→\tidx       int\n   392→}\n   393→\n   394→func (s *scriptedLLM) Complete(ctx context.Context, system, user string) (string, error) {\n   395→\tresp := s.responses[s.idx]\n   396→\ts.idx++\n   397→\treturn resp, nil\n   398→}\n   399→\n   400→func TestOrchestratorEndToEnd(t *testing.T) {\n   401→\tdir := t.TempDir()\n   402→\n   403→\t// Set up project structure\n   404→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   405→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   406→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   407→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n   408→\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n   409→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n   410→\t\t[]byte(\"Write good code.\\n\"), 0644)\n   411→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   412→\t\t[]byte(`workflow \"develop\" {\n   413→  step implement {\n   414→    prompt = file(\".cloche/prompts/implement.md\")\n   415→    results = [success, fail]\n   416→  }\n   417→  step test {\n   418→    run = \"make test\"\n   419→    results = [success, fail]\n   420→  }\n   421→  implement:success -> test\n   422→  test:success -> done\n   423→  test:fail -> abort\n   424→}`), 0644)\n   425→\n   426→\t// Fake LLM that returns appropriate responses per stage\n   427→\tllm := &scriptedLLM{\n   428→\t\tresponses: []string{\n   429→\t\t\t// Classifier\n   430→\t\t\t`{\"classification\": \"bug\"}`,\n   431→\t\t\t// Reflector\n   432→\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n   433→\t\t\t// Curator\n   434→\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n   435→\t\t},\n   436→\t}\n   437→\n   438→\torch := NewOrchestrator(OrchestratorConfig{\n   439→\t\tProjectDir:    dir,\n   440→\t\tWorkflowName:  \"develop\",\n   441→\t\tLLM:           llm,\n   442→\t\tMinConfidence: \"medium\",\n   443→\t})\n   444→\n   445→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   446→\trequire.NoError(t, err)\n   447→\tassert.Equal(t, \"bug\", result.Classification)\n   448→\trequire.Len(t, result.Changes, 1)\n   449→\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n   450→\n   451→\t// Verify prompt was actually updated\n   452→\tcontent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n   453→\tassert.Contains(t, string(content), \"sanitize user inputs\")\n   454→\n   455→\t// Verify audit log was written\n   456→\tlogContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n   457→\tassert.Contains(t, string(logContent), \"prompt_update\")\n   458→\tassert.Contains(t, string(logContent), \"XSS pattern\")\n   459→\n   460→\t// Verify knowledge base was updated\n   461→\tkbContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"))\n   462→\tassert.Contains(t, string(kbContent), \"L001\")\n   463→}\n   464→\n   465→func TestOrchestratorNewStepWiredIntoGraph(t *testing.T) {\n   466→\tdir := t.TempDir()\n   467→\n   468→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   469→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   470→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n   471→\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n   472→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   473→\t\t[]byte(`workflow \"develop\" {\n   474→  step implement {\n   475→    prompt = file(\".cloche/prompts/implement.md\")\n   476→    results = [success, fail]\n   477→  }\n   478→  step test {\n   479→    run = \"make test\"\n   480→    results = [success, fail]\n   481→  }\n   482→  implement:success -> test\n   483→  implement:fail -> abort\n   484→  test:success -> done\n   485→  test:fail -> abort\n   486→}`), 0644)\n   487→\n   488→\tllm := &scriptedLLM{\n   489→\t\tresponses: []string{\n   490→\t\t\t// Classifier\n   491→\t\t\t`{\"classification\": \"enhancement\"}`,\n   492→\t\t\t// Reflector\n   493→\t\t\t`{\"lessons\": [{\"id\": \"L002\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"No security scanning\", \"suggested_action\": \"Add gosec scan\", \"evidence\": [\"run-2\"], \"confidence\": \"high\"}]}`,\n   494→\t\t\t// ScriptGenerator\n   495→\t\t\t`{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`,\n   496→\t\t},\n   497→\t}\n   498→\n   499→\torch := NewOrchestrator(OrchestratorConfig{\n   500→\t\tProjectDir:    dir,\n   501→\t\tWorkflowName:  \"develop\",\n   502→\t\tLLM:           llm,\n   503→\t\tMinConfidence: \"medium\",\n   504→\t})\n   505→\n   506→\tresult, err := orch.Run(context.Background(), \"run-2\", nil, nil)\n   507→\trequire.NoError(t, err)\n   508→\trequire.Len(t, result.Changes, 2) // add_script + add_step\n   509→\tassert.Equal(t, \"add_script\", result.Changes[0].Type)\n   510→\tassert.Equal(t, \"add_step\", result.Changes[1].Type)\n   511→\n   512→\t// Read the updated workflow and verify the new step is reachable\n   513→\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   514→\trequire.NoError(t, err)\n   515→\n   516→\twfStr := string(wfContent)\n   517→\t// The new step should be wired into the graph\n   518→\tassert.Contains(t, wfStr, \"step security-scan\")\n   519→\t// An existing step should wire to the new step (rewired from -> done)\n   520→\tassert.Contains(t, wfStr, \"test:success -> security-scan\")\n   521→\t// The new step should wire its results to terminals\n   522→\tassert.Contains(t, wfStr, \"security-scan:success -> done\")\n   523→\tassert.Contains(t, wfStr, \"security-scan:fail -> abort\")\n   524→\n   525→\t// Verify the workflow parses and validates\n   526→\twf, err := dsl.Parse(wfStr)\n   527→\trequire.NoError(t, err)\n   528→\trequire.NoError(t, wf.Validate())\n   529→}\n   530→\n   531→func TestOrchestratorNoLessons(t *testing.T) {\n   532→\tdir := t.TempDir()\n   533→\n   534→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   535→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   536→\t\t[]byte(`workflow \"develop\" {\n   537→  step s {\n   538→    run = \"echo hi\"\n   539→    results = [success]\n   540→  }\n   541→  s:success -> done\n   542→}`), 0644)\n   543→\n   544→\tllm := &scriptedLLM{\n   545→\t\tresponses: []string{\n   546→\t\t\t// Classifier\n   547→\t\t\t`{\"classification\": \"feature\"}`,\n   548→\t\t\t// Reflector — no lessons\n   549→\t\t\t`{\"lessons\": []}`,\n   550→\t\t},\n   551→\t}\n   552→\n   553→\torch := NewOrchestrator(OrchestratorConfig{\n   554→\t\tProjectDir:    dir,\n   555→\t\tWorkflowName:  \"develop\",\n   556→\t\tLLM:           llm,\n   557→\t\tMinConfidence: \"medium\",\n   558→\t})\n   559→\n   560→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   561→\trequire.NoError(t, err)\n   562→\tassert.Equal(t, \"feature\", result.Classification)\n   563→\tassert.Empty(t, result.Changes)\n   564→}\n   565→"}]},"parent_tool_use_id":null,"session_id":"e4cfca95-080f-4ed6-8c8d-4b515387a6e7","uuid":"6ef91a90-32ef-4024-903f-066ec1503539","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/evolution_test.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// fakeLLM returns a fixed response for testing.\ntype fakeLLM struct {\n\tresponse string\n}\n\nfunc (f *fakeLLM) Complete(ctx context.Context, system, user string) (string, error) {\n\treturn f.response, nil\n}\n\n// --- Collector tests ---\n\nfunc TestCollectorGathersData(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n\t\t[]byte(\"# Knowledge Base\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"Write good code\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step impl {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success]\n  }\n  impl:success -> done\n}`), 0644)\n\n\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n\tdata, err := c.Collect(context.Background(), nil, nil)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, \"# Knowledge Base\\n\", data.KnowledgeBase)\n\tassert.Contains(t, data.CurrentPrompts, \".cloche/prompts/implement.md\")\n\tassert.Equal(t, \"Write good code\", data.CurrentPrompts[\".cloche/prompts/implement.md\"])\n\tassert.NotEmpty(t, data.CurrentWorkflow)\n\tassert.Equal(t, dir, data.ProjectDir)\n\tassert.Equal(t, \"develop\", data.WorkflowName)\n}\n\nfunc TestCollectorNoKnowledgeBase(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n\n\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n\tdata, err := c.Collect(context.Background(), nil, nil)\n\trequire.NoError(t, err)\n\tassert.Empty(t, data.KnowledgeBase)\n}\n\nfunc TestExtractPromptFiles(t *testing.T) {\n\tworkflow := `step impl { prompt = file(\".cloche/prompts/implement.md\") }\nstep fix { prompt = file(\".cloche/prompts/fix.md\") }\nstep test { run = \"make test\" }`\n\n\tfiles := extractPromptFiles(workflow)\n\tassert.Len(t, files, 2)\n\tassert.Contains(t, files, \".cloche/prompts/implement.md\")\n\tassert.Contains(t, files, \".cloche/prompts/fix.md\")\n}\n\n// --- Classifier tests ---\n\nfunc TestClassifierCategorizesRun(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tresponse string\n\t\texpected string\n\t}{\n\t\t{\"bug\", `{\"classification\": \"bug\"}`, \"bug\"},\n\t\t{\"feature\", `{\"classification\": \"feature\"}`, \"feature\"},\n\t\t{\"feedback\", `{\"classification\": \"feedback\"}`, \"feedback\"},\n\t\t{\"enhancement\", `{\"classification\": \"enhancement\"}`, \"enhancement\"},\n\t\t{\"chore\", `{\"classification\": \"chore\"}`, \"chore\"},\n\t\t{\"invalid defaults to feature\", `{\"classification\": \"unknown\"}`, \"feature\"},\n\t\t{\"malformed JSON defaults to feature\", `not json`, \"feature\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tllm := &fakeLLM{response: tt.response}\n\t\t\tc := &Classifier{LLM: llm}\n\t\t\tresult, err := c.Classify(context.Background(), \"some prompt\")\n\t\t\trequire.NoError(t, err)\n\t\t\tassert.Equal(t, tt.expected, result)\n\t\t})\n\t}\n}\n\n// --- Reflector tests ---\n\nfunc TestReflectorExtractsLessons(t *testing.T) {\n\tlessonsJSON, _ := json.Marshal(map[string]any{\n\t\t\"lessons\": []map[string]any{\n\t\t\t{\n\t\t\t\t\"id\":               \"lesson-001\",\n\t\t\t\t\"category\":         \"prompt_improvement\",\n\t\t\t\t\"target\":           \".cloche/prompts/implement.md\",\n\t\t\t\t\"insight\":          \"Agent produces unsanitized HTML\",\n\t\t\t\t\"suggested_action\": \"Add sanitization rule\",\n\t\t\t\t\"evidence\":         []string{\"run-1\", \"run-2\"},\n\t\t\t\t\"confidence\":       \"high\",\n\t\t\t},\n\t\t},\n\t})\n\n\tllm := &fakeLLM{response: string(lessonsJSON)}\n\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n\n\tdata := &CollectedData{WorkflowName: \"develop\", KnowledgeBase: \"# KB\\n\"}\n\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n\trequire.NoError(t, err)\n\trequire.Len(t, lessons, 1)\n\tassert.Equal(t, \"prompt_improvement\", lessons[0].Category)\n\tassert.Equal(t, \"high\", lessons[0].Confidence)\n}\n\nfunc TestReflectorFiltersLowConfidence(t *testing.T) {\n\tlessonsJSON, _ := json.Marshal(map[string]any{\n\t\t\"lessons\": []map[string]any{\n\t\t\t{\"id\": \"L1\", \"category\": \"new_step\", \"confidence\": \"low\"},\n\t\t\t{\"id\": \"L2\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n\t\t},\n\t})\n\n\tllm := &fakeLLM{response: string(lessonsJSON)}\n\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n\n\tlessons, err := r.Reflect(context.Background(), &CollectedData{}, \"bug\")\n\trequire.NoError(t, err)\n\tassert.Len(t, lessons, 1)\n\tassert.Equal(t, \"L2\", lessons[0].ID)\n}\n\nfunc TestConfidenceLevel(t *testing.T) {\n\tassert.Equal(t, 3, confidenceLevel(\"high\"))\n\tassert.Equal(t, 2, confidenceLevel(\"medium\"))\n\tassert.Equal(t, 1, confidenceLevel(\"low\"))\n\tassert.Equal(t, 0, confidenceLevel(\"\"))\n}\n\n// --- Audit Logger tests ---\n\nfunc TestAuditLoggerAppendsJSONL(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\"), 0755)\n\n\tlogger := &AuditLogger{ProjectDir: dir}\n\n\tresult1 := &EvolutionResult{\n\t\tID:           \"evo-1\",\n\t\tWorkflowName: \"develop\",\n\t\tChanges:      []Change{{Type: \"prompt_update\", File: \".cloche/prompts/impl.md\"}},\n\t}\n\trequire.NoError(t, logger.Log(result1))\n\n\tresult2 := &EvolutionResult{\n\t\tID:           \"evo-2\",\n\t\tWorkflowName: \"develop\",\n\t\tChanges:      []Change{{Type: \"add_step\", File: \".cloche/develop.cloche\"}},\n\t}\n\trequire.NoError(t, logger.Log(result2))\n\n\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n\trequire.NoError(t, err)\n\n\tlines := strings.Split(strings.TrimSpace(string(content)), \"\\n\")\n\tassert.Len(t, lines, 2)\n\n\tvar entry1 EvolutionResult\n\trequire.NoError(t, json.Unmarshal([]byte(lines[0]), &entry1))\n\tassert.Equal(t, \"evo-1\", entry1.ID)\n}\n\nfunc TestAuditLoggerSnapshot(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"original content\"), 0644)\n\n\tlogger := &AuditLogger{ProjectDir: dir}\n\tsnapName, err := logger.Snapshot(\".cloche/prompts/implement.md\")\n\trequire.NoError(t, err)\n\tassert.NotEmpty(t, snapName)\n\n\tsnapPath := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\", snapName)\n\tcontent, err := os.ReadFile(snapPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"original content\", string(content))\n}\n\nfunc TestAuditLoggerUpdatesKnowledge(t *testing.T) {\n\tdir := t.TempDir()\n\tkbDir := filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\")\n\tos.MkdirAll(kbDir, 0755)\n\tos.WriteFile(filepath.Join(kbDir, \"develop.md\"), []byte(\"# Knowledge Base: develop workflow\\n\"), 0644)\n\n\tlogger := &AuditLogger{ProjectDir: dir}\n\tlessons := []Lesson{\n\t\t{\n\t\t\tID:              \"P001\",\n\t\t\tCategory:        \"prompt_improvement\",\n\t\t\tConfidence:      \"high\",\n\t\t\tInsight:         \"Always sanitize HTML inputs\",\n\t\t\tSuggestedAction: \"Add rule to implement prompt\",\n\t\t\tEvidence:        []string{\"run-1\", \"run-2\"},\n\t\t},\n\t}\n\n\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", lessons))\n\n\tcontent, err := os.ReadFile(filepath.Join(kbDir, \"develop.md\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"[P001]\")\n\tassert.Contains(t, string(content), \"sanitize HTML\")\n\tassert.Contains(t, string(content), \"run-1, run-2\")\n}\n\n// --- LLM Client tests ---\n\n// --- Curator tests ---\n\nfunc TestCuratorUpdatesPrompt(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n\n\tupdatedContent := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"\n\tllm := &fakeLLM{response: updatedContent}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tID:              \"lesson-001\",\n\t\tCategory:        \"prompt_improvement\",\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"XSS vulnerabilities in form handlers\",\n\t\tSuggestedAction: \"Add sanitization rule\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"prompt_update\", change.Type)\n\tassert.Equal(t, \".cloche/prompts/implement.md\", change.File)\n\tassert.NotEmpty(t, change.Snapshot)\n\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"sanitize user inputs\")\n}\n\n// --- stripCodeFences tests ---\n\nfunc TestStripCodeFences(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tinput    string\n\t\texpected string\n\t}{\n\t\t{\n\t\t\tname:     \"no fences returns as-is\",\n\t\t\tinput:    \"# Prompt\\n\\nDo good work.\\n\",\n\t\t\texpected: \"# Prompt\\n\\nDo good work.\",\n\t\t},\n\t\t{\n\t\t\tname:     \"plain code fence\",\n\t\t\tinput:    \"```\\n# Prompt\\n\\nDo good work.\\n```\",\n\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n\t\t},\n\t\t{\n\t\t\tname:     \"code fence with language hint\",\n\t\t\tinput:    \"```markdown\\n# Prompt\\n\\nDo good work.\\n```\",\n\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n\t\t},\n\t\t{\n\t\t\tname:     \"commentary before and after fence\",\n\t\t\tinput:    \"Here's the updated prompt:\\n\\n```markdown\\n# Prompt\\n\\nDo good work.\\n```\\n\\nI've added the rule as requested.\",\n\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n\t\t},\n\t\t{\n\t\t\tname:     \"no closing fence returns as-is\",\n\t\t\tinput:    \"```markdown\\n# Prompt\\n\",\n\t\t\texpected: \"```markdown\\n# Prompt\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, tt.expected, stripCodeFences(tt.input))\n\t\t})\n\t}\n}\n\nfunc TestCuratorStripsCodeFencesFromResponse(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n\n\t// LLM returns content wrapped in code fences with commentary\n\tfencedResponse := \"Here is the updated prompt:\\n\\n```markdown\\n# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n```\\n\\nI added the validation rule.\"\n\tllm := &fakeLLM{response: fencedResponse}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Missing input validation\",\n\t\tSuggestedAction: \"Add validation rule\",\n\t}\n\n\t_, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\n\t// Should contain the actual prompt content, not the commentary\n\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n\tassert.Contains(t, string(content), \"Always validate inputs\")\n\tassert.NotContains(t, string(content), \"Here is the updated prompt\")\n\tassert.NotContains(t, string(content), \"I added the validation rule\")\n\tassert.NotContains(t, string(content), \"```\")\n}\n\n// --- Script Generator tests ---\n\nfunc TestScriptGeneratorCreatesScript(t *testing.T) {\n\tdir := t.TempDir()\n\n\tllm := &fakeLLM{response: `{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`}\n\tg := &ScriptGenerator{LLM: llm}\n\n\tlesson := &Lesson{\n\t\tID:              \"lesson-001\",\n\t\tCategory:        \"new_step\",\n\t\tStepType:        \"script\",\n\t\tInsight:         \"No security scanning\",\n\t\tSuggestedAction: \"Add gosec security scan\",\n\t}\n\n\tresult, err := g.Generate(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"scripts/security-scan.sh\", result.Path)\n\n\tcontent, err := os.ReadFile(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"gosec\")\n\n\tinfo, err := os.Stat(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n\trequire.NoError(t, err)\n\tassert.NotZero(t, info.Mode()&0111) // executable\n}\n\n// --- LLM Client tests ---\n\nfunc TestCommandLLMClient(t *testing.T) {\n\tc := &CommandLLMClient{Command: \"cat\", Args: []string{}}\n\tresult, err := c.Complete(context.Background(), \"system\", \"user prompt\")\n\trequire.NoError(t, err)\n\tassert.Contains(t, result, \"user prompt\")\n\tassert.Contains(t, result, \"system\")\n}\n\n// --- Orchestrator tests ---\n\n// scriptedLLM returns responses in order.\ntype scriptedLLM struct {\n\tresponses []string\n\tidx       int\n}\n\nfunc (s *scriptedLLM) Complete(ctx context.Context, system, user string) (string, error) {\n\tresp := s.responses[s.idx]\n\ts.idx++\n\treturn resp, nil\n}\n\nfunc TestOrchestratorEndToEnd(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Set up project structure\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"Write good code.\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n  implement:success -> test\n  test:success -> done\n  test:fail -> abort\n}`), 0644)\n\n\t// Fake LLM that returns appropriate responses per stage\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t// Reflector\n\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t\t// Curator\n\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"bug\", result.Classification)\n\trequire.Len(t, result.Changes, 1)\n\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n\n\t// Verify prompt was actually updated\n\tcontent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n\tassert.Contains(t, string(content), \"sanitize user inputs\")\n\n\t// Verify audit log was written\n\tlogContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n\tassert.Contains(t, string(logContent), \"prompt_update\")\n\tassert.Contains(t, string(logContent), \"XSS pattern\")\n\n\t// Verify knowledge base was updated\n\tkbContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"))\n\tassert.Contains(t, string(kbContent), \"L001\")\n}\n\nfunc TestOrchestratorNewStepWiredIntoGraph(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n  implement:success -> test\n  implement:fail -> abort\n  test:success -> done\n  test:fail -> abort\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"enhancement\"}`,\n\t\t\t// Reflector\n\t\t\t`{\"lessons\": [{\"id\": \"L002\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"No security scanning\", \"suggested_action\": \"Add gosec scan\", \"evidence\": [\"run-2\"], \"confidence\": \"high\"}]}`,\n\t\t\t// ScriptGenerator\n\t\t\t`{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-2\", nil, nil)\n\trequire.NoError(t, err)\n\trequire.Len(t, result.Changes, 2) // add_script + add_step\n\tassert.Equal(t, \"add_script\", result.Changes[0].Type)\n\tassert.Equal(t, \"add_step\", result.Changes[1].Type)\n\n\t// Read the updated workflow and verify the new step is reachable\n\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n\trequire.NoError(t, err)\n\n\twfStr := string(wfContent)\n\t// The new step should be wired into the graph\n\tassert.Contains(t, wfStr, \"step security-scan\")\n\t// An existing step should wire to the new step (rewired from -> done)\n\tassert.Contains(t, wfStr, \"test:success -> security-scan\")\n\t// The new step should wire its results to terminals\n\tassert.Contains(t, wfStr, \"security-scan:success -> done\")\n\tassert.Contains(t, wfStr, \"security-scan:fail -> abort\")\n\n\t// Verify the workflow parses and validates\n\twf, err := dsl.Parse(wfStr)\n\trequire.NoError(t, err)\n\trequire.NoError(t, wf.Validate())\n}\n\nfunc TestOrchestratorNoLessons(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step s {\n    run = \"echo hi\"\n    results = [success]\n  }\n  s:success -> done\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"feature\"}`,\n\t\t\t// Reflector — no lessons\n\t\t\t`{\"lessons\": []}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"feature\", result.Classification)\n\tassert.Empty(t, result.Changes)\n}\n","numLines":565,"startLine":1,"totalLines":565}}}
