[2026-03-15T16:10:51Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01AHoaUxKJeangqMmpoiu4EF","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01WPHdtGDb9kLUUYgssNJgnH","name":"Edit","input":{"replace_all":false,"file_path":"/workspace/internal/evolution/evolution_test.go","old_string":"// --- Script Generator tests ---","new_string":"// --- Curator rollback tests ---\n\nfunc TestCuratorRollsBackOnCorruptedOutput(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\n\toriginalContent := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n\tos.WriteFile(promptPath, []byte(originalContent), 0644)\n\n\t// LLM returns garbage (no heading, conversational)\n\tllm := &fakeLLM{response: \"Sure, here is the updated prompt with your changes applied nicely.\"}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tID:              \"lesson-001\",\n\t\tCategory:        \"prompt_improvement\",\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"XSS vulnerabilities\",\n\t\tSuggestedAction: \"Add sanitization rule\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\n\t// Change should indicate rollback\n\tassert.Equal(t, \"prompt_update_rollback\", change.Type)\n\tassert.Contains(t, change.Reason, \"rolled back\")\n\n\t// Original file content should be preserved\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, originalContent, string(content))\n}\n\nfunc TestCuratorRollbackPreservesSnapshot(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\n\toriginalContent := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n\tos.WriteFile(promptPath, []byte(originalContent), 0644)\n\n\t// LLM returns empty content (fails validation)\n\tllm := &fakeLLM{response: \"\"}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"Missing validation\",\n\t\tSuggestedAction: \"Add rule\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\n\t// Snapshot should NOT be deleted on rollback (it's evidence)\n\tassert.NotEmpty(t, change.Snapshot)\n\tsnapPath := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\", change.Snapshot)\n\t_, err = os.Stat(snapPath)\n\tassert.NoError(t, err, \"snapshot file should still exist after rollback\")\n\n\tsnapContent, err := os.ReadFile(snapPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, originalContent, string(snapContent))\n}\n\nfunc TestCuratorRollbackOnNoHeading(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"fix.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\n\toriginalContent := \"# Fix Prompt\\n\\nFix bugs carefully.\\n\"\n\tos.WriteFile(promptPath, []byte(originalContent), 0644)\n\n\t// LLM returns content without markdown heading\n\tllm := &fakeLLM{response: \"This is just plain text with no heading at all.\"}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tTarget:          \".cloche/prompts/fix.md\",\n\t\tInsight:         \"Bug not fixed\",\n\t\tSuggestedAction: \"Add fix rule\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"prompt_update_rollback\", change.Type)\n\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, originalContent, string(content))\n}\n\n// --- validatePromptContent tests ---\n\nfunc TestValidatePromptContent(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tcontent string\n\t\tvalid   bool\n\t}{\n\t\t{\"valid prompt\", \"# My Prompt\\n\\nDo good work.\\n\", true},\n\t\t{\"valid with learned rules\", \"# Prompt\\n\\n## Learned Rules\\n\\n- Rule 1\\n\", true},\n\t\t{\"empty string\", \"\", false},\n\t\t{\"whitespace only\", \"   \\n\\t\\n  \", false},\n\t\t{\"no heading\", \"This is just text without any heading.\", false},\n\t\t{\"conversational prefix\", \"Sure, here is the updated prompt.\", false},\n\t\t{\"here is prefix\", \"Here is the updated content with changes.\", false},\n\t\t{\"of course prefix\", \"Of course! Here are the changes.\", false},\n\t\t{\"plain text no hash\", \"Write good code and be careful.\", false},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, tt.valid, validatePromptContent(tt.content))\n\t\t})\n\t}\n}\n\n// --- Script Generator tests ---"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":370,"cache_read_input_tokens":34102,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":370},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e4cfca95-080f-4ed6-8c8d-4b515387a6e7","uuid":"5bb36938-ed39-44c3-91f4-1e1454e98ae1"}
