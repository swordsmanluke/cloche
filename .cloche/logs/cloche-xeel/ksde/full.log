ing","+    content string","+    valid   bool","+  }{","+    {\"valid prompt\", \"# My Prompt\\n\\nDo good work.\\n\", true},","+    {\"valid with learned rules\", \"# Prompt\\n\\n## Learned Rules\\n\\n- Rule 1\\n\", true},","+    {\"empty string\", \"\", false},","+    {\"whitespace only\", \"   \\n\\t\\n  \", false},","+    {\"no heading\", \"This is just text without any heading.\", false},","+    {\"conversational prefix\", \"Sure, here is the updated prompt.\", false},","+    {\"here is prefix\", \"Here is the updated content with changes.\", false},","+    {\"of course prefix\", \"Of course! Here are the changes.\", false},","+    {\"plain text no hash\", \"Write good code and be careful.\", false},","+  }","+","+  for _, tt := range tests {","+    t.Run(tt.name, func(t *testing.T) {","+      assert.Equal(t, tt.valid, validatePromptContent(tt.content))","+    })","+  }","+}","+"," // --- Script Generator tests ---"," "," func TestScriptGeneratorCreatesScript(t *testing.T) {"]}],"userModified":false,"replaceAll":false}}
