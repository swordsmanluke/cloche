[2026-03-15T18:56:28Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ek5PdWhFHwrQAZKsEKfJFP","type":"tool_result","content":"   150→\tassert.Len(t, lessons, 1)\n   151→\tassert.Equal(t, \"L2\", lessons[0].ID)\n   152→}\n   153→\n   154→func TestConfidenceLevel(t *testing.T) {\n   155→\tassert.Equal(t, 3, confidenceLevel(\"high\"))\n   156→\tassert.Equal(t, 2, confidenceLevel(\"medium\"))\n   157→\tassert.Equal(t, 1, confidenceLevel(\"low\"))\n   158→\tassert.Equal(t, 0, confidenceLevel(\"\"))\n   159→}\n   160→\n   161→// --- Audit Logger tests ---\n   162→\n   163→func TestAuditLoggerAppendsJSONL(t *testing.T) {\n   164→\tdir := t.TempDir()\n   165→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\"), 0755)\n   166→\n   167→\tlogger := &AuditLogger{ProjectDir: dir}\n   168→\n   169→\tresult1 := &EvolutionResult{\n   170→\t\tID:           \"evo-1\",\n   171→\t\tWorkflowName: \"develop\",\n   172→\t\tChanges:      []Change{{Type: \"prompt_update\", File: \".cloche/prompts/impl.md\"}},\n   173→\t}\n   174→\trequire.NoError(t, logger.Log(result1))\n   175→\n   176→\tresult2 := &EvolutionResult{\n   177→\t\tID:           \"evo-2\",\n   178→\t\tWorkflowName: \"develop\",\n   179→\t\tChanges:      []Change{{Type: \"add_step\", File: \".cloche/develop.cloche\"}},\n   180→\t}\n   181→\trequire.NoError(t, logger.Log(result2))\n   182→\n   183→\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n   184→\trequire.NoError(t, err)\n   185→\n   186→\tlines := strings.Split(strings.TrimSpace(string(content)), \"\\n\")\n   187→\tassert.Len(t, lines, 2)\n   188→\n   189→\tvar entry1 EvolutionResult\n   190→\trequire.NoError(t, json.Unmarshal([]byte(lines[0]), &entry1))\n   191→\tassert.Equal(t, \"evo-1\", entry1.ID)\n   192→}\n   193→\n   194→func TestAuditLoggerSnapshot(t *testing.T) {\n   195→\tdir := t.TempDir()\n   196→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   197→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   198→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"original content\"), 0644)\n   199→\n   200→\tlogger := &AuditLogger{ProjectDir: dir}\n   201→\tsnapName, err := logger.Snapshot(\".cloche/prompts/implement.md\")\n   202→\trequire.NoError(t, err)\n   203→\tassert.NotEmpty(t, snapName)\n   204→\n   205→\tsnapPath := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\", snapName)\n   206→\tcontent, err := os.ReadFile(snapPath)\n   207→\trequire.NoError(t, err)\n   208→\tassert.Equal(t, \"original content\", string(content))\n   209→}\n   210→\n   211→func TestAuditLoggerUpdatesKnowledge(t *testing.T) {\n   212→\tdir := t.TempDir()\n   213→\tkbDir := filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\")\n   214→\tos.MkdirAll(kbDir, 0755)\n   215→\n   216→\tlogger := &AuditLogger{ProjectDir: dir}\n   217→\tlessons := []Lesson{\n   218→\t\t{\n   219→\t\t\tID:              \"P001\",\n   220→\t\t\tCategory:        \"prompt_improvement\",\n   221→\t\t\tConfidence:      \"high\",\n   222→\t\t\tInsight:         \"Always sanitize HTML inputs\",\n   223→\t\t\tSuggestedAction: \"Add rule to implement prompt\",\n   224→\t\t\tEvidence:        []string{\"run-1\", \"run-2\"},\n   225→\t\t},\n   226→\t}\n   227→\n   228→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", lessons))\n   229→\n   230→\tcontent, err := os.ReadFile(filepath.Join(kbDir, \"develop.jsonl\"))\n   231→\trequire.NoError(t, err)\n   232→\tassert.Contains(t, string(content), \"P001\")\n   233→\tassert.Contains(t, string(content), \"sanitize HTML\")\n   234→\tassert.Contains(t, string(content), \"run-1\")\n   235→}\n   236→\n   237→func TestAuditLoggerDeduplicatesLessons(t *testing.T) {\n   238→\tdir := t.TempDir()\n   239→\tlogger := &AuditLogger{ProjectDir: dir}\n   240→\n   241→\tlesson := Lesson{\n   242→\t\tID:       \"L001\",\n   243→\t\tCategory: \"prompt_improvement\",\n   244→\t\tInsight:  \"Original insight\",\n   245→\t}\n   246→\n   247→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{lesson}))\n   248→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{lesson}))\n   249→\n   250→\t// Read back and verify only one entry\n   251→\tlessons, err := readKnowledge(logger.KnowledgePath(\"develop\"))\n   252→\trequire.NoError(t, err)\n   253→\tassert.Len(t, lessons, 1)\n   254→\tassert.Equal(t, \"L001\", lessons[0].ID)\n   255→}\n   256→\n   257→func TestAuditLoggerUpdatesExistingLesson(t *testing.T) {\n   258→\tdir := t.TempDir()\n   259→\tlogger := &AuditLogger{ProjectDir: dir}\n   260→\n   261→\toriginal := Lesson{ID: \"L001\", Insight: \"Original insight\"}\n   262→\tupdated := Lesson{ID: \"L001\", Insight: \"Updated insight\"}\n   263→\n   264→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{original}))\n   265→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{updated}))\n   266→\n   267→\tlessons, err := readKnowledge(logger.KnowledgePath(\"develop\"))\n   268→\trequire.NoError(t, err)\n   269→\tassert.Len(t, lessons, 1)\n   270→\tassert.Equal(t, \"Updated insight\", lessons[0].Insight)\n   271→}\n   272→\n   273→func TestAuditLoggerPrunesWithMaxPromptBullets(t *testing.T) {\n   274→\tdir := t.TempDir()\n   275→\tlogger := &AuditLogger{ProjectDir: dir, MaxPromptBullets: 5}\n   276→\n   277→\t// Add 10 lessons\n   278→\tfor i := 0; i < 10; i++ {\n   279→\t\tlesson := Lesson{\n   280→\t\t\tID:      fmt.Sprintf(\"L%03d\", i),\n   281→\t\t\tInsight: fmt.Sprintf(\"Insight %d\", i),\n   282→\t\t}\n   283→\t\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{lesson}))\n   284→\t}\n   285→\n   286→\tlessons, err := readKnowledge(logger.KnowledgePath(\"develop\"))\n   287→\trequire.NoError(t, err)\n   288→\tassert.Len(t, lessons, 5)\n   289→\t// Should keep the most recent 5 (L005-L009)\n   290→\tassert.Equal(t, \"L005\", lessons[0].ID)\n   291→\tassert.Equal(t, \"L009\", lessons[4].ID)\n   292→}\n   293→\n   294→// --- LLM Client tests ---\n   295→\n   296→// --- Curator tests ---\n   297→\n   298→func TestCuratorUpdatesPrompt(t *testing.T) {\n   299→\tdir := t.TempDir()\n   300→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   301→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   302→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   303→\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   304→\n   305→\tupdatedContent := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"\n   306→\tllm := &fakeLLM{response: updatedContent}\n   307→\n   308→\taudit := &AuditLogger{ProjectDir: dir}\n   309→\tc := &Curator{LLM: llm, Audit: audit}\n   310→\tlesson := &Lesson{\n   311→\t\tID:              \"lesson-001\",\n   312→\t\tCategory:        \"prompt_improvement\",\n   313→\t\tTarget:          \".cloche/prompts/implement.md\",\n   314→\t\tInsight:         \"XSS vulnerabilities in form handlers\",\n   315→\t\tSuggestedAction: \"Add sanitization rule\",\n   316→\t}\n   317→\n   318→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   319→\trequire.NoError(t, err)\n   320→\tassert.Equal(t, \"prompt_update\", change.Type)\n   321→\tassert.Equal(t, \".cloche/prompts/implement.md\", change.File)\n   322→\tassert.NotEmpty(t, change.Snapshot)\n   323→\n   324→\tcontent, err := os.ReadFile(promptPath)\n   325→\trequire.NoError(t, err)\n   326→\tassert.Contains(t, string(content), \"sanitize user inputs\")\n   327→}\n   328→\n   329→// --- stripCodeFences tests ---\n   330→\n   331→func TestStripCodeFences(t *testing.T) {\n   332→\ttests := []struct {\n   333→\t\tname     string\n   334→\t\tinput    string\n   335→\t\texpected string\n   336→\t}{\n   337→\t\t{\n   338→\t\t\tname:     \"no fences returns as-is\",\n   339→\t\t\tinput:    \"# Prompt\\n\\nDo good work.\\n\",\n   340→\t\t\texpected: \"# Prompt\\n\\nDo good work.\",\n   341→\t\t},\n   342→\t\t{\n   343→\t\t\tname:     \"plain code fence\",\n   344→\t\t\tinput:    \"```\\n# Prompt\\n\\nDo good work.\\n```\",\n   345→\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   346→\t\t},\n   347→\t\t{\n   348→\t\t\tname:     \"code fence with language hint\",\n   349→\t\t\tinput:    \"```markdown\\n# Prompt\\n\\nDo good work.\\n```\",\n   350→\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   351→\t\t},\n   352→\t\t{\n   353→\t\t\tname:     \"commentary before and after fence\",\n   354→\t\t\tinput:    \"Here's the updated prompt:\\n\\n```markdown\\n# Prompt\\n\\nDo good work.\\n```\\n\\nI've added the rule as requested.\",\n   355→\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   356→\t\t},\n   357→\t\t{\n   358→\t\t\tname:     \"no closing fence returns as-is\",\n   359→\t\t\tinput:    \"```markdown\\n# Prompt\\n\",\n   360→\t\t\texpected: \"```markdown\\n# Prompt\",\n   361→\t\t},\n   362→\t}\n   363→\n   364→\tfor _, tt := range tests {\n   365→\t\tt.Run(tt.name, func(t *testing.T) {\n   366→\t\t\tassert.Equal(t, tt.expected, stripCodeFences(tt.input))\n   367→\t\t})\n   368→\t}\n   369→}\n   370→\n   371→func TestCuratorStripsCodeFencesFromResponse(t *testing.T) {\n   372→\tdir := t.TempDir()\n   373→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   374→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   375→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   376→\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   377→\n   378→\t// LLM returns content wrapped in code fences with commentary\n   379→\tfencedResponse := \"Here is the updated prompt:\\n\\n```markdown\\n# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n```\\n\\nI added the validation rule.\"\n   380→\tllm := &fakeLLM{response: fencedResponse}\n   381→\n   382→\taudit := &AuditLogger{ProjectDir: dir}\n   383→\tc := &Curator{LLM: llm, Audit: audit}\n   384→\tlesson := &Lesson{\n   385→\t\tTarget:          \".cloche/prompts/implement.md\",\n   386→\t\tInsight:         \"Missing input validation\",\n   387→\t\tSuggestedAction: \"Add validation rule\",\n   388→\t}\n   389→\n   390→\t_, err := c.Apply(context.Background(), dir, lesson)\n   391→\trequire.NoError(t, err)\n   392→\n   393→\tcontent, err := os.ReadFile(promptPath)\n   394→\trequire.NoError(t, err)\n   395→\n   396→\t// Should contain the actual prompt content, not the commentary\n   397→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   398→\tassert.Contains(t, string(content), \"Always validate inputs\")\n   399→\tassert.NotContains(t, string(content), \"Here is the updated prompt\")"}]},"parent_tool_use_id":"toolu_01MUQcEWdHV2GEJu3gAkcznX","session_id":"937aed02-7c16-4e6e-ac4e-ccdcceb237c8","uuid":"6656a113-afe8-4394-bfbb-e6225de6b190"}
