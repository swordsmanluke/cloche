ce one change\")\n  1178→\n  1179→\t// Second run: same lesson ID — the knowledge base now contains L010,\n  1180→\t// and the prompt contains the insight text.\n  1181→\tllm2 := &scriptedLLM{\n  1182→\t\tresponses: []string{\n  1183→\t\t\t`{\"classification\": \"bug\"}`,\n  1184→\t\t\t`{\"lessons\": [{\"id\": \"L010\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"Always sanitize user inputs\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n  1185→\t\t},\n  1186→\t}\n  1187→\n  1188→\torch2 := NewOrchestrator(OrchestratorConfig{\n  1189→\t\tProjectDir:    dir,\n  1190→\t\tWorkflowName:  \"develop\",\n  1191→\t\tLLM:           llm2,\n  1192→\t\tMinConfidence: \"low\",\n  1193→\t})\n  1194→\n  1195→\tresult2, err := orch2.Run(context.Background(), \"run-2\", nil, nil)\n  1196→\trequire.NoError(t, err)\n  1197→\tassert.Empty(t, result2.Changes, \"second run should produce zero changes\")\n  1198→}\n  1199→"}]},"parent_tool_use_id":null,"session_id":"937aed02-7c16-4e6e-ac4e-ccdcceb237c8","uuid":"8a5f718d-2d97-43bd-9b0a-bf269d3ac2b0","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/evolution_test.go","content":"\nfunc TestOrchestratorSkipsAlreadyAppliedLessons(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n\t\t[]byte(\"# Knowledge Base\\n\\n- **[L001]** (prompt_improvement, confidence: high) XSS pattern\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"Write good code.\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step s {\n    run = \"echo hi\"\n    results = 