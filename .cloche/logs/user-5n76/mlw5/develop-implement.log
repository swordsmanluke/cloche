e := filepath.Join(clocheDir, workflow+\".cloche\")\n   118→\n   119→\t// Refuse to overwrite existing workflow\n   120→\tif _, err := os.Stat(workflowFile); err == nil {\n   121→\t\tfmt.Fprintf(os.Stderr, \"error: %s already exists\\n\", workflowFile)\n   122→\t\tos.Exit(1)\n   123→\t}\n   124→\n   125→\t// Create directories\n   126→\tfor _, dir := range []string{\n   127→\t\tclocheDir,\n   128→\t\tfilepath.Join(clocheDir, \"prompts\"),\n   129→\t\tfilepath.Join(clocheDir, \"overrides\"),\n   130→\t} {\n   131→\t\tif err := os.MkdirAll(dir, 0755); err != nil {\n   132→\t\t\tfmt.Fprintf(os.Stderr, \"error creating %s/: %v\\n\", dir, err)\n   133→\t\t\tos.Exit(1)\n   134→\t\t}\n   135→\t}\n   136→\n   137→\t// Write all files, skipping any that already exist\n   138→\tfiles := []struct{ path, content string }{\n   139→\t\t{workflowFile, fmt.Sprintf(workflowTemplate, workflow)},\n   140→\t\t{filepath.Join(clocheDir, \"Dockerfile\"), fmt.Sprintf(dockerfileTemplate, image)},\n   141→\t\t{filepath.Join(clocheDir, \"prompts\", \"implement.md\"), implementPrompt},\n   142→\t\t{filepath.Join(clocheDir, \"prompts\", \"fix.md\"), fixPrompt},\n   143→\t\t{filepath.Join(clocheDir, \"prompts\", \"update-docs.md\"), updateDocsPrompt},\n   144→\t}\n   145→\n   146→\tfor _, f := range files {\n   147→\t\tif _, err := os.Stat(f.path); err == nil {\n   148→\t\t\tfmt.Fprintf(os.Stderr, \"  skip %s (already exists)\\n\", f.path)\n   149→\t\t\tcontinue\n   150→\t\t}\n   151→\t\tif err := os.WriteFile(f.path, []byte(f.content), 0644); err != nil {\n   152→\t\t\tfmt.Fprintf(os.Stderr, \"error writing %s: %v\\n\", f.path, err)\n   153→\t\t\tos.Exit(1)\n   154→\t\t}\n   155→\t\tfmt.Fprintf(os.Stderr, \"  create %s\\n\", f.path)\n   156→\t}\n   157→\n   158→\taddGitignoreEntries([]string{\n   159→\t\t\".cloche/*/\",\n   160→\t\t\"!.cloche/prompts/\",\n   161→\t\t\"!.cloche/overrides/\",\n   162→\t\t\"!.cloche/evolution/\",\n   163→\t\t\".gitworktrees/\",\n   164→\t})\n   165→\n   166→\tcwd,