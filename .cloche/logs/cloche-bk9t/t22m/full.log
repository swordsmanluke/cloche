ontext, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n    52→\t// Stage 1: Collect\n    53→\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n    54→\tif err != nil {\n    55→\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n    56→\t}\n    57→\n    58→\t// Stage 2: Classify the triggering run\n    59→\tclassification, err := o.classifier.Classify(ctx, \"\")\n    60→\tif err != nil {\n    61→\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n    62→\t}\n    63→\n    64→\t// Stage 3: Reflect\n    65→\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n    66→\tif err != nil {\n    67→\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n    68→\t}\n    69→\n    70→\tresult := &EvolutionResult{\n    71→\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n    72→\t\tProjectDir:     o.cfg.ProjectDir,\n    73→\t\tWorkflowName:   o.cfg.WorkflowName,\n    74→\t\tTriggerRunID:   triggerRunID,\n    75→\t\tTimestamp:      time.Now().Format(time.RFC3339),\n    76→\t\tClassification: classification,\n    77→\t}\n    78→\n    79→\tif len(lessons) == 0 {\n    80→\t\t// No actionable lessons — log and return\n    81→\t\to.audit.Log(result)\n    82→\t\treturn result, nil\n    83→\t}\n    84→\n    85→\t// Stage 4: Execute branches based on lesson category\n    86→\tfor _, lesson := range lessons {\n    87→\t\tswitch lesson.Category {\n    88→\t\tcase \"prompt_improvement\":\n    89→\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n    90→\t\t\tif err != nil {\n    91→\t\t\t\tcontinue // log but don't fail the whole pipeline\n    92→\t\t\t}\n    93→\t\t\tresult.Changes = append(result.Changes, *change)\n    94→\n    95→\t\tcase \"new_step\":\n    96→\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n    97→\t\t\t\tcontinue\n    98→\t\t\t}\n    99→\t\t}\n   100→\t}\n   101→\n   102→\t// Stage 5: Audit\n   103→\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n   104→\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n   105→\to.audit.Log(result)\n   106→\n   107→\t// Save to store if available\n   108→\tif evoStore != nil {\n   109→\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n   110→\t\t\tID:             result.ID,\n   111→\t\t\tProjectDir:     result.ProjectDir,\n   112→\t\t\tWorkflowName:   result.WorkflowName,\n   113→\t\t\tTriggerRunID:   result.TriggerRunID,\n   114→\t\t\tCreatedAt:      time.Now(),\n   115→\t\t\tClassification: result.Classification,\n   116→\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n   117→\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n   118→\t\t})\n   119→\t}\n   120→\n   121→\treturn result, nil\n   122→}\n   123→\n   124→// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\n   125→func (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n   126→\t// Generate the script or prompt file\n   127→\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n   128→\tif err != nil {\n   129→\t\treturn err\n   130→\t}\n   131→\n   132→\tresult.Changes = append(result.Changes, Change{\n   133→\t\tType:   \"add_script\",\n   134→\t\tFile:   generated.Path,\n   135→\t\tReason: lesson.Insight,\n   136→\t})\n   137→\n   138→\t// Add step and wiring to the workflow file\n   139→\tif data.WorkflowPath == \"\" {\n   140→\t\treturn nil\n   141→\t}\n   142→\n   143→\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n   144→\tif err != nil {\n   145→\t\treturn err\n   146→\t}\n   147→\n   148→\t// Snapshot the workflow\n   149→\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n   150→\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n   151→\toriginal := string(workflowContent)\n   152→\n   153→\t// Derive step name from the script path\n   154→\tstepName := filepath.Base(generated.Path)\n   155→\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n   156→\n   157→\t// Check if a step with this name already exists — skip if so\n   158→\texistingWf, parseErr := dsl.Parse(original)\n   159→\tif parseErr == nil {\n   160→\t\tif _, exists := existingWf.Steps[stepName]; exists {\n   161→\t\t\treturn nil\n   162→\t\t}\n   163→\t}\n   164→\n   165→\t// Determine the config based on step type\n   166→\tconfig := map[string]string{}\n   167→\tswitch lesson.StepType {\n   168→\tcase \"agent\":\n   169→\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n   170→\tdefault: // script\n   171→\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n   172→\t}\n   173→\n   174→\t// Add the step\n   175→\tupdated, err := o.mutator.AddStep(original, dsl.StepDef{\n   176→\t\tName:    stepName,\n   177→\t\tType:    lesson.StepType,\n   178→\t\tConfig:  config,\n   179→\t\tResults: []string{\"success\", \"fail\"},\n   180→\t})\n   181→\tif err != nil {\n   182→\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n   183→\t}\n   184→\n   185→\t// Wire the new step into the existing graph by finding a wire\n   186→\t// that currently goes to \"done\" and rerouting it through the new step.\n   187→\twf, parseErr := dsl.Parse(updated)\n   188→\tif parseErr == nil {\n   189→\t\tfor _, wire := range wf.Wiring {\n   190→\t\t\tif wire.To == \"done\" {\n   191→\t\t\t\trewired, rewireErr := o.mutator.RewireResult(updated, wire.From, wire.Result, \"done\", stepName)\n   192→\t\t\t\tif rewireErr == nil {\n   193→\t\t\t\t\tupdated = rewired\n   194→\t\t\t\t\tbreak\n   195→\t\t\t\t}\n   196→\t\t\t}\n   197→\t\t}\n   198→\t}\n   199→\n   200→\t// Wire the new step's results to terminals\n   201→\twires := []dsl.WireDef{\n   202→\t\t{From: stepName, Result: \"success\", To: \"done\"},\n   203→\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n   204→\t}\n   205→\tupdated, err = o.mutator.AddWiring(updated, wires)\n   206→\tif err != nil {\n   207→\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n   208→\t}\n   209→\n   210→\t// Validate the final workflow graph — roll back on failure\n   211→\tfinalWf, parseErr := dsl.Parse(updated)\n   212→\tif parseErr != nil {\n   213→\t\treturn fmt.Errorf(\"parsing updated workflow: %w\", parseErr)\n   214→\t}\n   215→\tif valErr := finalWf.Validate(); valErr != nil {\n   216→\t\treturn fmt.Errorf(\"workflow validation failed after adding step %q: %w\", stepName, valErr)\n   217→\t}\n   218→\n   219→\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n   220→\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n   221→\t}\n   222→\n   223→\tresult.Changes = append(result.Changes, Change{\n   224→\t\tType:     \"add_step\",\n   225→\t\tFile:     wfRelPath,\n   226→\t\tReason:   lesson.Insight,\n   227→\t\tSnapshot: snapName,\n   228→\t})\n   229→\n   230→\treturn nil\n   231→}\n   232→"}]},"parent_tool_use_id":null,"session_id":"41846d44-0d79-434c-81b9-81f7289ac468","uuid":"488e7c33-dc1e-43c2-a0c9-e5b3f4dd9c9b","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/orchestrator.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// OrchestratorConfig configures the evolution pipeline.\ntype OrchestratorConfig struct {\n\tProjectDir       string\n\tWorkflowName     string\n\tLLM              LLMClient\n\tMinConfidence    string\n\tMaxPromptBullets int\n}\n\n// Orchestrator wires all evolution pipeline stages together.\ntype Orchestrator struct {\n\tcfg        OrchestratorConfig\n\tcollector  *Collector\n\tclassifier *Classifier\n\treflector  *Reflector\n\tcurator    *Curator\n\tscriptGen  *ScriptGenerator\n\tmutator    *dsl.Mutator\n\taudit      *AuditLogger\n}\n\n// NewOrchestrator creates a fully wired evolution pipeline.\nfunc NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir, MaxPromptBullets: cfg.MaxPromptBullets}\n\treturn &Orchestrator{\n\t\tcfg:        cfg,\n\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n\t\tclassifier: &Classifier{LLM: cfg.LLM},\n\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n\t\tmutator:    &dsl.Mutator{},\n\t\taudit:      audit,\n\t}\n}\n\n// Run executes the full evolution pipeline.\nfunc (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n\t// Stage 1: Collect\n\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n\t}\n\n\t// Stage 2: Classify the triggering run\n\tclassification, err := o.classifier.Classify(ctx, \"\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n\t}\n\n\t// Stage 3: Reflect\n\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n\t}\n\n\tresult := &EvolutionResult{\n\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n\t\tProjectDir:     o.cfg.ProjectDir,\n\t\tWorkflowName:   o.cfg.WorkflowName,\n\t\tTriggerRunID:   triggerRunID,\n\t\tTimestamp:      time.Now().Format(time.RFC3339),\n\t\tClassification: classification,\n\t}\n\n\tif len(lessons) == 0 {\n\t\t// No actionable lessons — log and return\n\t\to.audit.Log(result)\n\t\treturn result, nil\n\t}\n\n\t// Stage 4: Execute branches based on lesson category\n\tfor _, lesson := range lessons {\n\t\tswitch lesson.Category {\n\t\tcase \"prompt_improvement\":\n\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // log but don't fail the whole pipeline\n\t\t\t}\n\t\t\tresult.Changes = append(result.Changes, *change)\n\n\t\tcase \"new_step\":\n\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\t}\n\n\t// Stage 5: Audit\n\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n\to.audit.Log(result)\n\n\t// Save to store if available\n\tif evoStore != nil {\n\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n\t\t\tID:             result.ID,\n\t\t\tProjectDir:     result.ProjectDir,\n\t\t\tWorkflowName:   result.WorkflowName,\n\t\t\tTriggerRunID:   result.TriggerRunID,\n\t\t\tCreatedAt:      time.Now(),\n\t\t\tClassification: result.Classification,\n\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n\t\t})\n\t}\n\n\treturn result, nil\n}\n\n// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\nfunc (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n\t// Generate the script or prompt file\n\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tresult.Changes = append(result.Changes, Change{\n\t\tType:   \"add_script\",\n\t\tFile:   generated.Path,\n\t\tReason: lesson.Insight,\n\t})\n\n\t// Add step and wiring to the workflow file\n\tif data.WorkflowPath == \"\" {\n\t\treturn nil\n\t}\n\n\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// Snapshot the workflow\n\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n\toriginal := string(workflowContent)\n\n\t// Derive step name from the script path\n\tstepName := filepath.Base(generated.Path)\n\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n\n\t// Check if a step with this name already exists — skip if so\n\texistingWf, parseErr := dsl.Parse(original)\n\tif parseErr == nil {\n\t\tif _, exists := existingWf.Steps[stepName]; exists {\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Determine the config based on step type\n\tconfig := map[string]string{}\n\tswitch lesson.StepType {\n\tcase \"agent\":\n\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n\tdefault: // script\n\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n\t}\n\n\t// Add the step\n\tupdated, err := o.mutator.AddStep(original, dsl.StepDef{\n\t\tName:    stepName,\n\t\tType:    lesson.StepType,\n\t\tConfig:  config,\n\t\tResults: []string{\"success\", \"fail\"},\n\t})\n\tif err != nil {\n\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n\t}\n\n\t// Wire the new step into the existing graph by finding a wire\n\t// that currently goes to \"done\" and rerouting it through the new step.\n\twf, parseErr := dsl.Parse(updated)\n\tif parseErr == nil {\n\t\tfor _, wire := range wf.Wiring {\n\t\t\tif wire.To == \"done\" {\n\t\t\t\trewired, rewireErr := o.mutator.RewireResult(updated, wire.From, wire.Result, \"done\", stepName)\n\t\t\t\tif rewireErr == nil {\n\t\t\t\t\tupdated = rewired\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Wire the new step's results to terminals\n\twires := []dsl.WireDef{\n\t\t{From: stepName, Result: \"success\", To: \"done\"},\n\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n\t}\n\tupdated, err = o.mutator.AddWiring(updated, wires)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n\t}\n\n\t// Validate the final workflow graph — roll back on failure\n\tfinalWf, parseErr := dsl.Parse(updated)\n\tif parseErr != nil {\n\t\treturn fmt.Errorf(\"parsing updated workflow: %w\", parseErr)\n\t}\n\tif valErr := finalWf.Validate(); valErr != nil {\n\t\treturn fmt.Errorf(\"workflow validation failed after adding step %q: %w\", stepName, valErr)\n\t}\n\n\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n\t}\n\n\tresult.Changes = append(result.Changes, Change{\n\t\tType:     \"add_step\",\n\t\tFile:     wfRelPath,\n\t\tReason:   lesson.Insight,\n\t\tSnapshot: snapName,\n\t})\n\n\treturn nil\n}\n","numLines":232,"startLine":1,"totalLines":232}}}
