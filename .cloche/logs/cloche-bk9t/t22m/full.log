  30,\n    47→\t\t\tMinConfidence:    \"medium\",\n    48→\t\t\tMaxPromptBullets: 50,\n    49→\t\t},\n    50→\t\tOrchestration: OrchestrationConfig{\n    51→\t\t\tConcurrency:    1,\n    52→\t\t\tStaggerSeconds: 1.0,\n    53→\t\t},\n    54→\t}\n    55→}\n    56→\n    57→// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    58→func Load(projectDir string) (*Config, error) {\n    59→\tcfg := defaults()\n    60→\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    61→\n    62→\tdata, err := os.ReadFile(path)\n    63→\tif os.IsNotExist(err) {\n    64→\t\treturn &cfg, nil\n    65→\t}\n    66→\tif err != nil {\n    67→\t\treturn nil, err\n    68→\t}\n    69→\n    70→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    71→\t\treturn nil, err\n    72→\t}\n    73→\treturn &cfg, nil\n    74→}\n    75→\n    76→// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n    77→// Returns defaults if the file does not exist.\n    78→func LoadGlobal() (*Config, error) {\n    79→\tcfg := defaults()\n    80→\n    81→\thome, err := os.UserHomeDir()\n    82→\tif err != nil {\n    83→\t\treturn &cfg, nil\n    84→\t}\n    85→\n    86→\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n    87→\tdata, err := os.ReadFile(path)\n    88→\tif os.IsNotExist(err) {\n    89→\t\treturn &cfg, nil\n    90→\t}\n    91→\tif err != nil {\n    92→\t\treturn nil, err\n    93→\t}\n    94→\n    95→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    96→\t\treturn nil, err\n    97→\t}\n    98→\treturn &cfg, nil\n    99→}\n   100→\n   101→// StateDir returns the path to ~/.config/cloche/ and ensures it exists.\n   102→// Falls back to a temp directory if the home directory cannot be determined.\n   103→func StateDir() string {\n   104→\thome, err := os.UserHomeDir()\n   105→\tif err != nil {\n   106→\t\treturn filepath.Join(os.TempDir(), \"cloche\")\n   107→\t}\n   108→\treturn filepath.Join(home, \".config\", \"cloche\")\n   109→}\n   110→\n   111→// EnsureStateDir creates the state directory if it doesn't exist.\n   112→func EnsureStateDir() (string, error) {\n   113→\tdir := StateDir()\n   114→\tif err := os.MkdirAll(dir, 0755); err != nil {\n   115→\t\treturn \"\", err\n   116→\t}\n   117→\treturn dir, nil\n   118→}\n   119→\n   120→// DefaultDBPath returns the default database path: ~/.config/cloche/cloche.db\n   121→func DefaultDBPath() string {\n   122→\treturn filepath.Join(StateDir(), \"cloche.db\")\n   123→}\n   124→\n   125→// DefaultSocketAddr returns the default Unix socket address: unix://~/.config/cloche/cloche.sock\n   126→func DefaultSocketAddr() string {\n   127→\treturn \"unix://\" + filepath.Join(StateDir(), \"cloche.sock\")\n   128→}\n   129→\n   130→// LoadGlobalFrom reads the global config from a specific path.\n   131→// Useful for testing.\n   132→func LoadGlobalFrom(path string) (*Config, error) {\n   133→\tcfg := defaults()\n   134→\n   135→\tdata, err := os.ReadFile(path)\n   136→\tif os.IsNotExist(err) {\n   137→\t\treturn &cfg, nil\n   138→\t}\n   139→\tif err != nil {\n   140→\t\treturn nil, err\n   141→\t}\n   142→\n   143→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   144→\t\treturn nil, err\n   145→\t}\n   146→\treturn &cfg, nil\n   147→}\n   148→"}]},"parent_tool_use_id":null,"session_id":"016a7e3e-d9d2-46f5-8da9-2b20f96020ee","uuid":"d9021c98-2583-4238-bf40-4b14a57fa7ec","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/config/config.go","content":"package config\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\n\t\"github.com/BurntSushi/toml\"\n)\n\ntype DaemonConfig struct {\n\tListen     string `toml:\"listen\"`\n\tHTTP       string `toml:\"http\"`\n\tImage      string `toml:\"image\"`\n\tDB         string `toml:\"db\"`\n\tRuntime    string `toml:\"runtime\"`\n\tAgentPath  string `toml:\"agent_path\"`\n\tLLMCommand string `toml:\"llm_command\"`\n}\n\ntype EvolutionConfig struct {\n\tEnabled          bool   `toml:\"enabled\"`\n\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n\tMinConfidence    string `toml:\"min_confidence\"`\n\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n}\n\ntype OrchestrationConfig struct {\n\tConcurrency      int     `toml:\"concurrency\"`\n\tStaggerSeconds   float64 `toml:\"stagger_seconds\"`\n\tListTasksCommand string  `toml:\"list_tasks_command\"` // shell command to list open tasks (JSON array output)\n\tDedupSeconds     float64 `toml:\"dedup_seconds\"`      // dedup window for task assignment (default: 300)\n\tStopOnError      bool    `toml:\"stop_on_error\"`      // halt orchestration loop on unrecovered error\n}\n\ntype Config struct {\n\tActive        bool                `toml:\"active\"`\n\tDaemon        DaemonConfig        `toml:\"daemon\"`\n\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n}\n\nfunc defaults() Config {\n\treturn Config{\n\t\tEvolution: EvolutionConfig{\n\t\t\tEnabled:          true,\n\t\t\tDebounceSeconds:  30,\n\t\t\tMinConfidence:    \"medium\",\n\t\t\tMaxPromptBullets: 50,\n\t\t},\n\t\tOrchestration: OrchestrationConfig{\n\t\t\tConcurrency:    1,\n\t\t\tStaggerSeconds: 1.0,\n\t\t},\n\t}\n}\n\n// Load reads a per-project config from <projectDir>/.cloche/config.toml.\nfunc Load(projectDir string) (*Config, error) {\n\tcfg := defaults()\n\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n// Returns defaults if the file does not exist.\nfunc LoadGlobal() (*Config, error) {\n\tcfg := defaults()\n\n\thome, err := os.UserHomeDir()\n\tif err != nil {\n\t\treturn &cfg, nil\n\t}\n\n\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// StateDir returns the path to ~/.config/cloche/ and ensures it exists.\n// Falls back to a temp directory if the home directory cannot be determined.\nfunc StateDir() string {\n\thome, err := os.UserHomeDir()\n\tif err != nil {\n\t\treturn filepath.Join(os.TempDir(), \"cloche\")\n\t}\n\treturn filepath.Join(home, \".config\", \"cloche\")\n}\n\n// EnsureStateDir creates the state directory if it doesn't exist.\nfunc EnsureStateDir() (string, error) {\n\tdir := StateDir()\n\tif err := os.MkdirAll(dir, 0755); err != nil {\n\t\treturn \"\", err\n\t}\n\treturn dir, nil\n}\n\n// DefaultDBPath returns the default database path: ~/.config/cloche/cloche.db\nfunc DefaultDBPath() string {\n\treturn filepath.Join(StateDir(), \"cloche.db\")\n}\n\n// DefaultSocketAddr returns the default Unix socket address: unix://~/.config/cloche/cloche.sock\nfunc DefaultSocketAddr() string {\n\treturn \"unix://\" + filepath.Join(StateDir(), \"cloche.sock\")\n}\n\n// LoadGlobalFrom reads the global config from a specific path.\n// Useful for testing.\nfunc LoadGlobalFrom(path string) (*Config, error) {\n\tcfg := defaults()\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n","numLines":148,"startLine":1,"totalLines":148}}}
