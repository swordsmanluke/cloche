[2026-03-15T16:16:54Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012XjcCeDJ7QFYWz5subpoRX","type":"tool_result","content":"     1→package config\n     2→\n     3→import (\n     4→\t\"os\"\n     5→\t\"path/filepath\"\n     6→\t\"testing\"\n     7→\n     8→\t\"github.com/stretchr/testify/assert\"\n     9→\t\"github.com/stretchr/testify/require\"\n    10→)\n    11→\n    12→func TestLoadEvolutionConfig(t *testing.T) {\n    13→\tdir := t.TempDir()\n    14→\tclocheDir := filepath.Join(dir, \".cloche\")\n    15→\tos.MkdirAll(clocheDir, 0755)\n    16→\n    17→\tos.WriteFile(filepath.Join(clocheDir, \"config.toml\"), []byte(`\n    18→[evolution]\n    19→enabled = true\n    20→debounce_seconds = 45\n    21→min_confidence = \"high\"\n    22→max_prompt_bullets = 30\n    23→`), 0644)\n    24→\n    25→\tcfg, err := Load(dir)\n    26→\trequire.NoError(t, err)\n    27→\tassert.True(t, cfg.Evolution.Enabled)\n    28→\tassert.Equal(t, 45, cfg.Evolution.DebounceSeconds)\n    29→\tassert.Equal(t, \"high\", cfg.Evolution.MinConfidence)\n    30→\tassert.Equal(t, 30, cfg.Evolution.MaxPromptBullets)\n    31→}\n    32→\n    33→func TestLoadEvolutionConfigDefaults(t *testing.T) {\n    34→\tdir := t.TempDir()\n    35→\n    36→\tcfg, err := Load(dir)\n    37→\trequire.NoError(t, err)\n    38→\tassert.True(t, cfg.Evolution.Enabled)\n    39→\tassert.Equal(t, 30, cfg.Evolution.DebounceSeconds)\n    40→\tassert.Equal(t, \"medium\", cfg.Evolution.MinConfidence)\n    41→\tassert.Equal(t, 50, cfg.Evolution.MaxPromptBullets)\n    42→}\n    43→\n    44→func TestLoadDaemonConfig(t *testing.T) {\n    45→\tdir := t.TempDir()\n    46→\tclocheDir := filepath.Join(dir, \".cloche\")\n    47→\tos.MkdirAll(clocheDir, 0755)\n    48→\n    49→\tos.WriteFile(filepath.Join(clocheDir, \"config.toml\"), []byte(`\n    50→[daemon]\n    51→listen = \"localhost:9090\"\n    52→http = \"localhost:8080\"\n    53→image = \"my-agent:v2\"\n    54→db = \"/var/lib/cloche/data.db\"\n    55→runtime = \"local\"\n    56→agent_path = \"/usr/local/bin/cloche-agent\"\n    57→llm_command = \"claude\"\n    58→`), 0644)\n    59→\n    60→\tcfg, err := Load(dir)\n    61→\trequire.NoError(t, err)\n    62→\tassert.Equal(t, \"localhost:9090\", cfg.Daemon.Listen)\n    63→\tassert.Equal(t, \"localhost:8080\", cfg.Daemon.HTTP)\n    64→\tassert.Equal(t, \"my-agent:v2\", cfg.Daemon.Image)\n    65→\tassert.Equal(t, \"/var/lib/cloche/data.db\", cfg.Daemon.DB)\n    66→\tassert.Equal(t, \"local\", cfg.Daemon.Runtime)\n    67→\tassert.Equal(t, \"/usr/local/bin/cloche-agent\", cfg.Daemon.AgentPath)\n    68→\tassert.Equal(t, \"claude\", cfg.Daemon.LLMCommand)\n    69→}\n    70→\n    71→func TestLoadDaemonConfigDefaults(t *testing.T) {\n    72→\tdir := t.TempDir()\n    73→\n    74→\tcfg, err := Load(dir)\n    75→\trequire.NoError(t, err)\n    76→\t// All daemon fields default to zero values (empty strings)\n    77→\tassert.Equal(t, \"\", cfg.Daemon.Listen)\n    78→\tassert.Equal(t, \"\", cfg.Daemon.HTTP)\n    79→\tassert.Equal(t, \"\", cfg.Daemon.Image)\n    80→\tassert.Equal(t, \"\", cfg.Daemon.DB)\n    81→\tassert.Equal(t, \"\", cfg.Daemon.Runtime)\n    82→}\n    83→\n    84→func TestLoadGlobalFrom(t *testing.T) {\n    85→\tdir := t.TempDir()\n    86→\tconfigPath := filepath.Join(dir, \"config\")\n    87→\n    88→\tos.WriteFile(configPath, []byte(`\n    89→[daemon]\n    90→http = \"0.0.0.0:3000\"\n    91→image = \"custom:latest\"\n    92→`), 0644)\n    93→\n    94→\tcfg, err := LoadGlobalFrom(configPath)\n    95→\trequire.NoError(t, err)\n    96→\tassert.Equal(t, \"0.0.0.0:3000\", cfg.Daemon.HTTP)\n    97→\tassert.Equal(t, \"custom:latest\", cfg.Daemon.Image)\n    98→\tassert.Equal(t, \"\", cfg.Daemon.Listen) // unset stays empty\n    99→}\n   100→\n   101→func TestLoadActiveFlag(t *testing.T) {\n   102→\tdir := t.TempDir()\n   103→\tclocheDir := filepath.Join(dir, \".cloche\")\n   104→\tos.MkdirAll(clocheDir, 0755)\n   105→\n   106→\tos.WriteFile(filepath.Join(clocheDir, \"config.toml\"), []byte(`\n   107→active = true\n   108→`), 0644)\n   109→\n   110→\tcfg, err := Load(dir)\n   111→\trequire.NoError(t, err)\n   112→\tassert.True(t, cfg.Active)\n   113→}\n   114→\n   115→func TestLoadActiveFlagDefault(t *testing.T) {\n   116→\tdir := t.TempDir()\n   117→\n   118→\tcfg, err := Load(dir)\n   119→\trequire.NoError(t, err)\n   120→\tassert.False(t, cfg.Active)\n   121→}\n   122→\n   123→func TestLoadOrchestrationConfig(t *testing.T) {\n   124→\tdir := t.TempDir()\n   125→\tclocheDir := filepath.Join(dir, \".cloche\")\n   126→\tos.MkdirAll(clocheDir, 0755)\n   127→\n   128→\tos.WriteFile(filepath.Join(clocheDir, \"config.toml\"), []byte(`\n   129→[orchestration]\n   130→concurrency = 2\n   131→stagger_seconds = 3.5\n   132→`), 0644)\n   133→\n   134→\tcfg, err := Load(dir)\n   135→\trequire.NoError(t, err)\n   136→\tassert.Equal(t, 2, cfg.Orchestration.Concurrency)\n   137→\tassert.Equal(t, 3.5, cfg.Orchestration.StaggerSeconds)\n   138→}\n   139→\n   140→func TestLoadOrchestrationConfigDefaults(t *testing.T) {\n   141→\tdir := t.TempDir()\n   142→\n   143→\tcfg, err := Load(dir)\n   144→\trequire.NoError(t, err)\n   145→\tassert.Equal(t, 1, cfg.Orchestration.Concurrency)\n   146→\tassert.Equal(t, 1.0, cfg.Orchestration.StaggerSeconds)\n   147→\tassert.False(t, cfg.Orchestration.StopOnError)\n   148→}\n   149→\n   150→func TestLoadOrchestrationStopOnError(t *testing.T) {\n   151→\tdir := t.TempDir()\n   152→\tclocheDir := filepath.Join(dir, \".cloche\")\n   153→\tos.MkdirAll(clocheDir, 0755)\n   154→\n   155→\tos.WriteFile(filepath.Join(clocheDir, \"config.toml\"), []byte(`\n   156→[orchestration]\n   157→stop_on_error = true\n   158→concurrency = 1\n   159→`), 0644)\n   160→\n   161→\tcfg, err := Load(dir)\n   162→\trequire.NoError(t, err)\n   163→\tassert.True(t, cfg.Orchestration.StopOnError)\n   164→\tassert.Equal(t, 1, cfg.Orchestration.Concurrency)\n   165→}\n   166→\n   167→func TestLoadGlobalFromMissing(t *testing.T) {\n   168→\tcfg, err := LoadGlobalFrom(\"/nonexistent/path/config\")\n   169→\trequire.NoError(t, err)\n   170→\t// Returns defaults, no error\n   171→\tassert.True(t, cfg.Evolution.Enabled)\n   172→\tassert.Equal(t, \"\", cfg.Daemon.HTTP)\n   173→}\n   174→\n   175→func TestStateDir(t *testing.T) {\n   176→\tdir := StateDir()\n   177→\tassert.Contains(t, dir, \".config/cloche\")\n   178→\tassert.True(t, filepath.IsAbs(dir))\n   179→}\n   180→\n   181→func TestEnsureStateDir(t *testing.T) {\n   182→\t// Override HOME to a temp directory so we don't touch the real home.\n   183→\ttmp := t.TempDir()\n   184→\tt.Setenv(\"HOME\", tmp)\n   185→\n   186→\tdir, err := EnsureStateDir()\n   187→\trequire.NoError(t, err)\n   188→\tassert.Equal(t, filepath.Join(tmp, \".config\", \"cloche\"), dir)\n   189→\n   190→\t// Directory should exist\n   191→\tinfo, err := os.Stat(dir)\n   192→\trequire.NoError(t, err)\n   193→\tassert.True(t, info.IsDir())\n   194→}\n   195→\n   196→func TestDefaultDBPath(t *testing.T) {\n   197→\tpath := DefaultDBPath()\n   198→\tassert.Contains(t, path, \"cloche.db\")\n   199→\tassert.Contains(t, path, \".config/cloche\")\n   200→\tassert.True(t, filepath.IsAbs(path))\n   201→}\n   202→\n   203→func TestDefaultSocketAddr(t *testing.T) {\n   204→\taddr := DefaultSocketAddr()\n   205→\tassert.True(t, len(addr) > 7 && addr[:7] == \"unix://\")\n   206→\tassert.Contains(t, addr, \".config/cloche/cloche.sock\")\n   207→}\n   208→"}]},"parent_tool_use_id":"toolu_01WJ3dv2tt3U5N3cEvcAex23","session_id":"016a7e3e-d9d2-46f5-8da9-2b20f96020ee","uuid":"f13cc6bf-4b98-436f-9e34-e49b4e65cf7b"}
