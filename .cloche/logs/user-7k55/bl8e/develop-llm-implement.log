{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K6cYkw9Xj27BbrcFx3GoMx","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"errors\"\n     8→\t\"fmt\"\n     9→\t\"io\"\n    10→\t\"net/http\"\n    11→\t\"os\"\n    12→\t\"path/filepath\"\n    13→\t\"strings\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    18→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    19→\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    20→\t\"google.golang.org/grpc\"\n    21→\t\"google.golang.org/grpc/credentials/insecure\"\n    22→)\n    23→\n    24→func main() {\n    25→\tif len(os.Args) < 2 {\n    26→\t\tusage()\n    27→\t\tos.Exit(1)\n    28→\t}\n    29→\n    30→\t// Commands that don't need a daemon connection\n    31→\tswitch os.Args[1] {\n    32→\tcase \"init\":\n    33→\t\tcmdInit(os.Args[2:])\n    34→\t\treturn\n    35→\tcase \"health\":\n    36→\t\tcmdHealth(os.Args[2:])\n    37→\t\treturn\n    38→\tcase \"get\":\n    39→\t\tcmdGet(os.Args[2:])\n    40→\t\treturn\n    41→\tcase \"set\":\n    42→\t\tcmdSet(os.Args[2:])\n    43→\t\treturn\n    44→\tcase \"tasks\":\n    45→\t\tcmdTasks(os.Args[2:])\n    46→\t\treturn\n    47→\t}\n    48→\n    49→\t// Commands that need a daemon connection\n    50→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    51→\tif addr == \"\" {\n    52→\t\taddr = \"unix:///tmp/cloche.sock\"\n    53→\t}\n    54→\n    55→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n    56→\tif err != nil {\n    57→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n    58→\t\tos.Exit(1)\n    59→\t}\n    60→\tdefer conn.Close()\n    61→\n    62→\tclient := pb.NewClocheServiceClient(conn)\n    63→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n    64→\tdefer cancel()\n    65→\n    66→\tswitch os.Args[1] {\n    67→\tcase \"run\":\n    68→\t\tcmdRun(ctx, client, os.Args[2:])\n    69→\tcase \"status\":\n    70→\t\tcmdStatus(ctx, client, os.Args[2:])\n    71→\tcase \"logs\":\n    72→\t\tcmdLogs(client, os.Args[2:])\n    73→\tcase \"poll\":\n    74→\t\tcmdPoll(client, os.Args[2:])\n    75→\tcase \"list\":\n    76→\t\tcmdList(ctx, client, os.Args[2:])\n    77→\tcase \"stop\":\n    78→\t\tcmdStop(ctx, client, os.Args[2:])\n    79→\tcase \"delete\":\n    80→\t\tcmdDelete(ctx, client, os.Args[2:])\n    81→\tcase \"loop\":\n    82→\t\tcmdLoop(ctx, client, os.Args[2:])\n    83→\tcase \"shutdown\":\n    84→\t\tcmdShutdown(ctx, client)\n    85→\tdefault:\n    86→\t\tusage()\n    87→\t\tos.Exit(1)\n    88→\t}\n    89→}\n    90→\n    91→func usage() {\n    92→\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n    93→\n    94→Commands:\n    95→  init [--workflow <name>] [--base-image <image>]\n    96→                                             Initialize a Cloche project\n    97→  health                                   Show project health summary\n    98→  run --workflow <name> [--prompt \"...\"] [--title \"...\"] [--keep-container]\n    99→                                             Launch a workflow run\n   100→  status <run-id>                            Check run status\n   101→  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n   102→                                             Show logs for a run\n   103→  poll <run-id>                              Wait for a run to finish\n   104→  list [--all]                                List runs (last hour by default)\n   105→  stop <run-id>                              Stop a running workflow\n   106→  delete <container-or-run-id>               Delete a retained container\n   107→  tasks [--project <dir>]                     Show task pipeline and assignment state\n   108→  loop [--max <n>]                            Start orchestration loop (default max=1)\n   109→  loop stop                                  Stop orchestration loop\n   110→  get <key>                                  Get a value from the run context store\n   111→  set <key> <value>                          Set a value in the run context store\n   112→  shutdown                                   Shut down the daemon\n   113→`)\n   114→}\n   115→\n   116→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   117→\tvar workflow, prompt, title string\n   118→\tvar keepContainer bool\n   119→\n   120→\tfor i := 0; i < len(args); i++ {\n   121→\t\tswitch args[i] {\n   122→\t\tcase \"--workflow\":\n   123→\t\t\tif i+1 < len(args) {\n   124→\t\t\t\ti++\n   125→\t\t\t\tworkflow = args[i]\n   126→\t\t\t}\n   127→\t\tcase \"--prompt\", \"-p\":\n   128→\t\t\tif i+1 < len(args) {\n   129→\t\t\t\ti++\n   130→\t\t\t\tprompt = args[i]\n   131→\t\t\t}\n   132→\t\tcase \"--title\":\n   133→\t\t\tif i+1 < len(args) {\n   134→\t\t\t\ti++\n   135→\t\t\t\ttitle = args[i]\n   136→\t\t\t}\n   137→\t\tcase \"--keep-container\":\n   138→\t\t\tkeepContainer = true\n   139→\t\tdefault:\n   140→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   141→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   142→\t\t\t\tworkflow = args[i]\n   143→\t\t\t}\n   144→\t\t}\n   145→\t}\n   146→\n   147→\tif workflow == \"\" {\n   148→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   149→\t\tos.Exit(1)\n   150→\t}\n   151→\n   152→\tcwd, _ := os.Getwd()\n   153→\n   154→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   155→\tvar image string\n   156→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   157→\tif data, err := os.ReadFile(wfPath); err == nil {\n   158→\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   159→\t\t\timage = wf.Config[\"container.image\"]\n   160→\t\t}\n   161→\t}\n   162→\n   163→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   164→\t\tWorkflowName:  workflow,\n   165→\t\tProjectDir:    cwd,\n   166→\t\tImage:         image,\n   167→\t\tPrompt:        prompt,\n   168→\t\tKeepContainer: keepContainer,\n   169→\t\tTitle:         title,\n   170→\t})\n   171→\tif err != nil {\n   172→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   173→\t\tos.Exit(1)\n   174→\t}\n   175→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   176→}\n   177→\n   178→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   179→\tif len(args) < 1 {\n   180→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   181→\t\tos.Exit(1)\n   182→\t}\n   183→\n   184→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   185→\tif err != nil {\n   186→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   187→\t\tos.Exit(1)\n   188→\t}\n   189→\n   190→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   191→\tif resp.Title != \"\" {\n   192→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   193→\t}\n   194→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   195→\tif resp.IsHost {\n   196→\t\tfmt.Printf(\"Type:      host\\n\")\n   197→\t} else {\n   198→\t\tfmt.Printf(\"Type:      container\\n\")\n   199→\t}\n   200→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   201→\tif resp.ContainerId != \"\" {\n   202→\t\tcid := resp.ContainerId\n   203→\t\tif len(cid) > 12 {\n   204→\t\t\tcid = cid[:12]\n   205→\t\t}\n   206→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   207→\t}\n   208→\tif resp.ErrorMessage != \"\" {\n   209→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   210→\t}\n   211→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   212→\tfor _, exec := range resp.StepExecutions {\n   213→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   214→\t}\n   215→}\n   216→\n   217→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   218→\tvar all bool\n   219→\tfor _, arg := range args {\n   220→\t\tif arg == \"--all\" {\n   221→\t\t\tall = true\n   222→\t\t}\n   223→\t}\n   224→\n   225→\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n   226→\tif err != nil {\n   227→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   228→\t\tos.Exit(1)\n   229→\t}\n   230→\n   231→\tif len(resp.Runs) == 0 {\n   232→\t\tfmt.Println(\"No runs found.\")\n   233→\t\treturn\n   234→\t}\n   235→\n   236→\tfor _, run := range resp.Runs {\n   237→\t\trunType := \"container\"\n   238→\t\tif run.IsHost {\n   239→\t\t\trunType = \"host\"\n   240→\t\t}\n   241→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   242→\t\tif run.Title != \"\" {\n   243→\t\t\tt := run.Title\n   244→\t\t\tif len(t) > 40 {\n   245→\t\t\t\tt = t[:37] + \"...\"\n   246→\t\t\t}\n   247→\t\t\tline += \"  \" + t\n   248→\t\t}\n   249→\t\tif run.ContainerId != \"\" {\n   250→\t\t\tline += \"  \" + run.ContainerId\n   251→\t\t}\n   252→\t\tif run.ErrorMessage != \"\" {\n   253→\t\t\terrMsg := run.ErrorMessage\n   254→\t\t\tif len(errMsg) > 60 {\n   255→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   256→\t\t\t}\n   257→\t\t\tline += \"  \" + errMsg\n   258→\t\t}\n   259→\t\tfmt.Println(line)\n   260→\t}\n   261→}\n   262→\n   263→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   264→\tif len(args) < 1 {\n   265→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n   266→\t\tos.Exit(1)\n   267→\t}\n   268→\n   269→\tvar stepFilter, typeFilter string\n   270→\tvar follow bool\n   271→\trunID := args[0]\n   272→\n   273→\tfor i := 1; i < len(args); i++ {\n   274→\t\tswitch args[i] {\n   275→\t\tcase \"--step\":\n   276→\t\t\tif i+1 < len(args) {\n   277→\t\t\t\ti++\n   278→\t\t\t\tstepFilter = args[i]\n   279→\t\t\t}\n   280→\t\tcase \"--type\":\n   281→\t\t\tif i+1 < len(args) {\n   282→\t\t\t\ti++\n   283→\t\t\t\ttypeFilter = args[i]\n   284→\t\t\t}\n   285→\t\tcase \"--follow\", \"-f\":\n   286→\t\t\tfollow = true\n   287→\t\t}\n   288→\t}\n   289→\n   290→\tif follow {\n   291→\t\tcmdLogsFollow(runID)\n   292→\t\treturn\n   293→\t}\n   294→\n   295→\t// Use background context — log output can be large\n   296→\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n   297→\t\tRunId:    runID,\n   298→\t\tStepName: stepFilter,\n   299→\t\tLogType:  typeFilter,\n   300→\t})\n   301→\tif err != nil {\n   302→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   303→\t\tos.Exit(1)\n   304→\t}\n   305→\n   306→\tfor {\n   307→\t\tentry, err := stream.Recv()\n   308→\t\tif err != nil {\n   309→\t\t\tif errors.Is(err, io.EOF) {\n   310→\t\t\t\tbreak\n   311→\t\t\t}\n   312→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   313→\t\t\tos.Exit(1)\n   314→\t\t}\n   315→\n   316→\t\tswitch entry.Type {\n   317→\t\tcase \"step_started\":\n   318→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   319→\t\t\tif entry.Message != \"\" {\n   320→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   321→\t\t\t}\n   322→\t\tcase \"step_completed\":\n   323→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   324→\t\t\tif entry.Message != \"\" {\n   325→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   326→\t\t\t}\n   327→\t\tcase \"run_completed\":\n   328→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   329→\t\t\tif entry.Message != \"\" {\n   330→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   331→\t\t\t}\n   332→\t\tcase \"full_log\":\n   333→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   334→\t\tcase \"log\":\n   335→\t\t\t// Live-streamed log line from an active run.\n   336→\t\t\tfmt.Println(entry.Message)\n   337→\t\tdefault:\n   338→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   339→\t\t\tif entry.StepName != \"\" {\n   340→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   341→\t\t\t}\n   342→\t\t\tif entry.Message != \"\" {\n   343→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   344→\t\t\t}\n   345→\t\t}\n   346→\t}\n   347→}\n   348→\n   349→func cmdLogsFollow(runID string) {\n   350→\t// Determine HTTP address from env\n   351→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   352→\tif httpAddr == \"\" {\n   353→\t\thttpAddr = \"localhost:8080\"\n   354→\t}\n   355→\t// Strip protocol prefix if present\n   356→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   357→\n   358→\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n   359→\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n   360→\tif err != nil {\n   361→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   362→\t\tos.Exit(1)\n   363→\t}\n   364→\treq.Header.Set(\"Accept\", \"text/event-stream\")\n   365→\n   366→\tresp, err := http.DefaultClient.Do(req)\n   367→\tif err != nil {\n   368→\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n   369→\t\tos.Exit(1)\n   370→\t}\n   371→\tdefer resp.Body.Close()\n   372→\n   373→\tif resp.StatusCode != 200 {\n   374→\t\tbody, _ := io.ReadAll(resp.Body)\n   375→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   376→\t\tos.Exit(1)\n   377→\t}\n   378→\n   379→\tscanner := bufio.NewScanner(resp.Body)\n   380→\tfor scanner.Scan() {\n   381→\t\tline := scanner.Text()\n   382→\t\tif strings.HasPrefix(line, \"event: done\") {\n   383→\t\t\tbreak\n   384→\t\t}\n   385→\t\tif !strings.HasPrefix(line, \"data: \") {\n   386→\t\t\tcontinue\n   387→\t\t}\n   388→\t\tdata := strings.TrimPrefix(line, \"data: \")\n   389→\n   390→\t\tvar entry struct {\n   391→\t\t\tTimestamp string `json:\"timestamp\"`\n   392→\t\t\tType      string `json:\"type\"`\n   393→\t\t\tContent   string `json:\"content\"`\n   394→\t\t}\n   395→\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n   396→\t\t\tcontinue\n   397→\t\t}\n   398→\n   399→\t\t// Color-code by type\n   400→\t\tswitch entry.Type {\n   401→\t\tcase \"status\":\n   402→\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   403→\t\tcase \"llm\":\n   404→\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   405→\t\tdefault:\n   406→\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n   407→\t\t}\n   408→\t}\n   409→}\n   410→\n   411→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   412→\tif len(args) < 1 {\n   413→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   414→\t\tos.Exit(1)\n   415→\t}\n   416→\n   417→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   418→\tif err != nil {\n   419→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   420→\t\tos.Exit(1)\n   421→\t}\n   422→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   423→}\n   424→\n   425→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   426→\tif len(args) < 1 {\n   427→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   428→\t\tos.Exit(1)\n   429→\t}\n   430→\n   431→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   432→\tif err != nil {\n   433→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   434→\t\tos.Exit(1)\n   435→\t}\n   436→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   437→}\n   438→\n   439→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   440→\tcwd, _ := os.Getwd()\n   441→\n   442→\t// Check for \"stop\" subcommand\n   443→\tif len(args) > 0 && args[0] == \"stop\" {\n   444→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   445→\t\tif err != nil {\n   446→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   447→\t\t\tos.Exit(1)\n   448→\t\t}\n   449→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   450→\t\treturn\n   451→\t}\n   452→\n   453→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   454→\tvar maxConcurrent int32\n   455→\tfor i := 0; i < len(args); i++ {\n   456→\t\tswitch args[i] {\n   457→\t\tcase \"--max\":\n   458→\t\t\tif i+1 < len(args) {\n   459→\t\t\t\ti++\n   460→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   461→\t\t\t\tif n != 1 || err != nil {\n   462→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   463→\t\t\t\t\tos.Exit(1)\n   464→\t\t\t\t}\n   465→\t\t\t}\n   466→\t\t}\n   467→\t}\n   468→\n   469→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   470→\t\tProjectDir:    cwd,\n   471→\t\tMaxConcurrent: maxConcurrent,\n   472→\t})\n   473→\tif err != nil {\n   474→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   475→\t\tos.Exit(1)\n   476→\t}\n   477→\tif maxConcurrent > 0 {\n   478→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   479→\t} else {\n   480→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   481→\t}\n   482→}\n   483→\n   484→func cmdTasks(args []string) {\n   485→\t// Determine HTTP address from env\n   486→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   487→\tif httpAddr == \"\" {\n   488→\t\thttpAddr = \"localhost:8080\"\n   489→\t}\n   490→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   491→\n   492→\t// Determine project label from --project flag or current directory\n   493→\tprojectDir := \"\"\n   494→\tfor i := 0; i < len(args); i++ {\n   495→\t\tswitch args[i] {\n   496→\t\tcase \"--project\":\n   497→\t\t\tif i+1 < len(args) {\n   498→\t\t\t\ti++\n   499→\t\t\t\tprojectDir = args[i]\n   500→\t\t\t}\n   501→\t\t}\n   502→\t}\n   503→\n   504→\tif projectDir == \"\" {\n   505→\t\tcwd, _ := os.Getwd()\n   506→\t\tprojectDir = filepath.Base(cwd)\n   507→\t}\n   508→\n   509→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   510→\tresp, err := http.Get(tasksURL)\n   511→\tif err != nil {\n   512→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   513→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   514→\t\tos.Exit(1)\n   515→\t}\n   516→\tdefer resp.Body.Close()\n   517→\n   518→\tif resp.StatusCode != 200 {\n   519→\t\tbody, _ := io.ReadAll(resp.Body)\n   520→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   521→\t\tos.Exit(1)\n   522→\t}\n   523→\n   524→\ttype taskEntry struct {\n   525→\t\tID          string `json:\"id\"`\n   526→\t\tStatus      string `json:\"status\"`\n   527→\t\tTitle       string `json:\"title\"`\n   528→\t\tDescription string `json:\"description\"`\n   529→\t\tAssigned    bool   `json:\"assigned\"`\n   530→\t\tAssignedAt  string `json:\"assigned_at\"`\n   531→\t\tRunID       string `json:\"run_id\"`\n   532→\t}\n   533→\n   534→\tvar tasks []taskEntry\n   535→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   536→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   537→\t\tos.Exit(1)\n   538→\t}\n   539→\n   540→\tif len(tasks) == 0 {\n   541→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   542→\t\treturn\n   543→\t}\n   544→\n   545→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   546→\tfor _, t := range tasks {\n   547→\t\tstatus := t.Status\n   548→\t\tif status == \"\" {\n   549→\t\t\tstatus = \"open\"\n   550→\t\t}\n   551→\t\tassigned := \"-\"\n   552→\t\tif t.Assigned {\n   553→\t\t\tassigned = \"yes\"\n   554→\t\t}\n   555→\t\trunID := \"\"\n   556→\t\tif t.RunID != \"\" {\n   557→\t\t\trunID = t.RunID\n   558→\t\t\tif len(runID) > 30 {\n   559→\t\t\t\trunID = runID[:27] + \"...\"\n   560→\t\t\t}\n   561→\t\t}\n   562→\t\ttitle := t.Title\n   563→\t\tif len(title) > 40 {\n   564→\t\t\ttitle = title[:37] + \"...\"\n   565→\t\t}\n   566→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   567→\t}\n   568→}\n   569→\n   570→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   571→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   572→\tif err != nil {\n   573→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   574→\t\tos.Exit(1)\n   575→\t}\n   576→\tfmt.Println(\"Daemon shutting down.\")\n   577→}\n   578→\n   579→// resolveRunContext returns the project directory and run ID for context\n   580→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   581→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   582→func resolveRunContext() (projectDir, runID string, err error) {\n   583→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   584→\tif runID == \"\" {\n   585→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   586→\t}\n   587→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   588→\tif projectDir == \"\" {\n   589→\t\tprojectDir, err = os.Getwd()\n   590→\t\tif err != nil {\n   591→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   592→\t\t}\n   593→\t}\n   594→\treturn projectDir, runID, nil\n   595→}\n   596→\n   597→func cmdGet(args []string) {\n   598→\tif len(args) < 1 {\n   599→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   600→\t\tos.Exit(1)\n   601→\t}\n   602→\n   603→\tprojectDir, runID, err := resolveRunContext()\n   604→\tif err != nil {\n   605→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   606→\t\tos.Exit(1)\n   607→\t}\n   608→\n   609→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   610→\tif err != nil {\n   611→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   612→\t\tos.Exit(1)\n   613→\t}\n   614→\tif !ok {\n   615→\t\tos.Exit(1)\n   616→\t}\n   617→\tfmt.Println(val)\n   618→}\n   619→\n   620→func cmdSet(args []string) {\n   621→\tif len(args) < 2 {\n   622→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   623→\t\tos.Exit(1)\n   624→\t}\n   625→\n   626→\tprojectDir, runID, err := resolveRunContext()\n   627→\tif err != nil {\n   628→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   629→\t\tos.Exit(1)\n   630→\t}\n   631→\n   632→\tif err := runcontext.Set(projectDir, runID, args[0], args[1]); err != nil {\n   633→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   634→\t\tos.Exit(1)\n   635→\t}\n   636→}\n   637→"}]},"parent_tool_use_id":"toolu_01DRJpD1eM96SarjwC2tMEGw","session_id":"8b59bc36-4d9a-4087-87ff-725aff05648e","uuid":"1eee1f55-b367-4db7-bd3c-bb8d32b82e99"}
