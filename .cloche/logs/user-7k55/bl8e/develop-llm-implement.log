equest{\n1121-\t\tRunId:    resp.RunId,\n1122-\t\tStepName: \"build\",\n1123-\t\tLogType:  \"llm\",\n1124-\t}, mock2)\n1125-\trequire.NoError(t, err)\n1126-\tassert.GreaterOrEqual(t, len(mock2.entries), 1, \"should have at least one LLM log entry\")\n1127-\n1128-\tfor _, e := range mock2.entries {\n1129-\t\tif e.Message != \"\" {\n1130-\t\t\tassert.Contains(t, e.Message, \"llm conversation\", \"should contain LLM output\")\n1131-\t\t}\n1132-\t}\n1133-}\n1134-\n1135-func TestServer_StreamLogs_FullLog(t *testing.T) {\n1136-\tstore, err := sqlite.NewStore(\":memory:\")\n1137-\trequire.NoError(t, err)\n1138-\tdefer store.Close()\n1139-\n--\n1179:\tmock := &mockLogStream{ctx: context.Background()}\n1180-\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n1181-\trequire.NoError(t, err)\n1182-\n1183-\t// Should have a full_log entry\n1184-\tvar foundFullLog bool\n1185-\tfor _, e := range mock.entries {\n1186-\t\tif e.Type == \"full_log\" {\n1187-\t\t\tfoundFullLog = true\n1188-\t\t\tassert.Contains(t, e.Message, \"unified log content here\")\n1189-\t\t}\n1190-\t}\n1191-\tassert.True(t, foundFullLog, \"should serve full.log as unified log when available\")\n1192-}\n1193-\n1194-func TestServer_StreamLogs_LiveStreaming(t *testing.T) {\n1195-\tstore, err := sqlite.NewStore(\":memory:\")\n1196-\trequire.NoError(t, err)\n1197-\tdefer store.Close()\n1198-\n1199-\t// Create a running run (no container needed — we test the broadcaster path directly).\n--\n1214:\tmock := &mockLogStream{ctx: streamCtx}\n1215-\n1216-\t// Publish log lines in a goroutine, then finish the broadcast.\n1217-\tgo func() {\n1218-\t\ttime.Sleep(50 * time.Millisecond)\n1219-\t\tbroadcaster.Publish(\"live-test-1\", logstream.LogLine{\n1220-\t\t\tTimestamp: \"2026-03-10T10:00:00Z\",\n1221-\t\t\tType:      \"status\",\n1222-\t\t\tContent:   \"step_started: implement\",\n1223-\t\t\tStepName:  \"implement\",\n1224-\t\t})\n1225-\t\ttime.Sleep(50 * time.Millisecond)\n1226-\t\tbroadcaster.Publish(