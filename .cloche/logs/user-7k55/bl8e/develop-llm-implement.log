{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NXG7nn1gLC3nfLBRenYc63","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    19→\t\"github.com/cloche-dev/cloche/internal/config\"\n    20→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    21→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    22→\t\"github.com/cloche-dev/cloche/internal/host\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    26→\trpcgrpc \"google.golang.org/grpc\"\n    27→)\n    28→\n    29→type ClocheServer struct {\n    30→\tpb.UnimplementedClocheServiceServer\n    31→\tstore        ports.RunStore\n    32→\tcaptures     ports.CaptureStore\n    33→\tlogStore     ports.LogStore\n    34→\tcontainer    ports.ContainerRuntime\n    35→\tdefaultImage string\n    36→\tevolution    *evolution.Trigger\n    37→\tlogBroadcast *logstream.Broadcaster\n    38→\tshutdownFn   func()\n    39→\tmu           sync.Mutex\n    40→\trunIDs       map[string]string      // run_id -> container_id\n    41→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    42→}\n    43→\n    44→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    45→\treturn &ClocheServer{\n    46→\t\tstore:     store,\n    47→\t\tcontainer: container,\n    48→\t\trunIDs:    make(map[string]string),\n    49→\t\tloops:     make(map[string]*host.Loop),\n    50→\t}\n    51→}\n    52→\n    53→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    54→\treturn &ClocheServer{\n    55→\t\tstore:        store,\n    56→\t\tcaptures:     captures,\n    57→\t\tcontainer:    container,\n    58→\t\tdefaultImage: defaultImage,\n    59→\t\trunIDs:       make(map[string]string),\n    60→\t\tloops:        make(map[string]*host.Loop),\n    61→\t}\n    62→}\n    63→\n    64→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    65→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    66→\ts.logStore = ls\n    67→}\n    68→\n    69→\n    70→// SetEvolution attaches an evolution trigger to the server.\n    71→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    72→\ts.evolution = trigger\n    73→}\n    74→\n    75→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    76→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    77→\ts.logBroadcast = b\n    78→}\n    79→\n    80→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    81→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    82→\ts.shutdownFn = fn\n    83→}\n    84→\n    85→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    86→\tif s.container == nil {\n    87→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    88→\t}\n    89→\n    90→\t// Generate a unique run ID, retrying on collision\n    91→\tvar runID string\n    92→\tfor attempts := 0; attempts < 10; attempts++ {\n    93→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    94→\t\texisting, err := s.store.GetRun(ctx, runID)\n    95→\t\tif err != nil {\n    96→\t\t\tbreak // ID is free\n    97→\t\t}\n    98→\t\t// Reuse if completed more than 1 hour ago\n    99→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   100→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   101→\t\t\tbreak\n   102→\t\t}\n   103→\t}\n   104→\n   105→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   106→\tif req.Prompt != \"\" {\n   107→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   108→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   109→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   110→\t\t}\n   111→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   112→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   113→\t\t}\n   114→\t}\n   115→\trun := domain.NewRun(runID, req.WorkflowName)\n   116→\trun.ProjectDir = req.ProjectDir\n   117→\trun.Title = req.Title\n   118→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   119→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   120→\t}\n   121→\n   122→\t// Resolve image: request-level override, then server default\n   123→\timage := req.Image\n   124→\tif image == \"\" {\n   125→\t\timage = s.defaultImage\n   126→\t}\n   127→\n   128→\t// Launch container start + tracking in background so the RPC returns immediately.\n   129→\t// The run stays in \"pending\" state until the container is up.\n   130→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   131→\n   132→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   133→}\n   134→\n   135→// launchAndTrack starts the container and then tracks it to completion.\n   136→// It runs in a background goroutine with its own context, independent of the\n   137→// RPC context which may be cancelled after RunWorkflow returns.\n   138→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   139→\tctx := context.Background()\n   140→\n   141→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   142→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   143→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   144→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   145→\t\t\tif run != nil {\n   146→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   147→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   148→\t\t\t}\n   149→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   150→\t\t\t\treturn\n   151→\t\t}\n   152→\t}\n   153→\n   154→\tbaseSHA := gitHEAD(req.ProjectDir)\n   155→\n   156→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   157→\t\tImage:        image,\n   158→\t\tWorkflowName: req.WorkflowName,\n   159→\t\tProjectDir:   req.ProjectDir,\n   160→\t\tRunID:        runID,\n   161→\t\tNetworkAllow: []string{\"*\"},\n   162→\t})\n   163→\tif err != nil {\n   164→\t\trun, _ := s.store.GetRun(ctx, runID)\n   165→\t\tif run != nil {\n   166→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   167→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   168→\t\t}\n   169→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   170→\t\treturn\n   171→\t}\n   172→\n   173→\ts.mu.Lock()\n   174→\ts.runIDs[runID] = containerID\n   175→\ts.mu.Unlock()\n   176→\n   177→\trun, _ := s.store.GetRun(ctx, runID)\n   178→\tif run != nil {\n   179→\t\trun.Start()\n   180→\t\trun.ContainerID = containerID\n   181→\t\trun.BaseSHA = baseSHA\n   182→\t\t_ = s.store.UpdateRun(ctx, run)\n   183→\t}\n   184→\n   185→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   186→}\n   187→\n   188→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   189→\tctx := context.Background()\n   190→\n   191→\t// Attach to agent output\n   192→\treader, err := s.container.AttachOutput(ctx, containerID)\n   193→\tif err != nil {\n   194→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   195→\t\t\treturn\n   196→\t}\n   197→\n   198→\t// Parse JSON-lines status messages\n   199→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   200→\tscanner := bufio.NewScanner(reader)"}]},"parent_tool_use_id":"toolu_01DRJpD1eM96SarjwC2tMEGw","session_id":"8b59bc36-4d9a-4087-87ff-725aff05648e","uuid":"1cd638ec-b589-4eb1-8361-2af9b26d19a4"}
