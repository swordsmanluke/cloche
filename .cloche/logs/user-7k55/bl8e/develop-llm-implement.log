{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KRZPx8NT3KfiqJJphfTywp","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"net/http\"\n     8→\t\"net/http/httptest\"\n     9→\t\"os\"\n    10→\t\"path/filepath\"\n    11→\t\"strings\"\n    12→\t\"testing\"\n    13→\t\"time\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    16→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    17→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    18→\t\"github.com/stretchr/testify/assert\"\n    19→\t\"github.com/stretchr/testify/require\"\n    20→)\n    21→\n    22→func setupHandlerWithBroadcaster(t *testing.T) (*Handler, *sqlite.Store, *logstream.Broadcaster) {\n    23→\tt.Helper()\n    24→\tstore, err := sqlite.NewStore(\":memory:\")\n    25→\trequire.NoError(t, err)\n    26→\tt.Cleanup(func() { store.Close() })\n    27→\n    28→\tb := logstream.NewBroadcaster()\n    29→\th, err := NewHandler(store, store, WithLogBroadcaster(b))\n    30→\trequire.NoError(t, err)\n    31→\treturn h, store, b\n    32→}\n    33→\n    34→func TestSSE_CompletedRun_ServesFullLog(t *testing.T) {\n    35→\th, store, _ := setupHandlerWithBroadcaster(t)\n    36→\n    37→\tdir := t.TempDir()\n    38→\n    39→\t// Create a completed run\n    40→\tctx := context.Background()\n    41→\trun := domain.NewRun(\"sse-test-1\", \"develop\")\n    42→\trun.ProjectDir = dir\n    43→\trun.Start()\n    44→\trun.ContainerID = \"abc123\"\n    45→\trun.Complete(domain.RunStateSucceeded)\n    46→\trequire.NoError(t, store.CreateRun(ctx, run))\n    47→\n    48→\t// Write full.log\n    49→\toutputDir := filepath.Join(dir, \".cloche\", \"sse-test-1\", \"output\")\n    50→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n    51→\tlogContent := \"[2026-03-03T10:15:00Z] [status] step_started: build\\n\" +\n    52→\t\t\"[2026-03-03T10:15:01Z] [script] npm run build\\n\" +\n    53→\t\t\"[2026-03-03T10:15:02Z] [llm] Claude: Starting analysis\\n\"\n    54→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"full.log\"), []byte(logContent), 0644))\n    55→\n    56→\treq := httptest.NewRequest(\"GET\", \"/api/runs/sse-test-1/stream\", nil)\n    57→\tw := httptest.NewRecorder()\n    58→\th.ServeHTTP(w, req)\n    59→\n    60→\tassert.Equal(t, http.StatusOK, w.Code)\n    61→\tassert.Equal(t, \"text/event-stream\", w.Header().Get(\"Content-Type\"))\n    62→\n    63→\t// Parse SSE events\n    64→\tbody := w.Body.String()\n    65→\tlines := strings.Split(body, \"\\n\")\n    66→\n    67→\tvar events []logstream.LogLine\n    68→\tfor _, line := range lines {\n    69→\t\tif strings.HasPrefix(line, \"data: \") {\n    70→\t\t\tdata := strings.TrimPrefix(line, \"data: \")\n    71→\t\t\tvar ll logstream.LogLine\n    72→\t\t\tif json.Unmarshal([]byte(data), &ll) == nil {\n    73→\t\t\t\tevents = append(events, ll)\n    74→\t\t\t}\n    75→\t\t}\n    76→\t}\n    77→\n    78→\trequire.Len(t, events, 3)\n    79→\tassert.Equal(t, \"status\", events[0].Type)\n    80→\tassert.Equal(t, \"step_started: build\", events[0].Content)\n    81→\tassert.Equal(t, \"script\", events[1].Type)\n    82→\tassert.Equal(t, \"npm run build\", events[1].Content)\n    83→\tassert.Equal(t, \"llm\", events[2].Type)\n    84→\tassert.Equal(t, \"Claude: Starting analysis\", events[2].Content)\n    85→\n    86→\t// Should contain done event\n    87→\tassert.Contains(t, body, \"event: done\")\n    88→}\n    89→\n    90→func TestSSE_ActiveRun_StreamsLive(t *testing.T) {\n    91→\th, store, b := setupHandlerWithBroadcaster(t)\n    92→\n    93→\t// Create a running run\n    94→\tctx := context.Background()\n    95→\trun := domain.NewRun(\"sse-live-1\", \"develop\")\n    96→\trun.ProjectDir = t.TempDir()\n    97→\trun.Start()\n    98→\trun.ContainerID = \"abc123\"\n    99→\trequire.NoError(t, store.CreateRun(ctx, run))\n   100→"}]},"parent_tool_use_id":"toolu_01DRJpD1eM96SarjwC2tMEGw","session_id":"8b59bc36-4d9a-4087-87ff-725aff05648e","uuid":"f550fbcd-9935-4fa2-ab22-bd114c4115f8"}
