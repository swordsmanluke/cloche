[2026-03-16T17:14:26Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_015rYukhj99hMqetp1tUrJcB","type":"message","role":"assistant","content":[{"type":"text","text":"The issue is that in legacy mode without a task assigner, the first failure causes a 2-minute backoff (idlePollInterval). The loop only runs 1 job within the 500ms test window. The problem is that my tests need `StopOnError: false` explicitly (otherwise the first failure also halts via StopOnError... wait, no, StopOnError defaults to false).\n\nThe real issue is the backoff. After a failure, the loop sleeps for `idlePollInterval` (2 minutes), so within 500ms we only see 1 run. I need to understand the flow better. Let me re-examine.\n\nLooking at `runLegacy`: after a failure, it calls `l.sleep(idlePollInterval)` which is 2 minutes. The test only waits 500ms, so only 1 run completes. The consecutive failures never reach 3 because we can't run 3 jobs in 500ms with 2min backoff between failures.\n\nI need to make the tests work with the backoff. The trick is that `resumeCh` can wake the loop from sleep. Let me adjust the tests to send resume signals to wake the loop, or I need a different approach.\n\nActually, looking at existing tests like `TestLoop_StopOnError_Disabled_ContinuesOnFailure`, it also only checks for >= 1 run for the same reason. The clean approach is to check in a longer time or use the resume channel to wake it up.\n\nA better approach: the tests should use the phased mode where we can control task creation to generate multiple failures quickly. Actually no, the backoff happens in both modes.\n\nThe simplest fix: after each failure the loop backs off for 2 min. But `Resume()` wakes it. So I can use a wrapper around the runFn that calls Resume() to wake the loop faster. But that's hacky.\n\nActually, looking more carefully at the code flow, in legacy mode without task assigner: failure → `recordConsecutiveFailure()` → backoff 2 min. So we can never reach 3 in 500ms. The tests need to work differently.\n\nLet me think about the best approach. I could:\n1. Make the backoff interval configurable (over-engineering)\n2. Have the tests use resume to wake up faster\n3. Test the `recordConsecutiveFailure` and `resetConsecutiveFailures` methods directly, plus a simpler integration test\n\nOption 3 is cleanest. Let me rewrite the tests:"}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3742,"cache_read_input_tokens":70858,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3742},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"77daf22e-aee8-40ec-9b79-2fa0d1f74d8f","uuid":"4cb424e0-a199-410a-94c1-0c978ed50b2b"}
[2026-03-16T17:14:26Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_015rYukhj99hMqetp1tUrJcB","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01MmxkTb7L6ssrDUvrjgQ8bM","name":"Edit","input":{"replace_all":false,"file_path":"/workspace/internal/host/loop_test.go","old_string":"// --- MaxConsecutiveFailures tests ---\n\nfunc TestLoop_ConsecutiveFailures_HaltsAfterThreshold(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tcalled.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 3,\n\t}, store, runFn)\n\n\tloop.Start()\n\t// Wait for 3 failures + halt.\n\ttime.Sleep(500 * time.Millisecond)\n\n\thalted, haltErr := loop.Halted()\n\tassert.True(t, halted, \"loop should be halted after 3 consecutive failures\")\n\tassert.Contains(t, haltErr, \"consecutive failures\")\n\n\t// Exactly 3 runs should have been launched before halt.\n\tassert.Equal(t, int32(3), called.Load(), \"should halt after exactly 3 failures\")\n\n\tloop.Stop()\n}\n\nfunc TestLoop_ConsecutiveFailures_ResetOnSuccess(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tn := called.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\t// Succeed on call 2 to reset the counter, then fail again.\n\t\tif n == 2 {\n\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t\t}\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 2,\n\t}, store, runFn)\n\n\tloop.Start()\n\t// Run 1: fail (count=1), Run 2: succeed (count=0), Run 3: fail (count=1), Run 4: fail (count=2 → halt)\n\ttime.Sleep(800 * time.Millisecond)\n\n\thalted, _ := loop.Halted()\n\tassert.True(t, halted, \"loop should eventually halt\")\n\t// At least 4 runs: fail, succeed, fail, fail\n\tassert.GreaterOrEqual(t, called.Load(), int32(4))\n\n\tloop.Stop()\n}\n\nfunc TestLoop_ConsecutiveFailures_ResumeResetsCounter(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tcalled.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 2,\n\t}, store, runFn)\n\n\tloop.Start()\n\ttime.Sleep(400 * time.Millisecond)\n\n\thalted, _ := loop.Halted()\n\tassert.True(t, halted, \"loop should halt after 2 consecutive failures\")\n\tassert.Equal(t, int32(2), called.Load())\n\n\t// Resume clears the counter so it takes another 2 failures to halt again.\n\tloop.Resume()\n\ttime.Sleep(400 * time.Millisecond)\n\n\thalted, _ = loop.Halted()\n\tassert.True(t, halted, \"loop should halt again after resume\")\n\tassert.Equal(t, int32(4), called.Load())\n\n\tloop.Stop()\n}\n\nfunc TestLoop_ConsecutiveFailures_DefaultThreshold(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\t// MaxConsecutiveFailures=0 should default to 3.\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 0,\n\t}, store, func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t})\n\n\tassert.Equal(t, defaultMaxConsecutiveFailures, loop.config.MaxConsecutiveFailures)\n\tloop.Stop()\n}\n\nfunc TestPhaseLoop_ConsecutiveFailures_HaltsAfterThreshold(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar mainCalls atomic.Int32\n\ttaskCounter := 0\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\ttaskCounter++\n\t\treturn []Task{{ID: fmt.Sprintf(\"task-%d\", taskCounter), Status: \"open\"}}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{RunID: \"run-\" + taskID, State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tDedupTimeout:           50 * time.Millisecond,\n\t\tMaxConsecutiveFailures: 2,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(500 * time.Millisecond)\n\n\thalted, haltErr := loop.Halted()\n\tassert.True(t, halted, \"phased loop should be halted after consecutive failures\")\n\tassert.Contains(t, haltErr, \"consecutive failures\")\n\tassert.Equal(t, int32(2), mainCalls.Load())\n\n\tloop.Stop()\n}","new_string":"// --- MaxConsecutiveFailures tests ---\n\nfunc TestLoop_ConsecutiveFailures_RecordAndReset(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 3,\n\t}, store, func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t})\n\n\t// Below threshold — not halted.\n\tassert.False(t, loop.recordConsecutiveFailure())\n\tassert.False(t, loop.recordConsecutiveFailure())\n\n\t// Third failure reaches threshold.\n\tassert.True(t, loop.recordConsecutiveFailure())\n\n\t// Reset clears the counter.\n\tloop.resetConsecutiveFailures()\n\tassert.False(t, loop.recordConsecutiveFailure()) // back to 1\n}\n\nfunc TestLoop_ConsecutiveFailures_HaltsLoopOnThreshold(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tn := called.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\tif n == 1 {\n\t\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t\t}\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\t// With MaxConsecutiveFailures=1, behaves like stop_on_error.\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, haltErr := loop.Halted()\n\tassert.True(t, halted, \"loop should be halted after 1 consecutive failure\")\n\tassert.Contains(t, haltErr, \"consecutive failures\")\n\tassert.Equal(t, int32(1), called.Load())\n\n\tloop.Stop()\n}\n\nfunc TestLoop_ConsecutiveFailures_ResumeResetsCounter(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tcalled.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, _ := loop.Halted()\n\tassert.True(t, halted, \"loop should halt after 1 consecutive failure\")\n\tassert.Equal(t, int32(1), called.Load())\n\n\t// Resume clears the counter so it takes another failure to halt.\n\tloop.Resume()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, _ = loop.Halted()\n\tassert.True(t, halted, \"loop should halt again after resume\")\n\tassert.Equal(t, int32(2), called.Load())\n\n\tloop.Stop()\n}\n\nfunc TestLoop_ConsecutiveFailures_DefaultThreshold(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\t// MaxConsecutiveFailures=0 should default to 3.\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 0,\n\t}, store, func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t})\n\n\tassert.Equal(t, defaultMaxConsecutiveFailures, loop.config.MaxConsecutiveFailures)\n}\n\nfunc TestLoop_ConsecutiveFailures_SuccessResetsInLoop(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tn := called.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\t// First succeeds (resets counter), second fails and halts (threshold=1).\n\t\tif n == 1 {\n\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t\t}\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:             \"/tmp/test-project\",\n\t\tMaxConcurrent:          1,\n\t\tMaxConsecutiveFailures: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\n\thalted, _ := loop.Halted()\n\tassert.True(t, halted, \"loop should halt on second run (first failure after success)\")\n\tassert.Equal(t, int32(2), called.Load(), \"two runs: one success, one failure\")\n\n\tloop.Stop()\n}\n\nfunc TestPhaseLoop_ConsecutiveFailures_HaltsAfterThreshold(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar mainCalls atomic.Int32\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{{ID: fmt.Sprintf(\"task-%d\", mainC