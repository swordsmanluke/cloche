[2026-03-16T17:14:26Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PZdZsosaggnioZptmeFgEd","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"sort\"\n    13→\t\"strconv\"\n    14→\t\"strings\"\n    15→\t\"sync\"\n    16→\t\"time\"\n    17→\n    18→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    20→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    21→\t\"github.com/cloche-dev/cloche/internal/config\"\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    24→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    25→\t\"github.com/cloche-dev/cloche/internal/host\"\n    26→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    27→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    28→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    29→\t\"github.com/cloche-dev/cloche/internal/version\"\n    30→\trpcgrpc \"google.golang.org/grpc\"\n    31→\t\"google.golang.org/grpc/metadata\"\n    32→)\n    33→\n    34→type ClocheServer struct {\n    35→\tpb.UnimplementedClocheServiceServer\n    36→\tstore        ports.RunStore\n    37→\tcaptures     ports.CaptureStore\n    38→\tlogStore     ports.LogStore\n    39→\tcontainer    ports.ContainerRuntime\n    40→\tdefaultImage string\n    41→\tevolution    *evolution.Trigger\n    42→\tlogBroadcast *logstream.Broadcaster\n    43→\tshutdownFn   func()\n    44→\tmu           sync.Mutex\n    45→\trunIDs       map[string]string      // run_id -> container_id\n    46→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    47→}\n    48→\n    49→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    50→\treturn &ClocheServer{\n    51→\t\tstore:     store,\n    52→\t\tcontainer: container,\n    53→\t\trunIDs:    make(map[string]string),\n    54→\t\tloops:     make(map[string]*host.Loop),\n    55→\t}\n    56→}\n    57→\n    58→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    59→\treturn &ClocheServer{\n    60→\t\tstore:        store,\n    61→\t\tcaptures:     captures,\n    62→\t\tcontainer:    container,\n    63→\t\tdefaultImage: defaultImage,\n    64→\t\trunIDs:       make(map[string]string),\n    65→\t\tloops:        make(map[string]*host.Loop),\n    66→\t}\n    67→}\n    68→\n    69→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    70→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    71→\ts.logStore = ls\n    72→}\n    73→\n    74→\n    75→// SetEvolution attaches an evolution trigger to the server.\n    76→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    77→\ts.evolution = trigger\n    78→}\n    79→\n    80→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    81→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    82→\ts.logBroadcast = b\n    83→}\n    84→\n    85→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    86→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    87→\ts.shutdownFn = fn\n    88→}\n    89→\n    90→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    91→\t// Check for resume mode via gRPC metadata\n    92→\tif resumeRunID := resumeRunIDFromContext(ctx); resumeRunID != \"\" {\n    93→\t\treturn s.resumeRun(ctx, resumeRunID, resumeStepFromContext(ctx))\n    94→\t}\n    95→\n    96→\t// Check if this is a host workflow (has host {} block).\n    97→\tif hostWFs, err := host.FindHostWorkflows(req.ProjectDir); err == nil {\n    98→\t\tif _, isHost := hostWFs[req.WorkflowName]; isHost {\n    99→\t\t\treturn s.runHostWorkflow(ctx, req)\n   100→\t\t}\n   101→\t}\n   102→\n   103→\tif s.container == nil {\n   104→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   105→\t}\n   106→\n   107→\t// Generate a unique run ID, retrying on collision\n   108→\tvar runID string\n   109→\tfor attempts := 0; attempts < 10; attempts++ {\n   110→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n   111→\t\texisting, err := s.store.GetRun(ctx, runID)\n   112→\t\tif err != nil {\n   113→\t\t\tbreak // ID is free\n   114→\t\t}\n   115→\t\t// Reuse if completed more than 1 hour ago\n   116→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   117→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   118→\t\t\tbreak\n   119→\t\t}\n   120→\t}\n   121→\n   122→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   123→\tif req.Prompt != \"\" {\n   124→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   125→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   126→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   127→\t\t}\n   128→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   129→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   130→\t\t}\n   131→\t}\n   132→\trun := domain.NewRun(runID, req.WorkflowName)\n   133→\trun.ProjectDir = req.ProjectDir\n   134→\trun.Title = req.Title\n   135→\trun.TaskID = req.IssueId\n   136→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   137→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   138→\t}\n   139→\n   140→\t// Resolve image: request-level override, then server default\n   141→\timage := req.Image\n   142→\tif image == \"\" {\n   143→\t\timage = s.defaultImage\n   144→\t}\n   145→\n   146→\t// Launch container start + tracking in background so the RPC returns immediately.\n   147→\t// The run stays in \"pending\" state until the container is up.\n   148→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   149→\n   150→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   151→}\n   152→\n   153→// runHostWorkflow dispatches a host workflow via the host runner, returning\n   154→// immediately while the workflow runs in a background goroutine.\n   155→func (s *ClocheServer) runHostWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n   156→\trunID := domain.GenerateRunID(req.WorkflowName)\n   157→\n   158→\trunner := &host.Runner{\n   159→\t\tDispatcher:   s,\n   160→\t\tStore:        s.store,\n   161→\t\tCaptures:     s.captures,\n   162→\t\tLogBroadcast: s.logBroadcast,\n   163→\t\tTaskID:       req.IssueId,\n   164→\t}\n   165→\n   166→\tgo func() {\n   167→\t\trunner.RunNamedWithID(context.Background(), req.ProjectDir, req.WorkflowName, runID)\n   168→\t}()\n   169→\n   170→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   171→}\n   172→\n   173→// resumeRunIDFromContext extracts the resume run ID from gRPC metadata.\n   174→func resumeRunIDFromContext(ctx context.Context) string {\n   175→\tmd, ok := metadata.FromIncomingContext(ctx)\n   176→\tif !ok {\n   177→\t\treturn \"\"\n   178→\t}\n   179→\tvals := md.Get(\"x-cloche-resume-run-id\")\n   180→\tif len(vals) == 0 {\n   181→\t\treturn \"\"\n   182→\t}\n   183→\treturn vals[0]\n   184→}\n   185→\n   186→// resumeStepFromContext extracts the resume step name from gRPC metadata.\n   187→func resumeStepFromContext(ctx context.Context) string {\n   188→\tmd, ok := metadata.FromIncomingContext(ctx)\n   189→\tif !ok {\n   190→\t\treturn \"\"\n   191→\t}\n   192→\tvals := md.Get(\"x-cloche-resume-step\")\n   193→\tif len(vals) == 0 {\n   194→\t\treturn \"\"\n   195→\t}\n   196→\treturn vals[0]\n   197→}\n   198→\n   199→// resumeRun resumes a failed workflow run from a specific step.\n   200→func (s *ClocheServer) resumeRun(ctx context.Context, runID, stepName string) (*pb.RunWorkflowResponse, error) {\n   201→\trun, err := s.store.GetRun(ctx, runID)\n   202→\tif err != nil {\n   203→\t\treturn nil, fmt.Errorf(\"run %q not found: %w\", runID, err)\n   204→\t}\n   205→\n   206→\tif run.State != domain.RunStateFailed {\n   207→\t\treturn nil, fmt.Errorf(\"run %q is in state %q, only failed runs can be resumed\", runID, run.State)\n   208→\t}\n   209→\n   210→\t// Determine the resume step: use provided step name, or find first failed step\n   211→\tif stepName == \"\" {\n   212→\t\tstepName = run.FindFirstFailedStep()\n   213→\t\tif stepName == \"\" {\n   214→\t\t\treturn nil, fmt.Errorf(\"run %q has no failed step to resume from\", runID)\n   215→\t\t}\n   216→\t}\n   217→\n   218→\tif run.IsHost {\n   219→\t\treturn s.resumeHostRun(ctx, run, stepName)\n   220→\t}\n   221→\treturn s.resumeContainerRun(ctx, run, stepName)\n   222→}\n   223→\n   224→// resumeHostRun resumes a failed host workflow run.\n   225→func (s *ClocheServer) resumeHostRun(ctx context.Context, run *domain.Run, stepName string) (*pb.RunWorkflowResponse, error) {\n   226→\trunner := &host.Runner{\n   227→\t\tDispatcher:   s,\n   228→\t\tStore:        s.store,\n   229→\t\tCaptures:     s.captures,\n   230→\t\tLogBroadcast: s.logBroadcast,\n   231→\t\tTaskID:       run.TaskID,\n   232→\t}\n   233→\n   234→\tgo func() {\n   235→\t\trunner.ResumeRun(context.Background(), run, stepName)\n   236→\t}()\n   237→\n   238→\treturn &pb.RunWorkflowResponse{RunId: run.ID}, nil\n   239→}\n   240→\n   241→// resumeContainerRun resumes a failed container workflow run.\n   242→func (s *ClocheServer) resumeContainerRun(ctx context.Context, run *domain.Run, stepName string) (*pb.RunWorkflowResponse, error) {\n   243→\tif s.container == nil {\n   244→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   245→\t}\n   246→\n   247→\t// Verify container still exists\n   248→\tcs, err := s.container.Inspect(ctx, run.ContainerID)\n   249→\tif err != nil {\n   250→\t\treturn nil, fmt.Errorf(\"container %s not found (may have been cleaned up): %w\", run.ContainerID, err)"}]},"parent_tool_use_id":"toolu_01TqLHTKEsKF9ceU32q4Dtbq","session_id":"77daf22e-aee8-40ec-9b79-2fa0d1f74d8f","uuid":"680122f0-4bd8-4498-a08b-0bb427d9ce86"}
