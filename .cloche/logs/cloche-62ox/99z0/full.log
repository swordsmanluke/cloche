[2026-03-16T17:14:26Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VpjfCZqeA4nCTBCGLrSKHo","type":"tool_result","content":"  1036→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n  1037→\tprojectDir := req.ProjectDir\n  1038→\tif projectDir == \"\" {\n  1039→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n  1040→\t}\n  1041→\n  1042→\t// Verify at least one host workflow exists in the project.\n  1043→\thostWorkflows, err := host.FindHostWorkflows(projectDir)\n  1044→\tif err != nil || len(hostWorkflows) == 0 {\n  1045→\t\treturn nil, fmt.Errorf(\"no host workflows found in %s/.cloche/\", projectDir)\n  1046→\t}\n  1047→\n  1048→\t// Load project config for defaults.\n  1049→\tprojCfg, _ := config.Load(projectDir)\n  1050→\n  1051→\tmaxConc := int(req.MaxConcurrent)\n  1052→\tif maxConc <= 0 {\n  1053→\t\tmaxConc = projCfg.Orchestration.Concurrency\n  1054→\t}\n  1055→\tif maxConc <= 0 {\n  1056→\t\tmaxConc = 1\n  1057→\t}\n  1058→\n  1059→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n  1060→\n  1061→\t// Compute dedup timeout from config (default 5 minutes).\n  1062→\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n  1063→\n  1064→\tloopCfg := host.LoopConfig{\n  1065→\t\tProjectDir:    projectDir,\n  1066→\t\tMaxConcurrent: maxConc,\n  1067→\t\tStaggerDelay:  stagger,\n  1068→\t\tDedupTimeout:  dedupTimeout,\n  1069→\t\tStopOnError:   projCfg.Orchestration.StopOnError,\n  1070→\t}\n  1071→\n  1072→\ts.mu.Lock()\n  1073→\tdefer s.mu.Unlock()\n  1074→\n  1075→\t// Stop existing loop if running.\n  1076→\tif existing, ok := s.loops[projectDir]; ok {\n  1077→\t\texisting.Stop()\n  1078→\t}\n  1079→\n  1080→\t// Check if project defines a list-tasks workflow for three-phase mode.\n  1081→\tvar loop *host.Loop\n  1082→\tif _, hasListTasks := hostWorkflows[\"list-tasks\"]; hasListTasks {\n  1083→\t\tloop = s.createPhaseLoop(loopCfg, projectDir, dedupTimeout)\n  1084→\t} else {\n  1085→\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n  1086→\t}\n  1087→\n  1088→\ts.loops[projectDir] = loop\n  1089→\tloop.Start()\n  1090→\n  1091→\treturn &pb.EnableLoopResponse{}, nil\n  1092→}\n  1093→\n  1094→// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n  1095→// main, and finalize host workflows from any .cloche file.\n  1096→func (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir string, dedupTimeout time.Duration) *host.Loop {\n  1097→\t// Phase 1: list-tasks function\n  1098→\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n  1099→\t\trunner := &host.Runner{\n  1100→\t\t\tDispatcher: s,\n  1101→\t\t\tStore:      s.store,\n  1102→\t\t}\n  1103→\t\ttasks, _, err := host.RunListTasksWorkflow(ctx, runner, projDir)\n  1104→\t\treturn tasks, err\n  1105→\t}\n  1106→\n  1107→\t// Phase 2: main function\n  1108→\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n  1109→\t\trunner := &host.Runner{\n  1110→\t\t\tDispatcher:   s,\n  1111→\t\t\tStore:        s.store,\n  1112→\t\t\tCaptures:     s.captures,\n  1113→\t\t\tLogBroadcast: s.logBroadcast,\n  1114→\t\t\tTaskID:       taskID,\n  1115→\t\t}\n  1116→\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n  1117→\t}\n  1118→\n  1119→\t// Phase 3: finalize function (optional — only if a finalize host workflow exists)\n  1120→\tvar finalizeFn host.FinalizeFunc\n  1121→\tif hostWFs, err := host.FindHostWorkflows(projectDir); err == nil {\n  1122→\t\tif _, hasFinalize := hostWFs[\"finalize\"]; hasFinalize {\n  1123→\t\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n  1124→\t\t\t\tmainRunID := \"\"\n  1125→\t\t\t\tmainOutcome := \"failed\"\n  1126→\t\t\t\tif mainResult != nil {\n  1127→\t\t\t\t\tmainRunID = mainResult.RunID\n  1128→\t\t\t\t\tmainOutcome = string(mainResult.State)\n  1129→\t\t\t\t}\n  1130→\t\t\t\trunner := &host.Runner{\n  1131→\t\t\t\t\tDispatcher:   s,\n  1132→\t\t\t\t\tStore:        s.store,\n  1133→\t\t\t\t\tCaptures:     s.captures,\n  1134→\t\t\t\t\tLogBroadcast: s.logBroadcast,\n  1135→\t\t\t\t\tTaskID:       taskID,\n  1136→\t\t\t\t\tExtraEnv: []string{\n  1137→\t\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n  1138→\t\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n  1139→\t\t\t\t\t},\n  1140→\t\t\t\t}\n  1141→\t\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n  1142→\t\t\t}\n  1143→\t\t}\n  1144→\t}\n  1145→\n  1146→\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n  1147→\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n  1148→}\n  1149→\n  1150→// createLegacyLoop creates a legacy single-function orchestration loop.\n  1151→func (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n  1152→\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n  1153→\t\trunner := &host.Runner{\n  1154→\t\t\tDispatcher:   s,\n  1155→\t\t\tStore:        s.store,\n  1156→\t\t\tCaptures:     s.captures,\n  1157→\t\t\tLogBroadcast: s.logBroadcast,\n  1158→\t\t\tTaskID:       taskID,\n  1159→\t\t}\n  1160→\t\treturn runner.Run(ctx, projDir)\n  1161→\t}\n  1162→\n  1163→\tloop := host.NewLoop(loopCfg, s.store, runFn)\n  1164→\n  1165→\t// Configure daemon-managed task assignment if a list-tasks command is set.\n  1166→\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n  1167→\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n  1168→\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n  1169→\t}\n  1170→\n  1171→\treturn loop\n  1172→}\n  1173→\n  1174→// GetLoopTasks returns the current task pipeline state for a project's\n  1175→// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n  1176→// loop is active for the project.\n  1177→func (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n  1178→\ts.mu.Lock()\n  1179→\tloop, ok := s.loops[projectDir]\n  1180→\ts.mu.Unlock()\n  1181→\tif !ok {\n  1182→\t\treturn nil\n  1183→\t}\n  1184→\tsnapshot := loop.GetTaskSnapshot()\n  1185→\n  1186→\t// Build a set of task IDs that have active (pending/running) runs.\n  1187→\tactiveTaskIDs := make(map[string]bool)\n  1188→\tctx := context.Background()\n  1189→\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n  1190→\tfor _, r := range allRuns {\n  1191→\t\tif r.TaskID != \"\" && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n  1192→\t\t\tactiveTaskIDs[r.TaskID] = true\n  1193→\t\t}\n  1194→\t}\n  1195→\n  1196→\tentries := make([]web.TaskEntry, len(snapshot))\n  1197→\tfor i, e := range snapshot {\n  1198→\t\tentry := web.TaskEntry{\n  1199→\t\t\tID:          e.Task.ID,\n  1200→\t\t\tStatus:      e.Task.Status,\n  1201→\t\t\tTitle:       e.Task.Title,\n  1202→\t\t\tDescription: e.Task.Description,\n  1203→\t\t\tMetadata:    e.Task.Metadata,\n  1204→\t\t\tAssigned:    e.Assigned,\n  1205→\t\t\tRunID:       e.RunID,\n  1206→\t\t}\n  1207→\t\tif !e.AssignedAt.IsZero() {\n  1208→\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n  1209→\t\t}\n  1210→\t\t// Stale: task is in_progress but has no active worker.\n  1211→\t\tif host.TaskStatus(e.Task.Status) == host.TaskStatusInProgress && !activeTaskIDs[e.Task.ID] {\n  1212→\t\t\tentry.Stale = true\n  1213→\t\t}\n  1214→\t\tentries[i] = entry\n  1215→\t}\n  1216→\treturn entries\n  1217→}\n  1218→\n  1219→// ReleaseTask runs the release-task host workflow for a specific task,\n  1220→// returning it to open s