[2026-03-16T17:14:26Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TMew2xWf34ukQ9rKrnER1P","type":"tool_result","content":"   250→\t\treturn nil, fmt.Errorf(\"container %s not found (may have been cleaned up): %w\", run.ContainerID, err)\n   251→\t}\n   252→\tif cs.Running {\n   253→\t\treturn nil, fmt.Errorf(\"container %s is still running\", run.ContainerID)\n   254→\t}\n   255→\n   256→\t// Commit the container to preserve its filesystem state\n   257→\tcommitter, ok := s.container.(ports.ContainerCommitter)\n   258→\tif !ok {\n   259→\t\treturn nil, fmt.Errorf(\"container runtime does not support resume (no commit capability)\")\n   260→\t}\n   261→\n   262→\timageID, err := committer.Commit(ctx, run.ContainerID)\n   263→\tif err != nil {\n   264→\t\treturn nil, fmt.Errorf(\"committing container state: %w\", err)\n   265→\t}\n   266→\n   267→\t// Copy updated scripts and overrides from host into the committed image\n   268→\t// by starting a new container with the resume command\n   269→\tresumeCmd := []string{\n   270→\t\t\"cloche-agent\", \".cloche/\" + run.WorkflowName + \".cloche\",\n   271→\t\t\"--resume-from\", stepName,\n   272→\t}\n   273→\n   274→\t// Reset run state\n   275→\trun.State = domain.RunStateRunning\n   276→\trun.ErrorMessage = \"\"\n   277→\trun.CompletedAt = time.Time{}\n   278→\trun.ActiveSteps = nil\n   279→\t_ = s.store.UpdateRun(ctx, run)\n   280→\n   281→\t// Start new container from committed image with resume command\n   282→\tgo s.launchResumeContainer(run, imageID, resumeCmd)\n   283→\n   284→\treturn &pb.RunWorkflowResponse{RunId: run.ID}, nil\n   285→}\n   286→\n   287→// launchResumeContainer starts a new container from a committed image with\n   288→// the resume command, then tracks it to completion.\n   289→func (s *ClocheServer) launchResumeContainer(run *domain.Run, image string, cmd []string) {\n   290→\tctx := context.Background()\n   291→\n   292→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   293→\t\tImage:        image,\n   294→\t\tWorkflowName: run.WorkflowName,\n   295→\t\tProjectDir:   run.ProjectDir,\n   296→\t\tRunID:        run.ID,\n   297→\t\tNetworkAllow: []string{\"*\"},\n   298→\t\tCmd:          cmd,\n   299→\t})\n   300→\tif err != nil {\n   301→\t\trun.Fail(fmt.Sprintf(\"failed to start resume container: %v\", err))\n   302→\t\t_ = s.store.UpdateRun(ctx, run)\n   303→\t\tlog.Printf(\"run %s: failed to start resume container: %v\", run.ID, err)\n   304→\t\treturn\n   305→\t}\n   306→\n   307→\ts.mu.Lock()\n   308→\ts.runIDs[run.ID] = containerID\n   309→\ts.mu.Unlock()\n   310→\n   311→\trun.ContainerID = containerID\n   312→\t_ = s.store.UpdateRun(ctx, run)\n   313→\n   314→\ts.trackRun(run.ID, containerID, run.ProjectDir, run.WorkflowName, true)\n   315→}\n   316→\n   317→// launchAndTrack starts the container and then tracks it to completion.\n   318→// It runs in a background goroutine with its own context, independent of the\n   319→// RPC context which may be cancelled after RunWorkflow returns.\n   320→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   321→\tctx := context.Background()\n   322→\n   323→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   324→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   325→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   326→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   327→\t\t\tif run != nil {\n   328→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   329→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   330→\t\t\t}\n   331→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   332→\t\t\t\treturn\n   333→\t\t}\n   334→\t}\n   335→\n   336→\tbaseSHA := gitHEAD(req.ProjectDir)\n   337→\n   338→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   339→\t\tImage:        image,\n   340→\t\tWorkflowName: req.WorkflowName,\n   341→\t\tProjectDir:   req.ProjectDir,\n   342→\t\tRunID:        runID,\n   343→\t\tNetworkAllow: []string{\"*\"},\n   344→\t})\n   345→\tif err != nil {\n   346→\t\trun, _ := s.store.GetRun(ctx, runID)\n   347→\t\tif run != nil {\n   348→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   349→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   350→\t\t}\n   351→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   352→\t\treturn\n   353→\t}\n   354→\n   355→\ts.mu.Lock()\n   356→\ts.runIDs[runID] = containerID\n   357→\ts.mu.Unlock()\n   358→\n   359→\trun, _ := s.store.GetRun(ctx, runID)\n   360→\tif run != nil {\n   361→\t\trun.Start()\n   362→\t\trun.ContainerID = containerID\n   363→\t\trun.BaseSHA = baseSHA\n   364→\t\t_ = s.store.UpdateRun(ctx, run)\n   365→\t}\n   366→\n   367→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   368→}\n   369→\n   370→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   371→\tctx := context.Background()\n   372→\n   373→\t// Attach to agent output\n   374→\treader, err := s.container.AttachOutput(ctx, containerID)\n   375→\tif err != nil {\n   376→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   377→\t\t\treturn\n   378→\t}\n   379→\n   380→\t// Parse JSON-lines status messages\n   381→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   382→\tvar reportedError string  // captured from MsgError, used to set ErrorMessage on failed runs\n   383→\tscanner := bufio.NewScanner(reader)\n   384→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   385→\tfor scanner.Scan() {\n   386→\t\tvar msg protocol.StatusMessage\n   387→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   388→\t\t\tcontinue\n   389→\t\t}\n   390→\n   391→\t\t// Fast path: log messages don't need store interaction.\n   392→\t\tif msg.Type == protocol.MsgLog {\n   393→\t\t\tif s.logBroadcast != nil {\n   394→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   395→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   396→\t\t\t\t\tType:      \"llm\",\n   397→\t\t\t\t\tContent:   msg.Message,\n   398→\t\t\t\t\tStepName:  msg.StepName,\n   399→\t\t\t\t})\n   400→\t\t\t}\n   401→\t\t\tcontinue\n   402→\t\t}\n   403→\n   404→\t\trun, err := s.store.GetRun(ctx, runID)\n   405→\t\tif err != nil {\n   406→\t\t\tcontinue\n   407→\t\t}\n   408→\n   409→\t\tswitch msg.Type {\n   410→\t\tcase protocol.MsgStepStarted:\n   411→\t\t\trun.RecordStepStart(msg.StepName)\n   412→\t\t\tif s.captures != nil {\n   413→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   414→\t\t\t\t\tStepName:  msg.StepName,\n   415→\t\t\t\t\tStartedAt: msg.Timestamp,\n   416→\t\t\t\t})\n   417→\t\t\t}\n   418→\t\t\tif s.logBroadcast != nil {\n   419→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   420→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   421→\t\t\t\t\tType:      \"status\",\n   422→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   423→\t\t\t\t\tStepName:  msg.StepName,\n   424→\t\t\t\t})\n   425→\t\t\t}\n   426→\t\tcase protocol.MsgStepCompleted:\n   427→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   428→\t\t\tif s.captures != nil {\n   429→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   430→\t\t\t\t\tStepName:    msg.StepName,\n   431→\t\t\t\t\tResult:      msg.Result,\n   432→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   433→\t\t\t\t})\n   434→\t\t\t}\n   435→\t\t\tif s.logBroadcast != nil {\n   436→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   437→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   438→\t\t\t\t\tType:      \"status\",\n   439→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   440→\t\t\t\t\tStepName:  msg.StepName,\n   441→\t\t\t\t})\n   442→\t\t\t}\n   443→\t\tcase protocol.MsgRunTitle:\n   444→\t\t\tif run.Title == \"\" {\n   445→\t\t\t\trun.Title = msg.Message\n   446→\t\t\t}\n   447→\t\tcase protocol.MsgError:\n   448→\t\t\treportedError = msg.Message\n   449→\t\t\tcontinue // Don't persist; used during finalization\n   450→\t\tcase protocol.MsgRunCompleted:\n   451→\t\t\treportedResult = msg.Result\n   452→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   453→\t\t}\n   454→\n   455→\t\t_ = s.store.UpdateRun(ctx, run)\n   456→\t}\n   457→\treader.Close()\n   458→\n   459→\t// Signal live-stream subscribers that this run is done.\n   460→\tif s.logBroadcast != nil {\n   461→\t\ts.logBroadcast.Finish(runID)\n   462→\t}\n   463→\n   464→\t// Wait for process exit\n   465→\texitCode, err := s.container.Wait(ctx, containerID)\n   466→\tif err != nil {\n   467→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   468→\t}\n   469→\n   470→\t// Extract step output files from container before it's removed\n   471→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   472→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   473→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   474→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   475→\t\t}\n   476→\t}\n   477→\n   478→\t// Capture full container stdout/stderr before the container is removed\n   479→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   480→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   481→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   482→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   483→\t\t}\n   484→\t}\n   485→\n   486→\t// Index extracted log files in the log store\n   487→\tif s.logStore != nil {\n   488→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   489→\t}\n   490→\n   491→\t// Extract results to git branch BEFORE finalizing state, so that\n   492→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   493→\t// before the run is marked complete.\n   494→\tresultLabel := reportedResult\n   495→\tif resultLabel == \"\" {\n   496→\t\tif exitCode == 0 {\n   497→\t\t\tresultLabel = \"succeeded\"\n   498→\t\t} else {\n   499→\t\t\tresultLabel = \"failed\"\n   500→\t\t}\n   501→\t}\n   502→\t{\n   503→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   504→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   505→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   506→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   507→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   508→\t\t\t} else {\n   509→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   510→\t\t\t}\n   511→\t\t} else {\n   512→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   513→\t\t}\n   514→\t}\n   515→\n   516→\t// Now finalize run state\n   517→\trun, err := s.store.GetRun(ctx, runID)\n   518→\tif err != nil {\n   519→\t\treturn\n   520→\t}\n   521→\tif run.State == domain.RunStateRunning {\n   522→\t\tif reportedResult == \"succeeded\" {\n   523→\t\t\trun.Complete(domain.RunStateSucceeded)\n   524→\t\t} else if reportedResult != \"\" {\n   525→\t\t\tif reportedError != \"\" {\n   526→\t\t\t\trun.Fail(reportedError)\n   527→\t\t\t} else {\n   528→\t\t\t\trun.Complete(domain.RunStateFailed)\n   529→\t\t\t}\n   530→\t\t} else if exitCode == 0 {\n   531→\t\t\trun.Complete(domain.RunStateSucceeded)\n   532→\t\t} else {\n   533→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   534→\t\t}\n   535→\t\t_ = s.store.UpdateRun(ctx, run)\n   536→\t}\n   537→\n   538→\t// Fire evolution trigger if configured\n   539→\tif s.evolution != nil {\n   540→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   541→\t}\n   542→\n   543→\t// Merge is handled as a workflow step in host.cloche, not here.\n   544→\n   545→\t// Container retention policy:\n   546→\t// - Failed runs: always keep the container for debugging\n   547→\t// - Successful runs + --keep-container: keep the container\n   548→\t// - Successful runs without --keep-container: remove the container\n   549→\trunFinal, _ := s.store.GetRun(ctx, runID)"}]},"parent_tool_use_id":"toolu_01TqLHTKEsKF9ceU32q4Dtbq","session_id":"77daf22e-aee8-40ec-9b79-2fa0d1f74d8f","uuid":"d23415ea-f82b-4e69-8382-ec8623f9197e"}
