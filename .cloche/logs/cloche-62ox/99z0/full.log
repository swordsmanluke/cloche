[2026-03-16T17:14:26Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017SR35rLnsmUMGgzHCgDEA2","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"sync\"\n    10→\t\"time\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14→)\n    15→\n    16→const (\n    17→\tdefaultMaxConcurrent = 1\n    18→\tdefaultDedupTimeout  = 5 * time.Minute\n    19→\tidlePollInterval     = 2 * time.Minute\n    20→\tcapacityPollInterval = 30 * time.Second\n    21→)\n    22→\n    23→// LoopConfig holds configuration for an orchestration loop.\n    24→type LoopConfig struct {\n    25→\tProjectDir    string\n    26→\tMaxConcurrent int\n    27→\tStaggerDelay  time.Duration // delay between launching consecutive runs\n    28→\tDedupTimeout  time.Duration // how long to suppress reassignment of the same task ID\n    29→\tStopOnError   bool          // halt loop on unrecovered error (allow in-flight work to finish)\n    30→}\n    31→\n    32→// ListTasksFunc is called to discover available tasks. It should run the\n    33→// list-tasks workflow (or equivalent) and return the parsed tasks.\n    34→type ListTasksFunc func(ctx context.Context, projectDir string) ([]Task, error)\n    35→\n    36→// MainFunc is called to execute the main workflow for a given task.\n    37→type MainFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n    38→\n    39→// FinalizeFunc is called after the main workflow completes (both success and\n    40→// failure). It receives the task ID and the outcome of the main phase.\n    41→type FinalizeFunc func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error)\n    42→\n    43→// RunFunc is the legacy function signature for launching a host workflow run.\n    44→// When taskID is non-empty, the runner should propagate it as CLOCHE_TASK_ID.\n    45→type RunFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n    46→\n    47→// TaskAssignment tracks the assignment state of a task.\n    48→type TaskAssignment struct {\n    49→\tAssignedAt time.Time\n    50→\tRunID      string // run ID handling this task (set after main completes)\n    51→}\n    52→\n    53→// TaskStateEntry combines a task with its assignment state.\n    54→type TaskStateEntry struct {\n    55→\tTask       Task\n    56→\tAssigned   bool\n    57→\tAssignedAt time.Time\n    58→\tRunID      string // empty if not yet known\n    59→}\n    60→\n    61→// Loop manages a continuous orchestration loop for a project, keeping up to\n    62→// MaxConcurrent host workflow runs active at all times when work is available.\n    63→//\n    64→// When configured with three-phase functions (list-tasks, main, finalize), the\n    65→// loop discovers tasks via list-tasks, picks open ones, runs main for each, and\n    66→// then runs finalize on completion. When configured with a legacy RunFunc, it\n    67→// falls back to the single-function approach.\n    68→type Loop struct {\n    69→\tconfig     LoopConfig\n    70→\tlistTasks  ListTasksFunc\n    71→\tmainFn     MainFunc\n    72→\tfinalizeFn FinalizeFunc // optional; skipped if nil\n    73→\trunner     RunFunc      // legacy single-function mode\n    74→\tstore      ports.RunStore\n    75→\tassigner   TaskAssigner // optional; legacy task assignment\n    76→\tstopCh     chan struct{}\n    77→\tresumeCh   chan struct{} // signaled by Resume() to wake the loop\n    78→\tmu         sync.Mutex\n    79→\trunning    bool\n    80→\thaltedMu   sync.RWMutex\n    81→\thalted     bool   // true when loop is halted due to an unrecovered error\n    82→\thaltError  string // the error message that caused the halt\n    83→\tdedupMu    sync.Mutex\n    84→\tdedup      map[string]time.Time // task ID -> last assignment time\n    85→\ttasksMu    sync.RWMutex\n    86→\tlastTasks  []Task                    // most recently fetched tasks\n    87→\ttaskRuns   map[string]TaskAssignment // task ID -> assignment info\n    88→}\n    89→\n    90→// NewLoop creates an orchestration loop using a single run function (legacy mode).\n    91→// For three-phase orchestration, use NewPhaseLoop instead.\n    92→func NewLoop(cfg LoopConfig, store ports.RunStore, runFn RunFunc) *Loop {\n    93→\tif cfg.MaxConcurrent <= 0 {\n    94→\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n    95→\t}\n    96→\tif cfg.DedupTimeout <= 0 {\n    97→\t\tcfg.DedupTimeout = defaultDedupTimeout\n    98→\t}\n    99→\treturn &Loop{\n   100→\t\tconfig:   cfg,\n   101→\t\trunner:   runFn,\n   102→\t\tstore:    store,\n   103→\t\tresumeCh: make(chan struct{}, 1),\n   104→\t\tdedup:    make(map[string]time.Time),\n   105→\t\ttaskRuns: make(map[string]TaskAssignment),\n   106→\t}\n   107→}\n   108→\n   109→// NewPhaseLoop creates a three-phase orchestration loop. The listTasksFn\n   110→// discovers available tasks, mainFn executes the main workflow for a task,\n   111→// and finalizeFn (optional) runs cleanup after main completes.\n   112→func NewPhaseLoop(cfg LoopConfig, store ports.RunStore, listTasksFn ListTasksFunc, mainFn MainFunc, finalizeFn FinalizeFunc) *Loop {\n   113→\tif cfg.MaxConcurrent <= 0 {\n   114→\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n   115→\t}\n   116→\tif cfg.DedupTimeout <= 0 {\n   117→\t\tcfg.DedupTimeout = defaultDedupTimeout\n   118→\t}\n   119→\treturn &Loop{\n   120→\t\tconfig:     cfg,\n   121→\t\tlistTasks:  listTasksFn,\n   122→\t\tmainFn:     mainFn,\n   123→\t\tfinalizeFn: finalizeFn,\n   124→\t\tstore:      store,\n   125→\t\tresumeCh:   make(chan struct{}, 1),\n   126→\t\tdedup:      make(map[string]time.Time),\n   127→\t\ttaskRuns:   make(map[string]TaskAssignment),\n   128→\t}\n   129→}\n   130→\n   131→// SetTaskAssigner configures a TaskAssigner for daemon-managed task assignment.\n   132→// Only used in legacy (single RunFunc) mode when no list-tasks function is set.\n   133→func (l *Loop) SetTaskAssigner(a TaskAssigner) {\n   134→\tl.assigner = a\n   135→}\n   136→\n   137→// Start begins the orchestration loop. No-op if already running.\n   138→func (l *Loop) Start() {\n   139→\tl.mu.Lock()\n   140→\tdefer l.mu.Unlock()\n   141→\tif l.running {\n   142→\t\treturn\n   143→\t}\n   144→\tl.running = true\n   145→\tl.stopCh = make(chan struct{})\n   146→\tgo l.run()\n   147→\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n   148→}\n   149→\n   150→// Stop signals the loop to stop. Active runs continue to completion.\n   151→func (l *Loop) Stop() {\n   152→\tl.mu.Lock()\n   153→\tdefer l.mu.Unlock()\n   154→\tif !l.running {\n   155→\t\treturn\n   156→\t}\n   157→\tl.running = false\n   158→\tclose(l.stopCh)\n   159→\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n   160→}\n   161→\n   162→// Running returns whether the loop is currently active.\n   163→func (l *Loop) Running() bool {\n   164→\tl.mu.Lock()\n   165→\tdefer l.mu.Unlock()\n   166→\treturn l.running\n   167→}\n   168→\n   169→// Halted returns whether the loop is halted due to an unrecovered error,\n   170→// along with the error message that caused the halt. When halted, the loop\n   171→// is still running but will not pick up new work.\n   172→func (l *Loop) Halted() (bool, string) {\n   173→\tl.haltedMu.RLock()\n   174→\tdefer l.haltedMu.RUnlock()\n   175→\treturn l.halted, l.haltError\n   176→}\n   177→\n   178→// Resume clears the halted state so the loop resumes picking up new work.\n   179→func (l *Loop) Resume() {\n   180→\tl.haltedMu.Lock()\n   181→\tdefer l.haltedMu.Unlock()\n   182→\tif l.halted {\n   183→\t\tlog.Printf(\"orchestration loop: resumed for %s (was halted: %s)\", l.config.ProjectDir, l.haltError)\n   184→\t\tl.halted = false\n   185→\t\tl.haltError = \"\"\n   186→\t\t// Wake the loop from any sleep so it picks up work immediately.\n   187→\t\tselect {\n   188→\t\tcase l.resumeCh <- struct{}{}:\n   189→\t\tdefault:\n   190→\t\t}\n   191→\t}\n   192→}\n   193→\n   194→// halt sets the loop into halted state with the given error message.\n   195→func (l *Loop) halt(errMsg string) {\n   196→\tl.haltedMu.Lock()\n   197→\tdefer l.haltedMu.Unlock()\n   198→\tl.halted = true\n   199→\tl.haltError = errMsg\n   200→\tlog.Printf(\"orchestration loop: halted for %s (stop_on_error): %s\", l.config.ProjectDir, errMsg)\n   201→}\n   202→\n   203→// isHalted returns true if the loop is currently halted.\n   204→func (l *Loop) isHalted() bool {\n   205→\tl.haltedMu.RLock()\n   206→\tdefer l.haltedMu.RUnlock()\n   207→\treturn l.halted\n   208→}\n   209→\n   210→func (l *Loop) run() {\n   211→\tif l.listTasks != nil && l.mainFn != nil {\n   212→\t\tl.runPhased()\n   213→\t} else {\n   214→\t\tl.runLegacy()\n   215→\t}\n   216→}\n   217→\n   218→// runPhased implements the three-phase orchestration loop:\n   219→// 1. list-tasks → discover available work\n   220→// 2. main → execute work for each open task (up to MaxConcurrent)\n   221→// 3. finalize → cleanup after main completes (on both success and failure)\n   222→func (l *Loop) runPhased() {\n   223→\ttype result struct {\n   224→\t\tstate  domain.RunState\n   225→\t\terrMsg string\n   226→\t}\n   227→\n   228→\tcompletions := make(chan result, l.config.MaxConcurrent)\n   229→\tinFlight := 0\n   230→\n   231→\tfor {\n   232→\t\t// Fill up to max concurrent slots.\n   233→\t\tlaunched := 0\n   234→\t\tfor inFlight < l.config.MaxConcurrent {\n   235→\t\t\tselect {\n   236→\t\t\tcase <-l.stopCh:\n   237→\t\t\t\treturn\n   238→\t\t\tdefault:\n   239→\t\t\t}\n   240→\n   241→\t\t\t// If halted, don't pick up new work.\n   242→\t\t\tif l.isHalted() {\n   243→\t\t\t\tbreak\n   244→\t\t\t}\n   245→\n   246→\t\t\t// Check how many host runs are active for this project.\n   247→\t\t\tactive := l.countActiveHostRuns()\n   248→\t\t\tif active >= l.config.MaxConcurrent {\n   249→\t\t\t\tbreak\n   250→\t\t\t}\n   251→\n   252→\t\t\t// Stagger consecutive launches.\n   253→\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   254→\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   255→\t\t\t\t\treturn\n   256→\t\t\t\t}\n   257→\t\t\t}\n   258→\n   259→\t\t\t// Phase 1: list-tasks — discover available work.\n   260→\t\t\ttaskID, ok := l.pickTaskFromPhase()\n   261→\t\t\tif !ok {\n   262→\t\t\t\tbreak // no assignable tasks\n   263→\t\t\t}\n   264→\n   265→\t\t\t// Launch main + finalize in a goroutine.\n   266→\t\t\tinFlight++\n   267→\t\t\tlaunched++\n   268→\t\t\ttid := taskID\n   269→\t\t\tgo func() {\n   270→\t\t\t\t// Phase 2: main — do the work.\n   271→\t\t\t\tmainResult, err := l.mainFn(context.Background(), l.config.ProjectDir, tid)\n   272→\t\t\t\tif err != nil {\n   273→\t\t\t\t\tlog.Printf(\"orchestration loop: main failed for %s task %s: %v\", l.config.ProjectDir, tid, err)\n   274→\t\t\t\t\tif mainResult == nil {\n   275→\t\t\t\t\t\tmainResult = &RunResult{State: domain.RunStateFailed}\n   276→\t\t\t\t\t}\n   277→\t\t\t\t}\n   278→\n   279→\t\t\t\t// Track the run ID for this task.\n   280→\t\t\t\tif mainResult != nil && mainResult.RunID != \"\" {\n   281→\t\t\t\t\tl.tasksMu.Lock()\n   282→\t\t\t\t\tl.taskRuns[tid] = TaskAssignment{\n   283→\t\t\t\t\t\tAssignedAt: time.Now(),\n   284→\t\t\t\t\t\tRunID:      mainResult.RunID,\n   285→\t\t\t\t\t}\n   286→\t\t\t\t\tl.tasksMu.Unlock()\n   287→\t\t\t\t}\n   288→\n   289→\t\t\t\t// Phase 3: finalize — cleanup (runs on both success and failure).\n   290→\t\t\t\t// The overall state is the worst of main and finalize outcomes.\n   291→\t\t\t\toverallState := mainResult.State\n   292→\t\t\t\tif l.finalizeFn != nil {\n   293→\t\t\t\t\tfinalizeResult, finalizeErr := l.finalizeFn(context.Background(), l.config.ProjectDir, tid, mainResult)\n   294→\t\t\t\t\tif finalizeErr != nil {\n   295→\t\t\t\t\t\tlog.Printf(\"orchestration loop: finalize failed for %s task %s: %v\", l.config.ProjectDir, tid, finalizeErr)\n   296→\t\t\t\t\t\toverallState = domain.WorseState(overallState, domain.RunStateFailed)\n   297→\t\t\t\t\t} else if finalizeResult != nil {\n   298→\t\t\t\t\t\toverallState = domain.WorseState(overallState, finalizeResult.State)\n   299→\t\t\t\t\t}\n   300→\t\t\t\t}\n   301→\n   302→\t\t\t\tcompletions <- result{state: overallState, errMsg: fmt.Sprintf(\"task %s failed\", tid)}\n   303→\t\t\t}()\n   304→\t\t}\n   305→\n   306→\t\tif inFlight == 0 {\n   307→\t\t\t// Nothing in flight and couldn't launch anything — wait before checking again.\n   308→\t\t\tif !l.sleep(capacityPollInterval) {\n   309→\t\t\t\treturn\n   310→\t\t\t}\n   311→\t\t\tcontinue\n   312→\t\t}\n   313→\n   314→\t\t// Wait for any run to complete.\n   315→\t\tselect {\n   316→\t\tcase r := <-completions:\n   317→\t\t\tinFlight--\n   318→\t\t\tif r.state == domain.RunStateSucceeded {\n   319→\t\t\t\t// Work was done — try to fill slots immediately.\n   320→\t\t\t\tcontinue\n   321→\t\t\t}\n   322→\t\t\t// Run failed or aborted.\n   323→\t\t\tif l.config.StopOnError {\n   324→\t\t\t\tl.halt(r.errMsg)\n   325→\t\t\t}\n   326→\t\t\t// Back off.\n   327→\t\t\tif !l.sleep(idlePollInterval) {\n   328→\t\t\t\treturn\n   329→\t\t\t}\n   330→\t\tcase <-l.stopCh:\n   331→\t\t\treturn\n   332→\t\t}\n   333→\t}\n   334→}\n   335→\n   336→// GetTaskSnapshot returns the current task pipeline state: the most recently\n   337→// fetched tasks with their assignment information.\n   338→func (l *Loop) GetTaskSnapshot() []TaskStateEntry {\n   339→\tl.tasksMu.RLock()\n   340→\ttasks := make([]Task, len(l.lastTasks))\n   341→\tcopy(tasks, l.lastTasks)\n   342→\tl.tasksMu.RUnlock()\n   343→\n   344→\tl.dedupMu.Lock()\n   345→\tdefer l.dedupMu.Unlock()\n   346→\n   347→\tnow := time.Now()\n   348→\tvar entries []TaskStateEntry\n   349→\tfor _, task := range tasks {\n   350→\t\tentry := TaskStateEntry{Task: task}\n   351→\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   352→\t\t\tentry.Assigned = true\n   353→\t\t\tentry.AssignedAt = ts\n   354→\t\t}\n   355→\n   356→\t\tl.tasksMu.RLock()\n   357→\t\tif a, ok := l.taskRuns[task.ID]; ok {\n   358→\t\t\tentry.RunID = a.RunID\n   359→\t\t\tif !entry.Assigned {\n   360→\t\t\t\tentry.AssignedAt = a.AssignedAt\n   361→\t\t\t}\n   362→\t\t}\n   363→\t\tl.tasksMu.RUnlock()\n   364→\n   365→\t\tentries = append(entries, entry)\n   366→\t}\n   367→\treturn entries\n   368→}\n   369→\n   370→// pickTaskFromPhase runs the list-tasks function and picks the first open,\n   371→// non-deduped task.\n   372→func (l *Loop) pickTaskFromPhase() (string, bool) {\n   373→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   374→\tdefer cancel()\n   375→\n   376→\ttasks, err := l.listTasks(ctx, l.config.ProjectDir)\n   377→\tif err != nil {\n   378→\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n   379→\t\treturn \"\", false\n   380→\t}\n   381→\n   382→\t// Cache the latest tasks for snapshot queries.\n   383→\tl.tasksMu.Lock()\n   384→\tl.lastTasks = tasks\n   385→\tl.tasksMu.Unlock()\n   386→\n   387→\tnow := time.Now()\n   388→\tl.dedupMu.Lock()\n   389→\tdefer l.dedupMu.Unlock()\n   390→\n   391→\t// Expire old dedup entries.\n   392→\tfor id, ts := range l.dedup {\n   393→\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n   394→\t\t\tdelete(l.dedup, id)\n   395→\t\t}\n   396→\t}\n   397→\n   398→\tfor _, task := range tasks {\n   399→\t\tif task.ID == \"\" {\n   400→\t\t\tcontinue\n   401→\t\t}\n   402→\t\tif !task.IsOpen() {\n   403→\t\t\tcontinue\n   404→\t\t}\n   405→\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   406→\t\t\tcontinue\n   407→\t\t}\n   408→\t\tl.dedup[task.ID] = now\n   409→\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n   410→\t\treturn task.ID, true\n   411→\t}\n   412→\n   413→\treturn \"\", false\n   414→}\n   415→\n   416→// runLegacy implements the original single-function orchestration loop.\n   417→func (l *Loop) runLegacy() {\n   418→\ttype result struct {\n   419→\t\tstate  domain.RunState\n   420→\t\terrMsg string\n   421→\t}\n   422→\n   423→\tcompletions := make(chan result, l.config.MaxConcurrent)\n   424→\tinFlight := 0\n   425→\n   426→\tfor {\n   427→\t\t// Fill up to max concurrent slots.\n   428→\t\tlaunched := 0\n   429→\t\tfor inFlight < l.config.MaxConcurrent {\n   430→\t\t\tselect {\n   431→\t\t\tcase <-l.stopCh:\n   432→\t\t\t\treturn\n   433→\t\t\tdefault:\n   434→\t\t\t}\n   435→\n   436→\t\t\t// If halted, don't pick up new work.\n   437→\t\t\tif l.isHalted() {\n   438→\t\t\t\tbreak\n   439→\t\t\t}\n   440→\n   441→\t\t\t// Check how many host runs are active for this project (in case of\n   442→\t\t\t// leftover runs from previous loops).\n   443→\t\t\tactive := l.countActiveHostRuns()\n   444→\t\t\tif active >= l.config.MaxConcurrent {\n   445→\t\t\t\tbreak\n   446→\t\t\t}\n   447→\n   448→\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n   449→\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   450→\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   451→\t\t\t\t\treturn\n   452→\t\t\t\t}\n   453→\t\t\t}\n   454→\n   455→\t\t\t// Determine task ID (if task assigner is configured).\n   456→\t\t\ttaskID := \"\"\n   457→\t\t\tif l.assigner != nil {\n   458→\t\t\t\tvar ok bool\n   459→\t\t\t\ttaskID, ok = l.pickTask()\n   460→\t\t\t\tif !ok {\n   461→\t\t\t\t\t// No assignable tasks available.\n   462→\t\t\t\t\tbreak\n   463→\t\t\t\t}\n   464→\t\t\t}\n   465→\n   466→\t\t\t// Launch a new orchestration run in a goroutine.\n   467→\t\t\tinFlight++\n   468→\t\t\tlaunched++\n   469→\t\t\ttid := taskID // capture for goroutine\n   470→\t\t\tgo func() {\n   471→\t\t\t\tres, err := l.runner(context.Background(), l.config.ProjectDir, tid)\n   472→\t\t\t\tif err != nil {\n   473→\t\t\t\t\tlog.Printf(\"orchestration loop: run failed for %s: %v\", l.config.ProjectDir, err)\n   474→\t\t\t\t\tcompletions <- result{state: domain.RunStateFailed, errMsg: err.Error()}\n   475→\t\t\t\t\treturn\n   476→\t\t\t\t}\n   477→\t\t\t\tif res.State != domain.RunStateSucceeded {\n   478→\t\t\t\t\tcompletions <- result{state: res.State, errMsg: \"run failed with state \" + string(res.State)}\n   479→\t\t\t\t\treturn\n   480→\t\t\t\t}\n   481→\t\t\t\tcompletions <- result{state: res.State}\n   482→\t\t\t}()\n   483→\t\t}\n   484→\n   485→\t\tif inFlight == 0 {\n   486→\t\t\t// Nothing in flight and at capacity — wait before checking again.\n   487→\t\t\tif !l.sleep(capacityPollInterval) {\n   488→\t\t\t\treturn\n   489→\t\t\t}\n   490→\t\t\tcontinue\n   491→\t\t}\n   492→\n   493→\t\t// Wait for any run to complete.\n   494→\t\tselect {\n   495→\t\tcase r := <-completions:\n   496→\t\t\tinFlight--\n   497→\t\t\tif r.state == domain.RunStateSucceeded {\n   498→\t\t\t\t// Work was done — try to fill slots immediately.\n   499→\t\t\t\tcontinue\n   500→\t\t\t}\n   501→\t\t\t// Run failed or aborted (no tasks available).\n   502→\t\t\tif l.config.StopOnError {\n   503→\t\t\t\tl.halt(r.errMsg)\n   504→\t\t\t}\n   505→\t\t\t// Back off.\n   506→\t\t\tif !l.sleep(idlePollInterval) {\n   507→\t\t\t\treturn\n   508→\t\t\t}\n   509→\t\tcase <-l.stopCh:\n   510→\t\t\treturn\n   511→\t\t}\n   512→\t}\n   513→}\n   514→\n   515→// pickTask queries the task assigner for available tasks, filters out those\n   516→// within the dedup timeout window, and returns the first assignable task ID.\n   517→// It records the assignment time so the same task won't be picked again until\n   518→// the dedup timeout expires. Returns (\"\", false) if no tasks are available.\n   519→func (l *Loop) pickTask() (string, bool) {\n   520→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   521→\tdefer cancel()\n   522→\n   523→\ttasks, err := l.assigner.ListTasks(ctx, l.config.ProjectDir)\n   524→\tif err != nil {\n   525→\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n   526→\t\treturn \"\", false\n   527→\t}\n   528→\n   529→\t// Cache the latest tasks for snapshot queries.\n   530→\tl.tasksMu.Lock()\n   531→\tl.lastTasks = tasks\n   532→\tl.tasksMu.Unlock()\n   533→\n   534→\tnow := time.Now()\n   535→\tl.dedupMu.Lock()\n   536→\tdefer l.dedupMu.Unlock()\n   537→\n   538→\t// Expire old dedup entries while we're here.\n   539→\tfor id, ts := range l.dedup {\n   540→\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n   541→\t\t\tdelete(l.dedup, id)\n   542→\t\t}\n   543→\t}\n   544→\n   545→\tfor _, task := range tasks {\n   546→\t\tif task.ID == \"\" {\n   547→\t\t\tcontinue\n   548→\t\t}\n   549→\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   550→\t\t\tcontinue // still within dedup window\n   551→\t\t}\n   552→\t\t// Assign this task.\n   553→\t\tl.dedup[task.ID] = now\n   554→\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n   555→\t\treturn task.ID, true\n   556→\t}\n   557→\n   558→\treturn \"\", false\n   559→}\n   560→\n   561→// countActiveHostRuns counts running or pending host runs for the project.\n   562→func (l *Loop) countActiveHostRuns() int {\n   563→\tctx := context.Background()\n   564→\truns, err := l.store.ListRunsByProject(ctx, l.config.ProjectDir, time.Time{})\n   565→\tif err != nil {\n   566→\t\treturn 0\n   567→\t}\n   568→\tcount := 0\n   569→\tfor _, r := range runs {\n   570→\t\tif r.IsHost && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n   571→\t\t\tcount++\n   572→\t\t}\n   573→\t}\n   574→\treturn count\n   575→}\n   576→\n   577→// sleep waits for the given duration or until the loop is stopped or resumed.\n   578→// Returns false if the loop was stopped.\n   579→func (l *Loop) sleep(d time.Duration) bool {\n   580→\tselect {\n   581→\tcase <-time.After(d):\n   582→\t\treturn true\n   583→\tcase <-l.resumeCh:\n   584→\t\treturn true\n   585→\tcase <-l.stopCh:\n   586→\t\treturn false\n   587→\t}\n   588→}\n   589→\n   590→// ReadListTasksOutput reads the output directory from a list-tasks workflow run\n   591→// and parses JSONL task output from the last step's output file.\n   592→func ReadListTasksOutput(outputDir string) ([]Task, error) {\n   593→\tentries, err := os.ReadDir(outputDir)\n   594→\tif err != nil {\n   595→\t\treturn nil, fmt.Errorf(\"reading list-tasks output dir: %w\", err)\n   596→\t}\n   597→\n   598→\t// Find the most recently modified .out file.\n   599→\tvar latest string\n   600→\tvar latestMod time.Time\n   601→\tfor _, e := range entries {\n   602→\t\tif e.IsDir() || filepath.Ext(e.Name()) != \".out\" {\n   603→\t\t\tcontinue\n   604→\t\t}\n   605→\t\tinfo, err := e.Info()\n   606→\t\tif err != nil {\n   607→\t\t\tcontinue\n   608→\t\t}\n   609→\t\tif latest == \"\" || info.ModTime().After(latestMod) {\n   610→\t\t\tlatest = e.Name()\n   611→\t\t\tlatestMod = info.ModTime()\n   612→\t\t}\n   613→\t}\n   614→\n   615→\tif latest == \"\" {\n   616→\t\treturn nil, fmt.Errorf(\"no output files found in %s\", outputDir)\n   617→\t}\n   618→\n   619→\tdata, err := os.ReadFile(filepath.Join(outputDir, latest))\n   620→\tif err != nil {\n   621→\t\treturn nil, fmt.Errorf(\"reading output file %s: %w\", latest, err)\n   622→\t}\n   623→\n   624→\treturn ParseTasksJSONL(string(data))\n   625→}\n   626→"}]},"parent_tool_use_id":null,"session_id":"77daf22e-aee8-40ec-9b79-2fa0d1f74d8f","uuid":"63d0d7d5-91d0-455c-bbb6-73b3d0eb0d9c","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/loop.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\nconst (\n\tdefaultMaxConcurrent = 1\n\tdefaultDedupTimeout  = 5 * time.Minute\n\tidlePollInterval     = 2 * time.Minute\n\tcapacityPollInterval = 30 * time.Second\n)\n\n// LoopConfig holds configuration for an orchestration loop.\ntype LoopConfig struct {\n\tProjectDir    string\n\tMaxConcurrent int\n\tStaggerDelay  time.Duration // delay between launching consecutive runs\n\tDedupTimeout  time.Duration // how long to suppress reassignment of the same task ID\n\tStopOnError   bool          // halt loop on unrecovered error (allow in-flight work to finish)\n}\n\n// ListTasksFunc is called to discover available tasks. It should run the\n// list-tasks workflow (or equivalent) and return the parsed tasks.\ntype ListTasksFunc func(ctx context.Context, projectDir string) ([]Task, error)\n\n// MainFunc is called to execute the main workflow for a given task.\ntype MainFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n\n// FinalizeFunc is called after the main workflow completes (both success and\n// failure). It receives the task ID and the outcome of the main phase.\ntype FinalizeFunc func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error)\n\n// RunFunc is the legacy function signature for launching a host workflow run.\n// When taskID is non-empty, the runner should propagate it as CLOCHE_TASK_ID.\ntype RunFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n\n// TaskAssignment tracks the assignment state of a task.\ntype TaskAssignment struct {\n\tAssignedAt time.Time\n\tRunID      string // run ID handling this task (set after main completes)\n}\n\n// TaskStateEntry combines a task with its assignment state.\ntype TaskStateEntry struct {\n\tTask       Task\n\tAssigned   bool\n\tAssignedAt time.Time\n\tRunID      string // empty if not yet known\n}\n\n// Loop manages a continuous orchestration loop for a project, keeping up to\n// MaxConcurrent host workflow runs active at all times when work is available.\n//\n// When configured with three-phase functions (list-tasks, main, finalize), the\n// loop discovers tasks via list-tasks, picks open ones, runs main for each, and\n// then runs finalize on completion. When configured with a legacy RunFunc, it\n// falls back to the single-function approach.\ntype Loop struct {\n\tconfig     LoopConfig\n\tlistTasks  ListTasksFunc\n\tmainFn     MainFunc\n\tfinalizeFn FinalizeFunc // optional; skipped if nil\n\trunner     RunFunc      // legacy single-function mode\n\tstore      ports.RunStore\n\tassigner   TaskAssigner // optional; legacy task assignment\n\tstopCh     chan struct{}\n\tresumeCh   chan struct{} // signaled by Resume() to wake the loop\n\tmu         sync.Mutex\n\trunning    bool\n\thaltedMu   sync.RWMutex\n\thalted     bool   // true when loop is halted due to an unrecovered error\n\thaltError  string // the error message that caused the halt\n\tdedupMu    sync.Mutex\n\tdedup      map[string]time.Time // task ID -> last assignment time\n\ttasksMu    sync.RWMutex\n\tlastTasks  []Task                    // most recently fetched tasks\n\ttaskRuns   map[string]TaskAssignment // task ID -> assignment info\n}\n\n// NewLoop creates an orchestration loop using a single run function (legacy mode).\n// For three-phase orchestration, use NewPhaseLoop instead.\nfunc NewLoop(cfg LoopConfig, store ports.RunStore, runFn RunFunc) *Loop {\n\tif cfg.MaxConcurrent <= 0 {\n\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n\t}\n\tif cfg.DedupTimeout <= 0 {\n\t\tcfg.DedupTimeout = defaultDedupTimeout\n\t}\n\treturn &Loop{\n\t\tconfig:   cfg,\n\t\trunner:   runFn,\n\t\tstore:    store,\n\t\tresumeCh: make(chan struct{}, 1),\n\t\tdedup:    make(map[string]time.Time),\n\t\ttaskRuns: make(map[string]TaskAssignment),\n\t}\n}\n\n// NewPhaseLoop creates a three-phase orchestration loop. The listTasksFn\n// discovers available tasks, mainFn executes the main workflow for a task,\n// and finalizeFn (optional) runs cleanup after main completes.\nfunc NewPhaseLoop(cfg LoopConfig, store ports.RunStore, listTasksFn ListTasksFunc, mainFn MainFunc, finalizeFn FinalizeFunc) *Loop {\n\tif cfg.MaxConcurrent <= 0 {\n\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n\t}\n\tif cfg.DedupTimeout <= 0 {\n\t\tcfg.DedupTimeout = defaultDedupTimeout\n\t}\n\treturn &Loop{\n\t\tconfig:     cfg,\n\t\tlistTasks:  listTasksFn,\n\t\tmainFn:     mainFn,\n\t\tfinalizeFn: finalizeFn,\n\t\tstore:      store,\n\t\tresumeCh:   make(chan struct{}, 1),\n\t\tdedup:      make(map[string]time.Time),\n\t\ttaskRuns:   make(map[string]TaskAssignment),\n\t}\n}\n\n// SetTaskAssigner configures a TaskAssigner for daemon-managed task assignment.\n// Only used in legacy (single RunFunc) mode when no list-tasks function is set.\nfunc (l *Loop) SetTaskAssigner(a TaskAssigner) {\n\tl.assigner = a\n}\n\n// Start begins the orchestration loop. No-op if already running.\nfunc (l *Loop) Start() {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\tif l.running {\n\t\treturn\n\t}\n\tl.running = true\n\tl.stopCh = make(chan struct{})\n\tgo l.run()\n\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n}\n\n// Stop signals the loop to stop. Active runs continue to completion.\nfunc (l *Loop) Stop() {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\tif !l.running {\n\t\treturn\n\t}\n\tl.running = false\n\tclose(l.stopCh)\n\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n}\n\n// Running returns whether the loop is currently active.\nfunc (l *Loop) Running() bool {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\treturn l.running\n}\n\n// Halted returns whether the loop is halted due to an unrecovered error,\n// along with the error message that caused the halt. When halted, the loop\n// is still running but will not pick up new work.\nfunc (l *Loop) Halted() (bool, string) {\n\tl.haltedMu.RLock()\n\tdefer l.haltedMu.RUnlock()\n\treturn l.halted, l.haltError\n}\n\n// Resume clears the halted state so the loop resumes picking up new work.\nfunc (l *Loop) Resume() {\n\tl.haltedMu.Lock()\n\tdefer l.haltedMu.Unlock()\n\tif l.halted {\n\t\tlog.Printf(\"orchestration loop: resumed for %s (was halted: %s)\", l.config.ProjectDir, l.haltError)\n\t\tl.halted = false\n\t\tl.haltError = \"\"\n\t\t// Wake the loop from any sleep so it picks up work immediately.\n\t\tselect {\n\t\tcase l.resumeCh <- struct{}{}:\n\t\tdefault:\n\t\t}\n\t}\n}\n\n// halt sets the loop into halted state with the given error message.\nfunc (l *Loop) halt(errMsg string) {\n\tl.haltedMu.Lock()\n\tdefer l.haltedMu.Unlock()\n\tl.halted = true\n\tl.haltError = errMsg\n\tlog.Printf(\"orchestration loop: halted for %s (stop_on_error): %s\", l.config.ProjectDir, errMsg)\n}\n\n// isHalted returns true if the loop is currently halted.\nfunc (l *Loop) isHalted() bool {\n\tl.haltedMu.RLock()\n\tdefer l.haltedMu.RUnlock()\n\treturn l.halted\n}\n\nfunc (l *Loop) run() {\n\tif l.listTasks != nil && l.mainFn != nil {\n\t\tl.runPhased()\n\t} else {\n\t\tl.runLegacy()\n\t}\n}\n\n// runPhased implements the three-phase orchestration loop:\n// 1. list-tasks → discover available work\n// 2. main → execute work for each open task (up to MaxConcurrent)\n// 3. finalize → cleanup after main completes (on both success and failure)\nfunc (l *Loop) runPhased() {\n\ttype result struct {\n\t\tstate  domain.RunState\n\t\terrMsg string\n\t}\n\n\tcompletions := make(chan result, l.config.MaxConcurrent)\n\tinFlight := 0\n\n\tfor {\n\t\t// Fill up to max concurrent slots.\n\t\tlaunched := 0\n\t\tfor inFlight < l.config.MaxConcurrent {\n\t\t\tselect {\n\t\t\tcase <-l.stopCh:\n\t\t\t\treturn\n\t\t\tdefault:\n\t\t\t}\n\n\t\t\t// If halted, don't pick up new work.\n\t\t\tif l.isHalted() {\n\t\t\t\tbreak\n\t\t\t}\n\n\t\t\t// Check how many host runs are active for this project.\n\t\t\tactive := l.countActiveHostRuns()\n\t\t\tif active >= l.config.MaxConcurrent {\n\t\t\t\tbreak\n\t\t\t}\n\n\t\t\t// Stagger consecutive launches.\n\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// Phase 1: list-tasks — discover available work.\n\t\t\ttaskID, ok := l.pickTaskFromPhase()\n\t\t\tif !ok {\n\t\t\t\tbreak // no assignable tasks\n\t\t\t}\n\n\t\t\t// Launch main + finalize in a goroutine.\n\t\t\tinFlight++\n\t\t\tlaunched++\n\t\t\ttid := taskID\n\t\t\tgo func() {\n\t\t\t\t// Phase 2: main — do the work.\n\t\t\t\tmainResult, err := l.mainFn(context.Background(), l.config.ProjectDir, tid)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlog.Printf(\"orchestration loop: main failed for %s task %s: %v\", l.config.ProjectDir, tid, err)\n\t\t\t\t\tif mainResult == nil {\n\t\t\t\t\t\tmainResult = &RunResult{State: domain.RunStateFailed}\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\t// Track the run ID for this task.\n\t\t\t\tif mainResult != nil && mainResult.RunID != \"\" {\n\t\t\t\t\tl.tasksMu.Lock()\n\t\t\t\t\tl.taskRuns[tid] = TaskAssignment{\n\t\t\t\t\t\tAssignedAt: time.Now(),\n\t\t\t\t\t\tRunID:      mainResult.RunID,\n\t\t\t\t\t}\n\t\t\t\t\tl.tasksMu.Unlock()\n\t\t\t\t}\n\n\t\t\t\t// Phase 3: finalize — cleanup (runs on both success and failure).\n\t\t\t\t// The overall state is the worst of main and finalize outcomes.\n\t\t\t\toverallState := mainResult.State\n\t\t\t\tif l.finalizeFn != nil {\n\t\t\t\t\tfinalizeResult, finalizeErr := l.finalizeFn(context.Background(), l.config.ProjectDir, tid, mainResult)\n\t\t\t\t\tif finalizeErr != nil {\n\t\t\t\t\t\tlog.Printf(\"orchestration loop: finalize failed for %s task %s: %v\", l.config.ProjectDir, tid, finalizeErr)\n\t\t\t\t\t\toverallState = domain.WorseState(overallState, domain.RunStateFailed)\n\t\t\t\t\t} else if finalizeResult != nil {\n\t\t\t\t\t\toverallState = domain.WorseState(overallState, finalizeResult.State)\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tcompletions <- result{state: overallState, errMsg: fmt.Sprintf(\"task %s failed\", tid)}\n\t\t\t}()\n\t\t}\n\n\t\tif inFlight == 0 {\n\t\t\t// Nothing in flight and couldn't launch anything — wait before checking again.\n\t\t\tif !l.sleep(capacityPollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t// Wait for any run to complete.\n\t\tselect {\n\t\tcase r := <-completions:\n\t\t\tinFlight--\n\t\t\tif r.state == domain.RunStateSucceeded {\n\t\t\t\t// Work was done — try to fill slots immediately.\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\t// Run failed or aborted.\n\t\t\tif l.config.StopOnError {\n\t\t\t\tl.halt(r.errMsg)\n\t\t\t}\n\t\t\t// Back off.\n\t\t\tif !l.sleep(idlePollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\tcase <-l.stopCh:\n\t\t\treturn\n\t\t}\n\t}\n}\n\n// GetTaskSnapshot returns the current task pipeline state: the most recently\n// fetched tasks with their assignment information.\nfunc (l *Loop) GetTaskSnapshot() []TaskStateEntry {\n\tl.tasksMu.RLock()\n\ttasks := make([]Task, len(l.lastTasks))\n\tcopy(tasks, l.lastTasks)\n\tl.tasksMu.RUnlock()\n\n\tl.dedupMu.Lock()\n\tdefer l.dedupMu.Unlock()\n\n\tnow := time.Now()\n\tvar entries []TaskStateEntry\n\tfor _, task := range tasks {\n\t\tentry := TaskStateEntry{Task: task}\n\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n\t\t\tentry.Assigned = true\n\t\t\tentry.AssignedAt = ts\n\t\t}\n\n\t\tl.tasksMu.RLock()\n\t\tif a, ok := l.taskRuns[task.ID]; ok {\n\t\t\tentry.RunID = a.RunID\n\t\t\tif !entry.Assigned {\n\t\t\t\tentry.AssignedAt = a.AssignedAt\n\t\t\t}\n\t\t}\n\t\tl.tasksMu.RUnlock()\n\n\t\tentries = append(entries, entry)\n\t}\n\treturn entries\n}\n\n// pickTaskFromPhase runs the list-tasks function and picks the first open,\n// non-deduped task.\nfunc (l *Loop) pickTaskFromPhase() (string, bool) {\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\ttasks, err := l.listTasks(ctx, l.config.ProjectDir)\n\tif err != nil {\n\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n\t\treturn \"\", false\n\t}\n\n\t// Cache the latest tasks for snapshot queries.\n\tl.tasksMu.Lock()\n\tl.lastTasks = tasks\n\tl.tasksMu.Unlock()\n\n\tnow := time.Now()\n\tl.dedupMu.Lock()\n\tdefer l.dedupMu.Unlock()\n\n\t// Expire old dedup entries.\n\tfor id, ts := range l.dedup {\n\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n\t\t\tdelete(l.dedup, id)\n\t\t}\n\t}\n\n\tfor _, task := range tasks {\n\t\tif task.ID == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif !task.IsOpen() {\n\t\t\tcontinue\n\t\t}\n\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n\t\t\tcontinue\n\t\t}\n\t\tl.dedup[task.ID] = now\n\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n\t\treturn task.ID, true\n\t}\n\n\treturn \"\", false\n}\n\n// runLegacy implements the original single-function orchestration loop.\nfunc (l *Loop) runLegacy() {\n\ttype result struct {\n\t\tstate  domain.RunState\n\t\terrMsg string\n\t}\n\n\tcompletions := make(chan result, l.config.MaxConcurrent)\n\tinFlight := 0\n\n\tfor {\n\t\t// Fill up to max concurrent slots.\n\t\tlaunched := 0\n\t\tfor inFlight < l.config.MaxConcurrent {\n\t\t\tselect {\n\t\t\tcase <-l.stopCh:\n\t\t\t\treturn\n\t\t\tdefault:\n\t\t\t}\n\n\t\t\t// If halted, don't pick up new work.\n\t\t\tif l.isHalted() {\n\t\t\t\tbreak\n\t\t\t}\n\n\t\t\t// Check how many host runs are active for this project (in case of\n\t\t\t// leftover runs from previous loops).\n\t\t\tactive := l.countActiveHostRuns()\n\t\t\tif active >= l.config.MaxConcurrent {\n\t\t\t\tbreak\n\t\t\t}\n\n\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// Determine task ID (if task assigner is configured).\n\t\t\ttaskID := \"\"\n\t\t\tif l.assigner != nil {\n\t\t\t\tvar ok bool\n\t\t\t\ttaskID, ok = l.pickTask()\n\t\t\t\tif !ok {\n\t\t\t\t\t// No assignable tasks available.\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// Launch a new orchestration run in a goroutine.\n\t\t\tinFlight++\n\t\t\tlaunched++\n\t\t\ttid := taskID // capture for goroutine\n\t\t\tgo func() {\n\t\t\t\tres, err := l.runner(context.Background(), l.config.ProjectDir, tid)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlog.Printf(\"orchestration loop: run failed for %s: %v\", l.config.ProjectDir, err)\n\t\t\t\t\tcompletions <- result{state: domain.RunStateFailed, errMsg: err.Error()}\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t\tif res.State != domain.RunStateSucceeded {\n\t\t\t\t\tcompletions <- result{state: res.State, errMsg: \"run failed with state \" + string(res.State)}\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t\tcompletions <- result{state: res.State}\n\t\t\t}()\n\t\t}\n\n\t\tif inFlight == 0 {\n\t\t\t// Nothing in flight and at capacity — wait before checking again.\n\t\t\tif !l.sleep(capacityPollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t// Wait for any run to complete.\n\t\tselect {\n\t\tcase r := <-completions:\n\t\t\tinFlight--\n\t\t\tif r.state == domain.RunStateSucceeded {\n\t\t\t\t// Work was done — try to fill slots immediately.\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\t// Run failed or aborted (no tasks available).\n\t\t\tif l.config.StopOnError {\n\t\t\t\tl.halt(r.errMsg)\n\t\t\t}\n\t\t\t// Back off.\n\t\t\tif !l.sleep(idlePollInterval) {\n\t\t\t\treturn\n\t\t\t}\n\t\tcase <-l.stopCh:\n\t\t\treturn\n\t\t}\n\t}\n}\n\n// pickTask queries the task assigner for available tasks, filters out those\n// within the dedup timeout window, and returns the first assignable task ID.\n// It records the assignment time so the same task won't be picked again until\n// the dedup timeout expires. Returns (\"\", false) if no tasks are available.\nfunc (l *Loop) pickTask() (string, bool) {\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\ttasks, err := l.assigner.ListTasks(ctx, l.config.ProjectDir)\n\tif err != nil {\n\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n\t\treturn \"\", false\n\t}\n\n\t// Cache the latest tasks for snapshot queries.\n\tl.tasksMu.Lock()\n\tl.lastTasks = tasks\n\tl.tasksMu.Unlock()\n\n\tnow := time.Now()\n\tl.dedupMu.Lock()\n\tdefer l.dedupMu.Unlock()\n\n\t// Expire old dedup entries while we're here.\n\tfor id, ts := range l.dedup {\n\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n\t\t\tdelete(l.dedup, id)\n\t\t}\n\t}\n\n\tfor _, task := range tasks {\n\t\tif task.ID == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n\t\t\tcontinue // still within dedup window\n\t\t}\n\t\t// Assign this task.\n\t\tl.dedup[task.ID] = now\n\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n\t\treturn task.ID, true\n\t}\n\n\treturn \"\", false\n}\n\n// countActiveHostRuns counts running or pending host runs for the project.\nfunc (l *Loop) countActiveHostRuns() int {\n\tctx := context.Background()\n\truns, err := l.store.ListRunsByProject(ctx, l.config.ProjectDir, time.Time{})\n\tif err != nil {\n\t\treturn 0\n\t}\n\tcount := 0\n\tfor _, r := range runs {\n\t\tif r.IsHost && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n\t\t\tcount++\n\t\t}\n\t}\n\treturn count\n}\n\n// sleep waits for the given duration or until the loop is stopped or resumed.\n// Returns false if the loop was stopped.\nfunc (l *Loop) sleep(d time.Duration) bool {\n\tselect {\n\tcase <-time.After(d):\n\t\treturn true\n\tcase <-l.resumeCh:\n\t\treturn true\n\tcase <-l.stopCh:\n\t\treturn false\n\t}\n}\n\n// ReadListTasksOutput reads the output directory from a list-tasks workflow run\n// and parses JSONL task output from the last step's output file.\nfunc ReadListTasksOutput(outputDir string) ([]Task, error) {\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading list-tasks output dir: %w\", err)\n\t}\n\n\t// Find the most recently modified .out file.\n\tvar latest string\n\tvar latestMod time.Time\n\tfor _, e := range entries {\n\t\tif e.IsDir() || filepath.Ext(e.Name()) != \".out\" {\n\t\t\tcontinue\n\t\t}\n\t\tinfo, err := e.Info()\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif latest == \"\" || info.ModTime().After(latestMod) {\n\t\t\tlatest = e.Name()\n\t\t\tlatestMod = info.ModTime()\n\t\t}\n\t}\n\n\tif latest == \"\" {\n\t\treturn nil, fmt.Errorf(\"no output files found in %s\", outputDir)\n\t}\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, latest))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading output file %s: %w\", latest, err)\n\t}\n\n\treturn ParseTasksJSONL(string(data))\n}\n","numLines":626,"startLine":1,"totalLines":626}}}
