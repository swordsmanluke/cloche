ow completed for %s: %s (run %s)\\n\", projDir, result.State, result.RunID)\n   242→\t\t\t}\n   243→\t\t}(projectDir)\n   244→\t}\n   245→}\n   246→\n   247→// envOrConfig returns the env var value if set, otherwise the config file\n   248→// value if non-empty, otherwise the fallback default.\n   249→func envOrConfig(envKey, configVal, fallback string) string {\n   250→\tif v := os.Getenv(envKey); v != \"\" {\n   251→\t\treturn v\n   252→\t}\n   253→\tif configVal != \"\" {\n   254→\t\treturn configVal\n   255→\t}\n   256→\treturn fallback\n   257→}\n   258→"}]},"parent_tool_use_id":"toolu_01TqLHTKEsKF9ceU32q4Dtbq","session_id":"77daf22e-aee8-40ec-9b79-2fa0d1f74d8f","uuid":"4b84bfdc-3ab7-44a3-adcd-ca4566f4d21e"}
