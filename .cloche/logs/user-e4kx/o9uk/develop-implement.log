{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013nQawMQZ5HGJTAnw7asinx","type":"tool_result","content":"     1â†’package web\n     2â†’\n     3â†’import (\n     4â†’\t\"bufio\"\n     5â†’\t\"context\"\n     6â†’\t\"embed\"\n     7â†’\t\"encoding/json\"\n     8â†’\t\"fmt\"\n     9â†’\t\"html/template\"\n    10â†’\t\"io/fs\"\n    11â†’\t\"net/http\"\n    12â†’\t\"os\"\n    13â†’\t\"os/exec\"\n    14â†’\t\"path/filepath\"\n    15â†’\t\"regexp\"\n    16â†’\t\"sort\"\n    17â†’\t\"strconv\"\n    18â†’\t\"strings\"\n    19â†’\t\"time\"\n    20â†’\n    21â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22â†’\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23â†’\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24â†’\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25â†’)\n    26â†’\n    27â†’// HandlerOption configures optional Handler dependencies.\n    28â†’type HandlerOption func(*Handler)\n    29â†’\n    30â†’// WithContainerLogger sets the container runtime for fetching live logs.\n    31â†’func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32â†’\treturn func(h *Handler) { h.container = c }\n    33â†’}\n    34â†’\n    35â†’// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36â†’func WithContainerManager(c ContainerManager) HandlerOption {\n    37â†’\treturn func(h *Handler) { h.container = c }\n    38â†’}\n    39â†’\n    40â†’// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41â†’func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42â†’\treturn func(h *Handler) { h.logBroadcast = b }\n    43â†’}\n    44â†’\n    45â†’// WithLogStore sets the log store for indexed log file lookups.\n    46â†’func WithLogStore(ls ports.LogStore) HandlerOption {\n    47â†’\treturn func(h *Handler) { h.logStore = ls }\n    48â†’}\n    49â†’\n    50â†’// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    51â†’func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    52â†’\treturn func(h *Handler) { h.orchestrateFn = fn }\n    53â†’}\n    54â†’\n    55â†’// OrchestratorController provides per-project orchestrator control.\n    56â†’type OrchestratorController interface {\n    57â†’\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    58â†’\tSetEnabled(dir string, enabled bool)\n    59â†’\tSetConcurrency(dir string, concurrency int)\n    60â†’}\n    61â†’\n    62â†’// WithOrchestrator sets the orchestrator controller for project-level control.\n    63â†’func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    64â†’\treturn func(h *Handler) { h.orchestrator = oc }\n    65â†’}\n    66â†’\n    67â†’//go:embed templates/*.html static/*\n    68â†’var content embed.FS\n    69â†’\n    70â†’// Handler serves the web dashboard.\n    71â†’// ContainerLogger can retrieve logs from a container by ID.\n    72â†’type ContainerLogger interface {\n    73â†’\tLogs(ctx context.Context, containerID string) (string, error)\n    74â†’}\n    75â†’\n    76â†’// ContainerManager extends ContainerLogger with container lifecycle operations.\n    77â†’type ContainerManager interface {\n    78â†’\tContainerLogger\n    79â†’\tRemove(ctx context.Context, containerID string) error\n    80â†’\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    81â†’}\n    82â†’\n    83â†’type Handler struct {\n    84â†’\tstore         ports.RunStore\n    85â†’\tcaptures      ports.CaptureStore\n    86â†’\tlogStore      ports.LogStore\n    87â†’\tcontainer     ContainerLogger\n    88â†’\tlogBroadcast  *logstream.Broadcaster\n    89â†’\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    90â†’\torchestrator  OrchestratorController\n    91â†’\tpages         map[string]*template.Template\n    92â†’\tmux           *http.ServeMux\n    93â†’}\n    94â†’\n    95â†’// NewHandler creates a web dashboard handler.\n    96â†’func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    97â†’\tfuncMap := template.FuncMap{\n    98â†’\t\t\"stateColor\":       stateColor,\n    99â†’\t\t\"healthColor\":      healthColor,\n   100â†’\t\t\"formatTime\":       formatTime,\n   101â†’\t\t\"formatDuration\":   formatDuration,\n   102â†’\t\t\"truncate\":         truncate,\n   103â†’\t\t\"shortContainerID\": shortContainerID,\n   104â†’\t}\n   105â†’\n   106â†’\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   107â†’\tif err != nil {\n   108â†’\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   109â†’\t}\n   110â†’\n   111â†’\tpages := map[string]*template.Template{}\n   112â†’\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   113â†’\t\tclone, err := base.Clone()\n   114â†’\t\tif err != nil {\n   115â†’\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   116â†’\t\t}\n   117â†’\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   118â†’\t\tif err != nil {\n   119â†’\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   120â†’\t\t}\n   121â†’\t\tpages[page] = clone\n   122â†’\t}\n   123â†’\n   124â†’\th := &Handler{\n   125â†’\t\tstore:    store,\n   126â†’\t\tcaptures: captures,\n   127â†’\t\tpages:    pages,\n   128â†’\t\tmux:      http.NewServeMux(),\n   129â†’\t}\n   130â†’\tfor _, opt := range opts {\n   131â†’\t\topt(h)\n   132â†’\t}\n   133â†’\n   134â†’\tstaticFS, err := fs.Sub(content, \"static\")\n   135â†’\tif err != nil {\n   136â†’\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   137â†’\t}\n   138â†’\n   139â†’\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   140â†’\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   141â†’\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   142â†’\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   143â†’\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   144â†’\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   145â†’\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   146â†’\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   147â†’\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   148â†’\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   149â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   150â†’\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   151â†’\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   152â†’\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   153â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   154â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   155â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   156â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   157â†’\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   158â†’\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   159â†’\n   160â†’\treturn h, nil\n   161â†’}\n   162â†’\n   163â†’func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   164â†’\th.mux.ServeHTTP(w, r)\n   165â†’}\n   166â†’\n   167â†’// --- HTML handlers ---\n   168â†’\n   169â†’// projectOverviewEntry holds data for a single project card on the landing page.\n   170â†’type projectOverviewEntry struct {\n   171â†’\tDir         string\n   172â†’\tLabel       string\n   173â†’\tHealth      domain.HealthResult\n   174â†’\tRecentRuns  []recentRunDot\n   175â†’\tActiveCount int\n   176â†’}\n   177â†’\n   178â†’// recentRunDot is a minimal representation of a run for the mini history display.\n   179â†’type recentRunDot struct {\n   180â†’\tID    string\n   181â†’\tState string\n   182â†’}\n   183â†’\n   184â†’const healthWindowSize = 10\n   185â†’\n   186â†’func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   187â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   188â†’\tlabels := projectLabels(projects)\n   189â†’\n   190â†’\tvar entries []projectOverviewEntry\n   191â†’\tfor _, dir := range projects {\n   192â†’\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   193â†’\t\tif err != nil {\n   194â†’\t\t\tcontinue\n   195â†’\t\t}\n   196â†’\n   197â†’\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   198â†’\t\trunValues := make([]domain.Run, len(runs))\n   199â†’\t\tfor i, rr := range runs {\n   200â†’\t\t\trunValues[i] = *rr\n   201â†’\t\t}\n   202â†’\n   203â†’\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   204â†’\n   205â†’\t\t// Take the last N runs for the mini history (most recent first).\n   206â†’\t\tn := healthWindowSize\n   207â†’\t\tif n > len(runs) {\n   208â†’\t\t\tn = len(runs)\n   209â†’\t\t}\n   210â†’\t\tdots := make([]recentRunDot, n)\n   211â†’\t\tfor i := 0; i < n; i++ {\n   212â†’\t\t\tdots[i] = recentRunDot{\n   213â†’\t\t\t\tID:    runs[i].ID,\n   214â†’\t\t\t\tState: string(runs[i].State),\n   215â†’\t\t\t}\n   216â†’\t\t}\n   217â†’\n   218â†’\t\tvar activeCount int\n   219â†’\t\tfor _, rr := range runs {\n   220â†’\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   221â†’\t\t\t\tactiveCount++\n   222â†’\t\t\t}\n   223â†’\t\t}\n   224â†’\n   225â†’\t\tentries = append(entries, projectOverviewEntry{\n   226â†’\t\t\tDir:         dir,\n   227â†’\t\t\tLabel:       labels[dir],\n   228â†’\t\t\tHealth:      health,\n   229â†’\t\t\tRecentRuns:  dots,\n   230â†’\t\t\tActiveCount: activeCount,\n   231â†’\t\t})\n   232â†’\t}\n   233â†’\n   234â†’\tsort.Slice(entries, func(i, j int) bool {\n   235â†’\t\treturn entries[i].Label < entries[j].Label\n   236â†’\t})\n   237â†’\n   238â†’\tdata := map[string]any{\n   239â†’\t\t\"Title\":    \"Projects\",\n   240â†’\t\t\"Projects\": entries,\n   241â†’\t}\n   242â†’\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   243â†’\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   244â†’\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   245â†’\t}\n   246â†’}\n   247â†’\n   248â†’func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   249â†’\tprojectFilter := r.URL.Query().Get(\"project\")\n   250â†’\n   251â†’\tvar runs []*domain.Run\n   252â†’\tvar err error\n   253â†’\tif projectFilter != \"\" {\n   254â†’\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   255â†’\t} else {\n   256â†’\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   257â†’\t}\n   258â†’\tif err != nil {\n   259â†’\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   260â†’\t\treturn\n   261â†’\t}\n   262â†’\n   263â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   264â†’\tlabels := projectLabels(projects)\n   265â†’\n   266â†’\t// Count retained containers per project\n   267â†’\tcontainerCounts := map[string]int{}\n   268â†’\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   269â†’\tfor _, run := range allRuns {\n   270â†’\t\tif run.ContainerKept {\n   271â†’\t\t\tcontainerCounts[run.ProjectDir]++\n   272â†’\t\t}\n   273â†’\t}\n   274â†’\n   275â†’\tvar projectList []projectEntry\n   276â†’\tfor _, dir := range projects {\n   277â†’\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   278â†’\t}\n   279â†’\tsort.Slice(projectList, func(i, j int) bool {\n   280â†’\t\treturn projectList[i].Label < projectList[j].Label\n   281â†’\t})\n   282â†’\n   283â†’\tdata := map[string]any{\n   284â†’\t\t\"Title\":         \"Runs\",\n   285â†’\t\t\"Runs\":          runs,\n   286â†’\t\t\"Projects\":      projectList,\n   287â†’\t\t\"ProjectFilter\": projectFilter,\n   288â†’\t\t\"ProjectLabels\": labels,\n   289â†’\t}\n   290â†’\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   291â†’\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   292â†’\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   293â†’\t}\n   294â†’}\n   295â†’\n   296â†’// stepEntry is a merged view of a step execution for the template.\n   297â†’type stepEntry struct {\n   298â†’\tIndex     int\n   299â†’\tStepName  string\n   300â†’\tResult    string\n   301â†’\tStartedAt time.Time\n   302â†’\tDuration  string\n   303â†’}\n   304â†’\n   305â†’// mergeCaptures collapses started/completed capture pairs into single entries.\n   306â†’func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   307â†’\tvar entries []stepEntry\n   308â†’\t// Track pending started rows by step name (LIFO for retries)\n   309â†’\tpending := map[string]*domain.StepExecution{}\n   310â†’\n   311â†’\tfor _, c := range caps {\n   312â†’\t\tif c.Result == \"\" {\n   313â†’\t\t\t// step_started row\n   314â†’\t\t\tpending[c.StepName] = c\n   315â†’\t\t\tcontinue\n   316â†’\t\t}\n   317â†’\t\t// step_completed row â€” merge with pending started if available\n   318â†’\t\tstartedAt := c.StartedAt\n   319â†’\t\tif started := pending[c.StepName]; started != nil {\n   320â†’\t\t\tstartedAt = started.StartedAt\n   321â†’\t\t\tdelete(pending, c.StepName)\n   322â†’\t\t}\n   323â†’\t\tentries = append(entries, stepEntry{\n   324â†’\t\t\tIndex:     len(entries),\n   325â†’\t\t\tStepName:  c.StepName,\n   326â†’\t\t\tResult:    c.Result,\n   327â†’\t\t\tStartedAt: startedAt,\n   328â†’\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   329â†’\t\t})\n   330â†’\t}\n   331â†’\n   332â†’\t// Append any started-but-not-completed steps (still running)\n   333â†’\tfor _, c := range caps {\n   334â†’\t\tif c.Result == \"\" {\n   335â†’\t\t\tif _, used := pending[c.StepName]; !used {\n   336â†’\t\t\t\tcontinue\n   337â†’\t\t\t}\n   338â†’\t\t\tentries = append(entries, stepEntry{\n   339â†’\t\t\t\tIndex:     len(entries),\n   340â†’\t\t\t\tStepName:  c.StepName,\n   341â†’\t\t\t\tStartedAt: c.StartedAt,\n   342â†’\t\t\t})\n   343â†’\t\t\tdelete(pending, c.StepName)\n   344â†’\t\t}\n   345â†’\t}\n   346â†’\n   347â†’\treturn entries\n   348â†’}\n   349â†’\n   350â†’// containerState inspects the container for a run and returns one of:\n   351â†’//   - \"running\"   â€“ container exists and is running\n   352â†’//   - \"stopped\"   â€“ container exists, not running, not kept\n   353â†’//   - \"available\" â€“ container exists, not running, kept (can be deleted)\n   354â†’//   - \"removed\"   â€“ no container ID, no manager, or inspect failed\n   355â†’func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   356â†’\tif run.ContainerID == \"\" {\n   357â†’\t\treturn \"removed\"\n   358â†’\t}\n   359â†’\tmgr, ok := h.container.(ContainerManager)\n   360â†’\tif !ok {\n   361â†’\t\treturn \"removed\"\n   362â†’\t}\n   363â†’\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   364â†’\tif err != nil {\n   365â†’\t\treturn \"removed\"\n   366â†’\t}\n   367â†’\tif status.Running {\n   368â†’\t\treturn \"running\"\n   369â†’\t}\n   370â†’\tif run.ContainerKept {\n   371â†’\t\treturn \"available\"\n   372â†’\t}\n   373â†’\treturn \"stopped\"\n   374â†’}\n   375â†’\n   376â†’func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   377â†’\tid := r.PathValue(\"id\")\n   378â†’\n   379â†’\trun, err := h.store.GetRun(r.Context(), id)\n   380â†’\tif err != nil {\n   381â†’\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   382â†’\t\treturn\n   383â†’\t}\n   384â†’\n   385â†’\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   386â†’\tif err != nil {\n   387â†’\t\tcaps = nil // non-fatal\n   388â†’\t}\n   389â†’\n   390â†’\tsteps := mergeCaptures(caps)\n   391â†’\n   392â†’\tdata := map[string]any{\n   393â†’\t\t\"Title\":          \"Run \" + run.ID,\n   394â†’\t\t\"Run\":            run,\n   395â†’\t\t\"Steps\":          steps,\n   396â†’\t\t\"Page\":           \"detail\",\n   397â†’\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   398â†’\t}\n   399â†’\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   400â†’\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   401â†’\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   402â†’\t}\n   403â†’}\n   404â†’\n   405â†’// --- JSON API handlers ---\n   406â†’\n   407â†’type apiRun struct {\n   408â†’\tID           string `json:\"id\"`\n   409â†’\tWorkflowName string `json:\"workflow_name\"`\n   410â†’\tProjectDir   string `json:\"project_dir\"`\n   411â†’\tProjectLabel string `json:\"project_label\"`\n   412â†’\tState        string `json:\"state\"`\n   413â†’\tStartedAt    string `json:\"started_at\"`\n   414â†’\tCompletedAt  string `json:\"completed_at\"`\n   415â†’\tContainerID  string `json:\"container_id\"`\n   416â†’\tErrorMessage string `json:\"error_message\"`\n   417â†’}\n   418â†’\n   419â†’type apiStep struct {\n   420â†’\tStepName    string `json:\"step_name\"`\n   421â†’\tResult      string `json:\"result\"`\n   422â†’\tStartedAt   string `json:\"started_at\"`\n   423â†’\tCompletedAt string `json:\"completed_at\"`\n   424â†’\tDuration    string `json:\"duration\"`\n   425â†’}\n   426â†’\n   427â†’type apiRunDetail struct {\n   428â†’\tapiRun\n   429â†’\tContainerState string    `json:\"container_state\"`\n   430â†’\tSteps          []apiStep `json:\"steps\"`\n   431â†’}\n   432â†’\n   433â†’func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   434â†’\treturn apiRun{\n   435â†’\t\tID:           r.ID,\n   436â†’\t\tWorkflowName: r.WorkflowName,\n   437â†’\t\tProjectDir:   r.ProjectDir,\n   438â†’\t\tProjectLabel: labels[r.ProjectDir],\n   439â†’\t\tState:        string(r.State),\n   440â†’\t\tStartedAt:    formatTime(r.StartedAt),\n   441â†’\t\tCompletedAt:  formatTime(r.CompletedAt),\n   442â†’\t\tContainerID:  r.ContainerID,\n   443â†’\t\tErrorMessage: r.ErrorMessage,\n   444â†’\t}\n   445â†’}\n   446â†’\n   447â†’func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   448â†’\tprojectFilter := r.URL.Query().Get(\"project\")\n   449â†’\n   450â†’\tvar runs []*domain.Run\n   451â†’\tvar err error\n   452â†’\tif projectFilter != \"\" {\n   453â†’\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   454â†’\t} else {\n   455â†’\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   456â†’\t}\n   457â†’\tif err != nil {\n   458â†’\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   459â†’\t\treturn\n   460â†’\t}\n   461â†’\n   462â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   463â†’\tlabels := projectLabels(projects)\n   464â†’\n   465â†’\tresult := make([]apiRun, len(runs))\n   466â†’\tfor i, run := range runs {\n   467â†’\t\tresult[i] = toAPIRun(run, labels)\n   468â†’\t}\n   469â†’\n   470â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   471â†’\tjson.NewEncoder(w).Encode(result)\n   472â†’}\n   473â†’\n   474â†’func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   475â†’\tprojects, err := h.store.ListProjects(r.Context())\n   476â†’\tif err != nil {\n   477â†’\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   478â†’\t\treturn\n   479â†’\t}\n   480â†’\tlabels := projectLabels(projects)\n   481â†’\n   482â†’\ttype apiHealth struct {\n   483â†’\t\tStatus string `json:\"status\"`\n   484â†’\t\tPassed int    `json:\"passed\"`\n   485â†’\t\tFailed int    `json:\"failed\"`\n   486â†’\t\tTotal  int    `json:\"total\"`\n   487â†’\t}\n   488â†’\ttype apiProject struct {\n   489â†’\t\tDir         string    `json:\"dir\"`\n   490â†’\t\tLabel       string    `json:\"label\"`\n   491â†’\t\tHealth      apiHealth `json:\"health\"`\n   492â†’\t\tActiveCount int       `json:\"active_count\"`\n   493â†’\t}\n   494â†’\tresult := make([]apiProject, len(projects))\n   495â†’\tfor i, dir := range projects {\n   496â†’\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   497â†’\t\trunValues := make([]domain.Run, len(runs))\n   498â†’\t\tfor j, rr := range runs {\n   499â†’\t\t\trunValues[j] = *rr\n   500â†’\t\t}\n   501â†’\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   502â†’\t\tvar activeCount int\n   503â†’\t\tfor _, rr := range runs {\n   504â†’\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   505â†’\t\t\t\tactiveCount++\n   506â†’\t\t\t}\n   507â†’\t\t}\n   508â†’\t\tresult[i] = apiProject{\n   509â†’\t\t\tDir:   dir,\n   510â†’\t\t\tLabel: labels[dir],\n   511â†’\t\t\tHealth: apiHealth{\n   512â†’\t\t\t\tStatus: string(health.Status),\n   513â†’\t\t\t\tPassed: health.Passed,\n   514â†’\t\t\t\tFailed: health.Failed,\n   515â†’\t\t\t\tTotal:  health.Total,\n   516â†’\t\t\t},\n   517â†’\t\t\tActiveCount: activeCount,\n   518â†’\t\t}\n   519â†’\t}\n   520â†’\n   521â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   522â†’\tjson.NewEncoder(w).Encode(result)\n   523â†’}\n   524â†’\n   525â†’func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   526â†’\tid := r.PathValue(\"id\")\n   527â†’\n   528â†’\trun, err := h.store.GetRun(r.Context(), id)\n   529â†’\tif err != nil {\n   530â†’\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   531â†’\t\treturn\n   532â†’\t}\n   533â†’\n   534â†’\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   535â†’\tif err != nil {\n   536â†’\t\tcaps = nil\n   537â†’\t}\n   538â†’\n   539â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   540â†’\tlabels := projectLabels(projects)\n   541â†’\n   542â†’\tmerged := mergeCaptures(caps)\n   543â†’\tsteps := make([]apiStep, len(merged))\n   544â†’\tfor i, e := range merged {\n   545â†’\t\tsteps[i] = apiStep{\n   546â†’\t\t\tStepName:  e.StepName,\n   547â†’\t\t\tResult:    e.Result,\n   548â†’\t\t\tStartedAt: formatTime(e.StartedAt),\n   549â†’\t\t\tDuration:  e.Duration,\n   550â†’\t\t}\n   551â†’\t}\n   552â†’\n   553â†’\tdetail := apiRunDetail{\n   554â†’\t\tapiRun:         toAPIRun(run, labels),\n   555â†’\t\tContainerState: h.containerState(r.Context(), run),\n   556â†’\t\tSteps:          steps,\n   557â†’\t}\n   558â†’\n   559â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   560â†’\tjson.NewEncoder(w).Encode(detail)\n   561â†’}\n   562â†’\n   563â†’func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   564â†’\tid := r.PathValue(\"id\")\n   565â†’\tstep := r.PathValue(\"step\")\n   566â†’\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   567â†’\n   568â†’\trun, err := h.store.GetRun(r.Context(), id)\n   569â†’\tif err != nil {\n   570â†’\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   571â†’\t\treturn\n   572â†’\t}\n   573â†’\n   574â†’\t// Try log index first for fast lookup\n   575â†’\tif h.logStore != nil {\n   576â†’\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   577â†’\t\tif err == nil && len(logFiles) > 0 {\n   578â†’\t\t\t// If type filter specified, narrow results\n   579â†’\t\t\tfor _, lf := range logFiles {\n   580â†’\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   581â†’\t\t\t\t\tcontinue\n   582â†’\t\t\t\t}\n   583â†’\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   584â†’\t\t\t\tif readErr == nil && len(data) > 0 {\n   585â†’\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   586â†’\t\t\t\t\tw.Write(data)\n   587â†’\t\t\t\t\treturn\n   588â†’\t\t\t\t}\n   589â†’\t\t\t}\n   590â†’\t\t}\n   591â†’\t}\n   592â†’\n   593â†’\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   594â†’\n   595â†’\t// Fall back to file path conventions\n   596â†’\t// If type is \"llm\", try llm-<step>.log\n   597â†’\tif logType == \"llm\" {\n   598â†’\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   599â†’\t\tdata, err := os.ReadFile(llmPath)\n   600â†’\t\tif err == nil && len(data) > 0 {\n   601â†’\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   602â†’\t\t\tw.Write(data)\n   603â†’\t\t\treturn\n   604â†’\t\t}\n   605â†’\t}\n   606â†’\n   607â†’\t// Try per-step output first, fall back to container.log, then live docker logs\n   608â†’\toutputPath := filepath.Join(outputDir, step+\".log\")\n   609â†’\tdata, err := os.ReadFile(outputPath)\n   610â†’\tif err == nil && len(data) > 0 {\n   611â†’\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   612â†’\t\tw.Write(data)\n   613â†’\t\treturn\n   614â†’\t}\n   615â†’\n   616â†’\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   617â†’\tdata, err = os.ReadFile(containerLog)\n   618â†’\tif err == nil && len(data) > 0 {\n   619â†’\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   620â†’\t\tw.Write(data)\n   621â†’\t\treturn\n   622â†’\t}\n   623â†’\n   624â†’\t// Last resort: try live docker logs from still-existing container\n   625â†’\tif h.container != nil && run.ContainerID != \"\" {\n   626â†’\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   627â†’\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   628â†’\t\t\tw.Write([]byte(logs))\n   629â†’\t\t\treturn\n   630â†’\t\t}\n   631â†’\t}\n   632â†’\n   633â†’\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   634â†’}\n   635â†’\n   636â†’func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   637â†’\tid := r.PathValue(\"id\")\n   638â†’\n   639â†’\trun, err := h.store.GetRun(r.Context(), id)\n   640â†’\tif err != nil {\n   641â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   642â†’\t\tw.WriteHeader(http.StatusNotFound)\n   643â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   644â†’\t\treturn\n   645â†’\t}\n   646â†’\n   647â†’\tmgr, ok := h.container.(ContainerManager)\n   648â†’\tif !ok || run.ContainerID == \"\" {\n   649â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   650â†’\t\tw.WriteHeader(http.StatusBadRequest)\n   651â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   652â†’\t\treturn\n   653â†’\t}\n   654â†’\n   655â†’\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   656â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   657â†’\t\tw.WriteHeader(http.StatusInternalServerError)\n   658â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   659â†’\t\treturn\n   660â†’\t}\n   661â†’\n   662â†’\trun.ContainerKept = false\n   663â†’\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   664â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   665â†’\t\tw.WriteHeader(http.StatusInternalServerError)\n   666â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   667â†’\t\treturn\n   668â†’\t}\n   669â†’\n   670â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   671â†’\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   672â†’}\n   673â†’\n   674â†’func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   675â†’\tlabel := r.PathValue(\"name\")\n   676â†’\n   677â†’\t// Resolve label back to project directory via the store.\n   678â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   679â†’\tlabels := projectLabels(projects)\n   680â†’\tvar projectDir string\n   681â†’\tfor dir, l := range labels {\n   682â†’\t\tif l == label {\n   683â†’\t\t\tprojectDir = dir\n   684â†’\t\t\tbreak\n   685â†’\t\t}\n   686â†’\t}\n   687â†’\tif projectDir == \"\" {\n   688â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   689â†’\t\tw.WriteHeader(http.StatusNotFound)\n   690â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   691â†’\t\treturn\n   692â†’\t}\n   693â†’\n   694â†’\tif h.orchestrateFn == nil {\n   695â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   696â†’\t\tw.WriteHeader(http.StatusNotImplemented)\n   697â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   698â†’\t\treturn\n   699â†’\t}\n   700â†’\n   701â†’\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   702â†’\tif err != nil {\n   703â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   704â†’\t\tw.WriteHeader(http.StatusInternalServerError)\n   705â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   706â†’\t\treturn\n   707â†’\t}\n   708â†’\n   709â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   710â†’\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   711â†’}\n   712â†’\n   713â†’// handleAPIStream serves an SSE stream of log lines for a run.\n   714â†’// For active runs, it subscribes to the live broadcaster.\n   715â†’// For completed runs, it serves the archived full.log then closes.\n   716â†’func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   717â†’\tid := r.PathValue(\"id\")\n   718â†’\n   719â†’\trun, err := h.store.GetRun(r.Context(), id)\n   720â†’\tif err != nil {\n   721â†’\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   722â†’\t\treturn\n   723â†’\t}\n   724â†’\n   725â†’\tflusher, ok := w.(http.Flusher)\n   726â†’\tif !ok {\n   727â†’\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   728â†’\t\treturn\n   729â†’\t}\n   730â†’\n   731â†’\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   732â†’\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   733â†’\tw.Header().Set(\"Connection\", \"keep-alive\")\n   734â†’\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   735â†’\n   736â†’\tisComplete := run.State == domain.RunStateSucceeded ||\n   737â†’\t\trun.State == domain.RunStateFailed ||\n   738â†’\t\trun.State == domain.RunStateCancelled\n   739â†’\n   740â†’\tif isComplete {\n   741â†’\t\t// Serve archived full.log\n   742â†’\t\th.streamFullLog(w, flusher, run)\n   743â†’\t\t// Send done event\n   744â†’\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   745â†’\t\tflusher.Flush()\n   746â†’\t\treturn\n   747â†’\t}\n   748â†’\n   749â†’\t// Active run: subscribe to live broadcaster\n   750â†’\tif h.logBroadcast == nil {\n   751â†’\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   752â†’\t\treturn\n   753â†’\t}\n   754â†’\n   755â†’\tsub := h.logBroadcast.Subscribe(id)\n   756â†’\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   757â†’\n   758â†’\tctx := r.Context()\n   759â†’\tfor {\n   760â†’\t\tselect {\n   761â†’\t\tcase <-ctx.Done():\n   762â†’\t\t\treturn\n   763â†’\t\tcase line, ok := <-sub.C:\n   764â†’\t\t\tif !ok {\n   765â†’\t\t\t\t// Stream finished (run completed)\n   766â†’\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   767â†’\t\t\t\tflusher.Flush()\n   768â†’\t\t\t\treturn\n   769â†’\t\t\t}\n   770â†’\t\t\tdata, _ := json.Marshal(line)\n   771â†’\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   772â†’\t\t\tflusher.Flush()\n   773â†’\t\t}\n   774â†’\t}\n   775â†’}\n   776â†’\n   777â†’// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   778â†’var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   779â†’\n   780â†’// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   781â†’func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   782â†’\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   783â†’\tf, err := os.Open(logPath)\n   784â†’\tif err != nil {\n   785â†’\t\treturn\n   786â†’\t}\n   787â†’\tdefer f.Close()\n   788â†’\n   789â†’\tscanner := bufio.NewScanner(f)\n   790â†’\tfor scanner.Scan() {\n   791â†’\t\ttext := scanner.Text()\n   792â†’\t\tline := parseFullLogLine(text)\n   793â†’\t\tdata, _ := json.Marshal(line)\n   794â†’\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   795â†’\t\tflusher.Flush()\n   796â†’\t}\n   797â†’}\n   798â†’\n   799â†’// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   800â†’func parseFullLogLine(text string) logstream.LogLine {\n   801â†’\tm := logLineRegex.FindStringSubmatch(text)\n   802â†’\tif m == nil {\n   803â†’\t\treturn logstream.LogLine{\n   804â†’\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   805â†’\t\t\tType:      \"script\",\n   806â†’\t\t\tContent:   text,\n   807â†’\t\t}\n   808â†’\t}\n   809â†’\treturn logstream.LogLine{\n   810â†’\t\tTimestamp: m[1],\n   811â†’\t\tType:      m[2],\n   812â†’\t\tContent:   m[3],\n   813â†’\t}\n   814â†’}\n   815â†’\n   816â†’// --- Project detail handlers ---\n   817â†’\n   818â†’// resolveProjectDir resolves a project label from the URL to its directory path.\n   819â†’// Returns (dir, label, ok). Writes a JSON error response if not found.\n   820â†’func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   821â†’\tlabel := r.PathValue(\"name\")\n   822â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   823â†’\tlabels := projectLabels(projects)\n   824â†’\tfor dir, l := range labels {\n   825â†’\t\tif l == label {\n   826â†’\t\t\treturn dir, label, true\n   827â†’\t\t}\n   828â†’\t}\n   829â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   830â†’\tw.WriteHeader(http.StatusNotFound)\n   831â†’\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   832â†’\treturn \"\", \"\", false\n   833â†’}\n   834â†’\n   835â†’func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   836â†’\tdir, label, ok := h.resolveProjectDir(w, r)\n   837â†’\tif !ok {\n   838â†’\t\treturn\n   839â†’\t}\n   840â†’\n   841â†’\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   842â†’\tn := 10\n   843â†’\tif n > len(runs) {\n   844â†’\t\tn = len(runs)\n   845â†’\t}\n   846â†’\tdots := make([]recentRunDot, n)\n   847â†’\tfor i := 0; i < n; i++ {\n   848â†’\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   849â†’\t}\n   850â†’\n   851â†’\tdata := map[string]any{\n   852â†’\t\t\"Title\":      label,\n   853â†’\t\t\"Label\":      label,\n   854â†’\t\t\"Dir\":        dir,\n   855â†’\t\t\"RecentRuns\": dots,\n   856â†’\t}\n   857â†’\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   858â†’\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   859â†’\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   860â†’\t}\n   861â†’}\n   862â†’\n   863â†’func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   864â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n   865â†’\tif !ok {\n   866â†’\t\treturn\n   867â†’\t}\n   868â†’\tif h.orchestrator == nil {\n   869â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   870â†’\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   871â†’\t\treturn\n   872â†’\t}\n   873â†’\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   874â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   875â†’\tjson.NewEncoder(w).Encode(map[string]any{\n   876â†’\t\t\"enabled\":     enabled,\n   877â†’\t\t\"in_flight\":   inFlight,\n   878â†’\t\t\"concurrency\": concurrency,\n   879â†’\t})\n   880â†’}\n   881â†’\n   882â†’func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   883â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n   884â†’\tif !ok {\n   885â†’\t\treturn\n   886â†’\t}\n   887â†’\tif h.orchestrator == nil {\n   888â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   889â†’\t\tw.WriteHeader(http.StatusNotImplemented)\n   890â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   891â†’\t\treturn\n   892â†’\t}\n   893â†’\th.orchestrator.SetEnabled(dir, true)\n   894â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   895â†’\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   896â†’}\n   897â†’\n   898â†’func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   899â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n   900â†’\tif !ok {\n   901â†’\t\treturn\n   902â†’\t}\n   903â†’\tif h.orchestrator == nil {\n   904â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   905â†’\t\tw.WriteHeader(http.StatusNotImplemented)\n   906â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   907â†’\t\treturn\n   908â†’\t}\n   909â†’\th.orchestrator.SetEnabled(dir, false)\n   910â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   911â†’\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   912â†’}\n   913â†’\n   914â†’func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   915â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n   916â†’\tif !ok {\n   917â†’\t\treturn\n   918â†’\t}\n   919â†’\tif h.orchestrator == nil {\n   920â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   921â†’\t\tw.WriteHeader(http.StatusNotImplemented)\n   922â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   923â†’\t\treturn\n   924â†’\t}\n   925â†’\tvar body struct {\n   926â†’\t\tConcurrency int `json:\"concurrency\"`\n   927â†’\t}\n   928â†’\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n   929â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   930â†’\t\tw.WriteHeader(http.StatusBadRequest)\n   931â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n   932â†’\t\treturn\n   933â†’\t}\n   934â†’\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n   935â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   936â†’\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   937â†’}\n   938â†’\n   939â†’func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   940â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n   941â†’\tif !ok {\n   942â†’\t\treturn\n   943â†’\t}\n   944â†’\n   945â†’\t// Docker image: read FROM line from Dockerfile\n   946â†’\tdockerImage := \"\"\n   947â†’\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   948â†’\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   949â†’\t\t// Find the last FROM line (final stage)\n   950â†’\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   951â†’\t\t\ttrimmed := strings.TrimSpace(line)\n   952â†’\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   953â†’\t\t\t\tparts := strings.Fields(trimmed)\n   954â†’\t\t\t\tif len(parts) >= 2 {\n   955â†’\t\t\t\t\tdockerImage = parts[1]\n   956â†’\t\t\t\t}\n   957â†’\t\t\t}\n   958â†’\t\t}\n   959â†’\t}\n   960â†’\n   961â†’\t// Version\n   962â†’\tversion := 0\n   963â†’\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   964â†’\tif data, err := os.ReadFile(versionPath); err == nil {\n   965â†’\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   966â†’\t\t\tversion = v\n   967â†’\t\t}\n   968â†’\t}\n   969â†’\n   970â†’\t// Prompt files history\n   971â†’\ttype commitEntry struct {\n   972â†’\t\tSHA     string `json:\"sha\"`\n   973â†’\t\tDate    string `json:\"date\"`\n   974â†’\t\tMessage string `json:\"message\"`\n   975â†’\t}\n   976â†’\ttype promptFile struct {\n   977â†’\t\tPath    string        `json:\"path\"`\n   978â†’\t\tHistory []commitEntry `json:\"history\"`\n   979â†’\t}\n   980â†’\n   981â†’\tvar promptFiles []promptFile\n   982â†’\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   983â†’\tif entries, err := os.ReadDir(promptsDir); err == nil {\n   984â†’\t\tfor _, e := range entries {\n   985â†’\t\t\tif e.IsDir() {\n   986â†’\t\t\t\tcontinue\n   987â†’\t\t\t}\n   988â†’\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n   989â†’\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n   990â†’\t\t\tcmd.Dir = dir\n   991â†’\t\t\tout, err := cmd.Output()\n   992â†’\t\t\tif err != nil {\n   993â†’\t\t\t\tcontinue\n   994â†’\t\t\t}\n   995â†’\t\t\tvar history []commitEntry\n   996â†’\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n   997â†’\t\t\t\tif line == \"\" {\n   998â†’\t\t\t\t\tcontinue\n   999â†’\t\t\t\t}\n  1000â†’\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1001â†’\t\t\t\tif len(parts) < 3 {\n  1002â†’\t\t\t\t\tcontinue\n  1003â†’\t\t\t\t}\n  1004â†’\t\t\t\t// Parse date to short form\n  1005â†’\t\t\t\tdateStr := parts[1]\n  1006â†’\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1007â†’\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1008â†’\t\t\t\t}\n  1009â†’\t\t\t\thistory = append(history, commitEntry{\n  1010â†’\t\t\t\t\tSHA:     parts[0][:7],\n  1011â†’\t\t\t\t\tDate:    dateStr,\n  1012â†’\t\t\t\t\tMessage: parts[2],\n  1013â†’\t\t\t\t})\n  1014â†’\t\t\t}\n  1015â†’\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1016â†’\t\t}\n  1017â†’\t}\n  1018â†’\n  1019â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1020â†’\tjson.NewEncoder(w).Encode(map[string]any{\n  1021â†’\t\t\"docker_image\": dockerImage,\n  1022â†’\t\t\"version\":      version,\n  1023â†’\t\t\"prompt_files\": promptFiles,\n  1024â†’\t})\n  1025â†’}\n  1026â†’\n  1027â†’func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1028â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n  1029â†’\tif !ok {\n  1030â†’\t\treturn\n  1031â†’\t}\n  1032â†’\tfile := r.URL.Query().Get(\"file\")\n  1033â†’\tsha := r.URL.Query().Get(\"sha\")\n  1034â†’\tif file == \"\" || sha == \"\" {\n  1035â†’\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1036â†’\t\treturn\n  1037â†’\t}\n  1038â†’\n  1039â†’\t// Validate sha is alphanumeric to prevent injection\n  1040â†’\tfor _, c := range sha {\n  1041â†’\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1042â†’\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1043â†’\t\t\treturn\n  1044â†’\t\t}\n  1045â†’\t}\n  1046â†’\n  1047â†’\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1048â†’\tcmd.Dir = dir\n  1049â†’\tout, err := cmd.Output()\n  1050â†’\tif err != nil {\n  1051â†’\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1052â†’\t\treturn\n  1053â†’\t}\n  1054â†’\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1055â†’\tw.Write(out)\n  1056â†’}\n  1057â†’\n  1058â†’func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1059â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n  1060â†’\tif !ok {\n  1061â†’\t\treturn\n  1062â†’\t}\n  1063â†’\n  1064â†’\tclocheDir := filepath.Join(dir, \".cloche\")\n  1065â†’\tentries, err := os.ReadDir(clocheDir)\n  1066â†’\tif err != nil {\n  1067â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1068â†’\t\tjson.NewEncoder(w).Encode([]any{})\n  1069â†’\t\treturn\n  1070â†’\t}\n  1071â†’\n  1072â†’\ttype apiWire struct {\n  1073â†’\t\tFrom   string `json:\"from\"`\n  1074â†’\t\tResult string `json:\"result\"`\n  1075â†’\t\tTo     string `json:\"to\"`\n  1076â†’\t}\n  1077â†’\ttype apiStepDef struct {\n  1078â†’\t\tName    string            `json:\"name\"`\n  1079â†’\t\tType    string            `json:\"type\"`\n  1080â†’\t\tResults []string          `json:\"results\"`\n  1081â†’\t\tConfig  map[string]string `json:\"config\"`\n  1082â†’\t}\n  1083â†’\ttype apiWorkflow struct {\n  1084â†’\t\tName      string       `json:\"name\"`\n  1085â†’\t\tFile      string       `json:\"file\"`\n  1086â†’\t\tSteps     []apiStepDef `json:\"steps\"`\n  1087â†’\t\tWires     []apiWire    `json:\"wires\"`\n  1088â†’\t\tEntryStep string       `json:\"entry_step\"`\n  1089â†’\t}\n  1090â†’\n  1091â†’\tvar workflows []apiWorkflow\n  1092â†’\tfor _, e := range entries {\n  1093â†’\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1094â†’\t\t\tcontinue\n  1095â†’\t\t}\n  1096â†’\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1097â†’\t\tif err != nil {\n  1098â†’\t\t\tcontinue\n  1099â†’\t\t}\n  1100â†’\t\twf, err := dsl.Parse(string(data))\n  1101â†’\t\tif err != nil {\n  1102â†’\t\t\tcontinue\n  1103â†’\t\t}\n  1104â†’\t\tvar steps []apiStepDef\n  1105â†’\t\tfor _, s := range wf.Steps {\n  1106â†’\t\t\tsteps = append(steps, apiStepDef{\n  1107â†’\t\t\t\tName:    s.Name,\n  1108â†’\t\t\t\tType:    string(s.Type),\n  1109â†’\t\t\t\tResults: s.Results,\n  1110â†’\t\t\t\tConfig:  s.Config,\n  1111â†’\t\t\t})\n  1112â†’\t\t}\n  1113â†’\t\t// Sort steps by name for consistent ordering\n  1114â†’\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1115â†’\n  1116â†’\t\tvar wires []apiWire\n  1117â†’\t\tfor _, wire := range wf.Wiring {\n  1118â†’\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1119â†’\t\t}\n  1120â†’\n  1121â†’\t\tworkflows = append(workflows, apiWorkflow{\n  1122â†’\t\t\tName:      wf.Name,\n  1123â†’\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1124â†’\t\t\tSteps:     steps,\n  1125â†’\t\t\tWires:     wires,\n  1126â†’\t\t\tEntryStep: wf.EntryStep,\n  1127â†’\t\t})\n  1128â†’\t}\n  1129â†’\n  1130â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1131â†’\tjson.NewEncoder(w).Encode(workflows)\n  1132â†’}\n  1133â†’\n  1134â†’func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1135â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n  1136â†’\tif !ok {\n  1137â†’\t\treturn\n  1138â†’\t}\n  1139â†’\tworkflowName := r.PathValue(\"workflow\")\n  1140â†’\tstepName := r.PathValue(\"step\")\n  1141â†’\n  1142â†’\t// Find the workflow file\n  1143â†’\tclocheDir := filepath.Join(dir, \".cloche\")\n  1144â†’\tvar wf *domain.Workflow\n  1145â†’\tentries, _ := os.ReadDir(clocheDir)\n  1146â†’\tfor _, e := range entries {\n  1147â†’\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1148â†’\t\t\tcontinue\n  1149â†’\t\t}\n  1150â†’\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1151â†’\t\tif err != nil {\n  1152â†’\t\t\tcontinue\n  1153â†’\t\t}\n  1154â†’\t\tparsed, err := dsl.Parse(string(data))\n  1155â†’\t\tif err != nil {\n  1156â†’\t\t\tcontinue\n  1157â†’\t\t}\n  1158â†’\t\tif parsed.Name == workflowName {\n  1159â†’\t\t\twf = parsed\n  1160â†’\t\t\tbreak\n  1161â†’\t\t}\n  1162â†’\t}\n  1163â†’\tif wf == nil {\n  1164â†’\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1165â†’\t\treturn\n  1166â†’\t}\n  1167â†’\n  1168â†’\tstep, ok := wf.Steps[stepName]\n  1169â†’\tif !ok {\n  1170â†’\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1171â†’\t\treturn\n  1172â†’\t}\n  1173â†’\n  1174â†’\t// Try to read the referenced file from step config\n  1175â†’\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1176â†’\n  1177â†’\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1178â†’\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1179â†’\t\tif err == nil {\n  1180â†’\t\t\tw.Write(data)\n  1181â†’\t\t\treturn\n  1182â†’\t\t}\n  1183â†’\t}\n  1184â†’\tif script := step.Config[\"command\"]; script != \"\" {\n  1185â†’\t\tw.Write([]byte(script))\n  1186â†’\t\treturn\n  1187â†’\t}\n  1188â†’\tif script := step.Config[\"script\"]; script != \"\" {\n  1189â†’\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1190â†’\t\tif err == nil {\n  1191â†’\t\t\tw.Write(data)\n  1192â†’\t\t\treturn\n  1193â†’\t\t}\n  1194â†’\t\tw.Write([]byte(script))\n  1195â†’\t\treturn\n  1196â†’\t}\n  1197â†’\n  1198â†’\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1199â†’}\n  1200â†’\n  1201â†’// --- Template helpers ---\n  1202â†’\n  1203â†’func stateColor(state domain.RunState) string {\n  1204â†’\tswitch state {\n  1205â†’\tcase domain.RunStatePending:\n  1206â†’\t\treturn \"pending\"\n  1207â†’\tcase domain.RunStateRunning:\n  1208â†’\t\treturn \"running\"\n  1209â†’\tcase domain.RunStateSucceeded:\n  1210â†’\t\treturn \"succeeded\"\n  1211â†’\tcase domain.RunStateFailed:\n  1212â†’\t\treturn \"failed\"\n  1213â†’\tcase domain.RunStateCancelled:\n  1214â†’\t\treturn \"cancelled\"\n  1215â†’\tdefault:\n  1216â†’\t\treturn \"pending\"\n  1217â†’\t}\n  1218â†’}\n  1219â†’\n  1220â†’func healthColor(status domain.HealthStatus) string {\n  1221â†’\tswitch status {\n  1222â†’\tcase domain.HealthGreen:\n  1223â†’\t\treturn \"green\"\n  1224â†’\tcase domain.HealthYellow:\n  1225â†’\t\treturn \"yellow\"\n  1226â†’\tcase domain.HealthRed:\n  1227â†’\t\treturn \"red\"\n  1228â†’\tcase domain.HealthBlue:\n  1229â†’\t\treturn \"blue\"\n  1230â†’\tdefault:\n  1231â†’\t\treturn \"grey\"\n  1232â†’\t}\n  1233â†’}\n  1234â†’\n  1235â†’func formatTime(t time.Time) string {\n  1236â†’\tif t.IsZero() {\n  1237â†’\t\treturn \"\"\n  1238â†’\t}\n  1239â†’\treturn t.Format(\"2006-01-02 15:04:05\")\n  1240â†’}\n  1241â†’\n  1242â†’func formatDuration(start, end time.Time) string {\n  1243â†’\tif start.IsZero() || end.IsZero() {\n  1244â†’\t\treturn \"\"\n  1245â†’\t}\n  1246â†’\td := end.Sub(start)\n  1247â†’\tif d < time.Second {\n  1248â†’\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1249â†’\t}\n  1250â†’\tif d < time.Minute {\n  1251â†’\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1252â†’\t}\n  1253â†’\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1254â†’}\n  1255â†’\n  1256â†’func truncate(s string, n int) string {\n  1257â†’\tif len(s) <= n {\n  1258â†’\t\treturn s\n  1259â†’\t}\n  1260â†’\treturn s[:n] + \"...\"\n  1261â†’}\n  1262â†’\n  1263â†’func shortContainerID(id string) string {\n  1264â†’\tif len(id) > 12 {\n  1265â†’\t\treturn id[:12]\n  1266â†’\t}\n  1267â†’\treturn id\n  1268â†’}\n  1269â†’\n  1270â†’// projectLabels builds a mapping from full project directory paths to short\n  1271â†’// display labels. Each label is the final directory component (e.g.\n  1272â†’// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1273â†’// the same final name, the parent directory is prepended to disambiguate\n  1274â†’// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1275â†’func projectLabels(dirs []string) map[string]string {\n  1276â†’\tlabels := make(map[string]string, len(dirs))\n  1277â†’\t// Group dirs by their base name to detect conflicts.\n  1278â†’\tbyBase := map[string][]string{}\n  1279â†’\tfor _, d := range dirs {\n  1280â†’\t\tbase := filepath.Base(d)\n  1281â†’\t\tbyBase[base] = append(byBase[base], d)\n  1282â†’\t}\n  1283â†’\tfor base, paths := range byBase {\n  1284â†’\t\tif len(paths) == 1 {\n  1285â†’\t\t\tlabels[paths[0]] = base\n  1286â†’\t\t} else {\n  1287â†’\t\t\tfor _, p := range paths {\n  1288â†’\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1289â†’\t\t\t\tlabels[p] = parent + \"/\" + base\n  1290â†’\t\t\t}\n  1291â†’\t\t}\n  1292â†’\t}\n  1293â†’\treturn labels\n  1294â†’}\n  1295â†’\n  1296â†’type projectEntry struct {\n  1297â†’\tDir            string\n  1298â†’\tLabel          string\n  1299â†’\tContainerCount int\n  1300â†’}\n  1301â†’"}]},"parent_tool_use_id":"toolu_01XmsoFPf1VhjJETg2su8ZXX","session_id":"b45cf3d1-b3cb-4cc4-9a8b-9d828c396ebb","uuid":"20c19f61-aa39-4363-8ee1-5bb8224498d6"}
