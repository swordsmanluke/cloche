d-text: #9ca3af;\n    51→\n    52→        --error-bg: #450a0a;\n    53→        --error-border: #7f1d1d;\n    54→        --error-text: #fca5a5;\n    55→    }\n    56→}\n    57→\n    58→*, *::before, *::after { box-sizing: border-box; }\n    59→\n    60→body {\n    61→    margin: 0;\n    62→    font-family: var(--font);\n    63→    background: var(--bg);\n    64→    color: var(--text);\n    65→    line-height: 1.5;\n    66→}\n    67→\n    68→.container {\n    69→    max-width: 1100px;\n    70→    margin: 0 auto;\n    71→    padding: 0 1rem;\n    72→}\n    73→\n    74→a { color: var(--link); text-decoration: none; }\n    75→a:hover { text-decoration: underline; }\n    76→\n    77→.navbar {\n    78→    background: var(--bg-surface);\n    79→    border-bottom: 1px solid var(--border);\n    80→    padding: 0.75rem 0;\n    81→    margin-bottom: 1.5rem;\n    82→}\n    83→\n    84→.logo {\n    85→    font-weight: 700;\n    86→    font-size: 1.1rem;\n    87→    color: var(--text);\n    88→}\n    89→.logo:hover { text-decoration: none; }\n    90→\n    91→h1 {\n    92→    font-size: 1.4rem;\n    93→    margin: 0 0 1rem;\n    94→    display: flex;\n    95→    align-items: center;\n    96→    gap: 0.5rem;\n    97→    flex-wrap: wrap;\n    98→}\n    99→\n   100→h1 a { font-weight: 400; }\n   101→\n   102→h2 {\n   103→    font-size: 1.1rem;\n   104→    margin: 1.5rem 0 0.75rem;\n   105→}\n   106→\n   107→/* Badges */\n   108→.badge {\n   109→    display: inline-block;\n   110→    padding: 0.15em 0.55em;\n   111→    border-radius: var(--radius);\n   112→    font-size: 0.8rem;\n   113→    font-weight: 600;\n   114→    white-space: nowrap;\n   115→}\n   116→\n   117→.badge-pending  { background: var(--badge-pending-bg);  color: var(--badge-pending-text); }\n   118→.badge-running  { background: var(--badge-running-bg);  color: var(--badge-running-text); animation: pulse 2s infinite; }\n   119→.badge-succeeded { background: var(--badge-succeeded-bg); color: var(--badge-succeeded-text); 