[2026-03-09T00:46:12Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019ixPQdC3ZGxM2c6TjAhrPU","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"os/exec\"\n    14→\t\"path/filepath\"\n    15→\t\"regexp\"\n    16→\t\"sort\"\n    17→\t\"strconv\"\n    18→\t\"strings\"\n    19→\t\"time\"\n    20→\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→)\n    26→\n    27→// HandlerOption configures optional Handler dependencies.\n    28→type HandlerOption func(*Handler)\n    29→\n    30→// WithContainerLogger sets the container runtime for fetching live logs.\n    31→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32→\treturn func(h *Handler) { h.container = c }\n    33→}\n    34→\n    35→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36→func WithContainerManager(c ContainerManager) HandlerOption {\n    37→\treturn func(h *Handler) { h.container = c }\n    38→}\n    39→\n    40→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42→\treturn func(h *Handler) { h.logBroadcast = b }\n    43→}\n    44→\n    45→// WithLogStore sets the log store for indexed log file lookups.\n    46→func WithLogStore(ls ports.LogStore) HandlerOption {\n    47→\treturn func(h *Handler) { h.logStore = ls }\n    48→}\n    49→\n    50→// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    51→func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    52→\treturn func(h *Handler) { h.orchestrateFn = fn }\n    53→}\n    54→\n    55→// OrchestratorController provides per-project orchestrator control.\n    56→type OrchestratorController interface {\n    57→\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    58→\tSetEnabled(dir string, enabled bool)\n    59→\tSetConcurrency(dir string, concurrency int)\n    60→}\n    61→\n    62→// WithOrchestrator sets the orchestrator controller for project-level control.\n    63→func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    64→\treturn func(h *Handler) { h.orchestrator = oc }\n    65→}\n    66→\n    67→//go:embed templates/*.html static/*\n    68→var content embed.FS\n    69→\n    70→// Handler serves the web dashboard.\n    71→// ContainerLogger can retrieve logs from a container by ID.\n    72→type ContainerLogger interface {\n    73→\tLogs(ctx context.Context, containerID string) (string, error)\n    74→}\n    75→\n    76→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    77→type ContainerManager interface {\n    78→\tContainerLogger\n    79→\tRemove(ctx context.Context, containerID string) error\n    80→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    81→}\n    82→\n    83→type Handler struct {\n    84→\tstore         ports.RunStore\n    85→\tcaptures      ports.CaptureStore\n    86→\tlogStore      ports.LogStore\n    87→\tcontainer     ContainerLogger\n    88→\tlogBroadcast  *logstream.Broadcaster\n    89→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    90→\torchestrator  OrchestratorController\n    91→\tpages         map[string]*template.Template\n    92→\tmux           *http.ServeMux\n    93→}\n    94→\n    95→// NewHandler creates a web dashboard handler.\n    96→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    97→\tfuncMap := template.FuncMap{\n    98→\t\t\"stateColor\":       stateColor,\n    99→\t\t\"healthColor\":      healthColor,\n   100→\t\t\"formatTime\":       formatTime,\n   101→\t\t\"formatDuration\":   formatDuration,\n   102→\t\t\"truncate\":         truncate,\n   103→\t\t\"shortContainerID\": shortContainerID,\n   104→\t}\n   105→\n   106→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   107→\tif err != nil {\n   108→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   109→\t}\n   110→\n   111→\tpages := map[string]*template.Template{}\n   112→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   113→\t\tclone, err := base.Clone()\n   114→\t\tif err != nil {\n   115→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   116→\t\t}\n   117→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   118→\t\tif err != nil {\n   119→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   120→\t\t}\n   121→\t\tpages[page] = clone\n   122→\t}\n   123→\n   124→\th := &Handler{\n   125→\t\tstore:    store,\n   126→\t\tcaptures: captures,\n   127→\t\tpages:    pages,\n   128→\t\tmux:      http.NewServeMux(),\n   129→\t}\n   130→\tfor _, opt := range opts {\n   131→\t\topt(h)\n   132→\t}\n   133→\n   134→\tstaticFS, err := fs.Sub(content, \"static\")\n   135→\tif err != nil {\n   136→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   137→\t}\n   138→\n   139→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   140→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   141→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   142→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   143→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   144→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   145→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   146→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   147→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   148→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   149→\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   150→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   151→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   152→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   153→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   154→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   155→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-content\", h.handleAPIPromptContent)\n   156→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   157→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   158→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   159→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   160→\n   161→\treturn h, nil\n   162→}\n   163→\n   164→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   165→\th.mux.ServeHTTP(w, r)\n   166→}\n   167→\n   168→// --- HTML handlers ---\n   169→\n   170→// projectOverviewEntry holds data for a single project card on the landing page.\n   171→type projectOverviewEntry struct {\n   172→\tDir         string\n   173→\tLabel       string\n   174→\tHealth      domain.HealthResult\n   175→\tRecentRuns  []recentRunDot\n   176→\tActiveCount int\n   177→}\n   178→\n   179→// recentRunDot is a minimal representation of a run for the mini history display.\n   180→type recentRunDot struct {\n   181→\tID    string\n   182→\tState string\n   183→}\n   184→\n   185→const healthWindowSize = 10\n   186→\n   187→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   188→\tprojects, _ := h.store.ListProjects(r.Context())\n   189→\tlabels := projectLabels(projects)\n   190→\n   191→\tvar entries []projectOverviewEntry\n   192→\tfor _, dir := range projects {\n   193→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   194→\t\tif err != nil {\n   195→\t\t\tcontinue\n   196→\t\t}\n   197→\n   198→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   199→\t\trunValues := make([]domain.Run, len(runs))\n   200→\t\tfor i, rr := range runs {\n   201→\t\t\trunValues[i] = *rr\n   202→\t\t}\n   203→\n   204→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   205→\n   206→\t\t// Take the last N runs for the mini history (most recent first).\n   207→\t\tn := healthWindowSize\n   208→\t\tif n > len(runs) {\n   209→\t\t\tn = len(runs)\n   210→\t\t}\n   211→\t\tdots := make([]recentRunDot, n)\n   212→\t\tfor i := 0; i < n; i++ {\n   213→\t\t\tdots[i] = recentRunDot{\n   214→\t\t\t\tID:    runs[i].ID,\n   215→\t\t\t\tState: string(runs[i].State),\n   216→\t\t\t}\n   217→\t\t}\n   218→\n   219→\t\tvar activeCount int\n   220→\t\tfor _, rr := range runs {\n   221→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   222→\t\t\t\tactiveCount++\n   223→\t\t\t}\n   224→\t\t}\n   225→\n   226→\t\tentries = append(entries, projectOverviewEntry{\n   227→\t\t\tDir:         dir,\n   228→\t\t\tLabel:       labels[dir],\n   229→\t\t\tHealth:      health,\n   230→\t\t\tRecentRuns:  dots,\n   231→\t\t\tActiveCount: activeCount,\n   232→\t\t})\n   233→\t}\n   234→\n   235→\tsort.Slice(entries, func(i, j int) bool {\n   236→\t\treturn entries[i].Label < entries[j].Label\n   237→\t})\n   238→\n   239→\tdata := map[string]any{\n   240→\t\t\"Title\":    \"Projects\",\n   241→\t\t\"Projects\": entries,\n   242→\t}\n   243→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   244→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   245→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   246→\t}\n   247→}\n   248→\n   249→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   250→\tprojectFilter := r.URL.Query().Get(\"project\")\n   251→\n   252→\tvar runs []*domain.Run\n   253→\tvar err error\n   254→\tif projectFilter != \"\" {\n   255→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   256→\t} else {\n   257→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   258→\t}\n   259→\tif err != nil {\n   260→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   261→\t\treturn\n   262→\t}\n   263→\n   264→\tprojects, _ := h.store.ListProjects(r.Context())\n   265→\tlabels := projectLabels(projects)\n   266→\n   267→\t// Count retained containers per project\n   268→\tcontainerCounts := map[string]int{}\n   269→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   270→\tfor _, run := range allRuns {\n   271→\t\tif run.ContainerKept {\n   272→\t\t\tcontainerCounts[run.ProjectDir]++\n   273→\t\t}\n   274→\t}\n   275→\n   276→\tvar projectList []projectEntry\n   277→\tfor _, dir := range projects {\n   278→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   279→\t}\n   280→\tsort.Slice(projectList, func(i, j int) bool {\n   281→\t\treturn projectList[i].Label < projectList[j].Label\n   282→\t})\n   283→\n   284→\tdata := map[string]any{\n   285→\t\t\"Title\":         \"Runs\",\n   286→\t\t\"Runs\":          runs,\n   287→\t\t\"Projects\":      projectList,\n   288→\t\t\"ProjectFilter\": projectFilter,\n   289→\t\t\"ProjectLabels\": labels,\n   290→\t}\n   291→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   292→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   293→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   294→\t}\n   295→}\n   296→\n   297→// stepEntry is a merged view of a step execution for the template.\n   298→type stepEntry struct {\n   299→\tIndex     int\n   300→\tStepName  string\n   301→\tResult    string\n   302→\tStartedAt time.Time\n   303→\tDuration  string\n   304→}\n   305→\n   306→// mergeCaptures collapses started/completed capture pairs into single entries.\n   307→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   308→\tvar entries []stepEntry\n   309→\t// Track pending started rows by step name (LIFO for retries)\n   310→\tpending := map[string]*domain.StepExecution{}\n   311→\n   312→\tfor _, c := range caps {\n   313→\t\tif c.Result == \"\" {\n   314→\t\t\t// step_started row\n   315→\t\t\tpending[c.StepName] = c\n   316→\t\t\tcontinue\n   317→\t\t}\n   318→\t\t// step_completed row — merge with pending started if available\n   319→\t\tstartedAt := c.StartedAt\n   320→\t\tif started := pending[c.StepName]; started != nil {\n   321→\t\t\tstartedAt = started.StartedAt\n   322→\t\t\tdelete(pending, c.StepName)\n   323→\t\t}\n   324→\t\tentries = append(entries, stepEntry{\n   325→\t\t\tIndex:     len(entries),\n   326→\t\t\tStepName:  c.StepName,\n   327→\t\t\tResult:    c.Result,\n   328→\t\t\tStartedAt: startedAt,\n   329→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   330→\t\t})\n   331→\t}\n   332→\n   333→\t// Append any started-but-not-completed steps (still running)\n   334→\tfor _, c := range caps {\n   335→\t\tif c.Result == \"\" {\n   336→\t\t\tif _, used := pending[c.StepName]; !used {\n   337→\t\t\t\tcontinue\n   338→\t\t\t}\n   339→\t\t\tentries = append(entries, stepEntry{\n   340→\t\t\t\tIndex:     len(entries),\n   341→\t\t\t\tStepName:  c.StepName,\n   342→\t\t\t\tStartedAt: c.StartedAt,\n   343→\t\t\t})\n   344→\t\t\tdelete(pending, c.StepName)\n   345→\t\t}\n   346→\t}\n   347→\n   348→\treturn entries\n   349→}\n   350→\n   351→// containerState inspects the container for a run and returns one of:\n   352→//   - \"running\"   – container exists and is running\n   353→//   - \"stopped\"   – container exists, not running, not kept\n   354→//   - \"available\" – container exists, not running, kept (can be deleted)\n   355→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   356→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   357→\tif run.ContainerID == \"\" {\n   358→\t\treturn \"removed\"\n   359→\t}\n   360→\tmgr, ok := h.container.(ContainerManager)\n   361→\tif !ok {\n   362→\t\treturn \"removed\"\n   363→\t}\n   364→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   365→\tif err != nil {\n   366→\t\treturn \"removed\"\n   367→\t}\n   368→\tif status.Running {\n   369→\t\treturn \"running\"\n   370→\t}\n   371→\tif run.ContainerKept {\n   372→\t\treturn \"available\"\n   373→\t}\n   374→\treturn \"stopped\"\n   375→}\n   376→\n   377→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   378→\tid := r.PathValue(\"id\")\n   379→\n   380→\trun, err := h.store.GetRun(r.Context(), id)\n   381→\tif err != nil {\n   382→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   383→\t\treturn\n   384→\t}\n   385→\n   386→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   387→\tif err != nil {\n   388→\t\tcaps = nil // non-fatal\n   389→\t}\n   390→\n   391→\tsteps := mergeCaptures(caps)\n   392→\n   393→\tdata := map[string]any{\n   394→\t\t\"Title\":          \"Run \" + run.ID,\n   395→\t\t\"Run\":            run,\n   396→\t\t\"Steps\":          steps,\n   397→\t\t\"Page\":           \"detail\",\n   398→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   399→\t}\n   400→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   401→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   402→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   403→\t}\n   404→}\n   405→\n   406→// --- JSON API handlers ---\n   407→\n   408→type apiRun struct {\n   409→\tID           string `json:\"id\"`\n   410→\tWorkflowName string `json:\"workflow_name\"`\n   411→\tProjectDir   string `json:\"project_dir\"`\n   412→\tProjectLabel string `json:\"project_label\"`\n   413→\tState        string `json:\"state\"`\n   414→\tStartedAt    string `json:\"started_at\"`\n   415→\tCompletedAt  string `json:\"completed_at\"`\n   416→\tContainerID  string `json:\"container_id\"`\n   417→\tErrorMessage string `json:\"error_message\"`\n   418→}\n   419→\n   420→type apiStep struct {\n   421→\tStepName    string `json:\"step_name\"`\n   422→\tResult      string `json:\"result\"`\n   423→\tStartedAt   string `json:\"started_at\"`\n   424→\tCompletedAt string `json:\"completed_at\"`\n   425→\tDuration    string `json:\"duration\"`\n   426→}\n   427→\n   428→type apiRunDetail struct {\n   429→\tapiRun\n   430→\tContainerState string    `json:\"container_state\"`\n   431→\tSteps          []apiStep `json:\"steps\"`\n   432→}\n   433→\n   434→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   435→\treturn apiRun{\n   436→\t\tID:           r.ID,\n   437→\t\tWorkflowName: r.WorkflowName,\n   438→\t\tProjectDir:   r.ProjectDir,\n   439→\t\tProjectLabel: labels[r.ProjectDir],\n   440→\t\tState:        string(r.State),\n   441→\t\tStartedAt:    formatTime(r.StartedAt),\n   442→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   443→\t\tContainerID:  r.ContainerID,\n   444→\t\tErrorMessage: r.ErrorMessage,\n   445→\t}\n   446→}\n   447→\n   448→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   449→\tprojectFilter := r.URL.Query().Get(\"project\")\n   450→\n   451→\tvar runs []*domain.Run\n   452→\tvar err error\n   453→\tif projectFilter != \"\" {\n   454→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   455→\t} else {\n   456→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   457→\t}\n   458→\tif err != nil {\n   459→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   460→\t\treturn\n   461→\t}\n   462→\n   463→\tprojects, _ := h.store.ListProjects(r.Context())\n   464→\tlabels := projectLabels(projects)\n   465→\n   466→\tresult := make([]apiRun, len(runs))\n   467→\tfor i, run := range runs {\n   468→\t\tresult[i] = toAPIRun(run, labels)\n   469→\t}\n   470→\n   471→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   472→\tjson.NewEncoder(w).Encode(result)\n   473→}\n   474→\n   475→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   476→\tprojects, err := h.store.ListProjects(r.Context())\n   477→\tif err != nil {\n   478→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   479→\t\treturn\n   480→\t}\n   481→\tlabels := projectLabels(projects)\n   482→\n   483→\ttype apiHealth struct {\n   484→\t\tStatus string `json:\"status\"`\n   485→\t\tPassed int    `json:\"passed\"`\n   486→\t\tFailed int    `json:\"failed\"`\n   487→\t\tTotal  int    `json:\"total\"`\n   488→\t}\n   489→\ttype apiProject struct {\n   490→\t\tDir         string    `json:\"dir\"`\n   491→\t\tLabel       string    `json:\"label\"`\n   492→\t\tHealth      apiHealth `json:\"health\"`\n   493→\t\tActiveCount int       `json:\"active_count\"`\n   494→\t}\n   495→\tresult := make([]apiProject, len(projects))\n   496→\tfor i, dir := range projects {\n   497→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   498→\t\trunValues := make([]domain.Run, len(runs))\n   499→\t\tfor j, rr := range runs {\n   500→\t\t\trunValues[j] = *rr\n   501→\t\t}\n   502→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   503→\t\tvar activeCount int\n   504→\t\tfor _, rr := range runs {\n   505→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   506→\t\t\t\tactiveCount++\n   507→\t\t\t}\n   508→\t\t}\n   509→\t\tresult[i] = apiProject{\n   510→\t\t\tDir:   dir,\n   511→\t\t\tLabel: labels[dir],\n   512→\t\t\tHealth: apiHealth{\n   513→\t\t\t\tStatus: string(health.Status),\n   514→\t\t\t\tPassed: health.Passed,\n   515→\t\t\t\tFailed: health.Failed,\n   516→\t\t\t\tTotal:  health.Total,\n   517→\t\t\t},\n   518→\t\t\tActiveCount: activeCount,\n   519→\t\t}\n   520→\t}\n   521→\n   522→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   523→\tjson.NewEncoder(w).Encode(result)\n   524→}\n   525→\n   526→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   527→\tid := r.PathValue(\"id\")\n   528→\n   529→\trun, err := h.store.GetRun(r.Context(), id)\n   530→\tif err != nil {\n   531→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   532→\t\treturn\n   533→\t}\n   534→\n   535→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   536→\tif err != nil {\n   537→\t\tcaps = nil\n   538→\t}\n   539→\n   540→\tprojects, _ := h.store.ListProjects(r.Context())\n   541→\tlabels := projectLabels(projects)\n   542→\n   543→\tmerged := mergeCaptures(caps)\n   544→\tsteps := make([]apiStep, len(merged))\n   545→\tfor i, e := range merged {\n   546→\t\tsteps[i] = apiStep{\n   547→\t\t\tStepName:  e.StepName,\n   548→\t\t\tResult:    e.Result,\n   549→\t\t\tStartedAt: formatTime(e.StartedAt),\n   550→\t\t\tDuration:  e.Duration,\n   551→\t\t}\n   552→\t}\n   553→\n   554→\tdetail := apiRunDetail{\n   555→\t\tapiRun:         toAPIRun(run, labels),\n   556→\t\tContainerState: h.containerState(r.Context(), run),\n   557→\t\tSteps:          steps,\n   558→\t}\n   559→\n   560→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   561→\tjson.NewEncoder(w).Encode(detail)\n   562→}\n   563→\n   564→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   565→\tid := r.PathValue(\"id\")\n   566→\tstep := r.PathValue(\"step\")\n   567→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   568→\n   569→\trun, err := h.store.GetRun(r.Context(), id)\n   570→\tif err != nil {\n   571→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   572→\t\treturn\n   573→\t}\n   574→\n   575→\t// Try log index first for fast lookup\n   576→\tif h.logStore != nil {\n   577→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   578→\t\tif err == nil && len(logFiles) > 0 {\n   579→\t\t\t// If type filter specified, narrow results\n   580→\t\t\tfor _, lf := range logFiles {\n   581→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   582→\t\t\t\t\tcontinue\n   583→\t\t\t\t}\n   584→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   585→\t\t\t\tif readErr == nil && len(data) > 0 {\n   586→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   587→\t\t\t\t\tw.Write(data)\n   588→\t\t\t\t\treturn\n   589→\t\t\t\t}\n   590→\t\t\t}\n   591→\t\t}\n   592→\t}\n   593→\n   594→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   595→\n   596→\t// Fall back to file path conventions\n   597→\t// If type is \"llm\", try llm-<step>.log\n   598→\tif logType == \"llm\" {\n   599→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   600→\t\tdata, err := os.ReadFile(llmPath)\n   601→\t\tif err == nil && len(data) > 0 {\n   602→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   603→\t\t\tw.Write(data)\n   604→\t\t\treturn\n   605→\t\t}\n   606→\t}\n   607→\n   608→\t// Try per-step output first, fall back to container.log, then live docker logs\n   609→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   610→\tdata, err := os.ReadFile(outputPath)\n   611→\tif err == nil && len(data) > 0 {\n   612→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   613→\t\tw.Write(data)\n   614→\t\treturn\n   615→\t}\n   616→\n   617→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   618→\tdata, err = os.ReadFile(containerLog)\n   619→\tif err == nil && len(data) > 0 {\n   620→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   621→\t\tw.Write(data)\n   622→\t\treturn\n   623→\t}\n   624→\n   625→\t// Last resort: try live docker logs from still-existing container\n   626→\tif h.container != nil && run.ContainerID != \"\" {\n   627→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   628→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   629→\t\t\tw.Write([]byte(logs))\n   630→\t\t\treturn\n   631→\t\t}\n   632→\t}\n   633→\n   634→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   635→}\n   636→\n   637→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   638→\tid := r.PathValue(\"id\")\n   639→\n   640→\trun, err := h.store.GetRun(r.Context(), id)\n   641→\tif err != nil {\n   642→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   643→\t\tw.WriteHeader(http.StatusNotFound)\n   644→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   645→\t\treturn\n   646→\t}\n   647→\n   648→\tmgr, ok := h.container.(ContainerManager)\n   649→\tif !ok || run.ContainerID == \"\" {\n   650→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   651→\t\tw.WriteHeader(http.StatusBadRequest)\n   652→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   653→\t\treturn\n   654→\t}\n   655→\n   656→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   657→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   658→\t\tw.WriteHeader(http.StatusInternalServerError)\n   659→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   660→\t\treturn\n   661→\t}\n   662→\n   663→\trun.ContainerKept = false\n   664→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   665→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   666→\t\tw.WriteHeader(http.StatusInternalServerError)\n   667→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   668→\t\treturn\n   669→\t}\n   670→\n   671→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   672→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   673→}\n   674→\n   675→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   676→\tlabel := r.PathValue(\"name\")\n   677→\n   678→\t// Resolve label back to project directory via the store.\n   679→\tprojects, _ := h.store.ListProjects(r.Context())\n   680→\tlabels := projectLabels(projects)\n   681→\tvar projectDir string\n   682→\tfor dir, l := range labels {\n   683→\t\tif l == label {\n   684→\t\t\tprojectDir = dir\n   685→\t\t\tbreak\n   686→\t\t}\n   687→\t}\n   688→\tif projectDir == \"\" {\n   689→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   690→\t\tw.WriteHeader(http.StatusNotFound)\n   691→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   692→\t\treturn\n   693→\t}\n   694→\n   695→\tif h.orchestrateFn == nil {\n   696→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   697→\t\tw.WriteHeader(http.StatusNotImplemented)\n   698→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   699→\t\treturn\n   700→\t}\n   701→\n   702→\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   703→\tif err != nil {\n   704→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   705→\t\tw.WriteHeader(http.StatusInternalServerError)\n   706→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   707→\t\treturn\n   708→\t}\n   709→\n   710→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   711→\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   712→}\n   713→\n   714→// handleAPIStream serves an SSE stream of log lines for a run.\n   715→// For active runs, it subscribes to the live broadcaster.\n   716→// For completed runs, it serves the archived full.log then closes.\n   717→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   718→\tid := r.PathValue(\"id\")\n   719→\n   720→\trun, err := h.store.GetRun(r.Context(), id)\n   721→\tif err != nil {\n   722→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   723→\t\treturn\n   724→\t}\n   725→\n   726→\tflusher, ok := w.(http.Flusher)\n   727→\tif !ok {\n   728→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   729→\t\treturn\n   730→\t}\n   731→\n   732→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   733→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   734→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   735→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   736→\n   737→\tisComplete := run.State == domain.RunStateSucceeded ||\n   738→\t\trun.State == domain.RunStateFailed ||\n   739→\t\trun.State == domain.RunStateCancelled\n   740→\n   741→\tif isComplete {\n   742→\t\t// Serve archived full.log\n   743→\t\th.streamFullLog(w, flusher, run)\n   744→\t\t// Send done event\n   745→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   746→\t\tflusher.Flush()\n   747→\t\treturn\n   748→\t}\n   749→\n   750→\t// Active run: subscribe to live broadcaster\n   751→\tif h.logBroadcast == nil {\n   752→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   753→\t\treturn\n   754→\t}\n   755→\n   756→\tsub := h.logBroadcast.Subscribe(id)\n   757→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   758→\n   759→\tctx := r.Context()\n   760→\tfor {\n   761→\t\tselect {\n   762→\t\tcase <-ctx.Done():\n   763→\t\t\treturn\n   764→\t\tcase line, ok := <-sub.C:\n   765→\t\t\tif !ok {\n   766→\t\t\t\t// Stream finished (run completed)\n   767→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   768→\t\t\t\tflusher.Flush()\n   769→\t\t\t\treturn\n   770→\t\t\t}\n   771→\t\t\tdata, _ := json.Marshal(line)\n   772→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   773→\t\t\tflusher.Flush()\n   774→\t\t}\n   775→\t}\n   776→}\n   777→\n   778→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   779→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   780→\n   781→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   782→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   783→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   784→\tf, err := os.Open(logPath)\n   785→\tif err != nil {\n   786→\t\treturn\n   787→\t}\n   788→\tdefer f.Close()\n   789→\n   790→\tscanner := bufio.NewScanner(f)\n   791→\tfor scanner.Scan() {\n   792→\t\ttext := scanner.Text()\n   793→\t\tline := parseFullLogLine(text)\n   794→\t\tdata, _ := json.Marshal(line)\n   795→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   796→\t\tflusher.Flush()\n   797→\t}\n   798→}\n   799→\n   800→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   801→func parseFullLogLine(text string) logstream.LogLine {\n   802→\tm := logLineRegex.FindStringSubmatch(text)\n   803→\tif m == nil {\n   804→\t\treturn logstream.LogLine{\n   805→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   806→\t\t\tType:      \"script\",\n   807→\t\t\tContent:   text,\n   808→\t\t}\n   809→\t}\n   810→\treturn logstream.LogLine{\n   811→\t\tTimestamp: m[1],\n   812→\t\tType:      m[2],\n   813→\t\tContent:   m[3],\n   814→\t}\n   815→}\n   816→\n   817→// --- Project detail handlers ---\n   818→\n   819→// resolveProjectDir resolves a project label from the URL to its directory path.\n   820→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   821→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   822→\tlabel := r.PathValue(\"name\")\n   823→\tprojects, _ := h.store.ListProjects(r.Context())\n   824→\tlabels := projectLabels(projects)\n   825→\tfor dir, l := range labels {\n   826→\t\tif l == label {\n   827→\t\t\treturn dir, label, true\n   828→\t\t}\n   829→\t}\n   830→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   831→\tw.WriteHeader(http.StatusNotFound)\n   832→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   833→\treturn \"\", \"\", false\n   834→}\n   835→\n   836→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   837→\tdir, label, ok := h.resolveProjectDir(w, r)\n   838→\tif !ok {\n   839→\t\treturn\n   840→\t}\n   841→\n   842→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   843→\tn := 10\n   844→\tif n > len(runs) {\n   845→\t\tn = len(runs)\n   846→\t}\n   847→\tdots := make([]recentRunDot, n)\n   848→\tfor i := 0; i < n; i++ {\n   849→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   850→\t}\n   851→\n   852→\tdata := map[string]any{\n   853→\t\t\"Title\":      label,\n   854→\t\t\"Label\":      label,\n   855→\t\t\"Dir\":        dir,\n   856→\t\t\"RecentRuns\": dots,\n   857→\t}\n   858→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   859→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   860→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   861→\t}\n   862→}\n   863→\n   864→func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   865→\tdir, _, ok := h.resolveProjectDir(w, r)\n   866→\tif !ok {\n   867→\t\treturn\n   868→\t}\n   869→\tif h.orchestrator == nil {\n   870→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   871→\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   872→\t\treturn\n   873→\t}\n   874→\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   875→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   876→\tjson.NewEncoder(w).Encode(map[string]any{\n   877→\t\t\"enabled\":     enabled,\n   878→\t\t\"in_flight\":   inFlight,\n   879→\t\t\"concurrency\": concurrency,\n   880→\t})\n   881→}\n   882→\n   883→func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   884→\tdir, _, ok := h.resolveProjectDir(w, r)\n   885→\tif !ok {\n   886→\t\treturn\n   887→\t}\n   888→\tif h.orchestrator == nil {\n   889→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   890→\t\tw.WriteHeader(http.StatusNotImplemented)\n   891→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   892→\t\treturn\n   893→\t}\n   894→\th.orchestrator.SetEnabled(dir, true)\n   895→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   896→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   897→}\n   898→\n   899→func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   900→\tdir, _, ok := h.resolveProjectDir(w, r)\n   901→\tif !ok {\n   902→\t\treturn\n   903→\t}\n   904→\tif h.orchestrator == nil {\n   905→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   906→\t\tw.WriteHeader(http.StatusNotImplemented)\n   907→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   908→\t\treturn\n   909→\t}\n   910→\th.orchestrator.SetEnabled(dir, false)\n   911→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   912→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   913→}\n   914→\n   915→func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   916→\tdir, _, ok := h.resolveProjectDir(w, r)\n   917→\tif !ok {\n   918→\t\treturn\n   919→\t}\n   920→\tif h.orchestrator == nil {\n   921→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   922→\t\tw.WriteHeader(http.StatusNotImplemented)\n   923→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   924→\t\treturn\n   925→\t}\n   926→\tvar body struct {\n   927→\t\tConcurrency int `json:\"concurrency\"`\n   928→\t}\n   929→\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n   930→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   931→\t\tw.WriteHeader(http.StatusBadRequest)\n   932→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n   933→\t\treturn\n   934→\t}\n   935→\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n   936→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   937→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   938→}\n   939→\n   940→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   941→\tdir, _, ok := h.resolveProjectDir(w, r)\n   942→\tif !ok {\n   943→\t\treturn\n   944→\t}\n   945→\n   946→\t// Docker image: read FROM line from Dockerfile\n   947→\tdockerImage := \"\"\n   948→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   949→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   950→\t\t// Find the last FROM line (final stage)\n   951→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   952→\t\t\ttrimmed := strings.TrimSpace(line)\n   953→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   954→\t\t\t\tparts := strings.Fields(trimmed)\n   955→\t\t\t\tif len(parts) >= 2 {\n   956→\t\t\t\t\tdockerImage = parts[1]\n   957→\t\t\t\t}\n   958→\t\t\t}\n   959→\t\t}\n   960→\t}\n   961→\n   962→\t// Version\n   963→\tversion := 0\n   964→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   965→\tif data, err := os.ReadFile(versionPath); err == nil {\n   966→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   967→\t\t\tversion = v\n   968→\t\t}\n   969→\t}\n   970→\n   971→\t// Prompt files history\n   972→\ttype commitEntry struct {\n   973→\t\tSHA     string `json:\"sha\"`\n   974→\t\tDate    string `json:\"date\"`\n   975→\t\tMessage string `json:\"message\"`\n   976→\t}\n   977→\ttype promptFile struct {\n   978→\t\tPath    string        `json:\"path\"`\n   979→\t\tHistory []commitEntry `json:\"history\"`\n   980→\t}\n   981→\n   982→\tvar promptFiles []promptFile\n   983→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   984→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n   985→\t\tfor _, e := range entries {\n   986→\t\t\tif e.IsDir() {\n   987→\t\t\t\tcontinue\n   988→\t\t\t}\n   989→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n   990→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n   991→\t\t\tcmd.Dir = dir\n   992→\t\t\tout, err := cmd.Output()\n   993→\t\t\tif err != nil {\n   994→\t\t\t\tcontinue\n   995→\t\t\t}\n   996→\t\t\tvar history []commitEntry\n   997→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n   998→\t\t\t\tif line == \"\" {\n   999→\t\t\t\t\tcontinue\n  1000→\t\t\t\t}\n  1001→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1002→\t\t\t\tif len(parts) < 3 {\n  1003→\t\t\t\t\tcontinue\n  1004→\t\t\t\t}\n  1005→\t\t\t\t// Parse date to short form\n  1006→\t\t\t\tdateStr := parts[1]\n  1007→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1008→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1009→\t\t\t\t}\n  1010→\t\t\t\thistory = append(history, commitEntry{\n  1011→\t\t\t\t\tSHA:     parts[0][:7],\n  1012→\t\t\t\t\tDate:    dateStr,\n  1013→\t\t\t\t\tMessage: parts[2],\n  1014→\t\t\t\t})\n  1015→\t\t\t}\n  1016→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1017→\t\t}\n  1018→\t}\n  1019→\n  1020→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1021→\tjson.NewEncoder(w).Encode(map[string]any{\n  1022→\t\t\"docker_image\": dockerImage,\n  1023→\t\t\"version\":      version,\n  1024→\t\t\"prompt_files\": promptFiles,\n  1025→\t})\n  1026→}\n  1027→\n  1028→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1029→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1030→\tif !ok {\n  1031→\t\treturn\n  1032→\t}\n  1033→\tfile := r.URL.Query().Get(\"file\")\n  1034→\tsha := r.URL.Query().Get(\"sha\")\n  1035→\tif file == \"\" || sha == \"\" {\n  1036→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1037→\t\treturn\n  1038→\t}\n  1039→\n  1040→\t// Validate sha is alphanumeric to prevent injection\n  1041→\tfor _, c := range sha {\n  1042→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1043→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1044→\t\t\treturn\n  1045→\t\t}\n  1046→\t}\n  1047→\n  1048→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1049→\tcmd.Dir = dir\n  1050→\tout, err := cmd.Output()\n  1051→\tif err != nil {\n  1052→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1053→\t\treturn\n  1054→\t}\n  1055→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1056→\tw.Write(out)\n  1057→}\n  1058→\n  1059→func (h *Handler) handleAPIPromptContent(w http.ResponseWriter, r *http.Request) {\n  1060→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1061→\tif !ok {\n  1062→\t\treturn\n  1063→\t}\n  1064→\tfile := r.URL.Query().Get(\"file\")\n  1065→\tif file == \"\" {\n  1066→\t\thttp.Error(w, \"file required\", http.StatusBadRequest)\n  1067→\t\treturn\n  1068→\t}\n  1069→\n  1070→\t// Validate file is under .cloche/prompts/ to prevent path traversal\n  1071→\tcleaned := filepath.Clean(file)\n  1072→\tif !strings.HasPrefix(cleaned, filepath.Join(\".cloche\", \"prompts\")+string(filepath.Separator)) {\n  1073→\t\thttp.Error(w, \"invalid file path\", http.StatusBadRequest)\n  1074→\t\treturn\n  1075→\t}\n  1076→\n  1077→\tdata, err := os.ReadFile(filepath.Join(dir, cleaned))\n  1078→\tif err != nil {\n  1079→\t\thttp.Error(w, \"file not found\", http.StatusNotFound)\n  1080→\t\treturn\n  1081→\t}\n  1082→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1083→\tw.Write(data)\n  1084→}\n  1085→\n  1086→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1087→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1088→\tif !ok {\n  1089→\t\treturn\n  1090→\t}\n  1091→\n  1092→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1093→\tentries, err := os.ReadDir(clocheDir)\n  1094→\tif err != nil {\n  1095→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1096→\t\tjson.NewEncoder(w).Encode([]any{})\n  1097→\t\treturn\n  1098→\t}\n  1099→\n  1100→\ttype apiWire struct {\n  1101→\t\tFrom   string `json:\"from\"`\n  1102→\t\tResult string `json:\"result\"`\n  1103→\t\tTo     string `json:\"to\"`\n  1104→\t}\n  1105→\ttype apiStepDef struct {\n  1106→\t\tName    string            `json:\"name\"`\n  1107→\t\tType    string            `json:\"type\"`\n  1108→\t\tResults []string          `json:\"results\"`\n  1109→\t\tConfig  map[string]string `json:\"config\"`\n  1110→\t}\n  1111→\ttype apiWorkflow struct {\n  1112→\t\tName      string       `json:\"name\"`\n  1113→\t\tFile      string       `json:\"file\"`\n  1114→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1115→\t\tWires     []apiWire    `json:\"wires\"`\n  1116→\t\tEntryStep string       `json:\"entry_step\"`\n  1117→\t}\n  1118→\n  1119→\tvar workflows []apiWorkflow\n  1120→\tfor _, e := range entries {\n  1121→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1122→\t\t\tcontinue\n  1123→\t\t}\n  1124→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1125→\t\tif err != nil {\n  1126→\t\t\tcontinue\n  1127→\t\t}\n  1128→\t\twf, err := dsl.Parse(string(data))\n  1129→\t\tif err != nil {\n  1130→\t\t\tcontinue\n  1131→\t\t}\n  1132→\t\tvar steps []apiStepDef\n  1133→\t\tfor _, s := range wf.Steps {\n  1134→\t\t\tsteps = append(steps, apiStepDef{\n  1135→\t\t\t\tName:    s.Name,\n  1136→\t\t\t\tType:    string(s.Type),\n  1137→\t\t\t\tResults: s.Results,\n  1138→\t\t\t\tConfig:  s.Config,\n  1139→\t\t\t})\n  1140→\t\t}\n  1141→\t\t// Sort steps by name for consistent ordering\n  1142→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1143→\n  1144→\t\tvar wires []apiWire\n  1145→\t\tfor _, wire := range wf.Wiring {\n  1146→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1147→\t\t}\n  1148→\n  1149→\t\tworkflows = append(workflows, apiWorkflow{\n  1150→\t\t\tName:      wf.Name,\n  1151→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1152→\t\t\tSteps:     steps,\n  1153→\t\t\tWires:     wires,\n  1154→\t\t\tEntryStep: wf.EntryStep,\n  1155→\t\t})\n  1156→\t}\n  1157→\n  1158→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1159→\tjson.NewEncoder(w).Encode(workflows)\n  1160→}\n  1161→\n  1162→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1163→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1164→\tif !ok {\n  1165→\t\treturn\n  1166→\t}\n  1167→\tworkflowName := r.PathValue(\"workflow\")\n  1168→\tstepName := r.PathValue(\"step\")\n  1169→\n  1170→\t// Find the workflow file\n  1171→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1172→\tvar wf *domain.Workflow\n  1173→\tentries, _ := os.ReadDir(clocheDir)\n  1174→\tfor _, e := range entries {\n  1175→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1176→\t\t\tcontinue\n  1177→\t\t}\n  1178→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1179→\t\tif err != nil {\n  1180→\t\t\tcontinue\n  1181→\t\t}\n  1182→\t\tparsed, err := dsl.Parse(string(data))\n  1183→\t\tif err != nil {\n  1184→\t\t\tcontinue\n  1185→\t\t}\n  1186→\t\tif parsed.Name == workflowName {\n  1187→\t\t\twf = parsed\n  1188→\t\t\tbreak\n  1189→\t\t}\n  1190→\t}\n  1191→\tif wf == nil {\n  1192→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1193→\t\treturn\n  1194→\t}\n  1195→\n  1196→\tstep, ok := wf.Steps[stepName]\n  1197→\tif !ok {\n  1198→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1199→\t\treturn\n  1200→\t}\n  1201→\n  1202→\t// Try to read the referenced file from step config\n  1203→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1204→\n  1205→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1206→\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1207→\t\tif err == nil {\n  1208→\t\t\tw.Write(data)\n  1209→\t\t\treturn\n  1210→\t\t}\n  1211→\t}\n  1212→\tif script := step.Config[\"command\"]; script != \"\" {\n  1213→\t\tw.Write([]byte(script))\n  1214→\t\treturn\n  1215→\t}\n  1216→\tif script := step.Config[\"script\"]; script != \"\" {\n  1217→\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1218→\t\tif err == nil {\n  1219→\t\t\tw.Write(data)\n  1220→\t\t\treturn\n  1221→\t\t}\n  1222→\t\tw.Write([]byte(script))\n  1223→\t\treturn\n  1224→\t}\n  1225→\n  1226→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1227→}\n  1228→\n  1229→// --- Template helpers ---\n  1230→\n  1231→func stateColor(state domain.RunState) string {\n  1232→\tswitch state {\n  1233→\tcase domain.RunStatePending:\n  1234→\t\treturn \"pending\"\n  1235→\tcase domain.RunStateRunning:\n  1236→\t\treturn \"running\"\n  1237→\tcase domain.RunStateSucceeded:\n  1238→\t\treturn \"succeeded\"\n  1239→\tcase domain.RunStateFailed:\n  1240→\t\treturn \"failed\"\n  1241→\tcase domain.RunStateCancelled:\n  1242→\t\treturn \"cancelled\"\n  1243→\tdefault:\n  1244→\t\treturn \"pending\"\n  1245→\t}\n  1246→}\n  1247→\n  1248→func healthColor(status domain.HealthStatus) string {\n  1249→\tswitch status {\n  1250→\tcase domain.HealthGreen:\n  1251→\t\treturn \"green\"\n  1252→\tcase domain.HealthYellow:\n  1253→\t\treturn \"yellow\"\n  1254→\tcase domain.HealthRed:\n  1255→\t\treturn \"red\"\n  1256→\tcase domain.HealthBlue:\n  1257→\t\treturn \"blue\"\n  1258→\tdefault:\n  1259→\t\treturn \"grey\"\n  1260→\t}\n  1261→}\n  1262→\n  1263→func formatTime(t time.Time) string {\n  1264→\tif t.IsZero() {\n  1265→\t\treturn \"\"\n  1266→\t}\n  1267→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1268→}\n  1269→\n  1270→func formatDuration(start, end time.Time) string {\n  1271→\tif start.IsZero() || end.IsZero() {\n  1272→\t\treturn \"\"\n  1273→\t}\n  1274→\td := end.Sub(start)\n  1275→\tif d < time.Second {\n  1276→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1277→\t}\n  1278→\tif d < time.Minute {\n  1279→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1280→\t}\n  1281→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1282→}\n  1283→\n  1284→func truncate(s string, n int) string {\n  1285→\tif len(s) <= n {\n  1286→\t\treturn s\n  1287→\t}\n  1288→\treturn s[:n] + \"...\"\n  1289→}\n  1290→\n  1291→func shortContainerID(id string) string {\n  1292→\tif len(id) > 12 {\n  1293→\t\treturn id[:12]\n  1294→\t}\n  1295→\treturn id\n  1296→}\n  1297→\n  1298→// projectLabels builds a mapping from full project directory paths to short\n  1299→// display labels. Each label is the final directory component (e.g.\n  1300→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1301→// the same final name, the parent directory is prepended to disambiguate\n  1302→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1303→func projectLabels(dirs []string) map[string]string {\n  1304→\tlabels := make(map[string]string, len(dirs))\n  1305→\t// Group dirs by their base name to detect conflicts.\n  1306→\tbyBase := map[string][]string{}\n  1307→\tfor _, d := range dirs {\n  1308→\t\tbase := filepath.Base(d)\n  1309→\t\tbyBase[base] = append(byBase[base], d)\n  1310→\t}\n  1311→\tfor base, paths := range byBase {\n  1312→\t\tif len(paths) == 1 {\n  1313→\t\t\tlabels[paths[0]] = base\n  1314→\t\t} else {\n  1315→\t\t\tfor _, p := range paths {\n  1316→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1317→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1318→\t\t\t}\n  1319→\t\t}\n  1320→\t}\n  1321→\treturn labels\n  1322→}\n  1323→\n  1324→type projectEntry struct {\n  1325→\tDir            string\n  1326→\tLabel          string\n  1327→\tContainerCount int\n  1328→}\n  1329→"}]},"parent_tool_use_id":null,"session_id":"5254cc0b-d1ce-445d-a549-63c446b20866","uuid":"5125fae0-74af-4704-9a2c-a05af68ca0b5","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\nfunc WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n\treturn func(h *Handler) { h.orchestrateFn = fn }\n}\n\n// OrchestratorController provides per-project orchestrator control.\ntype OrchestratorController interface {\n\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n\tSetEnabled(dir string, enabled bool)\n\tSetConcurrency(dir string, concurrency int)\n}\n\n// WithOrchestrator sets the orchestrator controller for project-level control.\nfunc WithOrchestrator(oc OrchestratorController) HandlerOption {\n\treturn func(h *Handler) { h.orchestrator = oc }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore         ports.RunStore\n\tcaptures      ports.CaptureStore\n\tlogStore      ports.LogStore\n\tcontainer     ContainerLogger\n\tlogBroadcast  *logstream.Broadcaster\n\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n\torchestrator  OrchestratorController\n\tpages         map[string]*template.Template\n\tmux           *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-content\", h.handleAPIPromptContent)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\n\t// Resolve label back to project directory via the store.\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tvar projectDir string\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\tprojectDir = dir\n\t\t\tbreak\n\t\t}\n\t}\n\tif projectDir == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\t\treturn\n\t}\n\n\tif h.orchestrateFn == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\n\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n\t\treturn\n\t}\n\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"enabled\":     enabled,\n\t\t\"in_flight\":   inFlight,\n\t\t\"concurrency\": concurrency,\n\t})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, true)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, false)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\tvar body struct {\n\t\tConcurrency int `json:\"concurrency\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n\t\treturn\n\t}\n\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIPromptContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tif file == \"\" {\n\t\thttp.Error(w, \"file required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate file is under .cloche/prompts/ to prevent path traversal\n\tcleaned := filepath.Clean(file)\n\tif !strings.HasPrefix(cleaned, filepath.Join(\".cloche\", \"prompts\")+string(filepath.Separator)) {\n\t\thttp.Error(w, \"invalid file path\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\tdata, err := os.ReadFile(filepath.Join(dir, cleaned))\n\tif err != nil {\n\t\thttp.Error(w, \"file not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(data)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\tif script := step.Config[\"command\"]; script != \"\" {\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1329,"startLine":1,"totalLines":1329}}}
[2026-03-09T00:46:12Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BE7DyfF2dzApXE78uF3nHE","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"net/http\"\n     8→\t\"net/http/httptest\"\n     9→\t\"os\"\n    10→\t\"path/filepath\"\n    11→\t\"testing\"\n    12→\t\"time\"\n    13→\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    17→\t\"github.com/stretchr/testify/assert\"\n    18→\t\"github.com/stretchr/testify/require\"\n    19→)\n    20→\n    21→// mockContainerManager implements ContainerManager for testing.\n    22→type mockContainerManager struct {\n    23→\tcontainers map[string]bool // containerID -> exists\n    24→\trunning    map[string]bool // containerID -> running\n    25→\tremoved    []string\n    26→}\n    27→\n    28→func newMockContainerManager() *mockContainerManager {\n    29→\treturn &mockContainerManager{\n    30→\t\tcontainers: map[string]bool{},\n    31→\t\trunning:    map[string]bool{},\n    32→\t}\n    33→}\n    34→\n    35→func (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n    36→\treturn \"mock logs\", nil\n    37→}\n    38→\n    39→func (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n    40→\tif !m.containers[containerID] {\n    41→\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n    42→\t}\n    43→\tdelete(m.containers, containerID)\n    44→\tm.removed = append(m.removed, containerID)\n    45→\treturn nil\n    46→}\n    47→\n    48→func (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n    49→\tif !m.containers[containerID] {\n    50→\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n    51→\t}\n    52→\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n    53→}\n    54→\n    55→func setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n    56→\tt.Helper()\n    57→\tstore, err := sqlite.NewStore(\":memory:\")\n    58→\trequire.NoError(t, err)\n    59→\tt.Cleanup(func() { store.Close() })\n    60→\n    61→\th, err := NewHandler(store, store)\n    62→\trequire.NoError(t, err)\n    63→\treturn h, store\n    64→}\n    65→\n    66→func seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n    67→\tt.Helper()\n    68→\tseedRunWithProject(t, store, id, workflow, state, \"\")\n    69→}\n    70→\n    71→func seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n    72→\tt.Helper()\n    73→\tctx := context.Background()\n    74→\trun := domain.NewRun(id, workflow)\n    75→\trun.ProjectDir = projectDir\n    76→\tif state != domain.RunStatePending {\n    77→\t\trun.Start()\n    78→\t\trun.ContainerID = \"abc123def456789\"\n    79→\t}\n    80→\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n    81→\t\trun.Complete(state)\n    82→\t}\n    83→\tif state == domain.RunStateFailed {\n    84→\t\trun.ErrorMessage = \"something went wrong\"\n    85→\t}\n    86→\trequire.NoError(t, store.CreateRun(ctx, run))\n    87→}\n    88→\n    89→func TestRunsList_WithRuns(t *testing.T) {\n    90→\th, store := setupHandler(t)\n    91→\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n    92→\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n    93→\n    94→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n    95→\tw := httptest.NewRecorder()\n    96→\th.ServeHTTP(w, req)\n    97→\n    98→\tassert.Equal(t, http.StatusOK, w.Code)\n    99→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   100→\tbody := w.Body.String()\n   101→\tassert.Contains(t, body, \"test-run-1\")\n   102→\tassert.Contains(t, body, \"test-run-2\")\n   103→\tassert.Contains(t, body, \"badge-running\")\n   104→\tassert.Contains(t, body, \"badge-succeeded\")\n   105→\tassert.Contains(t, body, \"develop\")\n   106→\tassert.Contains(t, body, \"deploy\")\n   107→}\n   108→\n   109→func TestRunsList_Empty(t *testing.T) {\n   110→\th, _ := setupHandler(t)\n   111→\n   112→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   113→\tw := httptest.NewRecorder()\n   114→\th.ServeHTTP(w, req)\n   115→\n   116→\tassert.Equal(t, http.StatusOK, w.Code)\n   117→\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n   118→}\n   119→\n   120→func TestRunDetail_WithCaptures(t *testing.T) {\n   121→\th, store := setupHandler(t)\n   122→\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n   123→\n   124→\tctx := context.Background()\n   125→\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n   126→\t\tStepName:    \"implement\",\n   127→\t\tResult:      \"success\",\n   128→\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n   129→\t\tCompletedAt: time.Now(),\n   130→\t}))\n   131→\n   132→\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n   133→\tw := httptest.NewRecorder()\n   134→\th.ServeHTTP(w, req)\n   135→\n   136→\tassert.Equal(t, http.StatusOK, w.Code)\n   137→\tbody := w.Body.String()\n   138→\tassert.Contains(t, body, \"run-detail-1\")\n   139→\tassert.Contains(t, body, \"implement\")\n   140→}\n   141→\n   142→func TestRunDetail_NotFound(t *testing.T) {\n   143→\th, _ := setupHandler(t)\n   144→\n   145→\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n   146→\tw := httptest.NewRecorder()\n   147→\th.ServeHTTP(w, req)\n   148→\n   149→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   150→}\n   151→\n   152→func TestAPIRuns(t *testing.T) {\n   153→\th, store := setupHandler(t)\n   154→\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n   155→\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n   156→\n   157→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   158→\tw := httptest.NewRecorder()\n   159→\th.ServeHTTP(w, req)\n   160→\n   161→\tassert.Equal(t, http.StatusOK, w.Code)\n   162→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   163→\n   164→\tvar runs []apiRun\n   165→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n   166→\tassert.Len(t, runs, 2)\n   167→\n   168→\tids := map[string]bool{}\n   169→\tfor _, r := range runs {\n   170→\t\tids[r.ID] = true\n   171→\t}\n   172→\tassert.True(t, ids[\"api-run-1\"])\n   173→\tassert.True(t, ids[\"api-run-2\"])\n   174→}\n   175→\n   176→func TestAPIRunDetail(t *testing.T) {\n   177→\th, store := setupHandler(t)\n   178→\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n   179→\n   180→\tctx := context.Background()\n   181→\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n   182→\t\tStepName:    \"build\",\n   183→\t\tResult:      \"success\",\n   184→\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n   185→\t\tCompletedAt: time.Now(),\n   186→\t}))\n   187→\n   188→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n   189→\tw := httptest.NewRecorder()\n   190→\th.ServeHTTP(w, req)\n   191→\n   192→\tassert.Equal(t, http.StatusOK, w.Code)\n   193→\n   194→\tvar detail apiRunDetail\n   195→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   196→\tassert.Equal(t, \"api-detail-1\", detail.ID)\n   197→\tassert.Equal(t, \"running\", detail.State)\n   198→\tassert.Len(t, detail.Steps, 1)\n   199→\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n   200→\tassert.NotEmpty(t, detail.Steps[0].Duration)\n   201→}\n   202→\n   203→func TestStaticCSS(t *testing.T) {\n   204→\th, _ := setupHandler(t)\n   205→\n   206→\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n   207→\tw := httptest.NewRecorder()\n   208→\th.ServeHTTP(w, req)\n   209→\n   210→\tassert.Equal(t, http.StatusOK, w.Code)\n   211→\tassert.Contains(t, w.Body.String(), \":root\")\n   212→\tassert.Contains(t, w.Body.String(), \"badge-running\")\n   213→}\n   214→\n   215→func TestHelpers(t *testing.T) {\n   216→\tt.Run(\"stateColor\", func(t *testing.T) {\n   217→\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n   218→\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n   219→\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n   220→\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n   221→\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n   222→\t})\n   223→\n   224→\tt.Run(\"formatTime\", func(t *testing.T) {\n   225→\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n   226→\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n   227→\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n   228→\t})\n   229→\n   230→\tt.Run(\"formatDuration\", func(t *testing.T) {\n   231→\t\tnow := time.Now()\n   232→\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n   233→\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n   234→\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n   235→\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n   236→\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n   237→\t})\n   238→\n   239→\tt.Run(\"truncate\", func(t *testing.T) {\n   240→\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n   241→\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n   242→\t})\n   243→\n   244→\tt.Run(\"shortContainerID\", func(t *testing.T) {\n   245→\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n   246→\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n   247→\t})\n   248→\n   249→\tt.Run(\"projectLabels\", func(t *testing.T) {\n   250→\t\t// No conflict: show base name only\n   251→\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n   252→\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n   253→\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n   254→\n   255→\t\t// Conflict: two dirs share the same base name\n   256→\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n   257→\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n   258→\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n   259→\n   260→\t\t// Mixed: some conflict, some don't\n   261→\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n   262→\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n   263→\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n   264→\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n   265→\n   266→\t\t// Empty list\n   267→\t\tlabels = projectLabels(nil)\n   268→\t\tassert.Empty(t, labels)\n   269→\t})\n   270→}\n   271→\n   272→func TestRunsList_ProjectFilter(t *testing.T) {\n   273→\th, store := setupHandler(t)\n   274→\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   275→\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   276→\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   277→\n   278→\t// Without filter: all runs shown\n   279→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   280→\tw := httptest.NewRecorder()\n   281→\th.ServeHTTP(w, req)\n   282→\tassert.Equal(t, http.StatusOK, w.Code)\n   283→\tbody := w.Body.String()\n   284→\tassert.Contains(t, body, \"run-a1\")\n   285→\tassert.Contains(t, body, \"run-b1\")\n   286→\n   287→\t// With project filter: only matching runs\n   288→\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n   289→\tw = httptest.NewRecorder()\n   290→\th.ServeHTTP(w, req)\n   291→\tassert.Equal(t, http.StatusOK, w.Code)\n   292→\tbody = w.Body.String()\n   293→\tassert.Contains(t, body, \"run-a1\")\n   294→\tassert.Contains(t, body, \"run-a2\")\n   295→\tassert.NotContains(t, body, \"run-b1\")\n   296→}\n   297→\n   298→func TestRunsList_ProjectColumn(t *testing.T) {\n   299→\th, store := setupHandler(t)\n   300→\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n   301→\n   302→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   303→\tw := httptest.NewRecorder()\n   304→\th.ServeHTTP(w, req)\n   305→\tassert.Equal(t, http.StatusOK, w.Code)\n   306→\tbody := w.Body.String()\n   307→\tassert.Contains(t, body, \"myproject\")\n   308→\tassert.Contains(t, body, \"Project\")\n   309→}\n   310→\n   311→func TestAPIRuns_ProjectFilter(t *testing.T) {\n   312→\th, store := setupHandler(t)\n   313→\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   314→\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   315→\n   316→\t// Without filter: all runs\n   317→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   318→\tw := httptest.NewRecorder()\n   319→\th.ServeHTTP(w, req)\n   320→\tassert.Equal(t, http.StatusOK, w.Code)\n   321→\n   322→\tvar allRuns []apiRun\n   323→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n   324→\tassert.Len(t, allRuns, 2)\n   325→\n   326→\t// With filter: only matching\n   327→\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n   328→\tw = httptest.NewRecorder()\n   329→\th.ServeHTTP(w, req)\n   330→\tassert.Equal(t, http.StatusOK, w.Code)\n   331→\n   332→\tvar filtered []apiRun\n   333→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n   334→\tassert.Len(t, filtered, 1)\n   335→\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n   336→\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n   337→\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n   338→}\n   339→\n   340→func setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n   341→\tt.Helper()\n   342→\tstore, err := sqlite.NewStore(\":memory:\")\n   343→\trequire.NoError(t, err)\n   344→\tt.Cleanup(func() { store.Close() })\n   345→\n   346→\tmgr := newMockContainerManager()\n   347→\th, err := NewHandler(store, store, WithContainerManager(mgr))\n   348→\trequire.NoError(t, err)\n   349→\treturn h, store, mgr\n   350→}\n   351→\n   352→func seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n   353→\tt.Helper()\n   354→\tctx := context.Background()\n   355→\trun := domain.NewRun(id, workflow)\n   356→\trun.ProjectDir = projectDir\n   357→\trun.Start()\n   358→\trun.ContainerID = containerID\n   359→\trun.ContainerKept = kept\n   360→\trun.Complete(domain.RunStateSucceeded)\n   361→\trequire.NoError(t, store.CreateRun(ctx, run))\n   362→\tif kept {\n   363→\t\tmgr.containers[containerID] = true\n   364→\t}\n   365→}\n   366→\n   367→func TestRunDetail_ContainerRunning(t *testing.T) {\n   368→\th, store, mgr := setupHandlerWithContainerManager(t)\n   369→\n   370→\tctx := context.Background()\n   371→\trun := domain.NewRun(\"run-cr\", \"develop\")\n   372→\trun.ProjectDir = \"/proj\"\n   373→\trun.Start()\n   374→\trun.ContainerID = \"cid-running\"\n   375→\trequire.NoError(t, store.CreateRun(ctx, run))\n   376→\tmgr.containers[\"cid-running\"] = true\n   377→\tmgr.running[\"cid-running\"] = true\n   378→\n   379→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n   380→\tw := httptest.NewRecorder()\n   381→\th.ServeHTTP(w, req)\n   382→\n   383→\tassert.Equal(t, http.StatusOK, w.Code)\n   384→\tbody := w.Body.String()\n   385→\tassert.Contains(t, body, \"Container running\")\n   386→\tassert.Contains(t, body, `badge-running\">Container running`)\n   387→}\n   388→\n   389→func TestRunDetail_ContainerStopped(t *testing.T) {\n   390→\th, store, mgr := setupHandlerWithContainerManager(t)\n   391→\n   392→\tctx := context.Background()\n   393→\trun := domain.NewRun(\"run-cs\", \"develop\")\n   394→\trun.ProjectDir = \"/proj\"\n   395→\trun.Start()\n   396→\trun.ContainerID = \"cid-stopped\"\n   397→\trun.ContainerKept = false\n   398→\trun.Complete(domain.RunStateSucceeded)\n   399→\trequire.NoError(t, store.CreateRun(ctx, run))\n   400→\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n   401→\n   402→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n   403→\tw := httptest.NewRecorder()\n   404→\th.ServeHTTP(w, req)\n   405→\n   406→\tassert.Equal(t, http.StatusOK, w.Code)\n   407→\tbody := w.Body.String()\n   408→\tassert.Contains(t, body, \"Container stopped\")\n   409→\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n   410→}\n   411→\n   412→func TestRunDetail_ContainerAvailable(t *testing.T) {\n   413→\th, store, mgr := setupHandlerWithContainerManager(t)\n   414→\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n   415→\n   416→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n   417→\tw := httptest.NewRecorder()\n   418→\th.ServeHTTP(w, req)\n   419→\n   420→\tassert.Equal(t, http.StatusOK, w.Code)\n   421→\tbody := w.Body.String()\n   422→\tassert.Contains(t, body, \"Container available\")\n   423→\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n   424→\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n   425→}\n   426→\n   427→func TestRunDetail_ContainerRemoved(t *testing.T) {\n   428→\th, store, _ := setupHandlerWithContainerManager(t)\n   429→\n   430→\tctx := context.Background()\n   431→\trun := domain.NewRun(\"run-c2\", \"develop\")\n   432→\trun.ProjectDir = \"/proj\"\n   433→\trun.Start()\n   434→\trun.ContainerID = \"cid-gone\"\n   435→\trun.ContainerKept = false\n   436→\trun.Complete(domain.RunStateSucceeded)\n   437→\trequire.NoError(t, store.CreateRun(ctx, run))\n   438→\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n   439→\n   440→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n   441→\tw := httptest.NewRecorder()\n   442→\th.ServeHTTP(w, req)\n   443→\n   444→\tassert.Equal(t, http.StatusOK, w.Code)\n   445→\tbody := w.Body.String()\n   446→\tassert.Contains(t, body, \"Container removed\")\n   447→\tassert.Contains(t, body, `badge-pending\">Container removed`)\n   448→}\n   449→\n   450→func TestAPIDeleteContainer_Success(t *testing.T) {\n   451→\th, store, mgr := setupHandlerWithContainerManager(t)\n   452→\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n   453→\n   454→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n   455→\tw := httptest.NewRecorder()\n   456→\th.ServeHTTP(w, req)\n   457→\n   458→\tassert.Equal(t, http.StatusOK, w.Code)\n   459→\n   460→\tvar resp map[string]string\n   461→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n   462→\tassert.Equal(t, \"ok\", resp[\"status\"])\n   463→\n   464→\t// Verify container was removed\n   465→\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n   466→\n   467→\t// Verify run was updated\n   468→\trun, err := store.GetRun(context.Background(), \"run-del1\")\n   469→\trequire.NoError(t, err)\n   470→\tassert.False(t, run.ContainerKept)\n   471→}\n   472→\n   473→func TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n   474→\th, _, _ := setupHandlerWithContainerManager(t)\n   475→\n   476→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n   477→\tw := httptest.NewRecorder()\n   478→\th.ServeHTTP(w, req)\n   479→\n   480→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   481→}\n   482→\n   483→func TestAPIDeleteContainer_NoManager(t *testing.T) {\n   484→\th, store := setupHandler(t) // no container manager\n   485→\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n   486→\n   487→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n   488→\tw := httptest.NewRecorder()\n   489→\th.ServeHTTP(w, req)\n   490→\n   491→\tassert.Equal(t, http.StatusBadRequest, w.Code)\n   492→}\n   493→\n   494→func TestAPIRunDetail_ContainerState(t *testing.T) {\n   495→\th, store, mgr := setupHandlerWithContainerManager(t)\n   496→\n   497→\t// Seed a running container\n   498→\tctx := context.Background()\n   499→\trun := domain.NewRun(\"api-cs1\", \"develop\")\n   500→\trun.ProjectDir = \"/proj\"\n   501→\trun.Start()\n   502→\trun.ContainerID = \"cid-api-running\"\n   503→\trequire.NoError(t, store.CreateRun(ctx, run))\n   504→\tmgr.containers[\"cid-api-running\"] = true\n   505→\tmgr.running[\"cid-api-running\"] = true\n   506→\n   507→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n   508→\tw := httptest.NewRecorder()\n   509→\th.ServeHTTP(w, req)\n   510→\n   511→\tassert.Equal(t, http.StatusOK, w.Code)\n   512→\n   513→\tvar detail apiRunDetail\n   514→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   515→\tassert.Equal(t, \"running\", detail.ContainerState)\n   516→\n   517→\t// Now stop it\n   518→\tmgr.running[\"cid-api-running\"] = false\n   519→\n   520→\tw = httptest.NewRecorder()\n   521→\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n   522→\n   523→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   524→\tassert.Equal(t, \"stopped\", detail.ContainerState)\n   525→}\n   526→\n   527→func TestRunsList_ContainerCount(t *testing.T) {\n   528→\th, store, mgr := setupHandlerWithContainerManager(t)\n   529→\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n   530→\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n   531→\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n   532→\n   533→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   534→\tw := httptest.NewRecorder()\n   535→\th.ServeHTTP(w, req)\n   536→\n   537→\tassert.Equal(t, http.StatusOK, w.Code)\n   538→\tbody := w.Body.String()\n   539→\t// alpha has 2 retained containers\n   540→\tassert.Contains(t, body, \"2 containers\")\n   541→\t// beta has 0, so no count should appear\n   542→\tassert.NotContains(t, body, \"0 container\")\n   543→}\n   544→\n   545→func TestAPIProjects(t *testing.T) {\n   546→\th, store := setupHandler(t)\n   547→\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   548→\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   549→\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   550→\n   551→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   552→\tw := httptest.NewRecorder()\n   553→\th.ServeHTTP(w, req)\n   554→\tassert.Equal(t, http.StatusOK, w.Code)\n   555→\n   556→\ttype apiHealth struct {\n   557→\t\tStatus string `json:\"status\"`\n   558→\t\tPassed int    `json:\"passed\"`\n   559→\t\tFailed int    `json:\"failed\"`\n   560→\t\tTotal  int    `json:\"total\"`\n   561→\t}\n   562→\ttype project struct {\n   563→\t\tDir         string    `json:\"dir\"`\n   564→\t\tLabel       string    `json:\"label\"`\n   565→\t\tHealth      apiHealth `json:\"health\"`\n   566→\t\tActiveCount int       `json:\"active_count\"`\n   567→\t}\n   568→\tvar projects []project\n   569→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   570→\tassert.Len(t, projects, 2)\n   571→\n   572→\tbyDir := map[string]project{}\n   573→\tfor _, p := range projects {\n   574→\t\tbyDir[p.Dir] = p\n   575→\t}\n   576→\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n   577→\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n   578→\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n   579→\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n   580→\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n   581→\t// beta has 1 running = blue (all in-progress), 1 active\n   582→\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n   583→\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n   584→}\n   585→\n   586→func TestProjectOverview_WithProjects(t *testing.T) {\n   587→\th, store := setupHandler(t)\n   588→\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   589→\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   590→\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   591→\n   592→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   593→\tw := httptest.NewRecorder()\n   594→\th.ServeHTTP(w, req)\n   595→\n   596→\tassert.Equal(t, http.StatusOK, w.Code)\n   597→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   598→\tbody := w.Body.String()\n   599→\t// Project cards should be present\n   600→\tassert.Contains(t, body, \"project-card\")\n   601→\tassert.Contains(t, body, \"alpha\")\n   602→\tassert.Contains(t, body, \"beta\")\n   603→\t// Health dots\n   604→\tassert.Contains(t, body, \"health-dot\")\n   605→\t// Run history dots\n   606→\tassert.Contains(t, body, \"run-dot\")\n   607→\t// Quick actions\n   608→\tassert.Contains(t, body, \"View Runs\")\n   609→\tassert.Contains(t, body, \"Trigger Orchestrator\")\n   610→}\n   611→\n   612→func TestProjectOverview_Empty(t *testing.T) {\n   613→\th, _ := setupHandler(t)\n   614→\n   615→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   616→\tw := httptest.NewRecorder()\n   617→\th.ServeHTTP(w, req)\n   618→\n   619→\tassert.Equal(t, http.StatusOK, w.Code)\n   620→\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n   621→}\n   622→\n   623→func TestAPITriggerOrchestrator_NoOrchestrator(t *testing.T) {\n   624→\th, store := setupHandler(t)\n   625→\tseedRunWithProject(t, store, \"orch-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   626→\n   627→\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n   628→\tw := httptest.NewRecorder()\n   629→\th.ServeHTTP(w, req)\n   630→\n   631→\tassert.Equal(t, http.StatusNotImplemented, w.Code)\n   632→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   633→\n   634→\tvar result map[string]string\n   635→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   636→\tassert.Equal(t, \"orchestrator not configured\", result[\"error\"])\n   637→}\n   638→\n   639→func TestAPITriggerOrchestrator_Success(t *testing.T) {\n   640→\tstore, err := sqlite.NewStore(\":memory:\")\n   641→\trequire.NoError(t, err)\n   642→\tt.Cleanup(func() { store.Close() })\n   643→\n   644→\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   645→\t\tassert.Equal(t, \"/home/user/myproject\", projectDir)\n   646→\t\treturn 3, nil\n   647→\t}))\n   648→\trequire.NoError(t, err)\n   649→\n   650→\tseedRunWithProject(t, store, \"orch-2\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   651→\n   652→\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n   653→\tw := httptest.NewRecorder()\n   654→\th.ServeHTTP(w, req)\n   655→\n   656→\tassert.Equal(t, http.StatusOK, w.Code)\n   657→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   658→\n   659→\tvar result map[string]any\n   660→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   661→\tassert.Equal(t, \"ok\", result[\"status\"])\n   662→\tassert.Equal(t, \"myproject\", result[\"project\"])\n   663→\tassert.Equal(t, float64(3), result[\"dispatched\"])\n   664→}\n   665→\n   666→func TestAPITriggerOrchestrator_ProjectNotFound(t *testing.T) {\n   667→\tstore, err := sqlite.NewStore(\":memory:\")\n   668→\trequire.NoError(t, err)\n   669→\tt.Cleanup(func() { store.Close() })\n   670→\n   671→\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   672→\t\treturn 0, nil\n   673→\t}))\n   674→\trequire.NoError(t, err)\n   675→\n   676→\treq := httptest.NewRequest(\"POST\", \"/api/projects/nonexistent/trigger\", nil)\n   677→\tw := httptest.NewRecorder()\n   678→\th.ServeHTTP(w, req)\n   679→\n   680→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   681→\n   682→\tvar result map[string]string\n   683→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   684→\tassert.Equal(t, \"project not found\", result[\"error\"])\n   685→}\n   686→\n   687→func TestAPITriggerOrchestrator_Error(t *testing.T) {\n   688→\tstore, err := sqlite.NewStore(\":memory:\")\n   689→\trequire.NoError(t, err)\n   690→\tt.Cleanup(func() { store.Close() })\n   691→\n   692→\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   693→\t\treturn 0, fmt.Errorf(\"orchestration failed\")\n   694→\t}))\n   695→\trequire.NoError(t, err)\n   696→\n   697→\tseedRunWithProject(t, store, \"orch-3\", \"develop\", domain.RunStateSucceeded, \"/home/user/errproject\")\n   698→\n   699→\treq := httptest.NewRequest(\"POST\", \"/api/projects/errproject/trigger\", nil)\n   700→\tw := httptest.NewRecorder()\n   701→\th.ServeHTTP(w, req)\n   702→\n   703→\tassert.Equal(t, http.StatusInternalServerError, w.Code)\n   704→\n   705→\tvar result map[string]string\n   706→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   707→\tassert.Equal(t, \"orchestration failed\", result[\"error\"])\n   708→}\n   709→\n   710→func TestHealthColor(t *testing.T) {\n   711→\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n   712→\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n   713→\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n   714→\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n   715→\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n   716→\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n   717→}\n   718→\n   719→func TestAPIProjects_HealthData(t *testing.T) {\n   720→\th, store := setupHandler(t)\n   721→\t// alpha: 3 succeeded, 1 failed → yellow\n   722→\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   723→\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   724→\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   725→\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   726→\n   727→\t// beta: all succeeded → green\n   728→\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   729→\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   730→\n   731→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   732→\tw := httptest.NewRecorder()\n   733→\th.ServeHTTP(w, req)\n   734→\tassert.Equal(t, http.StatusOK, w.Code)\n   735→\n   736→\ttype health struct {\n   737→\t\tStatus string `json:\"status\"`\n   738→\t\tPassed int    `json:\"passed\"`\n   739→\t\tFailed int    `json:\"failed\"`\n   740→\t\tTotal  int    `json:\"total\"`\n   741→\t}\n   742→\ttype project struct {\n   743→\t\tDir    string `json:\"dir\"`\n   744→\t\tLabel  string `json:\"label\"`\n   745→\t\tHealth health `json:\"health\"`\n   746→\t}\n   747→\tvar projects []project\n   748→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   749→\tassert.Len(t, projects, 2)\n   750→\n   751→\tbyDir := map[string]project{}\n   752→\tfor _, p := range projects {\n   753→\t\tbyDir[p.Dir] = p\n   754→\t}\n   755→\n   756→\talpha := byDir[\"/home/user/alpha\"]\n   757→\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n   758→\tassert.Equal(t, 3, alpha.Health.Passed)\n   759→\tassert.Equal(t, 1, alpha.Health.Failed)\n   760→\tassert.Equal(t, 4, alpha.Health.Total)\n   761→\n   762→\tbeta := byDir[\"/home/user/beta\"]\n   763→\tassert.Equal(t, \"green\", beta.Health.Status)\n   764→\tassert.Equal(t, 2, beta.Health.Passed)\n   765→\tassert.Equal(t, 0, beta.Health.Failed)\n   766→\tassert.Equal(t, 2, beta.Health.Total)\n   767→}\n   768→\n   769→func TestAPIProjects_HealthNoRuns(t *testing.T) {\n   770→\th, _ := setupHandler(t)\n   771→\n   772→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   773→\tw := httptest.NewRecorder()\n   774→\th.ServeHTTP(w, req)\n   775→\tassert.Equal(t, http.StatusOK, w.Code)\n   776→\n   777→\t// No projects means empty array\n   778→\ttype project struct {\n   779→\t\tDir   string `json:\"dir\"`\n   780→\t\tLabel string `json:\"label\"`\n   781→\t}\n   782→\tvar projects []project\n   783→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   784→\tassert.Empty(t, projects)\n   785→}\n   786→\n   787→func TestAPIPromptContent(t *testing.T) {\n   788→\t// Create a temp project dir with a prompt file\n   789→\ttmpDir := t.TempDir()\n   790→\tpromptsDir := filepath.Join(tmpDir, \".cloche\", \"prompts\")\n   791→\trequire.NoError(t, os.MkdirAll(promptsDir, 0o755))\n   792→\trequire.NoError(t, os.WriteFile(filepath.Join(promptsDir, \"develop.txt\"), []byte(\"You are a helpful assistant.\"), 0o644))\n   793→\n   794→\th, store := setupHandler(t)\n   795→\tseedRunWithProject(t, store, \"pc-1\", \"develop\", domain.RunStateSucceeded, tmpDir)\n   796→\n   797→\tlabel := filepath.Base(tmpDir)\n   798→\n   799→\tt.Run(\"returns file contents\", func(t *testing.T) {\n   800→\t\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/info/prompt-content?file=.cloche/prompts/develop.txt\", nil)\n   801→\t\tw := httptest.NewRecorder()\n   802→\t\th.ServeHTTP(w, req)\n   803→\t\tassert.Equal(t, http.StatusOK, w.Code)\n   804→\t\tassert.Equal(t, \"You are a helpful assistant.\", w.Body.String())\n   805→\t})\n   806→\n   807→\tt.Run(\"rejects missing file param\", func(t *testing.T) {\n   808→\t\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/info/prompt-content\", nil)\n   809→\t\tw := httptest.NewRecorder()\n   810→\t\th.ServeHTTP(w, req)\n   811→\t\tassert.Equal(t, http.StatusBadRequest, w.Code)\n   812→\t})\n   813→\n   814→\tt.Run(\"rejects path traversal\", func(t *testing.T) {\n   815→\t\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/info/prompt-content?file=../../etc/passwd\", nil)\n   816→\t\tw := httptest.NewRecorder()\n   817→\t\th.ServeHTTP(w, req)\n   818→\t\tassert.Equal(t, http.StatusBadRequest, w.Code)\n   819→\t})\n   820→\n   821→\tt.Run(\"returns 404 for nonexistent file\", func(t *testing.T) {\n   822→\t\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/info/prompt-content?file=.cloche/prompts/missing.txt\", nil)\n   823→\t\tw := httptest.NewRecorder()\n   824→\t\th.ServeHTTP(w, req)\n   825→\t\tassert.Equal(t, http.StatusNotFound, w.Code)\n   826→\t})\n   827→}\n   828→"}]},"parent_tool_use_id":null,"session_id":"5254cc0b-d1ce-445d-a549-63c446b20866","uuid":"b21d349f-86ae-4f99-8447-d779d615352d","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler_test.go","content":"package web\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// mockContainerManager implements ContainerManager for testing.\ntype mockContainerManager struct {\n\tcontainers map[string]bool // containerID -> exists\n\trunning    map[string]bool // containerID -> running\n\tremoved    []string\n}\n\nfunc newMockContainerManager() *mockContainerManager {\n\treturn &mockContainerManager{\n\t\tcontainers: map[string]bool{},\n\t\trunning:    map[string]bool{},\n\t}\n}\n\nfunc (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n\treturn \"mock logs\", nil\n}\n\nfunc (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n\tif !m.containers[containerID] {\n\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\tdelete(m.containers, containerID)\n\tm.removed = append(m.removed, containerID)\n\treturn nil\n}\n\nfunc (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n\tif !m.containers[containerID] {\n\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n}\n\nfunc setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store)\n\trequire.NoError(t, err)\n\treturn h, store\n}\n\nfunc seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n\tt.Helper()\n\tseedRunWithProject(t, store, id, workflow, state, \"\")\n}\n\nfunc seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\tif state != domain.RunStatePending {\n\t\trun.Start()\n\t\trun.ContainerID = \"abc123def456789\"\n\t}\n\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n\t\trun.Complete(state)\n\t}\n\tif state == domain.RunStateFailed {\n\t\trun.ErrorMessage = \"something went wrong\"\n\t}\n\trequire.NoError(t, store.CreateRun(ctx, run))\n}\n\nfunc TestRunsList_WithRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"test-run-1\")\n\tassert.Contains(t, body, \"test-run-2\")\n\tassert.Contains(t, body, \"badge-running\")\n\tassert.Contains(t, body, \"badge-succeeded\")\n\tassert.Contains(t, body, \"develop\")\n\tassert.Contains(t, body, \"deploy\")\n}\n\nfunc TestRunsList_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n}\n\nfunc TestRunDetail_WithCaptures(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"implement\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-detail-1\")\n\tassert.Contains(t, body, \"implement\")\n}\n\nfunc TestRunDetail_NotFound(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar runs []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n\tassert.Len(t, runs, 2)\n\n\tids := map[string]bool{}\n\tfor _, r := range runs {\n\t\tids[r.ID] = true\n\t}\n\tassert.True(t, ids[\"api-run-1\"])\n\tassert.True(t, ids[\"api-run-2\"])\n}\n\nfunc TestAPIRunDetail(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"build\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"api-detail-1\", detail.ID)\n\tassert.Equal(t, \"running\", detail.State)\n\tassert.Len(t, detail.Steps, 1)\n\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n\tassert.NotEmpty(t, detail.Steps[0].Duration)\n}\n\nfunc TestStaticCSS(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \":root\")\n\tassert.Contains(t, w.Body.String(), \"badge-running\")\n}\n\nfunc TestHelpers(t *testing.T) {\n\tt.Run(\"stateColor\", func(t *testing.T) {\n\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n\t})\n\n\tt.Run(\"formatTime\", func(t *testing.T) {\n\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n\t})\n\n\tt.Run(\"formatDuration\", func(t *testing.T) {\n\t\tnow := time.Now()\n\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n\t})\n\n\tt.Run(\"truncate\", func(t *testing.T) {\n\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n\t})\n\n\tt.Run(\"shortContainerID\", func(t *testing.T) {\n\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n\t})\n\n\tt.Run(\"projectLabels\", func(t *testing.T) {\n\t\t// No conflict: show base name only\n\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n\n\t\t// Conflict: two dirs share the same base name\n\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n\n\t\t// Mixed: some conflict, some don't\n\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n\n\t\t// Empty list\n\t\tlabels = projectLabels(nil)\n\t\tassert.Empty(t, labels)\n\t})\n}\n\nfunc TestRunsList_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs shown\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-b1\")\n\n\t// With project filter: only matching runs\n\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody = w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-a2\")\n\tassert.NotContains(t, body, \"run-b1\")\n}\n\nfunc TestRunsList_ProjectColumn(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"myproject\")\n\tassert.Contains(t, body, \"Project\")\n}\n\nfunc TestAPIRuns_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar allRuns []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n\tassert.Len(t, allRuns, 2)\n\n\t// With filter: only matching\n\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar filtered []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n\tassert.Len(t, filtered, 1)\n\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n}\n\nfunc setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\tmgr := newMockContainerManager()\n\th, err := NewHandler(store, store, WithContainerManager(mgr))\n\trequire.NoError(t, err)\n\treturn h, store, mgr\n}\n\nfunc seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\trun.Start()\n\trun.ContainerID = containerID\n\trun.ContainerKept = kept\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tif kept {\n\t\tmgr.containers[containerID] = true\n\t}\n}\n\nfunc TestRunDetail_ContainerRunning(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cr\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-running\"] = true\n\tmgr.running[\"cid-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container running\")\n\tassert.Contains(t, body, `badge-running\">Container running`)\n}\n\nfunc TestRunDetail_ContainerStopped(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cs\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-stopped\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container stopped\")\n\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n}\n\nfunc TestRunDetail_ContainerAvailable(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container available\")\n\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n}\n\nfunc TestRunDetail_ContainerRemoved(t *testing.T) {\n\th, store, _ := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-c2\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-gone\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container removed\")\n\tassert.Contains(t, body, `badge-pending\">Container removed`)\n}\n\nfunc TestAPIDeleteContainer_Success(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"ok\", resp[\"status\"])\n\n\t// Verify container was removed\n\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n\n\t// Verify run was updated\n\trun, err := store.GetRun(context.Background(), \"run-del1\")\n\trequire.NoError(t, err)\n\tassert.False(t, run.ContainerKept)\n}\n\nfunc TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n\th, _, _ := setupHandlerWithContainerManager(t)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIDeleteContainer_NoManager(t *testing.T) {\n\th, store := setupHandler(t) // no container manager\n\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusBadRequest, w.Code)\n}\n\nfunc TestAPIRunDetail_ContainerState(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\t// Seed a running container\n\tctx := context.Background()\n\trun := domain.NewRun(\"api-cs1\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-api-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-api-running\"] = true\n\tmgr.running[\"cid-api-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"running\", detail.ContainerState)\n\n\t// Now stop it\n\tmgr.running[\"cid-api-running\"] = false\n\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"stopped\", detail.ContainerState)\n}\n\nfunc TestRunsList_ContainerCount(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\t// alpha has 2 retained containers\n\tassert.Contains(t, body, \"2 containers\")\n\t// beta has 0, so no count should appear\n\tassert.NotContains(t, body, \"0 container\")\n}\n\nfunc TestAPIProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n\t// beta has 1 running = blue (all in-progress), 1 active\n\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n}\n\nfunc TestProjectOverview_WithProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\t// Project cards should be present\n\tassert.Contains(t, body, \"project-card\")\n\tassert.Contains(t, body, \"alpha\")\n\tassert.Contains(t, body, \"beta\")\n\t// Health dots\n\tassert.Contains(t, body, \"health-dot\")\n\t// Run history dots\n\tassert.Contains(t, body, \"run-dot\")\n\t// Quick actions\n\tassert.Contains(t, body, \"View Runs\")\n\tassert.Contains(t, body, \"Trigger Orchestrator\")\n}\n\nfunc TestProjectOverview_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n}\n\nfunc TestAPITriggerOrchestrator_NoOrchestrator(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"orch-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotImplemented, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar result map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"orchestrator not configured\", result[\"error\"])\n}\n\nfunc TestAPITriggerOrchestrator_Success(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\tassert.Equal(t, \"/home/user/myproject\", projectDir)\n\t\treturn 3, nil\n\t}))\n\trequire.NoError(t, err)\n\n\tseedRunWithProject(t, store, \"orch-2\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar result map[string]any\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"ok\", result[\"status\"])\n\tassert.Equal(t, \"myproject\", result[\"project\"])\n\tassert.Equal(t, float64(3), result[\"dispatched\"])\n}\n\nfunc TestAPITriggerOrchestrator_ProjectNotFound(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\treturn 0, nil\n\t}))\n\trequire.NoError(t, err)\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/nonexistent/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n\n\tvar result map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"project not found\", result[\"error\"])\n}\n\nfunc TestAPITriggerOrchestrator_Error(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\treturn 0, fmt.Errorf(\"orchestration failed\")\n\t}))\n\trequire.NoError(t, err)\n\n\tseedRunWithProject(t, store, \"orch-3\", \"develop\", domain.RunStateSucceeded, \"/home/user/errproject\")\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/errproject/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusInternalServerError, w.Code)\n\n\tvar result map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"orchestration failed\", result[\"error\"])\n}\n\nfunc TestHealthColor(t *testing.T) {\n\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n}\n\nfunc TestAPIProjects_HealthData(t *testing.T) {\n\th, store := setupHandler(t)\n\t// alpha: 3 succeeded, 1 failed → yellow\n\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\t// beta: all succeeded → green\n\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype health struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir    string `json:\"dir\"`\n\t\tLabel  string `json:\"label\"`\n\t\tHealth health `json:\"health\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\n\talpha := byDir[\"/home/user/alpha\"]\n\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n\tassert.Equal(t, 3, alpha.Health.Passed)\n\tassert.Equal(t, 1, alpha.Health.Failed)\n\tassert.Equal(t, 4, alpha.Health.Total)\n\n\tbeta := byDir[\"/home/user/beta\"]\n\tassert.Equal(t, \"green\", beta.Health.Status)\n\tassert.Equal(t, 2, beta.Health.Passed)\n\tassert.Equal(t, 0, beta.Health.Failed)\n\tassert.Equal(t, 2, beta.Health.Total)\n}\n\nfunc TestAPIProjects_HealthNoRuns(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\t// No projects means empty array\n\ttype project struct {\n\t\tDir   string `json:\"dir\"`\n\t\tLabel string `json:\"label\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Empty(t, projects)\n}\n\nfunc TestAPIPromptContent(t *testing.T) {\n\t// Create a temp project dir with a prompt file\n\ttmpDir := t.TempDir()\n\tpromptsDir := filepath.Join(tmpDir, \".cloche\", \"prompts\")\n\trequire.NoError(t, os.MkdirAll(promptsDir, 0o755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(promptsDir, \"develop.txt\"), []byte(\"You are a helpful assistant.\"), 0o644))\n\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"pc-1\", \"develop\", domain.RunStateSucceeded, tmpDir)\n\n\tlabel := filepath.Base(tmpDir)\n\n\tt.Run(\"returns file contents\", func(t *testing.T) {\n\t\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/info/prompt-content?file=.cloche/prompts/develop.txt\", nil)\n\t\tw := httptest.NewRecorder()\n\t\th.ServeHTTP(w, req)\n\t\tassert.Equal(t, http.StatusOK, w.Code)\n\t\tassert.Equal(t, \"You are a helpful assistant.\", w.Body.String())\n\t})\n\n\tt.Run(\"rejects missing file param\", func(t *testing.T) {\n\t\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/info/prompt-content\", nil)\n\t\tw := httptest.NewRecorder()\n\t\th.ServeHTTP(w, req)\n\t\tassert.Equal(t, http.StatusBadRequest, w.Code)\n\t})\n\n\tt.Run(\"rejects path traversal\", func(t *testing.T) {\n\t\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/info/prompt-content?file=../../etc/passwd\", nil)\n\t\tw := httptest.NewRecorder()\n\t\th.ServeHTTP(w, req)\n\t\tassert.Equal(t, http.StatusBadRequest, w.Code)\n\t})\n\n\tt.Run(\"returns 404 for nonexistent file\", func(t *testing.T) {\n\t\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/info/prompt-content?file=.cloche/prompts/missing.txt\", nil)\n\t\tw := httptest.NewRecorder()\n\t\th.ServeHTTP(w, req)\n\t\tassert.Equal(t, http.StatusNotFound, w.Code)\n\t})\n}\n","numLines":828,"startLine":1,"totalLines":828}}}
