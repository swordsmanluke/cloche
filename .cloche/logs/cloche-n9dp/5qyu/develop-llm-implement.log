intSubcommandHelp(\"set\")\n    66→\t\t\treturn\n    67→\t\t}\n    68→\t\tcmdSet(os.Args[2:])\n    69→\t\treturn\n    70→\tcase \"tasks\":\n    71→\t\tif hasHelpFlag(os.Args[2:]) {\n    72→\t\t\tprintSubcommandHelp(\"tasks\")\n    73→\t\t\treturn\n    74→\t\t}\n    75→\t\tcmdTasks(os.Args[2:])\n    76→\t\treturn\n    77→\tcase \"workflow\":\n    78→\t\tif hasHelpFlag(os.Args[2:]) {\n    79→\t\t\tprintSubcommandHelp(\"workflow\")\n    80→\t\t\treturn\n    81→\t\t}\n    82→\t\tcmdWorkflow(os.Args[2:])\n    83→\t\treturn\n    84→\t}\n    85→\n    86→\t// Handle --help for daemon commands before connecting\n    87→\tdaemonCmds := map[string]bool{\n    88→\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n    89→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n    90→\t}\n    91→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n    92→\t\tprintSubcommandHelp(os.Args[1])\n    93→\t\treturn\n    94→\t}\n    95→\n    96→\t// Commands that need a daemon connection\n    97→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    98→\tif addr == \"\" {\n    99→\t\taddr = \"unix:///tmp/cloche.sock\"\n   100→\t}\n   101→\n   102→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   103→\tif err != nil {\n   104→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   105→\t\tos.Exit(1)\n   106→\t}\n   107→\tdefer conn.Close()\n   108→\n   109→\tclient := pb.NewClocheServiceClient(conn)\n   110→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   111→\tdefer cancel()\n   112→\n   113→\tswitch os.Args[1] {\n   114→\tcase \"run\":\n   115→\t\tcmdRun(ctx, client, os.Args[2:])\n   116→\tcase \"status\":\n   117→\t\tcmdStatus(ctx, client, os.Args[2:])\n   118→\tcase \"logs\":\n   119→\t\tcmdLogs(client, os.Args[2:])\n   120→\tcase \"poll\":\n   121→\t\tcmdPoll(client, os.Args[2:])\n   122→\tcase \"list\":\n   123→\t\tcmdList(ctx, client, os.Args[2:])\n   124→\tcase \"stop\":\n   125→\t\tcmdStop(ctx, client, os.Args[2:])\n   126→\tcase \"delete\":\n   127→\t\tcmdDelete(ctx, client, os.Args[2:])\n   128→\tcase \"loop\":\n   129→\t\tcmdLoop(ctx, client, os.Args[2:])\n   130→\tcase \"shutdown\":\n   131→\t\tcmdShutdown(ctx, client)\n   132→\tdefault:\n   133→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   134→\t\tprintTopLevelHelp()\n   135→\t\tos.Exit(1)\n   136→\t}\n   137→}\n   138→\n   139→\n   140→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   141→\tvar workflow, prompt, title string\n   142→\tvar keepContainer bool\n   143→\n   144→\tfor i := 0; i < len(args); i++ {\n   145→\t\tswitch args[i] {\n   146→\t\tcase \"--workflow\":\n   147→\t\t\tif i+1 < len(args) {\n   148→\t\t\t\ti++\n   149→\t\t\t\tworkflow = args[i]\n   150→\t\t\t}\n   151→\t\tcase \"--prompt\", \"-p\":\n   152→\t\t\tif i+1 < len(args) {\n   153→\t\t\t\ti++\n   154→\t\t\t\tprompt = args[i]\n   155→\t\t\t}\n   156→\t\tcase \"--title\":\n   157→\t\t\tif i+1 < len(args) {\n   158→\t\t\t\ti++\n   159→\t\t\t\ttitle = args[i]\n   160→\t\t\t}\n   161→\t\tcase \"--keep-container\":\n   162→\t\t\tkeepContainer = true\n   163→\t\tdefault:\n   164→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   165→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   166→\t\t\t\tworkflow = args[i]\n   167→\t\t\t}\n   168→\t\t}\n   169→\t}\n   170→\n   171→\tif workflow == \"\" {\n   172→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   173→\t\tos.Exit(1)\n   174→\t}\n   175→\n   176→\tcwd, _ := os.Getwd()\n   177→\n   178→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   179→\tvar image string\n   180→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   181→\tif data, err := os.ReadFile(wfPath); err == nil {\n   182→\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   183→\t\t\timage = wf.Config[\"container.image\"]\n   184→\t\t}\n   185→\t}\n   186→\n   187→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   188→\t\tWorkflowName:  workflow,\n   189→\t\tProjectDir:    cwd,\n   190→\t\tImage:         image,\n   191→\t\tPrompt:        prompt,\n   192→\t\tKeepContainer: keepContainer,\n   193→\t\tTitle:         title,\n   194→\t})\n   195→\tif err != nil {\n   196→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   197→\t\tos.Exit(1)\n   198→\t}\n   199→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   200→}\n   201→\n   202→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   203→\tif len(args) < 1 {\n   204→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   205→\t\tos.Exit(1)\n   206→\t}\n   207→\n   208→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   209→\tif err != nil {\n   210→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   211→\t\tos.Exit(1)\n   212→\t}\n   213→\n   214→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   215→\tif resp.Title != \"\" {\n   216→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   217→\t}\n   218→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   219→\tif resp.IsHost {\n   220→\t\tfmt.Printf(\"Type:      host\\n\")\n   221→\t} else {\n   222→\t\tfmt.Printf(\"Type:      container\\n\")\n   223→\t}\n   224→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   225→\tif resp.ContainerId != \"\" {\n   226→\t\tcid := resp.ContainerId\n   227→\t\tif len(cid) > 12 {\n   228→\t\t\tcid = cid[:12]\n   229→\t\t}\n   230→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   231→\t}\n   232→\tif resp.ErrorMessage != \"\" {\n   233→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   234→\t}\n   235→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   236→\tfor _, exec := range resp.StepExecutions {\n   237→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   238→\t}\n   239→}\n   240→\n   241→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   242→\tvar all bool\n   243→\tfor _, arg := range args {\n   244→\t\tif arg == \"--all\" {\n   245→\t\t\tall = true\n   246→\t\t}\n   247→\t}\n   248→\n   249→\treq := &pb.ListRunsRequest{}\n   250→\tif all {\n   251→\t\t// --all: show all runs across all projects (no time limit)\n   252→\t\treq.All = true\n   253→\t} else {\n   254→\t\t// Default: filter to current project\n   255→\t\tcwd, _ := os.Getwd()\n   256→\t\treq.ProjectDir = cwd\n   257→\t}\n   258→\n   259→\tresp, err := client.ListRuns(ctx, req)\n   260→\tif err != nil {\n   261→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   262→\t\tos.Exit(1)\n   263→\t}\n   264→\n   265→\tif len(resp.Runs) == 0 {\n   266→\t\tfmt.Println(\"No runs found.\")\n   267→\t\treturn\n   268→\t}\n   269→\n   270→\tfor _, run := range resp.Runs {\n   271→\t\trunType := \"container\"\n   272→\t\tif run.IsHost {\n   273→\t\t\trunType = \"host\"\n   274→\t\t}\n   275→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   276→\t\tif run.Title != \"\" {\n   277→\t\t\tt := run.Title\n   278→\t\t\tif len(t) > 40 {\n   279→\t\t\t\tt = t[:37] + \"...\"\n   280→\t\t\t}\n   281→\t\t\tline += \"  \" + t\n   282→\t\t}\n   283→\t\tif run.ContainerId != \"\" {\n   284→\t\t\tline += \"  \" + run.ContainerId\n   285→\t\t}\n   286→\t\tif run.ErrorMessage != \"\" {\n   287→\t\t\terrMsg := run.ErrorMessage\n   288→\t\t\tif len(errMsg) > 60 {\n   289→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   290→\t\t\t}\n   291→\t\t\tline += \"  \" + errMsg\n   292→\t\t}\n   293→\t\tfmt.Println(line)\n   294→\t}\n   295→}\n   296→\n   297→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   298→\tif len(args) < 1 {\n   299→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n   300→\t\tos.Exit(1)\n   301→\t}\n   302→\n   303→\tvar stepFilter, typeFilter string\n   304→\tvar follow bool\n   305→\trunID := args[0]\n   306→\n   307→\tfor i := 1; i < len(args); i++ {\n   308→\t\tswitch args[i] {\n   309→\t\tcase \"--step\":\n   310→\t\t\tif i+1 < len(args) {\n   311→\t\t\t\ti++\n   312→\t\t\t\tstepFilter = args[i]\n   313→\t\t\t}\n   314→\t\tcase \"--type\":\n   315→\t\t\tif i+1 < len(args) {\n   316→\t\t\t\ti++\n   317→\t\t\t\ttypeFilter = args[i]\n   318→\t\t\t}\n   319→\t\tcase \"--follow\", \"-f\":\n   320→\t\t\tfollow = true\n   321→\t\t}\n   322→\t}\n   323→\n   324→\t// Use background context — log output can be large and follow mode blocks.\n   325→\tctx := context.Background()\n   326→\tif follow {\n   327→\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n   328→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   329→\t}\n   330→\n   331→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   332→\t\tRunId:    runID,\n   333→\t\tStepName: stepFilter,\n   334→\t\tLogType:  typeFilter,\n   335→\t})\n   336→\tif err != nil {\n   337→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   338→\t\tos.Exit(1)\n   339→\t}\n   340→\n   341→\tfor {\n   342→\t\tentry, err := stream.Recv()\n   343→\t\tif err != nil {\n   344→\t\t\tif errors.Is(err, io.EOF) {\n   345→\t\t\t\tbreak\n   346→\t\t\t}\n   347→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   348→\t\t\tos.Exit(1)\n   349→\t\t}\n   350→\n   351→\t\tswitch entry.Type {\n   352→\t\tcase \"step_started\":\n   353→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   354→\t\t\tif entry.Message != \"\" {\n   355→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   356→\t\t\t}\n   357→\t\tcase \"step_completed\":\n   358→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   359→\t\t\tif entry.Message != \"\" {\n   360→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   361→\t\t\t}\n   362→\t\tcase \"run_completed\":\