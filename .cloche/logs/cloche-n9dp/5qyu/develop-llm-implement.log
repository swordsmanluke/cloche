{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PRzQwrKFih77QtBPLiFH6d","type":"tool_result","content":"  2137→func TestRunsList_TaskGrouping(t *testing.T) {\n  2138→\th, store := setupHandler(t)\n  2139→\tctx := context.Background()\n  2140→\n  2141→\t// Create two host runs with the same task ID\n  2142→\tmain1 := domain.NewRun(\"tg-main-1\", \"main\")\n  2143→\tmain1.IsHost = true\n  2144→\tmain1.ProjectDir = \"/project\"\n  2145→\tmain1.TaskID = \"task-100\"\n  2146→\tmain1.Start()\n  2147→\trequire.NoError(t, store.CreateRun(ctx, main1))\n  2148→\n  2149→\tfin1 := domain.NewRun(\"tg-fin-1\", \"finalize\")\n  2150→\tfin1.IsHost = true\n  2151→\tfin1.ProjectDir = \"/project\"\n  2152→\tfin1.TaskID = \"task-100\"\n  2153→\tfin1.Start()\n  2154→\trequire.NoError(t, store.CreateRun(ctx, fin1))\n  2155→\n  2156→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n  2157→\tw := httptest.NewRecorder()\n  2158→\th.ServeHTTP(w, req)\n  2159→\n  2160→\tassert.Equal(t, http.StatusOK, w.Code)\n  2161→\n  2162→\tvar entries []apiGroupedEntry\n  2163→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &entries))\n  2164→\n  2165→\t// Should have: 1 task header + 2 run entries = 3 entries\n  2166→\tassert.Len(t, entries, 3)\n  2167→\n  2168→\t// First entry should be the task header\n  2169→\tassert.True(t, entries[0].TaskHeader)\n  2170→\tassert.Equal(t, \"task-100\", entries[0].TaskID)\n  2171→\n  2172→\t// Remaining entries should be runs with task_id set\n  2173→\tfor _, e := range entries[1:] {\n  2174→\t\trequire.NotNil(t, e.Run)\n  2175→\t\tassert.Equal(t, \"task-100\", e.Run.TaskID)\n  2176→\t}\n  2177→}\n  2178→\n  2179→func TestTaskAggregateStatus(t *testing.T) {\n  2180→\tnow := time.Now()\n  2181→\ttests := []struct {\n  2182→\t\tname   string\n  2183→\t\tstates []domain.RunState\n  2184→\t\ttimes  []time.Time // optional StartedAt per run; nil uses zero\n  2185→\t\twant   string\n  2186→\t}{\n  2187→\t\t{\"all succeeded\", []domain