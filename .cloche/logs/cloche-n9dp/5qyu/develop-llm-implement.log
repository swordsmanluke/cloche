(data.deleted !== 1 ? 's' : '');\n    85→                }\n    86→            })\n    87→            .catch(function() {\n    88→                if (btn) {\n    89→                    btn.textContent = 'Cleanup failed';\n    90→                    btn.disabled = false;\n    91→                }\n    92→            });\n    93→    };\n    94→\n    95→    function poll() {\n    96→        var url;\n    97→        if (currentProject) {\n    98→            var label = dirToLabel[currentProject];\n    99→            url = label ? '/api/projects/' + encodeURIComponent(label) + '/runs' : '/api/runs';\n   100→        } else {\n   101→            url = '/api/runs';\n   102→        }\n   103→        fetch(url)\n   104→            .then(function(r) { return r.json(); })\n   105→            .then(function(entries) {\n   106→                var tbody = document.getElementById('runs-body');\n   107→                if (!entries || entries.length === 0) {\n   108→                    tbody.innerHTML = '<tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>';\n   109→                    return;\n   110→                }\n   111→\n   112→                var html = '';\n   113→                for (var i = 0; i < entries.length; i++) {\n   114→                    var entry = entries[i];\n   115→                    if (entry.task_header) {\n   116→                        var ts = entry.task_status || 'pending';\n   117→                        html += '<tr class=\"run-task-header\"><td colspan=\"9\">Task: ' + escapeHtml(entry.task_id) + ' <span class=\"badge badge-' + ts + '\">' + ts + '</span></td></tr>';\n   118→                        continue;\n   119→                    }\n   120→                    var r = entry.run;\n   121→                    if (!r) continue;\n   122→                    var cid = r.container_id || '';\n   123→                    if (cid.length > 12) cid = cid.substring(0, 12);\n   124→                    var err = r.error_message || '';\n   125→           