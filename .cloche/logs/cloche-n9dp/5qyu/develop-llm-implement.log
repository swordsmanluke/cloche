{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014dMK59SZKqii1YaBKCmKTX","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"os/exec\"\n     9→\t\"strings\"\n    10→)\n    11→\n    12→// TaskStatus represents the state of a task from a task tracker.\n    13→type TaskStatus string\n    14→\n    15→const (\n    16→\tTaskStatusOpen       TaskStatus = \"open\"\n    17→\tTaskStatusClosed     TaskStatus = \"closed\"\n    18→\tTaskStatusInProgress TaskStatus = \"in-progress\"\n    19→)\n    20→\n    21→// Task represents a work item from an external task tracker.\n    22→type Task struct {\n    23→\tID          string            `json:\"id\"`\n    24→\tStatus      string            `json:\"status\"`\n    25→\tTitle       string            `json:\"title\"`\n    26→\tDescription string            `json:\"description\"`\n    27→\tMetadata    map[string]string `json:\"metadata,omitempty\"`\n    28→}\n    29→\n    30→// IsOpen returns true if the task status is \"open\" or empty (for backward compatibility).\n    31→func (t Task) IsOpen() bool {\n    32→\treturn t.Status == \"\" || TaskStatus(t.Status) == TaskStatusOpen\n    33→}\n    34→\n    35→// TaskAssigner lists available tasks for the daemon to assign to workflow runs.\n    36→type TaskAssigner interface {\n    37→\tListTasks(ctx context.Context, projectDir string) ([]Task, error)\n    38→}\n    39→\n    40→// ScriptTaskAssigner runs a shell command to list tasks and parses the JSON output.\n    41→// The command should output a JSON array of objects with at least an \"id\" field.\n    42→type ScriptTaskAssigner struct {\n    43→\tCommand string // shell command to run (e.g., \"bash .cloche/scripts/ready-tasks.sh\")\n    44→}\n    45→\n    46→// ListTasks executes the configured command from the project directory and\n    47→// parses its stdout as a JSON array of Task objects.\n    48→func (s *ScriptTaskAssigner) ListTasks(ctx context.Context, projectDir string) ([]Task, error) {\n    49→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", s.Command)\n    50→\tcmd.Dir = MainWorktreeDir(projectDir)\n    51→\n    52→\tout, err := cmd.Output()\n    53→\tif err != nil {\n    54→\t\treturn nil, fmt.Errorf(\"running list-tasks command: %w\", err)\n    55→\t}\n    56→\n    57→\toutput := strings.TrimSpace(string(out))\n    58→\tif output == \"\" || output == \"[]\" {\n    59→\t\treturn nil, nil\n    60→\t}\n    61→\n    62→\tvar tasks []Task\n    63→\tif err := json.Unmarshal([]byte(output), &tasks); err != nil {\n    64→\t\treturn nil, fmt.Errorf(\"parsing list-tasks output: %w\", err)\n    65→\t}\n    66→\treturn tasks, nil\n    67→}\n    68→\n    69→// ParseTasksJSONL parses JSONL-formatted task output (one JSON object per line).\n    70→// Each line should have at least an \"id\" field. Lines that are empty or fail to\n    71→// parse are skipped.\n    72→func ParseTasksJSONL(data string) ([]Task, error) {\n    73→\tvar tasks []Task\n    74→\tscanner := bufio.NewScanner(strings.NewReader(data))\n    75→\tlineNum := 0\n    76→\tfor scanner.Scan() {\n    77→\t\tlineNum++\n    78→\t\tline := strings.TrimSpace(scanner.Text())\n    79→\t\tif line == \"\" {\n    80→\t\t\tcontinue\n    81→\t\t}\n    82→\t\tvar task Task\n    83→\t\tif err := json.Unmarshal([]byte(line), &task); err != nil {\n    84→\t\t\treturn nil, fmt.Errorf(\"parsing JSONL line %d: %w\", lineNum, err)\n    85→\t\t}\n    86→\t\ttasks = append(tasks, task)\n    87→\t}\n    88→\treturn tasks, nil\n    89→}\n    90→"}]},"parent_tool_use_id":"toolu_01UEbdv2B3daoK9TXD3fwdjK","session_id":"e3f34296-02df-46c1-8f5c-4634c003d0b4","uuid":"211005ef-33c6-45ef-81c6-51edcf3ae459"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019Hin1bFnPMSqyHKB9U6v61","type":"tool_result","content":"     1→package domain\n     2→\n     3→import (\n     4→\t\"strings\"\n     5→\t\"time\"\n     6→)\n     7→\n     8→type RunState string\n     9→\n    10→const (\n    11→\tRunStatePending   RunState = \"pending\"\n    12→\tRunStateRunning   RunState = \"running\"\n    13→\tRunStateSucceeded RunState = \"succeeded\"\n    14→\tRunStateFailed    RunState = \"failed\"\n    15→\tRunStateCancelled RunState = \"cancelled\"\n    16→)\n    17→\n    18→type StepExecution struct {\n    19→\tStepName    string\n    20→\tResult      string\n    21→\tStartedAt   time.Time\n    22→\tCompletedAt time.Time\n    23→\tLogs        string\n    24→\tGitRef      string // output state\n    25→}\n    26→\n    27→func (e *StepExecution) Duration() time.Duration {\n    28→\treturn e.CompletedAt.Sub(e.StartedAt)\n    29→}\n    30→\n    31→type Run struct {\n    32→\tID             string\n    33→\tWorkflowName   string\n    34→\tState          RunState\n    35→\tActiveSteps    []string\n    36→\tStepExecutions []*StepExecution\n    37→\tStartedAt      time.Time\n    38→\tCompletedAt    time.Time\n    39→\tProjectDir     string\n    40→\tErrorMessage   string\n    41→\tContainerID    string\n    42→\tBaseSHA        string // Git HEAD at run start, for result branch creation\n    43→\tContainerKept  bool   // true when the container was retained after run completion\n    44→\tTitle          string // One-line summary of the work being done\n    45→\tIsHost         bool   // true for host workflow runs (vs container runs)\n    46→\tParentRunID    string // ID of the parent (host) run, empty for top-level runs\n    47→\tTaskID         string // optional task ID this run is associated with\n    48→}\n    49→\n    50→func NewRun(id, workflowName string) *Run {\n    51→\treturn &Run{\n    52→\t\tID:           id,\n    53→\t\tWorkflowName: workflowName,\n    54→\t\tState:        RunStatePending,\n    55→\t}\n    56→}\n    57→\n    58→func (r *Run) Start() {\n    59→\tr.State = RunStateRunning\n    60→\tr.StartedAt = time.Now()\n    61→}\n    62→\n    63→func (r *Run) RecordStepStart(stepName string) {\n    64→\tr.ActiveSteps = append(r.ActiveSteps, stepName)\n    65→\tr.StepExecutions = append(r.StepExecutions, &StepExecution{\n    66→\t\tStepName:  stepName,\n    67→\t\tStartedAt: time.Now(),\n    68→\t})\n    69→}\n    70→\n    71→func (r *Run) RecordStepComplete(stepName, result string) {\n    72→\t// Remove from active steps\n    73→\tfor i, name := range r.ActiveSteps {\n    74→\t\tif name == stepName {\n    75→\t\t\tr.ActiveSteps = append(r.ActiveSteps[:i], r.ActiveSteps[i+1:]...)\n    76→\t\t\tbreak\n    77→\t\t}\n    78→\t}\n    79→\t// Mark execution complete\n    80→\tfor i := len(r.StepExecutions) - 1; i >= 0; i-- {\n    81→\t\tif r.StepExecutions[i].StepName == stepName && r.StepExecutions[i].CompletedAt.IsZero() {\n    82→\t\t\tr.StepExecutions[i].Result = result\n    83→\t\t\tr.StepExecutions[i].CompletedAt = time.Now()\n    84→\t\t\treturn\n    85→\t\t}\n    86→\t}\n    87→}\n    88→\n    89→// ActiveStepsString returns a comma-separated representation of active steps\n    90→// for backward-compatible serialization.\n    91→func (r *Run) ActiveStepsString() string {\n    92→\treturn strings.Join(r.ActiveSteps, \",\")\n    93→}\n    94→\n    95→// SetActiveStepsFromString parses a comma-separated string into ActiveSteps.\n    96→func (r *Run) SetActiveStepsFromString(s string) {\n    97→\tif s == \"\" {\n    98→\t\tr.ActiveSteps = nil\n    99→\t\treturn\n   100→\t}\n   101→\tr.ActiveSteps = strings.Split(s, \",\")\n   102→}\n   103→\n   104→func (r *Run) Complete(state RunState) {\n   105→\tr.State = state\n   106→\tr.CompletedAt = time.Now()\n   107→}\n   108→\n   109→func (r *Run) Fail(msg string) {\n   110→\tr.State = RunStateFailed\n   111→\tr.CompletedAt = time.Now()\n   112→\tr.ErrorMessage = msg\n   113→}\n   114→\n   115→// TaskAggregateStatus computes the aggregate status for a group of runs\n   116→// representing attempts at a task. Active statuses (running, pending) outweigh\n   117→// terminal ones, and among terminal-only statuses the most recently started\n   118→// run determines the result.\n   119→func TaskAggregateStatus(runs []*Run) RunState {\n   120→\tif len(runs) == 0 {\n   121→\t\treturn RunStatePending\n   122→\t}\n   123→\n   124→\t// Active statuses outweigh terminal ones. Prefer running over pending.\n   125→\thasRunning := false\n   126→\thasPending := false\n   127→\tfor _, r := range runs {\n   128→\t\tswitch r.State {\n   129→\t\tcase RunStateRunning:\n   130→\t\t\thasRunning = true\n   131→\t\tcase RunStatePending:\n   132→\t\t\thasPending = true\n   133→\t\t}\n   134→\t}\n   135→\tif hasRunning {\n   136→\t\treturn RunStateRunning\n   137→\t}\n   138→\tif hasPending {\n   139→\t\treturn RunStatePending\n   140→\t}\n   141→\n   142→\t// All runs are terminal — return the state of the most recent attempt.\n   143→\tvar latest *Run\n   144→\tfor _, r := range runs {\n   145→\t\tif latest == nil || r.StartedAt.After(latest.StartedAt) {\n   146→\t\t\tlatest = r\n   147→\t\t}\n   148→\t}\n   149→\treturn latest.State\n   150→}\n   151→"}]},"parent_tool_use_id":"toolu_01UEbdv2B3daoK9TXD3fwdjK","session_id":"e3f34296-02df-46c1-8f5c-4634c003d0b4","uuid":"1f95cbce-f262-4fb8-a2e8-b19ee70571f2"}
