w</th>\n            <th>Type</th>\n            <th>State</th>\n            <th>Timing</th>\n            <th>Container</th>\n            <th>Error</th>\n        </tr>\n    </thead>\n    <tbody id=\"runs-body\">\n    {{if .GroupedRuns}}\n        {{range .GroupedRuns}}\n        {{if .TaskHeader}}\n        <tr class=\"run-task-header\"><td colspan=\"9\">Task: {{.TaskID}}{{if .TaskTitle}}: {{.TaskTitle}}{{end}} <span class=\"badge badge-{{.TaskStatus}}\">{{.TaskStatus}}</span></td></tr>\n        {{else if .Run}}\n        <tr class=\"{{if .IsChild}}run-child-row{{else if .IsParent}}run-parent-row{{end}}\">\n            <td><a href=\"/runs/{{.Run.ID}}\">{{.Run.ID}}</a></td>\n            <td>{{truncate .Run.Title 50}}</td>\n            <td>{{.Run.ProjectLabel}}</td>\n            <td>{{.Run.WorkflowName}}</td>\n            <td>{{if .Run.IsHost}}host{{else}}container{{end}}</td>\n            <td><span class=\"badge badge-{{.Run.State}}\">{{.Run.State}}</span></td>\n            <td>{{.Run.Timing}}</td>\n            <td class=\"mono\">{{shortContainerID .Run.ContainerID}}</td>\n            <td class=\"error-cell\">{{truncate .Run.ErrorMessage 80}}</td>\n        </tr>\n        {{end}}\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var currentProject = '{{.ProjectFilter}}';\n    var dirToLabel = {{jsonMap .DirToLabel}};\n\n    function filterByProject(dir) {\n        if (dir) {\n            var label = dirToLabel[dir];\n            if (label) {\n                window.location.href = '/projects/' + encodeURIComponent(label) + '/runs';\n            } else {\n                window.location.href = '/runs';\n            }\n        } else {\n            window.location.href = '/runs';\n        }\n    }\n    window.filterByProject = filterByProject;\n\n    window.cleanupContainers = function() {\n        var btn = document.getElementById('cleanup-containers-btn');\n        if (btn) btn.disabled = true;\n        fetch('/api/containers', { method: 'DELETE' })\n            .then(function(r) { return r.json(); })\n            .then(function(data) {\n                if (btn) {\n                    btn.textContent = 'Cleaned up ' + data.deleted + ' container' + (data.deleted !== 1 ? 's' : '');\n                }\n            })\n            .catch(function() {\n                if (btn) {\n                    btn.textContent = 'Cleanup failed';\n                    btn.disabled = false;\n                }\n            });\n    };\n\n    function poll() {\n        var url;\n        if (currentProject) {\n            var label = dirToLabel[currentProject];\n            url = label ? '/api/projects/' + encodeURIComponent(label) + '/runs' : '/api/runs';\n        } else {\n            url = '/api/runs';\n        }\n        fetch(url)\n            .then(function(r) { return r.json(); })\n            .then(function(entries) {\n                var tbody = document.getElementById('runs-body');\n                if (!entries || entries.length === 0) {\n                    tbody.innerHTML = '<tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>';\n                    return;\n                }\n\n                var html = '';\n                for (var i = 0; i < entries.length; i++) {\n                    var entry = entries[i];\n                    if (entry.task_header) {\n                        var ts = entry.task_status || 'pending';\n                        html += '<tr class=\"run-task-header\"><td colspan=\"9\">Task: ' + escapeHtml(entry.task_id) + ' <span class=\"badge badge-' + ts + '\">' + ts + '</span></td></tr>';\n                        continue;\n                    }\n                    var r = entry.run;\n                    if (!r) continue;\n                    var cid = r.container_id || '';\n                    if (cid.length > 12) cid = cid.substring(0, 12);\n                    var err = r.error_message || '';\n                    if (err.length > 80) err = err.substring(0, 80) + '...';\n                    var title = r.title || '';\n                    if (title.length > 50) title = title.substring(0, 47) + '...';\n                    var runType = r.is_host ? 'host' : 'container';\n                    var rowClass = entry.is_child ? 'run-child-row' : (entry.is_parent ? 'run-parent-row' : '');\n                    var timing = r.timing || '';\n                    var wfName = r.workflow_name || '';\n                    var state = r.state || '';\n                    html += '<tr class=\"' + rowClass + '\">' +\n                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n                        '<td>' + escapeHtml(title) + '</td>' +\n                        '<td>' + escapeHtml(r.project_label || '') + '</td>' +\n                        '<td>' + wfName + '</td>' +\n                        '<td>' + runType + '</td>' +\n                        '<td><span class=\"badge badge-' + state + '\">' + state + '</span></td>' +\n                        '<td>' + escapeHtml(timing) + '</td>' +\n                        '<td class=\"mono\">' + cid + '</td>' +\n                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                        '</tr>';\n                }\n                tbody.innerHTML = html;\n            })\n            .catch(function() {});\n    }\n    function escapeHtml(s) {\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n    setInterval(poll, 3000);\n})();\n</script>\n{{end}}\n","structuredPatch":[{"oldStart":114,"oldLines":7,"newStart":114,"newLines":9,"lines":["                     var entry = entries[i];","                     if (entry.task_header) {","                         var ts = entry.task_status || 'pending';","-                        html += '<tr class=\"run-task-header\"><td colspan=