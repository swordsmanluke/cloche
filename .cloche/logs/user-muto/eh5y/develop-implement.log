{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GhW7m8c7KdqQ6F3SzYjC6t","type":"tool_result","content":"  1200→\t\tif err != nil {\n  1201→\t\t\tcontinue\n  1202→\t\t}\n  1203→\t\tparsed, err := dsl.ParseForContainer(string(data))\n  1204→\t\tif err != nil {\n  1205→\t\t\tcontinue\n  1206→\t\t}\n  1207→\t\tif parsed.Name == workflowName {\n  1208→\t\t\twf = parsed\n  1209→\t\t\tbreak\n  1210→\t\t}\n  1211→\t}\n  1212→\tif wf == nil {\n  1213→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1214→\t\treturn\n  1215→\t}\n  1216→\n  1217→\tstep, ok := wf.Steps[stepName]\n  1218→\tif !ok {\n  1219→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1220→\t\treturn\n  1221→\t}\n  1222→\n  1223→\t// Try to read the referenced file from step config\n  1224→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1225→\n  1226→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1227→\t\tcontent, err := resolveFileRef(prompt, dir)\n  1228→\t\tif err == nil {\n  1229→\t\t\tw.Write([]byte(content))\n  1230→\t\t\treturn\n  1231→\t\t}\n  1232→\t}\n  1233→\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n  1234→\t\tcontent, _ := resolveFileRef(cmd, dir)\n  1235→\t\tw.Write([]byte(content))\n  1236→\t\treturn\n  1237→\t}\n  1238→\tif script := step.Config[\"script\"]; script != \"\" {\n  1239→\t\tcontent, _ := resolveFileRef(script, dir)\n  1240→\t\tw.Write([]byte(content))\n  1241→\t\treturn\n  1242→\t}\n  1243→\n  1244→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1245→}\n  1246→\n  1247→// --- Template helpers ---\n  1248→\n  1249→// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n  1250→// If the value uses file() syntax, the referenced file is read from disk.\n  1251→// Otherwise the value is returned as-is.\n  1252→func resolveFileRef(value, baseDir string) (string, error) {\n  1253→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n  1254→\t\tpath := value[6 : len(value)-2]\n  1255→\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n  1256→\t\tif err != nil {\n  1257→\t\t\treturn \"\", err\n  1258→\t\t}\n  1259→\t\treturn string(data), nil\n  1260→\t}\n  1261→\treturn value, nil\n  1262→}\n  1263→\n  1264→func stateColor(state domain.RunState) string {\n  1265→\tswitch state {\n  1266→\tcase domain.RunStatePending:\n  1267→\t\treturn \"pending\"\n  1268→\tcase domain.RunStateRunning:\n  1269→\t\treturn \"running\"\n  1270→\tcase domain.RunStateSucceeded:\n  1271→\t\treturn \"succeeded\"\n  1272→\tcase domain.RunStateFailed:\n  1273→\t\treturn \"failed\"\n  1274→\tcase domain.RunStateCancelled:\n  1275→\t\treturn \"cancelled\"\n  1276→\tdefault:\n  1277→\t\treturn \"pending\"\n  1278→\t}\n  1279→}\n  1280→\n  1281→func healthColor(status domain.HealthStatus) string {\n  1282→\tswitch status {\n  1283→\tcase domain.HealthGreen:\n  1284→\t\treturn \"green\"\n  1285→\tcase domain.HealthYellow:\n  1286→\t\treturn \"yellow\"\n  1287→\tcase domain.HealthRed:\n  1288→\t\treturn \"red\"\n  1289→\tcase domain.HealthBlue:\n  1290→\t\treturn \"blue\"\n  1291→\tdefault:\n  1292→\t\treturn \"grey\"\n  1293→\t}\n  1294→}\n  1295→\n  1296→func formatTime(t time.Time) string {\n  1297→\tif t.IsZero() {\n  1298→\t\treturn \"\"\n  1299→\t}\n  1300→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1301→}\n  1302→\n  1303→func formatDuration(start, end time.Time) string {\n  1304→\tif start.IsZero() || end.IsZero() {\n  1305→\t\treturn \"\"\n  1306→\t}\n  1307→\td := end.Sub(start)\n  1308→\tif d < time.Second {\n  1309→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1310→\t}\n  1311→\tif d < time.Minute {\n  1312→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1313→\t}\n  1314→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1315→}\n  1316→\n  1317→// formatSmartDuration formats a duration into a human-friendly short string.\n  1318→// Examples: \"3s\", \"2m\", \"1h20m\", \"3h\".\n  1319→func formatSmartDuration(d time.Duration) string {\n  1320→\tif d < time.Minute {\n  1321→\t\treturn fmt.Sprintf(\"%ds\", int(d.Seconds()))\n  1322→\t}\n  1323→\th := int(d.Hours())\n  1324→\tm := int(d.Minutes()) % 60\n  1325→\tif h == 0 {\n  1326→\t\treturn fmt.Sprintf(\"%dm\", m)\n  1327→\t}\n  1328→\tif m == 0 {\n  1329→\t\treturn fmt.Sprintf(\"%dh\", h)\n  1330→\t}\n  1331→\treturn fmt.Sprintf(\"%dh%dm\", h, m)\n  1332→}\n  1333→\n  1334→// roundRelativeTime rounds a duration to neat display units:\n  1335→// <1m -> \"<1m ago\", then 1m,5m,10m,15m,30m,45m,1h,2h,3h,...24h,\n  1336→// then days.\n  1337→func roundRelativeTime(d time.Duration) string {\n  1338→\tif d < time.Minute {\n  1339→\t\treturn \"<1m ago\"\n  1340→\t}\n  1341→\tmins := int(d.Minutes())\n  1342→\thours := int(d.Hours())\n  1343→\tdays := hours / 24\n  1344→\n  1345→\tif days > 0 {\n  1346→\t\tif days == 1 {\n  1347→\t\t\treturn \"1 day ago\"\n  1348→\t\t}\n  1349→\t\treturn fmt.Sprintf(\"%d days ago\", days)\n  1350→\t}\n  1351→\tif hours >= 1 {\n  1352→\t\tif hours == 1 {\n  1353→\t\t\treturn \"1 hour ago\"\n  1354→\t\t}\n  1355→\t\treturn fmt.Sprintf(\"%d hours ago\", hours)\n  1356→\t}\n  1357→\t// Round minutes to neat breakpoints\n  1358→\tswitch {\n  1359→\tcase mins < 3:\n  1360→\t\treturn \"1m ago\"\n  1361→\tcase mins < 8:\n  1362→\t\treturn \"5m ago\"\n  1363→\tcase mins < 13:\n  1364→\t\treturn \"10m ago\"\n  1365→\tcase mins < 20:\n  1366→\t\treturn \"15m ago\"\n  1367→\tcase mins < 38:\n  1368→\t\treturn \"30m ago\"\n  1369→\tcase mins < 53:\n  1370→\t\treturn \"45m ago\"\n  1371→\tdefault:\n  1372→\t\treturn \"1 hour ago\"\n  1373→\t}\n  1374→}\n  1375→\n  1376→// formatRunTiming returns a smart timing string for display on the Runs page.\n  1377→// Running: \"5m\" (just duration so far)\n  1378→// Completed: \"20m, 1 hour ago\"\n  1379→// Pending: \"\"\n  1380→func formatRunTiming(state domain.RunState, startedAt, completedAt time.Time) string {\n  1381→\treturn formatRunTimingAt(state, startedAt, completedAt, time.Now())\n  1382→}\n  1383→\n  1384→// formatRunTimingAt is the testable version of formatRunTiming with an explicit \"now\".\n  1385→func formatRunTimingAt(state domain.RunState, startedAt, completedAt, now time.Time) string {\n  1386→\tif startedAt.IsZero() {\n  1387→\t\treturn \"\"\n  1388→\t}\n  1389→\tswitch state {\n  1390→\tcase domain.RunStateRunning:\n  1391→\t\td := now.Sub(startedAt)\n  1392→\t\treturn formatSmartDuration(d)\n  1393→\tdefault:\n  1394→\t\tif completedAt.IsZero() {\n  1395→\t\t\treturn \"\"\n  1396→\t\t}\n  1397→\t\td := completedAt.Sub(startedAt)\n  1398→\t\tago := now.Sub(completedAt)\n  1399→\t\treturn formatSmartDuration(d) + \", \" + roundRelativeTime(ago)\n  1400→\t}\n  1401→}\n  1402→\n  1403→func truncate(s string, n int) string {\n  1404→\tif len(s) <= n {\n  1405→\t\treturn s\n  1406→\t}\n  1407→\treturn s[:n] + \"...\"\n  1408→}\n  1409→\n  1410→func shortContainerID(id string) string {\n  1411→\tif len(id) > 12 {\n  1412→\t\treturn id[:12]\n  1413→\t}\n  1414→\treturn id\n  1415→}\n  1416→\n  1417→// projectLabels builds a mapping from full project directory paths to short\n  1418→// display labels. Each label is the final directory component (e.g.\n  1419→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1420→// the same final name, the parent directory is prepended to disambiguate\n  1421→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1422→func projectLabels(dirs []string) map[string]string {\n  1423→\tlabels := make(map[string]string, len(dirs))\n  1424→\t// Group dirs by their base name to detect conflicts.\n  1425→\tbyBase := map[string][]string{}\n  1426→\tfor _, d := range dirs {\n  1427→\t\tbase := filepath.Base(d)\n  1428→\t\tbyBase[base] = append(byBase[base], d)\n  1429→\t}\n  1430→\tfor base, paths := range byBase {\n  1431→\t\tif len(paths) == 1 {\n  1432→\t\t\tlabels[paths[0]] = base\n  1433→\t\t} else {\n  1434→\t\t\tfor _, p := range paths {\n  1435→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1436→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1437→\t\t\t}\n  1438→\t\t}\n  1439→\t}\n  1440→\treturn labels\n  1441→}\n  1442→\n  1443→type projectEntry struct {\n  1444→\tDir            string\n  1445→\tLabel          string\n  1446→\tContainerCount int\n  1447→}\n  1448→"}]},"parent_tool_use_id":"toolu_013XQfDqEQmSNKz8rGm66953","session_id":"ad3012fc-7915-4d91-bc2f-6e4358dcbb9c","uuid":"00796f71-02b6-4e62-a6ff-79be3cfcb370"}
