ject config from <projectDir>/.cloche/config.\n    57→func Load(projectDir string) (*Config, error) {\n    58→\tcfg := defaults()\n    59→\tpath := filepath.Join(projectDir, \".cloche\", \"config\")\n    60→\n    61→\tdata, err := os.ReadFile(path)\n    62→\tif os.IsNotExist(err) {\n    63→\t\treturn &cfg, nil\n    64→\t}\n    65→\tif err != nil {\n    66→\t\treturn nil, err\n    67→\t}\n    68→\n    69→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    70→\t\treturn nil, err\n    71→\t}\n    72→\treturn &cfg, nil\n    73→}\n    74→\n    75→// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n    76→// Returns defaults if the file does not exist.\n    77→func LoadGlobal() (*Config, error) {\n    78→\tcfg := defaults()\n    79→\n    80→\thome, err := os.UserHomeDir()\n    81→\tif err != nil {\n    82→\t\treturn &cfg, nil\n    83→\t}\n    84→\n    85→\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n    86→\tdata, err := os.ReadFile(path)\n    87→\tif os.IsNotExist(err) {\n    88→\t\treturn &cfg, nil\n    89→\t}\n    90→\tif err != nil {\n    91→\t\treturn nil, err\n    92→\t}\n    93→\n    94→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    95→\t\treturn nil, err\n    96→\t}\n    97→\treturn &cfg, nil\n    98→}\n    99→\n   100→// LoadGlobalFrom reads the global config from a specific path.\n   101→// Useful for testing.\n   102→func LoadGlobalFrom(path string) (*Config, error) {\n   103→\tcfg := defaults()\n   104→\n   105→\tdata, err := os.ReadFile(path)\n   106→\tif os.IsNotExist(err) {\n   107→\t\treturn &cfg, nil\n   108→\t}\n   109→\tif err != nil {\n   110→\t\treturn nil, err\n   111→\t}\n   112→\n   113→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   114→\t\treturn nil, err\n   115→\t}\n   116→\treturn &cfg, nil\n   117→}\n   118→"}]},"parent_tool_use_id":null,"session_id":"f160845f-7287-4e1b-bb4f-9126514fdaa6","uuid":"ab94b3ce-e8c4-45bf-9cc1-559f5db99712","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/config/config.go","content":"package config\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\n\t\"github.com/BurntSushi/toml\"\n)\n\ntype DaemonConfig struct {\n\tListen     string `toml:\"listen\"`\n\tHTTP       string `toml:\"http\"`\n\tImage      string `toml:\"image\"`\n\tDB         string `toml:\"db\"`\n\tRuntime    string `toml:\"runtime\"`\n\tAgentPath  string `toml:\"agent_path\"`\n\tLLMCommand string `toml:\"llm_command\"`\n}\n\ntype EvolutionConfig struct {\n\tEnabled          bool   `toml:\"enabled\"`\n\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n\tMinConfidence    string `toml:\"min_confidence\"`\n\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n}\n\ntype OrchestrationConfig struct {\n\tEnabled     bool   `toml:\"enabled\"`\n\tTracker     string `toml:\"tracker\"`\n\tConcurrency int    `toml:\"concurrency\"`\n\tWorkflow    string `toml:\"workflow\"`\n}\n\ntype Config struct {\n\tDaemon        DaemonConfig        `toml:\"daemon\"`\n\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n}\n\nfunc defaults() Config {\n\treturn Config{\n\t\tEvolution: EvolutionConfig{\n\t\t\tEnabled:          true,\n\t\t\tDebounceSeconds:  30,\n\t\t\tMinConfidence:    \"medium\",\n\t\t\tMaxPromptBullets: 50,\n\t\t},\n\t\tOrchestration: OrchestrationConfig{\n\t\t\tTracker:     \"beads\",\n\t\t\tConcurrency: 1,\n\t\t\tWorkflow:     \"develop\",\n\t\t},\n\t}\n}\n\n// Load reads a per-project config from <projectDir>/.cloche/config.\nfunc Load(projectDir string) (*Config, error) {\n\tcfg := defaults()\n\tpath := filepath.Join(projectDir, \".cloche\", \"config\")\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n// Returns defaults if the file does not exist.\nfunc LoadGlobal() (*Config, error) {\n\tcfg := defaults()\n\n\thome, err := os.UserHomeDir()\n\tif err != nil {\n\t\treturn &cfg, nil\n\t}\n\n\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadGlobalFrom reads the global config from a specific path.\n// Useful for testing.\nfunc LoadGlobalFrom(path string) (*Config, error) {\n\tcfg := defaults()\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n","numLines":118,"startLine":1,"totalLines":118}}}
