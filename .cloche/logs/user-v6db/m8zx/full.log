[2026-03-06T20:49:06Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013JtjTB2U3WWnbVLRR8fFS6","type":"tool_result","content":"The file /workspace/internal/adapters/docker/build_test.go has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"e2002079-b665-4375-893a-6251b75ea2c2","uuid":"4b043b2f-c30c-477e-8031-3f5bb0299775","tool_use_result":{"filePath":"/workspace/internal/adapters/docker/build_test.go","oldString":"import (\n\t\"context\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)","newString":"import (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)","originalFile":"package docker\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestHashBytes(t *testing.T) {\n\th1 := hashBytes([]byte(\"hello\"))\n\th2 := hashBytes([]byte(\"hello\"))\n\th3 := hashBytes([]byte(\"world\"))\n\n\tassert.Equal(t, h1, h2, \"same input should produce same hash\")\n\tassert.NotEqual(t, h1, h3, \"different input should produce different hash\")\n\tassert.Len(t, h1, 64, \"SHA-256 hex digest should be 64 chars\")\n}\n\nfunc TestEnsureImage_NoDockerfile(t *testing.T) {\n\trt := &Runtime{}\n\tdir := t.TempDir()\n\n\t// No .cloche/Dockerfile — should succeed (nothing to validate)\n\terr := rt.EnsureImage(context.Background(), dir, \"test-image:latest\")\n\tassert.NoError(t, err)\n}\n\nfunc TestImageLabel_NonexistentImage(t *testing.T) {\n\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n\t\tt.Skip(\"Docker not available\")\n\t}\n\n\t_, err := imageLabel(context.Background(), \"cloche-nonexistent-image-xyz:latest\", dockerfileHashLabel)\n\tassert.Error(t, err)\n}\n\nfunc TestEnsureImage_BuildsWhenImageMissing(t *testing.T) {\n\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n\t\tt.Skip(\"Docker not available\")\n\t}\n\n\tdir := t.TempDir()\n\tdockerfileDir := filepath.Join(dir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(dockerfileDir, 0755))\n\n\t// Write a minimal Dockerfile\n\tdockerfile := []byte(\"FROM alpine:latest\\nRUN echo hello\\n\")\n\trequire.NoError(t, os.WriteFile(filepath.Join(dockerfileDir, \"Dockerfile\"), dockerfile, 0644))\n\n\timage := \"cloche-test-ensure-build:latest\"\n\t// Clean up any pre-existing image\n\texec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n\n\trt := &Runtime{}\n\terr := rt.EnsureImage(context.Background(), dir, image)\n\trequire.NoError(t, err)\n\n\t// Verify the image exists and has the label\n\tlabel, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n\trequire.NoError(t, err)\n\tassert.Equal(t, hashBytes(dockerfile), label)\n}\n\nfunc TestEnsureImage_SkipsWhenUpToDate(t *testing.T) {\n\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n\t\tt.Skip(\"Docker not available\")\n\t}\n\n\tdir := t.TempDir()\n\tdockerfileDir := filepath.Join(dir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(dockerfileDir, 0755))\n\n\tdockerfile := []byte(\"FROM alpine:latest\\nRUN echo skip-test\\n\")\n\trequire.NoError(t, os.WriteFile(filepath.Join(dockerfileDir, \"Dockerfile\"), dockerfile, 0644))\n\n\timage := \"cloche-test-ensure-skip:latest\"\n\texec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n\n\trt := &Runtime{}\n\n\t// First call: builds\n\terr := rt.EnsureImage(context.Background(), dir, image)\n\trequire.NoError(t, err)\n\n\t// Second call with same Dockerfile: should skip (no rebuild)\n\terr = rt.EnsureImage(context.Background(), dir, image)\n\trequire.NoError(t, err)\n\n\t// Image should still have the correct label\n\tlabel, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n\trequire.NoError(t, err)\n\tassert.Equal(t, hashBytes(dockerfile), label)\n}\n\nfunc TestBaseImageFromDockerfile(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tcontent  string\n\t\texpected string\n\t}{\n\t\t{\n\t\t\tname:     \"single FROM\",\n\t\t\tcontent:  \"FROM ubuntu:24.04\\nRUN echo hello\\n\",\n\t\t\texpected: \"ubuntu:24.04\",\n\t\t},\n\t\t{\n\t\t\tname:     \"multi-stage build returns last FROM\",\n\t\t\tcontent:  \"FROM golang:1.22 AS builder\\nRUN go build\\nFROM alpine:latest\\nCOPY --from=builder /app /app\\n\",\n\t\t\texpected: \"alpine:latest\",\n\t\t},\n\t\t{\n\t\t\tname:     \"FROM with AS alias\",\n\t\t\tcontent:  \"FROM cloche-base:latest AS base\\nRUN echo hello\\n\",\n\t\t\texpected: \"cloche-base:latest\",\n\t\t},\n\t\t{\n\t\t\tname:     \"comments and blank lines\",\n\t\t\tcontent:  \"# This is a comment\\n\\nFROM ubuntu:22.04\\nRUN echo hello\\n\",\n\t\t\texpected: \"ubuntu:22.04\",\n\t\t},\n\t\t{\n\t\t\tname:     \"ARG before FROM\",\n\t\t\tcontent:  \"ARG BASE=ubuntu:24.04\\nFROM ubuntu:24.04\\nRUN echo hello\\n\",\n\t\t\texpected: \"ubuntu:24.04\",\n\t\t},\n\t\t{\n\t\t\tname:     \"commented FROM ignored\",\n\t\t\tcontent:  \"# FROM scratch\\nFROM alpine:3.19\\n\",\n\t\t\texpected: \"alpine:3.19\",\n\t\t},\n\t\t{\n\t\t\tname:     \"empty content\",\n\t\t\tcontent:  \"\",\n\t\t\texpected: \"\",\n\t\t},\n\t\t{\n\t\t\tname:     \"case insensitive FROM\",\n\t\t\tcontent:  \"from ubuntu:latest\\nRUN echo hello\\n\",\n\t\t\texpected: \"ubuntu:latest\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tresult := baseImageFromDockerfile([]byte(tt.content))\n\t\t\tassert.Equal(t, tt.expected, result)\n\t\t})\n\t}\n}\n\nfunc TestImageID_NonexistentImage(t *testing.T) {\n\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n\t\tt.Skip(\"Docker not available\")\n\t}\n\n\t_, err := imageID(context.Background(), \"cloche-nonexistent-image-xyz:latest\")\n\tassert.Error(t, err)\n}\n\nfunc TestEnsureImage_RebuildsWhenBaseImageChanges(t *testing.T) {\n\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n\t\tt.Skip(\"Docker not available\")\n\t}\n\n\tctx := context.Background()\n\tbaseImage := \"cloche-test-base-change:latest\"\n\tprojectImage := \"cloche-test-base-detect:latest\"\n\n\t// Clean up\n\texec.Command(\"docker\", \"rmi\", \"-f\", baseImage).Run()\n\texec.Command(\"docker\", \"rmi\", \"-f\", projectImage).Run()\n\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", baseImage).Run()\n\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", projectImage).Run()\n\n\t// Build base image v1\n\tbaseDir := t.TempDir()\n\tbaseDockerfile := filepath.Join(baseDir, \"Dockerfile\")\n\trequire.NoError(t, os.WriteFile(baseDockerfile, []byte(\"FROM alpine:latest\\nRUN echo base-v1\\n\"), 0644))\n\tcmd := exec.CommandContext(ctx, \"docker\", \"build\", \"-t\", baseImage, \"-f\", baseDockerfile, baseDir)\n\tcmd.Stdout = os.Stderr\n\tcmd.Stderr = os.Stderr\n\trequire.NoError(t, cmd.Run())\n\n\tbaseIDv1, err := imageID(ctx, baseImage)\n\trequire.NoError(t, err)\n\n\t// Build project image using the base\n\tdir := t.TempDir()\n\tdockerfileDir := filepath.Join(dir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(dockerfileDir, 0755))\n\tprojectDockerfile := []byte(fmt.Sprintf(\"FROM %s\\nRUN echo project\\n\", baseImage))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dockerfileDir, \"Dockerfile\"), projectDockerfile, 0644))\n\n\trt := &Runtime{}\n\trequire.NoError(t, rt.EnsureImage(ctx, dir, projectImage))\n\n\t// Verify base image ID label was stored\n\tstoredBaseID, err := imageLabel(ctx, projectImage, baseImageIDLabel)\n\trequire.NoError(t, err)\n\tassert.Equal(t, baseIDv1, storedBaseID)\n\n\t// Rebuild base image with different content (v2)\n\trequire.NoError(t, os.WriteFile(baseDockerfile, []byte(\"FROM alpine:latest\\nRUN echo base-v2\\n\"), 0644))\n\tcmd = exec.CommandContext(ctx, \"docker\", \"build\", \"-t\", baseImage, \"-f\", baseDockerfile, baseDir)\n\tcmd.Stdout = os.Stderr\n\tcmd.Stderr = os.Stderr\n\trequire.NoError(t, cmd.Run())\n\n\tbaseIDv2, err := imageID(ctx, baseImage)\n\trequire.NoError(t, err)\n\trequire.NotEqual(t, baseIDv1, baseIDv2, \"base image should have changed\")\n\n\t// EnsureImage should detect base image change and rebuild\n\trequire.NoError(t, rt.EnsureImage(ctx, dir, projectImage))\n\n\t// Verify the stored base image ID was updated\n\tstoredBaseID, err = imageLabel(ctx, projectImage, baseImageIDLabel)\n\trequire.NoError(t, err)\n\tassert.Equal(t, baseIDv2, storedBaseID)\n}\n\nfunc TestEnsureImage_RebuildsWhenDockerfileChanges(t *testing.T) {\n\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n\t\tt.Skip(\"Docker not available\")\n\t}\n\n\tdir := t.TempDir()\n\tdockerfileDir := filepath.Join(dir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(dockerfileDir, 0755))\n\n\tdockerfilePath := filepath.Join(dockerfileDir, \"Dockerfile\")\n\n\t// Initial Dockerfile\n\tv1 := []byte(\"FROM alpine:latest\\nRUN echo v1\\n\")\n\trequire.NoError(t, os.WriteFile(dockerfilePath, v1, 0644))\n\n\timage := \"cloche-test-ensure-rebuild:latest\"\n\texec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n\n\trt := &Runtime{}\n\n\t// Build with v1\n\terr := rt.EnsureImage(context.Background(), dir, image)\n\trequire.NoError(t, err)\n\n\tlabel1, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n\trequire.NoError(t, err)\n\tassert.Equal(t, hashBytes(v1), label1)\n\n\t// Change Dockerfile to v2\n\tv2 := []byte(\"FROM alpine:latest\\nRUN echo v2\\n\")\n\trequire.NoError(t, os.WriteFile(dockerfilePath, v2, 0644))\n\n\t// Should detect change and rebuild\n\terr = rt.EnsureImage(context.Background(), dir, image)\n\trequire.NoError(t, err)\n\n\tlabel2, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n\trequire.NoError(t, err)\n\tassert.Equal(t, hashBytes(v2), label2)\n\tassert.NotEqual(t, label1, label2, \"label should change after rebuild\")\n}\n","structuredPatch":[{"oldStart":2,"oldLines":6,"newStart":2,"newLines":7,"lines":[" "," import (","   \"context\"","+  \"fmt\"","   \"os\"","   \"os/exec\"","   \"path/filepath\""]}],"userModified":false,"replaceAll":false}}
