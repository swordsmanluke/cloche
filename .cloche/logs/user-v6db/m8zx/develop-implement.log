{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MskqEjhpXcinpgVtb8DsMF","type":"tool_result","content":"     1→package docker\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"context\"\n     6→\t\"crypto/sha256\"\n     7→\t\"encoding/hex\"\n     8→\t\"fmt\"\n     9→\t\"log\"\n    10→\t\"os\"\n    11→\t\"os/exec\"\n    12→\t\"path/filepath\"\n    13→\t\"strings\"\n    14→)\n    15→\n    16→const dockerfileHashLabel = \"cloche.dockerfile.hash\"\n    17→\n    18→// EnsureImage checks whether the Docker image is up-to-date with the project\n    19→// Dockerfile. If the image does not exist or the Dockerfile has changed since\n    20→// the image was built, it rebuilds automatically.\n    21→func (r *Runtime) EnsureImage(ctx context.Context, projectDir, image string) error {\n    22→\tdockerfilePath := filepath.Join(projectDir, \".cloche\", \"Dockerfile\")\n    23→\n    24→\tcontent, err := os.ReadFile(dockerfilePath)\n    25→\tif err != nil {\n    26→\t\tif os.IsNotExist(err) {\n    27→\t\t\t// No project Dockerfile — nothing to validate.\n    28→\t\t\treturn nil\n    29→\t\t}\n    30→\t\treturn fmt.Errorf(\"reading Dockerfile: %w\", err)\n    31→\t}\n    32→\n    33→\tcurrentHash := hashBytes(content)\n    34→\n    35→\tstoredHash, err := imageLabel(ctx, image, dockerfileHashLabel)\n    36→\tif err == nil && storedHash == currentHash {\n    37→\t\tlog.Printf(\"image %s is up-to-date (dockerfile hash %s)\", image, currentHash[:12])\n    38→\t\treturn nil\n    39→\t}\n    40→\n    41→\t// Image is missing or stale — rebuild.\n    42→\tif err != nil {\n    43→\t\tlog.Printf(\"image %s not found or cannot inspect; building\", image)\n    44→\t} else {\n    45→\t\tlog.Printf(\"image %s is stale (have %s, want %s); rebuilding\", image, storedHash[:12], currentHash[:12])\n    46→\t}\n    47→\n    48→\treturn buildImage(ctx, projectDir, dockerfilePath, image, currentHash)\n    49→}\n    50→\n    51→// hashBytes returns the hex-encoded SHA-256 digest of data.\n    52→func hashBytes(data []byte) string {\n    53→\th := sha256.Sum256(data)\n    54→\treturn hex.EncodeToString(h[:])\n    55→}\n    56→\n    57→// imageLabel retrieves a label value from a Docker image.\n    58→// Returns an error if the image does not exist or cannot be inspected.\n    59→func imageLabel(ctx context.Context, image, label string) (string, error) {\n    60→\tcmd := exec.CommandContext(ctx, \"docker\", \"inspect\",\n    61→\t\t\"--format\", fmt.Sprintf(\"{{index .Config.Labels %q}}\", label),\n    62→\t\timage)\n    63→\tvar stdout, stderr bytes.Buffer\n    64→\tcmd.Stdout = &stdout\n    65→\tcmd.Stderr = &stderr\n    66→\tif err := cmd.Run(); err != nil {\n    67→\t\treturn \"\", fmt.Errorf(\"inspecting image %s: %s: %w\", image, strings.TrimSpace(stderr.String()), err)\n    68→\t}\n    69→\tval := strings.TrimSpace(stdout.String())\n    70→\tif val == \"\" || val == \"<no value>\" {\n    71→\t\treturn \"\", fmt.Errorf(\"label %s not set on image %s\", label, image)\n    72→\t}\n    73→\treturn val, nil\n    74→}\n    75→\n    76→// buildImage runs docker build for the project, tagging the result with the\n    77→// given image name and embedding the Dockerfile hash as a label.\n    78→func buildImage(ctx context.Context, projectDir, dockerfilePath, image, hash string) error {\n    79→\tlog.Printf(\"building image %s from %s\", image, dockerfilePath)\n    80→\n    81→\targs := []string{\n    82→\t\t\"build\",\n    83→\t\t\"-t\", image,\n    84→\t\t\"-f\", dockerfilePath,\n    85→\t\t\"--label\", fmt.Sprintf(\"%s=%s\", dockerfileHashLabel, hash),\n    86→\t\tprojectDir,\n    87→\t}\n    88→\n    89→\tcmd := exec.CommandContext(ctx, \"docker\", args...)\n    90→\tcmd.Stdout = os.Stderr // stream build output to daemon stderr\n    91→\tcmd.Stderr = os.Stderr\n    92→\tif err := cmd.Run(); err != nil {\n    93→\t\treturn fmt.Errorf(\"building image %s: %w\", image, err)\n    94→\t}\n    95→\n    96→\tlog.Printf(\"image %s built successfully\", image)\n    97→\treturn nil\n    98→}\n    99→"}]},"parent_tool_use_id":null,"session_id":"e2002079-b665-4375-893a-6251b75ea2c2","uuid":"032070b4-38f9-4dc9-a4e5-7b0fa32c643d","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/docker/build.go","content":"package docker\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/sha256\"\n\t\"encoding/hex\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n)\n\nconst dockerfileHashLabel = \"cloche.dockerfile.hash\"\n\n// EnsureImage checks whether the Docker image is up-to-date with the project\n// Dockerfile. If the image does not exist or the Dockerfile has changed since\n// the image was built, it rebuilds automatically.\nfunc (r *Runtime) EnsureImage(ctx context.Context, projectDir, image string) error {\n\tdockerfilePath := filepath.Join(projectDir, \".cloche\", \"Dockerfile\")\n\n\tcontent, err := os.ReadFile(dockerfilePath)\n\tif err != nil {\n\t\tif os.IsNotExist(err) {\n\t\t\t// No project Dockerfile — nothing to validate.\n\t\t\treturn nil\n\t\t}\n\t\treturn fmt.Errorf(\"reading Dockerfile: %w\", err)\n\t}\n\n\tcurrentHash := hashBytes(content)\n\n\tstoredHash, err := imageLabel(ctx, image, dockerfileHashLabel)\n\tif err == nil && storedHash == currentHash {\n\t\tlog.Printf(\"image %s is up-to-date (dockerfile hash %s)\", image, currentHash[:12])\n\t\treturn nil\n\t}\n\n\t// Image is missing or stale — rebuild.\n\tif err != nil {\n\t\tlog.Printf(\"image %s not found or cannot inspect; building\", image)\n\t} else {\n\t\tlog.Printf(\"image %s is stale (have %s, want %s); rebuilding\", image, storedHash[:12], currentHash[:12])\n\t}\n\n\treturn buildImage(ctx, projectDir, dockerfilePath, image, currentHash)\n}\n\n// hashBytes returns the hex-encoded SHA-256 digest of data.\nfunc hashBytes(data []byte) string {\n\th := sha256.Sum256(data)\n\treturn hex.EncodeToString(h[:])\n}\n\n// imageLabel retrieves a label value from a Docker image.\n// Returns an error if the image does not exist or cannot be inspected.\nfunc imageLabel(ctx context.Context, image, label string) (string, error) {\n\tcmd := exec.CommandContext(ctx, \"docker\", \"inspect\",\n\t\t\"--format\", fmt.Sprintf(\"{{index .Config.Labels %q}}\", label),\n\t\timage)\n\tvar stdout, stderr bytes.Buffer\n\tcmd.Stdout = &stdout\n\tcmd.Stderr = &stderr\n\tif err := cmd.Run(); err != nil {\n\t\treturn \"\", fmt.Errorf(\"inspecting image %s: %s: %w\", image, strings.TrimSpace(stderr.String()), err)\n\t}\n\tval := strings.TrimSpace(stdout.String())\n\tif val == \"\" || val == \"<no value>\" {\n\t\treturn \"\", fmt.Errorf(\"label %s not set on image %s\", label, image)\n\t}\n\treturn val, nil\n}\n\n// buildImage runs docker build for the project, tagging the result with the\n// given image name and embedding the Dockerfile hash as a label.\nfunc buildImage(ctx context.Context, projectDir, dockerfilePath, image, hash string) error {\n\tlog.Printf(\"building image %s from %s\", image, dockerfilePath)\n\n\targs := []string{\n\t\t\"build\",\n\t\t\"-t\", image,\n\t\t\"-f\", dockerfilePath,\n\t\t\"--label\", fmt.Sprintf(\"%s=%s\", dockerfileHashLabel, hash),\n\t\tprojectDir,\n\t}\n\n\tcmd := exec.CommandContext(ctx, \"docker\", args...)\n\tcmd.Stdout = os.Stderr // stream build output to daemon stderr\n\tcmd.Stderr = os.Stderr\n\tif err := cmd.Run(); err != nil {\n\t\treturn fmt.Errorf(\"building image %s: %w\", image, err)\n\t}\n\n\tlog.Printf(\"image %s built successfully\", image)\n\treturn nil\n}\n","numLines":99,"startLine":1,"totalLines":99}}}
