{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y1C5mVrg9WKjYtanNiB7AR","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→\t\"time\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    15→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    17→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18→\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    19→)\n    20→\n    21→// Ensure hostStatusHandler implements engine.StatusHandler.\n    22→var _ engine.StatusHandler = (*hostStatusHandler)(nil)\n    23→\n    24→// Runner executes a host workflow by parsing host.cloche and walking the step graph.\n    25→type Runner struct {\n    26→\tDispatcher    RunDispatcher\n    27→\tStore         ports.RunStore\n    28→\tCaptures      ports.CaptureStore       // optional: saves step captures for cloche logs\n    29→\tLogBroadcast  *logstream.Broadcaster   // optional: publishes live log lines\n    30→\tTaskID        string                   // optional task ID assigned by the daemon loop\n    31→\tExtraEnv      []string                 // additional KEY=VALUE env vars passed to all steps\n    32→\tSkipRunRecord bool                     // when true, don't persist a run record to the store\n    33→}\n    34→\n    35→// RunResult contains the outcome of a host workflow execution.\n    36→type RunResult struct {\n    37→\tRunID     string\n    38→\tState     domain.RunState\n    39→\tOutputDir string // path to the step output directory\n    40→}\n    41→\n    42→// Run parses .cloche/host.cloche from projectDir and executes the \"main\" workflow.\n    43→func (r *Runner) Run(ctx context.Context, projectDir string) (*RunResult, error) {\n    44→\treturn r.RunWithID(ctx, projectDir, domain.GenerateRunID(\"main\"))\n    45→}\n    46→\n    47→// RunWithID is like Run but uses the provided run ID instead of generating one.\n    48→func (r *Runner) RunWithID(ctx context.Context, projectDir string, orchRunID string) (*RunResult, error) {\n    49→\treturn r.runNamedWorkflow(ctx, projectDir, \"main\", orchRunID)\n    50→}\n    51→\n    52→// RunNamed executes a named host workflow, generating a new run ID.\n    53→func (r *Runner) RunNamed(ctx context.Context, projectDir string, workflowName string) (*RunResult, error) {\n    54→\torchRunID := domain.GenerateRunID(workflowName)\n    55→\treturn r.runNamedWorkflow(ctx, projectDir, workflowName, orchRunID)\n    56→}\n    57→\n    58→// RunNamedWithID executes a named host workflow using the provided run ID.\n    59→func (r *Runner) RunNamedWithID(ctx context.Context, projectDir string, workflowName string, runID string) (*RunResult, error) {\n    60→\treturn r.runNamedWorkflow(ctx, projectDir, workflowName, runID)\n    61→}\n    62→\n    63→// runNamedWorkflow is the internal implementation that runs a specific named\n    64→// host workflow. Searches all .cloche files for the workflow.\n    65→func (r *Runner) runNamedWorkflow(ctx context.Context, projectDir string, workflowName string, orchRunID string) (*RunResult, error) {\n    66→\twf, err := findHostWorkflow(projectDir, workflowName)\n    67→\tif err != nil {\n    68→\t\treturn nil, err\n    69→\t}\n    70→\n    71→\t// Create output directory for step outputs\n    72→\toutputDir := filepath.Join(projectDir, \".cloche\", orchRunID, \"output\")\n    73→\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n    74→\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n    75→\t}\n    76→\n    77→\tlog.Printf(\"host workflow: starting %q for project %s (run %s)\", wf.Name, projectDir, orchRunID)\n    78→\n    79→\t// Persist the host run in the store so it appears in list/status/logs.\n    80→\t// When SkipRunRecord is set (e.g. for list-tasks polling), skip creating\n    81→\t// the record to avoid cluttering the run history.\n    82→\tif !r.SkipRunRecord {\n    83→\t\thostRun := domain.NewRun(orchRunID, wf.Name)\n    84→\t\thostRun.ProjectDir = projectDir\n    85→\t\thostRun.IsHost = true\n    86→\t\thostRun.TaskID = r.TaskID\n    87→\t\tif err := r.Store.CreateRun(ctx, hostRun); err != nil {\n    88→\t\t\treturn nil, fmt.Errorf(\"creating host run record: %w\", err)\n    89→\t\t}\n    90→\t\thostRun.Start()\n    91→\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n    92→\n    93→\t\t// Persist ExtraEnv so resume can restore it (e.g. CLOCHE_MAIN_RUN_ID).\n    94→\t\tsaveExtraEnv(projectDir, orchRunID, r.ExtraEnv)\n    95→\t}\n    96→\n    97→\texecutor := &Executor{\n    98→\t\tProjectDir: projectDir,\n    99→\t\tMainDir:    MainWorktreeDir(projectDir),\n   100→\t\tDispatcher: r.Dispatcher,\n   101→\t\tStore:      r.Store,\n   102→\t\tOutputDir:  outputDir,\n   103→\t\tWires:      wf.Wiring,\n   104→\t\tHostRunID:  orchRunID,\n   105→\t\tTaskID:     r.TaskID,\n   106→\t\tExtraEnv:   r.ExtraEnv,\n   107→\t}\n   108→\n   109→\t// Configure agent from workflow-level host config\n   110→\tif cmd := wf.Config[\"host.agent_command\"]; cmd != \"\" {\n   111→\t\texecutor.AgentCommands = prompt.ParseCommands(cmd)\n   112→\t}\n   113→\tif args := wf.Config[\"host.agent_args\"]; args != \"\" {\n   114→\t\texecutor.AgentArgs = strings.Fields(args)\n   115→\t}\n   116→\n   117→\t// Create a logstream.Writer so host runs persist logs to full.log,\n   118→\t// matching container-side behavior where the agent writes full.log.\n   119→\tvar ulog *logstream.Writer\n   120→\tif !r.SkipRunRecord {\n   121→\t\tw, err := logstream.NewAtDir(outputDir)\n   122→\t\tif err != nil {\n   123→\t\t\tlog.Printf(\"host workflow [%s]: failed to create log writer: %v\", orchRunID, err)\n   124→\t\t} else {\n   125→\t\t\tulog = w\n   126→\t\t}\n   127→\t}\n   128→\n   129→\t// Register run in broadcaster so IsActive returns true for live-stream callers.\n   130→\tif r.LogBroadcast != nil {\n   131→\t\tr.LogBroadcast.Start(orchRunID)\n   132→\t}\n   133→\n   134→\teng := engine.New(executor)\n   135→\teng.SetStatusHandler(&hostStatusHandler{\n   136→\t\tprojectDir:   projectDir,\n   137→\t\torchRunID:    orchRunID,\n   138→\t\tstore:        r.Store,\n   139→\t\tcaptures:     r.Captures,\n   140→\t\tlogBroadcast: r.LogBroadcast,\n   141→\t\toutputDir:    outputDir,\n   142→\t\tlogWriter:    ulog,\n   143→\t})\n   144→\n   145→\trun, runErr := eng.Run(ctx, wf)\n   146→\n   147→\tif ulog != nil {\n   148→\t\tulog.Close()\n   149→\t}\n   150→\n   151→\tresult := &RunResult{\n   152→\t\tRunID:     orchRunID,\n   153→\t\tState:     domain.RunStateFailed,\n   154→\t\tOutputDir: outputDir,\n   155→\t}\n   156→\tif run != nil {\n   157→\t\tresult.State = run.State\n   158→\t}\n   159→\n   160→\t// Persist final state.\n   161→\tif !r.SkipRunRecord {\n   162→\t\thostRun, _ := r.Store.GetRun(ctx, orchRunID)\n   163→\t\tif hostRun != nil {\n   164→\t\t\tif runErr != nil {\n   165→\t\t\t\thostRun.Fail(runErr.Error())\n   166→\t\t\t} else {\n   167→\t\t\t\thostRun.Complete(result.State)\n   168→\t\t\t}\n   169→\t\t\thostRun.ActiveSteps = nil\n   170→\t\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n   171→\t\t}\n   172→\t}\n   173→\n   174→\t// Signal live-stream subscribers that this run is done (after state update\n   175→\t// so subscribers see the final state when their channel closes).\n   176→\tif r.LogBroadcast != nil {\n   177→\t\tr.LogBroadcast.Finish(orchRunID)\n   178→\t}\n   179→\n   180→\tif runErr != nil {\n   181→\t\tlog.Printf(\"host workflow: %q failed for %s: %v\", wf.Name, projectDir, runErr)\n   182→\t\treturn result, runErr\n   183→\t}\n   184→\n   185→\tlog.Printf(\"host workflow: %q completed for %s with state %s\", wf.Name, projectDir, run.State)\n   186→\treturn result, nil\n   187→}\n   188→\n   189→// ResumeRun resumes a failed host workflow run from a specific step.\n   190→// Steps before resumeFrom are replayed from their stored results.\n   191→func (r *Runner) ResumeRun(ctx context.Context, run *domain.Run, resumeFrom string) (*RunResult, error) {\n   192→\twf, err := findHostWorkflow(run.ProjectDir, run.WorkflowName)\n   193→\tif err != nil {\n   194→\t\treturn nil, err\n   195→\t}\n   196→\n   197→\t// Validate the resume step exists\n   198→\tif _, ok := wf.Steps[resumeFrom]; !ok {\n   199→\t\treturn nil, fmt.Errorf(\"step %q not found in workflow %q\", resumeFrom, run.WorkflowName)\n   200→\t}\n   201→\n   202→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\")\n   203→\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n   204→\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n   205→\t}\n   206→\n   207→\tlog.Printf(\"host workflow: resuming %q from step %q for project %s (run %s)\", wf.Name, resumeFrom, run.ProjectDir, run.ID)\n   208→\n   209→\t// Restore ExtraEnv from the original run's context so that env vars like\n   210→\t// CLOCHE_MAIN_RUN_ID are available to re-executed steps.\n   211→\textraEnv := r.ExtraEnv\n   212→\tif len(extraEnv) == 0 {\n   213→\t\textraEnv = loadExtraEnv(run.ProjectDir, run.ID)\n   214→\t}\n   215→\n   216→\t// Reset run state\n   217→\trun.State = domain.RunStateRunning\n   218→\trun.ErrorMessage = \"\"\n   219→\trun.CompletedAt = time.Time{}\n   220→\trun.ActiveSteps = nil\n   221→\tif err := r.Store.UpdateRun(ctx, run); err != nil {\n   222→\t\treturn nil, fmt.Errorf(\"updating run state: %w\", err)\n   223→\t}\n   224→\n   225→\texecutor := &Executor{\n   226→\t\tProjectDir: run.ProjectDir,\n   227→\t\tMainDir:    MainWorktreeDir(run.ProjectDir),\n   228→\t\tDispatcher: r.Dispatcher,\n   229→\t\tStore:      r.Store,\n   230→\t\tOutputDir:  outputDir,\n   231→\t\tWires:      wf.Wiring,\n   232→\t\tHostRunID:  run.ID,\n   233→\t\tTaskID:     r.TaskID,\n   234→\t\tExtraEnv:   extraEnv,\n   235→\t}\n   236→\n   237→\t// Configure agent from workflow-level host config\n   238→\tif cmd := wf.Config[\"host.agent_command\"]; cmd != \"\" {\n   239→\t\texecutor.AgentCommands = prompt.ParseCommands(cmd)\n   240→\t}\n   241→\tif args := wf.Config[\"host.agent_args\"]; args != \"\" {\n   242→\t\texecutor.AgentArgs = strings.Fields(args)\n   243→\t}\n   244→\n   245→\t// Build preloaded results from previously completed steps\n   246→\tpreloaded := buildPreloadedResults(run, wf, resumeFrom)\n   247→\n   248→\t// Configure the executor to know which step is being resumed (for prompt resume)\n   249→\texecutor.ResumeStep = resumeFrom\n   250→\n   251→\tvar ulog *logstream.Writer\n   252→\tw, err := logstream.NewAtDir(outputDir)\n   253→\tif err != nil {\n   254→\t\tlog.Printf(\"host workflow [%s]: failed to create log writer: %v\", run.ID, err)\n   255→\t} else {\n   256→\t\tulog = w\n   257→\t}\n   258→\n   259→\t// Register run in broadcaster so IsActive returns true for live-stream callers.\n   260→\tif r.LogBroadcast != nil {\n   261→\t\tr.LogBroadcast.Start(run.ID)\n   262→\t}\n   263→\n   264→\teng := engine.New(executor)\n   265→\teng.SetPreloadedResults(preloaded)\n   266→\teng.SetStatusHandler(&hostStatusHandler{\n   267→\t\tprojectDir:   run.ProjectDir,\n   268→\t\torchRunID:    run.ID,\n   269→\t\tstore:        r.Store,\n   270→\t\tcaptures:     r.Captures,\n   271→\t\tlogBroadcast: r.LogBroadcast,\n   272→\t\toutputDir:    outputDir,\n   273→\t\tlogWriter:    ulog,\n   274→\t})\n   275→\n   276→\tengRun, runErr := eng.Run(ctx, wf)\n   277→\n   278→\tif ulog != nil {\n   279→\t\tulog.Close()\n   280→\t}\n   281→\n   282→\tresult := &RunResult{\n   283→\t\tRunID:     run.ID,\n   284→\t\tState:     domain.RunStateFailed,\n   285→\t\tOutputDir: outputDir,\n   286→\t}\n   287→\tif engRun != nil {\n   288→\t\tresult.State = engRun.State\n   289→\t}\n   290→\n   291→\t// Persist final state\n   292→\thostRun, _ := r.Store.GetRun(ctx, run.ID)\n   293→\tif hostRun != nil {\n   294→\t\tif runErr != nil {\n   295→\t\t\thostRun.Fail(runErr.Error())\n   296→\t\t} else {\n   297→\t\t\thostRun.Complete(result.State)\n   298→\t\t}\n   299→\t\thostRun.ActiveSteps = nil\n   300→\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n   301→\t}\n   302→\n   303→\t// Signal live-stream subscribers that this run is done.\n   304→\tif r.LogBroadcast != nil {\n   305→\t\tr.LogBroadcast.Finish(run.ID)\n   306→\t}\n   307→\n   308→\tif runErr != nil {\n   309→\t\tlog.Printf(\"host workflow: resume of %q failed for %s: %v\", wf.Name, run.ProjectDir, runErr)\n   310→\t\treturn result, runErr\n   311→\t}\n   312→\n   313→\tlog.Printf(\"host workflow: resume of %q completed for %s with state %s\", wf.Name, run.ProjectDir, engRun.State)\n   314→\treturn result, nil\n   315→}\n   316→\n   317→// buildPreloadedResults creates a map of step results for steps that completed\n   318→// before the resume point. It walks the workflow graph from the entry step,\n   319→// collecting results from the run's StepExecutions.\n   320→func buildPreloadedResults(run *domain.Run, wf *domain.Workflow, resumeFrom string) map[string]string {\n   321→\t// Build step result map from the run's executions\n   322→\tstepResults := make(map[string]string)\n   323→\tfor _, exec := range run.StepExecutions {\n   324→\t\tif exec.Result != \"\" && exec.Result != \"error\" {\n   325→\t\t\tstepResults[exec.StepName] = exec.Result\n   326→\t\t}\n   327→\t}\n   328→\n   329→\tpreloaded := make(map[string]string)\n   330→\tvisited := make(map[string]bool)\n   331→\tvar walk func(stepName string)\n   332→\twalk = func(stepName string) {\n   333→\t\tif visited[stepName] || stepName == resumeFrom {\n   334→\t\t\treturn\n   335→\t\t}\n   336→\t\tvisited[stepName] = true\n   337→\n   338→\t\tresult, ok := stepResults[stepName]\n   339→\t\tif !ok {\n   340→\t\t\treturn\n   341→\t\t}\n   342→\t\tpreloaded[stepName] = result\n   343→\n   344→\t\tnextSteps, err := wf.NextSteps(stepName, result)\n   345→\t\tif err != nil {\n   346→\t\t\treturn\n   347→\t\t}\n   348→\t\tfor _, next := range nextSteps {\n   349→\t\t\tif next != domain.StepDone && next != domain.StepAbort {\n   350→\t\t\t\twalk(next)\n   351→\t\t\t}\n   352→\t\t}\n   353→\t}\n   354→\n   355→\twalk(wf.EntryStep)\n   356→\treturn preloaded\n   357→}\n   358→\n   359→// RunListTasksWorkflow executes the list-tasks workflow and returns the\n   360→// discovered tasks. No run record is created for list-tasks executions since\n   361→// they are polling operations that would otherwise clutter the run history.\n   362→func RunListTasksWorkflow(ctx context.Context, runner *Runner, projectDir string) ([]Task, *RunResult, error) {\n   363→\trunner.SkipRunRecord = true\n   364→\tresult, err := runner.RunNamed(ctx, projectDir, \"list-tasks\")\n   365→\tif err != nil {\n   366→\t\treturn nil, nil, err\n   367→\t}\n   368→\tif result.State != domain.RunStateSucceeded {\n   369→\t\treturn nil, result, fmt.Errorf(\"list-tasks workflow failed with state %s\", result.State)\n   370→\t}\n   371→\ttasks, err := ReadListTasksOutput(result.OutputDir)\n   372→\tif err != nil {\n   373→\t\treturn nil, result, err\n   374→\t}\n   375→\treturn tasks, result, nil\n   376→}\n   377→\n   378→const extraEnvContextKey = \"extra_env\"\n   379→\n   380→// saveExtraEnv persists the runner's ExtraEnv into the run's context.json so\n   381→// that resume can restore env vars like CLOCHE_MAIN_RUN_ID.\n   382→func saveExtraEnv(projectDir, runID string, env []string) {\n   383→\tif len(env) == 0 {\n   384→\t\treturn\n   385→\t}\n   386→\tjoined := strings.Join(env, \"\\n\")\n   387→\t_ = runcontext.Set(projectDir, runID, extraEnvContextKey, joined)\n   388→}\n   389→\n   390→// loadExtraEnv restores ExtraEnv from the run's context.json.\n   391→func loadExtraEnv(projectDir, runID string) []string {\n   392→\tval, ok, err := runcontext.Get(projectDir, runID, extraEnvContextKey)\n   393→\tif err != nil || !ok || val == \"\" {\n   394→\t\treturn nil\n   395→\t}\n   396→\treturn strings.Split(val, \"\\n\")\n   397→}\n   398→\n   399→// findHostWorkflow searches all .cloche files in a project for a host workflow\n   400→// with the given name. A workflow is a host workflow if it contains a \"host { }\"\n   401→// block in its definition.\n   402→func findHostWorkflow(projectDir, workflowName string) (*domain.Workflow, error) {\n   403→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n   404→\tentries, _ := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n   405→\n   406→\tfor _, path := range entries {\n   407→\t\tdata, err := os.ReadFile(path)\n   408→\t\tif err != nil {\n   409→\t\t\tcontinue\n   410→\t\t}\n   411→\t\tworkflows, err := dsl.ParseAll(string(data))\n   412→\t\tif err != nil {\n   413→\t\t\tcontinue\n   414→\t\t}\n   415→\t\tif wf, ok := workflows[workflowName]; ok && wf.Location == domain.LocationHost {\n   416→\t\t\twf.ResolveAgents()\n   417→\t\t\treturn wf, nil\n   418→\t\t}\n   419→\t}\n   420→\n   421→\treturn nil, fmt.Errorf(\"host workflow %q not found in any .cloche file\", workflowName)\n   422→}\n   423→\n   424→// FindHostWorkflows returns all host workflows across all .cloche files.\n   425→func FindHostWorkflows(projectDir string) (map[string]*domain.Workflow, error) {\n   426→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n   427→\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n   428→\tif err != nil {\n   429→\t\treturn nil, err\n   430→\t}\n   431→\n   432→\tall := make(map[string]*domain.Workflow)\n   433→\tfor _, path := range entries {\n   434→\t\tdata, err := os.ReadFile(path)\n   435→\t\tif err != nil {\n   436→\t\t\tcontinue\n   437→\t\t}\n   438→\t\tworkflows, err := dsl.ParseAll(string(data))\n   439→\t\tif err != nil {\n   440→\t\t\tcontinue\n   441→\t\t}\n   442→\t\tfor name, wf := range workflows {\n   443→\t\t\tif wf.Location == domain.LocationHost {\n   444→\t\t\t\twf.ResolveAgents()\n   445→\t\t\t\tall[name] = wf\n   446→\t\t\t}\n   447→\t\t}\n   448→\t}\n   449→\n   450→\treturn all, nil\n   451→}\n   452→\n   453→// hostStatusHandler logs host workflow step events and persists them to the store.\n   454→// It mirrors the container-side status pipeline: saving captures and publishing\n   455→// to the log broadcaster so that cloche logs works identically for host runs.\n   456→type hostStatusHandler struct {\n   457→\tprojectDir   string\n   458→\torchRunID    string\n   459→\tstore        ports.RunStore\n   460→\tcaptures     ports.CaptureStore\n   461→\tlogBroadcast *logstream.Broadcaster\n   462→\toutputDir    string\n   463→\tlogWriter    *logstream.Writer // persists log entries to full.log\n   464→}\n   465→\n   466→func (h *hostStatusHandler) OnStepStart(_ *domain.Run, step *domain.Step) {\n   467→\tnow := time.Now()\n   468→\tlog.Printf(\"host workflow [%s]: step %q started\", h.orchRunID, step.Name)\n   469→\tif h.store != nil {\n   470→\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n   471→\t\t\tr.RecordStepStart(step.Name)\n   472→\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n   473→\t\t}\n   474→\t}\n   475→\tif h.captures != nil {\n   476→\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n   477→\t\t\tStepName:  step.Name,\n   478→\t\t\tStartedAt: now,\n   479→\t\t})\n   480→\t}\n   481→\tif h.logWriter != nil {\n   482→\t\th.logWriter.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n   483→\t}\n   484→\tif h.logBroadcast != nil {\n   485→\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n   486→\t\t\tTimestamp: now.Format(time.RFC3339),\n   487→\t\t\tType:      \"status\",\n   488→\t\t\tContent:   \"step_started: \" + step.Name,\n   489→\t\t\tStepName:  step.Name,\n   490→\t\t})\n   491→\t}\n   492→}\n   493→\n   494→func (h *hostStatusHandler) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   495→\tnow := time.Now()\n   496→\tlog.Printf(\"host workflow [%s]: step %q completed with result %q\", h.orchRunID, step.Name, result)\n   497→\tif h.store != nil {\n   498→\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n   499→\t\t\tr.RecordStepComplete(step.Name, result)\n   500→\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n   501→\t\t}\n   502→\t}\n   503→\tif h.captures != nil {\n   504→\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n   505→\t\t\tStepName:    step.Name,\n   506→\t\t\tResult:      result,\n   507→\t\t\tCompletedAt: now,\n   508→\t\t})\n   509→\t}\n   510→\t// Read step output for logging/broadcasting.\n   511→\tvar stepOutput string\n   512→\toutputPath := filepath.Join(h.outputDir, step.Name+\".out\")\n   513→\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   514→\t\tstepOutput = string(data)\n   515→\t\t// Write a .log copy so that \"cloche logs -s <step>\" and the web UI\n   516→\t\t// can find per-step log output using the standard .log convention.\n   517→\t\tlogPath := filepath.Join(h.outputDir, step.Name+\".log\")\n   518→\t\t_ = os.WriteFile(logPath, data, 0644)\n   519→\t}\n   520→\tif h.logWriter != nil {\n   521→\t\tif stepOutput != \"\" {\n   522→\t\t\th.logWriter.Log(logstream.TypeScript, stepOutput)\n   523→\t\t}\n   524→\t\th.logWriter.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n   525→\t}\n   526→\tif h.logBroadcast != nil {\n   527→\t\tif stepOutput != \"\" {\n   528→\t\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n   529→\t\t\t\tTimestamp: now.Format(time.RFC3339),\n   530→\t\t\t\tType:      \"script\",\n   531→\t\t\t\tContent:   stepOutput,\n   532→\t\t\t\tStepName:  step.Name,\n   533→\t\t\t})\n   534→\t\t}\n   535→\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n   536→\t\t\tTimestamp: now.Format(time.RFC3339),\n   537→\t\t\tType:      \"status\",\n   538→\t\t\tContent:   \"step_completed: \" + step.Name + \" -> \" + result,\n   539→\t\t\tStepName:  step.Name,\n   540→\t\t})\n   541→\t}\n   542→}\n   543→\n   544→func (h *hostStatusHandler) OnRunComplete(run *domain.Run) {\n   545→\tlog.Printf(\"host workflow [%s]: run completed with state %s\", h.orchRunID, run.State)\n   546→}\n   547→"}]},"parent_tool_use_id":null,"session_id":"1adcbaa0-7170-4746-a6d5-fe98785bcc48","uuid":"508d53af-033b-4828-91bc-051f7accde63","timestamp":"2026-03-18T19:01:03.692Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/runner.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n)\n\n// Ensure hostStatusHandler implements engine.StatusHandler.\nvar _ engine.StatusHandler = (*hostStatusHandler)(nil)\n\n// Runner executes a host workflow by parsing host.cloche and walking the step graph.\ntype Runner struct {\n\tDispatcher    RunDispatcher\n\tStore         ports.RunStore\n\tCaptures      ports.CaptureStore       // optional: saves step captures for cloche logs\n\tLogBroadcast  *logstream.Broadcaster   // optional: publishes live log lines\n\tTaskID        string                   // optional task ID assigned by the daemon loop\n\tExtraEnv      []string                 // additional KEY=VALUE env vars passed to all steps\n\tSkipRunRecord bool                     // when true, don't persist a run record to the store\n}\n\n// RunResult contains the outcome of a host workflow execution.\ntype RunResult struct {\n\tRunID     string\n\tState     domain.RunState\n\tOutputDir string // path to the step output directory\n}\n\n// Run parses .cloche/host.cloche from projectDir and executes the \"main\" workflow.\nfunc (r *Runner) Run(ctx context.Context, projectDir string) (*RunResult, error) {\n\treturn r.RunWithID(ctx, projectDir, domain.GenerateRunID(\"main\"))\n}\n\n// RunWithID is like Run but uses the provided run ID instead of generating one.\nfunc (r *Runner) RunWithID(ctx context.Context, projectDir string, orchRunID string) (*RunResult, error) {\n\treturn r.runNamedWorkflow(ctx, projectDir, \"main\", orchRunID)\n}\n\n// RunNamed executes a named host workflow, generating a new run ID.\nfunc (r *Runner) RunNamed(ctx context.Context, projectDir string, workflowName string) (*RunResult, error) {\n\torchRunID := domain.GenerateRunID(workflowName)\n\treturn r.runNamedWorkflow(ctx, projectDir, workflowName, orchRunID)\n}\n\n// RunNamedWithID executes a named host workflow using the provided run ID.\nfunc (r *Runner) RunNamedWithID(ctx context.Context, projectDir string, workflowName string, runID string) (*RunResult, error) {\n\treturn r.runNamedWorkflow(ctx, projectDir, workflowName, runID)\n}\n\n// runNamedWorkflow is the internal implementation that runs a specific named\n// host workflow. Searches all .cloche files for the workflow.\nfunc (r *Runner) runNamedWorkflow(ctx context.Context, projectDir string, workflowName string, orchRunID string) (*RunResult, error) {\n\twf, err := findHostWorkflow(projectDir, workflowName)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Create output directory for step outputs\n\toutputDir := filepath.Join(projectDir, \".cloche\", orchRunID, \"output\")\n\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n\t}\n\n\tlog.Printf(\"host workflow: starting %q for project %s (run %s)\", wf.Name, projectDir, orchRunID)\n\n\t// Persist the host run in the store so it appears in list/status/logs.\n\t// When SkipRunRecord is set (e.g. for list-tasks polling), skip creating\n\t// the record to avoid cluttering the run history.\n\tif !r.SkipRunRecord {\n\t\thostRun := domain.NewRun(orchRunID, wf.Name)\n\t\thostRun.ProjectDir = projectDir\n\t\thostRun.IsHost = true\n\t\thostRun.TaskID = r.TaskID\n\t\tif err := r.Store.CreateRun(ctx, hostRun); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating host run record: %w\", err)\n\t\t}\n\t\thostRun.Start()\n\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n\n\t\t// Persist ExtraEnv so resume can restore it (e.g. CLOCHE_MAIN_RUN_ID).\n\t\tsaveExtraEnv(projectDir, orchRunID, r.ExtraEnv)\n\t}\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tMainDir:    MainWorktreeDir(projectDir),\n\t\tDispatcher: r.Dispatcher,\n\t\tStore:      r.Store,\n\t\tOutputDir:  outputDir,\n\t\tWires:      wf.Wiring,\n\t\tHostRunID:  orchRunID,\n\t\tTaskID:     r.TaskID,\n\t\tExtraEnv:   r.ExtraEnv,\n\t}\n\n\t// Configure agent from workflow-level host config\n\tif cmd := wf.Config[\"host.agent_command\"]; cmd != \"\" {\n\t\texecutor.AgentCommands = prompt.ParseCommands(cmd)\n\t}\n\tif args := wf.Config[\"host.agent_args\"]; args != \"\" {\n\t\texecutor.AgentArgs = strings.Fields(args)\n\t}\n\n\t// Create a logstream.Writer so host runs persist logs to full.log,\n\t// matching container-side behavior where the agent writes full.log.\n\tvar ulog *logstream.Writer\n\tif !r.SkipRunRecord {\n\t\tw, err := logstream.NewAtDir(outputDir)\n\t\tif err != nil {\n\t\t\tlog.Printf(\"host workflow [%s]: failed to create log writer: %v\", orchRunID, err)\n\t\t} else {\n\t\t\tulog = w\n\t\t}\n\t}\n\n\t// Register run in broadcaster so IsActive returns true for live-stream callers.\n\tif r.LogBroadcast != nil {\n\t\tr.LogBroadcast.Start(orchRunID)\n\t}\n\n\teng := engine.New(executor)\n\teng.SetStatusHandler(&hostStatusHandler{\n\t\tprojectDir:   projectDir,\n\t\torchRunID:    orchRunID,\n\t\tstore:        r.Store,\n\t\tcaptures:     r.Captures,\n\t\tlogBroadcast: r.LogBroadcast,\n\t\toutputDir:    outputDir,\n\t\tlogWriter:    ulog,\n\t})\n\n\trun, runErr := eng.Run(ctx, wf)\n\n\tif ulog != nil {\n\t\tulog.Close()\n\t}\n\n\tresult := &RunResult{\n\t\tRunID:     orchRunID,\n\t\tState:     domain.RunStateFailed,\n\t\tOutputDir: outputDir,\n\t}\n\tif run != nil {\n\t\tresult.State = run.State\n\t}\n\n\t// Persist final state.\n\tif !r.SkipRunRecord {\n\t\thostRun, _ := r.Store.GetRun(ctx, orchRunID)\n\t\tif hostRun != nil {\n\t\t\tif runErr != nil {\n\t\t\t\thostRun.Fail(runErr.Error())\n\t\t\t} else {\n\t\t\t\thostRun.Complete(result.State)\n\t\t\t}\n\t\t\thostRun.ActiveSteps = nil\n\t\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n\t\t}\n\t}\n\n\t// Signal live-stream subscribers that this run is done (after state update\n\t// so subscribers see the final state when their channel closes).\n\tif r.LogBroadcast != nil {\n\t\tr.LogBroadcast.Finish(orchRunID)\n\t}\n\n\tif runErr != nil {\n\t\tlog.Printf(\"host workflow: %q failed for %s: %v\", wf.Name, projectDir, runErr)\n\t\treturn result, runErr\n\t}\n\n\tlog.Printf(\"host workflow: %q completed for %s with state %s\", wf.Name, projectDir, run.State)\n\treturn result, nil\n}\n\n// ResumeRun resumes a failed host workflow run from a specific step.\n// Steps before resumeFrom are replayed from their stored results.\nfunc (r *Runner) ResumeRun(ctx context.Context, run *domain.Run, resumeFrom string) (*RunResult, error) {\n\twf, err := findHostWorkflow(run.ProjectDir, run.WorkflowName)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Validate the resume step exists\n\tif _, ok := wf.Steps[resumeFrom]; !ok {\n\t\treturn nil, fmt.Errorf(\"step %q not found in workflow %q\", resumeFrom, run.WorkflowName)\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\")\n\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n\t}\n\n\tlog.Printf(\"host workflow: resuming %q from step %q for project %s (run %s)\", wf.Name, resumeFrom, run.ProjectDir, run.ID)\n\n\t// Restore ExtraEnv from the original run's context so that env vars like\n\t// CLOCHE_MAIN_RUN_ID are available to re-executed steps.\n\textraEnv := r.ExtraEnv\n\tif len(extraEnv) == 0 {\n\t\textraEnv = loadExtraEnv(run.ProjectDir, run.ID)\n\t}\n\n\t// Reset run state\n\trun.State = domain.RunStateRunning\n\trun.ErrorMessage = \"\"\n\trun.CompletedAt = time.Time{}\n\trun.ActiveSteps = nil\n\tif err := r.Store.UpdateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"updating run state: %w\", err)\n\t}\n\n\texecutor := &Executor{\n\t\tProjectDir: run.ProjectDir,\n\t\tMainDir:    MainWorktreeDir(run.ProjectDir),\n\t\tDispatcher: r.Dispatcher,\n\t\tStore:      r.Store,\n\t\tOutputDir:  outputDir,\n\t\tWires:      wf.Wiring,\n\t\tHostRunID:  run.ID,\n\t\tTaskID:     r.TaskID,\n\t\tExtraEnv:   extraEnv,\n\t}\n\n\t// Configure agent from workflow-level host config\n\tif cmd := wf.Config[\"host.agent_command\"]; cmd != \"\" {\n\t\texecutor.AgentCommands = prompt.ParseCommands(cmd)\n\t}\n\tif args := wf.Config[\"host.agent_args\"]; args != \"\" {\n\t\texecutor.AgentArgs = strings.Fields(args)\n\t}\n\n\t// Build preloaded results from previously completed steps\n\tpreloaded := buildPreloadedResults(run, wf, resumeFrom)\n\n\t// Configure the executor to know which step is being resumed (for prompt resume)\n\texecutor.ResumeStep = resumeFrom\n\n\tvar ulog *logstream.Writer\n\tw, err := logstream.NewAtDir(outputDir)\n\tif err != nil {\n\t\tlog.Printf(\"host workflow [%s]: failed to create log writer: %v\", run.ID, err)\n\t} else {\n\t\tulog = w\n\t}\n\n\t// Register run in broadcaster so IsActive returns true for live-stream callers.\n\tif r.LogBroadcast != nil {\n\t\tr.LogBroadcast.Start(run.ID)\n\t}\n\n\teng := engine.New(executor)\n\teng.SetPreloadedResults(preloaded)\n\teng.SetStatusHandler(&hostStatusHandler{\n\t\tprojectDir:   run.ProjectDir,\n\t\torchRunID:    run.ID,\n\t\tstore:        r.Store,\n\t\tcaptures:     r.Captures,\n\t\tlogBroadcast: r.LogBroadcast,\n\t\toutputDir:    outputDir,\n\t\tlogWriter:    ulog,\n\t})\n\n\tengRun, runErr := eng.Run(ctx, wf)\n\n\tif ulog != nil {\n\t\tulog.Close()\n\t}\n\n\tresult := &RunResult{\n\t\tRunID:     run.ID,\n\t\tState:     domain.RunStateFailed,\n\t\tOutputDir: outputDir,\n\t}\n\tif engRun != nil {\n\t\tresult.State = engRun.State\n\t}\n\n\t// Persist final state\n\thostRun, _ := r.Store.GetRun(ctx, run.ID)\n\tif hostRun != nil {\n\t\tif runErr != nil {\n\t\t\thostRun.Fail(runErr.Error())\n\t\t} else {\n\t\t\thostRun.Complete(result.State)\n\t\t}\n\t\thostRun.ActiveSteps = nil\n\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n\t}\n\n\t// Signal live-stream subscribers that this run is done.\n\tif r.LogBroadcast != nil {\n\t\tr.LogBroadcast.Finish(run.ID)\n\t}\n\n\tif runErr != nil {\n\t\tlog.Printf(\"host workflow: resume of %q failed for %s: %v\", wf.Name, run.ProjectDir, runErr)\n\t\treturn result, runErr\n\t}\n\n\tlog.Printf(\"host workflow: resume of %q completed for %s with state %s\", wf.Name, run.ProjectDir, engRun.State)\n\treturn result, nil\n}\n\n// buildPreloadedResults creates a map of step results for steps that completed\n// before the resume point. It walks the workflow graph from the entry step,\n// collecting results from the run's StepExecutions.\nfunc buildPreloadedResults(run *domain.Run, wf *domain.Workflow, resumeFrom string) map[string]string {\n\t// Build step result map from the run's executions\n\tstepResults := make(map[string]string)\n\tfor _, exec := range run.StepExecutions {\n\t\tif exec.Result != \"\" && exec.Result != \"error\" {\n\t\t\tstepResults[exec.StepName] = exec.Result\n\t\t}\n\t}\n\n\tpreloaded := make(map[string]string)\n\tvisited := make(map[string]bool)\n\tvar walk func(stepName string)\n\twalk = func(stepName string) {\n\t\tif visited[stepName] || stepName == resumeFrom {\n\t\t\treturn\n\t\t}\n\t\tvisited[stepName] = true\n\n\t\tresult, ok := stepResults[stepName]\n\t\tif !ok {\n\t\t\treturn\n\t\t}\n\t\tpreloaded[stepName] = result\n\n\t\tnextSteps, err := wf.NextSteps(stepName, result)\n\t\tif err != nil {\n\t\t\treturn\n\t\t}\n\t\tfor _, next := range nextSteps {\n\t\t\tif next != domain.StepDone && next != domain.StepAbort {\n\t\t\t\twalk(next)\n\t\t\t}\n\t\t}\n\t}\n\n\twalk(wf.EntryStep)\n\treturn preloaded\n}\n\n// RunListTasksWorkflow executes the list-tasks workflow and returns the\n// discovered tasks. No run record is created for list-tasks executions since\n// they are polling operations that would otherwise clutter the run history.\nfunc RunListTasksWorkflow(ctx context.Context, runner *Runner, projectDir string) ([]Task, *RunResult, error) {\n\trunner.SkipRunRecord = true\n\tresult, err := runner.RunNamed(ctx, projectDir, \"list-tasks\")\n\tif err != nil {\n\t\treturn nil, nil, err\n\t}\n\tif result.State != domain.RunStateSucceeded {\n\t\treturn nil, result, fmt.Errorf(\"list-tasks workflow failed with state %s\", result.State)\n\t}\n\ttasks, err := ReadListTasksOutput(result.OutputDir)\n\tif err != nil {\n\t\treturn nil, result, err\n\t}\n\treturn tasks, result, nil\n}\n\nconst extraEnvContextKey = \"extra_env\"\n\n// saveExtraEnv persists the runner's ExtraEnv into the run's context.json so\n// that resume can restore env vars like CLOCHE_MAIN_RUN_ID.\nfunc saveExtraEnv(projectDir, runID string, env []string) {\n\tif len(env) == 0 {\n\t\treturn\n\t}\n\tjoined := strings.Join(env, \"\\n\")\n\t_ = runcontext.Set(projectDir, runID, extraEnvContextKey, joined)\n}\n\n// loadExtraEnv restores ExtraEnv from the run's context.json.\nfunc loadExtraEnv(projectDir, runID string) []string {\n\tval, ok, err := runcontext.Get(projectDir, runID, extraEnvContextKey)\n\tif err != nil || !ok || val == \"\" {\n\t\treturn nil\n\t}\n\treturn strings.Split(val, \"\\n\")\n}\n\n// findHostWorkflow searches all .cloche files in a project for a host workflow\n// with the given name. A workflow is a host workflow if it contains a \"host { }\"\n// block in its definition.\nfunc findHostWorkflow(projectDir, workflowName string) (*domain.Workflow, error) {\n\tclocheDir := filepath.Join(projectDir, \".cloche\")\n\tentries, _ := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n\n\tfor _, path := range entries {\n\t\tdata, err := os.ReadFile(path)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tworkflows, err := dsl.ParseAll(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif wf, ok := workflows[workflowName]; ok && wf.Location == domain.LocationHost {\n\t\t\twf.ResolveAgents()\n\t\t\treturn wf, nil\n\t\t}\n\t}\n\n\treturn nil, fmt.Errorf(\"host workflow %q not found in any .cloche file\", workflowName)\n}\n\n// FindHostWorkflows returns all host workflows across all .cloche files.\nfunc FindHostWorkflows(projectDir string) (map[string]*domain.Workflow, error) {\n\tclocheDir := filepath.Join(projectDir, \".cloche\")\n\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tall := make(map[string]*domain.Workflow)\n\tfor _, path := range entries {\n\t\tdata, err := os.ReadFile(path)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tworkflows, err := dsl.ParseAll(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor name, wf := range workflows {\n\t\t\tif wf.Location == domain.LocationHost {\n\t\t\t\twf.ResolveAgents()\n\t\t\t\tall[name] = wf\n\t\t\t}\n\t\t}\n\t}\n\n\treturn all, nil\n}\n\n// hostStatusHandler logs host workflow step events and persists them to the store.\n// It mirrors the container-side status pipeline: saving captures and publishing\n// to the log broadcaster so that cloche logs works identically for host runs.\ntype hostStatusHandler struct {\n\tprojectDir   string\n\torchRunID    string\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogBroadcast *logstream.Broadcaster\n\toutputDir    string\n\tlogWriter    *logstream.Writer // persists log entries to full.log\n}\n\nfunc (h *hostStatusHandler) OnStepStart(_ *domain.Run, step *domain.Step) {\n\tnow := time.Now()\n\tlog.Printf(\"host workflow [%s]: step %q started\", h.orchRunID, step.Name)\n\tif h.store != nil {\n\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n\t\t\tr.RecordStepStart(step.Name)\n\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n\t\t}\n\t}\n\tif h.captures != nil {\n\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n\t\t\tStepName:  step.Name,\n\t\t\tStartedAt: now,\n\t\t})\n\t}\n\tif h.logWriter != nil {\n\t\th.logWriter.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n\t}\n\tif h.logBroadcast != nil {\n\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n\t\t\tTimestamp: now.Format(time.RFC3339),\n\t\t\tType:      \"status\",\n\t\t\tContent:   \"step_started: \" + step.Name,\n\t\t\tStepName:  step.Name,\n\t\t})\n\t}\n}\n\nfunc (h *hostStatusHandler) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n\tnow := time.Now()\n\tlog.Printf(\"host workflow [%s]: step %q completed with result %q\", h.orchRunID, step.Name, result)\n\tif h.store != nil {\n\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n\t\t\tr.RecordStepComplete(step.Name, result)\n\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n\t\t}\n\t}\n\tif h.captures != nil {\n\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n\t\t\tStepName:    step.Name,\n\t\t\tResult:      result,\n\t\t\tCompletedAt: now,\n\t\t})\n\t}\n\t// Read step output for logging/broadcasting.\n\tvar stepOutput string\n\toutputPath := filepath.Join(h.outputDir, step.Name+\".out\")\n\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\tstepOutput = string(data)\n\t\t// Write a .log copy so that \"cloche logs -s <step>\" and the web UI\n\t\t// can find per-step log output using the standard .log convention.\n\t\tlogPath := filepath.Join(h.outputDir, step.Name+\".log\")\n\t\t_ = os.WriteFile(logPath, data, 0644)\n\t}\n\tif h.logWriter != nil {\n\t\tif stepOutput != \"\" {\n\t\t\th.logWriter.Log(logstream.TypeScript, stepOutput)\n\t\t}\n\t\th.logWriter.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n\t}\n\tif h.logBroadcast != nil {\n\t\tif stepOutput != \"\" {\n\t\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n\t\t\t\tTimestamp: now.Format(time.RFC3339),\n\t\t\t\tType:      \"script\",\n\t\t\t\tContent:   stepOutput,\n\t\t\t\tStepName:  step.Name,\n\t\t\t})\n\t\t}\n\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n\t\t\tTimestamp: now.Format(time.RFC3339),\n\t\t\tType:      \"status\",\n\t\t\tContent:   \"step_completed: \" + step.Name + \" -> \" + result,\n\t\t\tStepName:  step.Name,\n\t\t})\n\t}\n}\n\nfunc (h *hostStatusHandler) OnRunComplete(run *domain.Run) {\n\tlog.Printf(\"host workflow [%s]: run completed with state %s\", h.orchRunID, run.State)\n}\n","numLines":547,"startLine":1,"totalLines":547}}}
