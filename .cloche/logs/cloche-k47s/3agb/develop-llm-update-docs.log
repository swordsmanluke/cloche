{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Pucp3HFs2MLzJngVAuGHHP","type":"tool_result","content":"     1â†’package logstream\n     2â†’\n     3â†’import (\n     4â†’\t\"fmt\"\n     5â†’\t\"os\"\n     6â†’\t\"path/filepath\"\n     7â†’\t\"strings\"\n     8â†’\t\"sync\"\n     9â†’\t\"time\"\n    10â†’)\n    11â†’\n    12â†’// EntryType identifies the source of a log entry in the unified log.\n    13â†’type EntryType string\n    14â†’\n    15â†’const (\n    16â†’\tTypeStatus EntryType = \"status\"\n    17â†’\tTypeScript EntryType = \"script\"\n    18â†’\tTypeLLM    EntryType = \"llm\"\n    19â†’)\n    20â†’\n    21â†’// Writer writes timestamped, type-prefixed entries to .cloche/output/full.log.\n    22â†’// It is safe for concurrent use.\n    23â†’type Writer struct {\n    24â†’\tmu   sync.Mutex\n    25â†’\tfile *os.File\n    26â†’\tNow  func() time.Time // overridable for testing\n    27â†’}\n    28â†’\n    29â†’// New creates a Writer that appends to .cloche/output/full.log under workDir.\n    30â†’// This is used by the in-container agent where workDir is the workspace root.\n    31â†’func New(workDir string) (*Writer, error) {\n    32â†’\treturn NewAtDir(filepath.Join(workDir, \".cloche\", \"output\"))\n    33â†’}\n    34â†’\n    35â†’// NewAtDir creates a Writer that appends to full.log in the given directory.\n    36â†’// The directory is created if it does not exist.\n    37â†’func NewAtDir(dir string) (*Writer, error) {\n    38â†’\tif err := os.MkdirAll(dir, 0755); err != nil {\n    39â†’\t\treturn nil, fmt.Errorf(\"creating output directory: %w\", err)\n    40â†’\t}\n    41â†’\tpath := filepath.Join(dir, \"full.log\")\n    42â†’\tf, err := os.OpenFile(path, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644)\n    43â†’\tif err != nil {\n    44â†’\t\treturn nil, fmt.Errorf(\"opening full.log: %w\", err)\n    45â†’\t}\n    46â†’\treturn &Writer{file: f, Now: func() time.Time { return time.Now().UTC() }}, nil\n    47â†’}\n    48â†’\n    49â†’// Log writes one or more lines to the unified log with the given type prefix.\n    50â†’// Multi-line messages are split into separate entries sharing the same timestamp.\n    51â†’func (w *Writer) Log(typ EntryType, message string) {\n    52â†’\ttrimmed := strings.TrimRight(message, \"\\n\")\n    53â†’\tif trimmed == \"\" {\n    54â†’\t\treturn\n    55â†’\t}\n    56â†’\n    57â†’\tw.mu.Lock()\n    58â†’\tdefer w.mu.Unlock()\n    59â†’\n    60â†’\tts := w.Now().Format(time.RFC3339)\n    61â†’\tfor _, line := range strings.Split(trimmed, \"\\n\") {\n    62â†’\t\tfmt.Fprintf(w.file, \"[%s] [%s] %s\\n\", ts, typ, line)\n    63â†’\t}\n    64â†’\t_ = w.file.Sync()\n    65â†’}\n    66â†’\n    67â†’// Close closes the underlying file.\n    68â†’func (w *Writer) Close() error {\n    69â†’\tif w.file != nil {\n    70â†’\t\treturn w.file.Close()\n    71â†’\t}\n    72â†’\treturn nil\n    73â†’}\n    74â†’"}]},"parent_tool_use_id":null,"session_id":"716f0d21-6af3-4a02-a7e8-d1264e25f9f9","uuid":"8f242dbb-1237-41a2-9a28-1a49286f2bf0","timestamp":"2026-03-18T22:03:03.037Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/logstream/logstream.go","content":"package logstream\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n)\n\n// EntryType identifies the source of a log entry in the unified log.\ntype EntryType string\n\nconst (\n\tTypeStatus EntryType = \"status\"\n\tTypeScript EntryType = \"script\"\n\tTypeLLM    EntryType = \"llm\"\n)\n\n// Writer writes timestamped, type-prefixed entries to .cloche/output/full.log.\n// It is safe for concurrent use.\ntype Writer struct {\n\tmu   sync.Mutex\n\tfile *os.File\n\tNow  func() time.Time // overridable for testing\n}\n\n// New creates a Writer that appends to .cloche/output/full.log under workDir.\n// This is used by the in-container agent where workDir is the workspace root.\nfunc New(workDir string) (*Writer, error) {\n\treturn NewAtDir(filepath.Join(workDir, \".cloche\", \"output\"))\n}\n\n// NewAtDir creates a Writer that appends to full.log in the given directory.\n// The directory is created if it does not exist.\nfunc NewAtDir(dir string) (*Writer, error) {\n\tif err := os.MkdirAll(dir, 0755); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating output directory: %w\", err)\n\t}\n\tpath := filepath.Join(dir, \"full.log\")\n\tf, err := os.OpenFile(path, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"opening full.log: %w\", err)\n\t}\n\treturn &Writer{file: f, Now: func() time.Time { return time.Now().UTC() }}, nil\n}\n\n// Log writes one or more lines to the unified log with the given type prefix.\n// Multi-line messages are split into separate entries sharing the same timestamp.\nfunc (w *Writer) Log(typ EntryType, message string) {\n\ttrimmed := strings.TrimRight(message, \"\\n\")\n\tif trimmed == \"\" {\n\t\treturn\n\t}\n\n\tw.mu.Lock()\n\tdefer w.mu.Unlock()\n\n\tts := w.Now().Format(time.RFC3339)\n\tfor _, line := range strings.Split(trimmed, \"\\n\") {\n\t\tfmt.Fprintf(w.file, \"[%s] [%s] %s\\n\", ts, typ, line)\n\t}\n\t_ = w.file.Sync()\n}\n\n// Close closes the underlying file.\nfunc (w *Writer) Close() error {\n\tif w.file != nil {\n\t\treturn w.file.Close()\n\t}\n\treturn nil\n}\n","numLines":74,"startLine":1,"totalLines":74}}}
