{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012qAzd3Hc8mGxDn9SLgjXp1","type":"tool_result","content":"     1â†’package sqlite\n     2â†’\n     3â†’import (\n     4â†’\t\"database/sql\"\n     5â†’\t\"fmt\"\n     6â†’\t\"log\"\n     7â†’\t\"os\"\n     8â†’\t\"path/filepath\"\n     9â†’\t\"sort\"\n    10â†’\t\"strings\"\n    11â†’\t\"time\"\n    12â†’\n    13â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14â†’)\n    15â†’\n    16â†’// migrateV2 creates the tasks and attempts tables, populates them from\n    17â†’// existing run records, and moves log files to the new directory layout.\n    18â†’// It is idempotent: a _migrations table tracks whether it has already run.\n    19â†’func migrateV2(db *sql.DB) error {\n    20â†’\t// Create migration tracking table\n    21â†’\tdb.Exec(`CREATE TABLE IF NOT EXISTS _migrations (\n    22â†’\t\tid TEXT PRIMARY KEY,\n    23â†’\t\tapplied_at TEXT NOT NULL\n    24â†’\t)`)\n    25â†’\n    26â†’\t// Check if already applied\n    27â†’\tvar count int\n    28â†’\trow := db.QueryRow(`SELECT COUNT(*) FROM _migrations WHERE id = 'v2-task-oriented'`)\n    29â†’\tif err := row.Scan(&count); err == nil && count > 0 {\n    30â†’\t\treturn nil // already migrated\n    31â†’\t}\n    32â†’\n    33â†’\t// Create new tables\n    34â†’\tif _, err := db.Exec(`CREATE TABLE IF NOT EXISTS tasks (\n    35â†’\t\tid TEXT PRIMARY KEY,\n    36â†’\t\ttitle TEXT NOT NULL DEFAULT '',\n    37â†’\t\tsource TEXT NOT NULL DEFAULT 'external',\n    38â†’\t\tproject_dir TEXT NOT NULL DEFAULT '',\n    39â†’\t\tcreated_at TEXT NOT NULL DEFAULT ''\n    40â†’\t)`); err != nil {\n    41â†’\t\treturn fmt.Errorf(\"creating tasks table: %w\", err)\n    42â†’\t}\n    43â†’\n    44â†’\tif _, err := db.Exec(`CREATE TABLE IF NOT EXISTS attempts (\n    45â†’\t\tid TEXT PRIMARY KEY,\n    46â†’\t\ttask_id TEXT NOT NULL REFERENCES tasks(id),\n    47â†’\t\tstarted_at TEXT NOT NULL DEFAULT '',\n    48â†’\t\tended_at TEXT,\n    49â†’\t\tresult TEXT NOT NULL DEFAULT 'running',\n    50â†’\t\tproject_dir TEXT NOT NULL DEFAULT ''\n    51â†’\t)`); err != nil {\n    52â†’\t\treturn fmt.Errorf(\"creating attempts table: %w\", err)\n    53â†’\t}\n    54â†’\n    55â†’\t// Add attempt_id column to runs (idempotent)\n    56â†’\tdb.Exec(`ALTER TABLE runs ADD COLUMN attempt_id TEXT NOT NULL DEFAULT ''`)\n    57â†’\n    58â†’\t// Query all existing runs, grouped by task_id\n    59â†’\trows, err := db.Query(`SELECT id, workflow_name, state, started_at, completed_at,\n    60â†’\t\tproject_dir, task_id, task_title, is_host, parent_run_id\n    61â†’\t\tFROM runs ORDER BY started_at ASC`)\n    62â†’\tif err != nil {\n    63â†’\t\treturn fmt.Errorf(\"querying runs: %w\", err)\n    64â†’\t}\n    65â†’\tdefer rows.Close()\n    66â†’\n    67â†’\ttype runRecord struct {\n    68â†’\t\tid           string\n    69â†’\t\tworkflow     string\n    70â†’\t\tstate        string\n    71â†’\t\tstartedAt    string\n    72â†’\t\tcompletedAt  string\n    73â†’\t\tprojectDir   string\n    74â†’\t\ttaskID       string\n    75â†’\t\ttaskTitle    string\n    76â†’\t\tisHost       bool\n    77â†’\t\tparentRunID  string\n    78â†’\t}\n    79â†’\n    80â†’\tvar allRuns []runRecord\n    81â†’\tfor rows.Next() {\n    82â†’\t\tvar r runRecord\n    83â†’\t\tvar isHost int\n    84â†’\t\tvar completedAt sql.NullString\n    85â†’\t\tif err := rows.Scan(&r.id, &r.workflow, &r.state, &r.startedAt,\n    86â†’\t\t\t&completedAt, &r.projectDir, &r.taskID, &r.taskTitle,\n    87â†’\t\t\t&isHost, &r.parentRunID); err != nil {\n    88â†’\t\t\tlog.Printf(\"v2 migration: skipping run (scan error): %v\", err)\n    89â†’\t\t\tcontinue\n    90â†’\t\t}\n    91â†’\t\tr.isHost = isHost == 1\n    92â†’\t\tif completedAt.Valid {\n    93â†’\t\t\tr.completedAt = completedAt.String\n    94â†’\t\t}\n    95â†’\t\tallRuns = append(allRuns, r)\n    96â†’\t}\n    97â†’\n    98â†’\tif len(allRuns) == 0 {\n    99â†’\t\t// No runs to migrate â€” skip marking as done so migration\n   100â†’\t\t// re-checks on next startup (cheap, handles upgrades where\n   101â†’\t\t// the daemon starts before any runs exist).\n   102â†’\t\treturn nil\n   103â†’\t}\n   104â†’\n   105â†’\t// Build parentâ†’child mapping\n   106â†’\tchildrenOf := map[string][]string{}\n   107â†’\trunByID := map[string]*runRecord{}\n   108â†’\tfor i := range allRuns {\n   109â†’\t\trunByID[allRuns[i].id] = &allRuns[i]\n   110â†’\t\tif allRuns[i].parentRunID != \"\" {\n   111â†’\t\t\tchildrenOf[allRuns[i].parentRunID] = append(childrenOf[allRuns[i].parentRunID], allRuns[i].id)\n   112â†’\t\t}\n   113â†’\t}\n   114â†’\n   115â†’\t// Identify top-level runs (no parent, or parent not in DB)\n   116â†’\tvar topLevel []runRecord\n   117â†’\tfor _, r := range allRuns {\n   118â†’\t\tif r.parentRunID == \"\" || runByID[r.parentRunID] == nil {\n   119â†’\t\t\ttopLevel = append(topLevel, r)\n   120â†’\t\t}\n   121â†’\t}\n   122â†’\n   123â†’\t// Group top-level runs by task_id. Each top-level run becomes an attempt.\n   124â†’\t// Runs without a task_id get a generated user-initiated task.\n   125â†’\ttaskCreated := map[string]bool{}\n   126â†’\tuserTaskCounter := 0\n   127â†’\n   128â†’\t// Sort by started_at for stable attempt numbering\n   129â†’\tsort.SliceStable(topLevel, func(i, j int) bool {\n   130â†’\t\treturn topLevel[i].startedAt < topLevel[j].startedAt\n   131â†’\t})\n   132â†’\n   133â†’\ttx, err := db.Begin()\n   134â†’\tif err != nil {\n   135â†’\t\treturn fmt.Errorf(\"starting transaction: %w\", err)\n   136â†’\t}\n   137â†’\tdefer tx.Rollback()\n   138â†’\n   139â†’\tfor _, r := range topLevel {\n   140â†’\t\ttaskID := r.taskID\n   141â†’\t\ttaskTitle := r.taskTitle\n   142â†’\t\ttaskSource := \"external\"\n   143â†’\n   144â†’\t\t// Create a user-initiated task for runs without a task ID\n   145â†’\t\tif taskID == \"\" {\n   146â†’\t\t\tuserTaskCounter++\n   147â†’\t\t\ttaskID = fmt.Sprintf(\"user-%s\", domain.GenerateAttemptID())\n   148â†’\t\t\ttaskSource = \"user-initiated\"\n   149â†’\t\t\tif taskTitle == \"\" {\n   150â†’\t\t\t\ttaskTitle = r.workflow + \" (user-initiated)\"\n   151â†’\t\t\t}\n   152â†’\t\t}\n   153â†’\n   154â†’\t\t// Create task record if not yet created\n   155â†’\t\tif !taskCreated[taskID] {\n   156â†’\t\t\t_, err := tx.Exec(`INSERT OR IGNORE INTO tasks (id, title, source, project_dir, created_at)\n   157â†’\t\t\t\tVALUES (?, ?, ?, ?, ?)`,\n   158â†’\t\t\t\ttaskID, taskTitle, taskSource, r.projectDir, r.startedAt)\n   159â†’\t\t\tif err != nil {\n   160â†’\t\t\t\tlog.Printf(\"v2 migration: failed to create task %s: %v\", taskID, err)\n   161â†’\t\t\t\tcontinue\n   162â†’\t\t\t}\n   163â†’\t\t\ttaskCreated[taskID] = true\n   164â†’\t\t}\n   165â†’\n   166â†’\t\t// Create attempt from this top-level run\n   167â†’\t\tattemptID := domain.GenerateAttemptID()\n   168â†’\t\tattemptResult := mapRunStateToAttemptResult(r.state)\n   169â†’\n   170â†’\t\t_, err := tx.Exec(`INSERT INTO attempts (id, task_id, started_at, ended_at, result, project_dir)\n   171â†’\t\t\tVALUES (?, ?, ?, ?, ?, ?)`,\n   172â†’\t\t\tattemptID, taskID, r.startedAt, nullIfEmpty(r.completedAt), attemptResult, r.projectDir)\n   173â†’\t\tif err != nil {\n   174â†’\t\t\tlog.Printf(\"v2 migration: failed to create attempt for run %s: %v\", r.id, err)\n   175â†’\t\t\tcontinue\n   176â†’\t\t}\n   177â†’\n   178â†’\t\t// Link this run and its children to the attempt\n   179â†’\t\trunIDs := []string{r.id}\n   180â†’\t\tfor _, childID := range childrenOf[r.id] {\n   181â†’\t\t\trunIDs = append(runIDs, childID)\n   182â†’\t\t}\n   183â†’\n   184â†’\t\tfor _, runID := range runIDs {\n   185â†’\t\t\ttx.Exec(`UPDATE runs SET attempt_id = ?, task_id = ? WHERE id = ?`, attemptID, taskID, runID)\n   186â†’\t\t}\n   187â†’\n   188â†’\t\t// Move log files on disk\n   189â†’\t\tmoveRunLogs(r.projectDir, r.id, taskID, attemptID, r.workflow)\n   190â†’\t\tfor _, childID := range childrenOf[r.id] {\n   191â†’\t\t\tchildRun := runByID[childID]\n   192â†’\t\t\tif childRun != nil {\n   193â†’\t\t\t\tmoveRunLogs(childRun.projectDir, childID, taskID, attemptID, childRun.workflow)\n   194â†’\t\t\t}\n   195â†’\t\t}\n   196â†’\t}\n   197â†’\n   198â†’\tif err := tx.Commit(); err != nil {\n   199â†’\t\treturn fmt.Errorf(\"committing migration: %w\", err)\n   200â†’\t}\n   201â†’\n   202â†’\t// Mark migration as complete\n   203â†’\tdb.Exec(`INSERT INTO _migrations (id, applied_at) VALUES ('v2-task-oriented', ?)`,\n   204â†’\t\ttime.Now().UTC().Format(time.RFC3339))\n   205â†’\n   206â†’\tlog.Printf(\"v2 migration: migrated %d top-level runs into tasks and attempts\", len(topLevel))\n   207â†’\treturn nil\n   208â†’}\n   209â†’\n   210â†’// moveRunLogs moves log files from .cloche/<run-id>/output/ to\n   211â†’// .cloche/logs/<task-id>/<attempt-id>/. Files are renamed from\n   212â†’// <step>.log to <workflow>-<step>.log.\n   213â†’func moveRunLogs(projectDir, runID, taskID, attemptID, workflow string) {\n   214â†’\tsrcDir := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   215â†’\tif _, err := os.Stat(srcDir); err != nil {\n   216â†’\t\treturn // no output directory\n   217â†’\t}\n   218â†’\n   219â†’\tdstDir := filepath.Join(projectDir, \".cloche\", \"logs\", taskID, attemptID)\n   220â†’\tif err := os.MkdirAll(dstDir, 0755); err != nil {\n   221â†’\t\tlog.Printf(\"v2 migration: failed to create log dir %s: %v\", dstDir, err)\n   222â†’\t\treturn\n   223â†’\t}\n   224â†’\n   225â†’\tentries, err := os.ReadDir(srcDir)\n   226â†’\tif err != nil {\n   227â†’\t\treturn\n   228â†’\t}\n   229â†’\n   230â†’\tfor _, entry := range entries {\n   231â†’\t\tif entry.IsDir() {\n   232â†’\t\t\tcontinue\n   233â†’\t\t}\n   234â†’\t\tsrcPath := filepath.Join(srcDir, entry.Name())\n   235â†’\t\t// Rename: full.log stays as full.log, others get workflow prefix\n   236â†’\t\tdstName := entry.Name()\n   237â†’\t\tif dstName != \"full.log\" && dstName != \"container.log\" {\n   238â†’\t\t\t// step.log â†’ workflow-step.log\n   239â†’\t\t\tdstName = workflow + \"-\" + dstName\n   240â†’\t\t}\n   241â†’\t\tdstPath := filepath.Join(dstDir, dstName)\n   242â†’\n   243â†’\t\t// Copy (not rename, to handle cross-device) then remove\n   244â†’\t\tdata, err := os.ReadFile(srcPath)\n   245â†’\t\tif err != nil {\n   246â†’\t\t\tcontinue\n   247â†’\t\t}\n   248â†’\t\tif err := os.WriteFile(dstPath, data, 0644); err != nil {\n   249â†’\t\t\tlog.Printf(\"v2 migration: failed to write %s: %v\", dstPath, err)\n   250â†’\t\t\tcontinue\n   251â†’\t\t}\n   252â†’\t}\n   253â†’\n   254â†’\t// Remove old output directory after successful copy\n   255â†’\tos.RemoveAll(srcDir)\n   256â†’\n   257â†’\t// Remove old run directory if now empty\n   258â†’\trunDir := filepath.Join(projectDir, \".cloche\", runID)\n   259â†’\tremoveIfEmpty(runDir)\n   260â†’}\n   261â†’\n   262â†’// removeIfEmpty removes a directory if it contains no files.\n   263â†’func removeIfEmpty(dir string) {\n   264â†’\tentries, err := os.ReadDir(dir)\n   265â†’\tif err != nil {\n   266â†’\t\treturn\n   267â†’\t}\n   268â†’\tif len(entries) == 0 {\n   269â†’\t\tos.Remove(dir)\n   270â†’\t}\n   271â†’}\n   272â†’\n   273â†’func mapRunStateToAttemptResult(state string) string {\n   274â†’\tswitch state {\n   275â†’\tcase \"succeeded\":\n   276â†’\t\treturn \"succeeded\"\n   277â†’\tcase \"failed\":\n   278â†’\t\treturn \"failed\"\n   279â†’\tcase \"cancelled\":\n   280â†’\t\treturn \"cancelled\"\n   281â†’\tcase \"running\", \"pending\":\n   282â†’\t\treturn \"running\"\n   283â†’\tdefault:\n   284â†’\t\treturn \"failed\"\n   285â†’\t}\n   286â†’}\n   287â†’\n   288â†’func nullIfEmpty(s string) interface{} {\n   289â†’\tif s == \"\" {\n   290â†’\t\treturn nil\n   291â†’\t}\n   292â†’\t// Also treat zero time as null\n   293â†’\tif strings.HasPrefix(s, \"0001-01-01\") {\n   294â†’\t\treturn nil\n   295â†’\t}\n   296â†’\treturn s\n   297â†’}\n   298â†’"}]},"parent_tool_use_id":null,"session_id":"716f0d21-6af3-4a02-a7e8-d1264e25f9f9","uuid":"3d6ddc24-8d62-4b5f-b649-49f18958db9c","timestamp":"2026-03-18T22:03:03.477Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/sqlite/migrate_v2.go","content":"package sqlite\n\nimport (\n\t\"database/sql\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n)\n\n// migrateV2 creates the tasks and attempts tables, populates them from\n// existing run records, and moves log files to the new directory layout.\n// It is idempotent: a _migrations table tracks whether it has already run.\nfunc migrateV2(db *sql.DB) error {\n\t// Create migration tracking table\n\tdb.Exec(`CREATE TABLE IF NOT EXISTS _migrations (\n\t\tid TEXT PRIMARY KEY,\n\t\tapplied_at TEXT NOT NULL\n\t)`)\n\n\t// Check if already applied\n\tvar count int\n\trow := db.QueryRow(`SELECT COUNT(*) FROM _migrations WHERE id = 'v2-task-oriented'`)\n\tif err := row.Scan(&count); err == nil && count > 0 {\n\t\treturn nil // already migrated\n\t}\n\n\t// Create new tables\n\tif _, err := db.Exec(`CREATE TABLE IF NOT EXISTS tasks (\n\t\tid TEXT PRIMARY KEY,\n\t\ttitle TEXT NOT NULL DEFAULT '',\n\t\tsource TEXT NOT NULL DEFAULT 'external',\n\t\tproject_dir TEXT NOT NULL DEFAULT '',\n\t\tcreated_at TEXT NOT NULL DEFAULT ''\n\t)`); err != nil {\n\t\treturn fmt.Errorf(\"creating tasks table: %w\", err)\n\t}\n\n\tif _, err := db.Exec(`CREATE TABLE IF NOT EXISTS attempts (\n\t\tid TEXT PRIMARY KEY,\n\t\ttask_id TEXT NOT NULL REFERENCES tasks(id),\n\t\tstarted_at TEXT NOT NULL DEFAULT '',\n\t\tended_at TEXT,\n\t\tresult TEXT NOT NULL DEFAULT 'running',\n\t\tproject_dir TEXT NOT NULL DEFAULT ''\n\t)`); err != nil {\n\t\treturn fmt.Errorf(\"creating attempts table: %w\", err)\n\t}\n\n\t// Add attempt_id column to runs (idempotent)\n\tdb.Exec(`ALTER TABLE runs ADD COLUMN attempt_id TEXT NOT NULL DEFAULT ''`)\n\n\t// Query all existing runs, grouped by task_id\n\trows, err := db.Query(`SELECT id, workflow_name, state, started_at, completed_at,\n\t\tproject_dir, task_id, task_title, is_host, parent_run_id\n\t\tFROM runs ORDER BY started_at ASC`)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"querying runs: %w\", err)\n\t}\n\tdefer rows.Close()\n\n\ttype runRecord struct {\n\t\tid           string\n\t\tworkflow     string\n\t\tstate        string\n\t\tstartedAt    string\n\t\tcompletedAt  string\n\t\tprojectDir   string\n\t\ttaskID       string\n\t\ttaskTitle    string\n\t\tisHost       bool\n\t\tparentRunID  string\n\t}\n\n\tvar allRuns []runRecord\n\tfor rows.Next() {\n\t\tvar r runRecord\n\t\tvar isHost int\n\t\tvar completedAt sql.NullString\n\t\tif err := rows.Scan(&r.id, &r.workflow, &r.state, &r.startedAt,\n\t\t\t&completedAt, &r.projectDir, &r.taskID, &r.taskTitle,\n\t\t\t&isHost, &r.parentRunID); err != nil {\n\t\t\tlog.Printf(\"v2 migration: skipping run (scan error): %v\", err)\n\t\t\tcontinue\n\t\t}\n\t\tr.isHost = isHost == 1\n\t\tif completedAt.Valid {\n\t\t\tr.completedAt = completedAt.String\n\t\t}\n\t\tallRuns = append(allRuns, r)\n\t}\n\n\tif len(allRuns) == 0 {\n\t\t// No runs to migrate â€” skip marking as done so migration\n\t\t// re-checks on next startup (cheap, handles upgrades where\n\t\t// the daemon starts before any runs exist).\n\t\treturn nil\n\t}\n\n\t// Build parentâ†’child mapping\n\tchildrenOf := map[string][]string{}\n\trunByID := map[string]*runRecord{}\n\tfor i := range allRuns {\n\t\trunByID[allRuns[i].id] = &allRuns[i]\n\t\tif allRuns[i].parentRunID != \"\" {\n\t\t\tchildrenOf[allRuns[i].parentRunID] = append(childrenOf[allRuns[i].parentRunID], allRuns[i].id)\n\t\t}\n\t}\n\n\t// Identify top-level runs (no parent, or parent not in DB)\n\tvar topLevel []runRecord\n\tfor _, r := range allRuns {\n\t\tif r.parentRunID == \"\" || runByID[r.parentRunID] == nil {\n\t\t\ttopLevel = append(topLevel, r)\n\t\t}\n\t}\n\n\t// Group top-level runs by task_id. Each top-level run becomes an attempt.\n\t// Runs without a task_id get a generated user-initiated task.\n\ttaskCreated := map[string]bool{}\n\tuserTaskCounter := 0\n\n\t// Sort by started_at for stable attempt numbering\n\tsort.SliceStable(topLevel, func(i, j int) bool {\n\t\treturn topLevel[i].startedAt < topLevel[j].startedAt\n\t})\n\n\ttx, err := db.Begin()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"starting transaction: %w\", err)\n\t}\n\tdefer tx.Rollback()\n\n\tfor _, r := range topLevel {\n\t\ttaskID := r.taskID\n\t\ttaskTitle := r.taskTitle\n\t\ttaskSource := \"external\"\n\n\t\t// Create a user-initiated task for runs without a task ID\n\t\tif taskID == \"\" {\n\t\t\tuserTaskCounter++\n\t\t\ttaskID = fmt.Sprintf(\"user-%s\", domain.GenerateAttemptID())\n\t\t\ttaskSource = \"user-initiated\"\n\t\t\tif taskTitle == \"\" {\n\t\t\t\ttaskTitle = r.workflow + \" (user-initiated)\"\n\t\t\t}\n\t\t}\n\n\t\t// Create task record if not yet created\n\t\tif !taskCreated[taskID] {\n\t\t\t_, err := tx.Exec(`INSERT OR IGNORE INTO tasks (id, title, source, project_dir, created_at)\n\t\t\t\tVALUES (?, ?, ?, ?, ?)`,\n\t\t\t\ttaskID, taskTitle, taskSource, r.projectDir, r.startedAt)\n\t\t\tif err != nil {\n\t\t\t\tlog.Printf(\"v2 migration: failed to create task %s: %v\", taskID, err)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\ttaskCreated[taskID] = true\n\t\t}\n\n\t\t// Create attempt from this top-level run\n\t\tattemptID := domain.GenerateAttemptID()\n\t\tattemptResult := mapRunStateToAttemptResult(r.state)\n\n\t\t_, err := tx.Exec(`INSERT INTO attempts (id, task_id, started_at, ended_at, result, project_dir)\n\t\t\tVALUES (?, ?, ?, ?, ?, ?)`,\n\t\t\tattemptID, taskID, r.startedAt, nullIfEmpty(r.completedAt), attemptResult, r.projectDir)\n\t\tif err != nil {\n\t\t\tlog.Printf(\"v2 migration: failed to create attempt for run %s: %v\", r.id, err)\n\t\t\tcontinue\n\t\t}\n\n\t\t// Link this run and its children to the attempt\n\t\trunIDs := []string{r.id}\n\t\tfor _, childID := range childrenOf[r.id] {\n\t\t\trunIDs = append(runIDs, childID)\n\t\t}\n\n\t\tfor _, runID := range runIDs {\n\t\t\ttx.Exec(`UPDATE runs SET attempt_id = ?, task_id = ? WHERE id = ?`, attemptID, taskID, runID)\n\t\t}\n\n\t\t// Move log files on disk\n\t\tmoveRunLogs(r.projectDir, r.id, taskID, attemptID, r.workflow)\n\t\tfor _, childID := range childrenOf[r.id] {\n\t\t\tchildRun := runByID[childID]\n\t\t\tif childRun != nil {\n\t\t\t\tmoveRunLogs(childRun.projectDir, childID, taskID, attemptID, childRun.workflow)\n\t\t\t}\n\t\t}\n\t}\n\n\tif err := tx.Commit(); err != nil {\n\t\treturn fmt.Errorf(\"committing migration: %w\", err)\n\t}\n\n\t// Mark migration as complete\n\tdb.Exec(`INSERT INTO _migrations (id, applied_at) VALUES ('v2-task-oriented', ?)`,\n\t\ttime.Now().UTC().Format(time.RFC3339))\n\n\tlog.Printf(\"v2 migration: migrated %d top-level runs into tasks and attempts\", len(topLevel))\n\treturn nil\n}\n\n// moveRunLogs moves log files from .cloche/<run-id>/output/ to\n// .cloche/logs/<task-id>/<attempt-id>/. Files are renamed from\n// <step>.log to <workflow>-<step>.log.\nfunc moveRunLogs(projectDir, runID, taskID, attemptID, workflow string) {\n\tsrcDir := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n\tif _, err := os.Stat(srcDir); err != nil {\n\t\treturn // no output directory\n\t}\n\n\tdstDir := filepath.Join(projectDir, \".cloche\", \"logs\", taskID, attemptID)\n\tif err := os.MkdirAll(dstDir, 0755); err != nil {\n\t\tlog.Printf(\"v2 migration: failed to create log dir %s: %v\", dstDir, err)\n\t\treturn\n\t}\n\n\tentries, err := os.ReadDir(srcDir)\n\tif err != nil {\n\t\treturn\n\t}\n\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tsrcPath := filepath.Join(srcDir, entry.Name())\n\t\t// Rename: full.log stays as full.log, others get workflow prefix\n\t\tdstName := entry.Name()\n\t\tif dstName != \"full.log\" && dstName != \"container.log\" {\n\t\t\t// step.log â†’ workflow-step.log\n\t\t\tdstName = workflow + \"-\" + dstName\n\t\t}\n\t\tdstPath := filepath.Join(dstDir, dstName)\n\n\t\t// Copy (not rename, to handle cross-device) then remove\n\t\tdata, err := os.ReadFile(srcPath)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif err := os.WriteFile(dstPath, data, 0644); err != nil {\n\t\t\tlog.Printf(\"v2 migration: failed to write %s: %v\", dstPath, err)\n\t\t\tcontinue\n\t\t}\n\t}\n\n\t// Remove old output directory after successful copy\n\tos.RemoveAll(srcDir)\n\n\t// Remove old run directory if now empty\n\trunDir := filepath.Join(projectDir, \".cloche\", runID)\n\tremoveIfEmpty(runDir)\n}\n\n// removeIfEmpty removes a directory if it contains no files.\nfunc removeIfEmpty(dir string) {\n\tentries, err := os.ReadDir(dir)\n\tif err != nil {\n\t\treturn\n\t}\n\tif len(entries) == 0 {\n\t\tos.Remove(dir)\n\t}\n}\n\nfunc mapRunStateToAttemptResult(state string) string {\n\tswitch state {\n\tcase \"succeeded\":\n\t\treturn \"succeeded\"\n\tcase \"failed\":\n\t\treturn \"failed\"\n\tcase \"cancelled\":\n\t\treturn \"cancelled\"\n\tcase \"running\", \"pending\":\n\t\treturn \"running\"\n\tdefault:\n\t\treturn \"failed\"\n\t}\n}\n\nfunc nullIfEmpty(s string) interface{} {\n\tif s == \"\" {\n\t\treturn nil\n\t}\n\t// Also treat zero time as null\n\tif strings.HasPrefix(s, \"0001-01-01\") {\n\t\treturn nil\n\t}\n\treturn s\n}\n","numLines":298,"startLine":1,"totalLines":298}}}
