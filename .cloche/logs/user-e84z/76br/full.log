\t\tstore:     store,\n    49→\t\tcontainer: container,\n    50→\t\trunIDs:    make(map[string]string),\n    51→\t}\n    52→}\n    53→\n    54→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    55→\treturn &ClocheServer{\n    56→\t\tstore:        store,\n    57→\t\tcaptures:     captures,\n    58→\t\tcontainer:    container,\n    59→\t\tdefaultImage: defaultImage,\n    60→\t\trunIDs:       make(map[string]string),\n    61→\t}\n    62→}\n    63→\n    64→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    65→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    66→\ts.logStore = ls\n    67→}\n    68→\n    69→\n    70→// SetEvolution attaches an evolution trigger to the server.\n    71→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    72→\ts.evolution = trigger\n    73→}\n    74→\n    75→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    76→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    77→\ts.logBroadcast = b\n    78→}\n    79→\n    80→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    81→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    82→\ts.shutdownFn = fn\n    83→}\n    84→\n    85→// SetOnRunComplete sets a callback invoked after each workflow run completes.\n    86→func (s *ClocheServer) SetOnRunComplete(fn OnRunCompleteFunc) {\n    87→\ts.onRunComplete = fn\n    88→}\n    89→\n    90→\n    91→// SetOrchestrateFunc sets the function invoked by the Orchestrate RPC.\n    92→func (s *ClocheServer) SetOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) {\n    93→\ts.orchestrateFn = fn\n    94→}\n    95→\n    96→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    97→\tif s.container == nil {\n    98→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    99→\t}\n   100→"}]},"parent_tool_use_id":"toolu_01UrbVxAhg4J7XmRgi48FVn7","session_id":"be3855ff-2535-428a-8a0c-d975245212ae","uuid":"51bb5ff4-0d45-4741-8c52-0f52556233ed"}
