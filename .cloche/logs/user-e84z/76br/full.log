tore) (*EvolutionResult, error) {\n    51→\t// Stage 1: Collect\n    52→\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n    53→\tif err != nil {\n    54→\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n    55→\t}\n    56→\n    57→\t// Stage 2: Classify the triggering run\n    58→\tclassification, err := o.classifier.Classify(ctx, \"\")\n    59→\tif err != nil {\n    60→\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n    61→\t}\n    62→\n    63→\t// Stage 3: Reflect\n    64→\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n    65→\tif err != nil {\n    66→\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n    67→\t}\n    68→\n    69→\tresult := &EvolutionResult{\n    70→\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n    71→\t\tProjectDir:     o.cfg.ProjectDir,\n    72→\t\tWorkflowName:   o.cfg.WorkflowName,\n    73→\t\tTriggerRunID:   triggerRunID,\n    74→\t\tTimestamp:      time.Now().Format(time.RFC3339),\n    75→\t\tClassification: classification,\n    76→\t}\n    77→\n    78→\tif len(lessons) == 0 {\n    79→\t\t// No actionable lessons — log and return\n    80→\t\to.audit.Log(result)\n    81→\t\treturn result, nil\n    82→\t}\n    83→\n    84→\t// Stage 4: Execute branches based on lesson category\n    85→\tfor _, lesson := range lessons {\n    86→\t\tswitch lesson.Category {\n    87→\t\tcase \"prompt_improvement\":\n    88→\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n    89→\t\t\tif err != nil {\n    90→\t\t\t\tcontinue // log but don't fail the whole pipeline\n    91→\t\t\t}\n    92→\t\t\tresult.Changes = append(result.Changes, *change)\n    93→\n    94→\t\tcase \"new_step\":\n    95→\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n    96→\t\t\t\tcontinue\n    97→\t\t\t}\n    98→\t\t}\n    99→\t}\n   100→\n   101→\t// Stage 5: Audit\n   102→\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n   103→\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n   104→\to.audit.Log(result)\n   105→\n   106→\t// Save to store if available\n   107→\tif evoStore != nil {\n   108→\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n   109→\t\t\tID:             result.ID,\n   110→\t\t\tProjectDir:     result.ProjectDir,\n   111→\t\t\tWorkflowName:   result.WorkflowName,\n   112→\t\t\tTriggerRunID:   result.TriggerRunID,\n   113→\t\t\tCreatedAt:      time.Now(),\n   114→\t\t\tClassification: result.Classification,\n   115→\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n   116→\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n   117→\t\t})\n   118→\t}\n   119→\n   120→\treturn result, nil\n   121→}\n   122→\n   123→// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\n   124→func (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n   125→\t// Generate the script or prompt file\n   126→\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n   127→\tif err != nil {\n   128→\t\treturn err\n   129→\t}\n   130→\n   131→\tresult.Changes = append(result.Changes, Change{\n   132→\t\tType:   \"add_script\",\n   133→\t\tFile:   generated.Path,\n   134→\t\tReason: lesson.Insight,\n   135→\t})\n   136→\n   137→\t// Add step and wiring to the workflow file\n   138→\tif data.WorkflowPath == \"\" {\n   139→\t\treturn nil\n   140→\t}\n   141→\n   142→\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n   143→\tif err != nil {\n   144→\t\treturn err\n   145→\t}\n   146→\n   147→\t// Snapshot the workflow\n   148→\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n   149→\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n   150→\n   151→\t// Derive step name from the script path\n   152→\tstepName := filepath.Base(generated.Path)\n   153→\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n   154→\n   155→\t// Determine the config based on step type\n   156→\tconfig := map[string]string{}\n   157→\tswitch lesson.StepType {\n   158→\tcase \"agent\":\n   159→\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n   160→\tdefault: // script\n   161→\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n   162→\t}\n   163→\n   164→\t// Add the step\n   165→\tupdated, err := o.mutator.AddStep(string(workflowContent), dsl.StepDef{\n   166→\t\tName:    stepName,\n   167→\t\tType:    lesson.StepType,\n   168→\t\tConfig:  config,\n   169→\t\tResults: []string{\"success\", \"fail\"},\n   170→\t})\n   171→\tif err != nil {\n   172→\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n   173→\t}\n   174→\n   175→\t// Add wiring: wire the new step's fail to the fix step (if it exists),\n   176→\t// and success to done\n   177→\twires := []dsl.WireDef{\n   178→\t\t{From: stepName, Result: \"success\", To: \"done\"},\n   179→\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n   180→\t}\n   181→\tupdated, err = o.mutator.AddWiring(updated, wires)\n   182→\tif err != nil {\n   183→\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n   184→\t}\n   185→\n   186→\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n   187→\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n   188→\t}\n   189→\n   190→\tresult.Changes = append(result.Changes, Change{\n   191→\t\tType:     \"add_step\",\n   192→\t\tFile:     wfRelPath,\n   193→\t\tReason:   lesson.Insight,\n   194→\t\tSnapshot: snapName,\n   195→\t})\n   196→\n   197→\treturn nil\n   198→}\n   199→"}]},"parent_tool_use_id":null,"session_id":"be3855ff-2535-428a-8a0c-d975245212ae","uuid":"46e89e41-99b1-4f6b-ab3f-e598bad4b390","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/orchestrator.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// OrchestratorConfig configures the evolution pipeline.\ntype OrchestratorConfig struct {\n\tProjectDir    string\n\tWorkflowName  string\n\tLLM           LLMClient\n\tMinConfidence string\n}\n\n// Orchestrator wires all evolution pipeline stages together.\ntype Orchestrator struct {\n\tcfg        OrchestratorConfig\n\tcollector  *Collector\n\tclassifier *Classifier\n\treflector  *Reflector\n\tcurator    *Curator\n\tscriptGen  *ScriptGenerator\n\tmutator    *dsl.Mutator\n\taudit      *AuditLogger\n}\n\n// NewOrchestrator creates a fully wired evolution pipeline.\nfunc NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir}\n\treturn &Orchestrator{\n\t\tcfg:        cfg,\n\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n\t\tclassifier: &Classifier{LLM: cfg.LLM},\n\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n\t\tmutator:    &dsl.Mutator{},\n\t\taudit:      audit,\n\t}\n}\n\n// Run executes the full evolution pipeline.\nfunc (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n\t// Stage 1: Collect\n\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n\t}\n\n\t// Stage 2: Classify the triggering run\n\tclassification, err := o.classifier.Classify(ctx, \"\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n\t}\n\n\t// Stage 3: Reflect\n\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n\t}\n\n\tresult := &EvolutionResult{\n\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n\t\tProjectDir:     o.cfg.ProjectDir,\n\t\tWorkflowName:   o.cfg.WorkflowName,\n\t\tTriggerRunID:   triggerRunID,\n\t\tTimestamp:      time.Now().Format(time.RFC3339),\n\t\tClassification: classification,\n\t}\n\n\tif len(lessons) == 0 {\n\t\t// No actionable lessons — log and return\n\t\to.audit.Log(result)\n\t\treturn result, nil\n\t}\n\n\t// Stage 4: Execute branches based on lesson category\n\tfor _, lesson := range lessons {\n\t\tswitch lesson.Category {\n\t\tcase \"prompt_improvement\":\n\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // log but don't fail the whole pipeline\n\t\t\t}\n\t\t\tresult.Changes = append(result.Changes, *change)\n\n\t\tcase \"new_step\":\n\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\t}\n\n\t// Stage 5: Audit\n\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n\to.audit.Log(result)\n\n\t// Save to store if available\n\tif evoStore != nil {\n\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n\t\t\tID:             result.ID,\n\t\t\tProjectDir:     result.ProjectDir,\n\t\t\tWorkflowName:   result.WorkflowName,\n\t\t\tTriggerRunID:   result.TriggerRunID,\n\t\t\tCreatedAt:      time.Now(),\n\t\t\tClassification: result.Classification,\n\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n\t\t})\n\t}\n\n\treturn result, nil\n}\n\n// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\nfunc (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n\t// Generate the script or prompt file\n\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tresult.Changes = append(result.Changes, Change{\n\t\tType:   \"add_script\",\n\t\tFile:   generated.Path,\n\t\tReason: lesson.Insight,\n\t})\n\n\t// Add step and wiring to the workflow file\n\tif data.WorkflowPath == \"\" {\n\t\treturn nil\n\t}\n\n\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// Snapshot the workflow\n\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n\n\t// Derive step name from the script path\n\tstepName := filepath.Base(generated.Path)\n\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n\n\t// Determine the config based on step type\n\tconfig := map[string]string{}\n\tswitch lesson.StepType {\n\tcase \"agent\":\n\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n\tdefault: // script\n\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n\t}\n\n\t// Add the step\n\tupdated, err := o.mutator.AddStep(string(workflowContent), dsl.StepDef{\n\t\tName:    stepName,\n\t\tType:    lesson.StepType,\n\t\tConfig:  config,\n\t\tResults: []string{\"success\", \"fail\"},\n\t})\n\tif err != nil {\n\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n\t}\n\n\t// Add wiring: wire the new step's fail to the fix step (if it exists),\n\t// and success to done\n\twires := []dsl.WireDef{\n\t\t{From: stepName, Result: \"success\", To: \"done\"},\n\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n\t}\n\tupdated, err = o.mutator.AddWiring(updated, wires)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n\t}\n\n\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n\t}\n\n\tresult.Changes = append(result.Changes, Change{\n\t\tType:     \"add_step\",\n\t\tFile:     wfRelPath,\n\t\tReason:   lesson.Insight,\n\t\tSnapshot: snapName,\n\t})\n\n\treturn nil\n}\n","numLines":199,"startLine":1,"totalLines":199}}}
