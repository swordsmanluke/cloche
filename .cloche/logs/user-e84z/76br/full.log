\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1252→\t}\n  1253→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1254→}\n  1255→\n  1256→func truncate(s string, n int) string {\n  1257→\tif len(s) <= n {\n  1258→\t\treturn s\n  1259→\t}\n  1260→\treturn s[:n] + \"...\"\n  1261→}\n  1262→\n  1263→func shortContainerID(id string) string {\n  1264→\tif len(id) > 12 {\n  1265→\t\treturn id[:12]\n  1266→\t}\n  1267→\treturn id\n  1268→}\n  1269→\n  1270→// projectLabels builds a mapping from full project directory paths to short\n  1271→// display labels. Each label is the final directory component (e.g.\n  1272→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1273→// the same final name, the parent directory is prepended to disambiguate\n  1274→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1275→func projectLabels(dirs []string) map[string]string {\n  1276→\tlabels := make(map[string]string, len(dirs))\n  1277→\t// Group dirs by their base name to detect conflicts.\n  1278→\tbyBase := map[string][]string{}\n  1279→\tfor _, d := range dirs {\n  1280→\t\tbase := filepath.Base(d)\n  1281→\t\tbyBase[base] = append(byBase[base], d)\n  1282→\t}\n  1283→\tfor base, paths := range byBase {\n  1284→\t\tif len(paths) == 1 {\n  1285→\t\t\tlabels[paths[0]] = base\n  1286→\t\t} else {\n  1287→\t\t\tfor _, p := range paths {\n  1288→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1289→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1290→\t\t\t}\n  1291→\t\t}\n  1292→\t}\n  1293→\treturn labels\n  1294→}\n  1295→\n  1296→type projectEntry struct {\n  1297→\tDir            string\n  1298→\tLabel          string\n  1299→\tContainerCount int\n  1300→}\n  1301→"}]},"parent_tool_use_id":"toolu_01UrbVxAhg4J7XmRgi48FVn7","session_id":"be3855ff-2535-428a-8a0c-d975245212ae","uuid":"86b4a6cd-aae3-4561-b1e5-d46ae3bfddd1"}
