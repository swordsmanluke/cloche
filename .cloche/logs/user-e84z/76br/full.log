[2026-03-08T02:59:34Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KQqBRmQxwxB57PHWxQ2XM8","type":"tool_result","content":"     1→package orchestrator\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"sync\"\n     9→\t\"testing\"\n    10→\t\"time\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    14→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    15→\t\"github.com/stretchr/testify/assert\"\n    16→\t\"github.com/stretchr/testify/require\"\n    17→)\n    18→\n    19→// mockTracker implements ports.TaskTracker for testing.\n    20→type mockTracker struct {\n    21→\tmu       sync.Mutex\n    22→\ttasks    []ports.TrackerTask\n    23→\tclaimed  []string\n    24→\tcompleted []string\n    25→\tfailed   []string\n    26→\tclaimErr error\n    27→}\n    28→\n    29→func (m *mockTracker) ListReady(_ context.Context, project string) ([]ports.TrackerTask, error) {\n    30→\tm.mu.Lock()\n    31→\tdefer m.mu.Unlock()\n    32→\t// Return a copy\n    33→\tresult := make([]ports.TrackerTask, len(m.tasks))\n    34→\tcopy(result, m.tasks)\n    35→\treturn result, nil\n    36→}\n    37→\n    38→func (m *mockTracker) Claim(_ context.Context, taskID string) error {\n    39→\tm.mu.Lock()\n    40→\tdefer m.mu.Unlock()\n    41→\tif m.claimErr != nil {\n    42→\t\treturn m.claimErr\n    43→\t}\n    44→\tm.claimed = append(m.claimed, taskID)\n    45→\treturn nil\n    46→}\n    47→\n    48→func (m *mockTracker) Complete(_ context.Context, taskID string) error {\n    49→\tm.mu.Lock()\n    50→\tdefer m.mu.Unlock()\n    51→\tm.completed = append(m.completed, taskID)\n    52→\treturn nil\n    53→}\n    54→\n    55→func (m *mockTracker) Fail(_ context.Context, taskID string) error {\n    56→\tm.mu.Lock()\n    57→\tdefer m.mu.Unlock()\n    58→\tm.failed = append(m.failed, taskID)\n    59→\treturn nil\n    60→}\n    61→\n    62→// mockPromptGen implements PromptGenerator for testing.\n    63→type mockPromptGen struct {\n    64→\tresponse string\n    65→\terr      error\n    66→\tcalls    int\n    67→}\n    68→\n    69→func (m *mockPromptGen) Generate(_ context.Context, task ports.TrackerTask, projectDir string) (string, error) {\n    70→\tm.calls++\n    71→\treturn m.response, m.err\n    72→}\n    73→\n    74→func TestOrchestratorRun_DispatchesTasks(t *testing.T) {\n    75→\ttracker := &mockTracker{\n    76→\t\ttasks: []ports.TrackerTask{\n    77→\t\t\t{ID: \"task-1\", Title: \"First task\", Priority: 2},\n    78→\t\t\t{ID: \"task-2\", Title: \"Second task\", Priority: 1},\n    79→\t\t},\n    80→\t}\n    81→\tpromptGen := &mockPromptGen{response: \"generated prompt\"}\n    82→\n    83→\tvar dispatched []string\n    84→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n    85→\t\tdispatched = append(dispatched, prompt)\n    86→\t\treturn \"run-\" + fmt.Sprintf(\"%d\", len(dispatched)), nil\n    87→\t}\n    88→\n    89→\torch := New(promptGen, dispatch)\n    90→\torch.Register(&ProjectConfig{\n    91→\t\tDir:         \"/test/project\",\n    92→\t\tWorkflow:    \"develop\",\n    93→\t\tConcurrency: 2,\n    94→\t\tTracker:     tracker,\n    95→\t})\n    96→\n    97→\tn, err := orch.Run(context.Background(), \"/test/project\")\n    98→\trequire.NoError(t, err)\n    99→\tassert.Equal(t, 2, n)\n   100→\tassert.Equal(t, 2, len(dispatched))\n   101→\tassert.Equal(t, []string{\"task-1\", \"task-2\"}, tracker.claimed)\n   102→\tassert.Equal(t, 2, promptGen.calls)\n   103→}\n   104→\n   105→func TestOrchestratorRun_RespectsConncurrencyLimit(t *testing.T) {\n   106→\ttracker := &mockTracker{\n   107→\t\ttasks: []ports.TrackerTask{\n   108→\t\t\t{ID: \"task-1\", Title: \"First\", Priority: 2},\n   109→\t\t\t{ID: \"task-2\", Title: \"Second\", Priority: 1},\n   110→\t\t},\n   111→\t}\n   112→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   113→\n   114→\tdispatchCount := 0\n   115→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   116→\t\tdispatchCount++\n   117→\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n   118→\t}\n   119→\n   120→\torch := New(promptGen, dispatch)\n   121→\torch.Register(&ProjectConfig{\n   122→\t\tDir:         \"/test/project\",\n   123→\t\tWorkflow:    \"develop\",\n   124→\t\tConcurrency: 1, // only 1 slot\n   125→\t\tTracker:     tracker,\n   126→\t})\n   127→\n   128→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   129→\trequire.NoError(t, err)\n   130→\tassert.Equal(t, 1, n)\n   131→\tassert.Equal(t, 1, dispatchCount)\n   132→\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed) // highest priority\n   133→}\n   134→\n   135→func TestOrchestratorRun_NoAvailableSlots(t *testing.T) {\n   136→\ttracker := &mockTracker{\n   137→\t\ttasks: []ports.TrackerTask{\n   138→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   139→\t\t},\n   140→\t}\n   141→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   142→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   143→\t\treturn \"run-1\", nil\n   144→\t}\n   145→\n   146→\torch := New(promptGen, dispatch)\n   147→\torch.Register(&ProjectConfig{\n   148→\t\tDir:         \"/test/project\",\n   149→\t\tWorkflow:    \"develop\",\n   150→\t\tConcurrency: 1,\n   151→\t\tTracker:     tracker,\n   152→\t})\n   153→\n   154→\t// Simulate an in-flight run\n   155→\torch.mu.Lock()\n   156→\torch.inFlight[\"/test/project\"] = 1\n   157→\torch.mu.Unlock()\n   158→\n   159→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   160→\trequire.NoError(t, err)\n   161→\tassert.Equal(t, 0, n)\n   162→}\n   163→\n   164→func TestOrchestratorRun_NoReadyTasks(t *testing.T) {\n   165→\ttracker := &mockTracker{tasks: nil}\n   166→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   167→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   168→\t\tt.Fatal(\"dispatch should not be called\")\n   169→\t\treturn \"\", nil\n   170→\t}\n   171→\n   172→\torch := New(promptGen, dispatch)\n   173→\torch.Register(&ProjectConfig{\n   174→\t\tDir:         \"/test/project\",\n   175→\t\tWorkflow:    \"develop\",\n   176→\t\tConcurrency: 1,\n   177→\t\tTracker:     tracker,\n   178→\t})\n   179→\n   180→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   181→\trequire.NoError(t, err)\n   182→\tassert.Equal(t, 0, n)\n   183→}\n   184→\n   185→func TestOrchestratorRun_UnregisteredProject(t *testing.T) {\n   186→\torch := New(nil, nil)\n   187→\t_, err := orch.Run(context.Background(), \"/unknown\")\n   188→\tassert.Error(t, err)\n   189→\tassert.Contains(t, err.Error(), \"not registered\")\n   190→}\n   191→\n   192→func TestOrchestratorRun_PromptGenerationFailure(t *testing.T) {\n   193→\ttracker := &mockTracker{\n   194→\t\ttasks: []ports.TrackerTask{\n   195→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   196→\t\t},\n   197→\t}\n   198→\tpromptGen := &mockPromptGen{err: fmt.Errorf(\"LLM unavailable\")}\n   199→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   200→\t\tt.Fatal(\"dispatch should not be called on prompt failure\")\n   201→\t\treturn \"\", nil\n   202→\t}\n   203→\n   204→\torch := New(promptGen, dispatch)\n   205→\torch.Register(&ProjectConfig{\n   206→\t\tDir:         \"/test/project\",\n   207→\t\tWorkflow:    \"develop\",\n   208→\t\tConcurrency: 1,\n   209→\t\tTracker:     tracker,\n   210→\t})\n   211→\n   212→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   213→\trequire.NoError(t, err) // errors are logged, not returned\n   214→\tassert.Equal(t, 0, n)\n   215→\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed)\n   216→\tassert.Equal(t, []string{\"task-1\"}, tracker.failed) // task should be failed back\n   217→}\n   218→\n   219→func TestOrchestratorRun_DispatchFailure(t *testing.T) {\n   220→\ttracker := &mockTracker{\n   221→\t\ttasks: []ports.TrackerTask{\n   222→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   223→\t\t},\n   224→\t}\n   225→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   226→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   227→\t\treturn \"\", fmt.Errorf(\"container start failed\")\n   228→\t}\n   229→\n   230→\torch := New(promptGen, dispatch)\n   231→\torch.Register(&ProjectConfig{\n   232→\t\tDir:         \"/test/project\",\n   233→\t\tWorkflow:    \"develop\",\n   234→\t\tConcurrency: 1,\n   235→\t\tTracker:     tracker,\n   236→\t})\n   237→\n   238→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   239→\trequire.NoError(t, err)\n   240→\tassert.Equal(t, 0, n)\n   241→\tassert.Equal(t, []string{\"task-1\"}, tracker.failed)\n   242→}\n   243→\n   244→func TestOrchestratorRun_ClaimFailure(t *testing.T) {\n   245→\ttracker := &mockTracker{\n   246→\t\ttasks: []ports.TrackerTask{\n   247→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   248→\t\t},\n   249→\t\tclaimErr: fmt.Errorf(\"already claimed\"),\n   250→\t}\n   251→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   252→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   253→\t\tt.Fatal(\"dispatch should not be called on claim failure\")\n   254→\t\treturn \"\", nil\n   255→\t}\n   256→\n   257→\torch := New(promptGen, dispatch)\n   258→\torch.Register(&ProjectConfig{\n   259→\t\tDir:         \"/test/project\",\n   260→\t\tWorkflow:    \"develop\",\n   261→\t\tConcurrency: 1,\n   262→\t\tTracker:     tracker,\n   263→\t})\n   264→\n   265→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   266→\trequire.NoError(t, err)\n   267→\tassert.Equal(t, 0, n)\n   268→}\n   269→\n   270→func TestOrchestratorTriggerAll(t *testing.T) {\n   271→\ttracker1 := &mockTracker{\n   272→\t\ttasks: []ports.TrackerTask{{ID: \"t1\", Title: \"T1\", Priority: 1}},\n   273→\t}\n   274→\ttracker2 := &mockTracker{\n   275→\t\ttasks: []ports.TrackerTask{{ID: \"t2\", Title: \"T2\", Priority: 1}},\n   276→\t}\n   277→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   278→\n   279→\tdispatchCount := 0\n   280→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   281→\t\tdispatchCount++\n   282→\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n   283→\t}\n   284→\n   285→\torch := New(promptGen, dispatch)\n   286→\torch.Register(&ProjectConfig{Dir: \"/proj1\", Workflow: \"dev\", Concurrency: 1, Tracker: tracker1})\n   287→\torch.Register(&ProjectConfig{Dir: \"/proj2\", Workflow: \"dev\", Concurrency: 1, Tracker: tracker2})\n   288→\n   289→\ttotal := orch.TriggerAll(context.Background())\n   290→\tassert.Equal(t, 2, total)\n   291→\tassert.Equal(t, 2, dispatchCount)\n   292→}\n   293→\n   294→func TestOrchestratorOnRunComplete(t *testing.T) {\n   295→\ttracker := &mockTracker{\n   296→\t\ttasks: []ports.TrackerTask{\n   297→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   298→\t\t},\n   299→\t}\n   300→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   301→\n   302→\tdispatchCount := 0\n   303→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   304→\t\tdispatchCount++\n   305→\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n   306→\t}\n   307→\n   308→\torch := New(promptGen, dispatch)\n   309→\torch.Register(&ProjectConfig{\n   310→\t\tDir:         \"/test/project\",\n   311→\t\tWorkflow:    \"develop\",\n   312→\t\tConcurrency: 1,\n   313→\t\tTracker:     tracker,\n   314→\t})\n   315→\n   316→\t// Simulate a run is in flight (fills the concurrency slot)\n   317→\torch.mu.Lock()\n   318→\torch.inFlight[\"/test/project\"] = 1\n   319→\torch.trackTask(\"/test/project\", \"existing-run\", \"existing-task\")\n   320→\torch.mu.Unlock()\n   321→\n   322→\t// OnRunComplete should decrement in-flight and trigger new dispatch\n   323→\torch.OnRunComplete(context.Background(), \"/test/project\", \"existing-run\", domain.RunStateSucceeded)\n   324→\n   325→\t// After OnRunComplete: 1 → 0 (decrement) → 1 (new run dispatched)\n   326→\tassert.Equal(t, 1, orch.InFlight(\"/test/project\"))\n   327→\tassert.Equal(t, 1, dispatchCount) // should have dispatched the waiting task\n   328→}\n   329→\n   330→func TestOrchestratorOnRunComplete_ClosesTask(t *testing.T) {\n   331→\ttracker := &mockTracker{tasks: nil} // no more ready tasks\n   332→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   333→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   334→\t\treturn \"run-1\", nil\n   335→\t}\n   336→\n   337→\torch := New(promptGen, dispatch)\n   338→\torch.Register(&ProjectConfig{\n   339→\t\tDir:         \"/test/project\",\n   340→\t\tWorkflow:    \"develop\",\n   341→\t\tConcurrency: 1,\n   342→\t\tTracker:     tracker,\n   343→\t})\n   344→\n   345→\t// Simulate a run for task-1 in flight\n   346→\torch.mu.Lock()\n   347→\torch.inFlight[\"/test/project\"] = 1\n   348→\torch.trackTask(\"/test/project\", \"run-1\", \"task-1\")\n   349→\torch.mu.Unlock()\n   350→\n   351→\t// Run succeeds → task should be completed\n   352→\torch.OnRunComplete(context.Background(), \"/test/project\", \"run-1\", domain.RunStateSucceeded)\n   353→\tassert.Equal(t, []string{\"task-1\"}, tracker.completed)\n   354→\tassert.Empty(t, tracker.failed)\n   355→}\n   356→\n   357→func TestOrchestratorOnRunComplete_FailsTask(t *testing.T) {\n   358→\ttracker := &mockTracker{tasks: nil}\n   359→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   360→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   361→\t\treturn \"run-1\", nil\n   362→\t}\n   363→\n   364→\torch := New(promptGen, dispatch)\n   365→\torch.Register(&ProjectConfig{\n   366→\t\tDir:         \"/test/project\",\n   367→\t\tWorkflow:    \"develop\",\n   368→\t\tConcurrency: 1,\n   369→\t\tTracker:     tracker,\n   370→\t})\n   371→\n   372→\t// Simulate a run for task-1 in flight\n   373→\torch.mu.Lock()\n   374→\torch.inFlight[\"/test/project\"] = 1\n   375→\torch.trackTask(\"/test/project\", \"run-1\", \"task-1\")\n   376→\torch.mu.Unlock()\n   377→\n   378→\t// Run fails → task should be failed\n   379→\torch.OnRunComplete(context.Background(), \"/test/project\", \"run-1\", domain.RunStateFailed)\n   380→\tassert.Equal(t, []string{\"task-1\"}, tracker.failed)\n   381→\tassert.Empty(t, tracker.completed)\n   382→}\n   383→\n   384→func TestOrchestratorRun_SkipsDuplicateTasks(t *testing.T) {\n   385→\ttracker := &mockTracker{\n   386→\t\ttasks: []ports.TrackerTask{\n   387→\t\t\t{ID: \"task-1\", Title: \"Already running\", Priority: 2},\n   388→\t\t\t{ID: \"task-2\", Title: \"New task\", Priority: 1},\n   389→\t\t},\n   390→\t}\n   391→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   392→\n   393→\tvar dispatched []string\n   394→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   395→\t\tdispatched = append(dispatched, fmt.Sprintf(\"run-%d\", len(dispatched)+1))\n   396→\t\treturn dispatched[len(dispatched)-1], nil\n   397→\t}\n   398→\n   399→\torch := New(promptGen, dispatch)\n   400→\torch.Register(&ProjectConfig{\n   401→\t\tDir:         \"/test/project\",\n   402→\t\tWorkflow:    \"develop\",\n   403→\t\tConcurrency: 2,\n   404→\t\tTracker:     tracker,\n   405→\t})\n   406→\n   407→\t// Simulate task-1 already in flight\n   408→\torch.mu.Lock()\n   409→\torch.inFlight[\"/test/project\"] = 1\n   410→\torch.trackTask(\"/test/project\", \"existing-run\", \"task-1\")\n   411→\torch.mu.Unlock()\n   412→\n   413→\tn, err := orch.Run(context.Background(), \"/test/project\")\n   414→\trequire.NoError(t, err)\n   415→\tassert.Equal(t, 1, n) // only task-2 should be dispatched\n   416→\tassert.Equal(t, []string{\"task-2\"}, tracker.claimed) // task-1 skipped\n   417→}\n   418→\n   419→func TestOrchestratorInFlightTracking(t *testing.T) {\n   420→\ttracker := &mockTracker{\n   421→\t\ttasks: []ports.TrackerTask{\n   422→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   423→\t\t},\n   424→\t}\n   425→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   426→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   427→\t\treturn \"run-1\", nil\n   428→\t}\n   429→\n   430→\torch := New(promptGen, dispatch)\n   431→\torch.Register(&ProjectConfig{\n   432→\t\tDir:         \"/test/project\",\n   433→\t\tWorkflow:    \"develop\",\n   434→\t\tConcurrency: 2,\n   435→\t\tTracker:     tracker,\n   436→\t})\n   437→\n   438→\tassert.Equal(t, 0, orch.InFlight(\"/test/project\"))\n   439→\n   440→\t_, err := orch.Run(context.Background(), \"/test/project\")\n   441→\trequire.NoError(t, err)\n   442→\n   443→\tassert.Equal(t, 1, orch.InFlight(\"/test/project\"))\n   444→}\n   445→\n   446→func TestOrchestratorRun_HostWorkflowPath(t *testing.T) {\n   447→\ttmpDir := t.TempDir()\n   448→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   449→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   450→\n   451→\t// Write a host.cloche file\n   452→\thostCloche := `workflow \"orchestrate\" {\n   453→  step prep {\n   454→    run     = \"echo hello\"\n   455→    results = [success, fail]\n   456→  }\n   457→\n   458→  prep:success -> done\n   459→  prep:fail    -> abort\n   460→}\n   461→`\n   462→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   463→\n   464→\ttracker := &mockTracker{\n   465→\t\ttasks: []ports.TrackerTask{\n   466→\t\t\t{ID: \"task-1\", Title: \"Test Task\", Description: \"task body\"},\n   467→\t\t},\n   468→\t}\n   469→\tpromptGen := &mockPromptGen{response: \"should not be called\"}\n   470→\n   471→\tdispatchCalled := false\n   472→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   473→\t\tdispatchCalled = true\n   474→\t\treturn \"run-1\", nil\n   475→\t}\n   476→\n   477→\tparseFunc := func(input string) (*domain.Workflow, error) {\n   478→\t\treturn dsl.Parse(input)\n   479→\t}\n   480→\n   481→\twaiter := &mockRunWaiter{state: domain.RunStateSucceeded}\n   482→\thostRunner := &HostRunner{\n   483→\t\tDispatch: dispatch,\n   484→\t\tWaitRun:  waiter,\n   485→\t}\n   486→\n   487→\torch := New(promptGen, dispatch,\n   488→\t\tWithHostRunner(hostRunner),\n   489→\t\tWithParseHostWorkflow(parseFunc),\n   490→\t)\n   491→\torch.Register(&ProjectConfig{\n   492→\t\tDir:         tmpDir,\n   493→\t\tWorkflow:    \"develop\",\n   494→\t\tConcurrency: 1,\n   495→\t\tTracker:     tracker,\n   496→\t})\n   497→\n   498→\tn, err := orch.Run(context.Background(), tmpDir)\n   499→\trequire.NoError(t, err)\n   500→\tassert.Equal(t, 1, n)\n   501→\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed)\n   502→\t// promptGen should NOT have been called (host workflow path used instead)\n   503→\tassert.Equal(t, 0, promptGen.calls)\n   504→\t// dispatch should NOT have been called directly (host runner handles it)\n   505→\tassert.False(t, dispatchCalled)\n   506→\n   507→\t// Wait for the background goroutine to finish so TempDir cleanup succeeds.\n   508→\trequire.Eventually(t, func() bool {\n   509→\t\ttracker.mu.Lock()\n   510→\t\tdefer tracker.mu.Unlock()\n   511→\t\treturn len(tracker.completed) > 0\n   512→\t}, time.Second, 10*time.Millisecond)\n   513→}\n   514→\n   515→func TestOrchestratorRun_FallbackWithoutHostCloche(t *testing.T) {\n   516→\ttmpDir := t.TempDir()\n   517→\t// No host.cloche file — should fall back to promptGen → dispatch path\n   518→\n   519→\ttracker := &mockTracker{\n   520→\t\ttasks: []ports.TrackerTask{\n   521→\t\t\t{ID: \"task-1\", Title: \"Test Task\"},\n   522→\t\t},\n   523→\t}\n   524→\tpromptGen := &mockPromptGen{response: \"generated prompt\"}\n   525→\n   526→\tdispatched := false\n   527→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   528→\t\tdispatched = true\n   529→\t\treturn \"run-1\", nil\n   530→\t}\n   531→\n   532→\twaiter := &mockRunWaiter{state: domain.RunStateSucceeded}\n   533→\thostRunner := &HostRunner{\n   534→\t\tDispatch: dispatch,\n   535→\t\tWaitRun:  waiter,\n   536→\t}\n   537→\n   538→\tparseFunc := func(input string) (*domain.Workflow, error) {\n   539→\t\treturn dsl.Parse(input)\n   540→\t}\n   541→\n   542→\torch := New(promptGen, dispatch,\n   543→\t\tWithHostRunner(hostRunner),\n   544→\t\tWithParseHostWorkflow(parseFunc),\n   545→\t)\n   546→\torch.Register(&ProjectConfig{\n   547→\t\tDir:         tmpDir,\n   548→\t\tWorkflow:    \"develop\",\n   549→\t\tConcurrency: 1,\n   550→\t\tTracker:     tracker,\n   551→\t})\n   552→\n   553→\tn, err := orch.Run(context.Background(), tmpDir)\n   554→\trequire.NoError(t, err)\n   555→\tassert.Equal(t, 1, n)\n   556→\tassert.Equal(t, 1, promptGen.calls)\n   557→\tassert.True(t, dispatched)\n   558→}\n   559→\n   560→func TestOrchestratorRun_UsesCorrectWorkflow(t *testing.T) {\n   561→\ttracker := &mockTracker{\n   562→\t\ttasks: []ports.TrackerTask{\n   563→\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n   564→\t\t},\n   565→\t}\n   566→\tpromptGen := &mockPromptGen{response: \"prompt\"}\n   567→\n   568→\tvar capturedWorkflow string\n   569→\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n   570→\t\tcapturedWorkflow = workflow\n   571→\t\treturn \"run-1\", nil\n   572→\t}\n   573→\n   574→\torch := New(promptGen, dispatch)\n   575→\torch.Register(&ProjectConfig{\n   576→\t\tDir:         \"/test/project\",\n   577→\t\tWorkflow:    \"custom-workflow\",\n   578→\t\tConcurrency: 1,\n   579→\t\tTracker:     tracker,\n   580→\t})\n   581→\n   582→\t_, err := orch.Run(context.Background(), \"/test/project\")\n   583→\trequire.NoError(t, err)\n   584→\tassert.Equal(t, \"custom-workflow\", capturedWorkflow)\n   585→}\n   586→"}]},"parent_tool_use_id":null,"session_id":"be3855ff-2535-428a-8a0c-d975245212ae","uuid":"926c1492-1d14-4e69-bbea-a698758c86c8","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/orchestrator/orchestrator_test.go","content":"package orchestrator\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// mockTracker implements ports.TaskTracker for testing.\ntype mockTracker struct {\n\tmu       sync.Mutex\n\ttasks    []ports.TrackerTask\n\tclaimed  []string\n\tcompleted []string\n\tfailed   []string\n\tclaimErr error\n}\n\nfunc (m *mockTracker) ListReady(_ context.Context, project string) ([]ports.TrackerTask, error) {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\t// Return a copy\n\tresult := make([]ports.TrackerTask, len(m.tasks))\n\tcopy(result, m.tasks)\n\treturn result, nil\n}\n\nfunc (m *mockTracker) Claim(_ context.Context, taskID string) error {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tif m.claimErr != nil {\n\t\treturn m.claimErr\n\t}\n\tm.claimed = append(m.claimed, taskID)\n\treturn nil\n}\n\nfunc (m *mockTracker) Complete(_ context.Context, taskID string) error {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tm.completed = append(m.completed, taskID)\n\treturn nil\n}\n\nfunc (m *mockTracker) Fail(_ context.Context, taskID string) error {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tm.failed = append(m.failed, taskID)\n\treturn nil\n}\n\n// mockPromptGen implements PromptGenerator for testing.\ntype mockPromptGen struct {\n\tresponse string\n\terr      error\n\tcalls    int\n}\n\nfunc (m *mockPromptGen) Generate(_ context.Context, task ports.TrackerTask, projectDir string) (string, error) {\n\tm.calls++\n\treturn m.response, m.err\n}\n\nfunc TestOrchestratorRun_DispatchesTasks(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"First task\", Priority: 2},\n\t\t\t{ID: \"task-2\", Title: \"Second task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"generated prompt\"}\n\n\tvar dispatched []string\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatched = append(dispatched, prompt)\n\t\treturn \"run-\" + fmt.Sprintf(\"%d\", len(dispatched)), nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 2,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 2, n)\n\tassert.Equal(t, 2, len(dispatched))\n\tassert.Equal(t, []string{\"task-1\", \"task-2\"}, tracker.claimed)\n\tassert.Equal(t, 2, promptGen.calls)\n}\n\nfunc TestOrchestratorRun_RespectsConncurrencyLimit(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"First\", Priority: 2},\n\t\t\t{ID: \"task-2\", Title: \"Second\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\n\tdispatchCount := 0\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatchCount++\n\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1, // only 1 slot\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 1, n)\n\tassert.Equal(t, 1, dispatchCount)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed) // highest priority\n}\n\nfunc TestOrchestratorRun_NoAvailableSlots(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\treturn \"run-1\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\t// Simulate an in-flight run\n\torch.mu.Lock()\n\torch.inFlight[\"/test/project\"] = 1\n\torch.mu.Unlock()\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 0, n)\n}\n\nfunc TestOrchestratorRun_NoReadyTasks(t *testing.T) {\n\ttracker := &mockTracker{tasks: nil}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tt.Fatal(\"dispatch should not be called\")\n\t\treturn \"\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 0, n)\n}\n\nfunc TestOrchestratorRun_UnregisteredProject(t *testing.T) {\n\torch := New(nil, nil)\n\t_, err := orch.Run(context.Background(), \"/unknown\")\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"not registered\")\n}\n\nfunc TestOrchestratorRun_PromptGenerationFailure(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{err: fmt.Errorf(\"LLM unavailable\")}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tt.Fatal(\"dispatch should not be called on prompt failure\")\n\t\treturn \"\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err) // errors are logged, not returned\n\tassert.Equal(t, 0, n)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.failed) // task should be failed back\n}\n\nfunc TestOrchestratorRun_DispatchFailure(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\treturn \"\", fmt.Errorf(\"container start failed\")\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 0, n)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.failed)\n}\n\nfunc TestOrchestratorRun_ClaimFailure(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t\tclaimErr: fmt.Errorf(\"already claimed\"),\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tt.Fatal(\"dispatch should not be called on claim failure\")\n\t\treturn \"\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 0, n)\n}\n\nfunc TestOrchestratorTriggerAll(t *testing.T) {\n\ttracker1 := &mockTracker{\n\t\ttasks: []ports.TrackerTask{{ID: \"t1\", Title: \"T1\", Priority: 1}},\n\t}\n\ttracker2 := &mockTracker{\n\t\ttasks: []ports.TrackerTask{{ID: \"t2\", Title: \"T2\", Priority: 1}},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\n\tdispatchCount := 0\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatchCount++\n\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{Dir: \"/proj1\", Workflow: \"dev\", Concurrency: 1, Tracker: tracker1})\n\torch.Register(&ProjectConfig{Dir: \"/proj2\", Workflow: \"dev\", Concurrency: 1, Tracker: tracker2})\n\n\ttotal := orch.TriggerAll(context.Background())\n\tassert.Equal(t, 2, total)\n\tassert.Equal(t, 2, dispatchCount)\n}\n\nfunc TestOrchestratorOnRunComplete(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\n\tdispatchCount := 0\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatchCount++\n\t\treturn fmt.Sprintf(\"run-%d\", dispatchCount), nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\t// Simulate a run is in flight (fills the concurrency slot)\n\torch.mu.Lock()\n\torch.inFlight[\"/test/project\"] = 1\n\torch.trackTask(\"/test/project\", \"existing-run\", \"existing-task\")\n\torch.mu.Unlock()\n\n\t// OnRunComplete should decrement in-flight and trigger new dispatch\n\torch.OnRunComplete(context.Background(), \"/test/project\", \"existing-run\", domain.RunStateSucceeded)\n\n\t// After OnRunComplete: 1 → 0 (decrement) → 1 (new run dispatched)\n\tassert.Equal(t, 1, orch.InFlight(\"/test/project\"))\n\tassert.Equal(t, 1, dispatchCount) // should have dispatched the waiting task\n}\n\nfunc TestOrchestratorOnRunComplete_ClosesTask(t *testing.T) {\n\ttracker := &mockTracker{tasks: nil} // no more ready tasks\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\treturn \"run-1\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\t// Simulate a run for task-1 in flight\n\torch.mu.Lock()\n\torch.inFlight[\"/test/project\"] = 1\n\torch.trackTask(\"/test/project\", \"run-1\", \"task-1\")\n\torch.mu.Unlock()\n\n\t// Run succeeds → task should be completed\n\torch.OnRunComplete(context.Background(), \"/test/project\", \"run-1\", domain.RunStateSucceeded)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.completed)\n\tassert.Empty(t, tracker.failed)\n}\n\nfunc TestOrchestratorOnRunComplete_FailsTask(t *testing.T) {\n\ttracker := &mockTracker{tasks: nil}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\treturn \"run-1\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\t// Simulate a run for task-1 in flight\n\torch.mu.Lock()\n\torch.inFlight[\"/test/project\"] = 1\n\torch.trackTask(\"/test/project\", \"run-1\", \"task-1\")\n\torch.mu.Unlock()\n\n\t// Run fails → task should be failed\n\torch.OnRunComplete(context.Background(), \"/test/project\", \"run-1\", domain.RunStateFailed)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.failed)\n\tassert.Empty(t, tracker.completed)\n}\n\nfunc TestOrchestratorRun_SkipsDuplicateTasks(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Already running\", Priority: 2},\n\t\t\t{ID: \"task-2\", Title: \"New task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\n\tvar dispatched []string\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatched = append(dispatched, fmt.Sprintf(\"run-%d\", len(dispatched)+1))\n\t\treturn dispatched[len(dispatched)-1], nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 2,\n\t\tTracker:     tracker,\n\t})\n\n\t// Simulate task-1 already in flight\n\torch.mu.Lock()\n\torch.inFlight[\"/test/project\"] = 1\n\torch.trackTask(\"/test/project\", \"existing-run\", \"task-1\")\n\torch.mu.Unlock()\n\n\tn, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, 1, n) // only task-2 should be dispatched\n\tassert.Equal(t, []string{\"task-2\"}, tracker.claimed) // task-1 skipped\n}\n\nfunc TestOrchestratorInFlightTracking(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\treturn \"run-1\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 2,\n\t\tTracker:     tracker,\n\t})\n\n\tassert.Equal(t, 0, orch.InFlight(\"/test/project\"))\n\n\t_, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, 1, orch.InFlight(\"/test/project\"))\n}\n\nfunc TestOrchestratorRun_HostWorkflowPath(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\n\t// Write a host.cloche file\n\thostCloche := `workflow \"orchestrate\" {\n  step prep {\n    run     = \"echo hello\"\n    results = [success, fail]\n  }\n\n  prep:success -> done\n  prep:fail    -> abort\n}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Test Task\", Description: \"task body\"},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"should not be called\"}\n\n\tdispatchCalled := false\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatchCalled = true\n\t\treturn \"run-1\", nil\n\t}\n\n\tparseFunc := func(input string) (*domain.Workflow, error) {\n\t\treturn dsl.Parse(input)\n\t}\n\n\twaiter := &mockRunWaiter{state: domain.RunStateSucceeded}\n\thostRunner := &HostRunner{\n\t\tDispatch: dispatch,\n\t\tWaitRun:  waiter,\n\t}\n\n\torch := New(promptGen, dispatch,\n\t\tWithHostRunner(hostRunner),\n\t\tWithParseHostWorkflow(parseFunc),\n\t)\n\torch.Register(&ProjectConfig{\n\t\tDir:         tmpDir,\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, 1, n)\n\tassert.Equal(t, []string{\"task-1\"}, tracker.claimed)\n\t// promptGen should NOT have been called (host workflow path used instead)\n\tassert.Equal(t, 0, promptGen.calls)\n\t// dispatch should NOT have been called directly (host runner handles it)\n\tassert.False(t, dispatchCalled)\n\n\t// Wait for the background goroutine to finish so TempDir cleanup succeeds.\n\trequire.Eventually(t, func() bool {\n\t\ttracker.mu.Lock()\n\t\tdefer tracker.mu.Unlock()\n\t\treturn len(tracker.completed) > 0\n\t}, time.Second, 10*time.Millisecond)\n}\n\nfunc TestOrchestratorRun_FallbackWithoutHostCloche(t *testing.T) {\n\ttmpDir := t.TempDir()\n\t// No host.cloche file — should fall back to promptGen → dispatch path\n\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Test Task\"},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"generated prompt\"}\n\n\tdispatched := false\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tdispatched = true\n\t\treturn \"run-1\", nil\n\t}\n\n\twaiter := &mockRunWaiter{state: domain.RunStateSucceeded}\n\thostRunner := &HostRunner{\n\t\tDispatch: dispatch,\n\t\tWaitRun:  waiter,\n\t}\n\n\tparseFunc := func(input string) (*domain.Workflow, error) {\n\t\treturn dsl.Parse(input)\n\t}\n\n\torch := New(promptGen, dispatch,\n\t\tWithHostRunner(hostRunner),\n\t\tWithParseHostWorkflow(parseFunc),\n\t)\n\torch.Register(&ProjectConfig{\n\t\tDir:         tmpDir,\n\t\tWorkflow:    \"develop\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\tn, err := orch.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, 1, n)\n\tassert.Equal(t, 1, promptGen.calls)\n\tassert.True(t, dispatched)\n}\n\nfunc TestOrchestratorRun_UsesCorrectWorkflow(t *testing.T) {\n\ttracker := &mockTracker{\n\t\ttasks: []ports.TrackerTask{\n\t\t\t{ID: \"task-1\", Title: \"Task\", Priority: 1},\n\t\t},\n\t}\n\tpromptGen := &mockPromptGen{response: \"prompt\"}\n\n\tvar capturedWorkflow string\n\tdispatch := func(ctx context.Context, workflow, projectDir, prompt string) (string, error) {\n\t\tcapturedWorkflow = workflow\n\t\treturn \"run-1\", nil\n\t}\n\n\torch := New(promptGen, dispatch)\n\torch.Register(&ProjectConfig{\n\t\tDir:         \"/test/project\",\n\t\tWorkflow:    \"custom-workflow\",\n\t\tConcurrency: 1,\n\t\tTracker:     tracker,\n\t})\n\n\t_, err := orch.Run(context.Background(), \"/test/project\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"custom-workflow\", capturedWorkflow)\n}\n","numLines":586,"startLine":1,"totalLines":586}}}
