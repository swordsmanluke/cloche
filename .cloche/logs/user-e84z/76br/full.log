015→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1016→\t\t}\n  1017→\t}\n  1018→\n  1019→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1020→\tjson.NewEncoder(w).Encode(map[string]any{\n  1021→\t\t\"docker_image\": dockerImage,\n  1022→\t\t\"version\":      version,\n  1023→\t\t\"prompt_files\": promptFiles,\n  1024→\t})\n  1025→}\n  1026→\n  1027→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1028→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1029→\tif !ok {\n  1030→\t\treturn\n  1031→\t}\n  1032→\tfile := r.URL.Query().Get(\"file\")\n  1033→\tsha := r.URL.Query().Get(\"sha\")\n  1034→\tif file == \"\" || sha == \"\" {\n  1035→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1036→\t\treturn\n  1037→\t}\n  1038→\n  1039→\t// Validate sha is alphanumeric to prevent injection\n  1040→\tfor _, c := range sha {\n  1041→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1042→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1043→\t\t\treturn\n  1044→\t\t}\n  1045→\t}\n  1046→\n  1047→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1048→\tcmd.Dir = dir\n  1049→\tout, err := cmd.Output()\n  1050→\tif err != nil {\n  1051→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1052→\t\treturn\n  1053→\t}\n  1054→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1055→\tw.Write(out)\n  1056→}\n  1057→\n  1058→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1059→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1060→\tif !ok {\n  1061→\t\treturn\n  1062→\t}\n  1063→\n  1064→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1065→\tentries, err := os.ReadDir(clocheDir)\n  1066→\tif err != nil {\n  1067→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1068→\t\tjson.NewEncoder(w).Encode([]any{})\n  1069→\t\treturn\n  1070→