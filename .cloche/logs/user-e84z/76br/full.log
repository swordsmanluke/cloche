open store: %v\\n\", err)\n    45→\t\tos.Exit(1)\n    46→\t}\n    47→\tdefer store.Close()\n    48→\n    49→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    50→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    51→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    52→\t} else if n > 0 {\n    53→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    54→\t}\n    55→\n    56→\truntime, err := initRuntime(globalCfg)\n    57→\tif err != nil {\n    58→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    59→\t\tos.Exit(1)\n    60→\t}\n    61→\n    62→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    63→\n    64→\tbroadcaster := logstream.NewBroadcaster()\n    65→\n    66→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    67→\tsrv.SetLogStore(store)\n    68→\tsrv.SetLogBroadcaster(broadcaster)\n    69→\n    70→\t// Set up evolution trigger\n    71→\tevoTrigger := initEvolution(globalCfg, store, store)\n    72→\tif evoTrigger != nil {\n    73→\t\tsrv.SetEvolution(evoTrigger)\n    74→\t}\n    75→\n    76→\t// Set up orchestrator\n    77→\torch := initOrchestrator(globalCfg, store, srv)\n    78→\tif orch != nil {\n    79→\t\tsrv.SetOnRunComplete(func(ctx context.Context, projectDir string, runID string, state domain.RunState) {\n    80→\t\t\torch.OnRunComplete(ctx, projectDir, runID, state)\n    81→\t\t})\n    82→\t\tsrv.SetOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n    83→\t\t\tif projectDir != \"\" {\n    84→\t\t\t\treturn orch.Run(ctx, projectDir)\n    85→\t\t\t}\n    86→\t\t\treturn orch.TriggerAll(ctx), nil\n    87→\t\t})\n    88→\t}\n    89→\n    90→\tgrpcServer := grpc.NewServer()\n    91→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    92→\n    93→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    94→\n    95→\tlis, err := listen(listenAddr)\n    96→\tif err != nil {\n    97→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    98→\t\tos.Exit(1)\n    99→\t}\n   100→\n   101→\tvar httpServer *http.Server\n   102→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n   103→\t\twebOpts := []web.HandlerOption{\n   104→\t\t\tweb.WithContainerLogger(runtime),\n   105→\t\t\tweb.WithLogStore(store),\n   106→\t\t\tweb.WithLogBroadcaster(broadcaster),\n   107→\t\t}\n   108→\t\tif orch != nil {\n   109→\t\t\twebOpts = append(webOpts, web.WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   110→\t\t\t\treturn orch.Run(ctx, projectDir)\n   111→\t\t\t}))\n   112→\t\t\twebOpts = append(webOpts, web.WithOrchestrator(orch))\n   113→\t\t}\n   114→\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n   115→\t\tif err != nil {\n   116→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n   117→\t\t\tos.Exit(1)\n   118→\t\t}\n   119→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n   120→\t\tgo func() {\n   121→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   122→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   123→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   124→\t\t\t}\n   125→\t\t}()\n   126→\t}\n   127→\n   128→\tsigCh := make(chan os.Signal, 1)\n   129→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   130→\tgo func() {\n   131→\t\t<-sigCh\n   132→\t\tif httpServer != nil {\n   133→\t\t\thttpServer.Close()\n   134→\t\t}\n   135→\t\tgrpcServer.GracefulStop()\n   136→\t}()\n   137→\n   138→\t// Trigger orchestration on startup\n   139→\tif orch != nil {\n   140→\t\tgo func() {\n   141→\t\t\tn := orch.TriggerAll(context.Background())\n   142→\t\t\tif n > 0 {\n   143→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: orchestrator dispatched %d run(s)\\n\", n)\n   144→\t\t\t}\n   145→\t\t}()\n   146→\t}\n   147→\n   148→\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   149→\tif err := grpcServer.Serve(lis); err != nil {\n   150→\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   151→\t\tos.Exit(1)\n   152→\t}\n   153→}\n   154→\n   155→func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   156→\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   157→\n   158→\tswitch runtimeType {\n   159→\tcase \"local\":\n   160→\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   161→\t\tif agentPath == \"\" {\n   162→\t\t\t// Look for cloche-agent next to this binary\n   163→\t\t\texe, err := os.Executable()\n   164→\t\t\tif err == nil {\n   165→\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   166→\t\t\t} else {\n   167→\t\t\t\tagentPath = \"cloche-agent\"\n   168→\t\t\t}\n   169→\t\t}\n   170→\t\treturn local.NewRuntime(agentPath), nil\n   171→\tcase \"docker\":\n   172→\t\treturn docker.NewRuntime()\n   173→\tdefault:\n   174→\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   175→\t}\n   176→}\n   177→\n   178→func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   179→\t// Load config from working directory (daemon-level defaults)\n   180→\tcfg, err := config.Load(\".\")\n   181→\tif err != nil || !cfg.Evolution.Enabled {\n   182→\t\treturn nil\n   183→\t}\n   184→\n   185→\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   186→\tif llmCmd == \"\" {\n   187→\t\treturn nil\n   188→\t}\n   189→\n   190→\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   191→\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   192→\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   193→\t\t\t// Load per-project config for confidence threshold\n   194→\t\t\tprojCfg, err := config.Load(projectDir)\n   195→\t\t\tif err != nil {\n   196→\t\t\t\tprojCfg = cfg // fall back to daemon config\n   197→\t\t\t}\n   198→\n   199→\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   200→\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   201→\t\t\t\tProjectDir:    projectDir,\n   202→\t\t\t\tWorkflowName:  workflowName,\n   203→\t\t\t\tLLM:           llm,\n   204→\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   205→\t\t\t})\n   206→\n   207→\t\t\tctx := context.Background()\n   208→\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   209→\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   210→\t\t\t}\n   211→\t\t},\n   212→\t})\n   213→\n   214→\treturn trigger\n   215→}\n   216→\n   217→func listen(addr string) (net.Listener, error) {\n   218→\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   219→\t\tsockPath := addr[7:]\n   220→\t\tos.Remove(sockPath)\n   221→\t\treturn net.Listen(\"unix\", sockPath)\n   222→\t}\n   223→\treturn net.Listen(\"tcp\", addr)\n   224→}\n   225→\n   226→func initOrchestrator(globalCfg *config.Config, store ports.RunStore, srv *adaptgrpc.ClocheServer) *orchestrator.Orchestrator {\n   227→\tllmClient := orchestrator.NewCommandLLMClientFromEnv()\n   228→\tpromptGen := &orchestrator.LLMPromptGenerator{LLM: llmClient}\n   229→\n   230→\tdispatch := func(ctx context.Context, workflowName, projectDir, prompt string) (string, error) {\n   231→\t\tresp, err := srv.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   232→\t\t\tWorkflowName: workflowName,\n   233→\t\t\tProjectDir:   projectDir,\n   234→\t\t\tPrompt:       prompt,\n   235→\t\t})\n   236→\t\tif err != nil {\n   237→\t\t\treturn \"\", err\n   238→\t\t}\n   239→\t\treturn resp.RunId, nil\n   240→\t}\n   241→\n   242→\twaiter := &orchestrator.StoreRunWaiter{Store: store}\n   243→\thostRunner := &orchestrator.HostRunner{\n   244→\t\tDispatch: dispatch,\n   245→\t\tWaitRun:  waiter,\n   246→\t}\n   247→\n   248→\torch := orchestrator.New(promptGen, dispatch,\n   249→\t\torchestrator.WithHostRunner(hostRunner),\n   250→\t\torchestrator.WithParseHostWorkflow(dsl.Parse),\n   251→\t)\n   252→\n   253→\t// Collect candidate project directories: cwd + all known projects from the store.\n   254→\tcandidates := map[string]bool{}\n   255→\tif cwd, err := os.Getwd(); err == nil {\n   256→\t\tcandidates[cwd] = true\n   257→\t}\n   258→\tif projects, err := store.ListProjects(context.Background()); err == nil {\n   259→\t\tfor _, dir := range projects {\n   260→\t\t\tcandidates[dir] = true\n   261→\t\t}\n   262→\t}\n   263→\n   264→\t// Register every project that has orchestration enabled.\n   265→\tregistered := 0\n   266→\tfor dir := range candidates {\n   267→\t\tcfg, err := config.Load(dir)\n   268→\t\tif err != nil || !cfg.Orchestration.Enabled {\n   269→\t\t\tcontinue\n   270→\t\t}\n   271→\t\ttracker := beads.NewTracker(dir)\n   272→\t\torch.Register(&orchestrator.ProjectConfig{\n   273→\t\t\tDir:         dir,\n   274→\t\t\tWorkflow:    cfg.Orchestration.Workflow,\n   275→\t\t\tConcurrency: cfg.Orchestration.Concurrency,\n   276→\t\t\tTracker:     tracker,\n   277→\t\t\tEnabled:     true,\n   278→\t\t})\n   279→\t\tregistered++\n   280→\t}\n   281→\n   282→\tif registered == 0 {\n   283→\t\treturn nil\n   284→\t}\n   285→\treturn orch\n   286→}\n   287→\n   288→\n   289→// envOrConfig returns the env var value if set, otherwise the config file\n   290→// value if non-empty, otherwise the fallback default.\n   291→func envOrConfig(envKey, configVal, fallback string) string {\n   292→\tif v := os.Getenv(envKey); v != \"\" {\n   293→\t\treturn v\n   294→\t}\n   295→\tif configVal != \"\" {\n   296→\t\treturn configVal\n   297→\t}\n   298→\treturn fallback\n   299→}\n   300→"}]},"parent_tool_use_id":"toolu_01UrbVxAhg4J7XmRgi48FVn7","session_id":"be3855