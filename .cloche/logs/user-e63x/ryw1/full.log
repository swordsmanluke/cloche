tcase \"logs\":\n    61â†’\t\tcmdLogs(client, os.Args[2:])\n    62â†’\tcase \"poll\":\n    63â†’\t\tcmdPoll(client, os.Args[2:])\n    64â†’\tcase \"list\":\n    65â†’\t\tcmdList(ctx, client, os.Args[2:])\n    66â†’\tcase \"stop\":\n    67â†’\t\tcmdStop(ctx, client, os.Args[2:])\n    68â†’\tcase \"delete\":\n    69â†’\t\tcmdDelete(ctx, client, os.Args[2:])\n    70â†’\tcase \"orchestrate\":\n    71â†’\t\tcmdOrchestrate(ctx, client)\n    72â†’\tcase \"shutdown\":\n    73â†’\t\tcmdShutdown(ctx, client)\n    74â†’\tdefault:\n    75â†’\t\tusage()\n    76â†’\t\tos.Exit(1)\n    77â†’\t}\n    78â†’}\n    79â†’\n    80â†’func usage() {\n    81â†’\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n    82â†’\n    83â†’Commands:\n    84â†’  init [--workflow <name>] [--image <base>]  Initialize a Cloche project\n    85â†’  health                                   Show project health summary\n    86â†’  run --workflow <name> [--prompt \"...\"] [--keep-container]\n    87â†’                                             Launch a workflow run\n    88â†’  status <run-id>                            Check run status\n    89â†’  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n    90â†’                                             Show logs for a run\n    91â†’  poll <run-id>                              Wait for a run to finish\n    92â†’  list [--all]                                List runs (last hour by default)\n    93â†’  stop <run-id>                              Stop a running workflow\n    94â†’  delete <container-or-run-id>               Delete a retained container\n    95â†’  orchestrate                                Dispatch ready workflow runs\n    96â†’  shutdown                                   Shut down the daemon\n    97â†’`)\n    98â†’}\n    99â†’\n   100â†’func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   101â†’\tvar workflow, prompt string\n   102â†’\tvar keepContainer bool\n   103â†’\n   104â†’\tfor i := 0; i < len(args); i++ {\n   105â†’\t\tswitch args[i] {\n   106â†’\t\tcase \"--workflow\":\n   107â†’\t\t\tif i+1 < len(args) {\n   108â†’\t\t\t\ti++\n   109â†’\t\t\t\tworkflow = args[i]\n   110â†’\t\t\t}\n   111â†’\t\tcase \"--prompt\", \"-p\":\n   112â†’\t\t\tif i+1 < len(args) {\n   113â†’\t\t\t\ti++\n   114â†’\t\t\t\tprompt = args[i]\n   115â†’\t\t\t}\n   116â†’\t\tcase \"--keep-container\":\n   117â†’\t\t\tkeepContainer = true\n   118â†’\t\tdefault:\n   119â†’\t\t\t// Support bare positional arg as workflow name for backwards compat\n   120â†’\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   121â†’\t\t\t\tworkflow = args[i]\n   122â†’\t\t\t}\n   123â†’\t\t}\n   124â†’\t}\n   125â†’\n   126â†’\tif workflow == \"\" {\n   127â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"]\\n\")\n   128â†’\t\tos.Exit(1)\n   129â†’\t}\n   130â†’\n   131â†’\tcwd, _ := os.Getwd()\n   132â†’\n   133â†’\t// Resolve image from workflow file (soft failure â€” fall back to daemon default)\n   134â†’\tvar image string\n   135â†’\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   136â†’\tif data, err := os.ReadFile(wfPath); err == nil {\n   137â†’\t\tif wf, err := dsl.Parse(string(data)); err == nil {\n   138â†’\t\t\timage = wf.Config[\"container.image\"]\n   139â†’\t\t}\n   140â†’\t}\n   141â†’\n   142â†’\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   143â†’\t\tWorkflowName:  workflow,\n   144â†’\t\tProjectDir:    cwd,\n   145â†’\t\tImage:         image,\n   146â†’\t\tPrompt:        prompt,\n   147â†’\t\tKeepContainer: keepContainer,\n   148â†’\t})\n   149â†’\tif err != nil {\n   150â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   151â†’\t\tos.Exit(1)\n   152â†’\t}\n   153â†’\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   154â†’}\n   155â†’\n   156â†’func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   157â†’\tif len(args) < 1 {\n   158â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   159â†’\t\tos.Exit(1)\n   160â†’\t}\n   161â†’\n   162â†’\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   163â†’\tif err != nil {\n   164â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   165â†’\t\tos.Exit(1)\n   166â†’\t}\n   167â†’\n   168â†’\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   169â†’\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   170â†’\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   171â†’\tif resp.ContainerId != \"\" {\n   172â†’\t\tcid := resp.ContainerId\n   173â†’\t\tif len(cid) > 12 {\n   174â†’\t\t\tcid = cid[:12]\n   175â†’\t\t}\n   176â†’\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   177â†’\t}\n   178â†’\tif resp.ErrorMessage != \"\" {\n   179â†’\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   180â†’\t}\n   181â†’\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   182â†’\tfor _, exec := range resp.StepExecutions {\n   183â†’\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   184â†’\t}\n   185â†’}\n   186â†’\n   187â†’func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   188â†’\tvar all bool\n   189â†’\tfor _, arg := range args {\n   190â†’\t\tif arg == \"--all\" {\n   191â†’\t\t\tall = true\n   192â†’\t\t}\n   193â†’\t}\n   194â†’\n   195â†’\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n   196â†’\tif err != nil {\n   197â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   198â†’\t\tos.Exit(1)\n   199â†’\t}\n   200â†’\n   201â†’\tif len(resp.Runs) == 0 {\n   202â†’\t\tfmt.Println(\"No runs found.\")\n   203â†’\t\treturn\n   204â†’\t}\n   205â†’\n   206â†’\tfor _, run := range resp.Runs {\n   207â†’\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s\", run.RunId, run.WorkflowName, run.State)\n   208â†’\t\tif run.ContainerId != \"\" {\n   209â†’\t\t\tline += \"  \" + run.ContainerId\n   210â†’\t\t}\n   211â†’\t\tif run.ErrorMessage != \"\" {\n   212â†’\t\t\terrMsg := run.ErrorMessage\n   213â†’\t\t\tif len(errMsg) > 60 {\n   214â†’\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   215â†’\t\t\t}\n   216â†’\t\t\tline += \"  \" + errMsg\n   217â†’\t\t}\n   218â†’\t\tfmt.Println(line)\n   219â†’\t}\n   220â†’}\n   221â†’\n   222â†’func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   223â†’\tif len(args) < 1 {\n   224â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n   225â†’\t\tos.Exit(1)\n   226â†’\t}\n   227â†’\n   228â†’\tvar stepFilter, typeFilter string\n   229â†’\tvar follow bool\n   230â†’\trunID := args[0]\n   231â†’\n   232â†’\tfor i := 1; i < len(args); i++ {\n   233â†’\t\tswitch args[i] {\n   234â†’\t\tcase \"--step\":\n   235â†’\t\t\tif i+1 < len(args) {\n   236â†’\t\t\t\ti++\n   237â†’\t\t\t\tstepFilter = args[i]\n   238â†’\t\t\t}\n   239â†’\t\tcase \"--type\":\n   240â†’\t\t\tif i+1 < len(args) {\n   241â†’\t\t\t\ti++\n   242â†’\t\t\t\ttypeFilter = args[i]\n   243â†’\t\t\t}\n   244â†’\t\tcase \"--follow\", \"-f\":\n   245â†’\t\t\tfollow = true\n   246â†’\t\t}\n   247â†’\t}\n   248â†’\n   249â†’\tif follow {\n   250â†’\t\tcmdLogsFollow(runID)\n   251â†’\t\treturn\n   252â†’\t}\n   253â†’\n   254â†’\t// Use background context â€” log output can be large\n   255â†’\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n   256â†’\t\tRunId:    runID,\n   257â†’\t\tStepName: stepFilter,\n   258â†’\t\tLogType:  typeFilter,\n   259â†’\t})\n   260â†’\tif err != nil {\n   261â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   262â†’\t\tos.Exit(1)\n   263â†’\t}\n   264â†’\n   265â†’\tfor {\n   266â†’\t\tentry, err := stream.Recv()\n   267â†’\t\tif err != nil {\n   268â†’\t\t\tif errors.Is(err, io.EOF) {\n   269â†’\t\t\t\tbreak\n   270â†’\t\t\t}\n   271â†’\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   272â†’\t\t\tos.Exit(1)\n   273â†’\t\t}\n   274â†’\n   275â†’\t\tswitch entry.Type {\n   276â†’\t\tcase \"step_started\":\n   277â†’\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   278â†’\t\t\tif entry.Message != \"\" {\n   279â†’\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   280â†’\t\t\t}\n   281â†’\t\tcase \"step_completed\":\n   282â†’\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   283â†’\t\t\tif entry.Message != \"\" {\n   284â†’\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   285â†’\t\t\t}\n   286â†’\t\tcase \"run_completed\":\n   287â†’\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   288â†’\t\t\tif entry.Message != \"\" {\n   289â†’\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   290â†’\t\t\t}\n   291â†’\t\tcase \"full_log\":\n   292â†’\t\t\tfmt.Print(entry.Message)\n   293â†’\t\tdefault:\n   294â†’\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   295â†’\t\t\tif entry.StepName != \"\" {\n   296â†’\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   297â†’\t\t\t}\n   298â†’\t\t\tif entry.Message != \"\" {\n   299â†’\t\t\t\tfmt.Print(entry.Message)\n   300â†’\t\t\t}\n   301â†’\t\t}\n   302â†’\t}\n   303â†’}\n   304â†’\n   305â†’func cmdLogsFollow(runID string) {\n   306â†’\t// Determine HTTP address from env\n   307â†’\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   308â†’\tif httpAddr == \"\" {\n   309â†’\t\thttpAddr = \"localhost:8080\"\n   310â†’\t}\n   311â†’\t// Strip protocol prefix if present\n   312â†’\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   313â†’\n   314â†’\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n   315â†’\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n   316â†’\tif err != nil {\n   317â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   318â†’\t\tos.Exit(1)\n   319â†’\t}\n   320â†’\treq.Header.Set(\"Accept\", \"text/event-stream\")\n   321â†’\n   322â†’\tresp, err := http.DefaultClient.Do(req)\n   323â†’\tif err != nil {\n   324â†’\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n   325â†’\t\tos.Exit(1)\n   326â†’\t}\n   327â†’\tdefer resp.Body.Close()\n   328â†’\n   329â†’\tif resp.StatusCode != 200 {\n   330â†’\t\tbody, _ := io.ReadAll(resp.Body)\n   331â†’\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   332â†’\t\tos.Exit(1)\n   333â†’\t}\n   334â†’\n   335â†’\tscanner := bufio.NewScanner(resp.Body)\n   336â†’\tfor scanner.Scan() {\n   337â†’\t\tline := scanner.Text()\n   338â†’\t\tif strings.HasPrefix(line, \"event: done\") {\n   339â†’\t\t\tbreak\n   340â†’\t\t}\n   341â†’\t\tif !strings.HasPrefix(line, \"data: \") {\n   342â†’\t\t\tcontinue\n   343â†’\t\t}\n   344â†’\t\tdata := strings.TrimPrefix(line, \"data: \")\n   345â†’\n   346â†’\t\tvar entry struct {\n   347â†’\t\t\tTimestamp string `json:\"timestamp\"`\n   348â†’\t\t\tType      string `json:\"type\"`\n   349â†’\t\t\tContent   string `json:\"content\"`\n   350â†’\t\t}\n   351â†’\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n   352â†’\t\t\tcontinue\n   353â†’\t\t}\n   354â†’\n   355â†’\t\t// Color-code by type\n   356â†’\t\tswitch entry.Type {\n   357â†’\t\tcase \"status\":\n   358â†’\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   359â†’\t\tcase \"llm\":\n   360â†’\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   361â†’\t\tdefault:\n   362â†’\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n   363â†’\t\t}\n   364â†’\t}\n   365â†’}\n   366â†’\n   367â†’func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   368â†’\tif len(args) < 1 {\n   369â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   370â†’\t\tos.Exit(1)\n   371â†’\t}\n   372â†’\n   373â†’\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   374â†’\tif err != nil {\n   375â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   376â†’\t\tos.Exit(1)\n   377â†’\t}\n   378â†’\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   379â†’}\n   380â†’\n   381â†’func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   382â†’\tif len(args) < 1 {\n   383â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   384â†’\t\tos.Exit(1)\n   385â†’\t}\n   386â†’\n   387â†’\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   388â†’\tif err != nil {\n   389â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   390â†’\t\tos.Exit(1)\n   391â†’\t}\n   392â†’\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   393â†’}\n   394â†’\n   395â†’func cmdOrchestrate(ctx context.Context, client pb.ClocheServiceClient) {\n   396â†’\tcwd, _ := os.Getwd()\n   397â†’\tresp, err := client.Orchestrate(ctx, &pb.OrchestrateRequest{ProjectDir: cwd})\n   398â†’\tif err != nil {\n   399â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   400â†’\t\tos.Exit(1)\n   401â†’\t}\n   402â†’\tif resp.Dispatched == 0 {\n   403â†’\t\tfmt.Println(\"No ready work found.\")\n   404â†’\t} else {\n   405â†’\t\tfmt.Printf(\"Dispatched %d run(s).\\n\", resp.Dispatched)\n   406â†’\t}\n   407â†’}\n   408â†’\n   409â†’func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   410â†’\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   411â†’\tif err != nil {\n   412â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   413â†’\t\tos.Exit(1)\n   414â†’\t}\n   415â†’\tfmt.Println(\"Daemon shutting down.\")\n   416â†’}\n   417â†’"}]},"parent_tool_use_id":null,"session_id":"f8e7ea77-8cf0-445d-a2e2-1745f779a6ff","uuid":"1a784f77-6a4d-4f49-969d-2a54c12b2295","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"orchestrate\":\n\t\tcmdOrchestrate(ctx, client)\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client)\n\tdefault:\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n}\n\nfunc usage() {\n\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n\nCommands:\n  init [--workflow <name>] [--image <base>]  Initialize a Cloche project\n  health                                   Show project health summary\n  run --workflow <name> [--prompt \"...\"] [--keep-container]\n                                             Launch a workflow run\n  status <run-id>                            Check run status\n  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n                                             Show logs for a run\n  poll <run-id>                              Wait for a run to finish\n  list [--all]                                List runs (last hour by default)\n  stop <run-id>                              Stop a running workflow\n  delete <container-or-run-id>               Delete a retained container\n  orchestrate                                Dispatch ready workflow runs\n  shutdown                                   Shut down the daemon\n`)\n}\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure â€” fall back to daemon default)\n\tvar image string\n\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n\tif data, err := os.ReadFile(wfPath); err == nil {\n\t\tif wf, err := dsl.Parse(string(data)); err == nil {\n\t\t\timage = wf.Config[\"container.image\"]\n\t\t}\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t}\n\t}\n\n\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s\", run.RunId, run.WorkflowName, run.State)\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\t}\n\t}\n\n\tif follow {\n\t\tcmdLogsFollow(runID)\n\t\treturn\n\t}\n\n\t// Use background context â€” log output can be large\n\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(entry.Message)\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdLogsFollow(runID string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\t// Strip protocol prefix if present\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\treq.Header.Set(\"Accept\", \"text/event-stream\")\n\n\tresp, err := http.DefaultClient.Do(req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\tscanner := bufio.NewScanner(resp.Body)\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"event: done\") {\n\t\t\tbreak\n\t\t}\n\t\tif !strings.HasPrefix(line, \"data: \") {\n\t\t\tcontinue\n\t\t}\n\t\tdata := strings.TrimPrefix(line, \"data: \")\n\n\t\tvar entry struct {\n\t\t\tTimestamp string `json:\"timestamp\"`\n\t\t\tType      string `json:\"type\"`\n\t\t\tContent   string `json:\"content\"`\n\t\t}\n\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Color-code by type\n\t\tswitch entry.Type {\n\t\tcase \"status\":\n\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tcase \"llm\":\n\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tdefault:\n\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdOrchestrate(ctx context.Context, client pb.ClocheServiceClient) {\n\tcwd, _ := os.Getwd()\n\tresp, err := client.Orchestrate(ctx, &pb.OrchestrateRequest{ProjectDir: cwd})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif resp.Dispatched == 0 {\n\t\tfmt.Println(\"No ready work found.\")\n\t} else {\n\t\tfmt.Printf(\"Dispatched %d run(s).\\n\", resp.Dispatched)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n","numLines":417,"startLine":1,"totalLines":417}}}
