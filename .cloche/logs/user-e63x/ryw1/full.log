i]\n   107â†’\t\t\t}\n   108â†’\t\tcase \"--image\":\n   109â†’\t\t\tif i+1 < len(args) {\n   110â†’\t\t\t\ti++\n   111â†’\t\t\t\timage = args[i]\n   112â†’\t\t\t}\n   113â†’\t\t}\n   114â†’\t}\n   115â†’\n   116â†’\tclocheDir := \".cloche\"\n   117â†’\tworkflowFile := filepath.Join(clocheDir, workflow+\".cloche\")\n   118â†’\n   119â†’\t// Refuse to overwrite existing workflow\n   120â†’\tif _, err := os.Stat(workflowFile); err == nil {\n   121â†’\t\tfmt.Fprintf(os.Stderr, \"error: %s already exists\\n\", workflowFile)\n   122â†’\t\tos.Exit(1)\n   123â†’\t}\n   124â†’\n   125â†’\t// Create directories\n   126â†’\tfor _, dir := range []string{\n   127â†’\t\tclocheDir,\n   128â†’\t\tfilepath.Join(clocheDir, \"prompts\"),\n   129â†’\t\tfilepath.Join(clocheDir, \"overrides\"),\n   130â†’\t} {\n   131â†’\t\tif err := os.MkdirAll(dir, 0755); err != nil {\n   132â†’\t\t\tfmt.Fprintf(os.Stderr, \"error creating %s/: %v\\n\", dir, err)\n   133â†’\t\t\tos.Exit(1)\n   134â†’\t\t}\n   135â†’\t}\n   136â†’\n   137â†’\t// Write all files, skipping any that already exist\n   138â†’\tfiles := []struct{ path, content string }{\n   139â†’\t\t{workflowFile, fmt.Sprintf(workflowTemplate, workflow)},\n   140â†’\t\t{filepath.Join(clocheDir, \"Dockerfile\"), fmt.Sprintf(dockerfileTemplate, image)},\n   141â†’\t\t{filepath.Join(clocheDir, \"prompts\", \"implement.md\"), implementPrompt},\n   142â†’\t\t{filepath.Join(clocheDir, \"prompts\", \"fix.md\"), fixPrompt},\n   143â†’\t\t{filepath.Join(clocheDir, \"prompts\", \"update-docs.md\"), updateDocsPrompt},\n   144â†’\t}\n   145â†’\n   146â†’\tfor _, f := range files {\n   147â†’\t\tif _, err := os.Stat(f.path); err == nil {\n   148â†’\t\t\tfmt.Fprintf(os.Stderr, \"  skip %s (already exists)\\n\", f.path)\n   149â†’\t\t\tcontinue\n   150â†’\t\t}\n   151â†’\t\tif err := os.WriteFile(f.path, []byte(f.content), 0644); err != nil {\n   152â†’\t\t\tfmt.Fprintf(os.Stderr, \"error writing %s: %v\\n\", f.path, err)\n   153â†’\t\t\tos.Exit(1)\n   15