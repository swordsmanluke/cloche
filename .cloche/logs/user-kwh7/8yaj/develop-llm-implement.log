ster sets the log broadcaster for SSE streaming.\n    42→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    43→\treturn func(h *Handler) { h.logBroadcast = b }\n    44→}\n    45→\n    46→// WithLogStore sets the log store for indexed log file lookups.\n    47→func WithLogStore(ls ports.LogStore) HandlerOption {\n    48→\treturn func(h *Handler) { h.logStore = ls }\n    49→}\n    50→\n    51→// WithTaskProvider sets the task provider for querying orchestration loop task state.\n    52→func WithTaskProvider(tp TaskProvider) HandlerOption {\n    53→\treturn func(h *Handler) { h.taskProvider = tp }\n    54→}\n    55→\n    56→//go:embed templates/*.html static/*\n    57→var content embed.FS\n    58→\n    59→// Handler serves the web dashboard.\n    60→// ContainerLogger can retrieve logs from a container by ID.\n    61→type ContainerLogger interface {\n    62→\tLogs(ctx context.Context, containerID string) (string, error)\n    63→}\n    64→\n    65→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    66→type ContainerManager interface {\n    67→\tContainerLogger\n    68→\tStop(ctx context.Context, containerID string) error\n    69→\tRemove(ctx context.Context, containerID string) error\n    70→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    71→}\n    72→\n    73→// TaskEntry represents a task with its assignment state for external consumers.\n    74→type TaskEntry struct {\n    75→\tID          string            `json:\"id\"`\n    76→\tStatus      string            `json:\"status\"`\n    77→\tTitle       string            `json:\"title\"`\n    78→\tDescription string            `json:\"description,omitempty\"`\n    79→\tMetadata    map[string]string `json:\"metadata,omitempty\"`\n    80→\tAssigned    bool              `json:\"assigned\"`\n    81→\tAssignedAt  string            `json:\"assigned_at,omitempty\"`\n    82→\tRunID       string            `json:\"run_id,omitempty\"`\n    83→}\n    84→\n    85→// TaskProvider retrieves task pipeline state for a project's orchestration loop.\n    86→type TaskProvider interface {\n    87→\tGetLoopTasks(projectDir string) []TaskEntry\n    88→}\n    89→\n    90→type Handler struct {\n    91→\tstore        ports.RunStore\n    92→\tcaptures     ports.CaptureStore\n    93→\tlogStore     ports.LogStore\n    94→\tcontainer    ContainerLogger\n    95→\tlogBroadcast *logstream.Broadcaster\n    96→\ttaskProvider TaskProvider\n    97→\tpages        map[string]*template.Template\n    98→\tmux          *http.ServeMux\n    99→}\n   100→\n   101→// NewHandler creates a web dashboard handler.\n   102→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n   103→\tfuncMap := template.FuncMap{\n   104→\t\t\"stateColor\":       stateColor,\n   105→\t\t\"healthColor\":      healthColor,\n   106→\t\t\"formatTime\":       formatTime,\n   107→\t\t\"formatDuration\":   formatDuration,\n   108→\t\t\"formatRunTiming\":  formatRunTiming,\n   109→\t\t\"truncate\":         truncate,\n   110→\t\t\"shortContainerID\": shortContainerID,\n   111→\t}\n   112→\n   113→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   114→\tif err != nil {\n   115→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   116→\t}\n   117→\n   118→\tpages := map[string]*template.Template{}\n   119→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   120→\t\tclone, err := base.Clone()\n   121→\t\tif err != nil {\n   122→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   123→\t\t}\n   124→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   125→\t\tif err != nil {\n   126→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   127→\t\t}\n   128→\t\tpages[page] = clone\n   129→\t}\n   130→\n   131→\th := &Handler{\n   132→\t\tstore:    store,\n   133→\t\tcaptures: captures,\n   134→\t\tpages:    pages,\n   135→\t\tmux:      http.NewServeMux(),\n   136→\t}\n   137→\tfor _, opt := range opts {\n   138→\t\topt(h)\n   139→\t}\n   140→\n   141→\tstaticFS, err := fs.Sub(content, \"static\")\n   142→\tif err != nil {\n   143→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   144→\t}\n   145→\n   146→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   147→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   148→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   149→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   150→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   151→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   152→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   153→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   154→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   155→\th.mux.HandleFunc(\"POST /api/runs/{id}/stop\", h.handleAPIStopRun)\n   156→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   157→\th.mux.HandleFunc(\"DELETE /api/projects/{name}/containers\", h.handleAPIDeleteProjectContainers)\n   158→\th.mux.HandleFunc(\"DELETE /api/containers\", h.handleAPIDeleteAllContainers)\n   159→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   160→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   161→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   162→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   163→\th.mux.HandleFunc(\"GET /api/projects/{name}/tasks\", h.handleAPITasks)\n   164→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   165→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   166→\n   167→\treturn h, nil\n   168→}\n   169→\n   170→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   171→\th.mux.ServeHTTP(w, r)\n   172→}\n   173→\n   174→// --- HTML handlers ---\n   175→\n   176→// projectOverviewEntry holds data for a single project card on the landing page.\n   177→type projectOverviewEntry struct {\n   178→\tDir         string\n   179→\tLabel       string\n   180→\tHealth      domain.HealthResult\n   181→\tRecentRuns  []recentRunDot\n   182→\tActiveCount int\n   183→}\n   184→\n   185→// recentRunDot is a minimal representation of a run for the mini history display.\n   186→type recentRunDot struct {\n   187→\tID    string\n   188→\tState string\n   189→}\n   190→\n   191→const healthWindowSize = 10\n   192→\n   193→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   194→\tprojects, _ := h.store.ListProjects(r.Context())\n   195→\tlabels := projectLabels(projects)\n   196→\n   197→\tvar entries []projectOverviewEntry\n   198→\tfor _, dir := range projects {\n   199→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   200→\t\tif err != nil {\n   201→\t\t\tcontinue\n   202→\t\t}\n   203→\n   204→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   205→\t\trunValues := make([]domain.Run, len(runs))\n   206→\t\tfor i, rr := range runs {\n   207→\t\t\trunValues[i] = *rr\n   208→\t\t}\n   209→\n   210→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   211→\n   212→\t\t// Take the last N runs for the mini history (most recent first).\n   213→\t\tn := healthWindowSize\n   214→\t\tif n > len(runs) {\n   215→\t\t\tn = len(runs)\n   216→\t\t}\n   217→\t\tdots := make([]recentRunDot, n)\n   218→\t\tfor i := 0; i < n; i++ {\n   219→\t\t\tdots[i] = recentRunDot{\n   220→\t\t\t\tID:    runs[i].ID,\n   221→\t\t\t\tState: string(runs[i].State),\n   222→\t\t\t}\n   223→\t\t}\n   224→\n   225→\t\tvar activeCount int\n   226→\t\tfor _, rr := range runs {\n   227→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   228→\t\t\t\tactiveCount++\n   229→\t\t\t}\n   230→\t\t}\n   231→\n   232→\t\tentries = append(entries, projectOverviewEntry{\n   233→\t\t\tDir:         dir,\n   234→\t\t\tLabel:       labels[dir],\n   235→\t\t\tHealth:      health,\n   236→\t\t\tRecentRuns:  dots,\n   237→\t\t\tActiveCount: activeCount,\n   238→\t\t})\n   239→\t}\n   240→\n   241→\tsort.Slice(entries, func(i, j int) bool {\n   242→\t\treturn entries[i].Label < entries[j].Label\n   243→\t})\n   244→\n   245→\tdata := map[string]any{\n   246→\t\t\"Title\":    \"Projects\",\n   247→\t\t\"Projects\": entries,\n   248→\t}\n   249→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   250→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   251→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   252→\t}\n   253→}\n   254→\n   255→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   256→\tprojectFilter := r.URL.Query().Get(\"project\")\n   257→\n   258→\tvar runs []*domain.Run\n   259→\tvar err error\n   260→\tif projectFilter != \"\" {\n   261→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   262→\t} else {\n   263→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   264→\t}\n   265→\tif err != nil {\n   266→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   267→\t\treturn\n   268→\t}\n   269→\n   270→\tprojects, _ := h.store.ListProjects(r.Context())\n   271→\tlabels := projectLabels(projects)\n   272→\n   273→\t// Count retained containers per project\n   274→\tcontainerCounts := map[string]int{}\n   275→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   276→\tfor _, run := range allRuns {\n   277→\t\tif run.ContainerKept {\n   278→\t\t\tcontainerCounts[run.ProjectDir]++\n   279→\t\t}\n   280→\t}\n   281→\n   282→\tvar projectList []projectEntry\n   283→\tfor _, dir := range projects {\n   284→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   285→\t}\n   286→\tsort.Slice(projectList, func(i, j int) bool {\n   287→\t\treturn projectList[i].Label < projectList[j].Label\n   288→\t})\n   289→\n   290→\tvar totalContainerCount int\n   291→\tfor _, c := range containerCounts {\n   292→\t\ttotalContainerCount += c\n   293→\t}\n   294→\n   295→\tdata := map[string]any{\n   296→\t\t\"Title\":               \"Runs\",\n   297→\t\t\"Runs\":                runs,\n   298→\t\t\"Projects\":            projectList,\n   299→\t\t\"ProjectFilter\":       projectFilter,\n   300→\t\t\"ProjectLabels\":       labels,\n   301→\t\t\"TotalContainerCount\": totalContainerCount,\n   302→\t}\n   303→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   304→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   305→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   306→\t}\n   307→}\n   308→\n   309→// handleProjectRuns redirects /projects/{name}/runs to /runs?project=<dir>.\n   310→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   311→\tdir, _, ok := h.resolveProjectDir(w, r)\n   312→\tif !ok {\n   313→\t\treturn\n   314→\t}\n   315→\thttp.Redirect(w, r, \"/runs?project=\"+url.QueryEscape(dir), http.StatusFound)\n   316→}\n   317→\n   318→// stepEntry is a merged view of a step execution for the template.\n   319→type stepEntry struct {\n   320→\tIndex     int\n   321→\tStepName  string\n   322→\tResult    string\n   323→\tStartedAt time.Time\n   324→\tDuration  string\n   325→}\n   326→\n   327→// mergeCaptures collapses started/completed capture pairs into single entries.\n   328→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   329→\tvar entries []stepEntry\n   330→\t// Track pending started rows by step name (LIFO for retries)\n   331→\tpending := map[string]*domain.StepExecution{}\n   332→\n   333→\tfor _, c := range caps {\n   334→\t\tif c.Result == \"\" {\n   335→\t\t\t// step_started row\n   336→\t\t\tpending[c.StepName] = c\n   337→\t\t\tcontinue\n   338→\t\t}\n   339→\t\t// step_completed row — merge with pending started if available\n   340→\t\tstartedAt := c.StartedAt\n   341→\t\tif started := pending[c.StepName]; started != nil {\n   342→\t\t\tstartedAt = started.StartedAt\n   343→\t\t\tdelete(pending, c.StepName)\n   344→\t\t}\n   345→\t\tentries = append(entries, stepEntry{\n   346→\t\t\tIndex:     len(entries),\n   347→\t\t\tStepName:  c.StepName,\n   348→\t\t\tResult:    c.Result,\n   349→\t\t\tStartedAt: startedAt,\n   350→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   351→\t\t})\n   352→\t}\n   353→\n   354→\t// Append any started-but-not-completed steps (still running)\n   355→\tfor _, c := range caps {\n   356→\t\tif c.Result == \"\" {\n   357→\t\t\tif _, used := pending[c.StepName]; !used {\n   358→\t\t\t\tcontinue\n   359→\t\t\t}\n   360→\t\t\tentries = append(entries, stepEntry{\n   361→\t\t\t\tIndex:     len(entries),\n   362→\t\t\t\tStepName:  c.StepName,\n   363→\t\t\t\tStartedAt: c.StartedAt,\n   364→\t\t\t})\n   365→\t\t\tdelete(pending, c.StepName)\n   366→\t\t}\n   367→\t}\n   368→\n   369→\treturn entries\n   370→}\n   371→\n   372→// containerState inspects the container for a run and returns one of:\n   373→//   - \"running\"   – container exists and is running\n   374→//   - \"stopped\"   – container exists, not running, not kept\n   375→//   - \"available\" – container exists, not running, kept (can be deleted)\n   376→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   377→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   378→\tif run.ContainerID == \"\" {\n   379→\t\treturn \"removed\"\n   380→\t}\n   381→\tmgr, ok := h.container.(ContainerManager)\n   382→\tif !ok {\n   383→\t\treturn \"removed\"\n   384→\t}\n   385→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   386→\tif err != nil {\n   387→\t\treturn \"removed\"\n   388→\t}\n   389→\tif status.Running {\n   390→\t\treturn \"running\"\n   391→\t}\n   392→\tif run.ContainerKept {\n   393→\t\treturn \"available\"\n   394→\t}\n   395→\treturn \"stopped\"\n   396→}\n   397→\n   398→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   399→\tid := r.PathValue(\"id\")\n   400→\n   401→\trun, err := h.store.GetRun(r.Context(), id)\n   402→\tif err != nil {\n   403→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   404→\t\treturn\n   405→\t}\n   406→\n   407→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   408→\tif err != nil {\n   409→\t\tcaps = nil // non-fatal\n   410→\t}\n   411→\n   412→\tsteps := mergeCaptures(caps)\n   413→\n   414→\t// Fetch parent run if this is a child\n   415→\tvar parentRun *domain.Run\n   416→\tif run.ParentRunID != \"\" {\n   417→\t\tparentRun, _ = h.store.GetRun(r.Context(), run.ParentRunID)\n   418→\t}\n   419→\n   420→\t// Fetch child runs\n   421→\tchildRuns, _ := h.store.ListChildRuns(r.Context(), id)\n   422→\n   423→\tdata := map[string]any{\n   424→\t\t\"Title\":          \"Run \" + run.ID,\n   425→\t\t\"Run\":            run,\n   426→\t\t\"Steps\":          steps,\n   427→\t\t\"Page\":           \"detail\",\n   428→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   429→\t\t\"ParentRun\":      parentRun,\n   430→\t\t\"ChildRuns\":      childRuns,\n   431→\t}\n   432→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   433→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   434→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   435→\t}\n   436→}\n   437→\n   438→// --- JSON API handlers ---\n   439→\n   440→type apiRun struct {\n   441→\tID           string `json:\"id\"`\n   442→\tWorkflowName string `json:\"workflow_name\"`\n   443→\tProjectDir   string `json:\"project_dir\"`\n   444→\tProjectLabel string `json:\"project_label\"`\n   445→\tState        string `json:\"state\"`\n   446→\tStartedAt    string `json:\"started_at\"`\n   447→\tCompletedAt  string `json:\"completed_at\"`\n   448→\tTiming       string `json:\"timing\"`\n   449→\tContainerID  string `json:\"container_id\"`\n   450→\tErrorMessage string `json:\"error_message\"`\n   451→\tTitle        string `json:\"title\"`\n   452→\tIsHost       bool   `json:\"is_host\"`\n   453→\tParentRunID  string `json:\"parent_run_id,omitempty\"`\n   454→}\n   455→\n   456→type apiStep struct {\n   457→\tStepName    string `json:\"step_name\"`\n   458→\tResult      string `json:\"result\"`\n   459→\tStartedAt   string `json:\"started_at\"`\n   460→\tCompletedAt string `json:\"completed_at\"`\n   461→\tDuration    string `json:\"duration\"`\n   462→}\n   463→\n   464→type apiRunDetail struct {\n   465→\tapiRun\n   466→\tContainerState string    `json:\"container_state\"`\n   467→\tSteps          []apiStep `json:\"steps\"`\n   468→\tChildRuns      []apiRun  `json:\"child_runs,omitempty\"`\n   469→}\n   470→\n   471→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   472→\treturn apiRun{\n   473→\t\tID:           r.ID,\n   474→\t\tWorkflowName: r.WorkflowName,\n   475→\t\tProjectDir:   r.ProjectDir,\n   476→\t\tProjectLabel: labels[r.ProjectDir],\n   477→\t\tState:        string(r.State),\n   478→\t\tStartedAt:    formatTime(r.StartedAt),\n   479→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   480→\t\tTiming:       formatRunTiming(r.State, r.StartedAt, r.CompletedAt),\n   481→\t\tContainerID:  r.ContainerID,\n   482→\t\tErrorMessage: r.ErrorMessage,\n   483→\t\tTitle:        r.Title,\n   484→\t\tIsHost:       r.IsHost,\n   485→\t\tParentRunID:  r.ParentRunID,\n   486→\t}\n   487→}\n   488→\n   489→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   490→\tprojectFilter := r.URL.Query().Get(\"project\")\n   491→\n   492→\tvar runs []*domain.Run\n   493→\tvar err error\n   494→\tif projectFilter != \"\" {\n   495→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   496→\t} else {\n   497→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   498→\t}\n   499→\tif err != nil {\n   500→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   501→\t\treturn\n   502→\t}\n   503→\n   504→\tprojects, _ := h.store.ListProjects(r.Context())\n   505→\tlabels := projectLabels(projects)\n   506→\n   507→\tresult := make([]apiRun, len(runs))\n   508→\tfor i, run := range runs {\n   509→\t\tresult[i] = toAPIRun(run, labels)\n   510→\t}\n   511→\n   512→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   513→\tjson.NewEncoder(w).Encode(result)\n   514→}\n   515→\n   516→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   517→\tprojects, err := h.store.ListProjects(r.Context())\n   518→\tif err != nil {\n   519→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   520→\t\treturn\n   521→\t}\n   522→\tlabels := projectLabels(projects)\n   523→\n   524→\ttype apiHealth struct {\n   525→\t\tStatus string `json:\"status\"`\n   526→\t\tPassed int    `json:\"passed\"`\n   527→\t\tFailed int    `json:\"failed\"`\n   528→\t\tTotal  int    `json:\"total\"`\n   529→\t}\n   530→\ttype apiProject struct {\n   531→\t\tDir         string    `json:\"dir\"`\n   532→\t\tLabel       string    `json:\"label\"`\n   533→\t\tHealth      apiHealth `json:\"health\"`\n   534→\t\tActiveCount int       `json:\"active_count\"`\n   535→\t}\n   536→\tresult := make([]apiProject, len(projects))\n   537→\tfor i, dir := range projects {\n   538→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   539→\t\trunValues := make([]domain.Run, len(runs))\n   540→\t\tfor j, rr := range runs {\n   541→\t\t\trunValues[j] = *rr\n   542→\t\t}\n   543→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   544→\t\tvar activeCount int\n   545→\t\tfor _, rr := range runs {\n   546→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   547→\t\t\t\tactiveCount++\n   548→\t\t\t}\n   549→\t\t}\n   550→\t\tresult[i] = apiProject{\n   551→\t\t\tDir:   dir,\n   552→\t\t\tLabel: labels[dir],\n   553→\t\t\tHealth: apiHealth{\n   554→\t\t\t\tStatus: string(health.Status),\n   555→\t\t\t\tPassed: health.Passed,\n   556→\t\t\t\tFailed: health.Failed,\n   557→\t\t\t\tTotal:  health.Total,\n   558→\t\t\t},\n   559→\t\t\tActiveCount: activeCount,\n   560→\t\t}\n   561→\t}\n   562→\n   563→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   564→\tjson.NewEncoder(w).Encode(result)\n   565→}\n   566→\n   567→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   568→\tid := r.PathValue(\"id\")\n   569→\n   570→\trun, err := h.store.GetRun(r.Context(), id)\n   571→\tif err != nil {\n   572→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   573→\t\treturn\n   574→\t}\n   575→\n   576→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   577→\tif err != nil {\n   578→\t\tcaps = nil\n   579→\t}\n   580→\n   581→\tprojects, _ := h.store.ListProjects(r.Context())\n   582→\tlabels := projectLabels(projects)\n   583→\n   584→\tmerged := mergeCaptures(caps)\n   585→\tsteps := make([]apiStep, len(merged))\n   586→\tfor i, e := range merged {\n   587→\t\tsteps[i] = apiStep{\n   588→\t\t\tStepName:  e.StepName,\n   589→\t\t\tResult:    e.Result,\n   590→\t\t\tStartedAt: formatTime(e.StartedAt),\n   591→\t\t\tDuration:  e.Duration,\n   592→\t\t}\n   593→\t}\n   594→\n   595→\t// Fetch child runs for the API response\n   596→\tvar apiChildren []apiRun\n   597→\tif children, err := h.store.ListChildRuns(r.Context(), id); err == nil {\n   598→\t\tfor _, c := range children {\n   599→\t\t\tapiChildren = append(apiChildren, toAPIRun(c, labels))\n   600→\t\t}\n   601→\t}\n   602→\n   603→\tdetail := apiRunDetail{\n   604→\t\tapiRun:         toAPIRun(run, labels),\n   605→\t\tContainerState: h.containerState(r.Context(), run),\n   606→\t\tSteps:          steps,\n   607→\t\tChildRuns:      apiChildren,\n   608→\t}\n   609→\n   610→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   611→\tjson.NewEncoder(w).Encode(detail)\n   612→}\n   613→\n   614→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   615→\tid := r.PathValue(\"id\")\n   616→\tstep := r.PathValue(\"step\")\n   617→\tlogType := r.URL.Query().Get(\"type\")   // optional: \"script\", \"llm\"\n   618→\tformat := r.URL.Query().Get(\"format\")  // optional: \"raw\" to skip parsing\n   619→\n   620→\trun, err := h.store.GetRun(r.Context(), id)\n   621→\tif err != nil {\n   622→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   623→\t\treturn\n   624→\t}\n   625→\n   626→\twriteOutput := func(data []byte) {\n   627→\t\tif format != \"raw\" {\n   628→\t\t\tdata = logstream.ParseClaudeStream(data)\n   629→\t\t}\n   630→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   631→\t\tw.Write(data)\n   632→\t}\n   633→\n   634→\t// Try log index first for fast lookup\n   635→\tif h.logStore != nil {\n   636→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   637→\t\tif err == nil && len(logFiles) > 0 {\n   638→\t\t\t// If type filter specified, narrow results\n   639→\t\t\tfor _, lf := range logFiles {\n   640→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   641→\t\t\t\t\tcontinue\n   642→\t\t\t\t}\n   643→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   644→\t\t\t\tif readErr == nil && len(data) > 0 {\n   645→\t\t\t\t\twriteOutput(data)\n   646→\t\t\t\t\treturn\n   647→\t\t\t\t}\n   648→\t\t\t}\n   649→\t\t}\n   650→\t}\n   651→\n   652→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   653→\n   654→\t// Fall back to file path conventions\n   655→\t// If type is \"llm\", try llm-<step>.log\n   656→\tif logType == \"llm\" {\n   657→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   658→\t\tdata, err := os.ReadFile(llmPath)\n   659→\t\tif err == nil && len(data) > 0 {\n   660→\t\t\twriteOutput(data)\n   661→\t\t\treturn\n   662→\t\t}\n   663→\t}\n   664→\n   665→\t// Try per-step output file\n   666→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   667→\tdata, err := os.ReadFile(outputPath)\n   668→\tif err == nil && len(data) > 0 {\n   669→\t\twriteOutput(data)\n   670→\t\treturn\n   671→\t}\n   672→\n   673→\t// Do NOT fall back to container.log or live docker logs here — those\n   674→\t// contain unfiltered output from ALL steps and would show the wrong\n   675→\t// content for this specific step (the root cause of web-UI log mismatches).\n   676→\n   677→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   678→}\n   679→\n   680→func (h *Handler) handleAPIStopRun(w http.ResponseWriter, r *http.Request) {\n   681→\tid := r.PathValue(\"id\")\n   682→\n   683→\trun, err := h.store.GetRun(r.Context(), id)\n   684→\tif err != nil {\n   685→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   686→\t\tw.WriteHeader(http.StatusNotFound)\n   687→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   688→\t\treturn\n   689→\t}\n   690→\n   691→\t// Only allow stopping active runs\n   692→\tif run.State != domain.RunStatePending && run.State != domain.RunStateRunning {\n   693→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   694→\t\tw.WriteHeader(http.StatusBadRequest)\n   695→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run is not active\"})\n   696→\t\treturn\n   697→\t}\n   698→\n   699→\tmgr, ok := h.container.(ContainerManager)\n   700→\tif !ok || run.ContainerID == \"\" {\n   701→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   702→\t\tw.WriteHeader(http.StatusBadRequest)\n   703→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   704→\t\treturn\n   705→\t}\n   706→\n   707→\tif err := mgr.Stop(r.Context(), run.ContainerID); err != nil {\n   708→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   709→\t\tw.WriteHeader(http.StatusInternalServerError)\n   710→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to stop run: %v\", err)})\n   711→\t\treturn\n   712→\t}\n   713→\n   714→\trun.Complete(domain.RunStateCancelled)\n   715→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   716→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   717→\t\tw.WriteHeader(http.StatusInternalServerError)\n   718→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   719→\t\treturn\n   720→\t}\n   721→\n   722→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   723→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   724→}\n   725→\n   726→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   727→\tid := r.PathValue(\"id\")\n   728→\n   729→\trun, err := h.store.GetRun(r.Context(), id)\n   730→\tif err != nil {\n   731→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   732→\t\tw.WriteHeader(http.StatusNotFound)\n   733→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   734→\t\treturn\n   735→\t}\n   736→\n   737→\tmgr, ok := h.container.(ContainerManager)\n   738→\tif !ok || run.ContainerID == \"\" {\n   739→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   740→\t\tw.WriteHeader(http.StatusBadRequest)\n   741→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   742→\t\treturn\n   743→\t}\n   744→\n   745→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   746→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   747→\t\tw.WriteHeader(http.StatusInternalServerError)\n   748→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   749→\t\treturn\n   750→\t}\n   751→\n   752→\trun.ContainerKept = false\n   753→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   754→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   755→\t\tw.WriteHeader(http.StatusInternalServerError)\n   756→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   757→\t\treturn\n   758→\t}\n   759→\n   760→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   761→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   762→}\n   763→\n   764→// handleAPIDeleteProjectContainers mass-deletes all retained/exited containers for a project.\n   765→func (h *Handler) handleAPIDeleteProjectContainers(w http.ResponseWriter, r *http.Request) {\n   766→\tdir, _, ok := h.resolveProjectDir(w, r)\n   767→\tif !ok {\n   768→\t\treturn\n   769→\t}\n   770→\n   771→\tmgr, ok := h.container.(ContainerManager)\n   772→\tif !ok {\n   773→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   774→\t\tw.WriteHeader(http.StatusBadRequest)\n   775→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   776→\t\treturn\n   777→\t}\n   778→\n   779→\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   780→\tif err != nil {\n   781→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   782→\t\tw.WriteHeader(http.StatusInternalServerError)\n   783→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"failed to list runs\"})\n   784→\t\treturn\n   785→\t}\n   786→\n   787→\tvar deleted int\n   788→\tvar errors []string\n   789→\tfor _, run := range runs {\n   790→\t\tif !run.ContainerKept || run.ContainerID == \"\" {\n   791→\t\t\tcontinue\n   792→\t\t}\n   793→\t\t// Check container is not running\n   794→\t\tstatus, err := mgr.Inspect(r.Context(), run.ContainerID)\n   795→\t\tif err != nil {\n   796→\t\t\t// Container already gone — just clear the flag\n   797→\t\t\trun.ContainerKept = false\n   798→\t\t\th.store.UpdateRun(r.Context(), run)\n   799→\t\t\tdeleted++\n   800→\t\t\tcontinue\n   801→\t\t}\n   802→\t\tif status.Running {\n   803→\t\t\tcontinue // skip running containers\n   804→\t\t}\n   805→\t\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   806→\t\t\terrors = append(errors, fmt.Sprintf(\"%s: %v\", run.ID, err))\n   807→\t\t\tcontinue\n   808→\t\t}\n   809→\t\trun.ContainerKept = false\n   810→\t\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   811→\t\t\terrors = append(errors, fmt.Sprintf(\"%s: update failed: %v\", run.ID, err))\n   812→\t\t\tcontinue\n   813→\t\t}\n   814→\t\tdeleted++\n   815→\t}\n   816→\n   817→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   818→\tresp := map[string]any{\"deleted\": deleted}\n   819→\tif len(errors) > 0 {\n   820→\t\tresp[\"errors\"] = errors\n   821→\t}\n   822→\tjson.NewEncoder(w).Encode(resp)\n   823→}\n   824→\n   825→// handleAPIDeleteAllContainers mass-deletes all retained/exited containers across all projects.\n   826→func (h *Handler) handleAPIDeleteAllContainers(w http.ResponseWriter, r *http.Request) {\n   827→\tmgr, ok := h.container.(ContainerManager)\n   828→\tif !ok {\n   829→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   830→\t\tw.WriteHeader(http.StatusBadRequest)\n   831→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   832→\t\treturn\n   833→\t}\n   834→\n   835→\truns, err := h.store.ListRuns(r.Context(), time.Time{})\n   836→\tif err != nil {\n   837→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   838→\t\tw.WriteHeader(http.StatusInternalServerError)\n   839→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"failed to list runs\"})\n   840→\t\treturn\n   841→\t}\n   842→\n   843→\tvar deleted int\n   844→\tvar errors []string\n   845→\tfor _, run := range runs {\n   846→\t\tif !run.ContainerKept || run.ContainerID == \"\" {\n   847→\t\t\tcontinue\n   848→\t\t}\n   849→\t\t// Check container is not running\n   850→\t\tstatus, err := mgr.Inspect(r.Context(), run.ContainerID)\n   851→\t\tif err != nil {\n   852→\t\t\t// Container already gone — just clear the flag\n   853→\t\t\trun.ContainerKept = false\n   854→\t\t\th.store.UpdateRun(r.Context(), run)\n   855→\t\t\tdeleted++\n   856→\t\t\tcontinue\n   857→\t\t}\n   858→\t\tif status.Running {\n   859→\t\t\tcontinue // skip running containers\n   860→\t\t}\n   861→\t\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   862→\t\t\terrors = append(errors, fmt.Sprintf(\"%s: %v\", run.ID, err))\n   863→\t\t\tcontinue\n   864→\t\t}\n   865→\t\trun.ContainerKept = false\n   866→\t\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   867→\t\t\terrors = append(errors, fmt.Sprintf(\"%s: update failed: %v\", run.ID, err))\n   868→\t\t\tcontinue\n   869→\t\t}\n   870→\t\tdeleted++\n   871→\t}\n   872→\n   873→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   874→\tresp := map[string]any{\"deleted\": deleted}\n   875→\tif len(errors) > 0 {\n   876→\t\tresp[\"errors\"] = errors\n   877→\t}\n   878→\tjson.NewEncoder(w).Encode(resp)\n   879→}\n   880→\n   881→// handleAPIStream serves an SSE stream of log lines for a run.\n   882→// For active runs, it subscribes to the live broadcaster.\n   883→// For completed runs, it serves the archived full.log then closes.\n   884→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   885→\tid := r.PathValue(\"id\")\n   886→\n   887→\trun, err := h.store.GetRun(r.Context(), id)\n   888→\tif err != nil {\n   889→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   890→\t\treturn\n   891→\t}\n   892→\n   893→\tflusher, ok := w.(http.Flusher)\n   894→\tif !ok {\n   895→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   896→\t\treturn\n   897→\t}\n   898→\n   899→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   900→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   901→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   902→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   903→\n   904→\tisComplete := run.State == domain.RunStateSucceeded ||\n   905→\t\trun.State == domain.RunStateFailed ||\n   906→\t\trun.State == domain.RunStateCancelled\n   907→\n   908→\tif isComplete {\n   909→\t\t// Serve archived full.log\n   910→\t\th.streamFullLog(w, flusher, run)\n   911→\t\t// Send done event\n   912→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   913→\t\tflusher.Flush()\n   914→\t\treturn\n   915→\t}\n   916→\n   917→\t// Active run: subscribe to live broadcaster\n   918→\tif h.logBroadcast == nil {\n   919→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   920→\t\treturn\n   921→\t}\n   922→\n   923→\tsub := h.logBroadcast.Subscribe(id)\n   924→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   925→\n   926→\tctx := r.Context()\n   927→\tfor {\n   928→\t\tselect {\n   929→\t\tcase <-ctx.Done():\n   930→\t\t\treturn\n   931→\t\tcase line, ok := <-sub.C:\n   932→\t\t\tif !ok {\n   933→\t\t\t\t// Stream finished (run completed)\n   934→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   935→\t\t\t\tflusher.Flush()\n   936→\t\t\t\treturn\n   937→\t\t\t}\n   938→\t\t\tline = parseLLMLogLine(line)\n   939→\t\t\tif line.Type == \"\" {\n   940→\t\t\t\tcontinue // skip protocol-only llm lines\n   941→\t\t\t}\n   942→\t\t\tdata, _ := json.Marshal(line)\n   943→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   944→\t\t\tflusher.Flush()\n   945→\t\t}\n   946→\t}\n   947→}\n   948→\n   949→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   950→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   951→\n   952→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   953→// LLM-type lines are parsed from raw Claude JSON into human-readable text.\n   954→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   955→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   956→\tf, err := os.Open(logPath)\n   957→\tif err != nil {\n   958→\t\treturn\n   959→\t}\n   960→\tdefer f.Close()\n   961→\n   962→\tscanner := bufio.NewScanner(f)\n   963→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large Claude JSON lines\n   964→\tfor scanner.Scan() {\n   965→\t\ttext := scanner.Text()\n   966→\t\tline := parseFullLogLine(text)\n   967→\t\tline = parseLLMLogLine(line)\n   968→\t\tif line.Type == \"\" {\n   969→\t\t\tcontinue // skip protocol-only llm lines\n   970→\t\t}\n   971→\t\tdata, _ := json.Marshal(line)\n   972→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   973→\t\tflusher.Flush()\n   974→\t}\n   975→}\n   976→\n   977→// parseLLMLogLine parses a LogLine whose type is \"llm\". If the content is\n   978→// Claude stream JSON, it extracts the human-readable text. Protocol-only\n   979→// events return a LogLine with an empty Type (caller should skip it).\n   980→// Non-llm lines are returned unchanged.\n   981→func parseLLMLogLine(line logstream.LogLine) logstream.LogLine {\n   982→\tif line.Type != \"llm\" {\n   983→\t\treturn line\n   984→\t}\n   985→\ttext, ok := logstream.ParseClaudeLine([]byte(line.Content))\n   986→\tif !ok {\n   987→\t\treturn logstream.LogLine{} // signal to skip\n   988→\t}\n   989→\tline.Content = text\n   990→\treturn line\n   991→}\n   992→\n   993→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   994→func parseFullLogLine(text string) logstream.LogLine {\n   995→\tm := logLineRegex.FindStringSubmatch(text)\n   996→\tif m == nil {\n   997→\t\treturn logstream.LogLine{\n   998→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   999→\t\t\tType:      \"script\",\n  1000→\t\t\tContent:   text,\n  1001→\t\t}\n  1002→\t}\n  1003→\treturn logstream.LogLine{\n  1004→\t\tTimestamp: m[1],\n  1005→\t\tType:      m[2],\n  1006→\t\tContent:   m[3],\n  1007→\t}\n  1008→}\n  1009→\n  1010→// --- Project detail handlers ---\n  1011→\n  1012→// resolveProjectDir resolves a project label from the URL to its directory path.\n  1013→// Returns (dir, label, ok). Writes a JSON error response if not found.\n  1014→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n  1015→\tlabel := r.PathValue(\"name\")\n  1016→\tprojects, _ := h.store.ListProjects(r.Context())\n  1017→\tlabels := projectLabels(projects)\n  1018→\tfor dir, l := range labels {\n  1019→\t\tif l == label {\n  1020→\t\t\treturn dir, label, true\n  1021→\t\t}\n  1022→\t}\n  1023→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1024→\tw.WriteHeader(http.StatusNotFound)\n  1025→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n  1026→\treturn \"\", \"\", false\n  1027→}\n  1028→\n  1029→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n  1030→\tdir, label, ok := h.resolveProjectDir(w, r)\n  1031→\tif !ok {\n  1032→\t\treturn\n  1033→\t}\n  1034→\n  1035→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n  1036→\tn := 10\n  1037→\tif n > len(runs) {\n  1038→\t\tn = len(runs)\n  1039→\t}\n  1040→\tdots := make([]recentRunDot, n)\n  1041→\tfor i := 0; i < n; i++ {\n  1042→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n  1043→\t}\n  1044→\n  1045→\tvar containerCount int\n  1046→\tfor _, run := range runs {\n  1047→\t\tif run.ContainerKept {\n  1048→\t\t\tcontainerCount++\n  1049→\t\t}\n  1050→\t}\n  1051→\n  1052→\tdata := map[string]any{\n  1053→\t\t\"Title\":          label,\n  1054→\t\t\"Label\":          label,\n  1055→\t\t\"Dir\":            dir,\n  1056→\t\t\"RecentRuns\":     dots,\n  1057→\t\t\"ContainerCount\": containerCount,\n  1058→\t}\n  1059→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n  1060→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n  1061→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n  1062→\t}\n  1063→}\n  1064→\n  1065→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n  1066→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1067→\tif !ok {\n  1068→\t\treturn\n  1069→\t}\n  1070→\n  1071→\t// Docker image: read FROM line from Dockerfile\n  1072→\tdockerImage := \"\"\n  1073→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n  1074→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n  1075→\t\t// Find the last FROM line (final stage)\n  1076→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n  1077→\t\t\ttrimmed := strings.TrimSpace(line)\n  1078→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n  1079→\t\t\t\tparts := strings.Fields(trimmed)\n  1080→\t\t\t\tif len(parts) >= 2 {\n  1081→\t\t\t\t\tdockerImage = parts[1]\n  1082→\t\t\t\t}\n  1083→\t\t\t}\n  1084→\t\t}\n  1085→\t}\n  1086→\n  1087→\t// Version\n  1088→\tversion := 0\n  1089→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n  1090→\tif data, err := os.ReadFile(versionPath); err == nil {\n  1091→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n  1092→\t\t\tversion = v\n  1093→\t\t}\n  1094→\t}\n  1095→\n  1096→\t// Prompt files history\n  1097→\ttype commitEntry struct {\n  1098→\t\tSHA     string `json:\"sha\"`\n  1099→\t\tDate    string `json:\"date\"`\n  1100→\t\tMessage string `json:\"message\"`\n  1101→\t}\n  1102→\ttype promptFile struct {\n  1103→\t\tPath    string        `json:\"path\"`\n  1104→\t\tContent string        `json:\"content\"`\n  1105→\t\tHistory []commitEntry `json:\"history\"`\n  1106→\t}\n  1107→\n  1108→\tvar promptFiles []promptFile\n  1109→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n  1110→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n  1111→\t\tfor _, e := range entries {\n  1112→\t\t\tif e.IsDir() {\n  1113→\t\t\t\tcontinue\n  1114→\t\t\t}\n  1115→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n  1116→\t\t\tcontent := \"\"\n  1117→\t\t\tif data, err := os.ReadFile(filepath.Join(promptsDir, e.Name())); err == nil {\n  1118→\t\t\t\tcontent = string(data)\n  1119→\t\t\t}\n  1120→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n  1121→\t\t\tcmd.Dir = dir\n  1122→\t\t\tout, err := cmd.Output()\n  1123→\t\t\tif err != nil {\n  1124→\t\t\t\tcontinue\n  1125→\t\t\t}\n  1126→\t\t\tvar history []commitEntry\n  1127→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n  1128→\t\t\t\tif line == \"\" {\n  1129→\t\t\t\t\tcontinue\n  1130→\t\t\t\t}\n  1131→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1132→\t\t\t\tif len(parts) < 3 {\n  1133→\t\t\t\t\tcontinue\n  1134→\t\t\t\t}\n  1135→\t\t\t\t// Parse date to short form\n  1136→\t\t\t\tdateStr := parts[1]\n  1137→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1138→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1139→\t\t\t\t}\n  1140→\t\t\t\thistory = append(history, commitEntry{\n  1141→\t\t\t\t\tSHA:     parts[0][:7],\n  1142→\t\t\t\t\tDate:    dateStr,\n  1143→\t\t\t\t\tMessage: parts[2],\n  1144→\t\t\t\t})\n  1145→\t\t\t}\n  1146→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, Content: content, History: history})\n  1147→\t\t}\n  1148→\t}\n  1149→\n  1150→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1151→\tjson.NewEncoder(w).Encode(map[string]any{\n  1152→\t\t\"docker_image\": dockerImage,\n  1153→\t\t\"version\":      version,\n  1154→\t\t\"prompt_files\": promptFiles,\n  1155→\t})\n  1156→}\n  1157→\n  1158→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1159→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1160→\tif !ok {\n  1161→\t\treturn\n  1162→\t}\n  1163→\tfile := r.URL.Query().Get(\"file\")\n  1164→\tsha := r.URL.Query().Get(\"sha\")\n  1165→\tif file == \"\" || sha == \"\" {\n  1166→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1167→\t\treturn\n  1168→\t}\n  1169→\n  1170→\t// Validate sha is alphanumeric to prevent injection\n  1171→\tfor _, c := range sha {\n  1172→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1173→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1174→\t\t\treturn\n  1175→\t\t}\n  1176→\t}\n  1177→\n  1178→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1179→\tcmd.Dir = dir\n  1180→\tout, err := cmd.Output()\n  1181→\tif err != nil {\n  1182→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1183→\t\treturn\n  1184→\t}\n  1185→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1186→\tw.Write(out)\n  1187→}\n  1188→\n  1189→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1190→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1191→\tif !ok {\n  1192→\t\treturn\n  1193→\t}\n  1194→\n  1195→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1196→\tentries, err := os.ReadDir(clocheDir)\n  1197→\tif err != nil {\n  1198→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1199→\t\tjson.NewEncoder(w).Encode([]any{})\n  1200→\t\treturn\n  1201→\t}\n  1202→\n  1203→\ttype apiWire struct {\n  1204→\t\tFrom   string `json:\"from\"`\n  1205→\t\tResult string `json:\"result\"`\n  1206→\t\tTo     string `json:\"to\"`\n  1207→\t}\n  1208→\ttype apiStepDef struct {\n  1209→\t\tName    string            `json:\"name\"`\n  1210→\t\tType    string            `json:\"type\"`\n  1211→\t\tResults []string          `json:\"results\"`\n  1212→\t\tConfig  map[string]string `json:\"config\"`\n  1213→\t}\n  1214→\ttype apiWorkflow struct {\n  1215→\t\tName      string       `json:\"name\"`\n  1216→\t\tFile      string       `json:\"file\"`\n  1217→\t\tLocation  string       `json:\"location\"`\n  1218→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1219→\t\tWires     []apiWire    `json:\"wires\"`\n  1220→\t\tEntryStep string       `json:\"entry_step\"`\n  1221→\t}\n  1222→\n  1223→\tvar workflows []apiWorkflow\n  1224→\tfor _, e := range entries {\n  1225→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1226→\t\t\tcontinue\n  1227→\t\t}\n  1228→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1229→\t\tif err != nil {\n  1230→\t\t\tcontinue\n  1231→\t\t}\n  1232→\t\twf, err := dsl.ParseForContainer(string(data))\n  1233→\t\tif err != nil {\n  1234→\t\t\tcontinue\n  1235→\t\t}\n  1236→\t\tvar steps []apiStepDef\n  1237→\t\tfor _, s := range wf.Steps {\n  1238→\t\t\tsteps = append(steps, apiStepDef{\n  1239→\t\t\t\tName:    s.Name,\n  1240→\t\t\t\tType:    string(s.Type),\n  1241→\t\t\t\tResults: s.Results,\n  1242→\t\t\t\tConfig:  s.Config,\n  1243→\t\t\t})\n  1244→\t\t}\n  1245→\t\t// Sort steps by name for consistent ordering\n  1246→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1247→\n  1248→\t\tvar wires []apiWire\n  1249→\t\tfor _, wire := range wf.Wiring {\n  1250→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1251→\t\t}\n  1252→\n  1253→\t\tworkflows = append(workflows, apiWorkflow{\n  1254→\t\t\tName:      wf.Name,\n  1255→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1256→\t\t\tLocation:  \"container\",\n  1257→\t\t\tSteps:     steps,\n  1258→\t\t\tWires:     wires,\n  1259→\t\t\tEntryStep: wf.EntryStep,\n  1260→\t\t})\n  1261→\t}\n  1262→\n  1263→\t// Parse host workflows from host.cloche\n  1264→\thostData, err := os.ReadFile(filepath.Join(clocheDir, \"host.cloche\"))\n  1265→\tif err == nil {\n  1266→\t\thostWfs, err := dsl.ParseAllForHost(string(hostData))\n  1267→\t\tif err == nil {\n  1268→\t\t\t// Sort host workflow names for consistent ordering\n  1269→\t\t\tvar hostNames []string\n  1270→\t\t\tfor name := range hostWfs {\n  1271→\t\t\t\thostNames = append(hostNames, name)\n  1272→\t\t\t}\n  1273→\t\t\tsort.Strings(hostNames)\n  1274→\n  1275→\t\t\tfor _, name := range hostNames {\n  1276→\t\t\t\thwf := hostWfs[name]\n  1277→\t\t\t\tvar steps []apiStepDef\n  1278→\t\t\t\tfor _, s := range hwf.Steps {\n  1279→\t\t\t\t\tsteps = append(steps, apiStepDef{\n  1280→\t\t\t\t\t\tName:    s.Name,\n  1281→\t\t\t\t\t\tType:    string(s.Type),\n  1282→\t\t\t\t\t\tResults: s.Results,\n  1283→\t\t\t\t\t\tConfig:  s.Config,\n  1284→\t\t\t\t\t})\n  1285→\t\t\t\t}\n  1286→\t\t\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1287→\n  1288→\t\t\t\tvar wires []apiWire\n  1289→\t\t\t\tfor _, wire := range hwf.Wiring {\n  1290→\t\t\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1291→\t\t\t\t}\n  1292→\n  1293→\t\t\t\tworkflows = append(workflows, apiWorkflow{\n  1294→\t\t\t\t\tName:      hwf.Name,\n  1295→\t\t\t\t\tFile:      filepath.Join(\".cloche\", \"host.cloche\"),\n  1296→\t\t\t\t\tLocation:  \"host\",\n  1297→\t\t\t\t\tSteps:     steps,\n  1298→\t\t\t\t\tWires:     wires,\n  1299→\t\t\t\t\tEntryStep: hwf.EntryStep,\n  1300→\t\t\t\t})\n  1301→\t\t\t}\n  1302→\t\t}\n  1303→\t}\n  1304→\n  1305→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1306→\tjson.NewEncoder(w).Encode(workflows)\n  1307→}\n  1308→\n  1309→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1310→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1311→\tif !ok {\n  1312→\t\treturn\n  1313→\t}\n  1314→\tworkflowName := r.PathValue(\"workflow\")\n  1315→\tstepName := r.PathValue(\"step\")\n  1316→\n  1317→\t// Find the workflow file (container workflows first, then host)\n  1318→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1319→\tvar wf *domain.Workflow\n  1320→\tentries, _ := os.ReadDir(clocheDir)\n  1321→\tfor _, e := range entries {\n  1322→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1323→\t\t\tcontinue\n  1324→\t\t}\n  1325→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1326→\t\tif err != nil {\n  1327→\t\t\tcontinue\n  1328→\t\t}\n  1329→\t\tparsed, err := dsl.ParseForContainer(string(data))\n  1330→\t\tif err != nil {\n  1331→\t\t\tcontinue\n  1332→\t\t}\n  1333→\t\tif parsed.Name == workflowName {\n  1334→\t\t\twf = parsed\n  1335→\t\t\tbreak\n  1336→\t\t}\n  1337→\t}\n  1338→\t// Try host workflows if not found in container workflows\n  1339→\tif wf == nil {\n  1340→\t\thostData, err := os.ReadFile(filepath.Join(clocheDir, \"host.cloche\"))\n  1341→\t\tif err == nil {\n  1342→\t\t\thostWfs, err := dsl.ParseAllForHost(string(hostData))\n  1343→\t\t\tif err == nil {\n  1344→\t\t\t\twf = hostWfs[workflowName]\n  1345→\t\t\t}\n  1346→\t\t}\n  1347→\t}\n  1348→\tif wf == nil {\n  1349→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1350→\t\treturn\n  1351→\t}\n  1352→\n  1353→\tstep, ok := wf.Steps[stepName]\n  1354→\tif !ok {\n  1355→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1356→\t\treturn\n  1357→\t}\n  1358→\n  1359→\t// Try to read the referenced file from step config\n  1360→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1361→\n  1362→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1363→\t\tcontent, err := resolveFileRef(prompt, dir)\n  1364→\t\tif err == nil {\n  1365→\t\t\tw.Write([]byte(content))\n  1366→\t\t\treturn\n  1367→\t\t}\n  1368→\t}\n  1369→\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n  1370→\t\tcontent, _ := resolveFileRef(cmd, dir)\n  1371→\t\tw.Write([]byte(content))\n  1372→\t\treturn\n  1373→\t}\n  1374→\tif script := step.Config[\"script\"]; script != \"\" {\n  1375→\t\tcontent, _ := resolveFileRef(script, dir)\n  1376→\t\tw.Write([]byte(content))\n  1377→\t\treturn\n  1378→\t}\n  1379→\tif run := step.Config[\"run\"]; run != \"\" {\n  1380→\t\tcontent, _ := resolveFileRef(run, dir)\n  1381→\t\t// If resolveFileRef returned the command as-is (not a file() ref),\n  1382→\t\t// try to find a script file referenced in the command and read it.\n  1383→\t\tif content == run {\n  1384→\t\t\tif scriptContent := readScriptFromCommand(run, dir); scriptContent != \"\" {\n  1385→\t\t\t\tw.Write([]byte(scriptContent))\n  1386→\t\t\t\treturn\n  1387→\t\t\t}\n  1388→\t\t}\n  1389→\t\tw.Write([]byte(content))\n  1390→\t\treturn\n  1391→\t}\n  1392→\tif wfName := step.Config[\"workflow_name\"]; wfName != \"\" {\n  1393→\t\tw.Write([]byte(\"Dispatches workflow: \" + wfName))\n  1394→\t\treturn\n  1395→\t}\n  1396→\n  1397→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1398→}\n  1399→\n  1400→// handleAPITasks returns the task pipeline state for a project's orchestration loop.\n  1401→func (h *Handler) handleAPITasks(w http.ResponseWriter, r *http.Request) {\n  1402→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1403→\tif !ok {\n  1404→\t\treturn\n  1405→\t}\n  1406→\n  1407→\tif h.taskProvider == nil {\n  1408→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1409→\t\tjson.NewEncoder(w).Encode([]any{})\n  1410→\t\treturn\n  1411→\t}\n  1412→\n  1413→\ttasks := h.taskProvider.GetLoopTasks(dir)\n  1414→\tif tasks == nil {\n  1415→\t\ttasks = []TaskEntry{}\n  1416→\t}\n  1417→\n  1418→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1419→\tjson.NewEncoder(w).Encode(tasks)\n  1420→}\n  1421→\n  1422→// --- Template helpers ---\n  1423→\n  1424→// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n  1425→// If the value uses file() syntax, the referenced file is read from disk.\n  1426→// Otherwise the value is returned as-is.\n  1427→func resolveFileRef(value, baseDir string) (string, error) {\n  1428→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n  1429→\t\tpath := value[6 : len(value)-2]\n  1430→\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n  1431→\t\tif err != nil {\n  1432→\t\t\treturn \"\", err\n  1433→\t\t}\n  1434→\t\treturn string(data), nil\n  1435→\t}\n  1436→\treturn value, nil\n  1437→}\n  1438→\n  1439→// readScriptFromCommand tries to find a script file referenced in a run command.\n  1440→// For commands like \"bash .cloche/scripts/setup.sh arg1\", it extracts the file\n  1441→// path and reads its contents. Returns empty string if no script file is found.\n  1442→func readScriptFromCommand(command, baseDir string) string {\n  1443→\tfields := strings.Fields(command)\n  1444→\tfor _, field := range fields {\n  1445→\t\t// Skip flags (e.g. -x, --verbose)\n  1446→\t\tif strings.HasPrefix(field, \"-\") {\n  1447→\t\t\tcontinue\n  1448→\t\t}\n  1449→\t\t// Skip shell redirections and pipes\n  1450→\t\tif field == \"2>&1\" || field == \">\" || field == \">>\" || field == \"|\" {\n  1451→\t\t\tcontinue\n  1452→\t\t}\n  1453→\t\tabsPath := filepath.Join(baseDir, field)\n  1454→\t\tinfo, err := os.Stat(absPath)\n  1455→\t\tif err == nil && !info.IsDir() {\n  1456→\t\t\tdata, err := os.ReadFile(absPath)\n  1457→\t\t\tif err == nil {\n  1458→\t\t\t\treturn string(data)\n  1459→\t\t\t}\n  1460→\t\t}\n  1461→\t}\n  1462→\treturn \"\"\n  1463→}\n  1464→\n  1465→func stateColor(state domain.RunState) string {\n  1466→\tswitch state {\n  1467→\tcase domain.RunStatePending:\n  1468→\t\treturn \"pending\"\n  1469→\tcase domain.RunStateRunning:\n  1470→\t\treturn \"running\"\n  1471→\tcase domain.RunStateSucceeded:\n  1472→\t\treturn \"succeeded\"\n  1473→\tcase domain.RunStateFailed:\n  1474→\t\treturn \"failed\"\n  1475→\tcase domain.RunStateCancelled:\n  1476→\t\treturn \"cancelled\"\n  1477→\tdefault:\n  1478→\t\treturn \"pending\"\n  1479→\t}\n  1480→}\n  1481→\n  1482→func healthColor(status domain.HealthStatus) string {\n  1483→\tswitch status {\n  1484→\tcase domain.HealthGreen:\n  1485→\t\treturn \"green\"\n  1486→\tcase domain.HealthYellow:\n  1487→\t\treturn \"yellow\"\n  1488→\tcase domain.HealthRed:\n  1489→\t\treturn \"red\"\n  1490→\tcase domain.HealthBlue:\n  1491→\t\treturn \"blue\"\n  1492→\tdefault:\n  1493→\t\treturn \"grey\"\n  1494→\t}\n  1495→}\n  1496→\n  1497→func formatTime(t time.Time) string {\n  1498→\tif t.IsZero() {\n  1499→\t\treturn \"\"\n  1500→\t}\n  1501→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1502→}\n  1503→\n  1504→func formatDuration(start, end time.Time) string {\n  1505→\tif start.IsZero() || end.IsZero() {\n  1506→\t\treturn \"\"\n  1507→\t}\n  1508→\td := end.Sub(start)\n  1509→\tif d < time.Second {\n  1510→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1511→\t}\n  1512→\tif d < time.Minute {\n  1513→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1514→\t}\n  1515→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1516→}\n  1517→\n  1518→// formatSmartDuration formats a duration into a human-friendly short string.\n  1519→// Examples: \"3s\", \"2m\", \"1h20m\", \"3h\".\n  1520→func formatSmartDuration(d time.Duration) string {\n  1521→\tif d < time.Minute {\n  1522→\t\treturn fmt.Sprintf(\"%ds\", int(d.Seconds()))\n  1523→\t}\n  1524→\th := int(d.Hours())\n  1525→\tm := int(d.Minutes()) % 60\n  1526→\tif h == 0 {\n  1527→\t\treturn fmt.Sprintf(\"%dm\", m)\n  1528→\t}\n  1529→\tif m == 0 {\n  1530→\t\treturn fmt.Sprintf(\"%dh\", h)\n  1531→\t}\n  1532→\treturn fmt.Sprintf(\"%dh%dm\", h, m)\n  1533→}\n  1534→\n  1535→// roundRelativeTime rounds a duration to neat display units:\n  1536→// <1m -> \"<1m ago\", then 1m,5m,10m,15m,30m,45m,1h,2h,3h,...24h,\n  1537→// then days.\n  1538→func roundRelativeTime(d time.Duration) string {\n  1539→\tif d < time.Minute {\n  1540→\t\treturn \"<1m ago\"\n  1541→\t}\n  1542→\tmins := int(d.Minutes())\n  1543→\thours := int(d.Hours())\n  1544→\tdays := hours / 24\n  1545→\n  1546→\tif days > 0 {\n  1547→\t\tif days == 1 {\n  1548→\t\t\treturn \"1 day ago\"\n  1549→\t\t}\n  1550→\t\treturn fmt.Sprintf(\"%d days ago\", days)\n  1551→\t}\n  1552→\tif hours >= 1 {\n  1553→\t\tif hours == 1 {\n  1554→\t\t\treturn \"1 hour ago\"\n  1555→\t\t}\n  1556→\t\treturn fmt.Sprintf(\"%d hours ago\", hours)\n  1557→\t}\n  1558→\t// Round minutes to neat breakpoints\n  1559→\tswitch {\n  1560→\tcase mins < 3:\n  1561→\t\treturn \"1m ago\"\n  1562→\tcase mins < 8:\n  1563→\t\treturn \"5m ago\"\n  1564→\tcase mins < 13:\n  1565→\t\treturn \"10m ago\"\n  1566→\tcase mins < 20:\n  1567→\t\treturn \"15m ago\"\n  1568→\tcase mins < 38:\n  1569→\t\treturn \"30m ago\"\n  1570→\tcase mins < 53:\n  1571→\t\treturn \"45m ago\"\n  1572→\tdefault:\n  1573→\t\treturn \"1 hour ago\"\n  1574→\t}\n  1575→}\n  1576→\n  1577→// formatRunTiming returns a smart timing string for display on the Runs page.\n  1578→// Running: \"5m\" (just duration so far)\n  1579→// Completed: \"20m, 1 hour ago\"\n  1580→// Pending: \"\"\n  1581→func formatRunTiming(state domain.RunState, startedAt, completedAt time.Time) string {\n  1582→\treturn formatRunTimingAt(state, startedAt, completedAt, time.Now())\n  1583→}\n  1584→\n  1585→// formatRunTimingAt is the testable version of formatRunTiming with an explicit \"now\".\n  1586→func formatRunTimingAt(state domain.RunState, startedAt, completedAt, now time.Time) string {\n  1587→\tif startedAt.IsZero() {\n  1588→\t\treturn \"\"\n  1589→\t}\n  1590→\tswitch state {\n  1591→\tcase domain.RunStateRunning:\n  1592→\t\td := now.Sub(startedAt)\n  1593→\t\treturn formatSmartDuration(d)\n  1594→\tdefault:\n  1595→\t\tif completedAt.IsZero() {\n  1596→\t\t\treturn \"\"\n  1597→\t\t}\n  1598→\t\td := completedAt.Sub(startedAt)\n  1599→\t\tago := now.Sub(completedAt)\n  1600→\t\treturn formatSmartDuration(d) + \", \" + roundRelativeTime(ago)\n  1601→\t}\n  1602→}\n  1603→\n  1604→func truncate(s string, n int) string {\n  1605→\tif len(s) <= n {\n  1606→\t\treturn s\n  1607→\t}\n  1608→\treturn s[:n] + \"...\"\n  1609→}\n  1610→\n  1611→func shortContainerID(id string) string {\n  1612→\tif len(id) > 12 {\n  1613→\t\treturn id[:12]\n  1614→\t}\n  1615→\treturn id\n  1616→}\n  1617→\n  1618→// projectLabels builds a mapping from full project directory paths to short\n  1619→// display labels. Each label is the final directory component (e.g.\n  1620→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1621→// the same final name, the parent directory is prepended to disambiguate\n  1622→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1623→func projectLabels(dirs []string) map[string]string {\n  1624→\tlabels := make(map[string]string, len(dirs))\n  1625→\t// Group dirs by their base name to detect conflicts.\n  1626→\tbyBase := map[string][]string{}\n  1627→\tfor _, d := range dirs {\n  1628→\t\tbase := filepath.Base(d)\n  1629→\t\tbyBase[base] = append(byBase[base], d)\n  1630→\t}\n  1631→\tfor base, paths := range byBase {\n  1632→\t\tif len(paths) == 1 {\n  1633→\t\t\tlabels[paths[0]] = base\n  1634→\t\t} else {\n  1635→\t\t\tfor _, p := range paths {\n  1636→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1637→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1638→\t\t\t}\n  1639→\t\t}\n  1640→\t}\n  1641→\treturn labels\n  1642→}\n  1643→\n  1644→type projectEntry struct {\n  1645→\tDir            string\n  1646→\tLabel          string\n  1647→\tContainerCount int\n  1648→}\n  1649→","numLines":1649,"startLine":1,"totalLines":1649}}}
