{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DTUNQVQS3eAvPsxkK5AfZ7","type":"tool_result","content":"22:\t\"github.com/cloche-dev/cloche/internal/domain\"\n180:\tHealth      domain.HealthResult\n204:\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n205:\t\trunValues := make([]domain.Run, len(runs))\n210:\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n227:\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n258:\tvar runs []*domain.Run\n328:func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n331:\tpending := map[string]*domain.StepExecution{}\n377:func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n415:\tvar parentRun *domain.Run\n471:func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n492:\tvar runs []*domain.Run\n539:\t\trunValues := make([]domain.Run, len(runs))\n543:\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n546:\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n692:\tif run.State != domain.RunStatePending && run.State != domain.RunStateRunning {\n714:\trun.Complete(domain.RunStateCancelled)\n904:\tisComplete := run.State == domain.RunStateSucceeded ||\n905:\t\trun.State == domain.RunStateFailed ||","is_error":false}]},"parent_tool_use_id":"toolu_01LQ8rVXczvGfmG2MXUNX7ZB","session_id":"8f295beb-8c86-4874-b68a-30cd91542139","uuid":"099dc500-c18e-48fd-b5de-162a52cf03bd"}
