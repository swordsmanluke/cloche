urn r.runNamedWorkflow(ctx, projectDir, \"main\", orchRunID)\n    45→}\n    46→\n    47→// RunNamed parses .cloche/host.cloche from projectDir and executes the workflow\n    48→// with the given name. The host.cloche file may contain multiple workflows (e.g.\n    49→// \"list-tasks\", \"main\", \"finalize\"). Returns an error if the named workflow is\n    50→// not found.\n    51→func (r *Runner) RunNamed(ctx context.Context, projectDir string, workflowName string) (*RunResult, error) {\n    52→\torchRunID := domain.GenerateRunID(workflowName)\n    53→\treturn r.runNamedWorkflow(ctx, projectDir, workflowName, orchRunID)\n    54→}\n    55→\n    56→// runNamedWorkflow is the internal implementation that runs a specific named\n    57→// workflow from host.cloche.\n    58→func (r *Runner) runNamedWorkflow(ctx context.Context, projectDir string, workflowName string, orchRunID string) (*RunResult, error) {\n    59→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n    60→\tdata, err := os.ReadFile(hostPath)\n    61→\tif err != nil {\n    62→\t\treturn nil, fmt.Errorf(\"reading host.cloche: %w\", err)\n    63→\t}\n    64→\n    65→\tworkflows, err := dsl.ParseAllForHost(string(data))\n    66→\tif err != nil {\n    67→\t\treturn nil, fmt.Errorf(\"parsing host.cloche: %w\", err)\n    68→\t}\n    69→\n    70→\twf, ok := workflows[workflowName]\n    71→\tif !ok {\n    72→\t\treturn nil, fmt.Errorf(\"host.cloche has no workflow %q\", workflowName)\n    73→\t}\n    74→\n    75→\t// Create output directory for step outputs\n    76→\toutputDir := filepath.Join(projectDir, \".cloche\", orchRunID, \"output\")\n    77→\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n    78→\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n    79→\t}\n    80→\n    81→\tlog.Printf(\"host workflow: starting %q for project %s (run %s)\", wf.Name, projectDir, orchRunID)\n    82→\n    83→\t// Persist the host run in the store so it appears in list/status/logs.\n    84→\t// When SkipRunRecord is set (e.g. for list-tasks polling), skip creating\n    85→\t// the record to avoid cluttering the run history.\n    86→\tif !r.SkipRunRecord {\n    87→\t\thostRun := domain.NewRun(orchRunID, wf.Name)\n    88→\t\thostRun.ProjectDir = projectDir\n    89→\t\thostRun.IsHost = true\n    90→\t\tif err := r.Store.CreateRun(ctx, hostRun); err != nil {\n    91→\t\t\treturn nil, fmt.Errorf(\"creating host run record: %w\", err)\n    92→\t\t}\n    93→\t\thostRun.Start()\n    94→\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n    95→\t}\n    96→\n    97→\texecutor := &Executor{\n    98→\t\tProjectDir: projectDir,\n    99→\t\tMainDir:    MainWorktreeDir(projectDir),\n   100→\t\tDispatcher: r.Dispatcher,\n   101→\t\tStore:      r.Store,\n   102→\t\tOutputDir:  outputDir,\n   103→\t\tWires:      wf.Wiring,\n   104→\t\tHostRunID:  orchRunID,\n   105→\t\tTaskID:     r.TaskID,\n   106→\t\tExtraEnv:   r.ExtraEnv,\n   107→\t}\n   108→\n   109→\t// Configure agent from workflow-level host config\n   110→\tif cmd := wf.Config[\"host.agent_command\"]; cmd != \"\" {\n   111→\t\texecutor.AgentCommands = prompt.ParseCommands(cmd)\n   112→\t}\n   113→\tif args := wf.Config[\"host.agent_args\"]; args != \"\" {\n   114→\t\texecutor.AgentArgs = strings.Fields(args)\n   115→\t}\n   116→\n   117→\teng := engine.New(executor)\n   118→\teng.SetStatusHandler(&hostStatusHandler{\n   119→\t\tprojectDir: projectDir,\n   120→\t\torchRunID:  orchRunID,\n   121→\t\tstore:      r.Store,\n   122→\t})\n   123→\n   124→\trun, runErr := eng.Run(ctx, wf)\n   125→\n   126→\tresult := &RunResult{\n   127→\t\tRunID:     orchRunID,\n   128→\t\tState:     domain.RunStateFailed,\n   129→\t\tOutputDir: outputDir,\n   130→\t}\n   131→\tif run != nil {\n   132→\t\tresult.State = run.State\n   133→\t}\n   134→\n   135→\t// Persist final state.\n   136→\tif !r.SkipRunRecord {\n   137→\t\thostRun, _ := r.Store.GetRun(ctx, orchRunID)\n   138→\t\tif hostRun != nil {\n   139→\t\t\tif runErr != nil {\n   140→\t\t\t\thostRun.Fail(runErr.Error())\n   141→\t\t\t} else {\n   142→\t\t\t\thostRun.Complete(result.State)\n   143→\t\t\t}\n   144→\t\t\thostRun.ActiveSteps = nil\n   145→\t\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n   146→\t\t}\n   147→\t}\n   148→\n   149→\tif runErr != nil {\n   150→\t\tlog.Printf(\"host workflow: %q failed for %s: %v\", wf.Name, projectDir, runErr)\n   151→\t\treturn result, runErr\n   152→\t}\n   153→\n   154→\tlog.Printf(\"host workflow: %q completed for %s with state %s\", wf.Name, projectDir, run.State)\n   155→\treturn result, nil\n   156→}\n   157→\n   158→// RunListTasksWorkflow executes the list-tasks workflow and returns the\n   159→// discovered tasks. No run record is created for list-tasks executions since\n   160→// they are polling operations that would otherwise clutter the run history.\n   161→func RunListTasksWorkflow(ctx context.Context, runner *Runner, projectDir string) ([]Task, *RunResult, error) {\n   162→\trunner.SkipRunRecord = true\n   163→\tresult, err := runner.RunNamed(ctx, projectDir, \"list-tasks\")\n   164→\tif err != nil {\n   165→\t\treturn nil, nil, err\n   166→\t}\n   167→\tif result.State != domain.RunStateSucceeded {\n   168→\t\treturn nil, result, fmt.Errorf(\"list-tasks workflow failed with state %s\", result.State)\n   169→\t}\n   170→\ttasks, err := ReadListTasksOutput(result.OutputDir)\n   171→\tif err != nil {\n   172→\t\treturn nil, result, err\n   173→\t}\n   174→\treturn tasks, result, nil\n   175→}\n   176→\n   177→// hostStatusHandler logs host workflow step events and persists them to the store.\n   178→type hostStatusHandler struct {\n   179→\tprojectDir string\n   180→\torchRunID  string\n   181→\tstore      ports.RunStore\n   182→}\n   183→\n   184→func (h *hostStatusHandler) OnStepStart(_ *domain.Run, step *domain.Step) {\n   185→\tlog.Printf(\"host workflow [%s]: step %q started\", h.orchRunID, step.Name)\n   186→\tif h.store != nil {\n   187→\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n   188→\t\t\tr.RecordStepStart(step.Name)\n   189→\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n   190→\t\t}\n   191→\t}\n   192→}\n   193→\n   194→func (h *hostStatusHandler) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   195→\tlog.Printf(\"host workflow [%s]: step %q completed with result %q\", h.orchRunID, step.Name, result)\n   196→\tif h.store != nil {\n   197→\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n   198→\t\t\tr.RecordStepComplete(step.Name, result)\n   199→\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n   200→\t\t}\n   201→\t}\n   202→}\n   203→\n   204→func (h *hostStatusHandler) OnRunComplete(run *domain.Run) {\n   205→\tlog.Printf(\"host workflow [%s]: run completed with state %s\", h.orchRunID, run.State)\n   206→}\n   207→"}]},"parent_tool_use_id":null,"session_id":"8f295beb-8c86-4874-b68a-30cd91542139","uuid":"aa8232b6-ea0c-4445-8d98-ea6c5f50e4bc","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/runner.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// Ensure hostStatusHandler implements engine.StatusHandler.\nvar _ engine.StatusHandler = (*hostStatusHandler)(nil)\n\n// Runner executes a host workflow by parsing host.cloche and walking the step graph.\ntype Runner struct {\n\tDispatcher    RunDispatcher\n\tStore         ports.RunStore\n\tTaskID        string   // optional task ID assigned by the daemon loop\n\tExtraEnv      []string // additional KEY=VALUE env vars passed to all steps\n\tSkipRunRecord bool     // when true, don't persist a run record to the store\n}\n\n// RunResult contains the outcome of a host workflow execution.\ntype RunResult struct {\n\tRunID     string\n\tState     domain.RunState\n\tOutputDir string // path to the step output directory\n}\n\n// Run parses .cloche/host.cloche from projectDir and executes the \"main\" workflow.\nfunc (r *Runner) Run(ctx context.Context, projectDir string) (*RunResult, error) {\n\treturn r.RunWithID(ctx, projectDir, domain.GenerateRunID(\"main\"))\n}\n\n// RunWithID is like Run but uses the provided run ID instead of generating one.\nfunc (r *Runner) RunWithID(ctx context.Context, projectDir string, orchRunID string) (*RunResult, error) {\n\treturn r.runNamedWorkflow(ctx, projectDir, \"main\", orchRunID)\n}\n\n// RunNamed parses .cloche/host.cloche from projectDir and executes the workflow\n// with the given name. The host.cloche file may contain multiple workflows (e.g.\n// \"list-tasks\", \"main\", \"finalize\"). Returns an error if the named workflow is\n// not found.\nfunc (r *Runner) RunNamed(ctx context.Context, projectDir string, workflowName string) (*RunResult, error) {\n\torchRunID := domain.GenerateRunID(workflowName)\n\treturn r.runNamedWorkflow(ctx, projectDir, workflowName, orchRunID)\n}\n\n// runNamedWorkflow is the internal implementation that runs a specific named\n// workflow from host.cloche.\nfunc (r *Runner) runNamedWorkflow(ctx context.Context, projectDir string, workflowName string, orchRunID string) (*RunResult, error) {\n\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n\tdata, err := os.ReadFile(hostPath)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading host.cloche: %w\", err)\n\t}\n\n\tworkflows, err := dsl.ParseAllForHost(string(data))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing host.cloche: %w\", err)\n\t}\n\n\twf, ok := workflows[workflowName]\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"host.cloche has no workflow %q\", workflowName)\n\t}\n\n\t// Create output directory for step outputs\n\toutputDir := filepath.Join(projectDir, \".cloche\", orchRunID, \"output\")\n\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n\t}\n\n\tlog.Printf(\"host workflow: starting %q for project %s (run %s)\", wf.Name, projectDir, orchRunID)\n\n\t// Persist the host run in the store so it appears in list/status/logs.\n\t// When SkipRunRecord is set (e.g. for list-tasks polling), skip creating\n\t// the record to avoid cluttering the run history.\n\tif !r.SkipRunRecord {\n\t\thostRun := domain.NewRun(orchRunID, wf.Name)\n\t\thostRun.ProjectDir = projectDir\n\t\thostRun.IsHost = true\n\t\tif err := r.Store.CreateRun(ctx, hostRun); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating host run record: %w\", err)\n\t\t}\n\t\thostRun.Start()\n\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n\t}\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tMainDir:    MainWorktreeDir(projectDir),\n\t\tDispatcher: r.Dispatcher,\n\t\tStore:      r.Store,\n\t\tOutputDir:  outputDir,\n\t\tWires:      wf.Wiring,\n\t\tHostRunID:  orchRunID,\n\t\tTaskID:     r.TaskID,\n\t\tExtraEnv:   r.ExtraEnv,\n\t}\n\n\t// Configure agent from workflow-level host config\n\tif cmd := wf.Config[\"host.agent_command\"]; cmd != \"\" {\n\t\texecutor.AgentCommands = prompt.ParseCommands(cmd)\n\t}\n\tif args := wf.Config[\"host.agent_args\"]; args != \"\" {\n\t\texecutor.AgentArgs = strings.Fields(args)\n\t}\n\n\teng := engine.New(executor)\n\teng.SetStatusHandler(&hostStatusHandler{\n\t\tprojectDir: projectDir,\n\t\torchRunID:  orchRunID,\n\t\tstore:      r.Store,\n\t})\n\n\trun, runErr := eng.Run(ctx, wf)\n\n\tresult := &RunResult{\n\t\tRunID:     orchRunID,\n\t\tState:     domain.RunStateFailed,\n\t\tOutputDir: outputDir,\n\t}\n\tif run != nil {\n\t\tresult.State = run.State\n\t}\n\n\t// Persist final state.\n\tif !r.SkipRunRecord {\n\t\thostRun, _ := r.Store.GetRun(ctx, orchRunID)\n\t\tif hostRun != nil {\n\t\t\tif runErr != nil {\n\t\t\t\thostRun.Fail(runErr.Error())\n\t\t\t} else {\n\t\t\t\thostRun.Complete(result.State)\n\t\t\t}\n\t\t\thostRun.ActiveSteps = nil\n\t\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n\t\t}\n\t}\n\n\tif runErr != nil {\n\t\tlog.Printf(\"host workflow: %q failed for %s: %v\", wf.Name, projectDir, runErr)\n\t\treturn result, runErr\n\t}\n\n\tlog.Printf(\"host workflow: %q completed for %s with state %s\", wf.Name, projectDir, run.State)\n\treturn result, nil\n}\n\n// RunListTasksWorkflow executes the list-tasks workflow and returns the\n// discovered tasks. No run record is created for list-tasks executions since\n// they are polling operations that would otherwise clutter the run history.\nfunc RunListTasksWorkflow(ctx context.Context, runner *Runner, projectDir string) ([]Task, *RunResult, error) {\n\trunner.SkipRunRecord = true\n\tresult, err := runner.RunNamed(ctx, projectDir, \"list-tasks\")\n\tif err != nil {\n\t\treturn nil, nil, err\n\t}\n\tif result.State != domain.RunStateSucceeded {\n\t\treturn nil, result, fmt.Errorf(\"list-tasks workflow failed with state %s\", result.State)\n\t}\n\ttasks, err := ReadListTasksOutput(result.OutputDir)\n\tif err != nil {\n\t\treturn nil, result, err\n\t}\n\treturn tasks, result, nil\n}\n\n// hostStatusHandler logs host workflow step events and persists them to the store.\ntype hostStatusHandler struct {\n\tprojectDir string\n\torchRunID  string\n\tstore      ports.RunStore\n}\n\nfunc (h *hostStatusHandler) OnStepStart(_ *domain.Run, step *domain.Step) {\n\tlog.Printf(\"host workflow [%s]: step %q started\", h.orchRunID, step.Name)\n\tif h.store != nil {\n\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n\t\t\tr.RecordStepStart(step.Name)\n\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n\t\t}\n\t}\n}\n\nfunc (h *hostStatusHandler) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n\tlog.Printf(\"host workflow [%s]: step %q completed with result %q\", h.orchRunID, step.Name, result)\n\tif h.store != nil {\n\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n\t\t\tr.RecordStepComplete(step.Name, result)\n\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n\t\t}\n\t}\n}\n\nfunc (h *hostStatusHandler) OnRunComplete(run *domain.Run) {\n\tlog.Printf(\"host workflow [%s]: run completed with state %s\", h.orchRunID, run.State)\n}\n","numLines":207,"startLine":1,"totalLines":207}}}
