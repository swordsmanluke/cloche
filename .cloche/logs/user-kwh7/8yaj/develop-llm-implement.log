 class=\"' + rowClass + '\">' +\n                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n                        '<td>' + escapeHtml(title) + '</td>' +\n                        '<td>' + escapeHtml(proj) + '</td>' +\n                        '<td>' + r.workflow_name + '</td>' +\n                        '<td>' + runType + '</td>' +\n                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n                        '<td>' + escapeHtml(timing) + '</td>' +\n                        '<td class=\"mono\">' + cid + '</td>' +\n                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                        '</tr>';\n                }\n                tbody.innerHTML = html;\n            })\n            .catch(function() {});\n    }\n    function escapeHtml(s) {\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n    setInterval(poll, 3000);\n})();\n</script>\n{{end}}\n","structuredPatch":[{"oldStart":31,"oldLines":6,"newStart":31,"newLines":7,"lines":["     <tbody id=\"runs-body\">","     {{if .Runs}}","         {{range .Runs}}","+        {{if ne .WorkflowName \"list-tasks\"}}","         <tr class=\"{{if .ParentRunID}}run-child-row{{else if .IsHost}}run-parent-row{{end}}\">","             <td><a href=\"/runs/{{.ID}}\">{{.ID}}</a></td>","             <td>{{truncate .Title 50}}</td>"]},{"oldStart":43,"oldLines":6,"newStart":44,"newLines":7,"lines":["             <td class=\"error-cell\">{{truncate .ErrorMessage 80}}</td>","         </tr>","         {{end}}","+        {{end}}","     {{else}}","         <tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>","     {{end}}"]},{"oldStart":82,"oldLines":9,"newStart":84,"newLines":19,"lines":["             });","     };"," ","-    // groupRuns arranges runs so children appear directly after their parent.","-    // Parents are de-emphasized; children (where active work happens) are prominent.","+    // groupRuns arranges runs by task, then by parent-child within each task.","+    // list-tasks runs are excluded. Runs with the same task_id are grouped","+    // under a task header row. Runs without a task_id appear ungrouped.","     function groupRuns(runs) {","+        // Filter out list-tasks runs","+        var filtered = [];","+        for (var i = 0; i < runs.length; i++) {","+            if (runs[i].workflow_name !== 'list-tasks') {","+                filtered.push(runs[i]);","+            }","+        }","+        runs = filtered;","+","         var parentMap = {};  // parent_run_id -> [children]","         var topLevel = [];","         var byId = {};"]},{"oldStart":111,"oldLines":15,"newStart":123,"newLines":55,"lines":["             return (b.started_at || '').localeCompare(a.started_at || '');","         });"," ","-        var result = [];","+        // Group top-level runs by task_id (preserving sort order within groups)","+        var taskGroups = {};   // task_id -> [top-level runs]","+        var taskOrder = [];    // ordered list of task_ids as first seen","+        var ungrouped = [];    // runs without a task_id","+","         for (var i = 0; i < topLevel.length; i++) {","             var r = topLevel[i];","+            var tid = r.task_id || '';","+            if (tid) {","+                if (!taskGroups[tid]) {","+                    taskGroups[tid] = [];","+                    taskOrder.push(tid);","+                }","+                taskGroups[tid].push(r);","+            } else {","+                ungrouped.push(r);","+            }","+        }","+","+        var result = [];","+","+        // Emit task groups first (they have active context)","+        for (var ti = 0; ti < taskOrder.length; ti++) {","+            var tid = taskOrder[ti];","+            var group = taskGroups[tid];","+            // Task header row","+            result.push({ run: null, isParent: false, isChild: false, isTaskHeader: true, taskID: tid });","+            for (var gi = 0; gi < group.length; gi++) {","+                var r = group[gi];","+                var children = parentMap[r.id];","+                var isParent = children && children.length > 0;","+                result.push({ run: r, isParent: isParent, isChild: false, isTaskHeader: false, taskID: '' });","+                if (children) {","+                    for (var j = 0; j < children.length; j++) {","+                        result.push({ run: children[j], isParent: false, isChild: true, isTaskHeader: false, taskID: '' });","+                    }","+                }","+            }","+        }","+","+        // Emit ungrouped runs","+        for (var i = 0; i < ungrouped.length; i++) {","+            var r = ungrouped[i];","             var children = parentMap[r.id];","             var isParent = children && children.length > 0;","-            result.push({ run: r, isParent: isParent, isChild: false });","+            result.push({ run: r, isParent: isParent, isChild: false, isTaskHeader: false, taskID: '' });","             if (children) {","                 for (var j = 0; j < children.length; j++) {","-                    result.push({ run: children[j], isParent: false, isChild: true });","+                    result.push({ run: children[j], isParent: false, isChild: true, isTaskHeader: false, taskID: '' });","                 }","             }","         }"]},{"oldStart":128,"oldLines":7,"newStart":180,"newLines":7,"lines":["         for (var i = 0; i < runs.length; i++) {","             var r = runs[i];","             if (r.parent_run_id && !byId[r.parent_run_id]) {","-                result.push({ run: r, isParent: false, isChild: true });","+                result.push({ run: r, isParent: false, isChild: true, isTaskHeader: false, taskID: '' });","             }","         }"," "]},{"oldStart":150,"oldLines":9,"newStart":202,"newLines":23,"lines":["                 }"," ","                 var grouped = groupRuns(runs);","+                // Check if all entries (after list-tasks filtering) are empty","+                var hasRuns = false;","+                for (var i = 0; i < grouped.length; i++) {","+                    if (grouped[i].run) { hasRuns = true; break; }","+                }","+                if (!hasRuns && grouped.length === 0) {","+                    tbody.innerHTML = '<tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>';","+                    return;","+                }","+","                 var html = '';","                 for (var i = 0; i < grouped.length; i++) {","                     var entry = grouped[i];","+                    if (entry.isTaskHeader) {","+                        html += '<tr class=\"run-task-header\"><td colspan=\"9\">Task: ' + escapeHtml(entry.taskID) + '</td></tr>';","+                        continue;","+                    }","                     var r = entry.run;","                     var cid = r.container_id || '';","                     if (cid.length > 12) cid = cid.substring(0, 12);"]}],"originalFile":"{{define \"content\"}}\n<h1>Runs</h1>\n{{if .Projects}}\n<div class=\"project-filter\">\n    <label for=\"project-select\">Project:</label>\n    <select id=\"project-select\" onchange=\"filterByProject(this.value)\">\n        <option value=\"\">All projects</option>\n        {{range .Projects}}\n        <option value=\"{{.Dir}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>\n        {{end}}\n    </select>\n    {{if .TotalContainerCount}}\n    <button class=\"btn btn-danger btn-sm\" id=\"cleanup-containers-btn\" onclick=\"cleanupContainers()\" style=\"margin-left:0.5rem\">Clean up {{.TotalContainerCount}} old container{{if gt .TotalContainerCount 1}}s{{end}}</button>\n    {{end}}\n</div>\n{{end}}\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Run ID</th>\n            <th>Title</th>\n            <th>Project</th>\n            <th>Workflow</th>\n            <th>Type</th>\n            <th>State</th>\n            <th>Timing</th>\n            <th>Container</th>\n            <th>Error</th>\n        </tr>\n    </thead>\n    <tbody id=\"runs-body\">\n    {{if .Runs}}\n        {{range .Runs}}\n        <tr class=\"{{if .ParentRunID}}run-child-row{{else if .IsHost}}run-parent-row{{end}}\">\n            <td><a href=\"/runs/{{.ID}}\">{{.ID}}</a></td>\n            <td>{{truncate .Title 50}}</td>\n            <td>{{index $.ProjectLabels .ProjectDir}}</td>\n            <td>{{.WorkflowName}}</td>\n            <td>{{if .IsHost}}host{{else}}container{{end}}</td>\n            <td><span class=\"badge badge-{{stateColor .State}}\">{{.State}}</span></td>\n            <td>{{formatRunTiming .State .StartedAt .CompletedAt}}</td>\n            <td class=\"mono\">{{shortContainerID .ContainerID}}</td>\n            <td class=\"error-cell\">{{truncate .ErrorMessage 80}}</td>\n        </tr>\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var currentProject = '{{.ProjectFilter}}';\n\n    function filterByProject(dir) {\n        if (dir) {\n            window.location.href = '/runs?project=' + encodeURIComponent(dir);\n        } else {\n            window.location.href = '/runs';\n        }\n    }\n    window.filterByProject = filterByProject;\n\n    window.cleanupContainers = function() {\n        var btn = document.getElementById('cleanup-containers-btn');\n        if (btn) btn.disabled = true;\n        fetch('/api/containers', { method: 'DELETE' })\n            .then(function(r) { return r.json(); })\n            .then(function(data) {\n                if (btn) {\n                    btn.textContent = 'Cleaned up ' + data.deleted + ' container' + (data.deleted !== 1 ? 's' : '');\n                }\n            })\n            .catch(function() {\n                if (btn) {\n                    btn.textContent = 'Cleanup failed';\n                    btn.disabled = false;\n                }\n            });\n    };\n\n    // groupRuns arranges runs so children appear directly after their parent.\n    // Parents are de-emphasized; children (where active work happens) are prominent.\n    function groupRuns(runs) {\n        var parentMap = {};  // parent_run_id -> [children]\n        var topLevel = [];\n        var byId = {};\n\n        for (var i = 0; i < runs.length; i++) {\n            byId[runs[i].id] = runs[i];\n        }\n\n        for (var i = 0; i < runs.length; i++) {\n            var r = runs[i];\n            if (r.parent_run_id && byId[r.parent_run_id]) {\n                if (!parentMap[r.parent_run_id]) parentMap[r.parent_run_id] = [];\n                parentMap[r.parent_run_id].push(r);\n            } else {\n                topLevel.push(r);\n            }\n        }\n\n        // Sort top-level: running first, then by started_at descending\n        topLevel.sort(function(a, b) {\n            var aRunning = a.state === 'running' ? 0 : 1;\n            var bRunning = b.state === 'running' ? 0 : 1;\n            if (aRunning !== bRunning) return aRunning - bRunning;\n            return (b.started_at || '').localeCompare(a.started_at || '');\n        });\n\n        var result = [];\n        for (var i = 0; i < topLevel.length; i++) {\n            var r = topLevel[i];\n            var children = parentMap[r.id];\n            var isParent = children && children.length > 0;\n            result.push({ run: r, isParent: isParent, isChild: false });\n            if (children) {\n                for (var j = 0; j < children.length; j++) {\n                    result.push({ run: children[j], isParent: false, isChild: true });\n                }\n            }\n        }\n\n        // Add orphaned children (parent not in current view)\n        for (var i = 0; i < runs.length; i++) {\n            var r = runs[i];\n            if (r.parent_run_id && !byId[r.parent_run_id]) {\n                result.push({ run: r, isParent: false, isChild: true });\n            }\n        }\n\n        return result;\n    }\n\n    function poll() {\n        var url = '/api/runs';\n        if (currentProject) {\n            url += '?project=' + encodeURIComponent(currentProject);\n        }\n        fetch(url)\n            .then(function(r) { return r.json(); })\n            .then(function(runs) {\n                var tbody = document.getElementById('runs-body');\n                if (!runs || runs.length === 0) {\n                    tbody.innerHTML = '<tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>';\n                    return;\n                }\n\n                var grouped = groupRuns(runs);\n                var html = '';\n                for (var i = 0; i < grouped.length; i++) {\n                    var entry = grouped[i];\n                    var r = entry.run;\n                    var cid = r.container_id || '';\n                    if (cid.length > 12) cid = cid.substring(0, 12);\n                    var err = r.error_message || '';\n                    if (err.length > 80) err = err.substring(0, 80) + '...';\n                    var proj = r.project_label || '';\n                    var title = r.title || '';\n                    if (title.length > 50) title = title.substring(0, 47) + '...';\n                    var runType = r.is_host ? 'host' : 'container';\n                    var rowClass = entry.isChild ? 'run-child-row' : (entry.isParent ? 'run-parent-row' : '');\n                    var timing = r.timing || '';\n                    html += '<tr class=\"' + rowClass + '\">' +\n                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n                        '<td>' + escapeHtml(title) + '</td>' +\n                        '<td>' + escapeHtml(proj) + '</td>' +\n                        '<td>' + r.workflow_name + '</td>' +\n                        '<td>' + runType + '</td>' +\n                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n                        '<td>' + escapeHtml(timing) + '</td>' +\n                        '<td class=\"mono\">' + cid + '</td>' +\n                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                        '</tr>';\n                }\n                tbody.innerHTML = html;\n            })\n            .catch(function() {});\n    }\n    function escapeHtml(s) {\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n    setInterval(poll, 3000);\n})();\n</script>\n{{end}}\n"}}
