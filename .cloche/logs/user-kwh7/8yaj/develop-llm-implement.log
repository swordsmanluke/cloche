{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019vufNArUnDnURnJMamByAK","type":"tool_result","content":"    85→    // groupRuns arranges runs so children appear directly after their parent.\n    86→    // Parents are de-emphasized; children (where active work happens) are prominent.\n    87→    function groupRuns(runs) {\n    88→        var parentMap = {};  // parent_run_id -> [children]\n    89→        var topLevel = [];\n    90→        var byId = {};\n    91→\n    92→        for (var i = 0; i < runs.length; i++) {\n    93→            byId[runs[i].id] = runs[i];\n    94→        }\n    95→\n    96→        for (var i = 0; i < runs.length; i++) {\n    97→            var r = runs[i];\n    98→            if (r.parent_run_id && byId[r.parent_run_id]) {\n    99→                if (!parentMap[r.parent_run_id]) parentMap[r.parent_run_id] = [];\n   100→                parentMap[r.parent_run_id].push(r);\n   101→            } else {\n   102→                topLevel.push(r);\n   103→            }\n   104→        }\n   105→\n   106→        // Sort top-level: running first, then by started_at descending\n   107→        topLevel.sort(function(a, b) {\n   108→            var aRunning = a.state === 'running' ? 0 : 1;\n   109→            var bRunning = b.state === 'running' ? 0 : 1;\n   110→            if (aRunning !== bRunning) return aRunning - bRunning;\n   111→            return (b.started_at || '').localeCompare(a.started_at || '');\n   112→        });\n   113→\n   114→        var result = [];\n   115→        for (var i = 0; i < topLevel.length; i++) {\n   116→            var r = topLevel[i];\n   117→            var children = parentMap[r.id];\n   118→            var isParent = children && children.length > 0;\n   119→            result.push({ run: r, isParent: isParent, isChild: false });\n   120→            if (children) {\n   121→                for (var j = 0; j < children.length; j++) {\n   122→                    result.push({ run: children[j], isParent: false, isChild: true });\n   123→                }\n   124→            }\n   125→        }\n   126→\n   127→        // Add orphaned children (parent not in current view)\n   128→        for (var i = 0; i < runs.length; i++) {\n   129→            var r = runs[i];\n   130→            if (r.parent_run_id && !byId[r.parent_run_id]) {\n   131→                result.push({ run: r, isParent: false, isChild: true });\n   132→            }\n   133→        }\n   134→\n   135→        return result;\n   136→    }\n   137→\n   138→    function poll() {\n   139→        var url = '/api/runs';\n   140→        if (currentProject) {\n   141→            url += '?project=' + encodeURIComponent(currentProject);\n   142→        }\n   143→        fetch(url)\n   144→            .then(function(r) { return r.json(); })"}]},"parent_tool_use_id":"toolu_01LQ8rVXczvGfmG2MXUNX7ZB","session_id":"8f295beb-8c86-4874-b68a-30cd91542139","uuid":"9800b08c-d51a-4d83-8ed5-fdc9dc951db8"}
