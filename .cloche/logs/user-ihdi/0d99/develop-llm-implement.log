 err != nil {\n    51→\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n    52→\t}\n    53→\n    54→\tlog.Printf(\"host workflow: starting %q for project %s (run %s)\", wf.Name, projectDir, orchRunID)\n    55→\n    56→\texecutor := &Executor{\n    57→\t\tProjectDir: projectDir,\n    58→\t\tDispatcher: r.Dispatcher,\n    59→\t\tStore:      r.Store,\n    60→\t\tOutputDir:  outputDir,\n    61→\t\tWires:      wf.Wiring,\n    62→\t}\n    63→\n    64→\teng := engine.New(executor)\n    65→\teng.SetStatusHandler(&hostStatusHandler{projectDir: projectDir, orchRunID: orchRunID})\n    66→\n    67→\trun, runErr := eng.Run(ctx, wf)\n    68→\n    69→\tresult := &RunResult{\n    70→\t\tRunID: orchRunID,\n    71→\t\tState: domain.RunStateFailed,\n    72→\t}\n    73→\tif run != nil {\n    74→\t\tresult.State = run.State\n    75→\t}\n    76→\n    77→\tif runErr != nil {\n    78→\t\tlog.Printf(\"host workflow: %q failed for %s: %v\", wf.Name, projectDir, runErr)\n    79→\t\treturn result, runErr\n    80→\t}\n    81→\n    82→\tlog.Printf(\"host workflow: %q completed for %s with state %s\", wf.Name, projectDir, run.State)\n    83→\treturn result, nil\n    84→}\n    85→\n    86→// hostStatusHandler logs host workflow step events.\n    87→type hostStatusHandler struct {\n    88→\tprojectDir string\n    89→\torchRunID  string\n    90→}\n    91→\n    92→func (h *hostStatusHandler) OnStepStart(_ *domain.Run, step *domain.Step) {\n    93→\tlog.Printf(\"host workflow [%s]: step %q started\", h.orchRunID, step.Name)\n    94→}\n    95→\n    96→func (h *hostStatusHandler) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n    97→\tlog.Printf(\"host workflow [%s]: step %q completed with result %q\", h.orchRunID, step.Name, result)\n    98→}\n    99→\n   100→func (h *hostStatusHandler) OnRunComplete(run *domain.Run) {\n   101→\tlog.Printf(\"host workflow [%s]: run completed with state %s\", h.orchRunID, run.State)\n   102→}\n   103→"}]},"parent_tool_use_id":null,"session_id":"83efa890-2574-44c5-a1f7-226ad3f671c0","uuid":"77eeeb4d-d8f9-4adb-8c30-765eaddba873","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/runner.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// Runner executes a host workflow by parsing host.cloche and walking the step graph.\ntype Runner struct {\n\tDispatcher RunDispatcher\n\tStore      ports.RunStore\n}\n\n// RunResult contains the outcome of a host workflow execution.\ntype RunResult struct {\n\tRunID string\n\tState domain.RunState\n}\n\n// Run parses .cloche/host.cloche from projectDir and executes the \"main\" workflow.\nfunc (r *Runner) Run(ctx context.Context, projectDir string) (*RunResult, error) {\n\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n\tdata, err := os.ReadFile(hostPath)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading host.cloche: %w\", err)\n\t}\n\n\twf, err := dsl.ParseForHost(string(data))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing host.cloche: %w\", err)\n\t}\n\n\tif wf.Name != \"main\" {\n\t\treturn nil, fmt.Errorf(\"host.cloche workflow is %q, expected \\\"main\\\"\", wf.Name)\n\t}\n\n\t// Generate a unique run ID for this host workflow execution\n\torchRunID := domain.GenerateRunID(\"main\")\n\n\t// Create output directory for step outputs\n\toutputDir := filepath.Join(projectDir, \".cloche\", orchRunID, \"output\")\n\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n\t}\n\n\tlog.Printf(\"host workflow: starting %q for project %s (run %s)\", wf.Name, projectDir, orchRunID)\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tDispatcher: r.Dispatcher,\n\t\tStore:      r.Store,\n\t\tOutputDir:  outputDir,\n\t\tWires:      wf.Wiring,\n\t}\n\n\teng := engine.New(executor)\n\teng.SetStatusHandler(&hostStatusHandler{projectDir: projectDir, orchRunID: orchRunID})\n\n\trun, runErr := eng.Run(ctx, wf)\n\n\tresult := &RunResult{\n\t\tRunID: orchRunID,\n\t\tState: domain.RunStateFailed,\n\t}\n\tif run != nil {\n\t\tresult.State = run.State\n\t}\n\n\tif runErr != nil {\n\t\tlog.Printf(\"host workflow: %q failed for %s: %v\", wf.Name, projectDir, runErr)\n\t\treturn result, runErr\n\t}\n\n\tlog.Printf(\"host workflow: %q completed for %s with state %s\", wf.Name, projectDir, run.State)\n\treturn result, nil\n}\n\n// hostStatusHandler logs host workflow step events.\ntype hostStatusHandler struct {\n\tprojectDir string\n\torchRunID  string\n}\n\nfunc (h *hostStatusHandler) OnStepStart(_ *domain.Run, step *domain.Step) {\n\tlog.Printf(\"host workflow [%s]: step %q started\", h.orchRunID, step.Name)\n}\n\nfunc (h *hostStatusHandler) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n\tlog.Printf(\"host workflow [%s]: step %q completed with result %q\", h.orchRunID, step.Name, result)\n}\n\nfunc (h *hostStatusHandler) OnRunComplete(run *domain.Run) {\n\tlog.Printf(\"host workflow [%s]: run completed with state %s\", h.orchRunID, run.State)\n}\n","numLines":103,"startLine":1,"totalLines":103}}}
