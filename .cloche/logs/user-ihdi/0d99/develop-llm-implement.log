→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    48→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    49→\t} else if n > 0 {\n    50→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    51→\t}\n    52→\n    53→\truntime, err := initRuntime(globalCfg)\n    54→\tif err != nil {\n    55→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    56→\t\tos.Exit(1)\n    57→\t}\n    58→\n    59→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    60→\n    61→\tbroadcaster := logstream.NewBroadcaster()\n    62→\n    63→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    64→\tsrv.SetLogStore(store)\n    65→\tsrv.SetLogBroadcaster(broadcaster)\n    66→\n    67→\t// Set up evolution trigger\n    68→\tevoTrigger := initEvolution(globalCfg, store, store)\n    69→\tif evoTrigger != nil {\n    70→\t\tsrv.SetEvolution(evoTrigger)\n    71→\t}\n    72→\n    73→\tgrpcServer := grpc.NewServer()\n    74→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    75→\n    76→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    77→\n    78→\tlis, err := listen(listenAddr)\n    79→\tif err != nil {\n    80→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    81→\t\tos.Exit(1)\n    82→\t}\n    83→\n    84→\tvar httpServer *http.Server\n    85→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n    86→\t\twebOpts := []web.HandlerOption{\n    87→\t\t\tweb.WithContainerLogger(runtime),\n    88→\t\t\tweb.WithLogStore(store),\n    89→\t\t\tweb.WithLogBroadcaster(broadcaster),\n    90→\t\t}\n    91→\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n    92→\t\tif err != nil {\n    93→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n    94→\t\t\tos.Exit(1)\n    95→\t\t}\n    96→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n    97→\t\tgo func() {\n    98→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n    99→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   100→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   101→\t\t\t}\n   102→\t\t}()\n   103→\t}\n   104→\n   105→\t// Auto-execute main workflow for active projects\n   106→\tautoRunActiveProjects(store, srv)\n   107→\n   108→\tsigCh := make(chan os.Signal, 1)\n   109→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   110→\tgo func() {\n   111→\t\t<-sigCh\n   112→\t\tif httpServer != nil {\n   113→\t\t\thttpServer.Close()\n   114→\t\t}\n   115→\t\tgrpcServer.GracefulStop()\n   116→\t}()\n   117→\n   118→\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   119→\tif err := grpcServer.Serve(lis); err != nil {\n   120→\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   121→\t\tos.Exit(1)\n   122→\t}\n   123→}\n   124→\n   125→func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   126→\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   127→\n   128→\tswitch runtimeType {\n   129→\tcase \"local\":\n   130→\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   131→\t\tif agentPath == \"\" {\n   132→\t\t\t// Look for cloche-agent next to this binary\n   133→\t\t\texe, err := os.Executable()\n   134→\t\t\tif err == nil {\n   135→\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   136→\t\t\t} else {\n   137→\t\t\t\tagentPath = \"cloche-agent\"\n   138→\t\t\t}\n   139→\t\t}\n   140→\t\treturn local.NewRuntime(agentPath), nil\n   141→\tcase \"docker\":\n   142→\t\treturn docker.NewRuntime()\n   143→\tdefault:\n   144→\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   145→\t}\n   146→}\n   147→\n   148→func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   149→\t// Load config from working directory (daemon-level defaults)\n   150→\tcfg, err := config.Load(\".\")\n   151→\tif err != nil || !cfg.Evolution.Enabled {\n   152→\t\treturn nil\n   153→\t}\n   154→\n   155→\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   156→\tif llmCmd == \"\" {\n   157→\t\treturn nil\n   158→\t}\n   159→\n   160→\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   161→\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   162→\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   163→\t\t\t// Load per-project config for confidence threshold\n   164→\t\t\tprojCfg, err := config.Load(projectDir)\n   165→\t\t\tif err != nil {\n   166→\t\t\t\tprojCfg = cfg // fall back to daemon config\n   167→\t\t\t}\n   168→\n   169→\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   170→\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   171→\t\t\t\tProjectDir:    projectDir,\n   172→\t\t\t\tWorkflowName:  workflowName,\n   173→\t\t\t\tLLM:           llm,\n   174→\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   175→\t\t\t})\n   176→\n   177→\t\t\tctx := context.Background()\n   178→\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   179→\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   180→\t\t\t}\n   181→\t\t},\n   182→\t})\n   183→\n   184→\treturn trigger\n   185→}\n   186→\n   187→func listen(addr string) (net.Listener, error) {\n   188→\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   189→\t\tsockPath := addr[7:]\n   190→\t\tos.Remove(sockPath)\n   191→\t\treturn net.Listen(\"unix\", sockPath)\n   192→\t}\n   193→\treturn net.Listen(\"tcp\", addr)\n   194→}\n   195→\n   196→// autoRunActiveProjects scans known projects for active = true in their config,\n   197→// parses .cloche/host.cloche and executes the full host workflow step by step.\n   198→func autoRunActiveProjects(store ports.RunStore, srv *adaptgrpc.ClocheServer) {\n   199→\tctx := context.Background()\n   200→\tprojects, err := store.ListProjects(ctx)\n   201→\tif err != nil {\n   202→\t\tfmt.Fprintf(os.Stderr, \"startup: failed to list projects: %v\\n\", err)\n   203→\t\treturn\n   204→\t}\n   205→\n   206→\tfor _, projectDir := range projects {\n   207→\t\tcfg, err := config.Load(projectDir)\n   208→\t\tif err != nil || !cfg.Active {\n   209→\t\t\tcontinue\n   210→\t\t}\n   211→\n   212→\t\t// Verify host.cloche exists before launching\n   213→\t\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   214→\t\tif _, err := os.Stat(hostPath); err != nil {\n   215→\t\t\tfmt.Fprintf(os.Stderr, \"startup: skipping active project %s: %v\\n\", projectDir, err)\n   216→\t\t\tcontinue\n   217→\t\t}\n   218→\n   219→\t\tfmt.Fprintf(os.Stderr, \"startup: auto-running host workflow for active project %s\\n\", projectDir)\n   220→\t\tgo func(projDir string) {\n   221→\t\t\trunner := &hostpkg.Runner{\n   222→\t\t\t\tDispatcher: srv,\n   223→\t\t\t\tStore:      store,\n   224→\t\t\t}\n   225→\t\t\tresult, err := runner.Run(context.Background(), projDir)\n   226→\t\t\tif err != nil {\n   227→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow failed for %s: %v\\n\", projDir, err)\n   228→\t\t\t} else {\n   229→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow completed for %s: %s (run %s)\\n\", projDir, result.State, result.RunID)\n   230→\t\t\t}\n   231→\t\t}(projectDir)\n   232→\t}\n   233→}\n   234→\n   235→// envOrConfig returns the env var value if set, otherwise the config file\n   236→// value if non-empty, otherwise the fallback default.\n   237→func envOrConfig(envKey, configVal, fallback string) string {\n   238→\tif v := os.Getenv(envKey); v != \"\" {\n   239→\t\treturn v\n   240→\t}\n   241→\tif configVal != \"\" {\n   242→\t\treturn configVal\n   243→\t}\n   244→\treturn fallback\n   245→}\n   246→"}]},"parent_tool_use_id":null,"session_id":"83efa890-2574-44c5-a1f7-226ad3f671c0","uuid":"19f9c424-7a26-4152-98db-c2d85f8aa8b4","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloched/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"path/filepath\"\n\t\"syscall\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\thostpkg \"github.com/cloche-dev/cloche/internal/host\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"google.golang.org/grpc\"\n)\n\nfunc main() {\n\t// Load global config file (~/.config/cloche/config)\n\tglobalCfg, err := config.LoadGlobal()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n\t\tdefaults := config.Config{}\n\t\tglobalCfg = &defaults\n\t}\n\n\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, \"cloche.db\")\n\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, \"unix:///tmp/cloche.sock\")\n\n\tstore, err := sqlite.NewStore(dbPath)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer store.Close()\n\n\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n\t} else if n > 0 {\n\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n\t}\n\n\truntime, err := initRuntime(globalCfg)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n\n\tbroadcaster := logstream.NewBroadcaster()\n\n\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n\tsrv.SetLogStore(store)\n\tsrv.SetLogBroadcaster(broadcaster)\n\n\t// Set up evolution trigger\n\tevoTrigger := initEvolution(globalCfg, store, store)\n\tif evoTrigger != nil {\n\t\tsrv.SetEvolution(evoTrigger)\n\t}\n\n\tgrpcServer := grpc.NewServer()\n\tpb.RegisterClocheServiceServer(grpcServer, srv)\n\n\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n\n\tlis, err := listen(listenAddr)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n\t\tos.Exit(1)\n\t}\n\n\tvar httpServer *http.Server\n\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n\t\twebOpts := []web.HandlerOption{\n\t\t\tweb.WithContainerLogger(runtime),\n\t\t\tweb.WithLogStore(store),\n\t\t\tweb.WithLogBroadcaster(broadcaster),\n\t\t}\n\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n\t\tgo func() {\n\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n\t\t\t}\n\t\t}()\n\t}\n\n\t// Auto-execute main workflow for active projects\n\tautoRunActiveProjects(store, srv)\n\n\tsigCh := make(chan os.Signal, 1)\n\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n\tgo func() {\n\t\t<-sigCh\n\t\tif httpServer != nil {\n\t\t\thttpServer.Close()\n\t\t}\n\t\tgrpcServer.GracefulStop()\n\t}()\n\n\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n\tif err := grpcServer.Serve(lis); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n\nfunc initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n\n\tswitch runtimeType {\n\tcase \"local\":\n\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n\t\tif agentPath == \"\" {\n\t\t\t// Look for cloche-agent next to this binary\n\t\t\texe, err := os.Executable()\n\t\t\tif err == nil {\n\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n\t\t\t} else {\n\t\t\t\tagentPath = \"cloche-agent\"\n\t\t\t}\n\t\t}\n\t\treturn local.NewRuntime(agentPath), nil\n\tcase \"docker\":\n\t\treturn docker.NewRuntime()\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n\t}\n}\n\nfunc initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n\t// Load config from working directory (daemon-level defaults)\n\tcfg, err := config.Load(\".\")\n\tif err != nil || !cfg.Evolution.Enabled {\n\t\treturn nil\n\t}\n\n\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n\tif llmCmd == \"\" {\n\t\treturn nil\n\t}\n\n\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n\t\tRunFunc: func(projectDir, workflowName, runID string) {\n\t\t\t// Load per-project config for confidence threshold\n\t\t\tprojCfg, err := config.Load(projectDir)\n\t\t\tif err != nil {\n\t\t\t\tprojCfg = cfg // fall back to daemon config\n\t\t\t}\n\n\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n\t\t\t\tProjectDir:    projectDir,\n\t\t\t\tWorkflowName:  workflowName,\n\t\t\t\tLLM:           llm,\n\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n\t\t\t})\n\n\t\t\tctx := context.Background()\n\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n\t\t\t}\n\t\t},\n\t})\n\n\treturn trigger\n}\n\nfunc listen(addr string) (net.Listener, error) {\n\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n\t\tsockPath := addr[7:]\n\t\tos.Remove(sockPath)\n\t\treturn net.Listen(\"unix\", sockPath)\n\t}\n\treturn net.Listen(\"tcp\", addr)\n}\n\n// autoRunActiveProjects scans known projects for active = true in their config,\n// parses .cloche/host.cloche and executes the full host workflow step by step.\nfunc autoRunActiveProjects(store ports.RunStore, srv *adaptgrpc.ClocheServer) {\n\tctx := context.Background()\n\tprojects, err := store.ListProjects(ctx)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"startup: failed to list projects: %v\\n\", err)\n\t\treturn\n\t}\n\n\tfor _, projectDir := range projects {\n\t\tcfg, err := config.Load(projectDir)\n\t\tif err != nil || !cfg.Active {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Verify host.cloche exists before launching\n\t\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n\t\tif _, err := os.Stat(hostPath); err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"startup: skipping active project %s: %v\\n\", projectDir, err)\n\t\t\tcontinue\n\t\t}\n\n\t\tfmt.Fprintf(os.Stderr, \"startup: auto-running host workflow for active project %s\\n\", projectDir)\n\t\tgo func(projDir string) {\n\t\t\trunner := &hostpkg.Runner{\n\t\t\t\tDispatcher: srv,\n\t\t\t\tStore:      store,\n\t\t\t}\n\t\t\tresult, err := runner.Run(context.Background(), projDir)\n\t\t\tif err != nil {\n\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow failed for %s: %v\\n\", projDir, err)\n\t\t\t} else {\n\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow completed for %s: %s (run %s)\\n\", projDir, result.State, result.RunID)\n\t\t\t}\n\t\t}(projectDir)\n\t}\n}\n\n// envOrConfig returns the env var value if set, otherwise the config file\n// value if non-empty, otherwise the fallback default.\nfunc envOrConfig(envKey, configVal, fallback string) string {\n\tif v := os.Getenv(envKey); v != \"\" {\n\t\treturn v\n\t}\n\tif configVal != \"\" {\n\t\treturn configVal\n\t}\n\treturn fallback\n}\n","numLines":246,"startLine":1,"totalLines":246}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JSjcDhvo3UQKrC79YmZc9H","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"net/http\"\n     8→\t\"net/http/httptest\"\n     9→\t\"os\"\n    10→\t\"path/filepath\"\n    11→\t\"testing\"\n    12→\t\"time\"\n    13→\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    17→\t\"github.com/stretchr/testify/assert\"\n    18→\t\"github.com/stretchr/testify/require\"\n    19→)\n    20→\n    21→// mockContainerManager implements ContainerManager for testing.\n    22→type mockContainerManager struct {\n    23→\tcontainers map[string]bool // containerID -> exists\n    24→\trunning    map[string]bool // containerID -> running\n    25→\tremoved    []string\n    26→}\n    27→\n    28→func newMockContainerManager() *mockContainerManager {\n    29→\treturn &mockContainerManager{\n    30→\t\tcontainers: map[string]bool{},\n    31→\t\trunning:    map[string]bool{},\n    32→\t}\n    33→}\n    34→\n    35→func (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n    36→\treturn \"mock logs\", nil\n    37→}\n    38→\n    39→func (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n    40→\tif !m.containers[containerID] {\n    41→\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n    42→\t}\n    43→\tdelete(m.containers, containerID)\n    44→\tm.removed = append(m.removed, containerID)\n    45→\treturn nil\n    46→}\n    47→\n    48→func (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n    49→\tif !m.containers[containerID] {\n    50→\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n    51→\t}\n    52→\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n    53→}\n    54→\n    55→func setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n    56→\tt.Helper()\n    57→\tstore, err := sqlite.NewStore(\":memory:\")\n    58→\trequire.NoError(t, err)\n    59→\tt.Cleanup(func() { store.Close() })\n    60→\n    61→\th, err := NewHandler(store, store)\n    62→\trequire.NoError(t, err)\n    63→\treturn h, store\n    64→}\n    65→\n    66→func seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n    67→\tt.Helper()\n    68→\tseedRunWithProject(t, store, id, workflow, state, \"\")\n    69→}\n    70→\n    71→func seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n    72→\tt.Helper()\n    73→\tctx := context.Background()\n    74→\trun := domain.NewRun(id, workflow)\n    75→\trun.ProjectDir = projectDir\n    76→\tif state != domain.RunStatePending {\n    77→\t\trun.Start()\n    78→\t\trun.ContainerID = \"abc123def456789\"\n    79→\t}\n    80→\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n    81→\t\trun.Complete(state)\n    82→\t}\n    83→\tif state == domain.RunStateFailed {\n    84→\t\trun.ErrorMessage = \"something went wrong\"\n    85→\t}\n    86→\trequire.NoError(t, store.CreateRun(ctx, run))\n    87→}\n    88→\n    89→func TestRunsList_WithRuns(t *testing.T) {\n    90→\th, store := setupHandler(t)\n    91→\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n    92→\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n    93→\n    94→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n    95→\tw := httptest.NewRecorder()\n    96→\th.ServeHTTP(w, req)\n    97→\n    98→\tassert.Equal(t, http.StatusOK, w.Code)\n    99→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   100→\tbody := w.Body.String()\n   101→\tassert.Contains(t, body, \"test-run-1\")\n   102→\tassert.Contains(t, body, \"test-run-2\")\n   103→\tassert.Contains(t, body, \"badge-running\")\n   104→\tassert.Contains(t, body, \"badge-succeeded\")\n   105→\tassert.Contains(t, body, \"develop\")\n   106→\tassert.Contains(t, body, \"deploy\")\n   107→}\n   108→\n   109→func TestRunsList_Empty(t *testing.T) {\n   110→\th, _ := setupHandler(t)\n   111→\n   112→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   113→\tw := httptest.NewRecorder()\n   114→\th.ServeHTTP(w, req)\n   115→\n   116→\tassert.Equal(t, http.StatusOK, w.Code)\n   117→\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n   118→}\n   119→\n   120→func TestRunDetail_WithCaptures(t *testing.T) {\n   121→\th, store := setupHandler(t)\n   122→\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n   123→\n   124→\tctx := context.Background()\n   125→\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n   126→\t\tStepName:    \"implement\",\n   127→\t\tResult:      \"success\",\n   128→\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n   129→\t\tCompletedAt: time.Now(),\n   130→\t}))\n   131→\n   132→\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n   133→\tw := httptest.NewRecorder()\n   134→\th.ServeHTTP(w, req)\n   135→\n   136→\tassert.Equal(t, http.StatusOK, w.Code)\n   137→\tbody := w.Body.String()\n   138→\tassert.Contains(t, body, \"run-detail-1\")\n   139→\tassert.Contains(t, body, \"implement\")\n   140→}\n   141→\n   142→func TestRunDetail_AccordionStatePreserved(t *testing.T) {\n   143→\t// Verify the rendered page includes JavaScript that preserves accordion state\n   144→\t// during SSE polling updates (captures open/closed state before DOM rebuild).\n   145→\th, store := setupHandler(t)\n   146→\tseedRun(t, store, \"run-accordion-1\", \"develop\", domain.RunStateRunning)\n   147→\n   148→\tctx := context.Background()\n   149→\trequire.NoError(t, store.SaveCapture(ctx, \"run-accordion-1\", &domain.StepExecution{\n   150→\t\tStepName:    \"build\",\n   151→\t\tResult:      \"success\",\n   152→\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n   153→\t\tCompletedAt: time.Now(),\n   154→\t}))\n   155→\n   156→\treq := httptest.NewRequest(\"GET\", \"/runs/run-accordion-1\", nil)\n   157→\tw := httptest.NewRecorder()\n   158→\th.ServeHTTP(w, req)\n   159→\n   160→\tassert.Equal(t, http.StatusOK, w.Code)\n   161→\tbody := w.Body.String()\n   162→\n   163→\t// The poll function should capture accordion state before rebuilding the DOM\n   164→\tassert.Contains(t, body, \"openAccordions\")\n   165→\tassert.Contains(t, body, \"loadedOutputs\")\n   166→\t// Verify it restores loaded output content after DOM rebuild\n   167→\tassert.Contains(t, body, \"loadedOutputs[key]\")\n   168→}\n   169→\n   170→func TestRunDetail_NotFound(t *testing.T) {\n   171→\th, _ := setupHandler(t)\n   172→\n   173→\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n   174→\tw := httptest.NewRecorder()\n   175→\th.ServeHTTP(w, req)\n   176→\n   177→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   178→}\n   179→\n   180→func TestAPIRuns(t *testing.T) {\n   181→\th, store := setupHandler(t)\n   182→\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n   183→\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n   184→\n   185→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   186→\tw := httptest.NewRecorder()\n   187→\th.ServeHTTP(w, req)\n   188→\n   189→\tassert.Equal(t, http.StatusOK, w.Code)\n   190→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   191→\n   192→\tvar runs []apiRun\n   193→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n   194→\tassert.Len(t, runs, 2)\n   195→\n   196→\tids := map[string]bool{}\n   197→\tfor _, r := range runs {\n   198→\t\tids[r.ID] = true\n   199→\t}\n   200→\tassert.True(t, ids[\"api-run-1\"])\n   201→\tassert.True(t, ids[\"api-run-2\"])\n   202→}\n   203→\n   204→func TestAPIRunDetail(t *testing.T) {\n   205→\th, store := setupHandler(t)\n   206→\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n   207→\n   208→\tctx := context.Background()\n   209→\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n   210→\t\tStepName:    \"build\",\n   211→\t\tResult:      \"success\",\n   212→\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n   213→\t\tCompletedAt: time.Now(),\n   214→\t}))\n   215→\n   216→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n   217→\tw := httptest.NewRecorder()\n   218→\th.ServeHTTP(w, req)\n   219→\n   220→\tassert.Equal(t, http.StatusOK, w.Code)\n   221→\n   222→\tvar detail apiRunDetail\n   223→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   224→\tassert.Equal(t, \"api-detail-1\", detail.ID)\n   225→\tassert.Equal(t, \"running\", detail.State)\n   226→\tassert.Len(t, detail.Steps, 1)\n   227→\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n   228→\tassert.NotEmpty(t, detail.Steps[0].Duration)\n   229→}\n   230→\n   231→func TestStaticCSS(t *testing.T) {\n   232→\th, _ := setupHandler(t)\n   233→\n   234→\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n   235→\tw := httptest.NewRecorder()\n   236→\th.ServeHTTP(w, req)\n   237→\n   238→\tassert.Equal(t, http.StatusOK, w.Code)\n   239→\tassert.Contains(t, w.Body.String(), \":root\")\n   240→\tassert.Contains(t, w.Body.String(), \"badge-running\")\n   241→}\n   242→\n   243→func TestHelpers(t *testing.T) {\n   244→\tt.Run(\"stateColor\", func(t *testing.T) {\n   245→\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n   246→\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n   247→\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n   248→\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n   249→\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n   250→\t})\n   251→\n   252→\tt.Run(\"formatTime\", func(t *testing.T) {\n   253→\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n   254→\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n   255→\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n   256→\t})\n   257→\n   258→\tt.Run(\"formatDuration\", func(t *testing.T) {\n   259→\t\tnow := time.Now()\n   260→\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n   261→\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n   262→\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n   263→\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n   264→\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n   265→\t})\n   266→\n   267→\tt.Run(\"truncate\", func(t *testing.T) {\n   268→\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n   269→\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n   270→\t})\n   271→\n   272→\tt.Run(\"shortContainerID\", func(t *testing.T) {\n   273→\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n   274→\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n   275→\t})\n   276→\n   277→\tt.Run(\"projectLabels\", func(t *testing.T) {\n   278→\t\t// No conflict: show base name only\n   279→\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n   280→\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n   281→\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n   282→\n   283→\t\t// Conflict: two dirs share the same base name\n   284→\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n   285→\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n   286→\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n   287→\n   288→\t\t// Mixed: some conflict, some don't\n   289→\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n   290→\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n   291→\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n   292→\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n   293→\n   294→\t\t// Empty list\n   295→\t\tlabels = projectLabels(nil)\n   296→\t\tassert.Empty(t, labels)\n   297→\t})\n   298→}\n   299→\n   300→func TestRunsList_ProjectFilter(t *testing.T) {\n   301→\th, store := setupHandler(t)\n   302→\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   303→\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   304→\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   305→\n   306→\t// Without filter: all runs shown\n   307→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   308→\tw := httptest.NewRecorder()\n   309→\th.ServeHTTP(w, req)\n   310→\tassert.Equal(t, http.StatusOK, w.Code)\n   311→\tbody := w.Body.String()\n   312→\tassert.Contains(t, body, \"run-a1\")\n   313→\tassert.Contains(t, body, \"run-b1\")\n   314→\n   315→\t// With project filter: only matching runs\n   316→\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n   317→\tw = httptest.NewRecorder()\n   318→\th.ServeHTTP(w, req)\n   319→\tassert.Equal(t, http.StatusOK, w.Code)\n   320→\tbody = w.Body.String()\n   321→\tassert.Contains(t, body, \"run-a1\")\n   322→\tassert.Contains(t, body, \"run-a2\")\n   323→\tassert.NotContains(t, body, \"run-b1\")\n   324→}\n   325→\n   326→func TestRunsList_ProjectColumn(t *testing.T) {\n   327→\th, store := setupHandler(t)\n   328→\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n   329→\n   330→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   331→\tw := httptest.NewRecorder()\n   332→\th.ServeHTTP(w, req)\n   333→\tassert.Equal(t, http.StatusOK, w.Code)\n   334→\tbody := w.Body.String()\n   335→\tassert.Contains(t, body, \"myproject\")\n   336→\tassert.Contains(t, body, \"Project\")\n   337→}\n   338→\n   339→func TestAPIRuns_ProjectFilter(t *testing.T) {\n   340→\th, store := setupHandler(t)\n   341→\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   342→\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   343→\n   344→\t// Without filter: all runs\n   345→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   346→\tw := httptest.NewRecorder()\n   347→\th.ServeHTTP(w, req)\n   348→\tassert.Equal(t, http.StatusOK, w.Code)\n   349→\n   350→\tvar allRuns []apiRun\n   351→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n   352→\tassert.Len(t, allRuns, 2)\n   353→\n   354→\t// With filter: only matching\n   355→\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n   356→\tw = httptest.NewRecorder()\n   357→\th.ServeHTTP(w, req)\n   358→\tassert.Equal(t, http.StatusOK, w.Code)\n   359→\n   360→\tvar filtered []apiRun\n   361→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n   362→\tassert.Len(t, filtered, 1)\n   363→\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n   364→\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n   365→\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n   366→}\n   367→\n   368→func setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n   369→\tt.Helper()\n   370→\tstore, err := sqlite.NewStore(\":memory:\")\n   371→\trequire.NoError(t, err)\n   372→\tt.Cleanup(func() { store.Close() })\n   373→\n   374→\tmgr := newMockContainerManager()\n   375→\th, err := NewHandler(store, store, WithContainerManager(mgr))\n   376→\trequire.NoError(t, err)\n   377→\treturn h, store, mgr\n   378→}\n   379→\n   380→func seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n   381→\tt.Helper()\n   382→\tctx := context.Background()\n   383→\trun := domain.NewRun(id, workflow)\n   384→\trun.ProjectDir = projectDir\n   385→\trun.Start()\n   386→\trun.ContainerID = containerID\n   387→\trun.ContainerKept = kept\n   388→\trun.Complete(domain.RunStateSucceeded)\n   389→\trequire.NoError(t, store.CreateRun(ctx, run))\n   390→\tif kept {\n   391→\t\tmgr.containers[containerID] = true\n   392→\t}\n   393→}\n   394→\n   395→func TestRunDetail_ContainerRunning(t *testing.T) {\n   396→\th, store, mgr := setupHandlerWithContainerManager(t)\n   397→\n   398→\tctx := context.Background()\n   399→\trun := domain.NewRun(\"run-cr\", \"develop\")\n   400→\trun.ProjectDir = \"/proj\"\n   401→\trun.Start()\n   402→\trun.ContainerID = \"cid-running\"\n   403→\trequire.NoError(t, store.CreateRun(ctx, run))\n   404→\tmgr.containers[\"cid-running\"] = true\n   405→\tmgr.running[\"cid-running\"] = true\n   406→\n   407→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n   408→\tw := httptest.NewRecorder()\n   409→\th.ServeHTTP(w, req)\n   410→\n   411→\tassert.Equal(t, http.StatusOK, w.Code)\n   412→\tbody := w.Body.String()\n   413→\tassert.Contains(t, body, \"Container running\")\n   414→\tassert.Contains(t, body, `badge-running\">Container running`)\n   415→}\n   416→\n   417→func TestRunDetail_ContainerStopped(t *testing.T) {\n   418→\th, store, mgr := setupHandlerWithContainerManager(t)\n   419→\n   420→\tctx := context.Background()\n   421→\trun := domain.NewRun(\"run-cs\", \"develop\")\n   422→\trun.ProjectDir = \"/proj\"\n   423→\trun.Start()\n   424→\trun.ContainerID = \"cid-stopped\"\n   425→\trun.ContainerKept = false\n   426→\trun.Complete(domain.RunStateSucceeded)\n   427→\trequire.NoError(t, store.CreateRun(ctx, run))\n   428→\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n   429→\n   430→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n   431→\tw := httptest.NewRecorder()\n   432→\th.ServeHTTP(w, req)\n   433→\n   434→\tassert.Equal(t, http.StatusOK, w.Code)\n   435→\tbody := w.Body.String()\n   436→\tassert.Contains(t, body, \"Container stopped\")\n   437→\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n   438→}\n   439→\n   440→func TestRunDetail_ContainerAvailable(t *testing.T) {\n   441→\th, store, mgr := setupHandlerWithContainerManager(t)\n   442→\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n   443→\n   444→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n   445→\tw := httptest.NewRecorder()\n   446→\th.ServeHTTP(w, req)\n   447→\n   448→\tassert.Equal(t, http.StatusOK, w.Code)\n   449→\tbody := w.Body.String()\n   450→\tassert.Contains(t, body, \"Container available\")\n   451→\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n   452→\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n   453→}\n   454→\n   455→func TestRunDetail_ContainerRemoved(t *testing.T) {\n   456→\th, store, _ := setupHandlerWithContainerManager(t)\n   457→\n   458→\tctx := context.Background()\n   459→\trun := domain.NewRun(\"run-c2\", \"develop\")\n   460→\trun.ProjectDir = \"/proj\"\n   461→\trun.Start()\n   462→\trun.ContainerID = \"cid-gone\"\n   463→\trun.ContainerKept = false\n   464→\trun.Complete(domain.RunStateSucceeded)\n   465→\trequire.NoError(t, store.CreateRun(ctx, run))\n   466→\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n   467→\n   468→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n   469→\tw := httptest.NewRecorder()\n   470→\th.ServeHTTP(w, req)\n   471→\n   472→\tassert.Equal(t, http.StatusOK, w.Code)\n   473→\tbody := w.Body.String()\n   474→\tassert.Contains(t, body, \"Container removed\")\n   475→\tassert.Contains(t, body, `badge-pending\">Container removed`)\n   476→}\n   477→\n   478→func TestAPIDeleteContainer_Success(t *testing.T) {\n   479→\th, store, mgr := setupHandlerWithContainerManager(t)\n   480→\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n   481→\n   482→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n   483→\tw := httptest.NewRecorder()\n   484→\th.ServeHTTP(w, req)\n   485→\n   486→\tassert.Equal(t, http.StatusOK, w.Code)\n   487→\n   488→\tvar resp map[string]string\n   489→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n   490→\tassert.Equal(t, \"ok\", resp[\"status\"])\n   491→\n   492→\t// Verify container was removed\n   493→\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n   494→\n   495→\t// Verify run was updated\n   496→\trun, err := store.GetRun(context.Background(), \"run-del1\")\n   497→\trequire.NoError(t, err)\n   498→\tassert.False(t, run.ContainerKept)\n   499→}\n   500→\n   501→func TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n   502→\th, _, _ := setupHandlerWithContainerManager(t)\n   503→\n   504→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n   505→\tw := httptest.NewRecorder()\n   506→\th.ServeHTTP(w, req)\n   507→\n   508→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   509→}\n   510→\n   511→func TestAPIDeleteContainer_NoManager(t *testing.T) {\n   512→\th, store := setupHandler(t) // no container manager\n   513→\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n   514→\n   515→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n   516→\tw := httptest.NewRecorder()\n   517→\th.ServeHTTP(w, req)\n   518→\n   519→\tassert.Equal(t, http.StatusBadRequest, w.Code)\n   520→}\n   521→\n   522→func TestAPIRunDetail_ContainerState(t *testing.T) {\n   523→\th, store, mgr := setupHandlerWithContainerManager(t)\n   524→\n   525→\t// Seed a running container\n   526→\tctx := context.Background()\n   527→\trun := domain.NewRun(\"api-cs1\", \"develop\")\n   528→\trun.ProjectDir = \"/proj\"\n   529→\trun.Start()\n   530→\trun.ContainerID = \"cid-api-running\"\n   531→\trequire.NoError(t, store.CreateRun(ctx, run))\n   532→\tmgr.containers[\"cid-api-running\"] = true\n   533→\tmgr.running[\"cid-api-running\"] = true\n   534→\n   535→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n   536→\tw := httptest.NewRecorder()\n   537→\th.ServeHTTP(w, req)\n   538→\n   539→\tassert.Equal(t, http.StatusOK, w.Code)\n   540→\n   541→\tvar detail apiRunDetail\n   542→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   543→\tassert.Equal(t, \"running\", detail.ContainerState)\n   544→\n   545→\t// Now stop it\n   546→\tmgr.running[\"cid-api-running\"] = false\n   547→\n   548→\tw = httptest.NewRecorder()\n   549→\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n   550→\n   551→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   552→\tassert.Equal(t, \"stopped\", detail.ContainerState)\n   553→}\n   554→\n   555→func TestRunsList_ContainerCount(t *testing.T) {\n   556→\th, store, mgr := setupHandlerWithContainerManager(t)\n   557→\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n   558→\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n   559→\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n   560→\n   561→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   562→\tw := httptest.NewRecorder()\n   563→\th.ServeHTTP(w, req)\n   564→\n   565→\tassert.Equal(t, http.StatusOK, w.Code)\n   566→\tbody := w.Body.String()\n   567→\t// alpha has 2 retained containers\n   568→\tassert.Contains(t, body, \"2 containers\")\n   569→\t// beta has 0, so no count should appear\n   570→\tassert.NotContains(t, body, \"0 container\")\n   571→}\n   572→\n   573→func TestAPIProjects(t *testing.T) {\n   574→\th, store := setupHandler(t)\n   575→\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   576→\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   577→\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   578→\n   579→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   580→\tw := httptest.NewRecorder()\n   581→\th.ServeHTTP(w, req)\n   582→\tassert.Equal(t, http.StatusOK, w.Code)\n   583→\n   584→\ttype apiHealth struct {\n   585→\t\tStatus string `json:\"status\"`\n   586→\t\tPassed int    `json:\"passed\"`\n   587→\t\tFailed int    `json:\"failed\"`\n   588→\t\tTotal  int    `json:\"total\"`\n   589→\t}\n   590→\ttype project struct {\n   591→\t\tDir         string    `json:\"dir\"`\n   592→\t\tLabel       string    `json:\"label\"`\n   593→\t\tHealth      apiHealth `json:\"health\"`\n   594→\t\tActiveCount int       `json:\"active_count\"`\n   595→\t}\n   596→\tvar projects []project\n   597→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   598→\tassert.Len(t, projects, 2)\n   599→\n   600→\tbyDir := map[string]project{}\n   601→\tfor _, p := range projects {\n   602→\t\tbyDir[p.Dir] = p\n   603→\t}\n   604→\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n   605→\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n   606→\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n   607→\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n   608→\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n   609→\t// beta has 1 running = blue (all in-progress), 1 active\n   610→\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n   611→\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n   612→}\n   613→\n   614→func TestProjectOverview_WithProjects(t *testing.T) {\n   615→\th, store := setupHandler(t)\n   616→\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   617→\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   618→\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   619→\n   620→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   621→\tw := httptest.NewRecorder()\n   622→\th.ServeHTTP(w, req)\n   623→\n   624→\tassert.Equal(t, http.StatusOK, w.Code)\n   625→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   626→\tbody := w.Body.String()\n   627→\t// Project cards should be present\n   628→\tassert.Contains(t, body, \"project-card\")\n   629→\tassert.Contains(t, body, \"alpha\")\n   630→\tassert.Contains(t, body, \"beta\")\n   631→\t// Health dots\n   632→\tassert.Contains(t, body, \"health-dot\")\n   633→\t// Run history dots\n   634→\tassert.Contains(t, body, \"run-dot\")\n   635→\t// Quick actions\n   636→\tassert.Contains(t, body, \"View Runs\")\n   637→}\n   638→\n   639→func TestProjectOverview_Empty(t *testing.T) {\n   640→\th, _ := setupHandler(t)\n   641→\n   642→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   643→\tw := httptest.NewRecorder()\n   644→\th.ServeHTTP(w, req)\n   645→\n   646→\tassert.Equal(t, http.StatusOK, w.Code)\n   647→\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n   648→}\n   649→\n   650→func TestHealthColor(t *testing.T) {\n   651→\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n   652→\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n   653→\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n   654→\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n   655→\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n   656→\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n   657→}\n   658→\n   659→func TestAPIProjects_HealthData(t *testing.T) {\n   660→\th, store := setupHandler(t)\n   661→\t// alpha: 3 succeeded, 1 failed → yellow\n   662→\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   663→\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   664→\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   665→\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   666→\n   667→\t// beta: all succeeded → green\n   668→\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   669→\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   670→\n   671→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   672→\tw := httptest.NewRecorder()\n   673→\th.ServeHTTP(w, req)\n   674→\tassert.Equal(t, http.StatusOK, w.Code)\n   675→\n   676→\ttype health struct {\n   677→\t\tStatus string `json:\"status\"`\n   678→\t\tPassed int    `json:\"passed\"`\n   679→\t\tFailed int    `json:\"failed\"`\n   680→\t\tTotal  int    `json:\"total\"`\n   681→\t}\n   682→\ttype project struct {\n   683→\t\tDir    string `json:\"dir\"`\n   684→\t\tLabel  string `json:\"label\"`\n   685→\t\tHealth health `json:\"health\"`\n   686→\t}\n   687→\tvar projects []project\n   688→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   689→\tassert.Len(t, projects, 2)\n   690→\n   691→\tbyDir := map[string]project{}\n   692→\tfor _, p := range projects {\n   693→\t\tbyDir[p.Dir] = p\n   694→\t}\n   695→\n   696→\talpha := byDir[\"/home/user/alpha\"]\n   697→\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n   698→\tassert.Equal(t, 3, alpha.Health.Passed)\n   699→\tassert.Equal(t, 1, alpha.Health.Failed)\n   700→\tassert.Equal(t, 4, alpha.Health.Total)\n   701→\n   702→\tbeta := byDir[\"/home/user/beta\"]\n   703→\tassert.Equal(t, \"green\", beta.Health.Status)\n   704→\tassert.Equal(t, 2, beta.Health.Passed)\n   705→\tassert.Equal(t, 0, beta.Health.Failed)\n   706→\tassert.Equal(t, 2, beta.Health.Total)\n   707→}\n   708→\n   709→func TestResolveFileRef(t *testing.T) {\n   710→\t// Create a temp directory with a test file\n   711→\tdir := t.TempDir()\n   712→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \"prompts\"), 0o755))\n   713→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \"prompts\", \"implement.md\"), []byte(\"# Implement\\nDo the thing.\"), 0o644))\n   714→\n   715→\tt.Run(\"file() reference resolves to contents\", func(t *testing.T) {\n   716→\t\tcontent, err := resolveFileRef(`file(\"prompts/implement.md\")`, dir)\n   717→\t\trequire.NoError(t, err)\n   718→\t\tassert.Equal(t, \"# Implement\\nDo the thing.\", content)\n   719→\t})\n   720→\n   721→\tt.Run(\"file() reference with missing file returns error\", func(t *testing.T) {\n   722→\t\t_, err := resolveFileRef(`file(\"prompts/nonexistent.md\")`, dir)\n   723→\t\tassert.Error(t, err)\n   724→\t})\n   725→\n   726→\tt.Run(\"plain string returned as-is\", func(t *testing.T) {\n   727→\t\tcontent, err := resolveFileRef(\"echo hello\", dir)\n   728→\t\trequire.NoError(t, err)\n   729→\t\tassert.Equal(t, \"echo hello\", content)\n   730→\t})\n   731→\n   732→\tt.Run(\"quoted string returned as-is\", func(t *testing.T) {\n   733→\t\tcontent, err := resolveFileRef(`\"some value\"`, dir)\n   734→\t\trequire.NoError(t, err)\n   735→\t\tassert.Equal(t, `\"some value\"`, content)\n   736→\t})\n   737→}\n   738→\n   739→func TestAPIStepContent_FileRef(t *testing.T) {\n   740→\th, store := setupHandler(t)\n   741→\n   742→\t// Create a temp project directory with a workflow and prompt file\n   743→\tdir := t.TempDir()\n   744→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0o755))\n   745→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"Build the feature.\"), 0o644))\n   746→\n   747→\tworkflowContent := `workflow \"develop\" {\n   748→    step implement {\n   749→        prompt = file(\".cloche/prompts/implement.md\")\n   750→        results = [success, fail]\n   751→    }\n   752→    implement:success -> done\n   753→    implement:fail -> abort\n   754→}\n   755→`\n   756→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"), []byte(workflowContent), 0o644))\n   757→\n   758→\t// Seed a run so the project is known\n   759→\tseedRunWithProject(t, store, \"sc-1\", \"develop\", domain.RunStateRunning, dir)\n   760→\n   761→\t// Request step content\n   762→\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+filepath.Base(dir)+\"/workflows/develop/steps/implement/content\", nil)\n   763→\tw := httptest.NewRecorder()\n   764→\th.ServeHTTP(w, req)\n   765→\n   766→\tassert.Equal(t, http.StatusOK, w.Code)\n   767→\tassert.Equal(t, \"Build the feature.\", w.Body.String())\n   768→}\n   769→\n   770→func TestAPIProjects_HealthNoRuns(t *testing.T) {\n   771→\th, _ := setupHandler(t)\n   772→\n   773→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   774→\tw := httptest.NewRecorder()\n   775→\th.ServeHTTP(w, req)\n   776→\tassert.Equal(t, http.StatusOK, w.Code)\n   777→\n   778→\t// No projects means empty array\n   779→\ttype project struct {\n   780→\t\tDir   string `json:\"dir\"`\n   781→\t\tLabel string `json:\"label\"`\n   782→\t}\n   783→\tvar projects []project\n   784→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   785→\tassert.Empty(t, projects)\n   786→}\n   787→"}]},"parent_tool_use_id":null,"session_id":"83efa890-2574-44c5-a1f7-226ad3f671c0","uuid":"865c7956-641f-477a-84cd-7071d19b2725","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler_test.go","content":"package web\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// mockContainerManager implements ContainerManager for testing.\ntype mockContainerManager struct {\n\tcontainers map[string]bool // containerID -> exists\n\trunning    map[string]bool // containerID -> running\n\tremoved    []string\n}\n\nfunc newMockContainerManager() *mockContainerManager {\n\treturn &mockContainerManager{\n\t\tcontainers: map[string]bool{},\n\t\trunning:    map[string]bool{},\n\t}\n}\n\nfunc (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n\treturn \"mock logs\", nil\n}\n\nfunc (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n\tif !m.containers[containerID] {\n\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\tdelete(m.containers, containerID)\n\tm.removed = append(m.removed, containerID)\n\treturn nil\n}\n\nfunc (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n\tif !m.containers[containerID] {\n\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n}\n\nfunc setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store)\n\trequire.NoError(t, err)\n\treturn h, store\n}\n\nfunc seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n\tt.Helper()\n\tseedRunWithProject(t, store, id, workflow, state, \"\")\n}\n\nfunc seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\tif state != domain.RunStatePending {\n\t\trun.Start()\n\t\trun.ContainerID = \"abc123def456789\"\n\t}\n\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n\t\trun.Complete(state)\n\t}\n\tif state == domain.RunStateFailed {\n\t\trun.ErrorMessage = \"something went wrong\"\n\t}\n\trequire.NoError(t, store.CreateRun(ctx, run))\n}\n\nfunc TestRunsList_WithRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"test-run-1\")\n\tassert.Contains(t, body, \"test-run-2\")\n\tassert.Contains(t, body, \"badge-running\")\n\tassert.Contains(t, body, \"badge-succeeded\")\n\tassert.Contains(t, body, \"develop\")\n\tassert.Contains(t, body, \"deploy\")\n}\n\nfunc TestRunsList_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n}\n\nfunc TestRunDetail_WithCaptures(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"implement\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-detail-1\")\n\tassert.Contains(t, body, \"implement\")\n}\n\nfunc TestRunDetail_AccordionStatePreserved(t *testing.T) {\n\t// Verify the rendered page includes JavaScript that preserves accordion state\n\t// during SSE polling updates (captures open/closed state before DOM rebuild).\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"run-accordion-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"run-accordion-1\", &domain.StepExecution{\n\t\tStepName:    \"build\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-accordion-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\n\t// The poll function should capture accordion state before rebuilding the DOM\n\tassert.Contains(t, body, \"openAccordions\")\n\tassert.Contains(t, body, \"loadedOutputs\")\n\t// Verify it restores loaded output content after DOM rebuild\n\tassert.Contains(t, body, \"loadedOutputs[key]\")\n}\n\nfunc TestRunDetail_NotFound(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar runs []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n\tassert.Len(t, runs, 2)\n\n\tids := map[string]bool{}\n\tfor _, r := range runs {\n\t\tids[r.ID] = true\n\t}\n\tassert.True(t, ids[\"api-run-1\"])\n\tassert.True(t, ids[\"api-run-2\"])\n}\n\nfunc TestAPIRunDetail(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"build\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"api-detail-1\", detail.ID)\n\tassert.Equal(t, \"running\", detail.State)\n\tassert.Len(t, detail.Steps, 1)\n\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n\tassert.NotEmpty(t, detail.Steps[0].Duration)\n}\n\nfunc TestStaticCSS(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \":root\")\n\tassert.Contains(t, w.Body.String(), \"badge-running\")\n}\n\nfunc TestHelpers(t *testing.T) {\n\tt.Run(\"stateColor\", func(t *testing.T) {\n\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n\t})\n\n\tt.Run(\"formatTime\", func(t *testing.T) {\n\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n\t})\n\n\tt.Run(\"formatDuration\", func(t *testing.T) {\n\t\tnow := time.Now()\n\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n\t})\n\n\tt.Run(\"truncate\", func(t *testing.T) {\n\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n\t})\n\n\tt.Run(\"shortContainerID\", func(t *testing.T) {\n\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n\t})\n\n\tt.Run(\"projectLabels\", func(t *testing.T) {\n\t\t// No conflict: show base name only\n\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n\n\t\t// Conflict: two dirs share the same base name\n\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n\n\t\t// Mixed: some conflict, some don't\n\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n\n\t\t// Empty list\n\t\tlabels = projectLabels(nil)\n\t\tassert.Empty(t, labels)\n\t})\n}\n\nfunc TestRunsList_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs shown\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-b1\")\n\n\t// With project filter: only matching runs\n\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody = w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-a2\")\n\tassert.NotContains(t, body, \"run-b1\")\n}\n\nfunc TestRunsList_ProjectColumn(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"myproject\")\n\tassert.Contains(t, body, \"Project\")\n}\n\nfunc TestAPIRuns_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar allRuns []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n\tassert.Len(t, allRuns, 2)\n\n\t// With filter: only matching\n\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar filtered []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n\tassert.Len(t, filtered, 1)\n\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n}\n\nfunc setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\tmgr := newMockContainerManager()\n\th, err := NewHandler(store, store, WithContainerManager(mgr))\n\trequire.NoError(t, err)\n\treturn h, store, mgr\n}\n\nfunc seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\trun.Start()\n\trun.ContainerID = containerID\n\trun.ContainerKept = kept\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tif kept {\n\t\tmgr.containers[containerID] = true\n\t}\n}\n\nfunc TestRunDetail_ContainerRunning(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cr\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-running\"] = true\n\tmgr.running[\"cid-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container running\")\n\tassert.Contains(t, body, `badge-running\">Container running`)\n}\n\nfunc TestRunDetail_ContainerStopped(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cs\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-stopped\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container stopped\")\n\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n}\n\nfunc TestRunDetail_ContainerAvailable(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container available\")\n\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n}\n\nfunc TestRunDetail_ContainerRemoved(t *testing.T) {\n\th, store, _ := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-c2\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-gone\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container removed\")\n\tassert.Contains(t, body, `badge-pending\">Container removed`)\n}\n\nfunc TestAPIDeleteContainer_Success(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"ok\", resp[\"status\"])\n\n\t// Verify container was removed\n\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n\n\t// Verify run was updated\n\trun, err := store.GetRun(context.Background(), \"run-del1\")\n\trequire.NoError(t, err)\n\tassert.False(t, run.ContainerKept)\n}\n\nfunc TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n\th, _, _ := setupHandlerWithContainerManager(t)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIDeleteContainer_NoManager(t *testing.T) {\n\th, store := setupHandler(t) // no container manager\n\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusBadRequest, w.Code)\n}\n\nfunc TestAPIRunDetail_ContainerState(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\t// Seed a running container\n\tctx := context.Background()\n\trun := domain.NewRun(\"api-cs1\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-api-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-api-running\"] = true\n\tmgr.running[\"cid-api-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"running\", detail.ContainerState)\n\n\t// Now stop it\n\tmgr.running[\"cid-api-running\"] = false\n\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"stopped\", detail.ContainerState)\n}\n\nfunc TestRunsList_ContainerCount(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\t// alpha has 2 retained containers\n\tassert.Contains(t, body, \"2 containers\")\n\t// beta has 0, so no count should appear\n\tassert.NotContains(t, body, \"0 container\")\n}\n\nfunc TestAPIProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n\t// beta has 1 running = blue (all in-progress), 1 active\n\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n}\n\nfunc TestProjectOverview_WithProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\t// Project cards should be present\n\tassert.Contains(t, body, \"project-card\")\n\tassert.Contains(t, body, \"alpha\")\n\tassert.Contains(t, body, \"beta\")\n\t// Health dots\n\tassert.Contains(t, body, \"health-dot\")\n\t// Run history dots\n\tassert.Contains(t, body, \"run-dot\")\n\t// Quick actions\n\tassert.Contains(t, body, \"View Runs\")\n}\n\nfunc TestProjectOverview_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n}\n\nfunc TestHealthColor(t *testing.T) {\n\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n}\n\nfunc TestAPIProjects_HealthData(t *testing.T) {\n\th, store := setupHandler(t)\n\t// alpha: 3 succeeded, 1 failed → yellow\n\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\t// beta: all succeeded → green\n\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype health struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir    string `json:\"dir\"`\n\t\tLabel  string `json:\"label\"`\n\t\tHealth health `json:\"health\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\n\talpha := byDir[\"/home/user/alpha\"]\n\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n\tassert.Equal(t, 3, alpha.Health.Passed)\n\tassert.Equal(t, 1, alpha.Health.Failed)\n\tassert.Equal(t, 4, alpha.Health.Total)\n\n\tbeta := byDir[\"/home/user/beta\"]\n\tassert.Equal(t, \"green\", beta.Health.Status)\n\tassert.Equal(t, 2, beta.Health.Passed)\n\tassert.Equal(t, 0, beta.Health.Failed)\n\tassert.Equal(t, 2, beta.Health.Total)\n}\n\nfunc TestResolveFileRef(t *testing.T) {\n\t// Create a temp directory with a test file\n\tdir := t.TempDir()\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \"prompts\"), 0o755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \"prompts\", \"implement.md\"), []byte(\"# Implement\\nDo the thing.\"), 0o644))\n\n\tt.Run(\"file() reference resolves to contents\", func(t *testing.T) {\n\t\tcontent, err := resolveFileRef(`file(\"prompts/implement.md\")`, dir)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, \"# Implement\\nDo the thing.\", content)\n\t})\n\n\tt.Run(\"file() reference with missing file returns error\", func(t *testing.T) {\n\t\t_, err := resolveFileRef(`file(\"prompts/nonexistent.md\")`, dir)\n\t\tassert.Error(t, err)\n\t})\n\n\tt.Run(\"plain string returned as-is\", func(t *testing.T) {\n\t\tcontent, err := resolveFileRef(\"echo hello\", dir)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, \"echo hello\", content)\n\t})\n\n\tt.Run(\"quoted string returned as-is\", func(t *testing.T) {\n\t\tcontent, err := resolveFileRef(`\"some value\"`, dir)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, `\"some value\"`, content)\n\t})\n}\n\nfunc TestAPIStepContent_FileRef(t *testing.T) {\n\th, store := setupHandler(t)\n\n\t// Create a temp project directory with a workflow and prompt file\n\tdir := t.TempDir()\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0o755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"Build the feature.\"), 0o644))\n\n\tworkflowContent := `workflow \"develop\" {\n    step implement {\n        prompt = file(\".cloche/prompts/implement.md\")\n        results = [success, fail]\n    }\n    implement:success -> done\n    implement:fail -> abort\n}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"), []byte(workflowContent), 0o644))\n\n\t// Seed a run so the project is known\n\tseedRunWithProject(t, store, \"sc-1\", \"develop\", domain.RunStateRunning, dir)\n\n\t// Request step content\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+filepath.Base(dir)+\"/workflows/develop/steps/implement/content\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Equal(t, \"Build the feature.\", w.Body.String())\n}\n\nfunc TestAPIProjects_HealthNoRuns(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\t// No projects means empty array\n\ttype project struct {\n\t\tDir   string `json:\"dir\"`\n\t\tLabel string `json:\"label\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Empty(t, projects)\n}\n","numLines":787,"startLine":1,"totalLines":787}}}
