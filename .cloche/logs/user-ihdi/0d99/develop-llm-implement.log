tions\">\n            <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary\">View Runs</a>\n        </div>\n    </div>\n    {{end}}\n</div>\n{{else}}\n<p class=\"empty\">No projects yet. Start a workflow run to see projects here.</p>\n{{end}}\n{{end}}\n\n{{define \"scripts\"}}\n{{end}}\n","structuredPatch":[{"oldStart":25,"oldLines":6,"newStart":25,"newLines":7,"lines":["         </div>","         <div class=\"project-actions\">","             <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary\">View Runs</a>","+            <button class=\"btn btn-secondary\" onclick=\"triggerOrchestrator(this, '{{.Label}}')\">Trigger Orchestrator</button>","         </div>","     </div>","     {{end}}"]}],"userModified":false,"replaceAll":false}}
