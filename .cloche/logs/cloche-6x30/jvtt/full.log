essage GetVersionRequest {}\n   174→\n   175→message GetVersionResponse {\n   176→  string version = 1;\n   177→}\n   178→"}]},"parent_tool_use_id":null,"session_id":"19ca68fe-1a86-4684-9b56-9a6129bb87d8","uuid":"a3caad7c-5c0f-43b1-88cf-082b4679784e","timestamp":"2026-03-18T19:06:45.008Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/api/proto/cloche/v1/cloche.proto","content":"syntax = \"proto3\";\n\npackage cloche.v1;\n\noption go_package = \"github.com/cloche-dev/cloche/api/clochepb\";\n\nservice ClocheService {\n  rpc RunWorkflow(RunWorkflowRequest) returns (RunWorkflowResponse);\n  rpc GetStatus(GetStatusRequest) returns (GetStatusResponse);\n  rpc StreamLogs(StreamLogsRequest) returns (stream LogEntry);\n  rpc StopRun(StopRunRequest) returns (StopRunResponse);\n  rpc ListRuns(ListRunsRequest) returns (ListRunsResponse);\n  rpc Shutdown(ShutdownRequest) returns (ShutdownResponse);\n  rpc DeleteContainer(DeleteContainerRequest) returns (DeleteContainerResponse);\n\n  rpc EnableLoop(EnableLoopRequest) returns (EnableLoopResponse);\n  rpc DisableLoop(DisableLoopRequest) returns (DisableLoopResponse);\n  rpc ResumeLoop(ResumeLoopRequest) returns (ResumeLoopResponse);\n\n  rpc GetProjectInfo(GetProjectInfoRequest) returns (GetProjectInfoResponse);\n\n  rpc GetVersion(GetVersionRequest) returns (GetVersionResponse);\n\n  // ResumeRun is handled via gRPC metadata on the RunWorkflow RPC:\n  //   x-cloche-resume-run-id: the run ID to resume\n  //   x-cloche-resume-step: optional step name to resume from\n  // When these headers are present, RunWorkflow enters resume mode instead\n  // of creating a new run.\n}\n\nmessage RunWorkflowRequest {\n  string workflow_name = 1;\n  string project_dir = 2;\n  string image = 3;\n  string prompt = 4;\n  bool keep_container = 5;\n  string title = 6;\n  string issue_id = 7;\n}\n\nmessage RunWorkflowResponse {\n  string run_id = 1;\n}\n\nmessage GetStatusRequest {\n  string run_id = 1;\n}\n\nmessage GetStatusResponse {\n  string run_id = 1;\n  string workflow_name = 2;\n  string state = 3;\n  string current_step = 4;\n  repeated StepExecutionStatus step_executions = 5;\n  string error_message = 6;\n  string container_id = 7;\n  bool container_alive = 8;\n  string container_dead_since = 9;\n  string title = 10;\n  bool is_host = 11;\n}\n\nmessage StepExecutionStatus {\n  string step_name = 1;\n  string result = 2;\n  string started_at = 3;\n  string completed_at = 4;\n}\n\nmessage StreamLogsRequest {\n  string run_id = 1;\n  string step_name = 2;\n  string log_type = 3;\n  bool follow = 4;  // When true, stream existing logs then continue tailing new lines (like tail -f).\n                     // Passed via gRPC metadata header \"x-cloche-follow\" until proto is regenerated.\n  int32 limit = 5;  // When > 0, display only the last N lines of output.\n                     // Passed via gRPC metadata header \"x-cloche-limit\" until proto is regenerated.\n}\n\nmessage LogEntry {\n  string type = 1;\n  string step_name = 2;\n  string result = 3;\n  string message = 4;\n  string timestamp = 5;\n}\n\nmessage StopRunRequest {\n  string run_id = 1;\n}\n\nmessage StopRunResponse {}\n\nmessage ShutdownRequest {\n  bool force = 1;  // If false, reject shutdown when runs are active.\n}\n\nmessage ShutdownResponse {}\n\nmessage DeleteContainerRequest {\n  string id = 1;\n}\n\nmessage DeleteContainerResponse {}\n\nmessage ListRunsRequest {\n  bool all = 1;\n  string project_dir = 2;\n  string state = 3;\n  int32 limit = 4;\n  string task_id = 5;\n}\n\nmessage ListRunsResponse {\n  repeated RunSummary runs = 1;\n}\n\nmessage RunSummary {\n  string run_id = 1;\n  string workflow_name = 2;\n  string state = 3;\n  string started_at = 4;\n  string error_message = 5;\n  string container_id = 6;\n  string title = 7;\n  bool is_host = 8;\n  string project_dir = 9;\n  string task_id = 10;\n}\n\nmessage EnableLoopRequest {\n  string project_dir = 1;\n  int32 max_concurrent = 2;\n}\n\nmessage EnableLoopResponse {}\n\nmessage DisableLoopRequest {\n  string project_dir = 1;\n}\n\nmessage DisableLoopResponse {}\n\nmessage ResumeLoopRequest {\n  string project_dir = 1;\n}\n\nmessage ResumeLoopResponse {}\n\nmessage GetProjectInfoRequest {\n  string project_dir = 1;  // Resolve by absolute path (default: cwd)\n  string name = 2;         // Resolve by project label (e.g. \"cloche\")\n}\n\nmessage GetProjectInfoResponse {\n  string project_dir = 1;\n  string name = 2;\n  bool active = 3;\n  int32 concurrency = 4;\n  double stagger_seconds = 5;\n  double dedup_seconds = 6;\n  bool evolution_enabled = 7;\n  bool loop_running = 8;\n  repeated RunSummary active_runs = 9;\n  repeated string container_workflows = 10;\n  repeated string host_workflows = 11;\n  bool stop_on_error = 12;\n  bool error_halted = 13;       // true when loop is halted due to an unrecovered error\n  string halt_error = 14;       // the error that caused the halt\n  int32 max_consecutive_failures = 15; // halt loop after N consecutive failures\n}\n\nmessage GetVersionRequest {}\n\nmessage GetVersionResponse {\n  string version = 1;\n}\n","numLines":178,"startLine":1,"totalLines":178}}}
