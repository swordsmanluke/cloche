\n  1244→\tcase domain.HealthRed:\n  1245→\t\treturn \"red\"\n  1246→\tcase domain.HealthBlue:\n  1247→\t\treturn \"blue\"\n  1248→\tdefault:\n  1249→\t\treturn \"grey\"\n  1250→\t}\n  1251→}\n  1252→\n  1253→func formatTime(t time.Time) string {\n  1254→\tif t.IsZero() {\n  1255→\t\treturn \"\"\n  1256→\t}\n  1257→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1258→}\n  1259→\n  1260→func formatDuration(start, end time.Time) string {\n  1261→\tif start.IsZero() || end.IsZero() {\n  1262→\t\treturn \"\"\n  1263→\t}\n  1264→\td := end.Sub(start)\n  1265→\tif d < time.Second {\n  1266→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1267→\t}\n  1268→\tif d < time.Minute {\n  1269→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1270→\t}\n  1271→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1272→}\n  1273→\n  1274→func truncate(s string, n int) string {\n  1275→\tif len(s) <= n {\n  1276→\t\treturn s\n  1277→\t}\n  1278→\treturn s[:n] + \"...\"\n  1279→}\n  1280→\n  1281→func shortContainerID(id string) string {\n  1282→\tif len(id) > 12 {\n  1283→\t\treturn id[:12]\n  1284→\t}\n  1285→\treturn id\n  1286→}\n  1287→\n  1288→// projectLabels builds a mapping from full project directory paths to short\n  1289→// display labels. Each label is the final directory component (e.g.\n  1290→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1291→// the same final name, the parent directory is prepended to disambiguate\n  1292→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1293→func projectLabels(dirs []string) map[string]string {\n  1294→\tlabels := make(map[string]string, len(dirs))\n  1295→\t// Group dirs by their base name to detect conflicts.\n  1296→\tbyBase := map[string][]string{}\n  1297→\tfor _, d := range dirs {\n  1298→\t\tbase := filepath.Base(d)\n  1299→\t\tbyBase[base] = append(byBase[base], d)\n  1300→\t}\n  1301→\tfor base, paths := range byBase {\n  1302→\t\tif len(paths) == 1 {\n  1303→\t\t\tlabel