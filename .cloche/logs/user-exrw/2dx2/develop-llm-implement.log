.md\"), []byte(promptContent), 0o644))\n\n\tworkflowContent := `workflow \"develop\" {\n  step fix {\n    prompt = file(\".cloche/prompts/fix.md\")\n    results = [success, fail]\n  }\n\n  fix:success -> done\n  fix:fail -> abort\n}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"develop.cloche\"), []byte(workflowContent), 0o644))\n\n\t// Register the project by creating a run\n\tseedRunWithProject(t, store, \"test-run-1\", \"develop\", domain.RunStateSucceeded, dir)\n\n\t// Resolve the label that would be used for this project\n\tlabel := filepath.Base(dir)\n\n\tt.Run(\"prompt with file() syntax returns contents\", func(t *testing.T) {\n\t\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/workflows/develop/steps/fix/content\", nil)\n\t\tw := httptest.NewRecorder()\n\t\th.ServeHTTP(w, req)\n\t\tassert.Equal(t, http.StatusOK, w.Code)\n\t\tassert.Equal(t, promptContent, w.Body.String())\n\t})\n\n\tt.Run(\"step not found\", func(t *testing.T) {\n\t\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/workflows/develop/steps/nonexistent/content\", nil)\n\t\tw := httptest.NewRecorder()\n\t\th.ServeHTTP(w, req)\n\t\tassert.Equal(t, http.StatusNotFound, w.Code)\n\t})\n\n\tt.Run(\"workflow not found\", func(t *testing.T) {\n\t\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/workflows/nope/steps/fix/content\", nil)\n\t\tw := httptest.NewRecorder()\n\t\th.ServeHTTP(w, req)\n\t\tassert.Equal(t, http.StatusNotFound, w.Code)\n\t})\n}\n\nfunc TestAPIStepContent_RunCommand(t *testing.T) {\n\th, store := setupHandler(t)\n\n\tdir := t.TempDir()\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0o755))\n\n\tworkflowContent := `workflow \"ci\" {\n  step test {\n    run = \"go test ./...\"\n    results = [success, fail]\n  }\n\n  test:success -> done\n  test:fail -> abort\n}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"ci.cloche\"), []byte(workflowContent), 0o644))\n\n\tseedRunWithProject(t, store, \"test-run-2\", \"ci\", domain.RunStateSucceeded, dir)\n\tlabel := filepath.Base(dir)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/workflows/ci/steps/test/content\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Equal(t, \"go test ./...\", w.Body.String())\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":573,"cache_read_input_tokens":39388,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":573},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"503a9c6b-ea73-4496-a067-8391d86da200","uuid":"6646c590-a186-45f8-a1d5-1ac7893d3885"}
