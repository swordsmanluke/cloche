\n   395→}\n   396→\n   397→.log-viewer pre {\n   398→    margin: 0;\n   399→    padding: 0.75rem;\n   400→    font-family: var(--mono);\n   401→    font-size: 0.8rem;\n   402→    white-space: pre-wrap;\n   403→    word-break: break-word;\n   404→    line-height: 1.4;\n   405→}\n   406→\n   407→.log-line { display: block; }\n   408→.log-type-status { color: var(--badge-running-text); }\n   409→.log-type-llm { color: var(--badge-succeeded-text); }\n   410→.log-type-script { color: var(--text); }\n   411→\n   412→/* Panels */\n   413→.panel {\n   414→    background: var(--bg-surface);\n   415→    border: 1px solid var(--border);\n   416→    border-radius: var(--radius);\n   417→    margin-bottom: 1rem;\n   418→}\n   419→\n   420→.panel-header {\n   421→    font-weight: 700;\n   422→    font-size: 0.9rem;\n   423→    padding: 0.6rem 1rem;\n   424→    border-bottom: 1px solid var(--border);\n   425→    text-transform: uppercase;\n   426→    letter-spacing: 0.03em;\n   427→    color: var(--text-muted);\n   428→}\n   429→\n   430→.panel-body {\n   431→    padding: 1rem;\n   432→}\n   433→\n   434→/* Tabs */\n   435→.tab-bar {\n   436→    display: flex;\n   437→    gap: 0;\n   438→    border-bottom: 1px solid var(--border);\n   439→    margin-bottom: 1rem;\n   440→}\n   441→\n   442→.tab-btn {\n   443→    padding: 0.4rem 1rem;\n   444→    font-family: var(--font);\n   445→    font-size: 0.85rem;\n   446→    font-weight: 600;\n   447→    background: none;\n   448→    border: none;\n   449→    border-bottom: 2px solid transparent;\n   450→    color: var(--text-muted);\n   451→    cursor: pointer;\n   452→}\n   453→\n   454→.tab-btn:hover { color: var(--text); }\n   455→.tab-btn.tab-active { color: var(--link); border-bottom-color: var(--link); }\n   456→\n   457→/* DAG */\n   458→.dag-svg { display: block; margin: 0 auto; }\n   459→\n   460→.dag-node-rect {\n   461→    fill: var(--bg);\n   462→    stroke: var(--border);\n   463→    stroke-width: 1.5;\n   464→    rx: 4;\n   465→}\n   466→\n   467→.dag-node:hover .dag-node-rect { stroke: var(--link); stroke-width: 2; }\n   468→\n   469→.dag-node-text {\n   470→    font-family: var(--font);\n   471→    font-size: 13px;\n   472→    fill: var(--text);\n   473→}\n   474→\n   475→.dag-edge {\n   476→    fill: none;\n   477→    stroke: var(--text-muted);\n   478→    stroke-width: 1.5;\n   479→}\n   480→\n   481→.dag-edge-label {\n   482→    font-family: var(--font);\n   483→    font-size: 10px;\n   484→    fill: var(--text-muted);\n   485→    text-anchor: middle;\n   486→}\n   487→\n   488→.dag-terminal-done { fill: var(--badge-succeeded-bg); stroke: var(--badge-succeeded-text); }\n   489→.dag-terminal-abort { fill: var(--badge-failed-bg); stroke: var(--badge-failed-text); }\n   490→\n   491→/* Drawer */\n   492→.drawer {\n   493→    position: fixed;\n   494→    top: 0;\n   495→    right: -420px;\n   496→    width: 400px;\n   497→    height: 100vh;\n   498→    background: var(--bg-surface);\n   499→    border-left: 1px solid var(--border);\n   500→    box-shadow: -4px 0 12px rgba(0,0,0,0.1);\n   501→    transition: right 0.25s ease;\n   502→    z-index: 100;\n   503→    display: flex;\n   504→    flex-direction: column;\n   505→    overflow: hidden;\n   506→}\n   507→\n   508→.drawer.drawer-open { right: 0; }\n   509→\n   510→.drawer-header {\n   511→    display: flex;\n   512→    justify-content: space-between;\n   513→    align-items: center;\n   514→    padding: 0.75rem 1rem;\n   515→    border-bottom: 1px solid var(--border);\n   516→    font-weight: 700;\n   517→    font-size: 1rem;\n   518→}\n   519→\n   520→.drawer-close {\n   521→    background: none;\n   522→    border: none;\n   523→    font-size: 1.4rem;\n   524→    cursor: pointer;\n   525→    color: var(--text-muted);\n   526→    padding: 0 0.25rem;\n   527→}\n   528→\n   529→.drawer-close:hover { color: var(--text); }\n   530→\n   531→.drawer-body {\n   532→    padding: 1rem;\n   533→    overflow-y: auto;\n   534→    flex: 1;\n   535→}\n   536→\n   537→.drawer-body pre {\n   538→    background: var(--bg);\n   539→    border: 1px solid var(--border);\n   540→    border-radius: var(--radius);\n   541→    padding: 0.75rem;\n   542→    font-family: var(--mono);\n   543→    font-size: 0.8rem;\n   544→    max-height: 400px;\n   545→    overflow: auto;\n   546→    white-space: pre-wrap;\n   547→    word-break: break-word;\n   548→}\n   549→\n   550→/* Diff block */\n   551→.diff-block {\n   552→    background: var(--bg);\n   553→    border: 1px solid var(--border);\n   554→    border-radius: var(--radius);\n   555→    padding: 0.5rem;\n   556→    font-family: var(--mono);\n   557→    font-size: 0.75rem;\n   558→    max-height: 300px;\n   559→    overflow: auto;\n   560→    white-space: pre-wrap;\n   561→    word-break: break-word;\n   562→    margin: 0.25rem 0 0.5rem;\n   563→}\n   564→\n   565→/* Orchestrator status */\n   566→.orch-status { font-size: 0.9rem; }\n   567→\n   568→/* Responsive */\n   569→@media (max-width: 768px) {\n   570→    .runs-table { font-size: 0.8rem; }\n   571→    .runs-table th, .runs-table td { padding: 0.4rem 0.5rem; }\n   572→    .run-meta dl { grid-template-columns: 1fr; }\n   573→    .project-cards { grid-template-columns: 1fr; }\n   574→    .log-viewer { max-height: 400px; }\n   575→    .drawer { width: 100%; right: -100%; }\n   576→}\n   577→"}]},"parent_tool_use_id":"toolu_01MfD86qGaYCESVqUTMLNaVG","session_id":"503a9c6b-ea73-4496-a067-8391d86da200","uuid":"716c6cf4-9de1-4071-8509-7eeb91b4535d"}
