[2026-03-08T04:28:16Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016BV4kVWJDzg488TudyCHX2","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"net/http\"\n     8→\t\"net/http/httptest\"\n     9→\t\"testing\"\n    10→\t\"time\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    15→\t\"github.com/stretchr/testify/assert\"\n    16→\t\"github.com/stretchr/testify/require\"\n    17→)\n    18→\n    19→// mockContainerManager implements ContainerManager for testing.\n    20→type mockContainerManager struct {\n    21→\tcontainers map[string]bool // containerID -> exists\n    22→\trunning    map[string]bool // containerID -> running\n    23→\tremoved    []string\n    24→}\n    25→\n    26→func newMockContainerManager() *mockContainerManager {\n    27→\treturn &mockContainerManager{\n    28→\t\tcontainers: map[string]bool{},\n    29→\t\trunning:    map[string]bool{},\n    30→\t}\n    31→}\n    32→\n    33→func (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n    34→\treturn \"mock logs\", nil\n    35→}\n    36→\n    37→func (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n    38→\tif !m.containers[containerID] {\n    39→\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n    40→\t}\n    41→\tdelete(m.containers, containerID)\n    42→\tm.removed = append(m.removed, containerID)\n    43→\treturn nil\n    44→}\n    45→\n    46→func (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n    47→\tif !m.containers[containerID] {\n    48→\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n    49→\t}\n    50→\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n    51→}\n    52→\n    53→func setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n    54→\tt.Helper()\n    55→\tstore, err := sqlite.NewStore(\":memory:\")\n    56→\trequire.NoError(t, err)\n    57→\tt.Cleanup(func() { store.Close() })\n    58→\n    59→\th, err := NewHandler(store, store)\n    60→\trequire.NoError(t, err)\n    61→\treturn h, store\n    62→}\n    63→\n    64→func seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n    65→\tt.Helper()\n    66→\tseedRunWithProject(t, store, id, workflow, state, \"\")\n    67→}\n    68→\n    69→func seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n    70→\tt.Helper()\n    71→\tctx := context.Background()\n    72→\trun := domain.NewRun(id, workflow)\n    73→\trun.ProjectDir = projectDir\n    74→\tif state != domain.RunStatePending {\n    75→\t\trun.Start()\n    76→\t\trun.ContainerID = \"abc123def456789\"\n    77→\t}\n    78→\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n    79→\t\trun.Complete(state)\n    80→\t}\n    81→\tif state == domain.RunStateFailed {\n    82→\t\trun.ErrorMessage = \"something went wrong\"\n    83→\t}\n    84→\trequire.NoError(t, store.CreateRun(ctx, run))\n    85→}\n    86→\n    87→func TestRunsList_WithRuns(t *testing.T) {\n    88→\th, store := setupHandler(t)\n    89→\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n    90→\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n    91→\n    92→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n    93→\tw := httptest.NewRecorder()\n    94→\th.ServeHTTP(w, req)\n    95→\n    96→\tassert.Equal(t, http.StatusOK, w.Code)\n    97→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n    98→\tbody := w.Body.String()\n    99→\tassert.Contains(t, body, \"test-run-1\")\n   100→\tassert.Contains(t, body, \"test-run-2\")\n   101→\tassert.Contains(t, body, \"badge-running\")\n   102→\tassert.Contains(t, body, \"badge-succeeded\")\n   103→\tassert.Contains(t, body, \"develop\")\n   104→\tassert.Contains(t, body, \"deploy\")\n   105→}\n   106→\n   107→func TestRunsList_Empty(t *testing.T) {\n   108→\th, _ := setupHandler(t)\n   109→\n   110→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   111→\tw := httptest.NewRecorder()\n   112→\th.ServeHTTP(w, req)\n   113→\n   114→\tassert.Equal(t, http.StatusOK, w.Code)\n   115→\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n   116→}\n   117→\n   118→func TestRunDetail_WithCaptures(t *testing.T) {\n   119→\th, store := setupHandler(t)\n   120→\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n   121→\n   122→\tctx := context.Background()\n   123→\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n   124→\t\tStepName:    \"implement\",\n   125→\t\tResult:      \"success\",\n   126→\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n   127→\t\tCompletedAt: time.Now(),\n   128→\t}))\n   129→\n   130→\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n   131→\tw := httptest.NewRecorder()\n   132→\th.ServeHTTP(w, req)\n   133→\n   134→\tassert.Equal(t, http.StatusOK, w.Code)\n   135→\tbody := w.Body.String()\n   136→\tassert.Contains(t, body, \"run-detail-1\")\n   137→\tassert.Contains(t, body, \"implement\")\n   138→}\n   139→\n   140→func TestRunDetail_NotFound(t *testing.T) {\n   141→\th, _ := setupHandler(t)\n   142→\n   143→\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n   144→\tw := httptest.NewRecorder()\n   145→\th.ServeHTTP(w, req)\n   146→\n   147→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   148→}\n   149→\n   150→func TestAPIRuns(t *testing.T) {\n   151→\th, store := setupHandler(t)\n   152→\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n   153→\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n   154→\n   155→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   156→\tw := httptest.NewRecorder()\n   157→\th.ServeHTTP(w, req)\n   158→\n   159→\tassert.Equal(t, http.StatusOK, w.Code)\n   160→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   161→\n   162→\tvar runs []apiRun\n   163→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n   164→\tassert.Len(t, runs, 2)\n   165→\n   166→\tids := map[string]bool{}\n   167→\tfor _, r := range runs {\n   168→\t\tids[r.ID] = true\n   169→\t}\n   170→\tassert.True(t, ids[\"api-run-1\"])\n   171→\tassert.True(t, ids[\"api-run-2\"])\n   172→}\n   173→\n   174→func TestAPIRunDetail(t *testing.T) {\n   175→\th, store := setupHandler(t)\n   176→\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n   177→\n   178→\tctx := context.Background()\n   179→\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n   180→\t\tStepName:    \"build\",\n   181→\t\tResult:      \"success\",\n   182→\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n   183→\t\tCompletedAt: time.Now(),\n   184→\t}))\n   185→\n   186→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n   187→\tw := httptest.NewRecorder()\n   188→\th.ServeHTTP(w, req)\n   189→\n   190→\tassert.Equal(t, http.StatusOK, w.Code)\n   191→\n   192→\tvar detail apiRunDetail\n   193→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   194→\tassert.Equal(t, \"api-detail-1\", detail.ID)\n   195→\tassert.Equal(t, \"running\", detail.State)\n   196→\tassert.Len(t, detail.Steps, 1)\n   197→\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n   198→\tassert.NotEmpty(t, detail.Steps[0].Duration)\n   199→}\n   200→\n   201→func TestStaticCSS(t *testing.T) {\n   202→\th, _ := setupHandler(t)\n   203→\n   204→\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n   205→\tw := httptest.NewRecorder()\n   206→\th.ServeHTTP(w, req)\n   207→\n   208→\tassert.Equal(t, http.StatusOK, w.Code)\n   209→\tassert.Contains(t, w.Body.String(), \":root\")\n   210→\tassert.Contains(t, w.Body.String(), \"badge-running\")\n   211→}\n   212→\n   213→func TestHelpers(t *testing.T) {\n   214→\tt.Run(\"stateColor\", func(t *testing.T) {\n   215→\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n   216→\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n   217→\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n   218→\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n   219→\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n   220→\t})\n   221→\n   222→\tt.Run(\"formatTime\", func(t *testing.T) {\n   223→\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n   224→\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n   225→\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n   226→\t})\n   227→\n   228→\tt.Run(\"formatDuration\", func(t *testing.T) {\n   229→\t\tnow := time.Now()\n   230→\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n   231→\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n   232→\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n   233→\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n   234→\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n   235→\t})\n   236→\n   237→\tt.Run(\"truncate\", func(t *testing.T) {\n   238→\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n   239→\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n   240→\t})\n   241→\n   242→\tt.Run(\"shortContainerID\", func(t *testing.T) {\n   243→\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n   244→\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n   245→\t})\n   246→\n   247→\tt.Run(\"projectLabels\", func(t *testing.T) {\n   248→\t\t// No conflict: show base name only\n   249→\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n   250→\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n   251→\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n   252→\n   253→\t\t// Conflict: two dirs share the same base name\n   254→\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n   255→\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n   256→\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n   257→\n   258→\t\t// Mixed: some conflict, some don't\n   259→\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n   260→\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n   261→\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n   262→\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n   263→\n   264→\t\t// Empty list\n   265→\t\tlabels = projectLabels(nil)\n   266→\t\tassert.Empty(t, labels)\n   267→\t})\n   268→}\n   269→\n   270→func TestRunsList_ProjectFilter(t *testing.T) {\n   271→\th, store := setupHandler(t)\n   272→\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   273→\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   274→\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   275→\n   276→\t// Without filter: all runs shown\n   277→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   278→\tw := httptest.NewRecorder()\n   279→\th.ServeHTTP(w, req)\n   280→\tassert.Equal(t, http.StatusOK, w.Code)\n   281→\tbody := w.Body.String()\n   282→\tassert.Contains(t, body, \"run-a1\")\n   283→\tassert.Contains(t, body, \"run-b1\")\n   284→\n   285→\t// With project filter: only matching runs\n   286→\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n   287→\tw = httptest.NewRecorder()\n   288→\th.ServeHTTP(w, req)\n   289→\tassert.Equal(t, http.StatusOK, w.Code)\n   290→\tbody = w.Body.String()\n   291→\tassert.Contains(t, body, \"run-a1\")\n   292→\tassert.Contains(t, body, \"run-a2\")\n   293→\tassert.NotContains(t, body, \"run-b1\")\n   294→}\n   295→\n   296→func TestRunsList_ProjectColumn(t *testing.T) {\n   297→\th, store := setupHandler(t)\n   298→\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n   299→\n   300→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   301→\tw := httptest.NewRecorder()\n   302→\th.ServeHTTP(w, req)\n   303→\tassert.Equal(t, http.StatusOK, w.Code)\n   304→\tbody := w.Body.String()\n   305→\tassert.Contains(t, body, \"myproject\")\n   306→\tassert.Contains(t, body, \"Project\")\n   307→}\n   308→\n   309→func TestAPIRuns_ProjectFilter(t *testing.T) {\n   310→\th, store := setupHandler(t)\n   311→\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   312→\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   313→\n   314→\t// Without filter: all runs\n   315→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   316→\tw := httptest.NewRecorder()\n   317→\th.ServeHTTP(w, req)\n   318→\tassert.Equal(t, http.StatusOK, w.Code)\n   319→\n   320→\tvar allRuns []apiRun\n   321→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n   322→\tassert.Len(t, allRuns, 2)\n   323→\n   324→\t// With filter: only matching\n   325→\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n   326→\tw = httptest.NewRecorder()\n   327→\th.ServeHTTP(w, req)\n   328→\tassert.Equal(t, http.StatusOK, w.Code)\n   329→\n   330→\tvar filtered []apiRun\n   331→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n   332→\tassert.Len(t, filtered, 1)\n   333→\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n   334→\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n   335→\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n   336→}\n   337→\n   338→func setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n   339→\tt.Helper()\n   340→\tstore, err := sqlite.NewStore(\":memory:\")\n   341→\trequire.NoError(t, err)\n   342→\tt.Cleanup(func() { store.Close() })\n   343→\n   344→\tmgr := newMockContainerManager()\n   345→\th, err := NewHandler(store, store, WithContainerManager(mgr))\n   346→\trequire.NoError(t, err)\n   347→\treturn h, store, mgr\n   348→}\n   349→\n   350→func seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n   351→\tt.Helper()\n   352→\tctx := context.Background()\n   353→\trun := domain.NewRun(id, workflow)\n   354→\trun.ProjectDir = projectDir\n   355→\trun.Start()\n   356→\trun.ContainerID = containerID\n   357→\trun.ContainerKept = kept\n   358→\trun.Complete(domain.RunStateSucceeded)\n   359→\trequire.NoError(t, store.CreateRun(ctx, run))\n   360→\tif kept {\n   361→\t\tmgr.containers[containerID] = true\n   362→\t}\n   363→}\n   364→\n   365→func TestRunDetail_ContainerRunning(t *testing.T) {\n   366→\th, store, mgr := setupHandlerWithContainerManager(t)\n   367→\n   368→\tctx := context.Background()\n   369→\trun := domain.NewRun(\"run-cr\", \"develop\")\n   370→\trun.ProjectDir = \"/proj\"\n   371→\trun.Start()\n   372→\trun.ContainerID = \"cid-running\"\n   373→\trequire.NoError(t, store.CreateRun(ctx, run))\n   374→\tmgr.containers[\"cid-running\"] = true\n   375→\tmgr.running[\"cid-running\"] = true\n   376→\n   377→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n   378→\tw := httptest.NewRecorder()\n   379→\th.ServeHTTP(w, req)\n   380→\n   381→\tassert.Equal(t, http.StatusOK, w.Code)\n   382→\tbody := w.Body.String()\n   383→\tassert.Contains(t, body, \"Container running\")\n   384→\tassert.Contains(t, body, `badge-running\">Container running`)\n   385→}\n   386→\n   387→func TestRunDetail_ContainerStopped(t *testing.T) {\n   388→\th, store, mgr := setupHandlerWithContainerManager(t)\n   389→\n   390→\tctx := context.Background()\n   391→\trun := domain.NewRun(\"run-cs\", \"develop\")\n   392→\trun.ProjectDir = \"/proj\"\n   393→\trun.Start()\n   394→\trun.ContainerID = \"cid-stopped\"\n   395→\trun.ContainerKept = false\n   396→\trun.Complete(domain.RunStateSucceeded)\n   397→\trequire.NoError(t, store.CreateRun(ctx, run))\n   398→\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n   399→\n   400→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n   401→\tw := httptest.NewRecorder()\n   402→\th.ServeHTTP(w, req)\n   403→\n   404→\tassert.Equal(t, http.StatusOK, w.Code)\n   405→\tbody := w.Body.String()\n   406→\tassert.Contains(t, body, \"Container stopped\")\n   407→\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n   408→}\n   409→\n   410→func TestRunDetail_ContainerAvailable(t *testing.T) {\n   411→\th, store, mgr := setupHandlerWithContainerManager(t)\n   412→\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n   413→\n   414→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n   415→\tw := httptest.NewRecorder()\n   416→\th.ServeHTTP(w, req)\n   417→\n   418→\tassert.Equal(t, http.StatusOK, w.Code)\n   419→\tbody := w.Body.String()\n   420→\tassert.Contains(t, body, \"Container available\")\n   421→\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n   422→\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n   423→}\n   424→\n   425→func TestRunDetail_ContainerRemoved(t *testing.T) {\n   426→\th, store, _ := setupHandlerWithContainerManager(t)\n   427→\n   428→\tctx := context.Background()\n   429→\trun := domain.NewRun(\"run-c2\", \"develop\")\n   430→\trun.ProjectDir = \"/proj\"\n   431→\trun.Start()\n   432→\trun.ContainerID = \"cid-gone\"\n   433→\trun.ContainerKept = false\n   434→\trun.Complete(domain.RunStateSucceeded)\n   435→\trequire.NoError(t, store.CreateRun(ctx, run))\n   436→\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n   437→\n   438→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n   439→\tw := httptest.NewRecorder()\n   440→\th.ServeHTTP(w, req)\n   441→\n   442→\tassert.Equal(t, http.StatusOK, w.Code)\n   443→\tbody := w.Body.String()\n   444→\tassert.Contains(t, body, \"Container removed\")\n   445→\tassert.Contains(t, body, `badge-pending\">Container removed`)\n   446→}\n   447→\n   448→func TestAPIDeleteContainer_Success(t *testing.T) {\n   449→\th, store, mgr := setupHandlerWithContainerManager(t)\n   450→\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n   451→\n   452→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n   453→\tw := httptest.NewRecorder()\n   454→\th.ServeHTTP(w, req)\n   455→\n   456→\tassert.Equal(t, http.StatusOK, w.Code)\n   457→\n   458→\tvar resp map[string]string\n   459→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n   460→\tassert.Equal(t, \"ok\", resp[\"status\"])\n   461→\n   462→\t// Verify container was removed\n   463→\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n   464→\n   465→\t// Verify run was updated\n   466→\trun, err := store.GetRun(context.Background(), \"run-del1\")\n   467→\trequire.NoError(t, err)\n   468→\tassert.False(t, run.ContainerKept)\n   469→}\n   470→\n   471→func TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n   472→\th, _, _ := setupHandlerWithContainerManager(t)\n   473→\n   474→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n   475→\tw := httptest.NewRecorder()\n   476→\th.ServeHTTP(w, req)\n   477→\n   478→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   479→}\n   480→\n   481→func TestAPIDeleteContainer_NoManager(t *testing.T) {\n   482→\th, store := setupHandler(t) // no container manager\n   483→\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n   484→\n   485→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n   486→\tw := httptest.NewRecorder()\n   487→\th.ServeHTTP(w, req)\n   488→\n   489→\tassert.Equal(t, http.StatusBadRequest, w.Code)\n   490→}\n   491→\n   492→func TestAPIRunDetail_ContainerState(t *testing.T) {\n   493→\th, store, mgr := setupHandlerWithContainerManager(t)\n   494→\n   495→\t// Seed a running container\n   496→\tctx := context.Background()\n   497→\trun := domain.NewRun(\"api-cs1\", \"develop\")\n   498→\trun.ProjectDir = \"/proj\"\n   499→\trun.Start()\n   500→\trun.ContainerID = \"cid-api-running\"\n   501→\trequire.NoError(t, store.CreateRun(ctx, run))\n   502→\tmgr.containers[\"cid-api-running\"] = true\n   503→\tmgr.running[\"cid-api-running\"] = true\n   504→\n   505→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n   506→\tw := httptest.NewRecorder()\n   507→\th.ServeHTTP(w, req)\n   508→\n   509→\tassert.Equal(t, http.StatusOK, w.Code)\n   510→\n   511→\tvar detail apiRunDetail\n   512→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   513→\tassert.Equal(t, \"running\", detail.ContainerState)\n   514→\n   515→\t// Now stop it\n   516→\tmgr.running[\"cid-api-running\"] = false\n   517→\n   518→\tw = httptest.NewRecorder()\n   519→\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n   520→\n   521→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   522→\tassert.Equal(t, \"stopped\", detail.ContainerState)\n   523→}\n   524→\n   525→func TestRunsList_ContainerCount(t *testing.T) {\n   526→\th, store, mgr := setupHandlerWithContainerManager(t)\n   527→\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n   528→\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n   529→\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n   530→\n   531→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   532→\tw := httptest.NewRecorder()\n   533→\th.ServeHTTP(w, req)\n   534→\n   535→\tassert.Equal(t, http.StatusOK, w.Code)\n   536→\tbody := w.Body.String()\n   537→\t// alpha has 2 retained containers\n   538→\tassert.Contains(t, body, \"2 containers\")\n   539→\t// beta has 0, so no count should appear\n   540→\tassert.NotContains(t, body, \"0 container\")\n   541→}\n   542→\n   543→func TestAPIProjects(t *testing.T) {\n   544→\th, store := setupHandler(t)\n   545→\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   546→\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   547→\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   548→\n   549→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   550→\tw := httptest.NewRecorder()\n   551→\th.ServeHTTP(w, req)\n   552→\tassert.Equal(t, http.StatusOK, w.Code)\n   553→\n   554→\ttype apiHealth struct {\n   555→\t\tStatus string `json:\"status\"`\n   556→\t\tPassed int    `json:\"passed\"`\n   557→\t\tFailed int    `json:\"failed\"`\n   558→\t\tTotal  int    `json:\"total\"`\n   559→\t}\n   560→\ttype project struct {\n   561→\t\tDir         string    `json:\"dir\"`\n   562→\t\tLabel       string    `json:\"label\"`\n   563→\t\tHealth      apiHealth `json:\"health\"`\n   564→\t\tActiveCount int       `json:\"active_count\"`\n   565→\t}\n   566→\tvar projects []project\n   567→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   568→\tassert.Len(t, projects, 2)\n   569→\n   570→\tbyDir := map[string]project{}\n   571→\tfor _, p := range projects {\n   572→\t\tbyDir[p.Dir] = p\n   573→\t}\n   574→\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n   575→\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n   576→\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n   577→\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n   578→\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n   579→\t// beta has 1 running = blue (all in-progress), 1 active\n   580→\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n   581→\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n   582→}\n   583→\n   584→func TestProjectOverview_WithProjects(t *testing.T) {\n   585→\th, store := setupHandler(t)\n   586→\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   587→\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   588→\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   589→\n   590→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   591→\tw := httptest.NewRecorder()\n   592→\th.ServeHTTP(w, req)\n   593→\n   594→\tassert.Equal(t, http.StatusOK, w.Code)\n   595→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   596→\tbody := w.Body.String()\n   597→\t// Project cards should be present\n   598→\tassert.Contains(t, body, \"project-card\")\n   599→\tassert.Contains(t, body, \"alpha\")\n   600→\tassert.Contains(t, body, \"beta\")\n   601→\t// Health dots\n   602→\tassert.Contains(t, body, \"health-dot\")\n   603→\t// Run history dots\n   604→\tassert.Contains(t, body, \"run-dot\")\n   605→\t// Quick actions\n   606→\tassert.Contains(t, body, \"View Runs\")\n   607→\tassert.Contains(t, body, \"Trigger Orchestrator\")\n   608→}\n   609→\n   610→func TestProjectOverview_Empty(t *testing.T) {\n   611→\th, _ := setupHandler(t)\n   612→\n   613→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   614→\tw := httptest.NewRecorder()\n   615→\th.ServeHTTP(w, req)\n   616→\n   617→\tassert.Equal(t, http.StatusOK, w.Code)\n   618→\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n   619→}\n   620→\n   621→func TestAPITriggerOrchestrator_NoOrchestrator(t *testing.T) {\n   622→\th, store := setupHandler(t)\n   623→\tseedRunWithProject(t, store, \"orch-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   624→\n   625→\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n   626→\tw := httptest.NewRecorder()\n   627→\th.ServeHTTP(w, req)\n   628→\n   629→\tassert.Equal(t, http.StatusNotImplemented, w.Code)\n   630→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   631→\n   632→\tvar result map[string]string\n   633→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   634→\tassert.Equal(t, \"orchestrator not configured\", result[\"error\"])\n   635→}\n   636→\n   637→func TestAPITriggerOrchestrator_Success(t *testing.T) {\n   638→\tstore, err := sqlite.NewStore(\":memory:\")\n   639→\trequire.NoError(t, err)\n   640→\tt.Cleanup(func() { store.Close() })\n   641→\n   642→\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   643→\t\tassert.Equal(t, \"/home/user/myproject\", projectDir)\n   644→\t\treturn 3, nil\n   645→\t}))\n   646→\trequire.NoError(t, err)\n   647→\n   648→\tseedRunWithProject(t, store, \"orch-2\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   649→\n   650→\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n   651→\tw := httptest.NewRecorder()\n   652→\th.ServeHTTP(w, req)\n   653→\n   654→\tassert.Equal(t, http.StatusOK, w.Code)\n   655→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   656→\n   657→\tvar result map[string]any\n   658→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   659→\tassert.Equal(t, \"ok\", result[\"status\"])\n   660→\tassert.Equal(t, \"myproject\", result[\"project\"])\n   661→\tassert.Equal(t, float64(3), result[\"dispatched\"])\n   662→}\n   663→\n   664→func TestAPITriggerOrchestrator_ProjectNotFound(t *testing.T) {\n   665→\tstore, err := sqlite.NewStore(\":memory:\")\n   666→\trequire.NoError(t, err)\n   667→\tt.Cleanup(func() { store.Close() })\n   668→\n   669→\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   670→\t\treturn 0, nil\n   671→\t}))\n   672→\trequire.NoError(t, err)\n   673→\n   674→\treq := httptest.NewRequest(\"POST\", \"/api/projects/nonexistent/trigger\", nil)\n   675→\tw := httptest.NewRecorder()\n   676→\th.ServeHTTP(w, req)\n   677→\n   678→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   679→\n   680→\tvar result map[string]string\n   681→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   682→\tassert.Equal(t, \"project not found\", result[\"error\"])\n   683→}\n   684→\n   685→func TestAPITriggerOrchestrator_Error(t *testing.T) {\n   686→\tstore, err := sqlite.NewStore(\":memory:\")\n   687→\trequire.NoError(t, err)\n   688→\tt.Cleanup(func() { store.Close() })\n   689→\n   690→\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   691→\t\treturn 0, fmt.Errorf(\"orchestration failed\")\n   692→\t}))\n   693→\trequire.NoError(t, err)\n   694→\n   695→\tseedRunWithProject(t, store, \"orch-3\", \"develop\", domain.RunStateSucceeded, \"/home/user/errproject\")\n   696→\n   697→\treq := httptest.NewRequest(\"POST\", \"/api/projects/errproject/trigger\", nil)\n   698→\tw := httptest.NewRecorder()\n   699→\th.ServeHTTP(w, req)\n   700→\n   701→\tassert.Equal(t, http.StatusInternalServerError, w.Code)\n   702→\n   703→\tvar result map[string]string\n   704→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   705→\tassert.Equal(t, \"orchestration failed\", result[\"error\"])\n   706→}\n   707→\n   708→func TestHealthColor(t *testing.T) {\n   709→\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n   710→\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n   711→\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n   712→\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n   713→\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n   714→\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n   715→}\n   716→\n   717→func TestAPIProjects_HealthData(t *testing.T) {\n   718→\th, store := setupHandler(t)\n   719→\t// alpha: 3 succeeded, 1 failed → yellow\n   720→\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   721→\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   722→\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   723→\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   724→\n   725→\t// beta: all succeeded → green\n   726→\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   727→\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   728→\n   729→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   730→\tw := httptest.NewRecorder()\n   731→\th.ServeHTTP(w, req)\n   732→\tassert.Equal(t, http.StatusOK, w.Code)\n   733→\n   734→\ttype health struct {\n   735→\t\tStatus string `json:\"status\"`\n   736→\t\tPassed int    `json:\"passed\"`\n   737→\t\tFailed int    `json:\"failed\"`\n   738→\t\tTotal  int    `json:\"total\"`\n   739→\t}\n   740→\ttype project struct {\n   741→\t\tDir    string `json:\"dir\"`\n   742→\t\tLabel  string `json:\"label\"`\n   743→\t\tHealth health `json:\"health\"`\n   744→\t}\n   745→\tvar projects []project\n   746→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   747→\tassert.Len(t, projects, 2)\n   748→\n   749→\tbyDir := map[string]project{}\n   750→\tfor _, p := range projects {\n   751→\t\tbyDir[p.Dir] = p\n   752→\t}\n   753→\n   754→\talpha := byDir[\"/home/user/alpha\"]\n   755→\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n   756→\tassert.Equal(t, 3, alpha.Health.Passed)\n   757→\tassert.Equal(t, 1, alpha.Health.Failed)\n   758→\tassert.Equal(t, 4, alpha.Health.Total)\n   759→\n   760→\tbeta := byDir[\"/home/user/beta\"]\n   761→\tassert.Equal(t, \"green\", beta.Health.Status)\n   762→\tassert.Equal(t, 2, beta.Health.Passed)\n   763→\tassert.Equal(t, 0, beta.Health.Failed)\n   764→\tassert.Equal(t, 2, beta.Health.Total)\n   765→}\n   766→\n   767→func TestAPIProjects_HealthNoRuns(t *testing.T) {\n   768→\th, _ := setupHandler(t)\n   769→\n   770→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   771→\tw := httptest.NewRecorder()\n   772→\th.ServeHTTP(w, req)\n   773→\tassert.Equal(t, http.StatusOK, w.Code)\n   774→\n   775→\t// No projects means empty array\n   776→\ttype project struct {\n   777→\t\tDir   string `json:\"dir\"`\n   778→\t\tLabel string `json:\"label\"`\n   779→\t}\n   780→\tvar projects []project\n   781→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   782→\tassert.Empty(t, projects)\n   783→}\n   784→"}]},"parent_tool_use_id":null,"session_id":"f2e3b2d0-9fec-45ae-be26-9ef919219ac8","uuid":"c0540937-cb47-40d2-a7d5-b9dfe114ecd0","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler_test.go","content":"package web\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// mockContainerManager implements ContainerManager for testing.\ntype mockContainerManager struct {\n\tcontainers map[string]bool // containerID -> exists\n\trunning    map[string]bool // containerID -> running\n\tremoved    []string\n}\n\nfunc newMockContainerManager() *mockContainerManager {\n\treturn &mockContainerManager{\n\t\tcontainers: map[string]bool{},\n\t\trunning:    map[string]bool{},\n\t}\n}\n\nfunc (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n\treturn \"mock logs\", nil\n}\n\nfunc (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n\tif !m.containers[containerID] {\n\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\tdelete(m.containers, containerID)\n\tm.removed = append(m.removed, containerID)\n\treturn nil\n}\n\nfunc (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n\tif !m.containers[containerID] {\n\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n}\n\nfunc setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store)\n\trequire.NoError(t, err)\n\treturn h, store\n}\n\nfunc seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n\tt.Helper()\n\tseedRunWithProject(t, store, id, workflow, state, \"\")\n}\n\nfunc seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\tif state != domain.RunStatePending {\n\t\trun.Start()\n\t\trun.ContainerID = \"abc123def456789\"\n\t}\n\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n\t\trun.Complete(state)\n\t}\n\tif state == domain.RunStateFailed {\n\t\trun.ErrorMessage = \"something went wrong\"\n\t}\n\trequire.NoError(t, store.CreateRun(ctx, run))\n}\n\nfunc TestRunsList_WithRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"test-run-1\")\n\tassert.Contains(t, body, \"test-run-2\")\n\tassert.Contains(t, body, \"badge-running\")\n\tassert.Contains(t, body, \"badge-succeeded\")\n\tassert.Contains(t, body, \"develop\")\n\tassert.Contains(t, body, \"deploy\")\n}\n\nfunc TestRunsList_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n}\n\nfunc TestRunDetail_WithCaptures(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"implement\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-detail-1\")\n\tassert.Contains(t, body, \"implement\")\n}\n\nfunc TestRunDetail_NotFound(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar runs []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n\tassert.Len(t, runs, 2)\n\n\tids := map[string]bool{}\n\tfor _, r := range runs {\n\t\tids[r.ID] = true\n\t}\n\tassert.True(t, ids[\"api-run-1\"])\n\tassert.True(t, ids[\"api-run-2\"])\n}\n\nfunc TestAPIRunDetail(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"build\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"api-detail-1\", detail.ID)\n\tassert.Equal(t, \"running\", detail.State)\n\tassert.Len(t, detail.Steps, 1)\n\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n\tassert.NotEmpty(t, detail.Steps[0].Duration)\n}\n\nfunc TestStaticCSS(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \":root\")\n\tassert.Contains(t, w.Body.String(), \"badge-running\")\n}\n\nfunc TestHelpers(t *testing.T) {\n\tt.Run(\"stateColor\", func(t *testing.T) {\n\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n\t})\n\n\tt.Run(\"formatTime\", func(t *testing.T) {\n\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n\t})\n\n\tt.Run(\"formatDuration\", func(t *testing.T) {\n\t\tnow := time.Now()\n\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n\t})\n\n\tt.Run(\"truncate\", func(t *testing.T) {\n\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n\t})\n\n\tt.Run(\"shortContainerID\", func(t *testing.T) {\n\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n\t})\n\n\tt.Run(\"projectLabels\", func(t *testing.T) {\n\t\t// No conflict: show base name only\n\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n\n\t\t// Conflict: two dirs share the same base name\n\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n\n\t\t// Mixed: some conflict, some don't\n\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n\n\t\t// Empty list\n\t\tlabels = projectLabels(nil)\n\t\tassert.Empty(t, labels)\n\t})\n}\n\nfunc TestRunsList_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs shown\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-b1\")\n\n\t// With project filter: only matching runs\n\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody = w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-a2\")\n\tassert.NotContains(t, body, \"run-b1\")\n}\n\nfunc TestRunsList_ProjectColumn(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"myproject\")\n\tassert.Contains(t, body, \"Project\")\n}\n\nfunc TestAPIRuns_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar allRuns []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n\tassert.Len(t, allRuns, 2)\n\n\t// With filter: only matching\n\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar filtered []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n\tassert.Len(t, filtered, 1)\n\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n}\n\nfunc setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\tmgr := newMockContainerManager()\n\th, err := NewHandler(store, store, WithContainerManager(mgr))\n\trequire.NoError(t, err)\n\treturn h, store, mgr\n}\n\nfunc seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\trun.Start()\n\trun.ContainerID = containerID\n\trun.ContainerKept = kept\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tif kept {\n\t\tmgr.containers[containerID] = true\n\t}\n}\n\nfunc TestRunDetail_ContainerRunning(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cr\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-running\"] = true\n\tmgr.running[\"cid-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container running\")\n\tassert.Contains(t, body, `badge-running\">Container running`)\n}\n\nfunc TestRunDetail_ContainerStopped(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cs\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-stopped\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container stopped\")\n\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n}\n\nfunc TestRunDetail_ContainerAvailable(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container available\")\n\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n}\n\nfunc TestRunDetail_ContainerRemoved(t *testing.T) {\n\th, store, _ := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-c2\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-gone\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container removed\")\n\tassert.Contains(t, body, `badge-pending\">Container removed`)\n}\n\nfunc TestAPIDeleteContainer_Success(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"ok\", resp[\"status\"])\n\n\t// Verify container was removed\n\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n\n\t// Verify run was updated\n\trun, err := store.GetRun(context.Background(), \"run-del1\")\n\trequire.NoError(t, err)\n\tassert.False(t, run.ContainerKept)\n}\n\nfunc TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n\th, _, _ := setupHandlerWithContainerManager(t)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIDeleteContainer_NoManager(t *testing.T) {\n\th, store := setupHandler(t) // no container manager\n\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusBadRequest, w.Code)\n}\n\nfunc TestAPIRunDetail_ContainerState(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\t// Seed a running container\n\tctx := context.Background()\n\trun := domain.NewRun(\"api-cs1\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-api-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-api-running\"] = true\n\tmgr.running[\"cid-api-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"running\", detail.ContainerState)\n\n\t// Now stop it\n\tmgr.running[\"cid-api-running\"] = false\n\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"stopped\", detail.ContainerState)\n}\n\nfunc TestRunsList_ContainerCount(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\t// alpha has 2 retained containers\n\tassert.Contains(t, body, \"2 containers\")\n\t// beta has 0, so no count should appear\n\tassert.NotContains(t, body, \"0 container\")\n}\n\nfunc TestAPIProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n\t// beta has 1 running = blue (all in-progress), 1 active\n\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n}\n\nfunc TestProjectOverview_WithProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\t// Project cards should be present\n\tassert.Contains(t, body, \"project-card\")\n\tassert.Contains(t, body, \"alpha\")\n\tassert.Contains(t, body, \"beta\")\n\t// Health dots\n\tassert.Contains(t, body, \"health-dot\")\n\t// Run history dots\n\tassert.Contains(t, body, \"run-dot\")\n\t// Quick actions\n\tassert.Contains(t, body, \"View Runs\")\n\tassert.Contains(t, body, \"Trigger Orchestrator\")\n}\n\nfunc TestProjectOverview_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n}\n\nfunc TestAPITriggerOrchestrator_NoOrchestrator(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"orch-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotImplemented, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar result map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"orchestrator not configured\", result[\"error\"])\n}\n\nfunc TestAPITriggerOrchestrator_Success(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\tassert.Equal(t, \"/home/user/myproject\", projectDir)\n\t\treturn 3, nil\n\t}))\n\trequire.NoError(t, err)\n\n\tseedRunWithProject(t, store, \"orch-2\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar result map[string]any\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"ok\", result[\"status\"])\n\tassert.Equal(t, \"myproject\", result[\"project\"])\n\tassert.Equal(t, float64(3), result[\"dispatched\"])\n}\n\nfunc TestAPITriggerOrchestrator_ProjectNotFound(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\treturn 0, nil\n\t}))\n\trequire.NoError(t, err)\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/nonexistent/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n\n\tvar result map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"project not found\", result[\"error\"])\n}\n\nfunc TestAPITriggerOrchestrator_Error(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\treturn 0, fmt.Errorf(\"orchestration failed\")\n\t}))\n\trequire.NoError(t, err)\n\n\tseedRunWithProject(t, store, \"orch-3\", \"develop\", domain.RunStateSucceeded, \"/home/user/errproject\")\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/errproject/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusInternalServerError, w.Code)\n\n\tvar result map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"orchestration failed\", result[\"error\"])\n}\n\nfunc TestHealthColor(t *testing.T) {\n\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n}\n\nfunc TestAPIProjects_HealthData(t *testing.T) {\n\th, store := setupHandler(t)\n\t// alpha: 3 succeeded, 1 failed → yellow\n\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\t// beta: all succeeded → green\n\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype health struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir    string `json:\"dir\"`\n\t\tLabel  string `json:\"label\"`\n\t\tHealth health `json:\"health\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\n\talpha := byDir[\"/home/user/alpha\"]\n\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n\tassert.Equal(t, 3, alpha.Health.Passed)\n\tassert.Equal(t, 1, alpha.Health.Failed)\n\tassert.Equal(t, 4, alpha.Health.Total)\n\n\tbeta := byDir[\"/home/user/beta\"]\n\tassert.Equal(t, \"green\", beta.Health.Status)\n\tassert.Equal(t, 2, beta.Health.Passed)\n\tassert.Equal(t, 0, beta.Health.Failed)\n\tassert.Equal(t, 2, beta.Health.Total)\n}\n\nfunc TestAPIProjects_HealthNoRuns(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\t// No projects means empty array\n\ttype project struct {\n\t\tDir   string `json:\"dir\"`\n\t\tLabel string `json:\"label\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Empty(t, projects)\n}\n","numLines":784,"startLine":1,"totalLines":784}}}
