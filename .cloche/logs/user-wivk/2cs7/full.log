rr := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store)\n\trequire.NoError(t, err)\n\n\tseedRunWithProject(t, store, \"sc-1\", \"develop\", domain.RunStateRunning, dir)\n\n\tlabel := filepath.Base(dir)\n\n\t// Test agent step content (file reference)\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/workflows/develop/steps/implement/content\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Equal(t, promptContent, w.Body.String())\n\n\t// Test script step content (inline run command)\n\treq = httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/workflows/develop/steps/test/content\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Equal(t, \"go test ./... 2>&1\", w.Body.String())\n}\n\nfunc TestAPIStepContent_InlinePrompt(t *testing.T) {\n\tdir := t.TempDir()\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\n\twfContent := `workflow \"simple\" {\n  step code {\n    prompt = \"Write hello world in Go\"\n    results = [success, fail]\n  }\n  code:success -> done\n  code:fail -> abort\n}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"simple.cloche\"), []byte(wfContent), 0644))\n\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store)\n\trequire.NoError(t, err)\n\n\tseedRunWithProject(t, store, \"sc-2\", \"simple\", domain.RunStateRunning, dir)\n\tlabel := filepath.Base(dir)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/workflows/simple/steps/code/content\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Equal(t, \"Write hello world in Go\", w.Body.String())\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":173,"cache_read_input_tokens":89910,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":173},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f2e3b2d0-9fec-45ae-be26-9ef919219ac8","uuid":"55525154-9a4f-4e34-898f-a01f2b1aadc5"}
