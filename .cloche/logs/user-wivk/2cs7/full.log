al)\n\t\t\t\t\tbuf.WriteRune('\"')\n\t\t\t\t} else {\n\t\t\t\t\tbuf.WriteString(p.current.Literal)\n\t\t\t\t}\n\t\t\t\tp.advance()\n\t\t\t}\n\t\t\tbuf.WriteRune(')')\n\t\t\tp.advance() // consume )\n\t\t}\n","numLines":30,"startLine":298,"totalLines":433}}}
