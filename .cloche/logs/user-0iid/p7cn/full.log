[2026-03-13T14:41:35Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012d4N5uDuQDzPRtAbgkX7oy","type":"tool_result","content":"     1→package agent\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"io\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n    12→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    15→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    17→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    18→)\n    19→\n    20→type RunnerConfig struct {\n    21→\tWorkflowPath string\n    22→\tWorkDir      string\n    23→\tStatusOutput io.Writer\n    24→\tRunID        string\n    25→}\n    26→\n    27→type Runner struct {\n    28→\tcfg RunnerConfig\n    29→}\n    30→\n    31→func NewRunner(cfg RunnerConfig) *Runner {\n    32→\treturn &Runner{\n    33→\t\tcfg: cfg,\n    34→\t}\n    35→}\n    36→\n    37→func (r *Runner) Run(ctx context.Context) error {\n    38→\tdata, err := os.ReadFile(r.cfg.WorkflowPath)\n    39→\tif err != nil {\n    40→\t\treturn fmt.Errorf(\"reading workflow file: %w\", err)\n    41→\t}\n    42→\n    43→\twf, err := dsl.ParseForContainer(string(data))\n    44→\tif err != nil {\n    45→\t\treturn fmt.Errorf(\"parsing workflow: %w\", err)\n    46→\t}\n    47→\n    48→\tstatusWriter := protocol.NewStatusWriter(r.cfg.StatusOutput)\n    49→\tgenericAdapter := generic.New()\n    50→\tgenericAdapter.RunID = r.cfg.RunID\n    51→\tpromptAdapter := prompt.New()\n    52→\tpromptAdapter.RunID = r.cfg.RunID\n    53→\tpromptAdapter.StatusWriter = statusWriter\n    54→\tif cmd, ok := os.LookupEnv(\"CLOCHE_AGENT_COMMAND\"); ok {\n    55→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    56→\t}\n    57→\tif cmd := wf.Config[\"container.agent_command\"]; cmd != \"\" {\n    58→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    59→\t}\n    60→\tif args := wf.Config[\"container.agent_args\"]; args != \"\" {\n    61→\t\tpromptAdapter.ExplicitArgs = strings.Fields(args)\n    62→\t}\n    63→\n    64→\t// Reset per-run state from any previous run\n    65→\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"attempt_count\"))\n    66→\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"output\"))\n    67→\n    68→\t// Create unified log writer\n    69→\tulog, err := logstream.New(r.cfg.WorkDir)\n    70→\tif err != nil {\n    71→\t\treturn fmt.Errorf(\"creating unified log: %w\", err)\n    72→\t}\n    73→\tdefer ulog.Close()\n    74→\n    75→\tgenericAdapter.StatusWriter = statusWriter\n    76→\n    77→\texecutor := &stepExecutor{\n    78→\t\tworkDir:      r.cfg.WorkDir,\n    79→\t\tgeneric:      genericAdapter,\n    80→\t\tprompt:       promptAdapter,\n    81→\t\tlogStream:    ulog,\n    82→\t\tstatusWriter: statusWriter,\n    83→\t}\n    84→\n    85→\teng := engine.New(executor)\n    86→\teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n    87→\n    88→\t// Generate a run title from the prompt if one was not provided by the caller.\n    89→\t// The daemon sets title from --title; if empty, the agent extracts from prompt.\n    90→\tif title := extractTitle(r.cfg.WorkDir, r.cfg.RunID); title != \"\" {\n    91→\t\tstatusWriter.RunTitle(title)\n    92→\t}\n    93→\n    94→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n    95→\n    96→\trun, runErr := eng.Run(ctx, wf)\n    97→\tif runErr != nil {\n    98→\t\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:failed\")\n    99→\t\tulog.Log(logstream.TypeStatus, \"error: \"+runErr.Error())\n   100→\t\tulog.Log(logstream.TypeStatus, \"run_completed: failed\")\n   101→\t\tstatusWriter.Error(\"\", runErr.Error())\n   102→\t\tstatusWriter.RunCompleted(\"failed\")\n   103→\t\treturn runErr\n   104→\t}\n   105→\n   106→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:\"+string(run.State))\n   107→\n   108→\tulog.Log(logstream.TypeStatus, \"run_completed: \"+string(run.State))\n   109→\tstatusWriter.RunCompleted(string(run.State))\n   110→\treturn nil\n   111→}\n   112→\n   113→type stepExecutor struct {\n   114→\tworkDir      string\n   115→\tgeneric      *generic.Adapter\n   116→\tprompt       *prompt.Adapter\n   117→\tlogStream    *logstream.Writer\n   118→\tstatusWriter *protocol.StatusWriter\n   119→}\n   120→\n   121→func (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n   122→\tswitch step.Type {\n   123→\tcase domain.StepTypeScript:\n   124→\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   125→\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   126→\t\treturn result, err\n   127→\tcase domain.StepTypeAgent:\n   128→\t\tif _, ok := step.Config[\"run\"]; ok {\n   129→\t\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   130→\t\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   131→\t\t\treturn result, err\n   132→\t\t}\n   133→\t\tif _, ok := step.Config[\"prompt\"]; ok {\n   134→\t\t\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   135→\t\t\t\te.prompt.Commands = prompt.ParseCommands(cmd)\n   136→\t\t\t}\n   137→\t\t\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   138→\t\t\t\te.prompt.ExplicitArgs = strings.Fields(args)\n   139→\t\t\t}\n   140→\t\t\tresult, err := e.prompt.Execute(ctx, step, e.workDir)\n   141→\t\t\te.copyToLLMLog(step.Name)\n   142→\t\t\te.logStepOutput(step.Name, logstream.TypeLLM)\n   143→\t\t\treturn result, err\n   144→\t\t}\n   145→\t\treturn \"\", fmt.Errorf(\"agent step %q requires either 'run' or 'prompt' config\", step.Name)\n   146→\tdefault:\n   147→\t\treturn \"\", fmt.Errorf(\"unknown step type: %s\", step.Type)\n   148→\t}\n   149→}\n   150→\n   151→// logStepOutput reads the per-step log file and writes its contents to the unified log.\n   152→func (e *stepExecutor) logStepOutput(stepName string, typ logstream.EntryType) {\n   153→\tpath := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   154→\tdata, err := os.ReadFile(path)\n   155→\tif err != nil || len(data) == 0 {\n   156→\t\treturn\n   157→\t}\n   158→\te.logStream.Log(typ, string(data))\n   159→}\n   160→\n   161→// copyToLLMLog copies <step>.log to llm-<step>.log for agent prompt steps.\n   162→func (e *stepExecutor) copyToLLMLog(stepName string) {\n   163→\tsrc := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   164→\tdst := filepath.Join(e.workDir, \".cloche\", \"output\", \"llm-\"+stepName+\".log\")\n   165→\tdata, err := os.ReadFile(src)\n   166→\tif err != nil {\n   167→\t\treturn\n   168→\t}\n   169→\t_ = os.WriteFile(dst, data, 0644)\n   170→}\n   171→\n   172→type statusReporter struct {\n   173→\twriter    *protocol.StatusWriter\n   174→\tlogStream *logstream.Writer\n   175→}\n   176→\n   177→func (s *statusReporter) OnStepStart(_ *domain.Run, step *domain.Step) {\n   178→\ts.writer.StepStarted(step.Name)\n   179→\ts.logStream.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n   180→}\n   181→\n   182→func (s *statusReporter) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   183→\ts.writer.StepCompleted(step.Name, result)\n   184→\ts.logStream.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n   185→}\n   186→\n   187→func (s *statusReporter) OnRunComplete(_ *domain.Run) {}\n   188→\n   189→// extractTitle tries to derive a one-line summary from the run's prompt content.\n   190→// It reads the per-run prompt.txt file (written by the daemon before container start),\n   191→// then returns the first non-empty line, truncated to 100 characters.\n   192→func extractTitle(workDir string, runID string) string {\n   193→\t// Try the per-run prompt file\n   194→\tpromptPath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   195→\tif _, err := os.Stat(promptPath); err != nil {\n   196→\t\t// Fall back to legacy path\n   197→\t\tpromptPath = filepath.Join(workDir, \".cloche\", \"prompt.txt\")\n   198→\t}\n   199→\tdata, err := os.ReadFile(promptPath)\n   200→\tif err != nil || len(data) == 0 {\n   201→\t\treturn \"\"\n   202→\t}\n   203→\n   204→\ttext := strings.TrimSpace(string(data))\n   205→\tif text == \"\" {\n   206→\t\treturn \"\"\n   207→\t}\n   208→\n   209→\t// Take first non-empty line as the title\n   210→\tfor _, line := range strings.Split(text, \"\\n\") {\n   211→\t\tline = strings.TrimSpace(line)\n   212→\t\t// Skip markdown headers, comment markers, and blank lines\n   213→\t\tif line == \"\" || line == \"---\" || line == \"```\" {\n   214→\t\t\tcontinue\n   215→\t\t}\n   216→\t\t// Strip leading markdown header markers\n   217→\t\tline = strings.TrimLeft(line, \"# \")\n   218→\t\tline = strings.TrimSpace(line)\n   219→\t\tif line == \"\" {\n   220→\t\t\tcontinue\n   221→\t\t}\n   222→\t\tif len(line) > 100 {\n   223→\t\t\tline = line[:97] + \"...\"\n   224→\t\t}\n   225→\t\treturn line\n   226→\t}\n   227→\treturn \"\"\n   228→}\n   229→"}]},"parent_tool_use_id":"toolu_01TQUiMsxdg5gnwAGacmevRe","session_id":"8ea6a4db-317b-4116-946b-dfa5f420f957","uuid":"652f7de6-387d-4ea7-bace-7d73a76f09ac"}
