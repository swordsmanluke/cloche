33â†’\t\tif _, err := os.Stat(claudeDir); err == nil {\n   134â†’\t\t\texec.CommandContext(ctx, \"docker\", \"cp\", claudeDir, containerID+\":/home/agent/.claude\").Run()\n   135â†’\t\t}\n   136â†’\t\tclaudeJSON := home + \"/.claude.json\"\n   137â†’\t\tif _, err := os.Stat(claudeJSON); err == nil {\n   138â†’\t\t\texec.CommandContext(ctx, \"docker\", \"cp\", claudeJSON, containerID+\":/home/agent/.claude.json\").Run()\n   139â†’\t\t}\n   140â†’\t}\n   141â†’\n   142â†’\t// 5. Start the container\n   143â†’\tstartCmd := exec.CommandContext(ctx, \"docker\", \"start\", containerID)\n   144â†’\tvar startStderr bytes.Buffer\n   145â†’\tstartCmd.Stderr = &startStderr\n   146â†’\tif err := startCmd.Run(); err != nil {\n   147â†’\t\texec.CommandContext(ctx, \"docker\", \"rm\", \"-f\", containerID).Run()\n   148â†’\t\treturn \"\", fmt.Errorf(\"starting container: %s: %w\", startStderr.String(), err)\n   149â†’\t}\n   150â†’\n   151â†’\treturn containerID, nil\n   152â†’}\n   153â†’\n   154â†’func (r *Runtime) Stop(ctx context.Context, containerID string) error {\n   155â†’\tcmd := exec.CommandContext(ctx, \"docker\", \"stop\", containerID)\n   156â†’\tvar stderr bytes.Buffer\n   157â†’\tcmd.Stderr = &stderr\n   158â†’\n   159â†’\tif err := cmd.Run(); err != nil {\n   160â†’\t\treturn fmt.Errorf(\"stopping container: %s: %w\", stderr.String(), err)\n   161â†’\t}\n   162â†’\treturn nil\n   163â†’}\n   164â†’\n   165â†’func (r *Runtime) AttachOutput(ctx context.Context, containerID string) (io.ReadCloser, error) {\n   166â†’\tcmd := exec.CommandContext(ctx, \"docker\", \"logs\", \"-f\", containerID)\n   167â†’\tstdout, err := cmd.StdoutPipe()\n   168â†’\tif err != nil {\n   169â†’\t\treturn nil, fmt.Errorf(\"creating stdout pipe: %w\", err)\n   170â†’\t}\n   171â†’\n   172â†’\tif err := cmd.Start(); err != nil {\n   173â†’\t\treturn nil, fmt.Errorf(\"attaching to container output: %w\", err)\n   174â†’\t}\n   175â†’\n   176â†’\treturn &cmdReadCloser{ReadCloser: stdout, cmd: cmd}, nil\n   177â†’}\n   178â†’\n   179â†’func (r *Runtime) Wait(ctx context.Context, containerID string) (int, error) {\n   180â†’\tcmd := exec.CommandContext(ctx, \"docker\", \"wait\", containerID)\n   181â†’\tvar stdout, stderr bytes.Buffer\n   182â†’\tcmd.Stdout = &stdout\n   183â†’\tcmd.Stderr = &stderr\n   184â†’\n   185â†’\tif err := cmd.Run(); err != nil {\n   186â†’\t\treturn -1, fmt.Errorf(\"waiting for container: %s: %w\", stderr.String(), err)\n   187â†’\t}\n   188â†’\n   189â†’\tcode, err := strconv.Atoi(strings.TrimSpace(stdout.String()))\n   190â†’\tif err != nil {\n   191â†’\t\treturn -1, fmt.Errorf(\"parsing exit code %q: %w\", stdout.String(), err)\n   192â†’\t}\n   193â†’\treturn code, nil\n   194â†’}\n   195â†’\n   196â†’func (r *Runtime) CopyFrom(ctx context.Context, containerID string, srcPath, dstPath string) error {\n   197â†’\tcmd := exec.CommandContext(ctx, \"docker\", \"cp\", containerID+\":\"+srcPath, dstPath)\n   198â†’\tvar stderr bytes.Buffer\n   199â†’\tcmd.Stderr = &stderr\n   200â†’\tif err := cmd.Run(); err != nil {\n   201â†’\t\treturn fmt.Errorf(\"copying from container: %s: %w\", stderr.String(), err)\n   202â†’\t}\n   203â†’\treturn nil\n   204â†’}\n   205â†’\n   206â†’func (r *Runtime) Logs(ctx context.Context, containerID string) (string, error) {\n   207â†’\tcmd := exec.CommandContext(ctx, \"docker\", \"logs\", containerID)\n   208â†’\tvar stdout, stderr bytes.Buffer\n   209â†’\tcmd.Stdout = &stdout\n   210â†’\tcmd.Stderr = &stderr\n   211â†’\tif err := cmd.Run(); err != nil {\n   212â†’\t\treturn \"\", fmt.Errorf(\"getting container logs: %s: %w\", stderr.String(), err)\n   213â†’\t}\n   214â†’\t// Combine stdout and stderr\n   215â†’\tcombined := stdout.String() + stderr.String()\n   216â†’\treturn combined, nil\n   217â†’}\n   218â†’\n   219â†’func (r *Runtime) Remove(ctx context.Context, containerID string) error {\n   220â†’\tcmd := exec.CommandContext(ctx, \"docker\", \"rm\", containerID)\n   221â†’\tvar stderr bytes.Bu