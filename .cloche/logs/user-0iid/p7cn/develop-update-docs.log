  48â†’\t\tcontainer: container,\n    49â†’\t\trunIDs:    make(map[string]string),\n    50â†’\t\tloops:     make(map[string]*host.Loop),\n    51â†’\t}\n    52â†’}\n    53â†’\n    54â†’func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    55â†’\treturn &ClocheServer{\n    56â†’\t\tstore:        store,\n    57â†’\t\tcaptures:     captures,\n    58â†’\t\tcontainer:    container,\n    59â†’\t\tdefaultImage: defaultImage,\n    60â†’\t\trunIDs:       make(map[string]string),\n    61â†’\t\tloops:        make(map[string]*host.Loop),\n    62â†’\t}\n    63â†’}\n    64â†’\n    65â†’// SetLogStore attaches a log store to the server for indexing extracted log files.\n    66â†’func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    67â†’\ts.logStore = ls\n    68â†’}\n    69â†’\n    70â†’\n    71â†’// SetEvolution attaches an evolution trigger to the server.\n    72â†’func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    73â†’\ts.evolution = trigger\n    74â†’}\n    75â†’\n    76â†’// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    77â†’func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    78â†’\ts.logBroadcast = b\n    79â†’}\n    80â†’\n    81â†’// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    82â†’func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    83â†’\ts.shutdownFn = fn\n    84â†’}\n    85â†’\n    86â†’func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    87â†’\tif s.container == nil {\n    88â†’\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    89â†’\t}\n    90â†’\n    91â†’\t// Generate a unique run ID, retrying on collision\n    92â†’\tvar runID string\n    93â†’\tfor attempts := 0; attempts < 10; attempts++ {\n    94â†’\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    95â†’\t\texisting, err := s.store.GetRun(ctx, runID)\n    96â†’\t\tif err != nil {\n    97â†’\t\t\tbreak // ID is free\n    98â†’\t\t}\n    99â†’\t\t// Reuse if completed more than 1 hour ago\n   100â†’\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   101â†’\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   102â†’\t\t\tbreak\n   103â†’\t\t}\n   104â†’\t}\n   105â†’\n   106â†’\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   107â†’\tif req.Prompt != \"\" {\n   108â†’\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   109â†’\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   110â†’\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   111â†’\t\t}\n   112â†’\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   113â†’\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   114â†’\t\t}\n   115â†’\t}\n   116â†’\trun := domain.NewRun(runID, req.WorkflowName)\n   117â†’\trun.ProjectDir = req.ProjectDir\n   118â†’\trun.Title = req.Title\n   119â†’\tif err := s.store.CreateRun(ctx, run); err != nil {\n   120â†’\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   121â†’\t}\n   122â†’\n   123â†’\t// Resolve image: request-level override, then server default\n   124â†’\timage := req.Image\n   125â†’\tif image == \"\" {\n   126â†’\t\timage = s.defaultImage\n   127â†’\t}\n   128â†’\n   129â†’\t// Launch container start + tracking in background so the RPC returns immediately.\n   130â†’\t// The run stays in \"pending\" state until the container is up.\n   131â†’\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   132â†’\n   133â†’\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   134â†’}\n   135â†’\n   136â†’// launchAndTrack starts the container and then tracks it to completion.\n   137â†’// It runs in a background goroutine with its own context, independent of the\n   138â†’// RPC context which may be cancelled after RunWorkflow returns.\n   139â†’func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   140â†’\tctx := context.Background()\n   141â†’\n   142â†’\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   143â†’\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   144â†’\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   145â†’\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   146â†’\t\t\tif run != nil {\n   147â†’\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   148â†’\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   149â†’\t\t\t}\n   150â†’\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   151â†’\t\t\t\treturn\n   152â†’\t\t}\n   153â†’\t}\n   154â†’\n   155â†’\tbaseSHA := gitHEAD(req.ProjectDir)\n   156â†’\n   157â†’\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   158â†’\t\tImage:        image,\n   159â†’\t\tWorkflowName: req.WorkflowName,\n   160â†’\t\tProjectDir:   req.ProjectDir,\n   161â†’\t\tRunID:        runID,\n   162â†’\t\tNetworkAllow: []string{\"*\"},\n   163â†’\t})\n   164â†’\tif err != nil {\n   165â†’\t\trun, _ := s.store.GetRun(ctx, runID)\n   166â†’\t\tif run != nil {\n   167â†’\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   168â†’\t\t\t_ = s.store.UpdateRun(ctx, run)\n   169â†’\t\t}\n   170â†’\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   171â†’\t\treturn\n   172â†’\t}\n   173â†’\n   174â†’\ts.mu.Lock()\n   175â†’\ts.runIDs[runID] = containerID\n   176â†’\ts.mu.Unlock()\n   177â†’\n   178â†’\trun, _ := s.store.GetRun(ctx, runID)\n   179â†’\tif run != nil {\n   180â†’\t\trun.Start()\n   181â†’\t\trun.ContainerID = containerID\n   182â†’\t\trun.BaseSHA = baseSHA\n   183â†’\t\t_ = s.store.UpdateRun(ctx, run)\n   184â†’\t}\n   185â†’\n   186â†’\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   187â†’}\n   188â†’\n   189â†’func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   190â†’\tctx := context.Background()\n   191â†’\n   192â†’\t// Attach to agent output\n   193â†’\treader, err := s.container.AttachOutput(ctx, containerID)\n   194â†’\tif err != nil {\n   195â†’\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   196â†’\t\t\treturn\n   197â†’\t}\n   198â†’\n   199â†’\t// Parse JSON-lines status messages\n   200â†’\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   201â†’\tscanner := bufio.NewScanner(reader)\n   202â†’\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   203â†’\tfor scanner.Scan() {\n   204â†’\t\tvar msg protocol.StatusMessage\n   205â†’\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   206â†’\t\t\tcontinue\n   207â†’\t\t}\n   208â†’\n   209â†’\t\t// Fast path: log messages don't need store interaction.\n   210â†’\t\tif msg.Type == protocol.MsgLog {\n   211â†’\t\t\tif s.logBroadcast != nil {\n   212â†’\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   213â†’\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   214â†’\t\t\t\t\tType:      \"llm\",\n   215â†’\t\t\t\t\tContent:   msg.Message,\n   216â†’\t\t\t\t\tStepName:  msg.StepName,\n   217â†’\t\t\t\t})\n   218â†’\t\t\t}\n   219â†’\t\t\tcontinue\n   220â†’\t\t}\n   221â†’\n   222â†’\t\trun, err := s.store.GetRun(ctx, runID)\n   223â†’\t\tif err != nil {\n   224â†’\t\t\tcontinue\n   225â†’\t\t}\n   226â†’\n   227â†’\t\tswitch msg.Type {\n   228â†’\t\tcase protocol.MsgStepStarted:\n   229â†’\t\t\trun.RecordStepStart(msg.StepName)\n   230â†’\t\t\tif s.captures != nil {\n   231â†’\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   232â†’\t\t\t\t\tStepName:  msg.StepName,\n   233â†’\t\t\t\t\tStartedAt: msg.Timestamp,\n   234â†’\t\t\t\t})\n   235â†’\t\t\t}\n   236â†’\t\t\tif s.logBroadcast != nil {\n   237â†’\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   238â†’\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   239â†’\t\t\t\t\tType:      \"status\",\n   240â†’\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   241â†’\t\t\t\t\tStepName:  msg.StepName,\n   242â†’\t\t\t\t})\n   243â†’\t\t\t}\n   244â†’\t\tcase protocol.MsgStepCompleted:\n   245â†’\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   246â†’\t\t\tif s.captures != nil {\n   247â†’\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   248â†’\t\t\t\t\tStepName:    msg.StepName,\n   249â†’\t\t\t\t\tResult:      msg.Result,\n   250â†’\t\t\t\t\tCompletedAt: msg.Timestamp,\n   251â†’\t\t\t\t})\n   252â†’\t\t\t}\n   253â†’\t\t\tif s.logBroadcast != nil {\n   254â†’\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   255â†’\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   256â†’\t\t\t\t\tType:      \"status\",\n   257â†’\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   258â†’\t\t\t\t\tStepName:  msg.StepName,\n   259â†’\t\t\t\t})\n   260â†’\t\t\t}\n   261â†’\t\tcase protocol.MsgRunTitle:\n   262â†’\t\t\tif run.Title == \"\" {\n   263â†’\t\t\t\trun.Title = msg.Message\n   264â†’\t\t\t}\n   265â†’\t\tcase protocol.MsgRunCompleted:\n   266â†’\t\t\treportedResult = msg.Result\n   267â†’\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   268â†’\t\t}\n   269â†’\n   270â†’\t\t_ = s.store.UpdateRun(ctx, run)\n   271â†’\t}\n   272â†’\treader.Close()\n   273â†’\n   274â†’\t// Signal live-stream subscribers that this run is done.\n   275â†’\tif s.logBroadcast != nil {\n   276â†’\t\ts.logBroadcast.Finish(runID)\n   277â†’\t}\n   278â†’\n   279â†’\t// Wait for process exit\n   280â†’\texitCode, err := s.container.Wait(ctx, containerID)\n   281â†’\tif err != nil {\n   282â†’\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   283â†’\t}\n   284â†’\n   285â†’\t// Extract step output files from container before it's removed\n   286â†’\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   287â†’\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   288â†’\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   289â†’\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   290â†’\t\t}\n   291â†’\t}\n   292â†’\n   293â†’\t// Capture full container stdout/stderr before the container is removed\n   294â†’\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   295â†’\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   296â†’\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   297â†’\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   298â†’\t\t}\n   299â†’\t}\n   300â†’\n   301â†’\t// Index extracted log files in the log store\n   302â†’\tif s.logStore != nil {\n   303â†’\t\ts.indexLogFiles(ctx, runID, outputDst)\n   304â†’\t}\n   305â†’\n   306â†’\t// Extract results to git branch BEFORE finalizing state, so that\n   307â†’\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   308â†’\t// before the run is marked complete.\n   309â†’\tresultLabel := reportedResult\n   310â†’\tif resultLabel == \"\" {\n   311â†’\t\tif exitCode == 0 {\n   312â†’\t\t\tresultLabel = \"succeeded\"\n   313â†’\t\t} else {\n   314â†’\t\t\tresultLabel = \"failed\"\n   315â†’\t\t}\n   316â†’\t}\n   317â†’\t{\n   318â†’\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   319â†’\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   320â†’\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   321â†’\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   322â†’\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   323â†’\t\t\t} else {\n   324â†’\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   325â†’\t\t\t}\n   326â†’\t\t} else {\n   327â†’\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   328â†’\t\t}\n   329â†’\t}\n   330â†’\n   331â†’\t// Now finalize run state\n   332â†’\trun, err := s.store.GetRun(ctx, runID)\n   333â†’\tif err != nil {\n   334â†’\t\treturn\n   335â†’\t}\n   336â†’\tif run.State == domain.RunStateRunning {\n   337â†’\t\tif reportedResult == \"succeeded\" {\n   338â†’\t\t\trun.Complete(domain.RunStateSucceeded)\n   339â†’\t\t} else if reportedResult != \"\" {\n   340â†’\t\t\trun.Complete(domain.RunStateFailed)\n   341â†’\t\t} else if exitCode == 0 {\n   342â†’\t\t\trun.Complete(domain.RunStateSucceeded)\n   343â†’\t\t} else {\n   344â†’\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   345â†’\t\t}\n   346â†’\t\t_ = s.store.UpdateRun(ctx, run)\n   347â†’\t}\n   348â†’\n   349â†’\t// Fire evolution trigger if configured\n   350â†’\tif s.evolution != nil {\n   351â†’\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   352â†’\t}\n   353â†’\n   354â†’\t// Merge is handled as a workflow step in host.cloche, not here.\n   355â†’\n   356â†’\t// Container retention policy:\n   357â†’\t// - Failed runs: always keep the container for debugging\n   358â†’\t// - Successful runs + --keep-container: keep the container\n   359â†’\t// - Successful runs without --keep-container: remove the container\n   360â†’\trunFinal, _ := s.store.GetRun(ctx, runID)\n   361â†’\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   362â†’\n   363â†’\tif keepContainer || runFailed {\n   364â†’\t\treason := \"--keep-container\"\n   365â†’\t\tif runFailed {\n   366â†’\t\t\treason = \"run failed\"\n   367â†’\t\t}\n   368â†’\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   369â†’\t\tif runFinal != nil {\n   370â†’\t\t\trunFinal.ContainerKept = true\n   371â†’\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   372â†’\t\t}\n   373â†’\t} else {\n   374â†’\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   375â†’\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   376â†’\t\t} else {\n   377â†’\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   378â†’\t\t}\n   379â†’\t}\n   380â†’\n   381â†’\t// Cleanup mapping\n   382â†’\ts.mu.Lock()\n   383â†’\tdelete(s.runIDs, runID)\n   384â†’\ts.mu.Unlock()\n   385â†’}\n   386â†’\n   387â†’func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   388â†’\tvar runs []*domain.Run\n   389â†’\tvar err error\n   390â†’\tif req.ProjectDir != \"\" {\n   391â†’\t\t// Project-scoped: no time filter (project is sufficient scoping)\n   392â†’\t\truns, err = s.store.ListRunsByProject(ctx, req.ProjectDir, time.Time{})\n   393â†’\t} else if req.All {\n   394â†’\t\truns, err = s.store.ListRuns(ctx, time.Time{})\n   395â†’\t} else {\n   396â†’\t\truns, err = s.store.ListRuns(ctx, time.Now().Add(-1*time.Hour))\n   397â†’\t}\n   398â†’\tif err != nil {\n   399â†’\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   400â†’\t}\n   401â†’\n   402â†’\tresp := &pb.ListRunsResponse{}\n   403â†’\tfor _, run := range runs {\n   404â†’\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   405â†’\t\t\tRunId:        run.ID,\n   406â†’\t\t\tWorkflowName: run.WorkflowName,\n   407â†’\t\t\tState:        string(run.State),\n   408â†’\t\t\tStartedAt:    run.StartedAt.String(),\n   409â†’\t\t\tErrorMessage: run.ErrorMessage,\n   410â†’\t\t\tContainerId:  run.ContainerID,\n   411â†’\t\t\tTitle:        run.Title,\n   412â†’\t\t\tIsHost:       run.IsHost,\n   413â†’\t\t\tProjectDir:   run.ProjectDir,\n   414â†’\t\t})\n   415â†’\t}\n   416â†’\treturn resp, nil\n   417â†’}\n   418â†’\n   419â†’func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   420â†’\trun, err := s.store.GetRun(ctx, req.RunId)\n   421â†’\tif err != nil {\n   422â†’\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   423â†’\t}\n   424â†’\n   425â†’\tresp := &pb.GetStatusResponse{\n   426â†’\t\tRunId:        run.ID,\n   427â†’\t\tWorkflowName: run.WorkflowName,\n   428â†’\t\tState:        string(run.State),\n   429â†’\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   430â†’\t\tErrorMessage: run.ErrorMessage,\n   431â†’\t\tContainerId:  run.ContainerID,\n   432â†’\t\tTitle:        run.Title,\n   433â†’\t\tIsHost:       run.IsHost,\n   434â†’\t}\n   435â†’\n   436â†’\t// Check container liveness\n   437â†’\tif run.ContainerID != \"\" && s.container != nil {\n   438â†’\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   439â†’\t\t\tresp.ContainerAlive = cs.Running\n   440â†’\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   441â†’\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   442â†’\t\t\t}\n   443â†’\t\t}\n   444â†’\t}\n   445â†’\n   446â†’\t// Load step executions from captures store if available\n   447â†’\tif s.captures != nil {\n   448â†’\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   449â†’\t\tif err == nil {\n   450â†’\t\t\tfor _, exec := range captures {\n   451â†’\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   452â†’\t\t\t\t\tStepName:    exec.StepName,\n   453â†’\t\t\t\t\tResult:      exec.Result,\n   454â†’\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   455â†’\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   456â†’\t\t\t\t})\n   457â†’\t\t\t}\n   458â†’\t\t}\n   459â†’\t} else {\n   460â†’\t\tfor _, exec := range run.StepExecutions {\n   461â†’\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   462â†’\t\t\t\tStepName:    exec.StepName,\n   463â†’\t\t\t\tResult:      exec.Result,\n   464â†’\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   465â†’\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   466â†’\t\t\t})\n   467â†’\t\t}\n   468â†’\t}\n   469â†’\n   470â†’\treturn resp, nil\n   471â†’}\n   472â†’\n   473â†’func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   474â†’\tctx := stream.Context()\n   475â†’\n   476â†’\t// Check for follow mode via gRPC metadata.\n   477â†’\tfollow := followFromContext(ctx)\n   478â†’\n   479â†’\t// Verify run exists\n   480â†’\trun, err := s.store.GetRun(ctx, req.RunId)\n   481â†’\tif err != nil {\n   482â†’\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   483â†’\t}\n   484â†’\n   485â†’\t// If step_name or log_type filter is set, serve content directly from the log index\n   486â†’\tif req.StepName != \"\" || req.LogType != \"\" {\n   487â†’\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   488â†’\t}\n   489â†’\n   490â†’\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n   491â†’\n   492â†’\t// With -f on an active run: send existing logs then tail live output.\n   493â†’\tif follow && isActive && s.logBroadcast != nil {\n   494â†’\t\treturn s.streamFollowLogs(req.RunId, run, stream)\n   495â†’\t}\n   496â†’\n   497â†’\t// Without -f on an active run: snapshot existing logs and return.\n   498â†’\t// (Legacy callers that relied on implicit live streaming should use -f.)\n   499â†’\t// With -f on a completed run: same as without -f â€” no new lines will arrive.\n   500â†’\n   501â†’\t// Check for full.log first â€” if it exists, serve it as the unified log\n   502â†’\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   503â†’\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   504â†’\t\tif err := stream.Send(&pb.LogEntry{\n   505â†’\t\t\tType:    \"full_log\",\n   506â†’\t\t\tMessage: string(data),\n   507â†’\t\t}); err != nil {\n   508â†’\t\t\treturn err\n   509â†’\t\t}\n   510â†’\t\tif !isActive {\n   511â†’\t\t\tif err := stream.Send(&pb.LogEntry{\n   512â†’\t\t\t\tType:      \"run_completed\",\n   513â†’\t\t\t\tResult:    string(run.State),\n   514â†’\t\t\t\tTimestamp: run.CompletedAt.String(),\n   515â†’\t\t\t\tMessage:   run.ErrorMessage,\n   516â†’\t\t\t}); err != nil {\n   517â†’\t\t\t\treturn err\n   518â†’\t\t\t}\n   519â†’\t\t}\n   520â†’\t\treturn nil\n   521â†’\t}\n   522â†’\n   523â†’\tif s.captures == nil {\n   524â†’\t\treturn fmt.Errorf(\"captures store not configured\")\n   525â†’\t}\n   526â†’\n   527â†’\t// Fall back to capture-based streaming\n   528â†’\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   529â†’\tif err != nil {\n   530â†’\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   531â†’\t}\n   532â†’\n   533â†’\tfor _, exec := range captures {\n   534â†’\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   535â†’\t\t// and one for step_completed (has Result).\n   536â†’\t\tif exec.Result == \"\" {\n   537â†’\t\t\tentry := &pb.LogEntry{\n   538â†’\t\t\t\tType:      \"step_started\",\n   539â†’\t\t\t\tStepName:  exec.StepName,\n   540â†’\t\t\t\tTimestamp: exec.StartedAt.String(),\n   541â†’\t\t\t}\n   542â†’\t\t\tif err := stream.Send(entry); err != nil {\n   543â†’\t\t\t\treturn err\n   544â†’\t\t\t}\n   545â†’\t\t} else {\n   546â†’\t\t\t// Read step output from per-step log file.\n   547â†’\t\t\t// Do NOT fall back to container.log â€” it contains unfiltered output\n   548â†’\t\t\t// from ALL steps and would show wrong content for this step.\n   549â†’\t\t\tvar output string\n   550â†’\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   551â†’\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   552â†’\t\t\t\toutput = string(data)\n   553â†’\t\t\t}\n   554â†’\t\t\tentry := &pb.LogEntry{\n   555â†’\t\t\t\tType:      \"step_completed\",\n   556â†’\t\t\t\tStepName:  exec.StepName,\n   557â†’\t\t\t\tResult:    exec.Result,\n   558â†’\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   559â†’\t\t\t\tMessage:   output,\n   560â†’\t\t\t}\n   561â†’\t\t\tif err := stream.Send(entry); err != nil {\n   562â†’\t\t\t\treturn err\n   563â†’\t\t\t}\n   564â†’\t\t}\n   565â†’\t}\n   566â†’\n   567â†’\t// Send run completion entry\n   568â†’\tif !isActive {\n   569â†’\t\tif err := stream.Send(&pb.LogEntry{\n   570â†’\t\t\tType:      \"run_completed\",\n   571â†’\t\t\tResult:    string(run.State),\n   572â†’\t\t\tTimestamp: run.CompletedAt.String(),\n   573â†’\t\t\tMessage:   run.ErrorMessage,\n   574â†’\t\t}); err != nil {\n   575â†’\t\t\treturn err\n   576â†’\t\t}\n   577â†’\t}\n   578â†’\n   579â†’\treturn nil\n   580â†’}\n   581â†’\n   582â†’// followFromContext checks for the follow flag in gRPC metadata.\n   583â†’func followFromContext(ctx context.Context) bool {\n   584â†’\tmd, ok := metadata.FromIncomingContext(ctx)\n   585â†’\tif !ok {\n   586â†’\t\treturn false\n   587â†’\t}\n   588â†’\tvals := md.Get(\"x-cloche-follow\")\n   589â†’\treturn len(vals) > 0 && vals[0] == \"true\"\n   590â†’}\n   591â†’\n   592â†’// streamFollowLogs sends existing log content then tails live output from the\n   593â†’// broadcaster. It combines snapshot + live streaming (like tail -f).\n   594â†’func (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   595â†’\t// Subscribe first so we don't miss lines written between read and subscribe.\n   596â†’\tsub := s.logBroadcast.Subscribe(runID)\n   597â†’\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   598â†’\n   599â†’\t// Send existing full.log content if available.\n   600â†’\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n   601â†’\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n   602â†’\t\tif err := stream.Send(&pb.LogEntry{\n   603â†’\t\t\tType:    \"full_log\",\n   604â†’\t\t\tMessage: string(data),\n   605â†’\t\t}); err != nil {\n   606â†’\t\t\treturn err\n   607â†’\t\t}\n   608â†’\t}\n   609â†’\n   610â†’\t// Now tail live output from the broadcaster.\n   611â†’\tctx := stream.Context()\n   612â†’\tfor {\n   613â†’\t\tselect {\n   614â†’\t\tcase <-ctx.Done():\n   615â†’\t\t\treturn ctx.Err()\n   616â†’\t\tcase line, ok := <-sub.C:\n   617â†’\t\t\tif !ok {\n   618â†’\t\t\t\t// Run completed â€” send terminal entry.\n   619â†’\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n   620â†’\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n   621â†’\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   622â†’\t\t\t\t\t\tType:      \"run_completed\",\n   623â†’\t\t\t\t\t\tResult:    string(r.State),\n   624â†’\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n   625â†’\t\t\t\t\t\tMessage:   r.ErrorMessage,\n   626â†’\t\t\t\t\t})\n   627â†’\t\t\t\t}\n   628â†’\t\t\t\treturn nil\n   629â†’\t\t\t}\n   630â†’\t\t\tif err := stream.Send(&pb.LogEntry{\n   631â†’\t\t\t\tType:      \"log\",\n   632â†’\t\t\t\tStepName:  line.StepName,\n   633â†’\t\t\t\tMessage:   line.Content,\n   634â†’\t\t\t\tTimestamp: line.Timestamp,\n   635â†’\t\t\t}); err != nil {\n   636â†’\t\t\t\treturn err\n   637â†’\t\t\t}\n   638â†’\t\t}\n   639â†’\t}\n   640â†’}\n   641â†’\n   642â†’// streamFilteredLogs serves log content filtered by step name and/or log type.\n   643â†’// It uses the log index when available, falling back to file path conventions.\n   644â†’func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   645â†’\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   646â†’\n   647â†’\t// Try log index first\n   648â†’\tif s.logStore != nil {\n   649â†’\t\tvar logFiles []*ports.LogFileEntry\n   650â†’\t\tvar err error\n   651â†’\n   652â†’\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   653â†’\t\t\t// Filter by both step and type\n   654â†’\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   655â†’\t\t\tif err == nil {\n   656â†’\t\t\t\tfiltered := logFiles[:0]\n   657â†’\t\t\t\tfor _, lf := range logFiles {\n   658â†’\t\t\t\t\tif lf.FileType == req.LogType {\n   659â†’\t\t\t\t\t\tfiltered = append(filtered, lf)\n   660â†’\t\t\t\t\t}\n   661â†’\t\t\t\t}\n   662â†’\t\t\t\tlogFiles = filtered\n   663â†’\t\t\t}\n   664â†’\t\t} else if req.StepName != \"\" {\n   665â†’\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   666â†’\t\t} else {\n   667â†’\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   668â†’\t\t}\n   669â†’\n   670â†’\t\tif err == nil && len(logFiles) > 0 {\n   671â†’\t\t\tfor _, lf := range logFiles {\n   672â†’\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   673â†’\t\t\t\tif readErr != nil {\n   674â†’\t\t\t\t\tcontinue\n   675â†’\t\t\t\t}\n   676â†’\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   677â†’\t\t\t\t\tType:     lf.FileType + \"_log\",\n   678â†’\t\t\t\t\tStepName: lf.StepName,\n   679â†’\t\t\t\t\tMessage:  string(data),\n   680â†’\t\t\t\t}); err != nil {\n   681â†’\t\t\t\t\treturn err\n   682â†’\t\t\t\t}\n   683â†’\t\t\t}\n   684â†’\t\t\treturn nil\n   685â†’\t\t}\n   686â†’\t}\n   687â†’\n   688â†’\t// Fall back to file path conventions\n   689â†’\tif req.StepName != \"\" {\n   690â†’\t\tvar logPath string\n   691â†’\t\tswitch req.LogType {\n   692â†’\t\tcase \"llm\":\n   693â†’\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   694â†’\t\tdefault:\n   695â†’\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   696â†’\t\t}\n   697â†’\n   698â†’\t\tdata, err := os.ReadFile(logPath)\n   699â†’\t\tif err != nil {\n   700â†’\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   701â†’\t\t}\n   702â†’\t\treturn stream.Send(&pb.LogEntry{\n   703â†’\t\t\tType:     \"step_log\",\n   704â†’\t\t\tStepName: req.StepName,\n   705â†’\t\t\tMessage:  string(data),\n   706â†’\t\t})\n   707â†’\t}\n   708â†’\n   709â†’\treturn fmt.Errorf(\"no log files found matching filter\")\n   710â†’}\n   711â†’\n   712â†’// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n   713â†’// time for an active run. The stream closes when the run completes or the\n   714â†’// client disconnects.\n   715â†’func (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   716â†’\tsub := s.logBroadcast.Subscribe(runID)\n   717â†’\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   718â†’\n   719â†’\tctx := stream.Context()\n   720â†’\tfor {\n   721â†’\t\tselect {\n   722â†’\t\tcase <-ctx.Done():\n   723â†’\t\t\treturn ctx.Err()\n   724â†’\t\tcase line, ok := <-sub.C:\n   725â†’\t\t\tif !ok {\n   726â†’\t\t\t\t// Run completed â€” send terminal entry.\n   727â†’\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   728â†’\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   729â†’\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   730â†’\t\t\t\t\t\tType:      \"run_completed\",\n   731â†’\t\t\t\t\t\tResult:    string(run.State),\n   732â†’\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   733â†’\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   734â†’\t\t\t\t\t})\n   735â†’\t\t\t\t}\n   736â†’\t\t\t\treturn nil\n   737â†’\t\t\t}\n   738â†’\t\t\tif err := stream.Send(&pb.LogEntry{\n   739â†’\t\t\t\tType:      \"log\",\n   740â†’\t\t\t\tStepName:  line.StepName,\n   741â†’\t\t\t\tMessage:   line.Content,\n   742â†’\t\t\t\tTimestamp: line.Timestamp,\n   743â†’\t\t\t}); err != nil {\n   744â†’\t\t\t\treturn err\n   745â†’\t\t\t}\n   746â†’\t\t}\n   747â†’\t}\n   748â†’}\n   749â†’\n   750â†’func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   751â†’\ts.mu.Lock()\n   752â†’\tcontainerID, ok := s.runIDs[req.RunId]\n   753â†’\ts.mu.Unlock()\n   754â†’\n   755â†’\tif !ok {\n   756â†’\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   757â†’\t}\n   758â†’\n   759â†’\tif err := s.container.Stop(ctx, containerID); err != nil {\n   760â†’\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   761â†’\t}\n   762â†’\n   763â†’\t// Mark as cancelled in store\n   764â†’\trun, err := s.store.GetRun(ctx, req.RunId)\n   765â†’\tif err == nil {\n   766â†’\t\trun.Complete(domain.RunStateCancelled)\n   767â†’\t\t_ = s.store.UpdateRun(ctx, run)\n   768â†’\t}\n   769â†’\n   770â†’\treturn &pb.StopRunResponse{}, nil\n   771â†’}\n   772â†’\n   773â†’func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   774â†’\tif s.container == nil {\n   775â†’\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   776â†’\t}\n   777â†’\n   778â†’\tid := req.Id\n   779â†’\tif id == \"\" {\n   780â†’\t\treturn nil, fmt.Errorf(\"id is required\")\n   781â†’\t}\n   782â†’\n   783â†’\t// Try to resolve as a run ID first\n   784â†’\tcontainerID := id\n   785â†’\trun, err := s.store.GetRun(ctx, id)\n   786â†’\tif err == nil {\n   787â†’\t\t// It's a run ID â€” use the container ID from the run record\n   788â†’\t\tif run.ContainerID == \"\" {\n   789â†’\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   790â†’\t\t}\n   791â†’\t\tcontainerID = run.ContainerID\n   792â†’\t}\n   793â†’\n   794â†’\t// Remove the container\n   795â†’\tif err := s.container.Remove(ctx, containerID); err != nil {\n   796â†’\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   797â†’\t}\n   798â†’\n   799â†’\t// If we resolved a run, clear the container_kept flag\n   800â†’\tif run != nil {\n   801â†’\t\trun.ContainerKept = false\n   802â†’\t\t_ = s.store.UpdateRun(ctx, run)\n   803â†’\t}\n   804â†’\n   805â†’\treturn &pb.DeleteContainerResponse{}, nil\n   806â†’}\n   807â†’\n   808â†’func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   809â†’\tprojectDir := req.ProjectDir\n   810â†’\tif projectDir == \"\" {\n   811â†’\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   812â†’\t}\n   813â†’\n   814â†’\t// Verify host.cloche exists\n   815â†’\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   816â†’\tif _, err := os.Stat(hostPath); err != nil {\n   817â†’\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n   818â†’\t}\n   819â†’\n   820â†’\t// Load project config for defaults.\n   821â†’\tprojCfg, _ := config.Load(projectDir)\n   822â†’\n   823â†’\tmaxConc := int(req.MaxConcurrent)\n   824â†’\tif maxConc <= 0 {\n   825â†’\t\tmaxConc = projCfg.Orchestration.Concurrency\n   826â†’\t}\n   827â†’\tif maxConc <= 0 {\n   828â†’\t\tmaxConc = 1\n   829â†’\t}\n   830â†’\n   831â†’\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   832â†’\n   833â†’\t// Compute dedup timeout from config (default 5 minutes).\n   834â†’\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n   835â†’\n   836â†’\tloopCfg := host.LoopConfig{\n   837â†’\t\tProjectDir:    projectDir,\n   838â†’\t\tMaxConcurrent: maxConc,\n   839â†’\t\tStaggerDelay:  stagger,\n   840â†’\t\tDedupTimeout:  dedupTimeout,\n   841â†’\t}\n   842â†’\n   843â†’\ts.mu.Lock()\n   844â†’\tdefer s.mu.Unlock()\n   845â†’\n   846â†’\t// Stop existing loop if running.\n   847â†’\tif existing, ok := s.loops[projectDir]; ok {\n   848â†’\t\texisting.Stop()\n   849â†’\t}\n   850â†’\n   851â†’\t// Check if host.cloche defines a list-tasks workflow for three-phase mode.\n   852â†’\tvar loop *host.Loop\n   853â†’\tif s.hasWorkflow(hostPath, \"list-tasks\") {\n   854â†’\t\tloop = s.createPhaseLoop(loopCfg, projectDir, hostPath, dedupTimeout)\n   855â†’\t} else {\n   856â†’\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n   857â†’\t}\n   858â†’\n   859â†’\ts.loops[projectDir] = loop\n   860â†’\tloop.Start()\n   861â†’\n   862â†’\treturn &pb.EnableLoopResponse{}, nil\n   863â†’}\n   864â†’\n   865â†’// hasWorkflow checks if host.cloche contains a workflow with the given name.\n   866â†’func (s *ClocheServer) hasWorkflow(hostPath, workflowName string) bool {\n   867â†’\tdata, err := os.ReadFile(hostPath)\n   868â†’\tif err != nil {\n   869â†’\t\treturn false\n   870â†’\t}\n   871â†’\treturn strings.Contains(string(data), fmt.Sprintf(\"workflow %q\", workflowName))\n   872â†’}\n   873â†’\n   874â†’// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n   875â†’// main, and finalize workflows from host.cloche.\n   876â†’func (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir, hostPath string, dedupTimeout time.Duration) *host.Loop {\n   877â†’\t// Phase 1: list-tasks function\n   878â†’\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n   879â†’\t\trunner := &host.Runner{\n   880â†’\t\t\tDispatcher: s,\n   881â†’\t\t\tStore:      s.store,\n   882â†’\t\t}\n   883â†’\t\ttasks, _, err := host.RunListTasksWorkflow(ctx, runner, projDir)\n   884â†’\t\treturn tasks, err\n   885â†’\t}\n   886â†’\n   887â†’\t// Phase 2: main function\n   888â†’\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   889â†’\t\trunner := &host.Runner{\n   890â†’\t\t\tDispatcher: s,\n   891â†’\t\t\tStore:      s.store,\n   892â†’\t\t\tTaskID:     taskID,\n   893â†’\t\t}\n   894â†’\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n   895â†’\t}\n   896â†’\n   897â†’\t// Phase 3: finalize function (optional â€” only if host.cloche has it)\n   898â†’\tvar finalizeFn host.FinalizeFunc\n   899â†’\tif s.hasWorkflow(hostPath, \"finalize\") {\n   900â†’\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n   901â†’\t\t\tmainRunID := \"\"\n   902â†’\t\t\tmainOutcome := \"failed\"\n   903â†’\t\t\tif mainResult != nil {\n   904â†’\t\t\t\tmainRunID = mainResult.RunID\n   905â†’\t\t\t\tmainOutcome = string(mainResult.State)\n   906â†’\t\t\t}\n   907â†’\t\t\trunner := &host.Runner{\n   908â†’\t\t\t\tDispatcher: s,\n   909â†’\t\t\t\tStore:      s.store,\n   910â†’\t\t\t\tTaskID:     taskID,\n   911â†’\t\t\t\tExtraEnv: []string{\n   912â†’\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n   913â†’\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n   914â†’\t\t\t\t},\n   915â†’\t\t\t}\n   916â†’\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n   917â†’\t\t}\n   918â†’\t}\n   919â†’\n   920â†’\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n   921â†’\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n   922â†’}\n   923â†’\n   924â†’// createLegacyLoop creates a legacy single-function orchestration loop.\n   925â†’func (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n   926â†’\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   927â†’\t\trunner := &host.Runner{\n   928â†’\t\t\tDispatcher: s,\n   929â†’\t\t\tStore:      s.store,\n   930â†’\t\t\tTaskID:     taskID,\n   931â†’\t\t}\n   932â†’\t\treturn runner.Run(ctx, projDir)\n   933â†’\t}\n   934â†’\n   935â†’\tloop := host.NewLoop(loopCfg, s.store, runFn)\n   936â†’\n   937â†’\t// Configure daemon-managed task assignment if a list-tasks command is set.\n   938â†’\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n   939â†’\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n   940â†’\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n   941â†’\t}\n   942â†’\n   943â†’\treturn loop\n   944â†’}\n   945â†’\n   946â†’// GetLoopTasks returns the current task pipeline state for a project's\n   947â†’// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n   948â†’// loop is active for the project.\n   949â†’func (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n   950â†’\ts.mu.Lock()\n   951â†’\tloop, ok := s.loops[projectDir]\n   952â†’\ts.mu.Unlock()\n   953â†’\tif !ok {\n   954â†’\t\treturn nil\n   955â†’\t}\n   956â†’\tsnapshot := loop.GetTaskSnapshot()\n   957â†’\tentries := make([]web.TaskEntry, len(snapshot))\n   958â†’\tfor i, e := range snapshot {\n   959â†’\t\tentry := web.TaskEntry{\n   960â†’\t\t\tID:          e.Task.ID,\n   961â†’\t\t\tStatus:      e.Task.Status,\n   962â†’\t\t\tTitle:       e.Task.Title,\n   963â†’\t\t\tDescription: e.Task.Description,\n   964â†’\t\t\tMetadata:    e.Task.Metadata,\n   965â†’\t\t\tAssigned:    e.Assigned,\n   966â†’\t\t\tRunID:       e.RunID,\n   967â†’\t\t}\n   968â†’\t\tif !e.AssignedAt.IsZero() {\n   969â†’\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n   970â†’\t\t}\n   971â†’\t\tentries[i] = entry\n   972â†’\t}\n   973â†’\treturn entries\n   974â†’}\n   975â†’\n   976â†’func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n   977â†’\tprojectDir := req.ProjectDir\n   978â†’\tif projectDir == \"\" {\n   979â†’\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   980â†’\t}\n   981â†’\n   982â†’\ts.mu.Lock()\n   983â†’\tdefer s.mu.Unlock()\n   984â†’\n   985â†’\tif loop, ok := s.loops[projectDir]; ok {\n   986â†’\t\tloop.Stop()\n   987â†’\t\tdelete(s.loops, projectDir)\n   988â†’\t}\n   989â†’\n   990â†’\treturn &pb.DisableLoopResponse{}, nil\n   991â†’}\n   992â†’\n   993â†’func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n   994â†’\t// Stop all orchestration loops.\n   995â†’\ts.mu.Lock()\n   996â†’\tfor _, loop := range s.loops {\n   997â†’\t\tloop.Stop()\n   998â†’\t}\n   999â†’\ts.loops = make(map[string]*host.Loop)\n  1000â†’\ts.mu.Unlock()\n  1001â†’\n  1002â†’\tif s.shutdownFn == nil {\n  1003â†’\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n  1004â†’\t}\n  1005â†’\tgo s.shutdownFn()\n  1006â†’\treturn &pb.ShutdownResponse{}, nil\n  1007â†’}\n  1008â†’\n  1009â†’// indexLogFiles scans the extracted output directory and creates log_files index entries.\n  1010â†’func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n  1011â†’\tentries, err := os.ReadDir(outputDir)\n  1012â†’\tif err != nil {\n  1013â†’\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n  1014â†’\t\treturn\n  1015â†’\t}\n  1016â†’\n  1017â†’\tnow := time.Now()\n  1018â†’\tfor _, entry := range entries {\n  1019â†’\t\tif entry.IsDir() {\n  1020â†’\t\t\tcontinue\n  1021â†’\t\t}\n  1022â†’\t\tname := entry.Name()\n  1023â†’\t\tif !strings.HasSuffix(name, \".log\") {\n  1024â†’\t\t\tcontinue\n  1025â†’\t\t}\n  1026â†’\n  1027â†’\t\tvar fileType, stepName string\n  1028â†’\t\tbase := strings.TrimSuffix(name, \".log\")\n  1029â†’\n  1030â†’\t\tswitch {\n  1031â†’\t\tcase name == \"full.log\":\n  1032â†’\t\t\tfileType = \"full\"\n  1033â†’\t\tcase name == \"container.log\":\n  1034â†’\t\t\t// container.log is internal, not indexed as a user-facing log type\n  1035â†’\t\t\tcontinue\n  1036â†’\t\tcase strings.HasPrefix(name, \"llm-\"):\n  1037â†’\t\t\tfileType = \"llm\"\n  1038â†’\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n  1039â†’\t\tdefault:\n  1040â†’\t\t\tfileType = \"script\"\n  1041â†’\t\t\tstepName = base\n  1042â†’\t\t}\n  1043â†’\n  1044â†’\t\tinfo, _ := entry.Info()\n  1045â†’\t\tvar fileSize int64\n  1046â†’\t\tif info != nil {\n  1047â†’\t\t\tfileSize = info.Size()\n  1048â†’\t\t}\n  1049â†’\n  1050â†’\t\tlogEntry := &ports.LogFileEntry{\n  1051â†’\t\t\tRunID:     runID,\n  1052â†’\t\t\tStepName:  stepName,\n  1053â†’\t\t\tFileType:  fileType,\n  1054â†’\t\t\tFilePath:  filepath.Join(outputDir, name),\n  1055â†’\t\t\tFileSize:  fileSize,\n  1056â†’\t\t\tCreatedAt: now,\n  1057â†’\t\t}\n  1058â†’\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n  1059â†’\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n  1060â†’\t\t}\n  1061â†’\t}\n  1062â†’}\n  1063â†’\n  1064â†’func gitHEAD(dir string) string {\n  1065â†’\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n  1066â†’\tcmd.Dir = dir\n  1067â†’\tout, err := cmd.Output()\n  1068â†’\tif err != nil {\n  1069â†’\t\treturn \"\"\n  1070â†’\t}\n  1071â†’\treturn strings.TrimSpace(string(out))\n  1072â†’}\n  1073â†’"}]},"parent_tool_use_id":"toolu_01TQUiMsxdg5gnwAGacmevRe","session_id":"8ea6a4db-317b-4116-946b-dfa5f420f957","uuid":"ccf1319d-1f04-4012-924c-57757dc40cde"}
