"-e\", \"ANTHROPIC_API_KEY\")\n    54â†’\t}\n    55â†’\n    56â†’\t// Claude auth files are copied (not mounted) after docker create so each\n    57â†’\t// container gets its own copy â€” avoids concurrent write conflicts.\n    58â†’\n    59â†’\t// Support extra volume mounts via CLOCHE_EXTRA_MOUNTS (comma-separated host:container pairs)\n    60â†’\tif mounts := os.Getenv(\"CLOCHE_EXTRA_MOUNTS\"); mounts != \"\" {\n    61â†’\t\tfor _, m := range strings.Split(mounts, \",\") {\n    62â†’\t\t\tif strings.Contains(m, \":\") {\n    63â†’\t\t\t\targs = append(args, \"-v\", m)\n    64â†’\t\t\t}\n    65â†’\t\t}\n    66â†’\t}\n    67â†’\n    68â†’\t// Support extra env vars via CLOCHE_EXTRA_ENV (comma-separated KEY=VALUE pairs)\n    69â†’\tif extraEnv := os.Getenv(\"CLOCHE_EXTRA_ENV\"); extraEnv != \"\" {\n    70â†’\t\tfor _, e := range strings.Split(extraEnv, \",\") {\n    71â†’\t\t\tif strings.Contains(e, \"=\") {\n    72â†’\t\t\t\targs = append(args, \"-e\", e)\n    73â†’\t\t\t}\n    74â†’\t\t}\n    75â†’\t}\n    76â†’\n    77â†’\t// No --network none: agent needs network for git push and API access\n    78â†’\n    79â†’\tif useDefaultCmd {\n    80â†’\t\t// Wrap: chown workspace, strip host-side tools (e.g. Serena MCP) that\n    81â†’\t\t// cause the agent to waste time on onboarding, then exec as agent.\n    82â†’\t\twrappedCmd := fmt.Sprintf(\n    83â†’\t\t\t\"chown -R agent:agent /workspace\"+\n    84â†’\t\t\t\t\" && chown -R agent:agent /home/agent/.claude /home/agent/.claude.json 2>/dev/null\"+\n    85â†’\t\t\t\t\" && rm -rf /workspace/.serena\"+\n    86â†’\t\t\t\t\" && f=/home/agent/.claude/settings.json\"+\n    87â†’\t\t\t\t` && [ -f \"$f\" ] && sed -i '/\"enabledPlugins\"/,/}/d' \"$f\"`+\n    88â†’\t\t\t\t\"; exec su agent -s /bin/sh -c %q\",\n    89â†’\t\t\tstrings.Join(containerCmd, \" \"),\n    90â†’\t\t)\n    91â†’\t\targs = append(args, cfg.Image, \"sh\", \"-c\", wrappedCmd)\n    92â†’\t} else {\n    93â†’\t\targs = append(args, cfg.Image)\n    94â†’\t\targs