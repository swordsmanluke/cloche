{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KJeWrmk7yJbkD7PyxskuZj","type":"tool_result","content":"     1→workflow \"main\" {\n     2→  host {\n     3→    agent_command = \"claude\"\n     4→  }\n     5→\n     6→  step ready-tasks {\n     7→    run     = \"bash .cloche/scripts/ready-tasks.sh 1\"\n     8→    results = [success, fail]\n     9→  }\n    10→\n    11→  step claim-task {\n    12→    run     = \"bash .cloche/scripts/claim-task.sh\"\n    13→    results = [success, fail]\n    14→  }\n    15→\n    16→  step prepare-prompt {\n    17→    run     = \"bash .cloche/scripts/prepare-prompt.sh\"\n    18→    results = [success, fail]\n    19→  }\n    20→\n    21→  step develop {\n    22→    workflow_name = \"develop\"\n    23→    results       = [success, fail]\n    24→  }\n    25→\n    26→  step merge {\n    27→    run     = \"bash .cloche/scripts/merge-to-main.sh\"\n    28→    results = [success, fail]\n    29→  }\n    30→\n    31→  step cleanup {\n    32→    run     = \"bash .cloche/scripts/cleanup-run.sh\"\n    33→    results = [success, fail]\n    34→  }\n    35→\n    36→  ready-tasks:success    -> claim-task\n    37→  ready-tasks:fail       -> abort\n    38→  claim-task:success     -> prepare-prompt\n    39→  claim-task:fail        -> abort\n    40→  prepare-prompt:success -> develop\n    41→  prepare-prompt:fail    -> abort\n    42→  develop:success        -> merge\n    43→  develop:fail           -> abort\n    44→  merge:success          -> cleanup\n    45→  merge:fail             -> abort\n    46→  cleanup:success        -> done\n    47→  cleanup:fail           -> done\n    48→}\n    49→"}]},"parent_tool_use_id":"toolu_017xCxwq7vtimYnzVCvKMfnj","session_id":"aeb114c6-22ff-4078-baec-d21a69457fa7","uuid":"b7564fa2-0481-4a04-bc53-557ff3a05559"}
