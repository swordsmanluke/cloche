{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JeRnDWiunar4jkCvX23tXL","type":"tool_result","content":"     1→package domain_test\n     2→\n     3→import (\n     4→\t\"testing\"\n     5→\t\"time\"\n     6→\n     7→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     8→\t\"github.com/stretchr/testify/assert\"\n     9→)\n    10→\n    11→func TestRun_Lifecycle(t *testing.T) {\n    12→\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n    13→\tassert.Equal(t, domain.RunStatePending, run.State)\n    14→\n    15→\trun.Start()\n    16→\tassert.Equal(t, domain.RunStateRunning, run.State)\n    17→\tassert.False(t, run.StartedAt.IsZero())\n    18→\n    19→\trun.RecordStepStart(\"code\")\n    20→\tassert.Equal(t, []string{\"code\"}, run.ActiveSteps)\n    21→\tassert.Len(t, run.StepExecutions, 1)\n    22→\n    23→\trun.RecordStepComplete(\"code\", \"success\")\n    24→\tassert.Empty(t, run.ActiveSteps)\n    25→\tassert.Equal(t, \"success\", run.StepExecutions[0].Result)\n    26→\tassert.False(t, run.StepExecutions[0].CompletedAt.IsZero())\n    27→\n    28→\trun.Complete(domain.RunStateSucceeded)\n    29→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n    30→\tassert.False(t, run.CompletedAt.IsZero())\n    31→}\n    32→\n    33→func TestRunProjectDir(t *testing.T) {\n    34→\tr := domain.NewRun(\"test-1\", \"develop\")\n    35→\tr.ProjectDir = \"/home/user/project\"\n    36→\tassert.Equal(t, \"/home/user/project\", r.ProjectDir)\n    37→}\n    38→\n    39→func TestRunTitle(t *testing.T) {\n    40→\tr := domain.NewRun(\"test-1\", \"develop\")\n    41→\tr.Title = \"Add dark mode toggle\"\n    42→\tassert.Equal(t, \"Add dark mode toggle\", r.Title)\n    43→}\n    44→\n    45→func TestStepExecutionFields(t *testing.T) {\n    46→\texec := &domain.StepExecution{\n    47→\t\tStepName: \"implement\",\n    48→\t\tResult:   \"success\",\n    49→\t}\n    50→\tassert.Equal(t, \"implement\", exec.StepName)\n    51→\tassert.Equal(t, \"success\", exec.Result)\n    52→}\n    53→\n    54→func TestRun_Fail(t *testing.T) {\n    55→\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n    56→\trun.Start()\n    57→\trun.Fail(\"container exploded\")\n    58→\tassert.Equal(t, domain.RunStateFailed, run.State)\n    59→\tassert.False(t, run.CompletedAt.IsZero())\n    60→\tassert.Equal(t, \"container exploded\", run.ErrorMessage)\n    61→}\n    62→\n    63→func TestRunIsHost(t *testing.T) {\n    64→\tr := domain.NewRun(\"host-1\", \"main\")\n    65→\tassert.False(t, r.IsHost)\n    66→\tr.IsHost = true\n    67→\tassert.True(t, r.IsHost)\n    68→}\n    69→\n    70→func TestRun_StepExecution_Duration(t *testing.T) {\n    71→\texec := &domain.StepExecution{\n    72→\t\tStepName:    \"code\",\n    73→\t\tStartedAt:   time.Now().Add(-5 * time.Second),\n    74→\t\tCompletedAt: time.Now(),\n    75→\t}\n    76→\tassert.InDelta(t, 5.0, exec.Duration().Seconds(), 0.1)\n    77→}\n    78→\n    79→func TestTaskAggregateStatus(t *testing.T) {\n    80→\tnow := time.Now()\n    81→\tmkRun := func(state domain.RunState, startedAt time.Time) *domain.Run {\n    82→\t\tr := domain.NewRun(\"r\", \"wf\")\n    83→\t\tr.State = state\n    84→\t\tr.StartedAt = startedAt\n    85→\t\treturn r\n    86→\t}\n    87→\n    88→\ttests := []struct {\n    89→\t\tname string\n    90→\t\truns []*domain.Run\n    91→\t\twant domain.RunState\n    92→\t}{\n    93→\t\t{\n    94→\t\t\tname: \"empty returns pending\",\n    95→\t\t\truns: nil,\n    96→\t\t\twant: domain.RunStatePending,\n    97→\t\t},\n    98→\t\t{\n    99→\t\t\tname: \"single succeeded\",\n   100→\t\t\truns: []*domain.Run{mkRun(domain.RunStateSucceeded, now)},\n   101→\t\t\twant: domain.RunStateSucceeded,\n   102→\t\t},\n   103→\t\t{\n   104→\t\t\tname: \"single failed\",\n   105→\t\t\truns: []*domain.Run{mkRun(domain.RunStateFailed, now)},\n   106→\t\t\twant: domain.RunStateFailed,\n   107→\t\t},\n   108→\t\t{\n   109→\t\t\tname: \"running outweighs succeeded\",\n   110→\t\t\truns: []*domain.Run{\n   111→\t\t\t\tmkRun(domain.RunStateSucceeded, now.Add(-1*time.Minute)),\n   112→\t\t\t\tmkRun(domain.RunStateRunning, now),\n   113→\t\t\t},\n   114→\t\t\twant: domain.RunStateRunning,\n   115→\t\t},\n   116→\t\t{\n   117→\t\t\tname: \"running outweighs failed\",\n   118→\t\t\truns: []*domain.Run{\n   119→\t\t\t\tmkRun(domain.RunStateFailed, now.Add(-1*time.Minute)),\n   120→\t\t\t\tmkRun(domain.RunStateRunning, now),\n   121→\t\t\t},\n   122→\t\t\twant: domain.RunStateRunning,\n   123→\t\t},\n   124→\t\t{\n   125→\t\t\tname: \"pending outweighs terminal\",\n   126→\t\t\truns: []*domain.Run{\n   127→\t\t\t\tmkRun(domain.RunStateFailed, now.Add(-1*time.Minute)),\n   128→\t\t\t\tmkRun(domain.RunStatePending, now),\n   129→\t\t\t},\n   130→\t\t\twant: domain.RunStatePending,\n   131→\t\t},\n   132→\t\t{\n   133→\t\t\tname: \"running outweighs pending\",\n   134→\t\t\truns: []*domain.Run{\n   135→\t\t\t\tmkRun(domain.RunStatePending, now.Add(-1*time.Minute)),\n   136→\t\t\t\tmkRun(domain.RunStateRunning, now),\n   137→\t\t\t},\n   138→\t\t\twant: domain.RunStateRunning,\n   139→\t\t},\n   140→\t\t{\n   141→\t\t\tname: \"most recent attempt wins - success after failure\",\n   142→\t\t\truns: []*domain.Run{\n   143→\t\t\t\tmkRun(domain.RunStateFailed, now.Add(-2*time.Minute)),\n   144→\t\t\t\tmkRun(domain.RunStateSucceeded, now),\n   145→\t\t\t},\n   146→\t\t\twant: domain.RunStateSucceeded,\n   147→\t\t},\n   148→\t\t{\n   149→\t\t\tname: \"most recent attempt wins - failure after success\",\n   150→\t\t\truns: []*domain.Run{\n   151→\t\t\t\tmkRun(domain.RunStateSucceeded, now.Add(-2*time.Minute)),\n   152→\t\t\t\tmkRun(domain.RunStateFailed, now),\n   153→\t\t\t},\n   154→\t\t\twant: domain.RunStateFailed,\n   155→\t\t},\n   156→\t\t{\n   157→\t\t\tname: \"cancelled is terminal - most recent wins\",\n   158→\t\t\truns: []*domain.Run{\n   159→\t\t\t\tmkRun(domain.RunStateCancelled, now.Add(-2*time.Minute)),\n   160→\t\t\t\tmkRun(domain.RunStateSucceeded, now),\n   161→\t\t\t},\n   162→\t\t\twant: domain.RunStateSucceeded,\n   163→\t\t},\n   164→\t\t{\n   165→\t\t\tname: \"active outweighs even most recent terminal\",\n   166→\t\t\truns: []*domain.Run{\n   167→\t\t\t\tmkRun(domain.RunStateRunning, now.Add(-5*time.Minute)),\n   168→\t\t\t\tmkRun(domain.RunStateFailed, now),\n   169→\t\t\t},\n   170→\t\t\twant: domain.RunStateRunning,\n   171→\t\t},\n   172→\t}\n   173→\n   174→\tfor _, tt := range tests {\n   175→\t\tt.Run(tt.name, func(t *testing.T) {\n   176→\t\t\tgot := domain.TaskAggregateStatus(tt.runs)\n   177→\t\t\tassert.Equal(t, tt.want, got)\n   178→\t\t})\n   179→\t}\n   180→}\n   181→"}]},"parent_tool_use_id":"toolu_01TSsKeDhqP9J9fyAVJSzBmN","session_id":"b8cb8c5e-8c4d-4714-8529-015666123eea","uuid":"00ab2700-ac3d-4ccb-9b18-5a3a8b608311"}
