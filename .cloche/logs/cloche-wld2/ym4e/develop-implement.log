{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QLg192hU9cBbJmCUrVR91U","type":"tool_result","content":"     1→package domain\n     2→\n     3→import (\n     4→\t\"strings\"\n     5→\t\"time\"\n     6→)\n     7→\n     8→type RunState string\n     9→\n    10→const (\n    11→\tRunStatePending   RunState = \"pending\"\n    12→\tRunStateRunning   RunState = \"running\"\n    13→\tRunStateSucceeded RunState = \"succeeded\"\n    14→\tRunStateFailed    RunState = \"failed\"\n    15→\tRunStateCancelled RunState = \"cancelled\"\n    16→)\n    17→\n    18→// RunListFilter holds optional filters for listing runs.\n    19→type RunListFilter struct {\n    20→\tProjectDir string\n    21→\tState      RunState\n    22→\tTaskID     string\n    23→\tLimit      int\n    24→\tSince      time.Time\n    25→}\n    26→\n    27→type StepExecution struct {\n    28→\tStepName    string\n    29→\tResult      string\n    30→\tStartedAt   time.Time\n    31→\tCompletedAt time.Time\n    32→\tLogs        string\n    33→\tGitRef      string // output state\n    34→}\n    35→\n    36→func (e *StepExecution) Duration() time.Duration {\n    37→\treturn e.CompletedAt.Sub(e.StartedAt)\n    38→}\n    39→\n    40→type Run struct {\n    41→\tID             string\n    42→\tWorkflowName   string\n    43→\tState          RunState\n    44→\tActiveSteps    []string\n    45→\tStepExecutions []*StepExecution\n    46→\tStartedAt      time.Time\n    47→\tCompletedAt    time.Time\n    48→\tProjectDir     string\n    49→\tErrorMessage   string\n    50→\tContainerID    string\n    51→\tBaseSHA        string // Git HEAD at run start, for result branch creation\n    52→\tContainerKept  bool   // true when the container was retained after run completion\n    53→\tTitle          string // One-line summary of the work being done\n    54→\tIsHost         bool   // true for host workflow runs (vs container runs)\n    55→\tParentRunID    string // ID of the parent (host) run, empty for top-level runs\n    56→\tTaskID         string // optional task ID this run is associated with\n    57→}\n    58→\n    59→func NewRun(id, workflowName string) *Run {\n    60→\treturn &Run{\n    61→\t\tID:           id,\n    62→\t\tWorkflowName: workflowName,\n    63→\t\tState:        RunStatePending,\n    64→\t}\n    65→}\n    66→\n    67→func (r *Run) Start() {\n    68→\tr.State = RunStateRunning\n    69→\tr.StartedAt = time.Now()\n    70→}\n    71→\n    72→func (r *Run) RecordStepStart(stepName string) {\n    73→\tr.ActiveSteps = append(r.ActiveSteps, stepName)\n    74→\tr.StepExecutions = append(r.StepExecutions, &StepExecution{\n    75→\t\tStepName:  stepName,\n    76→\t\tStartedAt: time.Now(),\n    77→\t})\n    78→}\n    79→\n    80→func (r *Run) RecordStepComplete(stepName, result string) {\n    81→\t// Remove from active steps\n    82→\tfor i, name := range r.ActiveSteps {\n    83→\t\tif name == stepName {\n    84→\t\t\tr.ActiveSteps = append(r.ActiveSteps[:i], r.ActiveSteps[i+1:]...)\n    85→\t\t\tbreak\n    86→\t\t}\n    87→\t}\n    88→\t// Mark execution complete\n    89→\tfor i := len(r.StepExecutions) - 1; i >= 0; i-- {\n    90→\t\tif r.StepExecutions[i].StepName == stepName && r.StepExecutions[i].CompletedAt.IsZero() {\n    91→\t\t\tr.StepExecutions[i].Result = result\n    92→\t\t\tr.StepExecutions[i].CompletedAt = time.Now()\n    93→\t\t\treturn\n    94→\t\t}\n    95→\t}\n    96→}\n    97→\n    98→// ActiveStepsString returns a comma-separated representation of active steps\n    99→// for backward-compatible serialization.\n   100→func (r *Run) ActiveStepsString() string {\n   101→\treturn strings.Join(r.ActiveSteps, \",\")\n   102→}\n   103→\n   104→// SetActiveStepsFromString parses a comma-separated string into ActiveSteps.\n   105→func (r *Run) SetActiveStepsFromString(s string) {\n   106→\tif s == \"\" {\n   107→\t\tr.ActiveSteps = nil\n   108→\t\treturn\n   109→\t}\n   110→\tr.ActiveSteps = strings.Split(s, \",\")\n   111→}\n   112→\n   113→func (r *Run) Complete(state RunState) {\n   114→\tr.State = state\n   115→\tr.CompletedAt = time.Now()\n   116→}\n   117→\n   118→func (r *Run) Fail(msg string) {\n   119→\tr.State = RunStateFailed\n   120→\tr.CompletedAt = time.Now()\n   121→\tr.ErrorMessage = msg\n   122→}\n   123→\n   124→// TaskAggregateStatus computes the aggregate status for a group of runs\n   125→// representing attempts at a task. Active statuses (running, pending) outweigh\n   126→// terminal ones, and among terminal-only statuses the most recently started\n   127→// run determines the result.\n   128→func TaskAggregateStatus(runs []*Run) RunState {\n   129→\tif len(runs) == 0 {\n   130→\t\treturn RunStatePending\n   131→\t}\n   132→\n   133→\t// Active statuses outweigh terminal ones. Prefer running over pending.\n   134→\thasRunning := false\n   135→\thasPending := false\n   136→\tfor _, r := range runs {\n   137→\t\tswitch r.State {\n   138→\t\tcase RunStateRunning:\n   139→\t\t\thasRunning = true\n   140→\t\tcase RunStatePending:\n   141→\t\t\thasPending = true\n   142→\t\t}\n   143→\t}\n   144→\tif hasRunning {\n   145→\t\treturn RunStateRunning\n   146→\t}\n   147→\tif hasPending {\n   148→\t\treturn RunStatePending\n   149→\t}\n   150→\n   151→\t// All runs are terminal — return the state of the most recent attempt.\n   152→\tvar latest *Run\n   153→\tfor _, r := range runs {\n   154→\t\tif latest == nil || r.StartedAt.After(latest.StartedAt) {\n   155→\t\t\tlatest = r\n   156→\t\t}\n   157→\t}\n   158→\treturn latest.State\n   159→}\n   160→"}]},"parent_tool_use_id":"toolu_01TSsKeDhqP9J9fyAVJSzBmN","session_id":"b8cb8c5e-8c4d-4714-8529-015666123eea","uuid":"d56523c0-2357-48a3-ad2b-7c9993c883b6"}
