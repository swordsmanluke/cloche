{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A9csjgCqKUeYTUZddmbs11","type":"tool_result","content":"     1→package sqlite\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"database/sql\"\n     6→\t\"fmt\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11→\t_ \"modernc.org/sqlite\"\n    12→)\n    13→\n    14→type Store struct {\n    15→\tdb *sql.DB\n    16→}\n    17→\n    18→func NewStore(dsn string) (*Store, error) {\n    19→\tdb, err := sql.Open(\"sqlite\", dsn)\n    20→\tif err != nil {\n    21→\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n    22→\t}\n    23→\n    24→\t// Enable WAL mode for concurrent read/write access\n    25→\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n    26→\n    27→\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n    28→\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n    29→\n    30→\t// Serialize all Go-side access through a single connection so SQLite\n    31→\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n    32→\tdb.SetMaxOpenConns(1)\n    33→\n    34→\tif err := migrate(db); err != nil {\n    35→\t\tdb.Close()\n    36→\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n    37→\t}\n    38→\n    39→\treturn &Store{db: db}, nil\n    40→}\n    41→\n    42→func (s *Store) Close() error {\n    43→\treturn s.db.Close()\n    44→}\n    45→\n    46→func migrate(db *sql.DB) error {\n    47→\t_, err := db.Exec(`\n    48→\t\tCREATE TABLE IF NOT EXISTS runs (\n    49→\t\t\tid TEXT PRIMARY KEY,\n    50→\t\t\tworkflow_name TEXT NOT NULL,\n    51→\t\t\tstate TEXT NOT NULL,\n    52→\t\t\tactive_steps TEXT,\n    53→\t\t\tstarted_at TEXT,\n    54→\t\t\tcompleted_at TEXT\n    55→\t\t);\n    56→\t\tCREATE TABLE IF NOT EXISTS step_executions (\n    57→\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    58→\t\t\trun_id TEXT NOT NULL,\n    59→\t\t\tstep_name TEXT NOT NULL,\n    60→\t\t\tresult TEXT,\n    61→\t\t\tstarted_at TEXT NOT NULL,\n    62→\t\t\tcompleted_at TEXT,\n    63→\t\t\tlogs TEXT,\n    64→\t\t\tgit_ref TEXT,\n    65→\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    66→\t\t);\n    67→\t`)\n    68→\tif err != nil {\n    69→\t\treturn err\n    70→\t}\n    71→\n    72→\t// Evolution schema additions (idempotent)\n    73→\talterStmts := []string{\n    74→\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n    75→\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n    76→\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n    77→\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n    78→\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n    79→\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n    80→\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n    81→\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n    82→\t\t`ALTER TABLE runs ADD COLUMN title TEXT NOT NULL DEFAULT ''`,\n    83→\t\t`ALTER TABLE runs ADD COLUMN is_host INTEGER NOT NULL DEFAULT 0`,\n    84→\t\t`ALTER TABLE runs ADD COLUMN parent_run_id TEXT NOT NULL DEFAULT ''`,\n    85→\t\t`ALTER TABLE runs ADD COLUMN task_id TEXT NOT NULL DEFAULT ''`,\n    86→\t}\n    87→\tfor _, stmt := range alterStmts {\n    88→\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n    89→\t}\n    90→\n    91→\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n    92→\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    93→\t\trun_id TEXT NOT NULL,\n    94→\t\tstep_name TEXT,\n    95→\t\tfile_type TEXT NOT NULL,\n    96→\t\tfile_path TEXT NOT NULL,\n    97→\t\tfile_size INTEGER,\n    98→\t\tcreated_at TEXT NOT NULL,\n    99→\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n   100→\t)`)\n   101→\tif errLog != nil {\n   102→\t\treturn errLog\n   103→\t}\n   104→\n   105→\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n   106→\t\trun_id TEXT PRIMARY KEY,\n   107→\t\tbranch TEXT NOT NULL,\n   108→\t\tproject TEXT NOT NULL,\n   109→\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n   110→\t\tenqueued_at TEXT NOT NULL,\n   111→\t\tcompleted_at TEXT\n   112→\t)`)\n   113→\tif errMQ != nil {\n   114→\t\treturn errMQ\n   115→\t}\n   116→\n   117→\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n   118→\t\tid TEXT PRIMARY KEY,\n   119→\t\tproject_dir TEXT NOT NULL,\n   120→\t\tworkflow_name TEXT NOT NULL,\n   121→\t\ttrigger_run_id TEXT NOT NULL,\n   122→\t\tcreated_at TEXT NOT NULL,\n   123→\t\tclassification TEXT,\n   124→\t\tchanges_json TEXT NOT NULL,\n   125→\t\tknowledge_delta TEXT\n   126→\t)`)\n   127→\tif err2 != nil {\n   128→\t\treturn err2\n   129→\t}\n   130→\n   131→\treturn nil\n   132→}\n   133→\n   134→func (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n   135→\t_, err := s.db.ExecContext(ctx,\n   136→\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept, title, is_host, parent_run_id, task_id)\n   137→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   138→\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n   139→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, truncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID,\n   140→\t)\n   141→\treturn err\n   142→}\n   143→\n   144→// runSelectCols is the standard column list for scanning a Run row.\n   145→const runSelectCols = `id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,''), COALESCE(is_host,0), COALESCE(parent_run_id,''), COALESCE(task_id,'')`\n   146→\n   147→// scanRun scans a single row into a *domain.Run.\n   148→func scanRun(scanner interface{ Scan(...any) error }) (*domain.Run, error) {\n   149→\trun := &domain.Run{}\n   150→\tvar activeSteps, startedAt, completedAt string\n   151→\tvar containerKept, isHost int\n   152→\terr := scanner.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title, &isHost, &run.ParentRunID, &run.TaskID)\n   153→\tif err != nil {\n   154→\t\treturn nil, err\n   155→\t}\n   156→\trun.SetActiveStepsFromString(activeSteps)\n   157→\trun.StartedAt = parseTime(startedAt)\n   158→\trun.CompletedAt = parseTime(completedAt)\n   159→\trun.ContainerKept = containerKept != 0\n   160→\trun.IsHost = isHost != 0\n   161→\treturn run, nil\n   162→}\n   163→\n   164→func (s *Store) GetRun(ctx context.Context, id string) (*domain.Run, error) {\n   165→\trow := s.db.QueryRowContext(ctx,\n   166→\t\t`SELECT `+runSelectCols+` FROM runs WHERE id = ?`, id)\n   167→\n   168→\trun, err := scanRun(row)\n   169→\tif err == sql.ErrNoRows {\n   170→\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n   171→\t}\n   172→\treturn run, err\n   173→}\n   174→\n   175→func (s *Store) UpdateRun(ctx context.Context, run *domain.Run) error {\n   176→\t_, err := s.db.ExecContext(ctx,\n   177→\t\t`UPDATE runs SET state = ?, active_steps = ?, started_at = ?, completed_at = ?, error_message = ?, container_id = ?, base_sha = ?, container_kept = ?, title = ?, is_host = ?, parent_run_id = ?, task_id = ? WHERE id = ?`,\n   178→\t\tstring(run.State), run.ActiveStepsString(),\n   179→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt),\n   180→\t\ttruncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID, run.ID,\n   181→\t)\n   182→\treturn err\n   183→}\n   184→\n   185→func (s *Store) DeleteRun(ctx context.Context, id string) error {\n   186→\t_, err := s.db.ExecContext(ctx, `DELETE FROM step_executions WHERE run_id = ?`, id)\n   187→\tif err != nil {\n   188→\t\treturn err\n   189→\t}\n   190→\t_, err = s.db.ExecContext(ctx, `DELETE FROM runs WHERE id = ?`, id)\n   191→\treturn err\n   192→}\n   193→\n   194→func (s *Store) ListRuns(ctx context.Context, since time.Time) ([]*domain.Run, error) {\n   195→\tvar rows *sql.Rows\n   196→\tvar err error\n   197→\tif since.IsZero() {\n   198→\t\trows, err = s.db.QueryContext(ctx,\n   199→\t\t\t`SELECT `+runSelectCols+` FROM runs ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`)\n   200→\t} else {\n   201→\t\trows, err = s.db.QueryContext(ctx,\n   202→\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   203→\t\t\tformatTime(since))\n   204→\t}\n   205→\tif err != nil {\n   206→\t\treturn nil, err\n   207→\t}\n   208→\tdefer rows.Close()\n   209→\treturn scanRuns(rows)\n   210→}\n   211→\n   212→// scanRuns scans all rows into a []*domain.Run slice.\n   213→func scanRuns(rows *sql.Rows) ([]*domain.Run, error) {\n   214→\tvar runs []*domain.Run\n   215→\tfor rows.Next() {\n   216→\t\trun, err := scanRun(rows)\n   217→\t\tif err != nil {\n   218→\t\t\treturn nil, err\n   219→\t\t}\n   220→\t\truns = append(runs, run)\n   221→\t}\n   222→\treturn runs, rows.Err()\n   223→}\n   224→\n   225→func (s *Store) ListRunsByProject(ctx context.Context, projectDir string, since time.Time) ([]*domain.Run, error) {\n   226→\tvar rows *sql.Rows\n   227→\tvar err error\n   228→\tif since.IsZero() {\n   229→\t\trows, err = s.db.QueryContext(ctx,\n   230→\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   231→\t\t\tprojectDir)\n   232→\t} else {\n   233→\t\trows, err = s.db.QueryContext(ctx,\n   234→\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? AND started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   235→\t\t\tprojectDir, formatTime(since))\n   236→\t}\n   237→\tif err != nil {\n   238→\t\treturn nil, err\n   239→\t}\n   240→\tdefer rows.Close()\n   241→\treturn scanRuns(rows)\n   242→}\n   243→\n   244→func (s *Store) ListRunsFiltered(ctx context.Context, filter domain.RunListFilter) ([]*domain.Run, error) {\n   245→\tquery := `SELECT ` + runSelectCols + ` FROM runs WHERE 1=1`\n   246→\tvar args []interface{}\n   247→\n   248→\tif filter.ProjectDir != \"\" {\n   249→\t\tquery += ` AND project_dir = ?`\n   250→\t\targs = append(args, filter.ProjectDir)"}]},"parent_tool_use_id":"toolu_01TSsKeDhqP9J9fyAVJSzBmN","session_id":"b8cb8c5e-8c4d-4714-8529-015666123eea","uuid":"0c3e7120-bd26-462f-ab52-aa01ddc3e3a3"}
