{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T9NJaAzVrHSDpeJHoKUCdG","type":"tool_result","content":"     1тЖТpackage config\n     2тЖТ\n     3тЖТimport (\n     4тЖТ\t\"os\"\n     5тЖТ\t\"path/filepath\"\n     6тЖТ\n     7тЖТ\t\"github.com/BurntSushi/toml\"\n     8тЖТ)\n     9тЖТ\n    10тЖТtype DaemonConfig struct {\n    11тЖТ\tListen     string `toml:\"listen\"`\n    12тЖТ\tHTTP       string `toml:\"http\"`\n    13тЖТ\tImage      string `toml:\"image\"`\n    14тЖТ\tDB         string `toml:\"db\"`\n    15тЖТ\tRuntime    string `toml:\"runtime\"`\n    16тЖТ\tAgentPath  string `toml:\"agent_path\"`\n    17тЖТ\tLLMCommand string `toml:\"llm_command\"`\n    18тЖТ}\n    19тЖТ\n    20тЖТtype EvolutionConfig struct {\n    21тЖТ\tEnabled          bool   `toml:\"enabled\"`\n    22тЖТ\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n    23тЖТ\tMinConfidence    string `toml:\"min_confidence\"`\n    24тЖТ\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n    25тЖТ}\n    26тЖТ\n    27тЖТtype OrchestrationConfig struct {\n    28тЖТ\tConcurrency      int     `toml:\"concurrency\"`\n    29тЖТ\tStaggerSeconds   float64 `toml:\"stagger_seconds\"`\n    30тЖТ\tListTasksCommand string  `toml:\"list_tasks_command\"` // shell command to list open tasks (JSON array output)\n    31тЖТ\tDedupSeconds     float64 `toml:\"dedup_seconds\"`      // dedup window for task assignment (default: 300)\n    32тЖТ}\n    33тЖТ\n    34тЖТtype Config struct {\n    35тЖТ\tActive        bool                `toml:\"active\"`\n    36тЖТ\tDaemon        DaemonConfig        `toml:\"daemon\"`\n    37тЖТ\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n    38тЖТ\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n    39тЖТ}\n    40тЖТ\n    41тЖТfunc defaults() Config {\n    42тЖТ\treturn Config{\n    43тЖТ\t\tEvolution: EvolutionConfig{\n    44тЖТ\t\t\tEnabled:          true,\n    45тЖТ\t\t\tDebounceSeconds:  30,\n    46тЖТ\t\t\tMinConfidence:    \"medium\",\n    47тЖТ\t\t\tMaxPromptBullets: 50,\n    48тЖТ\t\t},\n    49тЖТ\t\tOrchestration: OrchestrationConfig{\n    50тЖТ\t\t\tConcurrency:    1,\n    51тЖТ\t\t\tStaggerSeconds: 1.0,\n    52тЖТ\t\t},\n    53тЖТ\t}\n    54тЖТ}\n    55тЖТ\n    56тЖТ// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    57тЖТfunc Load(projectDir string) (*Config, error) {\n    58тЖТ\tcfg := defaults()\n    59тЖТ\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    60тЖТ\n    61тЖТ\tdata, err := os.ReadFile(path)\n    62тЖТ\tif os.IsNotExist(err) {\n    63тЖТ\t\treturn &cfg, nil\n    64тЖТ\t}\n    65тЖТ\tif err != nil {\n    66тЖТ\t\treturn nil, err\n    67тЖТ\t}\n    68тЖТ\n    69тЖТ\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    70тЖТ\t\treturn nil, err\n    71тЖТ\t}\n    72тЖТ\treturn &cfg, nil\n    73тЖТ}\n    74тЖТ\n    75тЖТ// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n    76тЖТ// Returns defaults if the file does not exist.\n    77тЖТfunc LoadGlobal() (*Config, error) {\n    78тЖТ\tcfg := defaults()\n    79тЖТ\n    80тЖТ\thome, err := os.UserHomeDir()\n    81тЖТ\tif err != nil {\n    82тЖТ\t\treturn &cfg, nil\n    83тЖТ\t}\n    84тЖТ\n    85тЖТ\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n    86тЖТ\tdata, err := os.ReadFile(path)\n    87тЖТ\tif os.IsNotExist(err) {\n    88тЖТ\t\treturn &cfg, nil\n    89тЖТ\t}\n    90тЖТ\tif err != nil {\n    91тЖТ\t\treturn nil, err\n    92тЖТ\t}\n    93тЖТ\n    94тЖТ\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    95тЖТ\t\treturn nil, err\n    96тЖТ\t}\n    97тЖТ\treturn &cfg, nil\n    98тЖТ}\n    99тЖТ\n   100тЖТ// LoadGlobalFrom reads the global config from a specific path.\n   101тЖТ// Useful for testing.\n   102тЖТfunc LoadGlobalFrom(path string) (*Config, error) {\n   103тЖТ\tcfg := defaults()\n   104тЖТ\n   105тЖТ\tdata, err := os.ReadFile(path)\n   106тЖТ\tif os.IsNotExist(err) {\n   107тЖТ\t\treturn &cfg, nil\n   108тЖТ\t}\n   109тЖТ\tif err != nil {\n   110тЖТ\t\treturn nil, err\n   111тЖТ\t}\n   112тЖТ\n   113тЖТ\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   114тЖТ\t\treturn nil, err\n   115тЖТ\t}\n   116тЖТ\treturn &cfg, nil\n   117тЖТ}\n   118тЖТ"}]},"parent_tool_use_id":"toolu_01VgKT2HRKQWwdGh23Lxewca","session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"728aaa6f-cf1d-47fa-bda1-1bbb8f16ccae"}
