(val)\n}\n\nfunc cmdSet(args []string) {\n\tif len(args) < 2 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif err := runcontext.Set(projectDir, runID, args[0], args[1]); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":313,"cache_read_input_tokens":54306,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":313},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"16d7e684-abe5-4024-bf03-a683c85ca521"}
