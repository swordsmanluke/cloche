{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y6PmjRRtGqbK5j22Y5b7wx","type":"tool_result","content":"     1тЖТpackage grpc\n     2тЖТ\n     3тЖТimport (\n     4тЖТ\t\"bufio\"\n     5тЖТ\t\"context\"\n     6тЖТ\t\"encoding/json\"\n     7тЖТ\t\"fmt\"\n     8тЖТ\t\"log\"\n     9тЖТ\t\"os\"\n    10тЖТ\t\"os/exec\"\n    11тЖТ\t\"path/filepath\"\n    12тЖТ\t\"strings\"\n    13тЖТ\t\"sync\"\n    14тЖТ\t\"time\"\n    15тЖТ\n    16тЖТ\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17тЖТ\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18тЖТ\t\"github.com/cloche-dev/cloche/internal/config\"\n    19тЖТ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    20тЖТ\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    21тЖТ\t\"github.com/cloche-dev/cloche/internal/host\"\n    22тЖТ\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    23тЖТ\t\"github.com/cloche-dev/cloche/internal/ports\"\n    24тЖТ\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    25тЖТ\trpcgrpc \"google.golang.org/grpc\"\n    26тЖТ)\n    27тЖТ\n    28тЖТtype ClocheServer struct {\n    29тЖТ\tpb.UnimplementedClocheServiceServer\n    30тЖТ\tstore        ports.RunStore\n    31тЖТ\tcaptures     ports.CaptureStore\n    32тЖТ\tlogStore     ports.LogStore\n    33тЖТ\tcontainer    ports.ContainerRuntime\n    34тЖТ\tdefaultImage string\n    35тЖТ\tevolution    *evolution.Trigger\n    36тЖТ\tlogBroadcast *logstream.Broadcaster\n    37тЖТ\tshutdownFn   func()\n    38тЖТ\tmu           sync.Mutex\n    39тЖТ\trunIDs       map[string]string      // run_id -> container_id\n    40тЖТ\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    41тЖТ}\n    42тЖТ\n    43тЖТfunc NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    44тЖТ\treturn &ClocheServer{\n    45тЖТ\t\tstore:     store,\n    46тЖТ\t\tcontainer: container,\n    47тЖТ\t\trunIDs:    make(map[string]string),\n    48тЖТ\t\tloops:     make(map[string]*host.Loop),\n    49тЖТ\t}\n    50тЖТ}\n    51тЖТ\n    52тЖТfunc NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    53тЖТ\treturn &ClocheServer{\n    54тЖТ\t\tstore:        store,\n    55тЖТ\t\tcaptures:     captures,\n    56тЖТ\t\tcontainer:    container,\n    57тЖТ\t\tdefaultImage: defaultImage,\n    58тЖТ\t\trunIDs:       make(map[string]string),\n    59тЖТ\t\tloops:        make(map[string]*host.Loop),\n    60тЖТ\t}\n    61тЖТ}\n    62тЖТ\n    63тЖТ// SetLogStore attaches a log store to the server for indexing extracted log files.\n    64тЖТfunc (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    65тЖТ\ts.logStore = ls\n    66тЖТ}\n    67тЖТ\n    68тЖТ\n    69тЖТ// SetEvolution attaches an evolution trigger to the server.\n    70тЖТfunc (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    71тЖТ\ts.evolution = trigger\n    72тЖТ}\n    73тЖТ\n    74тЖТ// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    75тЖТfunc (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    76тЖТ\ts.logBroadcast = b\n    77тЖТ}\n    78тЖТ\n    79тЖТ// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    80тЖТfunc (s *ClocheServer) SetShutdownFunc(fn func()) {\n    81тЖТ\ts.shutdownFn = fn\n    82тЖТ}\n    83тЖТ\n    84тЖТfunc (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    85тЖТ\tif s.container == nil {\n    86тЖТ\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    87тЖТ\t}\n    88тЖТ\n    89тЖТ\t// Generate a unique run ID, retrying on collision\n    90тЖТ\tvar runID string\n    91тЖТ\tfor attempts := 0; attempts < 10; attempts++ {\n    92тЖТ\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    93тЖТ\t\texisting, err := s.store.GetRun(ctx, runID)\n    94тЖТ\t\tif err != nil {\n    95тЖТ\t\t\tbreak // ID is free\n    96тЖТ\t\t}\n    97тЖТ\t\t// Reuse if completed more than 1 hour ago\n    98тЖТ\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n    99тЖТ\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   100тЖТ\t\t\tbreak\n   101тЖТ\t\t}\n   102тЖТ\t}\n   103тЖТ\n   104тЖТ\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   105тЖТ\tif req.Prompt != \"\" {\n   106тЖТ\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   107тЖТ\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   108тЖТ\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   109тЖТ\t\t}\n   110тЖТ\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   111тЖТ\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   112тЖТ\t\t}\n   113тЖТ\t}\n   114тЖТ\trun := domain.NewRun(runID, req.WorkflowName)\n   115тЖТ\trun.ProjectDir = req.ProjectDir\n   116тЖТ\trun.Title = req.Title\n   117тЖТ\tif err := s.store.CreateRun(ctx, run); err != nil {\n   118тЖТ\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   119тЖТ\t}\n   120тЖТ\n   121тЖТ\t// Resolve image: request-level override, then server default\n   122тЖТ\timage := req.Image\n   123тЖТ\tif image == \"\" {\n   124тЖТ\t\timage = s.defaultImage\n   125тЖТ\t}\n   126тЖТ\n   127тЖТ\t// Launch container start + tracking in background so the RPC returns immediately.\n   128тЖТ\t// The run stays in \"pending\" state until the container is up.\n   129тЖТ\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   130тЖТ\n   131тЖТ\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   132тЖТ}\n   133тЖТ\n   134тЖТ// launchAndTrack starts the container and then tracks it to completion.\n   135тЖТ// It runs in a background goroutine with its own context, independent of the\n   136тЖТ// RPC context which may be cancelled after RunWorkflow returns.\n   137тЖТfunc (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   138тЖТ\tctx := context.Background()\n   139тЖТ\n   140тЖТ\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   141тЖТ\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   142тЖТ\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   143тЖТ\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   144тЖТ\t\t\tif run != nil {\n   145тЖТ\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   146тЖТ\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   147тЖТ\t\t\t}\n   148тЖТ\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   149тЖТ\t\t\t\treturn\n   150тЖТ\t\t}\n   151тЖТ\t}\n   152тЖТ\n   153тЖТ\tbaseSHA := gitHEAD(req.ProjectDir)\n   154тЖТ\n   155тЖТ\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   156тЖТ\t\tImage:        image,\n   157тЖТ\t\tWorkflowName: req.WorkflowName,\n   158тЖТ\t\tProjectDir:   req.ProjectDir,\n   159тЖТ\t\tRunID:        runID,\n   160тЖТ\t\tNetworkAllow: []string{\"*\"},\n   161тЖТ\t})\n   162тЖТ\tif err != nil {\n   163тЖТ\t\trun, _ := s.store.GetRun(ctx, runID)\n   164тЖТ\t\tif run != nil {\n   165тЖТ\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   166тЖТ\t\t\t_ = s.store.UpdateRun(ctx, run)\n   167тЖТ\t\t}\n   168тЖТ\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   169тЖТ\t\treturn\n   170тЖТ\t}\n   171тЖТ\n   172тЖТ\ts.mu.Lock()\n   173тЖТ\ts.runIDs[runID] = containerID\n   174тЖТ\ts.mu.Unlock()\n   175тЖТ\n   176тЖТ\trun, _ := s.store.GetRun(ctx, runID)\n   177тЖТ\tif run != nil {\n   178тЖТ\t\trun.Start()\n   179тЖТ\t\trun.ContainerID = containerID\n   180тЖТ\t\trun.BaseSHA = baseSHA\n   181тЖТ\t\t_ = s.store.UpdateRun(ctx, run)\n   182тЖТ\t}\n   183тЖТ\n   184тЖТ\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   185тЖТ}\n   186тЖТ\n   187тЖТfunc (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   188тЖТ\tctx := context.Background()\n   189тЖТ\n   190тЖТ\t// Attach to agent output\n   191тЖТ\treader, err := s.container.AttachOutput(ctx, containerID)\n   192тЖТ\tif err != nil {\n   193тЖТ\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   194тЖТ\t\t\treturn\n   195тЖТ\t}\n   196тЖТ\n   197тЖТ\t// Parse JSON-lines status messages\n   198тЖТ\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   199тЖТ\tscanner := bufio.NewScanner(reader)\n   200тЖТ\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages"}]},"parent_tool_use_id":"toolu_01VgKT2HRKQWwdGh23Lxewca","session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"def1d608-b861-4147-b15b-ba6b72d3d8cc"}
