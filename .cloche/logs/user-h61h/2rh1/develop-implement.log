{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GaWAW2xa9eyzoTkDmeANM9","type":"tool_result","content":"     1тЖТpackage main\n     2тЖТ\n     3тЖТimport (\n     4тЖТ\t\"context\"\n     5тЖТ\t\"fmt\"\n     6тЖТ\t\"net\"\n     7тЖТ\t\"net/http\"\n     8тЖТ\t\"os\"\n     9тЖТ\t\"os/signal\"\n    10тЖТ\t\"path/filepath\"\n    11тЖТ\t\"syscall\"\n    12тЖТ\n    13тЖТ\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14тЖТ\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    15тЖТ\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    16тЖТ\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    17тЖТ\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    18тЖТ\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    19тЖТ\t\"github.com/cloche-dev/cloche/internal/config\"\n    20тЖТ\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    21тЖТ\thostpkg \"github.com/cloche-dev/cloche/internal/host\"\n    22тЖТ\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    23тЖТ\t\"github.com/cloche-dev/cloche/internal/ports\"\n    24тЖТ\t\"google.golang.org/grpc\"\n    25тЖТ)\n    26тЖТ\n    27тЖТfunc main() {\n    28тЖТ\t// Load global config file (~/.config/cloche/config)\n    29тЖТ\tglobalCfg, err := config.LoadGlobal()\n    30тЖТ\tif err != nil {\n    31тЖТ\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n    32тЖТ\t\tdefaults := config.Config{}\n    33тЖТ\t\tglobalCfg = &defaults\n    34тЖТ\t}\n    35тЖТ\n    36тЖТ\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, \"cloche.db\")\n    37тЖТ\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, \"unix:///tmp/cloche.sock\")\n    38тЖТ\n    39тЖТ\tstore, err := sqlite.NewStore(dbPath)\n    40тЖТ\tif err != nil {\n    41тЖТ\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    42тЖТ\t\tos.Exit(1)\n    43тЖТ\t}\n    44тЖТ\tdefer store.Close()\n    45тЖТ\n    46тЖТ\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    47тЖТ\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    48тЖТ\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    49тЖТ\t} else if n > 0 {\n    50тЖТ\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    51тЖТ\t}\n    52тЖТ\n    53тЖТ\truntime, err := initRuntime(globalCfg)\n    54тЖТ\tif err != nil {\n    55тЖТ\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    56тЖТ\t\tos.Exit(1)\n    57тЖТ\t}\n    58тЖТ\n    59тЖТ\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    60тЖТ\n    61тЖТ\tbroadcaster := logstream.NewBroadcaster()\n    62тЖТ\n    63тЖТ\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    64тЖТ\tsrv.SetLogStore(store)\n    65тЖТ\tsrv.SetLogBroadcaster(broadcaster)\n    66тЖТ\n    67тЖТ\t// Set up evolution trigger\n    68тЖТ\tevoTrigger := initEvolution(globalCfg, store, store)\n    69тЖТ\tif evoTrigger != nil {\n    70тЖТ\t\tsrv.SetEvolution(evoTrigger)\n    71тЖТ\t}\n    72тЖТ\n    73тЖТ\tgrpcServer := grpc.NewServer()\n    74тЖТ\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    75тЖТ\n    76тЖТ\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    77тЖТ\n    78тЖТ\tlis, err := listen(listenAddr)\n    79тЖТ\tif err != nil {\n    80тЖТ\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    81тЖТ\t\tos.Exit(1)\n    82тЖТ\t}\n    83тЖТ\n    84тЖТ\tvar httpServer *http.Server\n    85тЖТ\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n    86тЖТ\t\twebOpts := []web.HandlerOption{\n    87тЖТ\t\t\tweb.WithContainerLogger(runtime),\n    88тЖТ\t\t\tweb.WithLogStore(store),\n    89тЖТ\t\t\tweb.WithLogBroadcaster(broadcaster),\n    90тЖТ\t\t}\n    91тЖТ\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n    92тЖТ\t\tif err != nil {\n    93тЖТ\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n    94тЖТ\t\t\tos.Exit(1)\n    95тЖТ\t\t}\n    96тЖТ\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n    97тЖТ\t\tgo func() {\n    98тЖТ\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n    99тЖТ\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   100тЖТ\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   101тЖТ\t\t\t}\n   102тЖТ\t\t}()\n   103тЖТ\t}\n   104тЖТ\n   105тЖТ\t// Auto-execute main workflow for active projects\n   106тЖТ\tautoRunActiveProjects(store, srv)\n   107тЖТ\n   108тЖТ\tsigCh := make(chan os.Signal, 1)\n   109тЖТ\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   110тЖТ\tgo func() {\n   111тЖТ\t\t<-sigCh\n   112тЖТ\t\tif httpServer != nil {\n   113тЖТ\t\t\thttpServer.Close()\n   114тЖТ\t\t}\n   115тЖТ\t\tgrpcServer.GracefulStop()\n   116тЖТ\t}()\n   117тЖТ\n   118тЖТ\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   119тЖТ\tif err := grpcServer.Serve(lis); err != nil {\n   120тЖТ\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   121тЖТ\t\tos.Exit(1)\n   122тЖТ\t}\n   123тЖТ}\n   124тЖТ\n   125тЖТfunc initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   126тЖТ\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   127тЖТ\n   128тЖТ\tswitch runtimeType {\n   129тЖТ\tcase \"local\":\n   130тЖТ\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   131тЖТ\t\tif agentPath == \"\" {\n   132тЖТ\t\t\t// Look for cloche-agent next to this binary\n   133тЖТ\t\t\texe, err := os.Executable()\n   134тЖТ\t\t\tif err == nil {\n   135тЖТ\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   136тЖТ\t\t\t} else {\n   137тЖТ\t\t\t\tagentPath = \"cloche-agent\"\n   138тЖТ\t\t\t}\n   139тЖТ\t\t}\n   140тЖТ\t\treturn local.NewRuntime(agentPath), nil\n   141тЖТ\tcase \"docker\":\n   142тЖТ\t\treturn docker.NewRuntime()\n   143тЖТ\tdefault:\n   144тЖТ\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   145тЖТ\t}\n   146тЖТ}\n   147тЖТ\n   148тЖТfunc initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   149тЖТ\t// Load config from working directory (daemon-level defaults)\n   150тЖТ\tcfg, err := config.Load(\".\")\n   151тЖТ\tif err != nil || !cfg.Evolution.Enabled {\n   152тЖТ\t\treturn nil\n   153тЖТ\t}\n   154тЖТ\n   155тЖТ\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   156тЖТ\tif llmCmd == \"\" {\n   157тЖТ\t\treturn nil\n   158тЖТ\t}\n   159тЖТ\n   160тЖТ\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   161тЖТ\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   162тЖТ\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   163тЖТ\t\t\t// Load per-project config for confidence threshold\n   164тЖТ\t\t\tprojCfg, err := config.Load(projectDir)\n   165тЖТ\t\t\tif err != nil {\n   166тЖТ\t\t\t\tprojCfg = cfg // fall back to daemon config\n   167тЖТ\t\t\t}\n   168тЖТ\n   169тЖТ\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   170тЖТ\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   171тЖТ\t\t\t\tProjectDir:    projectDir,\n   172тЖТ\t\t\t\tWorkflowName:  workflowName,\n   173тЖТ\t\t\t\tLLM:           llm,\n   174тЖТ\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   175тЖТ\t\t\t})\n   176тЖТ\n   177тЖТ\t\t\tctx := context.Background()\n   178тЖТ\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   179тЖТ\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   180тЖТ\t\t\t}\n   181тЖТ\t\t},\n   182тЖТ\t})\n   183тЖТ\n   184тЖТ\treturn trigger\n   185тЖТ}\n   186тЖТ\n   187тЖТfunc listen(addr string) (net.Listener, error) {\n   188тЖТ\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   189тЖТ\t\tsockPath := addr[7:]\n   190тЖТ\t\tos.Remove(sockPath)\n   191тЖТ\t\treturn net.Listen(\"unix\", sockPath)\n   192тЖТ\t}\n   193тЖТ\treturn net.Listen(\"tcp\", addr)\n   194тЖТ}\n   195тЖТ\n   196тЖТ// autoRunActiveProjects scans known projects for active = true in their config,\n   197тЖТ// parses .cloche/host.cloche and executes the full host workflow step by step.\n   198тЖТfunc autoRunActiveProjects(store ports.RunStore, srv *adaptgrpc.ClocheServer) {\n   199тЖТ\tctx := context.Background()\n   200тЖТ\tprojects, err := store.ListProjects(ctx)\n   201тЖТ\tif err != nil {\n   202тЖТ\t\tfmt.Fprintf(os.Stderr, \"startup: failed to list projects: %v\\n\", err)\n   203тЖТ\t\treturn\n   204тЖТ\t}\n   205тЖТ\n   206тЖТ\tfor _, projectDir := range projects {\n   207тЖТ\t\tcfg, err := config.Load(projectDir)\n   208тЖТ\t\tif err != nil || !cfg.Active {\n   209тЖТ\t\t\tcontinue\n   210тЖТ\t\t}\n   211тЖТ\n   212тЖТ\t\t// Verify host.cloche exists before launching\n   213тЖТ\t\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   214тЖТ\t\tif _, err := os.Stat(hostPath); err != nil {\n   215тЖТ\t\t\tfmt.Fprintf(os.Stderr, \"startup: skipping active project %s: %v\\n\", projectDir, err)\n   216тЖТ\t\t\tcontinue\n   217тЖТ\t\t}\n   218тЖТ\n   219тЖТ\t\tfmt.Fprintf(os.Stderr, \"startup: auto-running host workflow for active project %s\\n\", projectDir)\n   220тЖТ\t\tgo func(projDir string) {\n   221тЖТ\t\t\trunner := &hostpkg.Runner{\n   222тЖТ\t\t\t\tDispatcher: srv,\n   223тЖТ\t\t\t\tStore:      store,\n   224тЖТ\t\t\t}\n   225тЖТ\t\t\tresult, err := runner.Run(context.Background(), projDir)\n   226тЖТ\t\t\tif err != nil {\n   227тЖТ\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow failed for %s: %v\\n\", projDir, err)\n   228тЖТ\t\t\t} else {\n   229тЖТ\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow completed for %s: %s (run %s)\\n\", projDir, result.State, result.RunID)\n   230тЖТ\t\t\t}\n   231тЖТ\t\t}(projectDir)\n   232тЖТ\t}\n   233тЖТ}\n   234тЖТ\n   235тЖТ// envOrConfig returns the env var value if set, otherwise the config file\n   236тЖТ// value if non-empty, otherwise the fallback default.\n   237тЖТfunc envOrConfig(envKey, configVal, fallback string) string {\n   238тЖТ\tif v := os.Getenv(envKey); v != \"\" {\n   239тЖТ\t\treturn v\n   240тЖТ\t}\n   241тЖТ\tif configVal != \"\" {\n   242тЖТ\t\treturn configVal\n   243тЖТ\t}\n   244тЖТ\treturn fallback\n   245тЖТ}\n   246тЖТ"}]},"parent_tool_use_id":"toolu_01VgKT2HRKQWwdGh23Lxewca","session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"2c5a2bde-055b-4d7e-823a-2f2a82ba5c4a"}
