{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KU2dtrEicS7smGhpoWEua1","type":"tool_result","content":"     1тЖТpackage engine\n     2тЖТ\n     3тЖТimport (\n     4тЖТ\t\"context\"\n     5тЖТ\t\"fmt\"\n     6тЖТ\t\"log\"\n     7тЖТ\t\"sync\"\n     8тЖТ\t\"time\"\n     9тЖТ\n    10тЖТ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11тЖТ)\n    12тЖТ\n    13тЖТconst DefaultStepTimeout = 30 * time.Minute\n    14тЖТ\n    15тЖТ// StepExecutor executes a single step and returns the result name.\n    16тЖТtype StepExecutor interface {\n    17тЖТ\tExecute(ctx context.Context, step *domain.Step) (string, error)\n    18тЖТ}\n    19тЖТ\n    20тЖТ// StepExecutorFunc adapts a function to the StepExecutor interface.\n    21тЖТtype StepExecutorFunc func(ctx context.Context, step *domain.Step) (string, error)\n    22тЖТ\n    23тЖТfunc (f StepExecutorFunc) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    24тЖТ\treturn f(ctx, step)\n    25тЖТ}\n    26тЖТ\n    27тЖТ// StatusHandler receives notifications about workflow execution progress.\n    28тЖТtype StatusHandler interface {\n    29тЖТ\tOnStepStart(run *domain.Run, step *domain.Step)\n    30тЖТ\tOnStepComplete(run *domain.Run, step *domain.Step, result string)\n    31тЖТ\tOnRunComplete(run *domain.Run)\n    32тЖТ}\n    33тЖТ\n    34тЖТtype noopStatus struct{}\n    35тЖТ\n    36тЖТfunc (noopStatus) OnStepStart(*domain.Run, *domain.Step)            {}\n    37тЖТfunc (noopStatus) OnStepComplete(*domain.Run, *domain.Step, string) {}\n    38тЖТfunc (noopStatus) OnRunComplete(*domain.Run)                        {}\n    39тЖТ\n    40тЖТtype Engine struct {\n    41тЖТ\texecutor       StepExecutor\n    42тЖТ\tstatus         StatusHandler\n    43тЖТ\tmaxSteps       int\n    44тЖТ\tdefaultTimeout time.Duration\n    45тЖТ}\n    46тЖТ\n    47тЖТfunc New(executor StepExecutor) *Engine {\n    48тЖТ\treturn &Engine{\n    49тЖТ\t\texecutor:       executor,\n    50тЖТ\t\tstatus:         noopStatus{},\n    51тЖТ\t\tmaxSteps:       1000,\n    52тЖТ\t\tdefaultTimeout: DefaultStepTimeout,\n    53тЖТ\t}\n    54тЖТ}\n    55тЖТ\n    56тЖТfunc (e *Engine) SetStatusHandler(h StatusHandler) {\n    57тЖТ\te.status = h\n    58тЖТ}\n    59тЖТ\n    60тЖТfunc (e *Engine) SetMaxSteps(n int) {\n    61тЖТ\te.maxSteps = n\n    62тЖТ}\n    63тЖТ\n    64тЖТ// SetDefaultTimeout sets the default timeout for steps that don't specify one.\n    65тЖТfunc (e *Engine) SetDefaultTimeout(d time.Duration) {\n    66тЖТ\te.defaultTimeout = d\n    67тЖТ}\n    68тЖТ\n    69тЖТ// stepResult is sent from worker goroutines back to the main event loop.\n    70тЖТtype stepResult struct {\n    71тЖТ\tstepName string\n    72тЖТ\tresult   string\n    73тЖТ\terr      error\n    74тЖТ}\n    75тЖТ\n    76тЖТ// collectState tracks the satisfaction state of a single Collect clause.\n    77тЖТtype collectState struct {\n    78тЖТ\tcollect   *domain.Collect\n    79тЖТ\tsatisfied map[int]bool\n    80тЖТ\tfired     bool\n    81тЖТ}\n    82тЖТ\n    83тЖТfunc (e *Engine) Run(ctx context.Context, wf *domain.Workflow) (*domain.Run, error) {\n    84тЖТ\tif err := wf.Validate(); err != nil {\n    85тЖТ\t\treturn nil, fmt.Errorf(\"invalid workflow: %w\", err)\n    86тЖТ\t}\n    87тЖТ\tfor _, w := range wf.ValidateConfig() {\n    88тЖТ\t\tlog.Printf(\"WARNING: %s\", w)\n    89тЖТ\t}\n    90тЖТ\n    91тЖТ\trun := domain.NewRun(generateRunID(), wf.Name)\n    92тЖТ\trun.Start()\n    93тЖТ\n    94тЖТ\t// Check context cancellation before starting.\n    95тЖТ\tif err := ctx.Err(); err != nil {\n    96тЖТ\t\trun.Complete(domain.RunStateCancelled)\n    97тЖТ\t\treturn run, fmt.Errorf(\"workflow cancelled: %w\", err)\n    98тЖТ\t}\n    99тЖТ\n   100тЖТ\t// Build a set of (step, result) pairs that are handled by collects,\n   101тЖТ\t// so we know when a missing wire is acceptable.\n   102тЖТ\tcollectHandled := make(map[string]map[string]bool)\n   103тЖТ\tfor _, c := range wf.Collects {\n   104тЖТ\t\tfor _, cond := range c.Conditions {\n   105тЖТ\t\t\tif collectHandled[cond.Step] == nil {\n   106тЖТ\t\t\t\tcollectHandled[cond.Step] = make(map[string]bool)\n   107тЖТ\t\t\t}\n   108тЖТ\t\t\tcollectHandled[cond.Step][cond.Result] = true\n   109тЖТ\t\t}\n   110тЖТ\t}\n   111тЖТ\n   112тЖТ\t// Initialize collect states.\n   113тЖТ\tcStates := make([]*collectState, len(wf.Collects))\n   114тЖТ\tfor i := range wf.Collects {\n   115тЖТ\t\tcStates[i] = &collectState{\n   116тЖТ\t\t\tcollect:   &wf.Collects[i],\n   117тЖТ\t\t\tsatisfied: make(map[int]bool),\n   118тЖТ\t\t}\n   119тЖТ\t}\n   120тЖТ\n   121тЖТ\tresults := make(chan stepResult, e.maxSteps)\n   122тЖТ\tactiveCount := 0\n   123тЖТ\tstepCount := 0\n   124тЖТ\tdoneCount := 0\n   125тЖТ\taborted := false\n   126тЖТ\tvar runErr error\n   127тЖТ\n   128тЖТ\t// Use a mutex to protect run state from concurrent goroutine access.\n   129тЖТ\t// Only the main loop should touch the Run, but we record step start before\n   130тЖТ\t// launching the goroutine, so this is safe without a mutex for now.\n   131тЖТ\t// The goroutines only read the step and send on the channel.\n   132тЖТ\n   133тЖТ\tlaunchStep := func(stepName string) error {\n   134тЖТ\t\tstepCount++\n   135тЖТ\t\tif stepCount > e.maxSteps {\n   136тЖТ\t\t\treturn fmt.Errorf(\"workflow exceeded maximum step count (%d)\", e.maxSteps)\n   137тЖТ\t\t}\n   138тЖТ\n   139тЖТ\t\tstep, ok := wf.Steps[stepName]\n   140тЖТ\t\tif !ok {\n   141тЖТ\t\t\treturn fmt.Errorf(\"step %q not found in workflow\", stepName)\n   142тЖТ\t\t}\n   143тЖТ\n   144тЖТ\t\tactiveCount++\n   145тЖТ\t\trun.RecordStepStart(step.Name)\n   146тЖТ\t\te.status.OnStepStart(run, step)\n   147тЖТ\n   148тЖТ\t\tgo func(s *domain.Step) {\n   149тЖТ\t\t\tstepCtx := ctx\n   150тЖТ\t\t\tif d := stepTimeout(s, e.defaultTimeout); d > 0 {\n   151тЖТ\t\t\t\tvar cancel context.CancelFunc\n   152тЖТ\t\t\t\tstepCtx, cancel = context.WithTimeout(ctx, d)\n   153тЖТ\t\t\t\tdefer cancel()\n   154тЖТ\t\t\t}\n   155тЖТ\t\t\tresult, err := e.executor.Execute(stepCtx, s)\n   156тЖТ\t\t\tresults <- stepResult{stepName: s.Name, result: result, err: err}\n   157тЖТ\t\t}(step)\n   158тЖТ\n   159тЖТ\t\treturn nil\n   160тЖТ\t}\n   161тЖТ\n   162тЖТ\t// Launch entry step.\n   163тЖТ\tif err := launchStep(wf.EntryStep); err != nil {\n   164тЖТ\t\trun.Complete(domain.RunStateFailed)\n   165тЖТ\t\treturn run, err\n   166тЖТ\t}\n   167тЖТ\n   168тЖТ\t// Main event loop.\n   169тЖТ\tfor activeCount > 0 {\n   170тЖТ\t\tselect {\n   171тЖТ\t\tcase <-ctx.Done():\n   172тЖТ\t\t\trun.Complete(domain.RunStateCancelled)\n   173тЖТ\t\t\treturn run, fmt.Errorf(\"workflow cancelled: %w\", ctx.Err())\n   174тЖТ\n   175тЖТ\t\tcase sr := <-results:\n   176тЖТ\t\t\tactiveCount--\n   177тЖТ\n   178тЖТ\t\t\t// Step execution error.\n   179тЖТ\t\t\tif sr.err != nil {\n   180тЖТ\t\t\t\trun.RecordStepComplete(sr.stepName, \"error\")\n   181тЖТ\t\t\t\trun.Complete(domain.RunStateFailed)\n   182тЖТ\t\t\t\te.status.OnRunComplete(run)\n   183тЖТ\t\t\t\treturn run, fmt.Errorf(\"step %q execution failed: %w\", sr.stepName, sr.err)\n   184тЖТ\t\t\t}\n   185тЖТ\n   186тЖТ\t\t\t// Validate result is declared in the step's Results list.\n   187тЖТ\t\t\tstep := wf.Steps[sr.stepName]\n   188тЖТ\t\t\tif !isResultDeclared(step, sr.result) {\n   189тЖТ\t\t\t\trun.RecordStepComplete(sr.stepName, sr.result)\n   190тЖТ\t\t\t\trun.Complete(domain.RunStateFailed)\n   191тЖТ\t\t\t\te.status.OnRunComplete(run)\n   192тЖТ\t\t\t\treturn run, fmt.Errorf(\"step %q returned undeclared result %q\", sr.stepName, sr.result)\n   193тЖТ\t\t\t}\n   194тЖТ\n   195тЖТ\t\t\trun.RecordStepComplete(sr.stepName, sr.result)\n   196тЖТ\t\t\te.status.OnStepComplete(run, step, sr.result)\n   197тЖТ\n   198тЖТ\t\t\t// Process wiring: get next steps for this (step, result) pair.\n   199тЖТ\t\t\tnextSteps, wireErr := wf.NextSteps(sr.stepName, sr.result)\n   200тЖТ\t\t\tif wireErr != nil {\n   201тЖТ\t\t\t\t// No wire found. Check if any collect handles this (step, result).\n   202тЖТ\t\t\t\tif !collectHandled[sr.stepName][sr.result] {\n   203тЖТ\t\t\t\t\t// Neither wires nor collects handle this result.\n   204тЖТ\t\t\t\t\trun.Complete(domain.RunStateFailed)\n   205тЖТ\t\t\t\t\te.status.OnRunComplete(run)\n   206тЖТ\t\t\t\t\treturn run, wireErr\n   207тЖТ\t\t\t\t}\n   208тЖТ\t\t\t\t// Collect handles it; no wire targets to launch.\n   209тЖТ\t\t\t} else {\n   210тЖТ\t\t\t\t// Process wire targets.\n   211тЖТ\t\t\t\tfor _, target := range nextSteps {\n   212тЖТ\t\t\t\t\tswitch target {\n   213тЖТ\t\t\t\t\tcase domain.StepDone:\n   214тЖТ\t\t\t\t\t\tdoneCount++\n   215тЖТ\t\t\t\t\tcase domain.StepAbort:\n   216тЖТ\t\t\t\t\t\taborted = true\n   217тЖТ\t\t\t\t\tdefault:\n   218тЖТ\t\t\t\t\t\tif err := launchStep(target); err != nil {\n   219тЖТ\t\t\t\t\t\t\trun.Complete(domain.RunStateFailed)\n   220тЖТ\t\t\t\t\t\t\te.status.OnRunComplete(run)\n   221тЖТ\t\t\t\t\t\t\treturn run, err\n   222тЖТ\t\t\t\t\t\t}\n   223тЖТ\t\t\t\t\t}\n   224тЖТ\t\t\t\t}\n   225тЖТ\t\t\t}\n   226тЖТ\n   227тЖТ\t\t\t// Check and fire collect conditions.\n   228тЖТ\t\t\tfor _, cs := range cStates {\n   229тЖТ\t\t\t\tif cs.fired {\n   230тЖТ\t\t\t\t\tcontinue\n   231тЖТ\t\t\t\t}\n   232тЖТ\t\t\t\tfor i, cond := range cs.collect.Conditions {\n   233тЖТ\t\t\t\t\tif cond.Step == sr.stepName && cond.Result == sr.result {\n   234тЖТ\t\t\t\t\t\tcs.satisfied[i] = true\n   235тЖТ\t\t\t\t\t}\n   236тЖТ\t\t\t\t}\n   237тЖТ\n   238тЖТ\t\t\t\tshouldFire := false\n   239тЖТ\t\t\t\tswitch cs.collect.Mode {\n   240тЖТ\t\t\t\tcase domain.CollectAll:\n   241тЖТ\t\t\t\t\tshouldFire = len(cs.satisfied) == len(cs.collect.Conditions)\n   242тЖТ\t\t\t\tcase domain.CollectAny:\n   243тЖТ\t\t\t\t\tshouldFire = len(cs.satisfied) > 0\n   244тЖТ\t\t\t\t}\n   245тЖТ\n   246тЖТ\t\t\t\tif shouldFire {\n   247тЖТ\t\t\t\t\tcs.fired = true\n   248тЖТ\t\t\t\t\ttarget := cs.collect.To\n   249тЖТ\t\t\t\t\tswitch target {\n   250тЖТ\t\t\t\t\tcase domain.StepDone:\n   251тЖТ\t\t\t\t\t\tdoneCount++\n   252тЖТ\t\t\t\t\tcase domain.StepAbort:\n   253тЖТ\t\t\t\t\t\taborted = true\n   254тЖТ\t\t\t\t\tdefault:\n   255тЖТ\t\t\t\t\t\tif err := launchStep(target); err != nil {\n   256тЖТ\t\t\t\t\t\t\trun.Complete(domain.RunStateFailed)\n   257тЖТ\t\t\t\t\t\t\te.status.OnRunComplete(run)\n   258тЖТ\t\t\t\t\t\t\treturn run, err\n   259тЖТ\t\t\t\t\t\t}\n   260тЖТ\t\t\t\t\t}\n   261тЖТ\t\t\t\t}\n   262тЖТ\t\t\t}\n   263тЖТ\t\t}\n   264тЖТ\t}\n   265тЖТ\n   266тЖТ\t// Determine final state.\n   267тЖТ\tif aborted || runErr != nil {\n   268тЖТ\t\trun.Complete(domain.RunStateFailed)\n   269тЖТ\t} else if doneCount > 0 {\n   270тЖТ\t\trun.Complete(domain.RunStateSucceeded)\n   271тЖТ\t} else {\n   272тЖТ\t\trun.Complete(domain.RunStateFailed)\n   273тЖТ\t\trunErr = fmt.Errorf(\"workflow %q: no branches reached done\", wf.Name)\n   274тЖТ\t}\n   275тЖТ\n   276тЖТ\te.status.OnRunComplete(run)\n   277тЖТ\treturn run, runErr\n   278тЖТ}\n   279тЖТ\n   280тЖТ// isResultDeclared checks whether the given result is in the step's declared Results list.\n   281тЖТfunc isResultDeclared(step *domain.Step, result string) bool {\n   282тЖТ\tfor _, r := range step.Results {\n   283тЖТ\t\tif r == result {\n   284тЖТ\t\t\treturn true\n   285тЖТ\t\t}\n   286тЖТ\t}\n   287тЖТ\treturn false\n   288тЖТ}\n   289тЖТ\n   290тЖТvar (\n   291тЖТ\trunCounter int\n   292тЖТ\trunMu      sync.Mutex\n   293тЖТ)\n   294тЖТ\n   295тЖТfunc generateRunID() string {\n   296тЖТ\trunMu.Lock()\n   297тЖТ\tdefer runMu.Unlock()\n   298тЖТ\trunCounter++\n   299тЖТ\treturn fmt.Sprintf(\"run-%d\", runCounter)\n   300тЖТ}\n   301тЖТ\n   302тЖТ// stepTimeout returns the timeout for a step. It checks step.Config[\"timeout\"]\n   303тЖТ// first, falling back to the provided default.\n   304тЖТfunc stepTimeout(step *domain.Step, defaultTimeout time.Duration) time.Duration {\n   305тЖТ\tif raw, ok := step.Config[\"timeout\"]; ok {\n   306тЖТ\t\tif d, err := time.ParseDuration(raw); err == nil {\n   307тЖТ\t\t\treturn d\n   308тЖТ\t\t}\n   309тЖТ\t}\n   310тЖТ\treturn defaultTimeout\n   311тЖТ}\n   312тЖТ"}]},"parent_tool_use_id":"toolu_01VgKT2HRKQWwdGh23Lxewca","session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"2ea8678a-4f56-4332-9a0f-4f5fafcaa950"}
