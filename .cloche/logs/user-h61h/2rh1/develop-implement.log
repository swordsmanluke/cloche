{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011nnaTHX2vBjqduZ5jBNzL6","type":"tool_result","content":"     1тЖТpackage protocol\n     2тЖТ\n     3тЖТimport (\n     4тЖТ\t\"bytes\"\n     5тЖТ\t\"strings\"\n     6тЖТ)\n     7тЖТ\n     8тЖТconst ResultPrefix = \"CLOCHE_RESULT:\"\n     9тЖТ\n    10тЖТ// ExtractResult scans output for the last CLOCHE_RESULT:<name> line.\n    11тЖТ// Returns the result name, the output with all marker lines removed, and\n    12тЖТ// whether a marker was found.\n    13тЖТfunc ExtractResult(output []byte) (result string, cleanOutput []byte, found bool) {\n    14тЖТ\tvar clean [][]byte\n    15тЖТ\tfor _, line := range bytes.Split(output, []byte(\"\\n\")) {\n    16тЖТ\t\ttrimmed := strings.TrimSpace(string(line))\n    17тЖТ\t\tif strings.HasPrefix(trimmed, ResultPrefix) {\n    18тЖТ\t\t\tresult = trimmed[len(ResultPrefix):]\n    19тЖТ\t\t\tfound = true\n    20тЖТ\t\t} else {\n    21тЖТ\t\t\tclean = append(clean, line)\n    22тЖТ\t\t}\n    23тЖТ\t}\n    24тЖТ\t// Rejoin and trim trailing empty line from split\n    25тЖТ\tjoined := bytes.Join(clean, []byte(\"\\n\"))\n    26тЖТ\tjoined = bytes.TrimRight(joined, \"\\n\")\n    27тЖТ\tif len(joined) > 0 {\n    28тЖТ\t\tjoined = append(joined, '\\n')\n    29тЖТ\t}\n    30тЖТ\treturn result, joined, found\n    31тЖТ}\n    32тЖТ"}]},"parent_tool_use_id":"toolu_01VgKT2HRKQWwdGh23Lxewca","session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"a33c91e9-0d3b-4a15-a69b-fa6682aa3a41"}
