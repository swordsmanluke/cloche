{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0185XGT9rUDZHW6MfEwSS8fm","type":"tool_result","content":"     1тЖТpackage dsl\n     2тЖТ\n     3тЖТimport (\n     4тЖТ\t\"fmt\"\n     5тЖТ\t\"strconv\"\n     6тЖТ\t\"strings\"\n     7тЖТ\n     8тЖТ\t\"github.com/cloche-dev/cloche/internal/domain\"\n     9тЖТ)\n    10тЖТ\n    11тЖТtype Parser struct {\n    12тЖТ\tlexer    *Lexer\n    13тЖТ\tcurrent  Token\n    14тЖТ\tpeek     Token\n    15тЖТ\tlocation domain.WorkflowLocation\n    16тЖТ}\n    17тЖТ\n    18тЖТ// ParseOption configures the parser.\n    19тЖТtype ParseOption func(*Parser)\n    20тЖТ\n    21тЖТ// WithLocation sets the workflow location, enabling location-based validation.\n    22тЖТfunc WithLocation(loc domain.WorkflowLocation) ParseOption {\n    23тЖТ\treturn func(p *Parser) {\n    24тЖТ\t\tp.location = loc\n    25тЖТ\t}\n    26тЖТ}\n    27тЖТ\n    28тЖТfunc Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n    29тЖТ\tp := &Parser{lexer: NewLexer(input)}\n    30тЖТ\tfor _, opt := range opts {\n    31тЖТ\t\topt(p)\n    32тЖТ\t}\n    33тЖТ\tp.advance() // load current\n    34тЖТ\tp.advance() // load peek\n    35тЖТ\treturn p.parseWorkflow()\n    36тЖТ}\n    37тЖТ\n    38тЖТ// ParseForHost parses a host.cloche file containing a single workflow.\n    39тЖТfunc ParseForHost(input string) (*domain.Workflow, error) {\n    40тЖТ\treturn Parse(input, WithLocation(domain.LocationHost))\n    41тЖТ}\n    42тЖТ\n    43тЖТ// ParseAllForHost parses a host.cloche file that may contain multiple workflows.\n    44тЖТ// Returns a map of workflow name to workflow definition.\n    45тЖТfunc ParseAllForHost(input string) (map[string]*domain.Workflow, error) {\n    46тЖТ\tp := &Parser{lexer: NewLexer(input), location: domain.LocationHost}\n    47тЖТ\tp.advance() // load current\n    48тЖТ\tp.advance() // load peek\n    49тЖТ\n    50тЖТ\tworkflows := make(map[string]*domain.Workflow)\n    51тЖТ\tfor p.current.Type != TokenEOF {\n    52тЖТ\t\twf, err := p.parseWorkflow()\n    53тЖТ\t\tif err != nil {\n    54тЖТ\t\t\treturn nil, err\n    55тЖТ\t\t}\n    56тЖТ\t\tif _, exists := workflows[wf.Name]; exists {\n    57тЖТ\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    58тЖТ\t\t}\n    59тЖТ\t\tworkflows[wf.Name] = wf\n    60тЖТ\t}\n    61тЖТ\n    62тЖТ\tif len(workflows) == 0 {\n    63тЖТ\t\treturn nil, fmt.Errorf(\"no workflows found in host.cloche\")\n    64тЖТ\t}\n    65тЖТ\n    66тЖТ\treturn workflows, nil\n    67тЖТ}\n    68тЖТ\n    69тЖТ// ParseForContainer parses a container workflow file.\n    70тЖТfunc ParseForContainer(input string) (*domain.Workflow, error) {\n    71тЖТ\treturn Parse(input, WithLocation(domain.LocationContainer))\n    72тЖТ}\n    73тЖТ\n    74тЖТfunc (p *Parser) advance() {\n    75тЖТ\tp.current = p.peek\n    76тЖТ\tp.peek = p.lexer.NextToken()\n    77тЖТ}\n    78тЖТ\n    79тЖТfunc (p *Parser) expect(typ TokenType) (Token, error) {\n    80тЖТ\tif p.current.Type != typ {\n    81тЖТ\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n    82тЖТ\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n    83тЖТ\t}\n    84тЖТ\ttok := p.current\n    85тЖТ\tp.advance()\n    86тЖТ\treturn tok, nil\n    87тЖТ}\n    88тЖТ\n    89тЖТfunc (p *Parser) expectIdent(value string) (Token, error) {\n    90тЖТ\tif p.current.Type != TokenIdent || p.current.Literal != value {\n    91тЖТ\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n    92тЖТ\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n    93тЖТ\t}\n    94тЖТ\ttok := p.current\n    95тЖТ\tp.advance()\n    96тЖТ\treturn tok, nil\n    97тЖТ}\n    98тЖТ\n    99тЖТfunc (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n   100тЖТ\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n   101тЖТ\t\treturn nil, err\n   102тЖТ\t}\n   103тЖТ\n   104тЖТ\tnameTok, err := p.expect(TokenString)\n   105тЖТ\tif err != nil {\n   106тЖТ\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n   107тЖТ\t}\n   108тЖТ\n   109тЖТ\tif _, err := p.expect(TokenLBrace); err != nil {\n   110тЖТ\t\treturn nil, err\n   111тЖТ\t}\n   112тЖТ\n   113тЖТ\twf := &domain.Workflow{\n   114тЖТ\t\tName:     nameTok.Literal,\n   115тЖТ\t\tLocation: p.location,\n   116тЖТ\t\tSteps:    make(map[string]*domain.Step),\n   117тЖТ\t\tConfig:   make(map[string]string),\n   118тЖТ\t}\n   119тЖТ\n   120тЖТ\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   121тЖТ\t\tif p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n   122тЖТ\t\t\tstep, err := p.parseStep()\n   123тЖТ\t\t\tif err != nil {\n   124тЖТ\t\t\t\treturn nil, err\n   125тЖТ\t\t\t}\n   126тЖТ\t\t\twf.Steps[step.Name] = step\n   127тЖТ\t\t\tif wf.EntryStep == \"\" {\n   128тЖТ\t\t\t\twf.EntryStep = step.Name\n   129тЖТ\t\t\t}\n   130тЖТ\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n   131тЖТ\t\t\tcollect, err := p.parseCollect()\n   132тЖТ\t\t\tif err != nil {\n   133тЖТ\t\t\t\treturn nil, err\n   134тЖТ\t\t\t}\n   135тЖТ\t\t\twf.Collects = append(wf.Collects, collect)\n   136тЖТ\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n   137тЖТ\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n   138тЖТ\t\t\t\treturn nil, err\n   139тЖТ\t\t\t}\n   140тЖТ\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n   141тЖТ\t\t\twire, err := p.parseWire()\n   142тЖТ\t\t\tif err != nil {\n   143тЖТ\t\t\t\treturn nil, err\n   144тЖТ\t\t\t}\n   145тЖТ\t\t\twf.Wiring = append(wf.Wiring, wire)\n   146тЖТ\t\t} else {\n   147тЖТ\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n   148тЖТ\t\t}\n   149тЖТ\t}\n   150тЖТ"}]},"parent_tool_use_id":"toolu_01VgKT2HRKQWwdGh23Lxewca","session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"5fab32fc-1807-47ef-bdab-7bd6348865c7"}
