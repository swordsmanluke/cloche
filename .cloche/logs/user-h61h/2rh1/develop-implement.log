{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015MaoBvG5xU6GCuxbxkftMt","type":"tool_result","content":"     1тЖТpackage host\n     2тЖТ\n     3тЖТimport (\n     4тЖТ\t\"bufio\"\n     5тЖТ\t\"context\"\n     6тЖТ\t\"encoding/json\"\n     7тЖТ\t\"fmt\"\n     8тЖТ\t\"os/exec\"\n     9тЖТ\t\"strings\"\n    10тЖТ)\n    11тЖТ\n    12тЖТ// TaskStatus represents the state of a task from a task tracker.\n    13тЖТtype TaskStatus string\n    14тЖТ\n    15тЖТconst (\n    16тЖТ\tTaskStatusOpen       TaskStatus = \"open\"\n    17тЖТ\tTaskStatusClosed     TaskStatus = \"closed\"\n    18тЖТ\tTaskStatusInProgress TaskStatus = \"in-progress\"\n    19тЖТ)\n    20тЖТ\n    21тЖТ// Task represents a work item from an external task tracker.\n    22тЖТtype Task struct {\n    23тЖТ\tID          string            `json:\"id\"`\n    24тЖТ\tStatus      string            `json:\"status\"`\n    25тЖТ\tTitle       string            `json:\"title\"`\n    26тЖТ\tDescription string            `json:\"description\"`\n    27тЖТ\tMetadata    map[string]string `json:\"metadata,omitempty\"`\n    28тЖТ}\n    29тЖТ\n    30тЖТ// IsOpen returns true if the task status is \"open\" or empty (for backward compatibility).\n    31тЖТfunc (t Task) IsOpen() bool {\n    32тЖТ\treturn t.Status == \"\" || TaskStatus(t.Status) == TaskStatusOpen\n    33тЖТ}\n    34тЖТ\n    35тЖТ// TaskAssigner lists available tasks for the daemon to assign to workflow runs.\n    36тЖТtype TaskAssigner interface {\n    37тЖТ\tListTasks(ctx context.Context, projectDir string) ([]Task, error)\n    38тЖТ}\n    39тЖТ\n    40тЖТ// ScriptTaskAssigner runs a shell command to list tasks and parses the JSON output.\n    41тЖТ// The command should output a JSON array of objects with at least an \"id\" field.\n    42тЖТtype ScriptTaskAssigner struct {\n    43тЖТ\tCommand string // shell command to run (e.g., \"bash .cloche/scripts/ready-tasks.sh\")\n    44тЖТ}\n    45тЖТ\n    46тЖТ// ListTasks executes the configured command from the project directory and\n    47тЖТ// parses its stdout as a JSON array of Task objects.\n    48тЖТfunc (s *ScriptTaskAssigner) ListTasks(ctx context.Context, projectDir string) ([]Task, error) {\n    49тЖТ\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", s.Command)\n    50тЖТ\tcmd.Dir = MainWorktreeDir(projectDir)\n    51тЖТ\n    52тЖТ\tout, err := cmd.Output()\n    53тЖТ\tif err != nil {\n    54тЖТ\t\treturn nil, fmt.Errorf(\"running list-tasks command: %w\", err)\n    55тЖТ\t}\n    56тЖТ\n    57тЖТ\toutput := strings.TrimSpace(string(out))\n    58тЖТ\tif output == \"\" || output == \"[]\" {\n    59тЖТ\t\treturn nil, nil\n    60тЖТ\t}\n    61тЖТ\n    62тЖТ\tvar tasks []Task\n    63тЖТ\tif err := json.Unmarshal([]byte(output), &tasks); err != nil {\n    64тЖТ\t\treturn nil, fmt.Errorf(\"parsing list-tasks output: %w\", err)\n    65тЖТ\t}\n    66тЖТ\treturn tasks, nil\n    67тЖТ}\n    68тЖТ\n    69тЖТ// ParseTasksJSONL parses JSONL-formatted task output (one JSON object per line).\n    70тЖТ// Each line should have at least an \"id\" field. Lines that are empty or fail to\n    71тЖТ// parse are skipped.\n    72тЖТfunc ParseTasksJSONL(data string) ([]Task, error) {\n    73тЖТ\tvar tasks []Task\n    74тЖТ\tscanner := bufio.NewScanner(strings.NewReader(data))\n    75тЖТ\tlineNum := 0\n    76тЖТ\tfor scanner.Scan() {\n    77тЖТ\t\tlineNum++\n    78тЖТ\t\tline := strings.TrimSpace(scanner.Text())\n    79тЖТ\t\tif line == \"\" {\n    80тЖТ\t\t\tcontinue\n    81тЖТ\t\t}\n    82тЖТ\t\tvar task Task\n    83тЖТ\t\tif err := json.Unmarshal([]byte(line), &task); err != nil {\n    84тЖТ\t\t\treturn nil, fmt.Errorf(\"parsing JSONL line %d: %w\", lineNum, err)\n    85тЖТ\t\t}\n    86тЖТ\t\ttasks = append(tasks, task)\n    87тЖТ\t}\n    88тЖТ\treturn tasks, nil\n    89тЖТ}\n    90тЖТ"}]},"parent_tool_use_id":"toolu_01VgKT2HRKQWwdGh23Lxewca","session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"e0fdec4b-6f7a-45b0-a98e-f8f8861a18da"}
