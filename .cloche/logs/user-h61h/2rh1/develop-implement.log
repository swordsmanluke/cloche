{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KxsDwwNWG4CvrfcbVq6e57","type":"tool_result","content":"     1тЖТpackage sqlite\n     2тЖТ\n     3тЖТimport (\n     4тЖТ\t\"context\"\n     5тЖТ\t\"database/sql\"\n     6тЖТ\t\"fmt\"\n     7тЖТ\t\"time\"\n     8тЖТ\n     9тЖТ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10тЖТ\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11тЖТ\t_ \"modernc.org/sqlite\"\n    12тЖТ)\n    13тЖТ\n    14тЖТtype Store struct {\n    15тЖТ\tdb *sql.DB\n    16тЖТ}\n    17тЖТ\n    18тЖТfunc NewStore(dsn string) (*Store, error) {\n    19тЖТ\tdb, err := sql.Open(\"sqlite\", dsn)\n    20тЖТ\tif err != nil {\n    21тЖТ\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n    22тЖТ\t}\n    23тЖТ\n    24тЖТ\t// Enable WAL mode for concurrent read/write access\n    25тЖТ\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n    26тЖТ\n    27тЖТ\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n    28тЖТ\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n    29тЖТ\n    30тЖТ\t// Serialize all Go-side access through a single connection so SQLite\n    31тЖТ\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n    32тЖТ\tdb.SetMaxOpenConns(1)\n    33тЖТ\n    34тЖТ\tif err := migrate(db); err != nil {\n    35тЖТ\t\tdb.Close()\n    36тЖТ\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n    37тЖТ\t}\n    38тЖТ\n    39тЖТ\treturn &Store{db: db}, nil\n    40тЖТ}\n    41тЖТ\n    42тЖТfunc (s *Store) Close() error {\n    43тЖТ\treturn s.db.Close()\n    44тЖТ}\n    45тЖТ\n    46тЖТfunc migrate(db *sql.DB) error {\n    47тЖТ\t_, err := db.Exec(`\n    48тЖТ\t\tCREATE TABLE IF NOT EXISTS runs (\n    49тЖТ\t\t\tid TEXT PRIMARY KEY,\n    50тЖТ\t\t\tworkflow_name TEXT NOT NULL,\n    51тЖТ\t\t\tstate TEXT NOT NULL,\n    52тЖТ\t\t\tactive_steps TEXT,\n    53тЖТ\t\t\tstarted_at TEXT,\n    54тЖТ\t\t\tcompleted_at TEXT\n    55тЖТ\t\t);\n    56тЖТ\t\tCREATE TABLE IF NOT EXISTS step_executions (\n    57тЖТ\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    58тЖТ\t\t\trun_id TEXT NOT NULL,\n    59тЖТ\t\t\tstep_name TEXT NOT NULL,\n    60тЖТ\t\t\tresult TEXT,\n    61тЖТ\t\t\tstarted_at TEXT NOT NULL,\n    62тЖТ\t\t\tcompleted_at TEXT,\n    63тЖТ\t\t\tlogs TEXT,\n    64тЖТ\t\t\tgit_ref TEXT,\n    65тЖТ\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    66тЖТ\t\t);\n    67тЖТ\t`)\n    68тЖТ\tif err != nil {\n    69тЖТ\t\treturn err\n    70тЖТ\t}\n    71тЖТ\n    72тЖТ\t// Evolution schema additions (idempotent)\n    73тЖТ\talterStmts := []string{\n    74тЖТ\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n    75тЖТ\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n    76тЖТ\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n    77тЖТ\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n    78тЖТ\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n    79тЖТ\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n    80тЖТ\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n    81тЖТ\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n    82тЖТ\t\t`ALTER TABLE runs ADD COLUMN title TEXT NOT NULL DEFAULT ''`,\n    83тЖТ\t\t`ALTER TABLE runs ADD COLUMN is_host INTEGER NOT NULL DEFAULT 0`,\n    84тЖТ\t\t`ALTER TABLE runs ADD COLUMN parent_run_id TEXT NOT NULL DEFAULT ''`,\n    85тЖТ\t}\n    86тЖТ\tfor _, stmt := range alterStmts {\n    87тЖТ\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n    88тЖТ\t}\n    89тЖТ\n    90тЖТ\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n    91тЖТ\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    92тЖТ\t\trun_id TEXT NOT NULL,\n    93тЖТ\t\tstep_name TEXT,\n    94тЖТ\t\tfile_type TEXT NOT NULL,\n    95тЖТ\t\tfile_path TEXT NOT NULL,\n    96тЖТ\t\tfile_size INTEGER,\n    97тЖТ\t\tcreated_at TEXT NOT NULL,\n    98тЖТ\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    99тЖТ\t)`)\n   100тЖТ\tif errLog != nil {\n   101тЖТ\t\treturn errLog\n   102тЖТ\t}\n   103тЖТ\n   104тЖТ\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n   105тЖТ\t\trun_id TEXT PRIMARY KEY,\n   106тЖТ\t\tbranch TEXT NOT NULL,\n   107тЖТ\t\tproject TEXT NOT NULL,\n   108тЖТ\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n   109тЖТ\t\tenqueued_at TEXT NOT NULL,\n   110тЖТ\t\tcompleted_at TEXT\n   111тЖТ\t)`)\n   112тЖТ\tif errMQ != nil {\n   113тЖТ\t\treturn errMQ\n   114тЖТ\t}\n   115тЖТ\n   116тЖТ\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n   117тЖТ\t\tid TEXT PRIMARY KEY,\n   118тЖТ\t\tproject_dir TEXT NOT NULL,\n   119тЖТ\t\tworkflow_name TEXT NOT NULL,\n   120тЖТ\t\ttrigger_run_id TEXT NOT NULL,\n   121тЖТ\t\tcreated_at TEXT NOT NULL,\n   122тЖТ\t\tclassification TEXT,\n   123тЖТ\t\tchanges_json TEXT NOT NULL,\n   124тЖТ\t\tknowledge_delta TEXT\n   125тЖТ\t)`)\n   126тЖТ\tif err2 != nil {\n   127тЖТ\t\treturn err2\n   128тЖТ\t}\n   129тЖТ\n   130тЖТ\treturn nil\n   131тЖТ}\n   132тЖТ\n   133тЖТfunc (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n   134тЖТ\t_, err := s.db.ExecContext(ctx,\n   135тЖТ\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept, title, is_host, parent_run_id)\n   136тЖТ\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   137тЖТ\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n   138тЖТ\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, run.ErrorMessage, run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID,\n   139тЖТ\t)\n   140тЖТ\treturn err\n   141тЖТ}\n   142тЖТ\n   143тЖТ// runSelectCols is the standard column list for scanning a Run row.\n   144тЖТconst runSelectCols = `id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,''), COALESCE(is_host,0), COALESCE(parent_run_id,'')`\n   145тЖТ\n   146тЖТ// scanRun scans a single row into a *domain.Run.\n   147тЖТfunc scanRun(scanner interface{ Scan(...any) error }) (*domain.Run, error) {\n   148тЖТ\trun := &domain.Run{}\n   149тЖТ\tvar activeSteps, startedAt, completedAt string\n   150тЖТ\tvar containerKept, isHost int"}]},"parent_tool_use_id":"toolu_01VgKT2HRKQWwdGh23Lxewca","session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"e0c208d3-da47-4a15-8877-a2151144683c"}
