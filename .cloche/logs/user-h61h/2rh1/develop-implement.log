{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VCLSZr5kTAZLHjHR5orCfx","type":"tool_result","content":"     1тЖТpackage main\n     2тЖТ\n     3тЖТimport (\n     4тЖТ\t\"context\"\n     5тЖТ\t\"fmt\"\n     6тЖТ\t\"os\"\n     7тЖТ\t\"os/signal\"\n     8тЖТ\t\"syscall\"\n     9тЖТ\n    10тЖТ\t\"github.com/cloche-dev/cloche/internal/agent\"\n    11тЖТ)\n    12тЖТ\n    13тЖТfunc main() {\n    14тЖТ\tif len(os.Args) < 2 {\n    15тЖТ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche-agent <workflow-file>\\n\")\n    16тЖТ\t\tos.Exit(1)\n    17тЖТ\t}\n    18тЖТ\n    19тЖТ\tworkflowPath := os.Args[1]\n    20тЖТ\tworkDir, _ := os.Getwd()\n    21тЖТ\n    22тЖТ\tctx, cancel := context.WithCancel(context.Background())\n    23тЖТ\tdefer cancel()\n    24тЖТ\n    25тЖТ\tsigCh := make(chan os.Signal, 1)\n    26тЖТ\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n    27тЖТ\tgo func() {\n    28тЖТ\t\t<-sigCh\n    29тЖТ\t\tcancel()\n    30тЖТ\t}()\n    31тЖТ\n    32тЖТ\trunID := os.Getenv(\"CLOCHE_RUN_ID\")\n    33тЖТ\tos.Unsetenv(\"CLOCHE_RUN_ID\")\n    34тЖТ\n    35тЖТ\trunner := agent.NewRunner(agent.RunnerConfig{\n    36тЖТ\t\tWorkflowPath: workflowPath,\n    37тЖТ\t\tWorkDir:      workDir,\n    38тЖТ\t\tStatusOutput: os.Stdout,\n    39тЖТ\t\tRunID:        runID,\n    40тЖТ\t})\n    41тЖТ\n    42тЖТ\tif err := runner.Run(ctx); err != nil {\n    43тЖТ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    44тЖТ\t\tos.Exit(1)\n    45тЖТ\t}\n    46тЖТ}\n    47тЖТ"}]},"parent_tool_use_id":"toolu_01VgKT2HRKQWwdGh23Lxewca","session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"eb3d2e63-af86-4a39-9b90-6cd7e58c6996"}
