{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01TpSZkNmJkzZNrXVZvgq5pb","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01YXYWoKrnjK4uEGDGdr3FUV","name":"Read","input":{"file_path":"/workspace/internal/host/loop.go"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":385,"cache_read_input_tokens":30620,"cache_creation":{"ephemeral_5m_input_tokens":385,"ephemeral_1h_input_tokens":0},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01VgKT2HRKQWwdGh23Lxewca","session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"5fd73152-c20b-443e-a157-c3eb9e3de71b"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YXYWoKrnjK4uEGDGdr3FUV","type":"tool_result","content":"     1тЖТpackage host\n     2тЖТ\n     3тЖТimport (\n     4тЖТ\t\"context\"\n     5тЖТ\t\"fmt\"\n     6тЖТ\t\"log\"\n     7тЖТ\t\"os\"\n     8тЖТ\t\"path/filepath\"\n     9тЖТ\t\"sync\"\n    10тЖТ\t\"time\"\n    11тЖТ\n    12тЖТ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13тЖТ\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14тЖТ)\n    15тЖТ\n    16тЖТconst (\n    17тЖТ\tdefaultMaxConcurrent = 1\n    18тЖТ\tdefaultDedupTimeout  = 5 * time.Minute\n    19тЖТ\tidlePollInterval     = 2 * time.Minute\n    20тЖТ\tcapacityPollInterval = 30 * time.Second\n    21тЖТ)\n    22тЖТ\n    23тЖТ// LoopConfig holds configuration for an orchestration loop.\n    24тЖТtype LoopConfig struct {\n    25тЖТ\tProjectDir    string\n    26тЖТ\tMaxConcurrent int\n    27тЖТ\tStaggerDelay  time.Duration // delay between launching consecutive runs\n    28тЖТ\tDedupTimeout  time.Duration // how long to suppress reassignment of the same task ID\n    29тЖТ}\n    30тЖТ\n    31тЖТ// ListTasksFunc is called to discover available tasks. It should run the\n    32тЖТ// list-tasks workflow (or equivalent) and return the parsed tasks.\n    33тЖТtype ListTasksFunc func(ctx context.Context, projectDir string) ([]Task, error)\n    34тЖТ\n    35тЖТ// MainFunc is called to execute the main workflow for a given task.\n    36тЖТtype MainFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n    37тЖТ\n    38тЖТ// FinalizeFunc is called after the main workflow completes (both success and\n    39тЖТ// failure). It receives the task ID and the outcome of the main phase.\n    40тЖТtype FinalizeFunc func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error)\n    41тЖТ\n    42тЖТ// RunFunc is the legacy function signature for launching a host workflow run.\n    43тЖТ// When taskID is non-empty, the runner should propagate it as CLOCHE_TASK_ID.\n    44тЖТtype RunFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n    45тЖТ\n    46тЖТ// Loop manages a continuous orchestration loop for a project, keeping up to\n    47тЖТ// MaxConcurrent host workflow runs active at all times when work is available.\n    48тЖТ//\n    49тЖТ// When configured with three-phase functions (list-tasks, main, finalize), the\n    50тЖТ// loop discovers tasks via list-tasks, picks open ones, runs main for each, and\n    51тЖТ// then runs finalize on completion. When configured with a legacy RunFunc, it\n    52тЖТ// falls back to the single-function approach.\n    53тЖТtype Loop struct {\n    54тЖТ\tconfig     LoopConfig\n    55тЖТ\tlistTasks  ListTasksFunc\n    56тЖТ\tmainFn     MainFunc\n    57тЖТ\tfinalizeFn FinalizeFunc // optional; skipped if nil\n    58тЖТ\trunner     RunFunc      // legacy single-function mode\n    59тЖТ\tstore      ports.RunStore\n    60тЖТ\tassigner   TaskAssigner // optional; legacy task assignment\n    61тЖТ\tstopCh     chan struct{}\n    62тЖТ\tmu         sync.Mutex\n    63тЖТ\trunning    bool\n    64тЖТ\tdedupMu    sync.Mutex\n    65тЖТ\tdedup      map[string]time.Time // task ID -> last assignment time\n    66тЖТ}\n    67тЖТ\n    68тЖТ// NewLoop creates an orchestration loop using a single run function (legacy mode).\n    69тЖТ// For three-phase orchestration, use NewPhaseLoop instead.\n    70тЖТfunc NewLoop(cfg LoopConfig, store ports.RunStore, runFn RunFunc) *Loop {\n    71тЖТ\tif cfg.MaxConcurrent <= 0 {\n    72тЖТ\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n    73тЖТ\t}\n    74тЖТ\tif cfg.DedupTimeout <= 0 {\n    75тЖТ\t\tcfg.DedupTimeout = defaultDedupTimeout\n    76тЖТ\t}\n    77тЖТ\treturn &Loop{\n    78тЖТ\t\tconfig: cfg,\n    79тЖТ\t\trunner: runFn,\n    80тЖТ\t\tstore:  store,\n    81тЖТ\t\tdedup:  make(map[string]time.Time),\n    82тЖТ\t}\n    83тЖТ}\n    84тЖТ\n    85тЖТ// NewPhaseLoop creates a three-phase orchestration loop. The listTasksFn\n    86тЖТ// discovers available tasks, mainFn executes the main workflow for a task,\n    87тЖТ// and finalizeFn (optional) runs cleanup after main completes.\n    88тЖТfunc NewPhaseLoop(cfg LoopConfig, store ports.RunStore, listTasksFn ListTasksFunc, mainFn MainFunc, finalizeFn FinalizeFunc) *Loop {\n    89тЖТ\tif cfg.MaxConcurrent <= 0 {\n    90тЖТ\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n    91тЖТ\t}\n    92тЖТ\tif cfg.DedupTimeout <= 0 {\n    93тЖТ\t\tcfg.DedupTimeout = defaultDedupTimeout\n    94тЖТ\t}\n    95тЖТ\treturn &Loop{\n    96тЖТ\t\tconfig:     cfg,\n    97тЖТ\t\tlistTasks:  listTasksFn,\n    98тЖТ\t\tmainFn:     mainFn,\n    99тЖТ\t\tfinalizeFn: finalizeFn,\n   100тЖТ\t\tstore:      store,\n   101тЖТ\t\tdedup:      make(map[string]time.Time),\n   102тЖТ\t}\n   103тЖТ}\n   104тЖТ\n   105тЖТ// SetTaskAssigner configures a TaskAssigner for daemon-managed task assignment.\n   106тЖТ// Only used in legacy (single RunFunc) mode when no list-tasks function is set.\n   107тЖТfunc (l *Loop) SetTaskAssigner(a TaskAssigner) {\n   108тЖТ\tl.assigner = a\n   109тЖТ}\n   110тЖТ\n   111тЖТ// Start begins the orchestration loop. No-op if already running.\n   112тЖТfunc (l *Loop) Start() {\n   113тЖТ\tl.mu.Lock()\n   114тЖТ\tdefer l.mu.Unlock()\n   115тЖТ\tif l.running {\n   116тЖТ\t\treturn\n   117тЖТ\t}\n   118тЖТ\tl.running = true\n   119тЖТ\tl.stopCh = make(chan struct{})\n   120тЖТ\tgo l.run()\n   121тЖТ\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n   122тЖТ}\n   123тЖТ\n   124тЖТ// Stop signals the loop to stop. Active runs continue to completion.\n   125тЖТfunc (l *Loop) Stop() {\n   126тЖТ\tl.mu.Lock()\n   127тЖТ\tdefer l.mu.Unlock()\n   128тЖТ\tif !l.running {\n   129тЖТ\t\treturn\n   130тЖТ\t}\n   131тЖТ\tl.running = false\n   132тЖТ\tclose(l.stopCh)\n   133тЖТ\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n   134тЖТ}\n   135тЖТ\n   136тЖТ// Running returns whether the loop is currently active.\n   137тЖТfunc (l *Loop) Running() bool {\n   138тЖТ\tl.mu.Lock()\n   139тЖТ\tdefer l.mu.Unlock()\n   140тЖТ\treturn l.running\n   141тЖТ}\n   142тЖТ\n   143тЖТfunc (l *Loop) run() {\n   144тЖТ\tif l.listTasks != nil && l.mainFn != nil {\n   145тЖТ\t\tl.runPhased()\n   146тЖТ\t} else {\n   147тЖТ\t\tl.runLegacy()\n   148тЖТ\t}\n   149тЖТ}\n   150тЖТ\n   151тЖТ// runPhased implements the three-phase orchestration loop:\n   152тЖТ// 1. list-tasks тЖТ discover available work\n   153тЖТ// 2. main тЖТ execute work for each open task (up to MaxConcurrent)\n   154тЖТ// 3. finalize тЖТ cleanup after main completes (on both success and failure)\n   155тЖТfunc (l *Loop) runPhased() {\n   156тЖТ\ttype result struct {\n   157тЖТ\t\tstate domain.RunState\n   158тЖТ\t}\n   159тЖТ\n   160тЖТ\tcompletions := make(chan result, l.config.MaxConcurrent)\n   161тЖТ\tinFlight := 0\n   162тЖТ\n   163тЖТ\tfor {\n   164тЖТ\t\t// Fill up to max concurrent slots.\n   165тЖТ\t\tlaunched := 0\n   166тЖТ\t\tfor inFlight < l.config.MaxConcurrent {\n   167тЖТ\t\t\tselect {\n   168тЖТ\t\t\tcase <-l.stopCh:\n   169тЖТ\t\t\t\treturn\n   170тЖТ\t\t\tdefault:\n   171тЖТ\t\t\t}\n   172тЖТ\n   173тЖТ\t\t\t// Check how many host runs are active for this project.\n   174тЖТ\t\t\tactive := l.countActiveHostRuns()\n   175тЖТ\t\t\tif active >= l.config.MaxConcurrent {\n   176тЖТ\t\t\t\tbreak\n   177тЖТ\t\t\t}\n   178тЖТ\n   179тЖТ\t\t\t// Stagger consecutive launches.\n   180тЖТ\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   181тЖТ\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   182тЖТ\t\t\t\t\treturn\n   183тЖТ\t\t\t\t}\n   184тЖТ\t\t\t}\n   185тЖТ\n   186тЖТ\t\t\t// Phase 1: list-tasks тАФ discover available work.\n   187тЖТ\t\t\ttaskID, ok := l.pickTaskFromPhase()\n   188тЖТ\t\t\tif !ok {\n   189тЖТ\t\t\t\tbreak // no assignable tasks\n   190тЖТ\t\t\t}\n   191тЖТ\n   192тЖТ\t\t\t// Launch main + finalize in a goroutine.\n   193тЖТ\t\t\tinFlight++\n   194тЖТ\t\t\tlaunched++\n   195тЖТ\t\t\ttid := taskID\n   196тЖТ\t\t\tgo func() {\n   197тЖТ\t\t\t\t// Phase 2: main тАФ do the work.\n   198тЖТ\t\t\t\tmainResult, err := l.mainFn(context.Background(), l.config.ProjectDir, tid)\n   199тЖТ\t\t\t\tif err != nil {\n   200тЖТ\t\t\t\t\tlog.Printf(\"orchestration loop: main failed for %s task %s: %v\", l.config.ProjectDir, tid, err)\n   201тЖТ\t\t\t\t\tif mainResult == nil {\n   202тЖТ\t\t\t\t\t\tmainResult = &RunResult{State: domain.RunStateFailed}\n   203тЖТ\t\t\t\t\t}\n   204тЖТ\t\t\t\t}\n   205тЖТ\n   206тЖТ\t\t\t\t// Phase 3: finalize тАФ cleanup (runs on both success and failure).\n   207тЖТ\t\t\t\tif l.finalizeFn != nil {\n   208тЖТ\t\t\t\t\t_, finalizeErr := l.finalizeFn(context.Background(), l.config.ProjectDir, tid, mainResult)\n   209тЖТ\t\t\t\t\tif finalizeErr != nil {\n   210тЖТ\t\t\t\t\t\tlog.Printf(\"orchestration loop: finalize failed for %s task %s: %v\", l.config.ProjectDir, tid, finalizeErr)\n   211тЖТ\t\t\t\t\t}\n   212тЖТ\t\t\t\t}\n   213тЖТ\n   214тЖТ\t\t\t\tcompletions <- result{state: mainResult.State}\n   215тЖТ\t\t\t}()\n   216тЖТ\t\t}\n   217тЖТ\n   218тЖТ\t\tif inFlight == 0 {\n   219тЖТ\t\t\t// Nothing in flight and couldn't launch anything тАФ wait before checking again.\n   220тЖТ\t\t\tif !l.sleep(capacityPollInterval) {\n   221тЖТ\t\t\t\treturn\n   222тЖТ\t\t\t}\n   223тЖТ\t\t\tcontinue\n   224тЖТ\t\t}\n   225тЖТ\n   226тЖТ\t\t// Wait for any run to complete.\n   227тЖТ\t\tselect {\n   228тЖТ\t\tcase r := <-completions:\n   229тЖТ\t\t\tinFlight--\n   230тЖТ\t\t\tif r.state == domain.RunStateSucceeded {\n   231тЖТ\t\t\t\t// Work was done тАФ try to fill slots immediately.\n   232тЖТ\t\t\t\tcontinue\n   233тЖТ\t\t\t}\n   234тЖТ\t\t\t// Run failed or aborted. Back off.\n   235тЖТ\t\t\tif !l.sleep(idlePollInterval) {\n   236тЖТ\t\t\t\treturn\n   237тЖТ\t\t\t}\n   238тЖТ\t\tcase <-l.stopCh:\n   239тЖТ\t\t\treturn\n   240тЖТ\t\t}\n   241тЖТ\t}\n   242тЖТ}\n   243тЖТ\n   244тЖТ// pickTaskFromPhase runs the list-tasks function and picks the first open,\n   245тЖТ// non-deduped task.\n   246тЖТfunc (l *Loop) pickTaskFromPhase() (string, bool) {\n   247тЖТ\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   248тЖТ\tdefer cancel()\n   249тЖТ\n   250тЖТ\ttasks, err := l.listTasks(ctx, l.config.ProjectDir)\n   251тЖТ\tif err != nil {\n   252тЖТ\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n   253тЖТ\t\treturn \"\", false\n   254тЖТ\t}\n   255тЖТ\n   256тЖТ\tnow := time.Now()\n   257тЖТ\tl.dedupMu.Lock()\n   258тЖТ\tdefer l.dedupMu.Unlock()\n   259тЖТ\n   260тЖТ\t// Expire old dedup entries.\n   261тЖТ\tfor id, ts := range l.dedup {\n   262тЖТ\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n   263тЖТ\t\t\tdelete(l.dedup, id)\n   264тЖТ\t\t}\n   265тЖТ\t}\n   266тЖТ\n   267тЖТ\tfor _, task := range tasks {\n   268тЖТ\t\tif task.ID == \"\" {\n   269тЖТ\t\t\tcontinue\n   270тЖТ\t\t}\n   271тЖТ\t\tif !task.IsOpen() {\n   272тЖТ\t\t\tcontinue\n   273тЖТ\t\t}\n   274тЖТ\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   275тЖТ\t\t\tcontinue\n   276тЖТ\t\t}\n   277тЖТ\t\tl.dedup[task.ID] = now\n   278тЖТ\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n   279тЖТ\t\treturn task.ID, true\n   280тЖТ\t}\n   281тЖТ\n   282тЖТ\treturn \"\", false\n   283тЖТ}\n   284тЖТ\n   285тЖТ// runLegacy implements the original single-function orchestration loop.\n   286тЖТfunc (l *Loop) runLegacy() {\n   287тЖТ\ttype result struct {\n   288тЖТ\t\tstate domain.RunState\n   289тЖТ\t}\n   290тЖТ\n   291тЖТ\tcompletions := make(chan result, l.config.MaxConcurrent)\n   292тЖТ\tinFlight := 0\n   293тЖТ\n   294тЖТ\tfor {\n   295тЖТ\t\t// Fill up to max concurrent slots.\n   296тЖТ\t\tlaunched := 0\n   297тЖТ\t\tfor inFlight < l.config.MaxConcurrent {\n   298тЖТ\t\t\tselect {\n   299тЖТ\t\t\tcase <-l.stopCh:\n   300тЖТ\t\t\t\treturn\n   301тЖТ\t\t\tdefault:\n   302тЖТ\t\t\t}\n   303тЖТ\n   304тЖТ\t\t\t// Check how many host runs are active for this project (in case of\n   305тЖТ\t\t\t// leftover runs from previous loops).\n   306тЖТ\t\t\tactive := l.countActiveHostRuns()\n   307тЖТ\t\t\tif active >= l.config.MaxConcurrent {\n   308тЖТ\t\t\t\tbreak\n   309тЖТ\t\t\t}\n   310тЖТ\n   311тЖТ\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n   312тЖТ\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   313тЖТ\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   314тЖТ\t\t\t\t\treturn\n   315тЖТ\t\t\t\t}\n   316тЖТ\t\t\t}\n   317тЖТ\n   318тЖТ\t\t\t// Determine task ID (if task assigner is configured).\n   319тЖТ\t\t\ttaskID := \"\"\n   320тЖТ\t\t\tif l.assigner != nil {\n   321тЖТ\t\t\t\tvar ok bool\n   322тЖТ\t\t\t\ttaskID, ok = l.pickTask()\n   323тЖТ\t\t\t\tif !ok {\n   324тЖТ\t\t\t\t\t// No assignable tasks available.\n   325тЖТ\t\t\t\t\tbreak\n   326тЖТ\t\t\t\t}\n   327тЖТ\t\t\t}\n   328тЖТ\n   329тЖТ\t\t\t// Launch a new orchestration run in a goroutine.\n   330тЖТ\t\t\tinFlight++\n   331тЖТ\t\t\tlaunched++\n   332тЖТ\t\t\ttid := taskID // capture for goroutine\n   333тЖТ\t\t\tgo func() {\n   334тЖТ\t\t\t\tres, err := l.runner(context.Background(), l.config.ProjectDir, tid)\n   335тЖТ\t\t\t\tif err != nil {\n   336тЖТ\t\t\t\t\tlog.Printf(\"orchestration loop: run failed for %s: %v\", l.config.ProjectDir, err)\n   337тЖТ\t\t\t\t\tcompletions <- result{state: domain.RunStateFailed}\n   338тЖТ\t\t\t\t\treturn\n   339тЖТ\t\t\t\t}\n   340тЖТ\t\t\t\tcompletions <- result{state: res.State}\n   341тЖТ\t\t\t}()\n   342тЖТ\t\t}\n   343тЖТ\n   344тЖТ\t\tif inFlight == 0 {\n   345тЖТ\t\t\t// Nothing in flight and at capacity тАФ wait before checking again.\n   346тЖТ\t\t\tif !l.sleep(capacityPollInterval) {\n   347тЖТ\t\t\t\treturn\n   348тЖТ\t\t\t}\n   349тЖТ\t\t\tcontinue\n   350тЖТ\t\t}\n   351тЖТ\n   352тЖТ\t\t// Wait for any run to complete.\n   353тЖТ\t\tselect {\n   354тЖТ\t\tcase r := <-completions:\n   355тЖТ\t\t\tinFlight--\n   356тЖТ\t\t\tif r.state == domain.RunStateSucceeded {\n   357тЖТ\t\t\t\t// Work was done тАФ try to fill slots immediately.\n   358тЖТ\t\t\t\tcontinue\n   359тЖТ\t\t\t}\n   360тЖТ\t\t\t// Run failed or aborted (no tasks available). Back off.\n   361тЖТ\t\t\tif !l.sleep(idlePollInterval) {\n   362тЖТ\t\t\t\treturn\n   363тЖТ\t\t\t}\n   364тЖТ\t\tcase <-l.stopCh:\n   365тЖТ\t\t\treturn\n   366тЖТ\t\t}\n   367тЖТ\t}\n   368тЖТ}\n   369тЖТ\n   370тЖТ// pickTask queries the task assigner for available tasks, filters out those\n   371тЖТ// within the dedup timeout window, and returns the first assignable task ID.\n   372тЖТ// It records the assignment time so the same task won't be picked again until\n   373тЖТ// the dedup timeout expires. Returns (\"\", false) if no tasks are available.\n   374тЖТfunc (l *Loop) pickTask() (string, bool) {\n   375тЖТ\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   376тЖТ\tdefer cancel()\n   377тЖТ\n   378тЖТ\ttasks, err := l.assigner.ListTasks(ctx, l.config.ProjectDir)\n   379тЖТ\tif err != nil {\n   380тЖТ\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n   381тЖТ\t\treturn \"\", false\n   382тЖТ\t}\n   383тЖТ\n   384тЖТ\tnow := time.Now()\n   385тЖТ\tl.dedupMu.Lock()\n   386тЖТ\tdefer l.dedupMu.Unlock()\n   387тЖТ\n   388тЖТ\t// Expire old dedup entries while we're here.\n   389тЖТ\tfor id, ts := range l.dedup {\n   390тЖТ\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n   391тЖТ\t\t\tdelete(l.dedup, id)\n   392тЖТ\t\t}\n   393тЖТ\t}\n   394тЖТ\n   395тЖТ\tfor _, task := range tasks {\n   396тЖТ\t\tif task.ID == \"\" {\n   397тЖТ\t\t\tcontinue\n   398тЖТ\t\t}\n   399тЖТ\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   400тЖТ\t\t\tcontinue // still within dedup window\n   401тЖТ\t\t}\n   402тЖТ\t\t// Assign this task.\n   403тЖТ\t\tl.dedup[task.ID] = now\n   404тЖТ\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n   405тЖТ\t\treturn task.ID, true\n   406тЖТ\t}\n   407тЖТ\n   408тЖТ\treturn \"\", false\n   409тЖТ}\n   410тЖТ\n   411тЖТ// countActiveHostRuns counts running or pending host runs for the project.\n   412тЖТfunc (l *Loop) countActiveHostRuns() int {\n   413тЖТ\tctx := context.Background()\n   414тЖТ\truns, err := l.store.ListRunsByProject(ctx, l.config.ProjectDir, time.Time{})\n   415тЖТ\tif err != nil {\n   416тЖТ\t\treturn 0\n   417тЖТ\t}\n   418тЖТ\tcount := 0\n   419тЖТ\tfor _, r := range runs {\n   420тЖТ\t\tif r.IsHost && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n   421тЖТ\t\t\tcount++\n   422тЖТ\t\t}\n   423тЖТ\t}\n   424тЖТ\treturn count\n   425тЖТ}\n   426тЖТ\n   427тЖТ// sleep waits for the given duration or until the loop is stopped.\n   428тЖТ// Returns false if the loop was stopped.\n   429тЖТfunc (l *Loop) sleep(d time.Duration) bool {\n   430тЖТ\tselect {\n   431тЖТ\tcase <-time.After(d):\n   432тЖТ\t\treturn true\n   433тЖТ\tcase <-l.stopCh:\n   434тЖТ\t\treturn false\n   435тЖТ\t}\n   436тЖТ}\n   437тЖТ\n   438тЖТ// ReadListTasksOutput reads the output directory from a list-tasks workflow run\n   439тЖТ// and parses JSONL task output from the last step's output file.\n   440тЖТfunc ReadListTasksOutput(outputDir string) ([]Task, error) {\n   441тЖТ\tentries, err := os.ReadDir(outputDir)\n   442тЖТ\tif err != nil {\n   443тЖТ\t\treturn nil, fmt.Errorf(\"reading list-tasks output dir: %w\", err)\n   444тЖТ\t}\n   445тЖТ\n   446тЖТ\t// Find the most recently modified .out file.\n   447тЖТ\tvar latest string\n   448тЖТ\tvar latestMod time.Time\n   449тЖТ\tfor _, e := range entries {\n   450тЖТ\t\tif e.IsDir() || filepath.Ext(e.Name()) != \".out\" {\n   451тЖТ\t\t\tcontinue\n   452тЖТ\t\t}\n   453тЖТ\t\tinfo, err := e.Info()\n   454тЖТ\t\tif err != nil {\n   455тЖТ\t\t\tcontinue\n   456тЖТ\t\t}\n   457тЖТ\t\tif latest == \"\" || info.ModTime().After(latestMod) {\n   458тЖТ\t\t\tlatest = e.Name()\n   459тЖТ\t\t\tlatestMod = info.ModTime()\n   460тЖТ\t\t}\n   461тЖТ\t}\n   462тЖТ\n   463тЖТ\tif latest == \"\" {\n   464тЖТ\t\treturn nil, fmt.Errorf(\"no output files found in %s\", outputDir)\n   465тЖТ\t}\n   466тЖТ\n   467тЖТ\tdata, err := os.ReadFile(filepath.Join(outputDir, latest))\n   468тЖТ\tif err != nil {\n   469тЖТ\t\treturn nil, fmt.Errorf(\"reading output file %s: %w\", latest, err)\n   470тЖТ\t}\n   471тЖТ\n   472тЖТ\treturn ParseTasksJSONL(string(data))\n   473тЖТ}\n   474тЖТ"}]},"parent_tool_use_id":"toolu_01VgKT2HRKQWwdGh23Lxewca","session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"3989694b-fff9-41f3-aa61-745ae36de021"}
