{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RA4GgseirjL5Qh1vmyKvNm","type":"tool_result","content":"     1тЖТpackage prompt\n     2тЖТ\n     3тЖТimport (\n     4тЖТ\t\"bufio\"\n     5тЖТ\t\"bytes\"\n     6тЖТ\t\"context\"\n     7тЖТ\t\"encoding/json\"\n     8тЖТ\t\"fmt\"\n     9тЖТ\t\"os\"\n    10тЖТ\t\"os/exec\"\n    11тЖТ\t\"path/filepath\"\n    12тЖТ\t\"strconv\"\n    13тЖТ\t\"strings\"\n    14тЖТ\n    15тЖТ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16тЖТ\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17тЖТ)\n    18тЖТ\n    19тЖТ// defaultAgentArgs maps known agent commands to their default arguments.\n    20тЖТ// Commands not in this map receive no default arguments (prompt on stdin only).\n    21тЖТvar defaultAgentArgs = map[string][]string{\n    22тЖТ\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n    23тЖТ}\n    24тЖТ\n    25тЖТtype Adapter struct {\n    26тЖТ\tCommands     []string // ordered fallback chain of agent commands\n    27тЖТ\tExplicitArgs []string // if non-nil, overrides default args for all commands\n    28тЖТ\tRunID        string\n    29тЖТ\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n    30тЖТ}\n    31тЖТ\n    32тЖТfunc New() *Adapter {\n    33тЖТ\treturn &Adapter{\n    34тЖТ\t\tCommands: []string{\"claude\"},\n    35тЖТ\t}\n    36тЖТ}\n    37тЖТ\n    38тЖТfunc (a *Adapter) Name() string {\n    39тЖТ\treturn \"prompt\"\n    40тЖТ}\n    41тЖТ\n    42тЖТ// argsFor returns the arguments for the given command. If ExplicitArgs is set,\n    43тЖТ// it is used for all commands. Otherwise, known agents get their default args.\n    44тЖТfunc (a *Adapter) argsFor(command string) []string {\n    45тЖТ\tif a.ExplicitArgs != nil {\n    46тЖТ\t\treturn a.ExplicitArgs\n    47тЖТ\t}\n    48тЖТ\tif args, ok := defaultAgentArgs[command]; ok {\n    49тЖТ\t\treturn args\n    50тЖТ\t}\n    51тЖТ\treturn nil\n    52тЖТ}\n    53тЖТ\n    54тЖТ// ParseCommands splits a comma-separated agent_command string into individual\n    55тЖТ// command names, trimming whitespace from each entry.\n    56тЖТfunc ParseCommands(s string) []string {\n    57тЖТ\tparts := strings.Split(s, \",\")\n    58тЖТ\tvar cmds []string\n    59тЖТ\tfor _, p := range parts {\n    60тЖТ\t\tp = strings.TrimSpace(p)\n    61тЖТ\t\tif p != \"\" {\n    62тЖТ\t\t\tcmds = append(cmds, p)\n    63тЖТ\t\t}\n    64тЖТ\t}\n    65тЖТ\treturn cmds\n    66тЖТ}\n    67тЖТ\n    68тЖТfunc (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    69тЖТ\t// Check attempt count for retry limiting\n    70тЖТ\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n    71тЖТ\t\tmax, err := strconv.Atoi(maxStr)\n    72тЖТ\t\tif err == nil {\n    73тЖТ\t\t\tcount := readAttemptCount(workDir, step.Name)\n    74тЖТ\t\t\tif count >= max {\n    75тЖТ\t\t\t\treturn \"give-up\", nil\n    76тЖТ\t\t\t}\n    77тЖТ\t\t}\n    78тЖТ\t}\n    79тЖТ\tincrementAttemptCount(workDir, step.Name)\n    80тЖТ\n    81тЖТ\t// Build the full prompt\n    82тЖТ\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n    83тЖТ\tif err != nil {\n    84тЖТ\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n    85тЖТ\t}\n    86тЖТ\n    87тЖТ\t// Try each command in the fallback chain\n    88тЖТ\tvar lastResult string\n    89тЖТ\tvar lastStdout []byte\n    90тЖТ\tvar lastErr error\n    91тЖТ\tran := false\n    92тЖТ\n    93тЖТ\tfor _, command := range a.Commands {\n    94тЖТ\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n    95тЖТ\t\tlastResult = result\n    96тЖТ\t\tlastStdout = stdout\n    97тЖТ\t\tlastErr = fallbackErr\n    98тЖТ\n    99тЖТ\t\tif fallbackErr == nil {\n   100тЖТ\t\t\t// Definitive result тАФ agent completed (exit 0 or exit non-zero with marker)\n   101тЖТ\t\t\tbreak\n   102тЖТ\t\t}\n   103тЖТ\t\tif stdout != nil {\n   104тЖТ\t\t\tran = true\n   105тЖТ\t\t}\n   106тЖТ\t\t// Fallback-eligible тАФ try next command\n   107тЖТ\t}\n   108тЖТ\n   109тЖТ\tif lastErr != nil && !ran && lastStdout == nil {\n   110тЖТ\t\t// All commands failed to produce any output (e.g., all not found)\n   111тЖТ\t\treturn \"\", lastErr\n   112тЖТ\t}\n   113тЖТ\n   114тЖТ\tresult := lastResult\n   115тЖТ\tif lastErr != nil {\n   116тЖТ\t\t// Last command in chain crashed without a result marker\n   117тЖТ\t\tresult = \"fail\"\n   118тЖТ\t}\n   119тЖТ\n   120тЖТ\t// Write output file\n   121тЖТ\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   122тЖТ\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n   123тЖТ\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n   124тЖТ\t}\n   125тЖТ\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n   126тЖТ\treturn result, nil\n   127тЖТ}\n   128тЖТ\n   129тЖТ// tryCommand executes a single agent command and returns:\n   130тЖТ//   - result: the step result name (e.g. \"success\", \"fail\")\n   131тЖТ//   - stdout: captured stdout bytes\n   132тЖТ//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n   133тЖТ//\n   134тЖТ// Fallback-eligible conditions:\n   135тЖТ//   - Command not found or failed to start (stdout will be nil)\n   136тЖТ//   - Command exited non-zero without a CLOCHE_RESULT marker\n   137тЖТ//\n   138тЖТ// Definitive (non-fallback) conditions:\n   139тЖТ//   - Command exited 0\n   140тЖТ//   - Command exited non-zero but produced a CLOCHE_RESULT marker\n   141тЖТfunc (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n   142тЖТ\targs := a.argsFor(command)\n   143тЖТ\tcmd := exec.CommandContext(ctx, command, args...)\n   144тЖТ\tcmd.Dir = workDir\n   145тЖТ\tcmd.Stdin = strings.NewReader(prompt)\n   146тЖТ\n   147тЖТ\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n   148тЖТ\tif a.StatusWriter == nil {\n   149тЖТ\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n   150тЖТ\t\tcmd.Stdout = &stdoutBuf\n   151тЖТ\t\tcmd.Stderr = &stderrBuf\n   152тЖТ\n   153тЖТ\t\trunErr := cmd.Run()\n   154тЖТ\t\tstdoutBytes := stdoutBuf.Bytes()\n   155тЖТ\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n   156тЖТ\t}\n   157тЖТ\n   158тЖТ\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n   159тЖТ\tpipe, err := cmd.StdoutPipe()\n   160тЖТ\tif err != nil {\n   161тЖТ\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n   162тЖТ\t}\n   163тЖТ\tcmd.Stderr = nil // discard stderr\n   164тЖТ\n   165тЖТ\tif err := cmd.Start(); err != nil {\n   166тЖТ\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n   167тЖТ\t}\n   168тЖТ\n   169тЖТ\t// textBuf accumulates extracted text content for result extraction.\n   170тЖТ\t// rawBuf accumulates raw stdout for the output log file.\n   171тЖТ\tvar textBuf, rawBuf bytes.Buffer\n   172тЖТ\t// lineBuf accumulates text deltas into lines for streaming.\n   173тЖТ\tvar lineBuf strings.Builder\n   174тЖТ\n   175тЖТ\tscanner := bufio.NewScanner(pipe)\n   176тЖТ\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n   177тЖТ\tfor scanner.Scan() {\n   178тЖТ\t\traw := scanner.Bytes()\n   179тЖТ\t\trawBuf.Write(raw)\n   180тЖТ\t\trawBuf.WriteByte('\\n')\n   181тЖТ\n   182тЖТ\t\ttext := extractStreamText(raw)\n   183тЖТ\t\tif text == \"\" {\n   184тЖТ\t\t\tcontinue\n   185тЖТ\t\t}\n   186тЖТ\t\ttextBuf.WriteString(text)\n   187тЖТ\n   188тЖТ\t\t// Stream complete lines to StatusWriter as they form.\n   189тЖТ\t\tlineBuf.WriteString(text)\n   190тЖТ\t\tfor {\n   191тЖТ\t\t\ts := lineBuf.String()\n   192тЖТ\t\t\tidx := strings.IndexByte(s, '\\n')\n   193тЖТ\t\t\tif idx < 0 {\n   194тЖТ\t\t\t\tbreak\n   195тЖТ\t\t\t}\n   196тЖТ\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n   197тЖТ\t\t\tlineBuf.Reset()\n   198тЖТ\t\t\tlineBuf.WriteString(s[idx+1:])\n   199тЖТ\t\t}\n   200тЖТ\t}\n   201тЖТ\t// Flush any remaining partial line.\n   202тЖТ\tif lineBuf.Len() > 0 {\n   203тЖТ\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n   204тЖТ\t}\n   205тЖТ\tif scanErr := scanner.Err(); scanErr != nil {\n   206тЖТ\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n   207тЖТ\t}\n   208тЖТ\n   209тЖТ\twaitErr := cmd.Wait()\n   210тЖТ\t// Prefer extracted text (stream-json) for result classification; fall back\n   211тЖТ\t// to raw output for non-JSON commands (scripts, non-claude agents).\n   212тЖТ\tclassifyBuf := textBuf.Bytes()\n   213тЖТ\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n   214тЖТ\t\tclassifyBuf = rawBuf.Bytes()\n   215тЖТ\t}\n   216тЖТ\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n   217тЖТ\treturn result, rawBuf.Bytes(), fallbackErr\n   218тЖТ}\n   219тЖТ\n   220тЖТ// classifyResult interprets the command's exit status and stdout to determine\n   221тЖТ// the step result.\n   222тЖТfunc (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n   223тЖТ\tif runErr != nil {\n   224тЖТ\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n   225тЖТ\t\t\t// Command failed to start (not found, permission denied, etc.)\n   226тЖТ\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n   227тЖТ\t\t}\n   228тЖТ\t\t// Command ran but exited non-zero\n   229тЖТ\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   230тЖТ\t\tif found {\n   231тЖТ\t\t\treturn markerResult, stdoutBytes, nil\n   232тЖТ\t\t}\n   233тЖТ\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n   234тЖТ\t}\n   235тЖТ\n   236тЖТ\t// Command succeeded (exit 0)\n   237тЖТ\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n   238тЖТ\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n   239тЖТ\t}\n   240тЖТ\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   241тЖТ\tresult := \"success\"\n   242тЖТ\tif found {\n   243тЖТ\t\tresult = markerResult\n   244тЖТ\t}\n   245тЖТ\treturn result, stdoutBytes, nil\n   246тЖТ}\n   247тЖТ\n   248тЖТ// extractStreamText parses a Claude Code stream-json line and returns text content.\n   249тЖТ//\n   250тЖТ// Claude Code's stream-json emits these event types:\n   251тЖТ//   - \"assistant\": one per turn, contains message.content[] with text and tool_use blocks\n   252тЖТ//   - \"result\": final event with the full result text (contains CLOCHE_RESULT marker)\n   253тЖТ//\n   254тЖТ// For assistant events, we extract text blocks and summarize tool_use blocks\n   255тЖТ// (e.g. \"--- Tool: Read('path') ---\"). Each assistant event has a unique uuid\n   256тЖТ// for dedup by the caller.\n   257тЖТfunc extractStreamText(line []byte) string {\n   258тЖТ\t// Fast path: skip lines that can't contain content we care about.\n   259тЖТ\tif !bytes.Contains(line, []byte(`\"type\"`)) {\n   260тЖТ\t\treturn \"\"\n   261тЖТ\t}\n   262тЖТ\n   263тЖТ\tvar envelope struct {\n   264тЖТ\t\tType string `json:\"type\"`\n   265тЖТ\t}\n   266тЖТ\tif json.Unmarshal(line, &envelope) != nil {\n   267тЖТ\t\treturn \"\"\n   268тЖТ\t}\n   269тЖТ\n   270тЖТ\tswitch envelope.Type {\n   271тЖТ\tcase \"assistant\":\n   272тЖТ\t\treturn extractAssistantText(line)\n   273тЖТ\tcase \"result\":\n   274тЖТ\t\treturn extractResultText(line)\n   275тЖТ\t}\n   276тЖТ\treturn \"\"\n   277тЖТ}\n   278тЖТ\n   279тЖТ// extractAssistantText extracts text and tool-use summaries from an assistant event.\n   280тЖТfunc extractAssistantText(line []byte) string {\n   281тЖТ\tvar event struct {\n   282тЖТ\t\tMessage struct {\n   283тЖТ\t\t\tContent []struct {\n   284тЖТ\t\t\t\tType  string          `json:\"type\"`\n   285тЖТ\t\t\t\tText  string          `json:\"text\"`\n   286тЖТ\t\t\t\tName  string          `json:\"name\"`\n   287тЖТ\t\t\t\tInput json.RawMessage `json:\"input\"`\n   288тЖТ\t\t\t} `json:\"content\"`\n   289тЖТ\t\t} `json:\"message\"`\n   290тЖТ\t}\n   291тЖТ\tif json.Unmarshal(line, &event) != nil {\n   292тЖТ\t\treturn \"\"\n   293тЖТ\t}\n   294тЖТ\n   295тЖТ\tvar b strings.Builder\n   296тЖТ\tfor _, c := range event.Message.Content {\n   297тЖТ\t\tswitch c.Type {\n   298тЖТ\t\tcase \"text\":\n   299тЖТ\t\t\tif c.Text != \"\" {\n   300тЖТ\t\t\t\tb.WriteString(c.Text)\n   301тЖТ\t\t\t\tif !strings.HasSuffix(c.Text, \"\\n\") {\n   302тЖТ\t\t\t\t\tb.WriteByte('\\n')\n   303тЖТ\t\t\t\t}\n   304тЖТ\t\t\t}\n   305тЖТ\t\tcase \"tool_use\":\n   306тЖТ\t\t\tb.WriteString(\"--- Tool: \")\n   307тЖТ\t\t\tb.WriteString(c.Name)\n   308тЖТ\t\t\tb.WriteString(toolInputSummary(c.Input))\n   309тЖТ\t\t\tb.WriteString(\" ---\\n\")\n   310тЖТ\t\t}\n   311тЖТ\t}\n   312тЖТ\treturn b.String()\n   313тЖТ}\n   314тЖТ\n   315тЖТ// extractResultText extracts the final result text (contains CLOCHE_RESULT marker).\n   316тЖТfunc extractResultText(line []byte) string {\n   317тЖТ\tif !bytes.Contains(line, []byte(`\"subtype\"`)) {\n   318тЖТ\t\treturn \"\"\n   319тЖТ\t}\n   320тЖТ\tvar event struct {\n   321тЖТ\t\tType   string `json:\"type\"`\n   322тЖТ\t\tResult string `json:\"result\"`\n   323тЖТ\t}\n   324тЖТ\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n   325тЖТ\t\treturn event.Result\n   326тЖТ\t}\n   327тЖТ\treturn \"\"\n   328тЖТ}\n   329тЖТ\n   330тЖТ// toolInputSummary returns a short parenthesized summary of a tool's input.\n   331тЖТfunc toolInputSummary(input json.RawMessage) string {\n   332тЖТ\tif len(input) == 0 {\n   333тЖТ\t\treturn \"\"\n   334тЖТ\t}\n   335тЖТ\tvar m map[string]json.RawMessage\n   336тЖТ\tif json.Unmarshal(input, &m) != nil {\n   337тЖТ\t\treturn \"\"\n   338тЖТ\t}\n   339тЖТ\t// Pick the most informative single argument to show.\n   340тЖТ\tfor _, key := range []string{\"file_path\", \"command\", \"pattern\", \"prompt\", \"skill\"} {\n   341тЖТ\t\tif v, ok := m[key]; ok {\n   342тЖТ\t\t\tvar s string\n   343тЖТ\t\t\tif json.Unmarshal(v, &s) == nil {\n   344тЖТ\t\t\t\tif len(s) > 60 {\n   345тЖТ\t\t\t\t\ts = s[:57] + \"...\"\n   346тЖТ\t\t\t\t}\n   347тЖТ\t\t\t\treturn \"('\" + s + \"')\"\n   348тЖТ\t\t\t}\n   349тЖТ\t\t}\n   350тЖТ\t}\n   351тЖТ\treturn \"\"\n   352тЖТ}\n   353тЖТ\n   354тЖТfunc assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n   355тЖТ\tvar parts []string\n   356тЖТ\n   357тЖТ\t// 1. Read system template from step config\n   358тЖТ\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n   359тЖТ\t\tcontent, err := resolveContent(tmpl, workDir)\n   360тЖТ\t\tif err != nil {\n   361тЖТ\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n   362тЖТ\t\t}\n   363тЖТ\t\tparts = append(parts, content)\n   364тЖТ\t}\n   365тЖТ\n   366тЖТ\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n   367тЖТ\tuserPrompt := readUserPrompt(workDir, runID)\n   368тЖТ\tif userPrompt != \"\" {\n   369тЖТ\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n   370тЖТ\t}\n   371тЖТ\n   372тЖТ\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n   373тЖТ\tif step.Config[\"feedback\"] == \"true\" {\n   374тЖТ\t\tfeedback := readFeedback(workDir)\n   375тЖТ\t\tif feedback != \"\" {\n   376тЖТ\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n   377тЖТ\t\t}\n   378тЖТ\t}\n   379тЖТ\n   380тЖТ\t// 4. Result selection instructions\n   381тЖТ\tif len(step.Results) > 0 {\n   382тЖТ\t\tvar resultLines []string\n   383тЖТ\t\tresultLines = append(resultLines, \"## Result Selection\")\n   384тЖТ\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n   385тЖТ\t\tfor _, r := range step.Results {\n   386тЖТ\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n   387тЖТ\t\t}\n   388тЖТ\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n   389тЖТ\t}\n   390тЖТ\n   391тЖТ\treturn strings.Join(parts, \"\\n\\n\"), nil\n   392тЖТ}\n   393тЖТ\n   394тЖТ// resolveContent handles file(\"path\") syntax or returns the string directly.\n   395тЖТfunc resolveContent(value string, workDir string) (string, error) {\n   396тЖТ\t// Check for file(\"path\") syntax from DSL parser\n   397тЖТ\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n   398тЖТ\t\tpath := value[6 : len(value)-2]\n   399тЖТ\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n   400тЖТ\t\tif err != nil {\n   401тЖТ\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n   402тЖТ\t\t}\n   403тЖТ\t\treturn string(data), nil\n   404тЖТ\t}\n   405тЖТ\treturn value, nil\n   406тЖТ}\n   407тЖТ\n   408тЖТfunc readFeedback(workDir string) string {\n   409тЖТ\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   410тЖТ\tentries, err := os.ReadDir(outputDir)\n   411тЖТ\tif err != nil {\n   412тЖТ\t\treturn \"\"\n   413тЖТ\t}\n   414тЖТ\n   415тЖТ\tvar parts []string\n   416тЖТ\tfor _, entry := range entries {\n   417тЖТ\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n   418тЖТ\t\t\tcontinue\n   419тЖТ\t\t}\n   420тЖТ\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n   421тЖТ\t\tif err != nil {\n   422тЖТ\t\t\tcontinue\n   423тЖТ\t\t}\n   424тЖТ\t\tcontent := strings.TrimSpace(string(data))\n   425тЖТ\t\tif content != \"\" {\n   426тЖТ\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n   427тЖТ\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n   428тЖТ\t\t}\n   429тЖТ\t}\n   430тЖТ\n   431тЖТ\treturn strings.Join(parts, \"\\n\\n\")\n   432тЖТ}\n   433тЖТ\n   434тЖТfunc readAttemptCount(workDir, stepName string) int {\n   435тЖТ\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n   436тЖТ\tdata, err := os.ReadFile(path)\n   437тЖТ\tif err != nil {\n   438тЖТ\t\treturn 0\n   439тЖТ\t}\n   440тЖТ\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n   441тЖТ\treturn n\n   442тЖТ}\n   443тЖТ\n   444тЖТ// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\n   445тЖТfunc readUserPrompt(workDir, runID string) string {\n   446тЖТ\tif runID == \"\" {\n   447тЖТ\t\treturn \"\"\n   448тЖТ\t}\n   449тЖТ\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   450тЖТ\tif data, err := os.ReadFile(path); err == nil {\n   451тЖТ\t\treturn string(data)\n   452тЖТ\t}\n   453тЖТ\treturn \"\"\n   454тЖТ}\n   455тЖТ\n   456тЖТfunc incrementAttemptCount(workDir, stepName string) {\n   457тЖТ\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n   458тЖТ\t_ = os.MkdirAll(dir, 0755)\n   459тЖТ\tcount := readAttemptCount(workDir, stepName) + 1\n   460тЖТ\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n   461тЖТ}\n   462тЖТ"}]},"parent_tool_use_id":"toolu_01VgKT2HRKQWwdGh23Lxewca","session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"dc3614cd-5139-491f-ba03-acdbe6dd0385"}
