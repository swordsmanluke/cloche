{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UP8XMwjhuTjf4oHo1QfPVu","type":"tool_result","content":"     1тЖТpackage docker\n     2тЖТ\n     3тЖТimport (\n     4тЖТ\t\"bytes\"\n     5тЖТ\t\"context\"\n     6тЖТ\t\"fmt\"\n     7тЖТ\t\"io\"\n     8тЖТ\t\"os\"\n     9тЖТ\t\"os/exec\"\n    10тЖТ\t\"path/filepath\"\n    11тЖТ\t\"strconv\"\n    12тЖТ\t\"strings\"\n    13тЖТ\t\"time\"\n    14тЖТ\n    15тЖТ\t\"github.com/cloche-dev/cloche/internal/ports\"\n    16тЖТ)\n    17тЖТ\n    18тЖТtype Runtime struct{}\n    19тЖТ\n    20тЖТfunc NewRuntime() (*Runtime, error) {\n    21тЖТ\tif _, err := exec.LookPath(\"docker\"); err != nil {\n    22тЖТ\t\treturn nil, fmt.Errorf(\"docker not found in PATH: %w\", err)\n    23тЖТ\t}\n    24тЖТ\treturn &Runtime{}, nil\n    25тЖТ}\n    26тЖТ\n    27тЖТfunc (r *Runtime) Start(ctx context.Context, cfg ports.ContainerConfig) (string, error) {\n    28тЖТ\t// Build docker create args\n    29тЖТ\tcontainerCmd := cfg.Cmd\n    30тЖТ\tuseDefaultCmd := len(containerCmd) == 0\n    31тЖТ\tif useDefaultCmd {\n    32тЖТ\t\tcontainerCmd = []string{\"cloche-agent\", \".cloche/\" + cfg.WorkflowName + \".cloche\"}\n    33тЖТ\t}\n    34тЖТ\n    35тЖТ\targs := []string{\n    36тЖТ\t\t\"create\",\n    37тЖТ\t\t\"--workdir\", \"/workspace\",\n    38тЖТ\t\t\"--add-host=host.docker.internal:host-gateway\",\n    39тЖТ\t}\n    40тЖТ\n    41тЖТ\t// When using the default command, run as root and wrap with chown + su agent\n    42тЖТ\t// so the workspace is owned by the agent user. Custom Cmd runs as-is.\n    43тЖТ\tif useDefaultCmd {\n    44тЖТ\t\targs = append(args, \"--user\", \"root\")\n    45тЖТ\t}\n    46тЖТ\n    47тЖТ\t// Pass run ID into container\n    48тЖТ\tif cfg.RunID != \"\" {\n    49тЖТ\t\targs = append(args, \"-e\", \"CLOCHE_RUN_ID=\"+cfg.RunID)\n    50тЖТ\t}\n    51тЖТ\t// Pass ANTHROPIC_API_KEY into container if set\n    52тЖТ\tif key := os.Getenv(\"ANTHROPIC_API_KEY\"); key != \"\" {\n    53тЖТ\t\targs = append(args, \