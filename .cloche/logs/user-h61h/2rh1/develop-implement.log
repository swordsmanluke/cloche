{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014iQiJr8ujhLkbGHyUtvrfu","type":"tool_result","content":"     1тЖТpackage protocol\n     2тЖТ\n     3тЖТimport (\n     4тЖТ\t\"bytes\"\n     5тЖТ\t\"encoding/json\"\n     6тЖТ\t\"fmt\"\n     7тЖТ\t\"io\"\n     8тЖТ\t\"time\"\n     9тЖТ)\n    10тЖТ\n    11тЖТtype MessageType string\n    12тЖТ\n    13тЖТconst (\n    14тЖТ\tMsgStepStarted  MessageType = \"step_started\"\n    15тЖТ\tMsgStepCompleted MessageType = \"step_completed\"\n    16тЖТ\tMsgRunCompleted  MessageType = \"run_completed\"\n    17тЖТ\tMsgRunTitle      MessageType = \"run_title\"\n    18тЖТ\tMsgLog           MessageType = \"log\"\n    19тЖТ\tMsgError         MessageType = \"error\"\n    20тЖТ)\n    21тЖТ\n    22тЖТtype StatusMessage struct {\n    23тЖТ\tType      MessageType `json:\"type\"`\n    24тЖТ\tStepName  string      `json:\"step_name,omitempty\"`\n    25тЖТ\tResult    string      `json:\"result,omitempty\"`\n    26тЖТ\tMessage   string      `json:\"message,omitempty\"`\n    27тЖТ\tTimestamp time.Time   `json:\"timestamp\"`\n    28тЖТ}\n    29тЖТ\n    30тЖТ// flusher is an optional interface for writers that support explicit flushing.\n    31тЖТtype flusher interface {\n    32тЖТ\tFlush() error\n    33тЖТ}\n    34тЖТ\n    35тЖТtype StatusWriter struct {\n    36тЖТ\tw   io.Writer\n    37тЖТ\tenc *json.Encoder\n    38тЖТ}\n    39тЖТ\n    40тЖТfunc NewStatusWriter(w io.Writer) *StatusWriter {\n    41тЖТ\treturn &StatusWriter{w: w, enc: json.NewEncoder(w)}\n    42тЖТ}\n    43тЖТ\n    44тЖТfunc (s *StatusWriter) StepStarted(stepName string) {\n    45тЖТ\ts.write(StatusMessage{Type: MsgStepStarted, StepName: stepName})\n    46тЖТ}\n    47тЖТ\n    48тЖТfunc (s *StatusWriter) StepCompleted(stepName, result string) {\n    49тЖТ\ts.write(StatusMessage{Type: MsgStepCompleted, StepName: stepName, Result: result})\n    50тЖТ}\n    51тЖТ\n    52тЖТfunc (s *StatusWriter) RunCompleted(result string) {\n    53тЖТ\ts.write(StatusMessage{Type: MsgRunCompleted, Result: result})\n    54тЖТ}\n    55тЖТ\n    56тЖТfunc (s *StatusWriter) RunTitle(title string) {\n    57тЖТ\ts.write(StatusMessage{Type: MsgRunTitle, Message: title})\n    58тЖТ}\n    59тЖТ\n    60тЖТfunc (s *StatusWriter) Log(stepName, message string) {\n    61тЖТ\ts.write(StatusMessage{Type: MsgLog, StepName: stepName, Message: message})\n    62тЖТ}\n    63тЖТ\n    64тЖТfunc (s *StatusWriter) Error(stepName, message string) {\n    65тЖТ\ts.write(StatusMessage{Type: MsgError, StepName: stepName, Message: message})\n    66тЖТ}\n    67тЖТ\n    68тЖТfunc (s *StatusWriter) write(msg StatusMessage) {\n    69тЖТ\tmsg.Timestamp = time.Now()\n    70тЖТ\t_ = s.enc.Encode(msg)\n    71тЖТ\t// Flush the underlying writer if it supports it, to ensure real-time delivery.\n    72тЖТ\tif f, ok := s.w.(flusher); ok {\n    73тЖТ\t\t_ = f.Flush()\n    74тЖТ\t}\n    75тЖТ}\n    76тЖТ\n    77тЖТfunc ParseStatusStream(data []byte) ([]StatusMessage, error) {\n    78тЖТ\tvar msgs []StatusMessage\n    79тЖТ\tdec := json.NewDecoder(bytes.NewReader(data))\n    80тЖТ\tfor dec.More() {\n    81тЖТ\t\tvar msg StatusMessage\n    82тЖТ\t\tif err := dec.Decode(&msg); err != nil {\n    83тЖТ\t\t\treturn msgs, fmt.Errorf(\"failed to decode status message: %w\", err)\n    84тЖТ\t\t}\n    85тЖТ\t\tmsgs = append(msgs, msg)\n    86тЖТ\t}\n    87тЖТ\treturn msgs, nil\n    88тЖТ}\n    89тЖТ"}]},"parent_tool_use_id":"toolu_01VgKT2HRKQWwdGh23Lxewca","session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"500c5fc2-367c-40f7-a938-d3eb0f554285"}
