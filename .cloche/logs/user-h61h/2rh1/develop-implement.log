{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FGRp9M2XNFTg1UvpUzJYeP","type":"tool_result","content":"     1тЖТpackage main\n     2тЖТ\n     3тЖТimport (\n     4тЖТ\t\"bufio\"\n     5тЖТ\t\"context\"\n     6тЖТ\t\"encoding/json\"\n     7тЖТ\t\"errors\"\n     8тЖТ\t\"fmt\"\n     9тЖТ\t\"io\"\n    10тЖТ\t\"net/http\"\n    11тЖТ\t\"os\"\n    12тЖТ\t\"path/filepath\"\n    13тЖТ\t\"strings\"\n    14тЖТ\t\"time\"\n    15тЖТ\n    16тЖТ\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17тЖТ\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    18тЖТ\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    19тЖТ\t\"google.golang.org/grpc\"\n    20тЖТ\t\"google.golang.org/grpc/credentials/insecure\"\n    21тЖТ)\n    22тЖТ\n    23тЖТfunc main() {\n    24тЖТ\tif len(os.Args) < 2 {\n    25тЖТ\t\tusage()\n    26тЖТ\t\tos.Exit(1)\n    27тЖТ\t}\n    28тЖТ\n    29тЖТ\t// Commands that don't need a daemon connection\n    30тЖТ\tswitch os.Args[1] {\n    31тЖТ\tcase \"init\":\n    32тЖТ\t\tcmdInit(os.Args[2:])\n    33тЖТ\t\treturn\n    34тЖТ\tcase \"health\":\n    35тЖТ\t\tcmdHealth(os.Args[2:])\n    36тЖТ\t\treturn\n    37тЖТ\t}\n    38тЖТ\n    39тЖТ\t// Commands that need a daemon connection\n    40тЖТ\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    41тЖТ\tif addr == \"\" {\n    42тЖТ\t\taddr = \"unix:///tmp/cloche.sock\"\n    43тЖТ\t}\n    44тЖТ\n    45тЖТ\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n    46тЖТ\tif err != nil {\n    47тЖТ\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n    48тЖТ\t\tos.Exit(1)\n    49тЖТ\t}\n    50тЖТ\tdefer conn.Close()\n    51тЖТ\n    52тЖТ\tclient := pb.NewClocheServiceClient(conn)\n    53тЖТ\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n    54тЖТ\tdefer cancel()\n    55тЖТ\n    56тЖТ\tswitch os.Args[1] {\n    57тЖТ\tcase \"run\":\n    58тЖТ\t\tcmdRun(ctx, client, os.Args[2:])\n    59тЖТ\tcase \"status\":\n    60тЖТ\t\tcmdStatus(ctx, client, os.Args[2:])\n    61тЖТ\tcase \"logs\":\n    62тЖТ\t\tcmdLogs(client, os.Args[2:])\n    63тЖТ\tcase \"poll\":\n    64тЖТ\t\tcmdPoll(client, os.Args[2:])\n    65тЖТ\tcase \"list\":\n    66тЖТ\t\tcmdList(ctx, client, os.Args[2:])\n    67тЖТ\tcase \"stop\":\n    68тЖТ\t\tcmdStop(ctx, client, os.Args[2:])\n    69тЖТ\tcase \"delete\":\n    70тЖТ\t\tcmdDelete(ctx, client, os.Args[2:])\n    71тЖТ\tcase \"loop\":\n    72тЖТ\t\tcmdLoop(ctx, client, os.Args[2:])\n    73тЖТ\tcase \"shutdown\":\n    74тЖТ\t\tcmdShutdown(ctx, client)\n    75тЖТ\tdefault:\n    76тЖТ\t\tusage()\n    77тЖТ\t\tos.Exit(1)\n    78тЖТ\t}\n    79тЖТ}\n    80тЖТ\n    81тЖТfunc usage() {\n    82тЖТ\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n    83тЖТ\n    84тЖТCommands:\n    85тЖТ  init [--workflow <name>] [--base-image <image>]\n    86тЖТ                                             Initialize a Cloche project\n    87тЖТ  health                                   Show project health summary\n    88тЖТ  run --workflow <name> [--prompt \"...\"] [--title \"...\"] [--keep-container]\n    89тЖТ                                             Launch a workflow run\n    90тЖТ  status <run-id>                            Check run status\n    91тЖТ  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n    92тЖТ                                             Show logs for a run\n    93тЖТ  poll <run-id>                              Wait for a run to finish\n    94тЖТ  list [--all]                                List runs (last hour by default)\n    95тЖТ  stop <run-id>                              Stop a running workflow\n    96тЖТ  delete <container-or-run-id>               Delete a retained container\n    97тЖТ  loop [--max <n>]                            Start orchestration loop (default max=1)\n    98тЖТ  loop stop                                  Stop orchestration loop\n    99тЖТ  shutdown                                   Shut down the daemon\n   100тЖТ`)\n   101тЖТ}\n   102тЖТ\n   103тЖТfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   104тЖТ\tvar workflow, prompt, title string\n   105тЖТ\tvar keepContainer bool\n   106тЖТ\n   107тЖТ\tfor i := 0; i < len(args); i++ {\n   108тЖТ\t\tswitch args[i] {\n   109тЖТ\t\tcase \"--workflow\":\n   110тЖТ\t\t\tif i+1 < len(args) {\n   111тЖТ\t\t\t\ti++\n   112тЖТ\t\t\t\tworkflow = args[i]\n   113тЖТ\t\t\t}\n   114тЖТ\t\tcase \"--prompt\", \"-p\":\n   115тЖТ\t\t\tif i+1 < len(args) {\n   116тЖТ\t\t\t\ti++\n   117тЖТ\t\t\t\tprompt = args[i]\n   118тЖТ\t\t\t}\n   119тЖТ\t\tcase \"--title\":\n   120тЖТ\t\t\tif i+1 < len(args) {\n   121тЖТ\t\t\t\ti++\n   122тЖТ\t\t\t\ttitle = args[i]\n   123тЖТ\t\t\t}\n   124тЖТ\t\tcase \"--keep-container\":\n   125тЖТ\t\t\tkeepContainer = true\n   126тЖТ\t\tdefault:\n   127тЖТ\t\t\t// Support bare positional arg as workflow name for backwards compat\n   128тЖТ\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   129тЖТ\t\t\t\tworkflow = args[i]\n   130тЖТ\t\t\t}\n   131тЖТ\t\t}\n   132тЖТ\t}\n   133тЖТ\n   134тЖТ\tif workflow == \"\" {\n   135тЖТ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   136тЖТ\t\tos.Exit(1)\n   137тЖТ\t}\n   138тЖТ\n   139тЖТ\tcwd, _ := os.Getwd()\n   140тЖТ\n   141тЖТ\t// Resolve image from workflow file (soft failure тАФ fall back to daemon default)\n   142тЖТ\tvar image string\n   143тЖТ\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   144тЖТ\tif data, err := os.ReadFile(wfPath); err == nil {\n   145тЖТ\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   146тЖТ\t\t\timage = wf.Config[\"container.image\"]\n   147тЖТ\t\t}\n   148тЖТ\t}\n   149тЖТ\n   150тЖТ\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   151тЖТ\t\tWorkflowName:  workflow,\n   152тЖТ\t\tProjectDir:    cwd,\n   153тЖТ\t\tImage:         image,\n   154тЖТ\t\tPrompt:        prompt,\n   155тЖТ\t\tKeepContainer: keepContainer,\n   156тЖТ\t\tTitle:         title,\n   157тЖТ\t})\n   158тЖТ\tif err != nil {\n   159тЖТ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   160тЖТ\t\tos.Exit(1)\n   161тЖТ\t}\n   162тЖТ\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   163тЖТ}\n   164тЖТ\n   165тЖТfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   166тЖТ\tif len(args) < 1 {\n   167тЖТ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   168тЖТ\t\tos.Exit(1)\n   169тЖТ\t}\n   170тЖТ\n   171тЖТ\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   172тЖТ\tif err != nil {\n   173тЖТ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   174тЖТ\t\tos.Exit(1)\n   175тЖТ\t}\n   176тЖТ\n   177тЖТ\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   178тЖТ\tif resp.Title != \"\" {\n   179тЖТ\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   180тЖТ\t}\n   181тЖТ\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   182тЖТ\tif resp.IsHost {\n   183тЖТ\t\tfmt.Printf(\"Type:      host\\n\")\n   184тЖТ\t} else {\n   185тЖТ\t\tfmt.Printf(\"Type:      container\\n\")\n   186тЖТ\t}\n   187тЖТ\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   188тЖТ\tif resp.ContainerId != \"\" {\n   189тЖТ\t\tcid := resp.ContainerId\n   190тЖТ\t\tif len(cid) > 12 {\n   191тЖТ\t\t\tcid = cid[:12]\n   192тЖТ\t\t}\n   193тЖТ\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   194тЖТ\t}\n   195тЖТ\tif resp.ErrorMessage != \"\" {\n   196тЖТ\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   197тЖТ\t}\n   198тЖТ\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   199тЖТ\tfor _, exec := range resp.StepExecutions {\n   200тЖТ\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   201тЖТ\t}\n   202тЖТ}\n   203тЖТ\n   204тЖТfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   205тЖТ\tvar all bool\n   206тЖТ\tfor _, arg := range args {\n   207тЖТ\t\tif arg == \"--all\" {\n   208тЖТ\t\t\tall = true\n   209тЖТ\t\t}\n   210тЖТ\t}\n   211тЖТ\n   212тЖТ\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n   213тЖТ\tif err != nil {\n   214тЖТ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   215тЖТ\t\tos.Exit(1)\n   216тЖТ\t}\n   217тЖТ\n   218тЖТ\tif len(resp.Runs) == 0 {\n   219тЖТ\t\tfmt.Println(\"No runs found.\")\n   220тЖТ\t\treturn\n   221тЖТ\t}\n   222тЖТ\n   223тЖТ\tfor _, run := range resp.Runs {\n   224тЖТ\t\trunType := \"container\"\n   225тЖТ\t\tif run.IsHost {\n   226тЖТ\t\t\trunType = \"host\"\n   227тЖТ\t\t}\n   228тЖТ\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   229тЖТ\t\tif run.Title != \"\" {\n   230тЖТ\t\t\tt := run.Title\n   231тЖТ\t\t\tif len(t) > 40 {\n   232тЖТ\t\t\t\tt = t[:37] + \"...\"\n   233тЖТ\t\t\t}\n   234тЖТ\t\t\tline += \"  \" + t\n   235тЖТ\t\t}\n   236тЖТ\t\tif run.ContainerId != \"\" {\n   237тЖТ\t\t\tline += \"  \" + run.ContainerId\n   238тЖТ\t\t}\n   239тЖТ\t\tif run.ErrorMessage != \"\" {\n   240тЖТ\t\t\terrMsg := run.ErrorMessage\n   241тЖТ\t\t\tif len(errMsg) > 60 {\n   242тЖТ\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   243тЖТ\t\t\t}\n   244тЖТ\t\t\tline += \"  \" + errMsg\n   245тЖТ\t\t}\n   246тЖТ\t\tfmt.Println(line)\n   247тЖТ\t}\n   248тЖТ}\n   249тЖТ\n   250тЖТfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n   251тЖТ\tif len(args) < 1 {\n   252тЖТ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n   253тЖТ\t\tos.Exit(1)\n   254тЖТ\t}\n   255тЖТ\n   256тЖТ\tvar stepFilter, typeFilter string\n   257тЖТ\tvar follow bool\n   258тЖТ\trunID := args[0]\n   259тЖТ\n   260тЖТ\tfor i := 1; i < len(args); i++ {\n   261тЖТ\t\tswitch args[i] {\n   262тЖТ\t\tcase \"--step\":\n   263тЖТ\t\t\tif i+1 < len(args) {\n   264тЖТ\t\t\t\ti++\n   265тЖТ\t\t\t\tstepFilter = args[i]\n   266тЖТ\t\t\t}\n   267тЖТ\t\tcase \"--type\":\n   268тЖТ\t\t\tif i+1 < len(args) {\n   269тЖТ\t\t\t\ti++\n   270тЖТ\t\t\t\ttypeFilter = args[i]\n   271тЖТ\t\t\t}\n   272тЖТ\t\tcase \"--follow\", \"-f\":\n   273тЖТ\t\t\tfollow = true\n   274тЖТ\t\t}\n   275тЖТ\t}\n   276тЖТ\n   277тЖТ\tif follow {\n   278тЖТ\t\tcmdLogsFollow(runID)\n   279тЖТ\t\treturn\n   280тЖТ\t}\n   281тЖТ\n   282тЖТ\t// Use background context тАФ log output can be large\n   283тЖТ\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n   284тЖТ\t\tRunId:    runID,\n   285тЖТ\t\tStepName: stepFilter,\n   286тЖТ\t\tLogType:  typeFilter,\n   287тЖТ\t})\n   288тЖТ\tif err != nil {\n   289тЖТ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   290тЖТ\t\tos.Exit(1)\n   291тЖТ\t}\n   292тЖТ\n   293тЖТ\tfor {\n   294тЖТ\t\tentry, err := stream.Recv()\n   295тЖТ\t\tif err != nil {\n   296тЖТ\t\t\tif errors.Is(err, io.EOF) {\n   297тЖТ\t\t\t\tbreak\n   298тЖТ\t\t\t}\n   299тЖТ\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   300тЖТ\t\t\tos.Exit(1)\n   301тЖТ\t\t}\n   302тЖТ\n   303тЖТ\t\tswitch entry.Type {\n   304тЖТ\t\tcase \"step_started\":\n   305тЖТ\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   306тЖТ\t\t\tif entry.Message != \"\" {\n   307тЖТ\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   308тЖТ\t\t\t}\n   309тЖТ\t\tcase \"step_completed\":\n   310тЖТ\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   311тЖТ\t\t\tif entry.Message != \"\" {\n   312тЖТ\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   313тЖТ\t\t\t}\n   314тЖТ\t\tcase \"run_completed\":\n   315тЖТ\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   316тЖТ\t\t\tif entry.Message != \"\" {\n   317тЖТ\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   318тЖТ\t\t\t}\n   319тЖТ\t\tcase \"full_log\":\n   320тЖТ\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   321тЖТ\t\tcase \"log\":\n   322тЖТ\t\t\t// Live-streamed log line from an active run.\n   323тЖТ\t\t\tfmt.Println(entry.Message)\n   324тЖТ\t\tdefault:\n   325тЖТ\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   326тЖТ\t\t\tif entry.StepName != \"\" {\n   327тЖТ\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   328тЖТ\t\t\t}\n   329тЖТ\t\t\tif entry.Message != \"\" {\n   330тЖТ\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   331тЖТ\t\t\t}\n   332тЖТ\t\t}\n   333тЖТ\t}\n   334тЖТ}\n   335тЖТ\n   336тЖТfunc cmdLogsFollow(runID string) {\n   337тЖТ\t// Determine HTTP address from env\n   338тЖТ\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   339тЖТ\tif httpAddr == \"\" {\n   340тЖТ\t\thttpAddr = \"localhost:8080\"\n   341тЖТ\t}\n   342тЖТ\t// Strip protocol prefix if present\n   343тЖТ\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   344тЖТ\n   345тЖТ\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n   346тЖТ\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n   347тЖТ\tif err != nil {\n   348тЖТ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   349тЖТ\t\tos.Exit(1)\n   350тЖТ\t}\n   351тЖТ\treq.Header.Set(\"Accept\", \"text/event-stream\")\n   352тЖТ\n   353тЖТ\tresp, err := http.DefaultClient.Do(req)\n   354тЖТ\tif err != nil {\n   355тЖТ\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n   356тЖТ\t\tos.Exit(1)\n   357тЖТ\t}\n   358тЖТ\tdefer resp.Body.Close()\n   359тЖТ\n   360тЖТ\tif resp.StatusCode != 200 {\n   361тЖТ\t\tbody, _ := io.ReadAll(resp.Body)\n   362тЖТ\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   363тЖТ\t\tos.Exit(1)\n   364тЖТ\t}\n   365тЖТ\n   366тЖТ\tscanner := bufio.NewScanner(resp.Body)\n   367тЖТ\tfor scanner.Scan() {\n   368тЖТ\t\tline := scanner.Text()\n   369тЖТ\t\tif strings.HasPrefix(line, \"event: done\") {\n   370тЖТ\t\t\tbreak\n   371тЖТ\t\t}\n   372тЖТ\t\tif !strings.HasPrefix(line, \"data: \") {\n   373тЖТ\t\t\tcontinue\n   374тЖТ\t\t}\n   375тЖТ\t\tdata := strings.TrimPrefix(line, \"data: \")\n   376тЖТ\n   377тЖТ\t\tvar entry struct {\n   378тЖТ\t\t\tTimestamp string `json:\"timestamp\"`\n   379тЖТ\t\t\tType      string `json:\"type\"`\n   380тЖТ\t\t\tContent   string `json:\"content\"`\n   381тЖТ\t\t}\n   382тЖТ\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n   383тЖТ\t\t\tcontinue\n   384тЖТ\t\t}\n   385тЖТ\n   386тЖТ\t\t// Color-code by type\n   387тЖТ\t\tswitch entry.Type {\n   388тЖТ\t\tcase \"status\":\n   389тЖТ\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   390тЖТ\t\tcase \"llm\":\n   391тЖТ\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   392тЖТ\t\tdefault:\n   393тЖТ\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n   394тЖТ\t\t}\n   395тЖТ\t}\n   396тЖТ}\n   397тЖТ\n   398тЖТfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   399тЖТ\tif len(args) < 1 {\n   400тЖТ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   401тЖТ\t\tos.Exit(1)\n   402тЖТ\t}\n   403тЖТ\n   404тЖТ\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   405тЖТ\tif err != nil {\n   406тЖТ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   407тЖТ\t\tos.Exit(1)\n   408тЖТ\t}\n   409тЖТ\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   410тЖТ}\n   411тЖТ\n   412тЖТfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   413тЖТ\tif len(args) < 1 {\n   414тЖТ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   415тЖТ\t\tos.Exit(1)\n   416тЖТ\t}\n   417тЖТ\n   418тЖТ\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   419тЖТ\tif err != nil {\n   420тЖТ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   421тЖТ\t\tos.Exit(1)\n   422тЖТ\t}\n   423тЖТ\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   424тЖТ}\n   425тЖТ\n   426тЖТfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   427тЖТ\tcwd, _ := os.Getwd()\n   428тЖТ\n   429тЖТ\t// Check for \"stop\" subcommand\n   430тЖТ\tif len(args) > 0 && args[0] == \"stop\" {\n   431тЖТ\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   432тЖТ\t\tif err != nil {\n   433тЖТ\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   434тЖТ\t\t\tos.Exit(1)\n   435тЖТ\t\t}\n   436тЖТ\t\tfmt.Println(\"Orchestration loop stopped.\")\n   437тЖТ\t\treturn\n   438тЖТ\t}\n   439тЖТ\n   440тЖТ\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   441тЖТ\tvar maxConcurrent int32\n   442тЖТ\tfor i := 0; i < len(args); i++ {\n   443тЖТ\t\tswitch args[i] {\n   444тЖТ\t\tcase \"--max\":\n   445тЖТ\t\t\tif i+1 < len(args) {\n   446тЖТ\t\t\t\ti++\n   447тЖТ\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   448тЖТ\t\t\t\tif n != 1 || err != nil {\n   449тЖТ\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   450тЖТ\t\t\t\t\tos.Exit(1)\n   451тЖТ\t\t\t\t}\n   452тЖТ\t\t\t}\n   453тЖТ\t\t}\n   454тЖТ\t}\n   455тЖТ\n   456тЖТ\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   457тЖТ\t\tProjectDir:    cwd,\n   458тЖТ\t\tMaxConcurrent: maxConcurrent,\n   459тЖТ\t})\n   460тЖТ\tif err != nil {\n   461тЖТ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   462тЖТ\t\tos.Exit(1)\n   463тЖТ\t}\n   464тЖТ\tif maxConcurrent > 0 {\n   465тЖТ\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   466тЖТ\t} else {\n   467тЖТ\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   468тЖТ\t}\n   469тЖТ}\n   470тЖТ\n   471тЖТfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   472тЖТ\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   473тЖТ\tif err != nil {\n   474тЖТ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   475тЖТ\t\tos.Exit(1)\n   476тЖТ\t}\n   477тЖТ\tfmt.Println(\"Daemon shutting down.\")\n   478тЖТ}\n   479тЖТ"}]},"parent_tool_use_id":null,"session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"ecbacf1c-2237-49e0-9a91-0ca2b4ac96c3","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client)\n\tdefault:\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n}\n\nfunc usage() {\n\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n\nCommands:\n  init [--workflow <name>] [--base-image <image>]\n                                             Initialize a Cloche project\n  health                                   Show project health summary\n  run --workflow <name> [--prompt \"...\"] [--title \"...\"] [--keep-container]\n                                             Launch a workflow run\n  status <run-id>                            Check run status\n  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n                                             Show logs for a run\n  poll <run-id>                              Wait for a run to finish\n  list [--all]                                List runs (last hour by default)\n  stop <run-id>                              Stop a running workflow\n  delete <container-or-run-id>               Delete a retained container\n  loop [--max <n>]                            Start orchestration loop (default max=1)\n  loop stop                                  Stop orchestration loop\n  shutdown                                   Shut down the daemon\n`)\n}\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure тАФ fall back to daemon default)\n\tvar image string\n\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n\tif data, err := os.ReadFile(wfPath); err == nil {\n\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n\t\t\timage = wf.Config[\"container.image\"]\n\t\t}\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t}\n\t}\n\n\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n\t\tif run.Title != \"\" {\n\t\t\tt := run.Title\n\t\t\tif len(t) > 40 {\n\t\t\t\tt = t[:37] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + t\n\t\t}\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\t}\n\t}\n\n\tif follow {\n\t\tcmdLogsFollow(runID)\n\t\treturn\n\t}\n\n\t// Use background context тАФ log output can be large\n\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdLogsFollow(runID string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\t// Strip protocol prefix if present\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\treq.Header.Set(\"Accept\", \"text/event-stream\")\n\n\tresp, err := http.DefaultClient.Do(req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\tscanner := bufio.NewScanner(resp.Body)\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"event: done\") {\n\t\t\tbreak\n\t\t}\n\t\tif !strings.HasPrefix(line, \"data: \") {\n\t\t\tcontinue\n\t\t}\n\t\tdata := strings.TrimPrefix(line, \"data: \")\n\n\t\tvar entry struct {\n\t\t\tTimestamp string `json:\"timestamp\"`\n\t\t\tType      string `json:\"type\"`\n\t\t\tContent   string `json:\"content\"`\n\t\t}\n\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Color-code by type\n\t\tswitch entry.Type {\n\t\tcase \"status\":\n\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tcase \"llm\":\n\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tdefault:\n\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n","numLines":479,"startLine":1,"totalLines":479}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01X3MYcRUwaSxh3Vu8cksDf3","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01B3rouXqZY4RarQnsrSJPVZ","name":"Read","input":{"file_path":"/workspace/internal/host/executor.go"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":9011,"cache_read_input_tokens":14377,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":9011},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"7e8ab360-d1b0-46e9-8341-a0be0a9abbe5"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B3rouXqZY4RarQnsrSJPVZ","type":"tool_result","content":"     1тЖТpackage host\n     2тЖТ\n     3тЖТimport (\n     4тЖТ\t\"context\"\n     5тЖТ\t\"fmt\"\n     6тЖТ\t\"log\"\n     7тЖТ\t\"os\"\n     8тЖТ\t\"os/exec\"\n     9тЖТ\t\"path/filepath\"\n    10тЖТ\t\"strings\"\n    11тЖТ\t\"time\"\n    12тЖТ\n    13тЖТ\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14тЖТ\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    15тЖТ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16тЖТ\t\"github.com/cloche-dev/cloche/internal/engine\"\n    17тЖТ\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18тЖТ\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    19тЖТ)\n    20тЖТ\n    21тЖТ// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    22тЖТ// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    23тЖТ// strings suitable for adding to a command's environment.\n    24тЖТfunc (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    25тЖТ\tvar env []string\n    26тЖТ\tfor _, w := range wires {\n    27тЖТ\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    28тЖТ\t\t\tcontinue\n    29тЖТ\t\t}\n    30тЖТ\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    31тЖТ\t\tif err != nil {\n    32тЖТ\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    33тЖТ\t\t}\n    34тЖТ\t\tfor _, m := range w.OutputMap {\n    35тЖТ\t\t\tval, err := m.Path.Evaluate(data)\n    36тЖТ\t\t\tif err != nil {\n    37тЖТ\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    38тЖТ\t\t\t}\n    39тЖТ\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    40тЖТ\t\t}\n    41тЖТ\t}\n    42тЖТ\treturn env, nil\n    43тЖТ}\n    44тЖТ\n    45тЖТ// RunDispatcher dispatches a container workflow run and returns the run ID.\n    46тЖТtype RunDispatcher interface {\n    47тЖТ\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    48тЖТ}\n    49тЖТ\n    50тЖТ// Executor implements engine.StepExecutor for host workflow steps.\n    51тЖТtype Executor struct {\n    52тЖТ\tProjectDir    string\n    53тЖТ\tMainDir       string         // main branch worktree dir; scripts execute from here\n    54тЖТ\tDispatcher    RunDispatcher\n    55тЖТ\tStore         ports.RunStore\n    56тЖТ\tOutputDir     string         // directory for step output files\n    57тЖТ\tWires         []domain.Wire  // workflow wiring (for output mappings)\n    58тЖТ\tHostRunID     string         // ID of the parent host run (set on child runs)\n    59тЖТ\tAgentCommands []string       // workflow-level agent command fallback chain\n    60тЖТ\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n    61тЖТ\tTaskID        string         // optional task ID assigned by the daemon loop\n    62тЖТ\tExtraEnv      []string       // additional KEY=VALUE env vars for all steps\n    63тЖТ}\n    64тЖТ\n    65тЖТ// scriptDir returns the directory from which scripts should execute.\n    66тЖТ// Uses MainDir if set, otherwise falls back to ProjectDir.\n    67тЖТfunc (e *Executor) scriptDir() string {\n    68тЖТ\tif e.MainDir != \"\" {\n    69тЖТ\t\treturn e.MainDir\n    70тЖТ\t}\n    71тЖТ\treturn e.ProjectDir\n    72тЖТ}\n    73тЖТ\n    74тЖТvar _ engine.StepExecutor = (*Executor)(nil)\n    75тЖТ\n    76тЖТ// Execute runs a single host workflow step.\n    77тЖТfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    78тЖТ\tswitch step.Type {\n    79тЖТ\tcase domain.StepTypeScript:\n    80тЖТ\t\treturn e.executeScript(ctx, step)\n    81тЖТ\tcase domain.StepTypeWorkflow:\n    82тЖТ\t\treturn e.executeWorkflow(ctx, step)\n    83тЖТ\tcase domain.StepTypeAgent:\n    84тЖТ\t\treturn e.executeAgent(ctx, step)\n    85тЖТ\tdefault:\n    86тЖТ\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    87тЖТ\t}\n    88тЖТ}\n    89тЖТ\n    90тЖТ// executeScript runs a shell command on the host.\n    91тЖТfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    92тЖТ\tcmdStr := step.Config[\"run\"]\n    93тЖТ\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    94тЖТ\tcmd.Dir = e.scriptDir()\n    95тЖТ\tcmd.Env = append(os.Environ(),\n    96тЖТ\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    97тЖТ\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    98тЖТ\t)\n    99тЖТ\n   100тЖТ\t// Pass daemon-assigned task ID if available\n   101тЖТ\tif e.TaskID != \"\" {\n   102тЖТ\t\tcmd.Env = append(cmd.Env, \"CLOCHE_TASK_ID=\"+e.TaskID)\n   103тЖТ\t}\n   104тЖТ\n   105тЖТ\t// Pass extra env vars (e.g. finalize phase outcome vars)\n   106тЖТ\tif len(e.ExtraEnv) > 0 {\n   107тЖТ\t\tcmd.Env = append(cmd.Env, e.ExtraEnv...)\n   108тЖТ\t}\n   109тЖТ\n   110тЖТ\t// Pass previous step output if available\n   111тЖТ\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n   112тЖТ\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n   113тЖТ\t}\n   114тЖТ\n   115тЖТ\t// Resolve output mappings from wires and add as env vars\n   116тЖТ\tif len(e.Wires) > 0 {\n   117тЖТ\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n   118тЖТ\t\tif err != nil {\n   119тЖТ\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n   120тЖТ\t\t}\n   121тЖТ\t\tcmd.Env = append(cmd.Env, mapped...)\n   122тЖТ\t}\n   123тЖТ\n   124тЖТ\toutput, err := cmd.CombinedOutput()\n   125тЖТ\n   126тЖТ\t// Extract result marker\n   127тЖТ\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n   128тЖТ\n   129тЖТ\t// Write output to file\n   130тЖТ\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   131тЖТ\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   132тЖТ\t}\n   133тЖТ\n   134тЖТ\tif err != nil {\n   135тЖТ\t\tif _, ok := err.(*exec.ExitError); ok {\n   136тЖТ\t\t\tresult := \"fail\"\n   137тЖТ\t\t\tif found {\n   138тЖТ\t\t\t\tresult = markerResult\n   139тЖТ\t\t\t}\n   140тЖТ\t\t\treturn result, nil\n   141тЖТ\t\t}\n   142тЖТ\t\treturn \"\", err\n   143тЖТ\t}\n   144тЖТ\n   145тЖТ\tresult := \"success\"\n   146тЖТ\tif found {\n   147тЖТ\t\tresult = markerResult\n   148тЖТ\t}\n   149тЖТ\treturn result, nil\n   150тЖТ}\n   151тЖТ\n   152тЖТ// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   153тЖТfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   154тЖТ\tworkflowName := step.Config[\"workflow_name\"]\n   155тЖТ\tif workflowName == \"\" {\n   156тЖТ\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   157тЖТ\t}\n   158тЖТ\n   159тЖТ\t// Read prompt from previous step output or prompt_step override\n   160тЖТ\tvar promptContent string\n   161тЖТ\tpromptSource := step.Config[\"prompt_step\"]\n   162тЖТ\tif promptSource != \"\" {\n   163тЖТ\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   164тЖТ\t\tif err == nil {\n   165тЖТ\t\t\tpromptContent = string(data)\n   166тЖТ\t\t}\n   167тЖТ\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   168тЖТ\t\tdata, err := os.ReadFile(prev)\n   169тЖТ\t\tif err == nil {\n   170тЖТ\t\t\tpromptContent = string(data)\n   171тЖТ\t\t}\n   172тЖТ\t}\n   173тЖТ\n   174тЖТ\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   175тЖТ\t\tWorkflowName: workflowName,\n   176тЖТ\t\tProjectDir:   e.ProjectDir,\n   177тЖТ\t\tPrompt:       promptContent,\n   178тЖТ\t})\n   179тЖТ\tif err != nil {\n   180тЖТ\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   181тЖТ\t}\n   182тЖТ\n   183тЖТ\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   184тЖТ\n   185тЖТ\t// Link child run to parent host run\n   186тЖТ\tif e.HostRunID != \"\" {\n   187тЖТ\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n   188тЖТ\t\t\tchildRun.ParentRunID = e.HostRunID\n   189тЖТ\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n   190тЖТ\t\t}\n   191тЖТ\t}\n   192тЖТ\n   193тЖТ\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n   194тЖТ\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   195тЖТ\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n   196тЖТ\t}\n   197тЖТ\n   198тЖТ\t// Poll until the run reaches a terminal state\n   199тЖТ\tstate, err := e.waitForRun(ctx, resp.RunId)\n   200тЖТ\tif err != nil {\n   201тЖТ\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   202тЖТ\t}\n   203тЖТ\n   204тЖТ\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   205тЖТ\n   206тЖТ\t// Map run state to step result\n   207тЖТ\tif state == domain.RunStateSucceeded {\n   208тЖТ\t\treturn \"success\", nil\n   209тЖТ\t}\n   210тЖТ\treturn \"fail\", nil\n   211тЖТ}\n   212тЖТ\n   213тЖТ// executeAgent runs an agent command on the host using the prompt adapter.\n   214тЖТfunc (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n   215тЖТ\tadapter := prompt.New()\n   216тЖТ\n   217тЖТ\t// Apply workflow-level agent config\n   218тЖТ\tif len(e.AgentCommands) > 0 {\n   219тЖТ\t\tadapter.Commands = e.AgentCommands\n   220тЖТ\t}\n   221тЖТ\tif len(e.AgentArgs) > 0 {\n   222тЖТ\t\tadapter.ExplicitArgs = e.AgentArgs\n   223тЖТ\t}\n   224тЖТ\n   225тЖТ\t// Step-level overrides\n   226тЖТ\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   227тЖТ\t\tadapter.Commands = prompt.ParseCommands(cmd)\n   228тЖТ\t}\n   229тЖТ\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   230тЖТ\t\tadapter.ExplicitArgs = strings.Fields(args)\n   231тЖТ\t}\n   232тЖТ\n   233тЖТ\tadapter.RunID = e.HostRunID\n   234тЖТ\n   235тЖТ\t// Write previous step output as user prompt so the adapter can pick it up.\n   236тЖТ\tvar promptContent string\n   237тЖТ\tpromptSource := step.Config[\"prompt_step\"]\n   238тЖТ\tif promptSource != \"\" {\n   239тЖТ\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n   240тЖТ\t\t\tpromptContent = string(data)\n   241тЖТ\t\t}\n   242тЖТ\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   243тЖТ\t\tif data, err := os.ReadFile(prev); err == nil {\n   244тЖТ\t\t\tpromptContent = string(data)\n   245тЖТ\t\t}\n   246тЖТ\t}\n   247тЖТ\n   248тЖТ\tif promptContent != \"\" {\n   249тЖТ\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n   250тЖТ\t\t_ = os.MkdirAll(promptDir, 0755)\n   251тЖТ\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n   252тЖТ\t}\n   253тЖТ\n   254тЖТ\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n   255тЖТ\tif err != nil {\n   256тЖТ\t\treturn \"\", err\n   257тЖТ\t}\n   258тЖТ\n   259тЖТ\t// Copy output from adapter's output location to executor's output path\n   260тЖТ\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n   261тЖТ\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n   262тЖТ\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   263тЖТ\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n   264тЖТ\t\t}\n   265тЖТ\t}\n   266тЖТ\n   267тЖТ\treturn result, nil\n   268тЖТ}\n   269тЖТ\n   270тЖТ// waitForRun polls the store until the run reaches a terminal state.\n   271тЖТfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   272тЖТ\tticker := time.NewTicker(2 * time.Second)\n   273тЖТ\tdefer ticker.Stop()\n   274тЖТ\n   275тЖТ\tfor {\n   276тЖТ\t\tselect {\n   277тЖТ\t\tcase <-ctx.Done():\n   278тЖТ\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   279тЖТ\t\tcase <-ticker.C:\n   280тЖТ\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   281тЖТ\t\t\tif err != nil {\n   282тЖТ\t\t\t\tcontinue // transient error, retry\n   283тЖТ\t\t\t}\n   284тЖТ\t\t\tswitch run.State {\n   285тЖТ\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   286тЖТ\t\t\t\treturn run.State, nil\n   287тЖТ\t\t\t}\n   288тЖТ\t\t\t// Still pending or running, continue polling\n   289тЖТ\t\t}\n   290тЖТ\t}\n   291тЖТ}\n   292тЖТ\n   293тЖТ// stepOutputPath returns the path for a step's output file.\n   294тЖТfunc (e *Executor) stepOutputPath(stepName string) string {\n   295тЖТ\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   296тЖТ}\n   297тЖТ\n   298тЖТ// findPrevOutput finds the output file from the step that wires into this one.\n   299тЖТ// It checks prompt_step config first, then walks the wiring graph to find the\n   300тЖТ// source step.\n   301тЖТfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n   302тЖТ\t// Explicit prompt_step config takes priority\n   303тЖТ\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   304тЖТ\t\tpath := e.stepOutputPath(ps)\n   305тЖТ\t\tif _, err := os.Stat(path); err == nil {\n   306тЖТ\t\t\treturn path\n   307тЖТ\t\t}\n   308тЖТ\t}\n   309тЖТ\n   310тЖТ\t// Walk wiring to find the step that feeds into this one\n   311тЖТ\tfor _, w := range e.Wires {\n   312тЖТ\t\tif w.To == step.Name {\n   313тЖТ\t\t\tpath := e.stepOutputPath(w.From)\n   314тЖТ\t\t\tif _, err := os.Stat(path); err == nil {\n   315тЖТ\t\t\t\treturn path\n   316тЖТ\t\t\t}\n   317тЖТ\t\t}\n   318тЖТ\t}\n   319тЖТ\treturn \"\"\n   320тЖТ}\n   321тЖТ\n   322тЖТ// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n   323тЖТ// the repository containing projectDir. If projectDir is already the main\n   324тЖТ// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n   325тЖТ// error (e.g. not a git repo).\n   326тЖТfunc MainWorktreeDir(projectDir string) string {\n   327тЖТ\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n   328тЖТ\tout, err := cmd.Output()\n   329тЖТ\tif err != nil {\n   330тЖТ\t\treturn projectDir\n   331тЖТ\t}\n   332тЖТ\t// The first \"worktree <path>\" line is always the main worktree.\n   333тЖТ\tfor _, line := range strings.Split(string(out), \"\\n\") {\n   334тЖТ\t\tif strings.HasPrefix(line, \"worktree \") {\n   335тЖТ\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n   336тЖТ\t\t}\n   337тЖТ\t}\n   338тЖТ\treturn projectDir\n   339тЖТ}\n   340тЖТ"}]},"parent_tool_use_id":null,"session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"958edd1c-c258-49da-9ac0-f5326c58d28f","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\n// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n// reads the source step's output, evaluates each mapping path, and returns KEY=value\n// strings suitable for adding to a command's environment.\nfunc (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n\tvar env []string\n\tfor _, w := range wires {\n\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n\t\t}\n\t\tfor _, m := range w.OutputMap {\n\t\t\tval, err := m.Path.Evaluate(data)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n\t\t\t}\n\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n\t\t}\n\t}\n\treturn env, nil\n}\n\n// RunDispatcher dispatches a container workflow run and returns the run ID.\ntype RunDispatcher interface {\n\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n}\n\n// Executor implements engine.StepExecutor for host workflow steps.\ntype Executor struct {\n\tProjectDir    string\n\tMainDir       string         // main branch worktree dir; scripts execute from here\n\tDispatcher    RunDispatcher\n\tStore         ports.RunStore\n\tOutputDir     string         // directory for step output files\n\tWires         []domain.Wire  // workflow wiring (for output mappings)\n\tHostRunID     string         // ID of the parent host run (set on child runs)\n\tAgentCommands []string       // workflow-level agent command fallback chain\n\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n\tTaskID        string         // optional task ID assigned by the daemon loop\n\tExtraEnv      []string       // additional KEY=VALUE env vars for all steps\n}\n\n// scriptDir returns the directory from which scripts should execute.\n// Uses MainDir if set, otherwise falls back to ProjectDir.\nfunc (e *Executor) scriptDir() string {\n\tif e.MainDir != \"\" {\n\t\treturn e.MainDir\n\t}\n\treturn e.ProjectDir\n}\n\nvar _ engine.StepExecutor = (*Executor)(nil)\n\n// Execute runs a single host workflow step.\nfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\treturn e.executeScript(ctx, step)\n\tcase domain.StepTypeWorkflow:\n\t\treturn e.executeWorkflow(ctx, step)\n\tcase domain.StepTypeAgent:\n\t\treturn e.executeAgent(ctx, step)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n\t}\n}\n\n// executeScript runs a shell command on the host.\nfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n\tcmdStr := step.Config[\"run\"]\n\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n\tcmd.Dir = e.scriptDir()\n\tcmd.Env = append(os.Environ(),\n\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n\t)\n\n\t// Pass daemon-assigned task ID if available\n\tif e.TaskID != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_TASK_ID=\"+e.TaskID)\n\t}\n\n\t// Pass extra env vars (e.g. finalize phase outcome vars)\n\tif len(e.ExtraEnv) > 0 {\n\t\tcmd.Env = append(cmd.Env, e.ExtraEnv...)\n\t}\n\n\t// Pass previous step output if available\n\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n\t}\n\n\t// Resolve output mappings from wires and add as env vars\n\tif len(e.Wires) > 0 {\n\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n\t\t}\n\t\tcmd.Env = append(cmd.Env, mapped...)\n\t}\n\n\toutput, err := cmd.CombinedOutput()\n\n\t// Extract result marker\n\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n\n\t// Write output to file\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n\t}\n\n\tif err != nil {\n\t\tif _, ok := err.(*exec.ExitError); ok {\n\t\t\tresult := \"fail\"\n\t\t\tif found {\n\t\t\t\tresult = markerResult\n\t\t\t}\n\t\t\treturn result, nil\n\t\t}\n\t\treturn \"\", err\n\t}\n\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, nil\n}\n\n// executeWorkflow dispatches a container workflow run and blocks until it completes.\nfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n\tworkflowName := step.Config[\"workflow_name\"]\n\tif workflowName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n\t}\n\n\t// Read prompt from previous step output or prompt_step override\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tdata, err := os.ReadFile(prev)\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName: workflowName,\n\t\tProjectDir:   e.ProjectDir,\n\t\tPrompt:       promptContent,\n\t})\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n\t}\n\n\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n\n\t// Link child run to parent host run\n\tif e.HostRunID != \"\" {\n\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n\t\t\tchildRun.ParentRunID = e.HostRunID\n\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n\t\t}\n\t}\n\n\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n\t}\n\n\t// Poll until the run reaches a terminal state\n\tstate, err := e.waitForRun(ctx, resp.RunId)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n\t}\n\n\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n\n\t// Map run state to step result\n\tif state == domain.RunStateSucceeded {\n\t\treturn \"success\", nil\n\t}\n\treturn \"fail\", nil\n}\n\n// executeAgent runs an agent command on the host using the prompt adapter.\nfunc (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n\tadapter := prompt.New()\n\n\t// Apply workflow-level agent config\n\tif len(e.AgentCommands) > 0 {\n\t\tadapter.Commands = e.AgentCommands\n\t}\n\tif len(e.AgentArgs) > 0 {\n\t\tadapter.ExplicitArgs = e.AgentArgs\n\t}\n\n\t// Step-level overrides\n\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n\t\tadapter.Commands = prompt.ParseCommands(cmd)\n\t}\n\tif args := step.Config[\"agent_args\"]; args != \"\" {\n\t\tadapter.ExplicitArgs = strings.Fields(args)\n\t}\n\n\tadapter.RunID = e.HostRunID\n\n\t// Write previous step output as user prompt so the adapter can pick it up.\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tif data, err := os.ReadFile(prev); err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tif promptContent != \"\" {\n\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n\t\t_ = os.MkdirAll(promptDir, 0755)\n\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n\t}\n\n\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\t// Copy output from adapter's output location to executor's output path\n\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\n// waitForRun polls the store until the run reaches a terminal state.\nfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n\tticker := time.NewTicker(2 * time.Second)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n\t\tcase <-ticker.C:\n\t\t\trun, err := e.Store.GetRun(ctx, runID)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // transient error, retry\n\t\t\t}\n\t\t\tswitch run.State {\n\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n\t\t\t\treturn run.State, nil\n\t\t\t}\n\t\t\t// Still pending or running, continue polling\n\t\t}\n\t}\n}\n\n// stepOutputPath returns the path for a step's output file.\nfunc (e *Executor) stepOutputPath(stepName string) string {\n\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n}\n\n// findPrevOutput finds the output file from the step that wires into this one.\n// It checks prompt_step config first, then walks the wiring graph to find the\n// source step.\nfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n\t// Explicit prompt_step config takes priority\n\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n\t\tpath := e.stepOutputPath(ps)\n\t\tif _, err := os.Stat(path); err == nil {\n\t\t\treturn path\n\t\t}\n\t}\n\n\t// Walk wiring to find the step that feeds into this one\n\tfor _, w := range e.Wires {\n\t\tif w.To == step.Name {\n\t\t\tpath := e.stepOutputPath(w.From)\n\t\t\tif _, err := os.Stat(path); err == nil {\n\t\t\t\treturn path\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n// the repository containing projectDir. If projectDir is already the main\n// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n// error (e.g. not a git repo).\nfunc MainWorktreeDir(projectDir string) string {\n\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn projectDir\n\t}\n\t// The first \"worktree <path>\" line is always the main worktree.\n\tfor _, line := range strings.Split(string(out), \"\\n\") {\n\t\tif strings.HasPrefix(line, \"worktree \") {\n\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n\t\t}\n\t}\n\treturn projectDir\n}\n","numLines":340,"startLine":1,"totalLines":340}}}
