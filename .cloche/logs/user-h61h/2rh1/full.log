[2026-03-11T21:25:46Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RA4GgseirjL5Qh1vmyKvNm","type":"tool_result","content":"     1→package prompt\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"bytes\"\n     6→\t\"context\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strconv\"\n    13→\t\"strings\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17→)\n    18→\n    19→// defaultAgentArgs maps known agent commands to their default arguments.\n    20→// Commands not in this map receive no default arguments (prompt on stdin only).\n    21→var defaultAgentArgs = map[string][]string{\n    22→\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n    23→}\n    24→\n    25→type Adapter struct {\n    26→\tCommands     []string // ordered fallback chain of agent commands\n    27→\tExplicitArgs []string // if non-nil, overrides default args for all commands\n    28→\tRunID        string\n    29→\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n    30→}\n    31→\n    32→func New() *Adapter {\n    33→\treturn &Adapter{\n    34→\t\tCommands: []string{\"claude\"},\n    35→\t}\n    36→}\n    37→\n    38→func (a *Adapter) Name() string {\n    39→\treturn \"prompt\"\n    40→}\n    41→\n    42→// argsFor returns the arguments for the given command. If ExplicitArgs is set,\n    43→// it is used for all commands. Otherwise, known agents get their default args.\n    44→func (a *Adapter) argsFor(command string) []string {\n    45→\tif a.ExplicitArgs != nil {\n    46→\t\treturn a.ExplicitArgs\n    47→\t}\n    48→\tif args, ok := defaultAgentArgs[command]; ok {\n    49→\t\treturn args\n    50→\t}\n    51→\treturn nil\n    52→}\n    53→\n    54→// ParseCommands splits a comma-separated agent_command string into individual\n    55→// command names, trimming whitespace from each entry.\n    56→func ParseCommands(s string) []string {\n    57→\tparts := strings.Split(s, \",\")\n    58→\tvar cmds []string\n    59→\tfor _, p := range parts {\n    60→\t\tp = strings.TrimSpace(p)\n    61→\t\tif p != \"\" {\n    62→\t\t\tcmds = append(cmds, p)\n    63→\t\t}\n    64→\t}\n    65→\treturn cmds\n    66→}\n    67→\n    68→func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    69→\t// Check attempt count for retry limiting\n    70→\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n    71→\t\tmax, err := strconv.Atoi(maxStr)\n    72→\t\tif err == nil {\n    73→\t\t\tcount := readAttemptCount(workDir, step.Name)\n    74→\t\t\tif count >= max {\n    75→\t\t\t\treturn \"give-up\", nil\n    76→\t\t\t}\n    77→\t\t}\n    78→\t}\n    79→\tincrementAttemptCount(workDir, step.Name)\n    80→\n    81→\t// Build the full prompt\n    82→\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n    83→\tif err != nil {\n    84→\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n    85→\t}\n    86→\n    87→\t// Try each command in the fallback chain\n    88→\tvar lastResult string\n    89→\tvar lastStdout []byte\n    90→\tvar lastErr error\n    91→\tran := false\n    92→\n    93→\tfor _, command := range a.Commands {\n    94→\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n    95→\t\tlastResult = result\n    96→\t\tlastStdout = stdout\n    97→\t\tlastErr = fallbackErr\n    98→\n    99→\t\tif fallbackErr == nil {\n   100→\t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n   101→\t\t\tbreak\n   102→\t\t}\n   103→\t\tif stdout != nil {\n   104→\t\t\tran = true\n   105→\t\t}\n   106→\t\t// Fallback-eligible — try next command\n   107→\t}\n   108→\n   109→\tif lastErr != nil && !ran && lastStdout == nil {\n   110→\t\t// All commands failed to produce any output (e.g., all not found)\n   111→\t\treturn \"\", lastErr\n   112→\t}\n   113→\n   114→\tresult := lastResult\n   115→\tif lastErr != nil {\n   116→\t\t// Last command in chain crashed without a result marker\n   117→\t\tresult = \"fail\"\n   118→\t}\n   119→\n   120→\t// Write output file\n   121→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   122→\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n   123→\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n   124→\t}\n   125→\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n   126→\treturn result, nil\n   127→}\n   128→\n   129→// tryCommand executes a single agent command and returns:\n   130→//   - result: the step result name (e.g. \"success\", \"fail\")\n   131→//   - stdout: captured stdout bytes\n   132→//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n   133→//\n   134→// Fallback-eligible conditions:\n   135→//   - Command not found or failed to start (stdout will be nil)\n   136→//   - Command exited non-zero without a CLOCHE_RESULT marker\n   137→//\n   138→// Definitive (non-fallback) conditions:\n   139→//   - Command exited 0\n   140→//   - Command exited non-zero but produced a CLOCHE_RESULT marker\n   141→func (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n   142→\targs := a.argsFor(command)\n   143→\tcmd := exec.CommandContext(ctx, command, args...)\n   144→\tcmd.Dir = workDir\n   145→\tcmd.Stdin = strings.NewReader(prompt)\n   146→\n   147→\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n   148→\tif a.StatusWriter == nil {\n   149→\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n   150→\t\tcmd.Stdout = &stdoutBuf\n   151→\t\tcmd.Stderr = &stderrBuf\n   152→\n   153→\t\trunErr := cmd.Run()\n   154→\t\tstdoutBytes := stdoutBuf.Bytes()\n   155→\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n   156→\t}\n   157→\n   158→\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n   159→\tpipe, err := cmd.StdoutPipe()\n   160→\tif err != nil {\n   161→\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n   162→\t}\n   163→\tcmd.Stderr = nil // discard stderr\n   164→\n   165→\tif err := cmd.Start(); err != nil {\n   166→\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n   167→\t}\n   168→\n   169→\t// textBuf accumulates extracted text content for result extraction.\n   170→\t// rawBuf accumulates raw stdout for the output log file.\n   171→\tvar textBuf, rawBuf bytes.Buffer\n   172→\t// lineBuf accumulates text deltas into lines for streaming.\n   173→\tvar lineBuf strings.Builder\n   174→\n   175→\tscanner := bufio.NewScanner(pipe)\n   176→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n   177→\tfor scanner.Scan() {\n   178→\t\traw := scanner.Bytes()\n   179→\t\trawBuf.Write(raw)\n   180→\t\trawBuf.WriteByte('\\n')\n   181→\n   182→\t\ttext := extractStreamText(raw)\n   183→\t\tif text == \"\" {\n   184→\t\t\tcontinue\n   185→\t\t}\n   186→\t\ttextBuf.WriteString(text)\n   187→\n   188→\t\t// Stream complete lines to StatusWriter as they form.\n   189→\t\tlineBuf.WriteString(text)\n   190→\t\tfor {\n   191→\t\t\ts := lineBuf.String()\n   192→\t\t\tidx := strings.IndexByte(s, '\\n')\n   193→\t\t\tif idx < 0 {\n   194→\t\t\t\tbreak\n   195→\t\t\t}\n   196→\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n   197→\t\t\tlineBuf.Reset()\n   198→\t\t\tlineBuf.WriteString(s[idx+1:])\n   199→\t\t}\n   200→\t}\n   201→\t// Flush any remaining partial line.\n   202→\tif lineBuf.Len() > 0 {\n   203→\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n   204→\t}\n   205→\tif scanErr := scanner.Err(); scanErr != nil {\n   206→\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n   207→\t}\n   208→\n   209→\twaitErr := cmd.Wait()\n   210→\t// Prefer extracted text (stream-json) for result classification; fall back\n   211→\t// to raw output for non-JSON commands (scripts, non-claude agents).\n   212→\tclassifyBuf := textBuf.Bytes()\n   213→\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n   214→\t\tclassifyBuf = rawBuf.Bytes()\n   215→\t}\n   216→\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n   217→\treturn result, rawBuf.Bytes(), fallbackErr\n   218→}\n   219→\n   220→// classifyResult interprets the command's exit status and stdout to determine\n   221→// the step result.\n   222→func (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n   223→\tif runErr != nil {\n   224→\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n   225→\t\t\t// Command failed to start (not found, permission denied, etc.)\n   226→\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n   227→\t\t}\n   228→\t\t// Command ran but exited non-zero\n   229→\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   230→\t\tif found {\n   231→\t\t\treturn markerResult, stdoutBytes, nil\n   232→\t\t}\n   233→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n   234→\t}\n   235→\n   236→\t// Command succeeded (exit 0)\n   237→\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n   238→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n   239→\t}\n   240→\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   241→\tresult := \"success\"\n   242→\tif found {\n   243→\t\tresult = markerResult\n   244→\t}\n   245→\treturn result, stdoutBytes, nil\n   246→}\n   247→\n   248→// extractStreamText parses a Claude Code stream-json line and returns text content.\n   249→//\n   250→// Claude Code's stream-json emits these event types:\n   251→//   - \"assistant\": one per turn, contains message.content[] with text and tool_use blocks\n   252→//   - \"result\": final event with the full result text (contains CLOCHE_RESULT marker)\n   253→//\n   254→// For assistant events, we extract text blocks and summarize tool_use blocks\n   255→// (e.g. \"--- Tool: Read('path') ---\"). Each assistant event has a unique uuid\n   256→// for dedup by the caller.\n   257→func extractStreamText(line []byte) string {\n   258→\t// Fast path: skip lines that can't contain content we care about.\n   259→\tif !bytes.Contains(line, []byte(`\"type\"`)) {\n   260→\t\treturn \"\"\n   261→\t}\n   262→\n   263→\tvar envelope struct {\n   264→\t\tType string `json:\"type\"`\n   265→\t}\n   266→\tif json.Unmarshal(line, &envelope) != nil {\n   267→\t\treturn \"\"\n   268→\t}\n   269→\n   270→\tswitch envelope.Type {\n   271→\tcase \"assistant\":\n   272→\t\treturn extractAssistantText(line)\n   273→\tcase \"result\":\n   274→\t\treturn extractResultText(line)\n   275→\t}\n   276→\treturn \"\"\n   277→}\n   278→\n   279→// extractAssistantText extracts text and tool-use summaries from an assistant event.\n   280→func extractAssistantText(line []byte) string {\n   281→\tvar event struct {\n   282→\t\tMessage struct {\n   283→\t\t\tContent []struct {\n   284→\t\t\t\tType  string          `json:\"type\"`\n   285→\t\t\t\tText  string          `json:\"text\"`\n   286→\t\t\t\tName  string          `json:\"name\"`\n   287→\t\t\t\tInput json.RawMessage `json:\"input\"`\n   288→\t\t\t} `json:\"content\"`\n   289→\t\t} `json:\"message\"`\n   290→\t}\n   291→\tif json.Unmarshal(line, &event) != nil {\n   292→\t\treturn \"\"\n   293→\t}\n   294→\n   295→\tvar b strings.Builder\n   296→\tfor _, c := range event.Message.Content {\n   297→\t\tswitch c.Type {\n   298→\t\tcase \"text\":\n   299→\t\t\tif c.Text != \"\" {\n   300→\t\t\t\tb.WriteString(c.Text)\n   301→\t\t\t\tif !strings.HasSuffix(c.Text, \"\\n\") {\n   302→\t\t\t\t\tb.WriteByte('\\n')\n   303→\t\t\t\t}\n   304→\t\t\t}\n   305→\t\tcase \"tool_use\":\n   306→\t\t\tb.WriteString(\"--- Tool: \")\n   307→\t\t\tb.WriteString(c.Name)\n   308→\t\t\tb.WriteString(toolInputSummary(c.Input))\n   309→\t\t\tb.WriteString(\" ---\\n\")\n   310→\t\t}\n   311→\t}\n   312→\treturn b.String()\n   313→}\n   314→\n   315→// extractResultText extracts the final result text (contains CLOCHE_RESULT marker).\n   316→func extractResultText(line []byte) string {\n   317→\tif !bytes.Contains(line, []byte(`\"subtype\"`)) {\n   318→\t\treturn \"\"\n   319→\t}\n   320→\tvar event struct {\n   321→\t\tType   string `json:\"type\"`\n   322→\t\tResult string `json:\"result\"`\n   323→\t}\n   324→\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n   325→\t\treturn event.Result\n   326→\t}\n   327→\treturn \"\"\n   328→}\n   329→\n   330→// toolInputSummary returns a short parenthesized summary of a tool's input.\n   331→func toolInputSummary(input json.RawMessage) string {\n   332→\tif len(input) == 0 {\n   333→\t\treturn \"\"\n   334→\t}\n   335→\tvar m map[string]json.RawMessage\n   336→\tif json.Unmarshal(input, &m) != nil {\n   337→\t\treturn \"\"\n   338→\t}\n   339→\t// Pick the most informative single argument to show.\n   340→\tfor _, key := range []string{\"file_path\", \"command\", \"pattern\", \"prompt\", \"skill\"} {\n   341→\t\tif v, ok := m[key]; ok {\n   342→\t\t\tvar s string\n   343→\t\t\tif json.Unmarshal(v, &s) == nil {\n   344→\t\t\t\tif len(s) > 60 {\n   345→\t\t\t\t\ts = s[:57] + \"...\"\n   346→\t\t\t\t}\n   347→\t\t\t\treturn \"('\" + s + \"')\"\n   348→\t\t\t}\n   349→\t\t}\n   350→\t}\n   351→\treturn \"\"\n   352→}\n   353→\n   354→func assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n   355→\tvar parts []string\n   356→\n   357→\t// 1. Read system template from step config\n   358→\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n   359→\t\tcontent, err := resolveContent(tmpl, workDir)\n   360→\t\tif err != nil {\n   361→\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n   362→\t\t}\n   363→\t\tparts = append(parts, content)\n   364→\t}\n   365→\n   366→\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n   367→\tuserPrompt := readUserPrompt(workDir, runID)\n   368→\tif userPrompt != \"\" {\n   369→\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n   370→\t}\n   371→\n   372→\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n   373→\tif step.Config[\"feedback\"] == \"true\" {\n   374→\t\tfeedback := readFeedback(workDir)\n   375→\t\tif feedback != \"\" {\n   376→\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n   377→\t\t}\n   378→\t}\n   379→\n   380→\t// 4. Result selection instructions\n   381→\tif len(step.Results) > 0 {\n   382→\t\tvar resultLines []string\n   383→\t\tresultLines = append(resultLines, \"## Result Selection\")\n   384→\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n   385→\t\tfor _, r := range step.Results {\n   386→\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n   387→\t\t}\n   388→\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n   389→\t}\n   390→\n   391→\treturn strings.Join(parts, \"\\n\\n\"), nil\n   392→}\n   393→\n   394→// resolveContent handles file(\"path\") syntax or returns the string directly.\n   395→func resolveContent(value string, workDir string) (string, error) {\n   396→\t// Check for file(\"path\") syntax from DSL parser\n   397→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n   398→\t\tpath := value[6 : len(value)-2]\n   399→\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n   400→\t\tif err != nil {\n   401→\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n   402→\t\t}\n   403→\t\treturn string(data), nil\n   404→\t}\n   405→\treturn value, nil\n   406→}\n   407→\n   408→func readFeedback(workDir string) string {\n   409→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   410→\tentries, err := os.ReadDir(outputDir)\n   411→\tif err != nil {\n   412→\t\treturn \"\"\n   413→\t}\n   414→\n   415→\tvar parts []string\n   416→\tfor _, entry := range entries {\n   417→\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n   418→\t\t\tcontinue\n   419→\t\t}\n   420→\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n   421→\t\tif err != nil {\n   422→\t\t\tcontinue\n   423→\t\t}\n   424→\t\tcontent := strings.TrimSpace(string(data))\n   425→\t\tif content != \"\" {\n   426→\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n   427→\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n   428→\t\t}\n   429→\t}\n   430→\n   431→\treturn strings.Join(parts, \"\\n\\n\")\n   432→}\n   433→\n   434→func readAttemptCount(workDir, stepName string) int {\n   435→\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n   436→\tdata, err := os.ReadFile(path)\n   437→\tif err != nil {\n   438→\t\treturn 0\n   439→\t}\n   440→\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n   441→\treturn n\n   442→}\n   443→\n   444→// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\n   445→func readUserPrompt(workDir, runID string) string {\n   446→\tif runID == \"\" {\n   447→\t\treturn \"\"\n   448→\t}\n   449→\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   450→\tif data, err := os.ReadFile(path); err == nil {\n   451→\t\treturn string(data)\n   452→\t}\n   453→\treturn \"\"\n   454→}\n   455→\n   456→func incrementAttemptCount(workDir, stepName string) {\n   457→\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n   458→\t_ = os.MkdirAll(dir, 0755)\n   459→\tcount := readAttemptCount(workDir, stepName) + 1\n   460→\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n   461→}\n   462→"}]},"par