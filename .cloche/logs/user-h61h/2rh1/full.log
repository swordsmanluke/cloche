[2026-03-11T21:25:46Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B3rouXqZY4RarQnsrSJPVZ","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"strings\"\n    11→\t\"time\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    17→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    19→)\n    20→\n    21→// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    22→// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    23→// strings suitable for adding to a command's environment.\n    24→func (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    25→\tvar env []string\n    26→\tfor _, w := range wires {\n    27→\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    28→\t\t\tcontinue\n    29→\t\t}\n    30→\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    31→\t\tif err != nil {\n    32→\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    33→\t\t}\n    34→\t\tfor _, m := range w.OutputMap {\n    35→\t\t\tval, err := m.Path.Evaluate(data)\n    36→\t\t\tif err != nil {\n    37→\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    38→\t\t\t}\n    39→\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    40→\t\t}\n    41→\t}\n    42→\treturn env, nil\n    43→}\n    44→\n    45→// RunDispatcher dispatches a container workflow run and returns the run ID.\n    46→type RunDispatcher interface {\n    47→\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    48→}\n    49→\n    50→// Executor implements engine.StepExecutor for host workflow steps.\n    51→type Executor struct {\n    52→\tProjectDir    string\n    53→\tMainDir       string         // main branch worktree dir; scripts execute from here\n    54→\tDispatcher    RunDispatcher\n    55→\tStore         ports.RunStore\n    56→\tOutputDir     string         // directory for step output files\n    57→\tWires         []domain.Wire  // workflow wiring (for output mappings)\n    58→\tHostRunID     string         // ID of the parent host run (set on child runs)\n    59→\tAgentCommands []string       // workflow-level agent command fallback chain\n    60→\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n    61→\tTaskID        string         // optional task ID assigned by the daemon loop\n    62→\tExtraEnv      []string       // additional KEY=VALUE env vars for all steps\n    63→}\n    64→\n    65→// scriptDir returns the directory from which scripts should execute.\n    66→// Uses MainDir if set, otherwise falls back to ProjectDir.\n    67→func (e *Executor) scriptDir() string {\n    68→\tif e.MainDir != \"\" {\n    69→\t\treturn e.MainDir\n    70→\t}\n    71→\treturn e.ProjectDir\n    72→}\n    73→\n    74→var _ engine.StepExecutor = (*Executor)(nil)\n    75→\n    76→// Execute runs a single host workflow step.\n    77→func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    78→\tswitch step.Type {\n    79→\tcase domain.StepTypeScript:\n    80→\t\treturn e.executeScript(ctx, step)\n    81→\tcase domain.StepTypeWorkflow:\n    82→\t\treturn e.executeWorkflow(ctx, step)\n    83→\tcase domain.StepTypeAgent:\n    84→\t\treturn e.executeAgent(ctx, step)\n    85→\tdefault:\n    86→\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    87→\t}\n    88→}\n    89→\n    90→// executeScript runs a shell command on the host.\n    91→func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    92→\tcmdStr := step.Config[\"run\"]\n    93→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    94→\tcmd.Dir = e.scriptDir()\n    95→\tcmd.Env = append(os.Environ(),\n    96→\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    97→\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    98→\t)\n    99→\n   100→\t// Pass daemon-assigned task ID if available\n   101→\tif e.TaskID != \"\" {\n   102→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_TASK_ID=\"+e.TaskID)\n   103→\t}\n   104→\n   105→\t// Pass extra env vars (e.g. finalize phase outcome vars)\n   106→\tif len(e.ExtraEnv) > 0 {\n   107→\t\tcmd.Env = append(cmd.Env, e.ExtraEnv...)\n   108→\t}\n   109→\n   110→\t// Pass previous step output if available\n   111→\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n   112→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n   113→\t}\n   114→\n   115→\t// Resolve output mappings from wires and add as env vars\n   116→\tif len(e.Wires) > 0 {\n   117→\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n   118→\t\tif err != nil {\n   119→\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n   120→\t\t}\n   121→\t\tcmd.Env = append(cmd.Env, mapped...)\n   122→\t}\n   123→\n   124→\toutput, err := cmd.CombinedOutput()\n   125→\n   126→\t// Extract result marker\n   127→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n   128→\n   129→\t// Write output to file\n   130→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   131→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   132→\t}\n   133→\n   134→\tif err != nil {\n   135→\t\tif _, ok := err.(*exec.ExitError); ok {\n   136→\t\t\tresult := \"fail\"\n   137→\t\t\tif found {\n   138→\t\t\t\tresult = markerResult\n   139→\t\t\t}\n   140→\t\t\treturn result, nil\n   141→\t\t}\n   142→\t\treturn \"\", err\n   143→\t}\n   144→\n   145→\tresult := \"success\"\n   146→\tif found {\n   147→\t\tresult = markerResult\n   148→\t}\n   149→\treturn result, nil\n   150→}\n   151→\n   152→// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   153→func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   154→\tworkflowName := step.Config[\"workflow_name\"]\n   155→\tif workflowName == \"\" {\n   156→\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   157→\t}\n   158→\n   159→\t// Read prompt from previous step output or prompt_step override\n   160→\tvar promptContent string\n   161→\tpromptSource := step.Config[\"prompt_step\"]\n   162→\tif promptSource != \"\" {\n   163→\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   164→\t\tif err == nil {\n   165→\t\t\tpromptContent = string(data)\n   166→\t\t}\n   167→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   168→\t\tdata, err := os.ReadFile(prev)\n   169→\t\tif err == nil {\n   170→\t\t\tpromptContent = string(data)\n   171→\t\t}\n   172→\t}\n   173→\n   174→\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   175→\t\tWorkflowName: workflowName,\n   176→\t\tProjectDir:   e.ProjectDir,\n   177→\t\tPrompt:       promptContent,\n   178→\t})\n   179→\tif err != nil {\n   180→\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   181→\t}\n   182→\n   183→\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   184→\n   185→\t// Link child run to parent host run\n   186→\tif e.HostRunID != \"\" {\n   187→\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n   188→\t\t\tchildRun.ParentRunID = e.HostRunID\n   189→\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n   190→\t\t}\n   191→\t}\n   192→\n   193→\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n   194→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   195→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n   196→\t}\n   197→\n   198→\t// Poll until the run reaches a terminal state\n   199→\tstate, err := e.waitForRun(ctx, resp.RunId)\n   200→\tif err != nil {\n   201→\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   202→\t}\n   203→\n   204→\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   205→\n   206→\t// Map run state to step result\n   207→\tif state == domain.RunStateSucceeded {\n   208→\t\treturn \"success\", nil\n   209→\t}\n   210→\treturn \"fail\", nil\n   211→}\n   212→\n   213→// executeAgent runs an agent command on the host using the prompt adapter.\n   214→func (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n   215→\tadapter := prompt.New()\n   216→\n   217→\t// Apply workflow-level agent config\n   218→\tif len(e.AgentCommands) > 0 {\n   219→\t\tadapter.Commands = e.AgentCommands\n   220→\t}\n   221→\tif len(e.AgentArgs) > 0 {\n   222→\t\tadapter.ExplicitArgs = e.AgentArgs\n   223→\t}\n   224→\n   225→\t// Step-level overrides\n   226→\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   227→\t\tadapter.Commands = prompt.ParseCommands(cmd)\n   228→\t}\n   229→\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   230→\t\tadapter.ExplicitArgs = strings.Fields(args)\n   231→\t}\n   232→\n   233→\tadapter.RunID = e.HostRunID\n   234→\n   235→\t// Write previous step output as user prompt so the adapter can pick it up.\n   236→\tvar promptContent string\n   237→\tpromptSource := step.Config[\"prompt_step\"]\n   238→\tif promptSource != \"\" {\n   239→\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n   240→\t\t\tpromptContent = string(data)\n   241→\t\t}\n   242→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   243→\t\tif data, err := os.ReadFile(prev); err == nil {\n   244→\t\t\tpromptContent = string(data)\n   245→\t\t}\n   246→\t}\n   247→\n   248→\tif promptContent != \"\" {\n   249→\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n   250→\t\t_ = os.MkdirAll(promptDir, 0755)\n   251→\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n   252→\t}\n   253→\n   254→\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n   255→\tif err != nil {\n   256→\t\treturn \"\", err\n   257→\t}\n   258→\n   259→\t// Copy output from adapter's output location to executor's output path\n   260→\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n   261→\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n   262→\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   263→\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n   264→\t\t}\n   265→\t}\n   266→\n   267→\treturn result, nil\n   268→}\n   269→\n   270→// waitForRun polls the store until the run reaches a terminal state.\n   271→func (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   272→\tticker := time.NewTicker(2 * time.Second)\n   273→\tdefer ticker.Stop()\n   274→\n   275→\tfor {\n   276→\t\tselect {\n   277→\t\tcase <-ctx.Done():\n   278→\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   279→\t\tcase <-ticker.C:\n   280→\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   281→\t\t\tif err != nil {\n   282→\t\t\t\tcontinue // transient error, retry\n   283→\t\t\t}\n   284→\t\t\tswitch run.State {\n   285→\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   286→\t\t\t\treturn run.State, nil\n   287→\t\t\t}\n   288→\t\t\t// Still pending or running, continue polling\n   289→\t\t}\n   290→\t}\n   291→}\n   292→\n   293→// stepOutputPath returns the path for a step's output file.\n   294→func (e *Executor) stepOutputPath(stepName string) string {\n   295→\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   296→}\n   297→\n   298→// findPrevOutput finds the output file from the step that wires into this one.\n   299→// It checks prompt_step config first, then walks the wiring graph to find the\n   300→// source step.\n   301→func (e *Executor) findPrevOutput(step *domain.Step) string {\n   302→\t// Explicit prompt_step config takes priority\n   303→\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   304→\t\tpath := e.stepOutputPath(ps)\n   305→\t\tif _, err := os.Stat(path); err == nil {\n   306→\t\t\treturn path\n   307→\t\t}\n   308→\t}\n   309→\n   310→\t// Walk wiring to find the step that feeds into this one\n   311→\tfor _, w := range e.Wires {\n   312→\t\tif w.To == step.Name {\n   313→\t\t\tpath := e.stepOutputPath(w.From)\n   314→\t\t\tif _, err := os.Stat(path); err == nil {\n   315→\t\t\t\treturn path\n   316→\t\t\t}\n   317→\t\t}\n   318→\t}\n   319→\treturn \"\"\n   320→}\n   321→\n   322→// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n   323→// the repository containing projectDir. If projectDir is already the main\n   324→// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n   325→// error (e.g. not a git repo).\n   326→func MainWorktreeDir(projectDir string) string {\n   327→\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n   328→\tout, err := cmd.Output()\n   329→\tif err != nil {\n   330→\t\treturn projectDir\n   331→\t}\n   332→\t// The first \"worktree <path>\" line is always the main worktree.\n   333→\tfor _, line := range strings.Split(string(out), \"\\n\") {\n   334→\t\tif strings.HasPrefix(line, \"worktree \") {\n   335→\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n   336→\t\t}\n   337→\t}\n   338→\treturn projectDir\n   339→}\n   340→"}]},"parent_tool_use_id":null,"session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"958edd1c-c258-49da-9ac0-f5326c58d28f","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\n// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n// reads the source step's output, evaluates each mapping path, and returns KEY=value\n// strings suitable for adding to a command's environment.\nfunc (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n\tvar env []string\n\tfor _, w := range wires {\n\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n\t\t}\n\t\tfor _, m := range w.OutputMap {\n\t\t\tval, err := m.Path.Evaluate(data)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n\t\t\t}\n\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n\t\t}\n\t}\n\treturn env, nil\n}\n\n// RunDispatcher dispatches a container workflow run and returns the run ID.\ntype RunDispatcher interface {\n\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n}\n\n// Executor implements engine.StepExecutor for host workflow steps.\ntype Executor struct {\n\tProjectDir    string\n\tMainDir       string         // main branch worktree dir; scripts execute from here\n\tDispatcher    RunDispatcher\n\tStore         ports.RunStore\n\tOutputDir     string         // directory for step output files\n\tWires         []domain.Wire  // workflow wiring (for output mappings)\n\tHostRunID     string         // ID of the parent host run (set on child runs)\n\tAgentCommands []string       // workflow-level agent command fallback chain\n\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n\tTaskID        string         // optional task ID assigned by the daemon loop\n\tExtraEnv      []string       // additional KEY=VALUE env vars for all steps\n}\n\n// scriptDir returns the directory from which scripts should execute.\n// Uses MainDir if set, otherwise falls back to ProjectDir.\nfunc (e *Executor) scriptDir() string {\n\tif e.MainDir != \"\" {\n\t\treturn e.MainDir\n\t}\n\treturn e.ProjectDir\n}\n\nvar _ engine.StepExecutor = (*Executor)(nil)\n\n// Execute runs a single host workflow step.\nfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\treturn e.executeScript(ctx, step)\n\tcase domain.StepTypeWorkflow:\n\t\treturn e.executeWorkflow(ctx, step)\n\tcase domain.StepTypeAgent:\n\t\treturn e.executeAgent(ctx, step)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n\t}\n}\n\n// executeScript runs a shell command on the host.\nfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n\tcmdStr := step.Config[\"run\"]\n\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n\tcmd.Dir = e.scriptDir()\n\tcmd.Env = append(os.Environ(),\n\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n\t)\n\n\t// Pass daemon-assigned task ID if available\n\tif e.TaskID != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_TASK_ID=\"+e.TaskID)\n\t}\n\n\t// Pass extra env vars (e.g. finalize phase outcome vars)\n\tif len(e.ExtraEnv) > 0 {\n\t\tcmd.Env = append(cmd.Env, e.ExtraEnv...)\n\t}\n\n\t// Pass previous step output if available\n\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n\t}\n\n\t// Resolve output mappings from wires and add as env vars\n\tif len(e.Wires) > 0 {\n\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n\t\t}\n\t\tcmd.Env = append(cmd.Env, mapped...)\n\t}\n\n\toutput, err := cmd.CombinedOutput()\n\n\t// Extract result marker\n\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n\n\t// Write output to file\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n\t}\n\n\tif err != nil {\n\t\tif _, ok := err.(*exec.ExitError); ok {\n\t\t\tresult := \"fail\"\n\t\t\tif found {\n\t\t\t\tresult = markerResult\n\t\t\t}\n\t\t\treturn result, nil\n\t\t}\n\t\treturn \"\", err\n\t}\n\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, nil\n}\n\n// executeWorkflow dispatches a container workflow run and blocks until it completes.\nfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n\tworkflowName := step.Config[\"workflow_name\"]\n\tif workflowName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n\t}\n\n\t// Read prompt from previous step output or prompt_step override\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tdata, err := os.ReadFile(prev)\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName: workflowName,\n\t\tProjectDir:   e.ProjectDir,\n\t\tPrompt:       promptContent,\n\t})\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n\t}\n\n\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n\n\t// Link child run to parent host run\n\tif e.HostRunID != \"\" {\n\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n\t\t\tchildRun.ParentRunID = e.HostRunID\n\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n\t\t}\n\t}\n\n\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n\t}\n\n\t// Poll until the run reaches a terminal state\n\tstate, err := e.waitForRun(ctx, resp.RunId)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n\t}\n\n\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n\n\t// Map run state to step result\n\tif state == domain.RunStateSucceeded {\n\t\treturn \"success\", nil\n\t}\n\treturn \"fail\", nil\n}\n\n// executeAgent runs an agent command on the host using the prompt adapter.\nfunc (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n\tadapter := prompt.New()\n\n\t// Apply workflow-level agent config\n\tif len(e.AgentCommands) > 0 {\n\t\tadapter.Commands = e.AgentCommands\n\t}\n\tif len(e.AgentArgs) > 0 {\n\t\tadapter.ExplicitArgs = e.AgentArgs\n\t}\n\n\t// Step-level overrides\n\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n\t\tadapter.Commands = prompt.ParseCommands(cmd)\n\t}\n\tif args := step.Config[\"agent_args\"]; args != \"\" {\n\t\tadapter.ExplicitArgs = strings.Fields(args)\n\t}\n\n\tadapter.RunID = e.HostRunID\n\n\t// Write previous step output as user prompt so the adapter can pick it up.\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tif data, err := os.ReadFile(prev); err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tif promptContent != \"\" {\n\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n\t\t_ = os.MkdirAll(promptDir, 0755)\n\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n\t}\n\n\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\t// Copy output from adapter's output location to executor's output path\n\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\n// waitForRun polls the store until the run reaches a terminal state.\nfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n\tticker := time.NewTicker(2 * time.Second)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n\t\tcase <-ticker.C:\n\t\t\trun, err := e.Store.GetRun(ctx, runID)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // transient error, retry\n\t\t\t}\n\t\t\tswitch run.State {\n\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n\t\t\t\treturn run.State, nil\n\t\t\t}\n\t\t\t// Still pending or running, continue polling\n\t\t}\n\t}\n}\n\n// stepOutputPath returns the path for a step's output file.\nfunc (e *Executor) stepOutputPath(stepName string) string {\n\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n}\n\n// findPrevOutput finds the output file from the step that wires into this one.\n// It checks prompt_step config first, then walks the wiring graph to find the\n// source step.\nfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n\t// Explicit prompt_step config takes priority\n\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n\t\tpath := e.stepOutputPath(ps)\n\t\tif _, err := os.Stat(path); err == nil {\n\t\t\treturn path\n\t\t}\n\t}\n\n\t// Walk wiring to find the step that feeds into this one\n\tfor _, w := range e.Wires {\n\t\tif w.To == step.Name {\n\t\t\tpath := e.stepOutputPath(w.From)\n\t\t\tif _, err := os.Stat(path); err == nil {\n\t\t\t\treturn path\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n// the repository containing projectDir. If projectDir is already the main\n// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n// error (e.g. not a git repo).\nfunc MainWorktreeDir(projectDir string) string {\n\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn projectDir\n\t}\n\t// The first \"worktree <path>\" line is always the main worktree.\n\tfor _, line := range strings.Split(string(out), \"\\n\") {\n\t\tif strings.HasPrefix(line, \"worktree \") {\n\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n\t\t}\n\t}\n\treturn projectDir\n}\n","numLines":340,"startLine":1,"totalLines":340}}}
