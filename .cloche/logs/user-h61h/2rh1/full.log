[2026-03-11T21:25:46Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YXYWoKrnjK4uEGDGdr3FUV","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"sync\"\n    10→\t\"time\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14→)\n    15→\n    16→const (\n    17→\tdefaultMaxConcurrent = 1\n    18→\tdefaultDedupTimeout  = 5 * time.Minute\n    19→\tidlePollInterval     = 2 * time.Minute\n    20→\tcapacityPollInterval = 30 * time.Second\n    21→)\n    22→\n    23→// LoopConfig holds configuration for an orchestration loop.\n    24→type LoopConfig struct {\n    25→\tProjectDir    string\n    26→\tMaxConcurrent int\n    27→\tStaggerDelay  time.Duration // delay between launching consecutive runs\n    28→\tDedupTimeout  time.Duration // how long to suppress reassignment of the same task ID\n    29→}\n    30→\n    31→// ListTasksFunc is called to discover available tasks. It should run the\n    32→// list-tasks workflow (or equivalent) and return the parsed tasks.\n    33→type ListTasksFunc func(ctx context.Context, projectDir string) ([]Task, error)\n    34→\n    35→// MainFunc is called to execute the main workflow for a given task.\n    36→type MainFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n    37→\n    38→// FinalizeFunc is called after the main workflow completes (both success and\n    39→// failure). It receives the task ID and the outcome of the main phase.\n    40→type FinalizeFunc func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error)\n    41→\n    42→// RunFunc is the legacy function signature for launching a host workflow run.\n    43→// When taskID is non-empty, the runner should propagate it as CLOCHE_TASK_ID.\n    44→type RunFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n    45→\n    46→// Loop manages a continuous orchestration loop for a project, keeping up to\n    47→// MaxConcurrent host workflow runs active at all times when work is available.\n    48→//\n    49→// When configured with three-phase functions (list-tasks, main, finalize), the\n    50→// loop discovers tasks via list-tasks, picks open ones, runs main for each, and\n    51→// then runs finalize on completion. When configured with a legacy RunFunc, it\n    52→// falls back to the single-function approach.\n    53→type Loop struct {\n    54→\tconfig     LoopConfig\n    55→\tlistTasks  ListTasksFunc\n    56→\tmainFn     MainFunc\n    57→\tfinalizeFn FinalizeFunc // optional; skipped if nil\n    58→\trunner     RunFunc      // legacy single-function mode\n    59→\tstore      ports.RunStore\n    60→\tassigner   TaskAssigner // optional; legacy task assignment\n    61→\tstopCh     chan struct{}\n    62→\tmu         sync.Mutex\n    63→\trunning    bool\n    64→\tdedupMu    sync.Mutex\n    65→\tdedup      map[string]time.Time // task ID -> last assignment time\n    66→}\n    67→\n    68→// NewLoop creates an orchestration loop using a single run function (legacy mode).\n    69→// For three-phase orchestration, use NewPhaseLoop instead.\n    70→func NewLoop(cfg LoopConfig, store ports.RunStore, runFn RunFunc) *Loop {\n    71→\tif cfg.MaxConcurrent <= 0 {\n    72→\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n    73→\t}\n    74→\tif cfg.DedupTimeout <= 0 {\n    75→\t\tcfg.DedupTimeout = defaultDedupTimeout\n    76→\t}\n    77→\treturn &Loop{\n    78→\t\tconfig: cfg,\n    79→\t\trunner: runFn,\n    80→\t\tstore:  store,\n    81→\t\tdedup:  make(map[string]time.Time),\n    82→\t}\n    83→}\n    84→\n    85→// NewPhaseLoop creates a three-phase orchestration loop. The listTasksFn\n    86→// discovers available tasks, mainFn executes the main workflow for a task,\n    87→// and finalizeFn (optional) runs cleanup after main completes.\n    88→func NewPhaseLoop(cfg LoopConfig, store ports.RunStore, listTasksFn ListTasksFunc, mainFn MainFunc, finalizeFn FinalizeFunc) *Loop {\n    89→\tif cfg.MaxConcurrent <= 0 {\n    90→\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n    91→\t}\n    92→\tif cfg.DedupTimeout <= 0 {\n    93→\t\tcfg.DedupTimeout = defaultDedupTimeout\n    94→\t}\n    95→\treturn &Loop{\n    96→\t\tconfig:     cfg,\n    97→\t\tlistTasks:  listTasksFn,\n    98→\t\tmainFn:     mainFn,\n    99→\t\tfinalizeFn: finalizeFn,\n   100→\t\tstore:      store,\n   101→\t\tdedup:      make(map[string]time.Time),\n   102→\t}\n   103→}\n   104→\n   105→// SetTaskAssigner configures a TaskAssigner for daemon-managed task assignment.\n   106→// Only used in legacy (single RunFunc) mode when no list-tasks function is set.\n   107→func (l *Loop) SetTaskAssigner(a TaskAssigner) {\n   108→\tl.assigner = a\n   109→}\n   110→\n   111→// Start begins the orchestration loop. No-op if already running.\n   112→func (l *Loop) Start() {\n   113→\tl.mu.Lock()\n   114→\tdefer l.mu.Unlock()\n   115→\tif l.running {\n   116→\t\treturn\n   117→\t}\n   118→\tl.running = true\n   119→\tl.stopCh = make(chan struct{})\n   120→\tgo l.run()\n   121→\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n   122→}\n   123→\n   124→// Stop signals the loop to stop. Active runs continue to completion.\n   125→func (l *Loop) Stop() {\n   126→\tl.mu.Lock()\n   127→\tdefer l.mu.Unlock()\n   128→\tif !l.running {\n   129→\t\treturn\n   130→\t}\n   131→\tl.running = false\n   132→\tclose(l.stopCh)\n   133→\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n   134→}\n   135→\n   136→// Running returns whether the loop is currently active.\n   137→func (l *Loop) Running() bool {\n   138→\tl.mu.Lock()\n   139→\tdefer l.mu.Unlock()\n   140→\treturn l.running\n   141→}\n   142→\n   143→func (l *Loop) run() {\n   144→\tif l.listTasks != nil && l.mainFn != nil {\n   145→\t\tl.runPhased()\n   146→\t} else {\n   147→\t\tl.runLegacy()\n   148→\t}\n   149→}\n   150→\n   151→// runPhased implements the three-phase orchestration loop:\n   152→// 1. list-tasks → discover available work\n   153→// 2. main → execute work for each open task (up to MaxConcurrent)\n   154→// 3. finalize → cleanup after main completes (on both success and failure)\n   155→func (l *Loop) runPhased() {\n   156→\ttype result struct {\n   157→\t\tstate domain.RunState\n   158→\t}\n   159→\n   160→\tcompletions := make(chan result, l.config.MaxConcurrent)\n   161→\tinFlight := 0\n   162→\n   163→\tfor {\n   164→\t\t// Fill up to max concurrent slots.\n   165→\t\tlaunched := 0\n   166→\t\tfor inFlight < l.config.MaxConcurrent {\n   167→\t\t\tselect {\n   168→\t\t\tcase <-l.stopCh:\n   169→\t\t\t\treturn\n   170→\t\t\tdefault:\n   171→\t\t\t}\n   172→\n   173→\t\t\t// Check how many host runs are active for this project.\n   174→\t\t\tactive := l.countActiveHostRuns()\n   175→\t\t\tif active >= l.config.MaxConcurrent {\n   176→\t\t\t\tbreak\n   177→\t\t\t}\n   178→\n   179→\t\t\t// Stagger consecutive launches.\n   180→\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   181→\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   182→\t\t\t\t\treturn\n   183→\t\t\t\t}\n   184→\t\t\t}\n   185→\n   186→\t\t\t// Phase 1: list-tasks — discover available work.\n   187→\t\t\ttaskID, ok := l.pickTaskFromPhase()\n   188→\t\t\tif !ok {\n   189→\t\t\t\tbreak // no assignable tasks\n   190→\t\t\t}\n   191→\n   192→\t\t\t// Launch main + finalize in a goroutine.\n   193→\t\t\tinFlight++\n   194→\t\t\tlaunched++\n   195→\t\t\ttid := taskID\n   196→\t\t\tgo func() {\n   197→\t\t\t\t// Phase 2: main — do the work.\n   198→\t\t\t\tmainResult, err := l.mainFn(context.Background(), l.config.ProjectDir, tid)\n   199→\t\t\t\tif err != nil {\n   200→\t\t\t\t\tlog.Printf(\"orchestration loop: main failed for %s task %s: %v\", l.config.ProjectDir, tid, err)\n   201→\t\t\t\t\tif mainResult == nil {\n   202→\t\t\t\t\t\tmainResult = &RunResult{State: domain.RunStateFailed}\n   203→\t\t\t\t\t}\n   204→\t\t\t\t}\n   205→\n   206→\t\t\t\t// Phase 3: finalize — cleanup (runs on both success and failure).\n   207→\t\t\t\tif l.finalizeFn != nil {\n   208→\t\t\t\t\t_, finalizeErr := l.finalizeFn(context.Background(), l.config.ProjectDir, tid, mainResult)\n   209→\t\t\t\t\tif finalizeErr != nil {\n   210→\t\t\t\t\t\tlog.Printf(\"orchestration loop: finalize failed for %s task %s: %v\", l.config.ProjectDir, tid, finalizeErr)\n   211→\t\t\t\t\t}\n   212→\t\t\t\t}\n   213→\n   214→\t\t\t\tcompletions <- result{state: mainResult.State}\n   215→\t\t\t}()\n   216→\t\t}\n   217→\n   218→\t\tif inFlight == 0 {\n   219→\t\t\t// Nothing in flight and couldn't launch anything — wait before checking again.\n   220→\t\t\tif !l.sleep(capacityPollInterval) {\n   221→\t\t\t\treturn\n   222→\t\t\t}\n   223→\t\t\tcontinue\n   224→\t\t}\n   225→\n   226→\t\t// Wait for any run to complete.\n   227→\t\tselect {\n   228→\t\tcase r := <-completions:\n   229→\t\t\tinFlight--\n   230→\t\t\tif r.state == domain.RunStateSucceeded {\n   231→\t\t\t\t// Work was done — try to fill slots immediately.\n   232→\t\t\t\tcontinue\n   233→\t\t\t}\n   234→\t\t\t// Run failed or aborted. Back off.\n   235→\t\t\tif !l.sleep(idlePollInterval) {\n   236→\t\t\t\treturn\n   237→\t\t\t}\n   238→\t\tcase <-l.stopCh:\n   239→\t\t\treturn\n   240→\t\t}\n   241→\t}\n   242→}\n   243→\n   244→// pickTaskFromPhase runs the list-tasks function and picks the first open,\n   245→// non-deduped task.\n   246→func (l *Loop) pickTaskFromPhase() (string, bool) {\n   247→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   248→\tdefer cancel()\n   249→\n   250→\ttasks, err := l.listTasks(ctx, l.config.ProjectDir)\n   251→\tif err != nil {\n   252→\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n   253→\t\treturn \"\", false\n   254→\t}\n   255→\n   256→\tnow := time.Now()\n   257→\tl.dedupMu.Lock()\n   258→\tdefer l.dedupMu.Unlock()\n   259→\n   260→\t// Expire old dedup entries.\n   261→\tfor id, ts := range l.dedup {\n   262→\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n   263→\t\t\tdelete(l.dedup, id)\n   264→\t\t}\n   265→\t}\n   266→\n   267→\tfor _, task := range tasks {\n   268→\t\tif task.ID == \"\" {\n   269→\t\t\tcontinue\n   270→\t\t}\n   271→\t\tif !task.IsOpen() {\n   272→\t\t\tcontinue\n   273→\t\t}\n   274→\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   275→\t\t\tcontinue\n   276→\t\t}\n   277→\t\tl.dedup[task.ID] = now\n   278→\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n   279→\t\treturn task.ID, true\n   280→\t}\n   281→\n   282→\treturn \"\", false\n   283→}\n   284→\n   285→// runLegacy implements the original single-function orchestration loop.\n   286→func (l *Loop) runLegacy() {\n   287→\ttype result struct {\n   288→\t\tstate domain.RunState\n   289→\t}\n   290→\n   291→\tcompletions := make(chan result, l.config.MaxConcurrent)\n   292→\tinFlight := 0\n   293→\n   294→\tfor {\n   295→\t\t// Fill up to max concurrent slots.\n   296→\t\tlaunched := 0\n   297→\t\tfor inFlight < l.config.MaxConcurrent {\n   298→\t\t\tselect {\n   299→\t\t\tcase <-l.stopCh:\n   300→\t\t\t\treturn\n   301→\t\t\tdefault:\n   302→\t\t\t}\n   303→\n   304→\t\t\t// Check how many host runs are active for this project (in case of\n   305→\t\t\t// leftover runs from previous loops).\n   306→\t\t\tactive := l.countActiveHostRuns()\n   307→\t\t\tif active >= l.config.MaxConcurrent {\n   308→\t\t\t\tbreak\n   309→\t\t\t}\n   310→\n   311→\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n   312→\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   313→\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   314→\t\t\t\t\treturn\n   315→\t\t\t\t}\n   316→\t\t\t}\n   317→\n   318→\t\t\t// Determine task ID (if task assigner is configured).\n   319→\t\t\ttaskID := \"\"\n   320→\t\t\tif l.assigner != nil {\n   321→\t\t\t\tvar ok bool\n   322→\t\t\t\ttaskID, ok = l.pickTask()\n   323→\t\t\t\tif !ok {\n   324→\t\t\t\t\t// No assignable tasks available.\n   325→\t\t\t\t\tbreak\n   326→\t\t\t\t}\n   327→\t\t\t}\n   328→\n   329→\t\t\t// Launch a new orchestration run in a goroutine.\n   330→\t\t\tinFlight++\n   331→\t\t\tlaunched++\n   332→\t\t\ttid := taskID // capture for goroutine\n   333→\t\t\tgo func() {\n   334→\t\t\t\tres, err := l.runner(context.Background(), l.config.ProjectDir, tid)\n   335→\t\t\t\tif err != nil {\n   336→\t\t\t\t\tlog.Printf(\"orchestration loop: run failed for %s: %v\", l.config.ProjectDir, err)\n   337→\t\t\t\t\tcompletions <- result{state: domain.RunStateFailed}\n   338→\t\t\t\t\treturn\n   339→\t\t\t\t}\n   340→\t\t\t\tcompletions <- result{state: res.State}\n   341→\t\t\t}()\n   342→\t\t}\n   343→\n   344→\t\tif inFlight == 0 {\n   345→\t\t\t// Nothing in flight and at capacity — wait before checking again.\n   346→\t\t\tif !l.sleep(capacityPollInterval) {\n   347→\t\t\t\treturn\n   348→\t\t\t}\n   349→\t\t\tcontinue\n   350→\t\t}\n   351→\n   352→\t\t// Wait for any run to complete.\n   353→\t\tselect {\n   354→\t\tcase r := <-completions:\n   355→\t\t\tinFlight--\n   356→\t\t\tif r.state == domain.RunStateSucceeded {\n   357→\t\t\t\t// Work was done — try to fill slots immediately.\n   358→\t\t\t\tcontinue\n   359→\t\t\t}\n   360→\t\t\t// Run failed or aborted (no tasks available). Back off.\n   361→\t\t\tif !l.sleep(idlePollInterval) {\n   362→\t\t\t\treturn\n   363→\t\t\t}\n   364→\t\tcase <-l.stopCh:\n   365→\t\t\treturn\n   366→\t\t}\n   367→\t}\n   368→}\n   369→\n   370→// pickTask queries the task assigner for available tasks, filters out those\n   371→// within the dedup timeout window, and returns the first assignable task ID.\n   372→// It records the assignment time so the same task won't be picked again until\n   373→// the dedup timeout expires. Returns (\"\", false) if no tasks are available.\n   374→func (l *Loop) pickTask() (string, bool) {\n   375→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   376→\tdefer cancel()\n   377→\n   378→\ttasks, err := l.assigner.ListTasks(ctx, l.config.ProjectDir)\n   379→\tif err != nil {\n   380→\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n   381→\t\treturn \"\", false\n   382→\t}\n   383→\n   384→\tnow := time.Now()\n   385→\tl.dedupMu.Lock()\n   386→\tdefer l.dedupMu.Unlock()\n   387→\n   388→\t// Expire old dedup entries while we're here.\n   389→\tfor id, ts := range l.dedup {\n   390→\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n   391→\t\t\tdelete(l.dedup, id)\n   392→\t\t}\n   393→\t}\n   394→\n   395→\tfor _, task := range tasks {\n   396→\t\tif task.ID == \"\" {\n   397→\t\t\tcontinue\n   398→\t\t}\n   399→\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   400→\t\t\tcontinue // still within dedup window\n   401→\t\t}\n   402→\t\t// Assign this task.\n   403→\t\tl.dedup[task.ID] = now\n   404→\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n   405→\t\treturn task.ID, true\n   406→\t}\n   407→\n   408→\treturn \"\", false\n   409→}\n   410→\n   411→// countActiveHostRuns counts running or pending host runs for the project.\n   412→func (l *Loop) countActiveHostRuns() int {\n   413→\tctx := context.Background()\n   414→\truns, err := l.store.ListRunsByProject(ctx, l.config.ProjectDir, time.Time{})\n   415→\tif err != nil {\n   416→\t\treturn 0\n   417→\t}\n   418→\tcount := 0\n   419→\tfor _, r := range runs {\n   420→\t\tif r.IsHost && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n   421→\t\t\tcount++\n   422→\t\t}\n   423→\t}\n   424→\treturn count\n   425→}\n   426→\n   427→// sleep waits for the given duration or until the loop is stopped.\n   428→// Returns false if the loop was stopped.\n   429→func (l *Loop) sleep(d time.Duration) bool {\n   430→\tselect {\n   431→\tcase <-time.After(d):\n   432→\t\treturn true\n   433→\tcase <-l.stopCh:\n   434→\t\treturn false\n   435→\t}\n   436→}\n   437→\n   438→// ReadListTasksOutput reads the output directory from a list-tasks workflow run\n   439→// and parses JSONL task output from the last step's output file.\n   440→func ReadListTasksOutput(outputDir string) ([]Task, error) {\n   441→\tentries, err := os.ReadDir(outputDir)\n   442→\tif err != nil {\n   443→\t\treturn nil, fmt.Errorf(\"reading list-tasks output dir: %w\", err)\n   444→\t}\n   445→\n   446→\t// Find the most recently modified .out file.\n   447→\tvar latest string\n   448→\tvar latestMod time.Time\n   449→\tfor _, e := range entries {\n   450→\t\tif e.IsDir() || filepath.Ext(e.Name()) != \".out\" {\n   451→\t\t\tcontinue\n   452→\t\t}\n   453→\t\tinfo, err := e.Info()\n   454→\t\tif err != nil {\n   455→\t\t\tcontinue\n   456→\t\t}\n   457→\t\tif latest == \"\" || info.ModTime().After(latestMod) {\n   458→\t\t\tlatest = e.Name()\n   459→\t\t\tlatestMod = info.ModTime()\n   460→\t\t}\n   461→\t}\n   462→\n   463→\tif latest == \"\" {\n   464→\t\treturn nil, fmt.Errorf(\"no output files found in %s\", outputDir)\n   465→\t}\n   466→\n   467→\tdata, err := os.ReadFile(filepath.Join(outputDir, latest))\n   468→\tif err != nil {\n   469→\t\treturn nil, fmt.Errorf(\"reading output file %s: %w\", latest, err)\n   470→\t}\n   471→\n   472→\treturn ParseTasksJSONL(string(data))\n   473→}\n   474→"}]},"parent_tool_use_id":"toolu_01VgKT2HRKQWwdGh23Lxewca","session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"3989694b-fff9-41f3-aa61-745ae36de021"}
