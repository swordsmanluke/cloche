[2026-03-11T21:25:46Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Bu4m5g4gdQA6XrkPNTdA9X","type":"tool_result","content":"   200→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   201→\tfor scanner.Scan() {\n   202→\t\tvar msg protocol.StatusMessage\n   203→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   204→\t\t\tcontinue\n   205→\t\t}\n   206→\n   207→\t\t// Fast path: log messages don't need store interaction.\n   208→\t\tif msg.Type == protocol.MsgLog {\n   209→\t\t\tif s.logBroadcast != nil {\n   210→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   211→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   212→\t\t\t\t\tType:      \"llm\",\n   213→\t\t\t\t\tContent:   msg.Message,\n   214→\t\t\t\t\tStepName:  msg.StepName,\n   215→\t\t\t\t})\n   216→\t\t\t}\n   217→\t\t\tcontinue\n   218→\t\t}\n   219→\n   220→\t\trun, err := s.store.GetRun(ctx, runID)\n   221→\t\tif err != nil {\n   222→\t\t\tcontinue\n   223→\t\t}\n   224→\n   225→\t\tswitch msg.Type {\n   226→\t\tcase protocol.MsgStepStarted:\n   227→\t\t\trun.RecordStepStart(msg.StepName)\n   228→\t\t\tif s.captures != nil {\n   229→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   230→\t\t\t\t\tStepName:  msg.StepName,\n   231→\t\t\t\t\tStartedAt: msg.Timestamp,\n   232→\t\t\t\t})\n   233→\t\t\t}\n   234→\t\t\tif s.logBroadcast != nil {\n   235→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   236→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   237→\t\t\t\t\tType:      \"status\",\n   238→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   239→\t\t\t\t\tStepName:  msg.StepName,\n   240→\t\t\t\t})\n   241→\t\t\t}\n   242→\t\tcase protocol.MsgStepCompleted:\n   243→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   244→\t\t\tif s.captures != nil {\n   245→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   246→\t\t\t\t\tStepName:    msg.StepName,\n   247→\t\t\t\t\tResult:      msg.Result,\n   248→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   249→\t\t\t\t})\n   250→\t\t\t}\n   251→\t\t\tif s.logBroadcast != nil {\n   252→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   253→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   254→\t\t\t\t\tType:      \"status\",\n   255→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   256→\t\t\t\t\tStepName:  msg.StepName,\n   257→\t\t\t\t})\n   258→\t\t\t}\n   259→\t\tcase protocol.MsgRunTitle:\n   260→\t\t\tif run.Title == \"\" {\n   261→\t\t\t\trun.Title = msg.Message\n   262→\t\t\t}\n   263→\t\tcase protocol.MsgRunCompleted:\n   264→\t\t\treportedResult = msg.Result\n   265→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   266→\t\t}\n   267→\n   268→\t\t_ = s.store.UpdateRun(ctx, run)\n   269→\t}\n   270→\treader.Close()\n   271→\n   272→\t// Signal live-stream subscribers that this run is done.\n   273→\tif s.logBroadcast != nil {\n   274→\t\ts.logBroadcast.Finish(runID)\n   275→\t}\n   276→\n   277→\t// Wait for process exit\n   278→\texitCode, err := s.container.Wait(ctx, containerID)\n   279→\tif err != nil {\n   280→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   281→\t}\n   282→\n   283→\t// Extract step output files from container before it's removed\n   284→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   285→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   286→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   287→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   288→\t\t}\n   289→\t}\n   290→\n   291→\t// Capture full container stdout/stderr before the container is removed\n   292→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   293→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   294→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   295→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   296→\t\t}\n   297→\t}\n   298→\n   299→\t// Index extracted log files in the log store\n   300→\tif s.logStore != nil {\n   301→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   302→\t}\n   303→\n   304→\t// Extract results to git branch BEFORE finalizing state, so that\n   305→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   306→\t// before the run is marked complete.\n   307→\tresultLabel := reportedResult\n   308→\tif resultLabel == \"\" {\n   309→\t\tif exitCode == 0 {\n   310→\t\t\tresultLabel = \"succeeded\"\n   311→\t\t} else {\n   312→\t\t\tresultLabel = \"failed\"\n   313→\t\t}\n   314→\t}\n   315→\t{\n   316→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   317→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   318→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   319→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   320→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   321→\t\t\t} else {\n   322→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   323→\t\t\t}\n   324→\t\t} else {\n   325→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   326→\t\t}\n   327→\t}\n   328→\n   329→\t// Now finalize run state\n   330→\trun, err := s.store.GetRun(ctx, runID)\n   331→\tif err != nil {\n   332→\t\treturn\n   333→\t}\n   334→\tif run.State == domain.RunStateRunning {\n   335→\t\tif reportedResult == \"succeeded\" {\n   336→\t\t\trun.Complete(domain.RunStateSucceeded)\n   337→\t\t} else if reportedResult != \"\" {\n   338→\t\t\trun.Complete(domain.RunStateFailed)\n   339→\t\t} else if exitCode == 0 {\n   340→\t\t\trun.Complete(domain.RunStateSucceeded)\n   341→\t\t} else {\n   342→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   343→\t\t}\n   344→\t\t_ = s.store.UpdateRun(ctx, run)\n   345→\t}\n   346→\n   347→\t// Fire evolution trigger if configured\n   348→\tif s.evolution != nil {\n   349→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   350→\t}\n   351→\n   352→\t// Merge is handled as a workflow step in host.cloche, not here.\n   353→\n   354→\t// Container retention policy:\n   355→\t// - Failed runs: always keep the container for debugging\n   356→\t// - Successful runs + --keep-container: keep the container\n   357→\t// - Successful runs without --keep-container: remove the container\n   358→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   359→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   360→\n   361→\tif keepContainer || runFailed {\n   362→\t\treason := \"--keep-container\"\n   363→\t\tif runFailed {\n   364→\t\t\treason = \"run failed\"\n   365→\t\t}\n   366→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   367→\t\tif runFinal != nil {\n   368→\t\t\trunFinal.ContainerKept = true\n   369→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   370→\t\t}\n   371→\t} else {\n   372→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   373→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   374→\t\t} else {\n   375→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   376→\t\t}\n   377→\t}\n   378→\n   379→\t// Cleanup mapping\n   380→\ts.mu.Lock()\n   381→\tdelete(s.runIDs, runID)\n   382→\ts.mu.Unlock()\n   383→}\n   384→\n   385→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   386→\tvar since time.Time\n   387→\tif !req.All {\n   388→\t\tsince = time.Now().Add(-1 * time.Hour)\n   389→\t}\n   390→\truns, err := s.store.ListRuns(ctx, since)\n   391→\tif err != nil {\n   392→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   393→\t}\n   394→\n   395→\tresp := &pb.ListRunsResponse{}\n   396→\tfor _, run := range runs {\n   397→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   398→\t\t\tRunId:        run.ID,\n   399→\t\t\tWorkflowName: run.WorkflowName,\n   400→\t\t\tState:        string(run.State),\n   401→\t\t\tStartedAt:    run.StartedAt.String(),\n   402→\t\t\tErrorMessage: run.ErrorMessage,\n   403→\t\t\tContainerId:  run.ContainerID,\n   404→\t\t\tTitle:        run.Title,\n   405→\t\t\tIsHost:       run.IsHost,\n   406→\t\t})\n   407→\t}\n   408→\treturn resp, nil\n   409→}\n   410→\n   411→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   412→\trun, err := s.store.GetRun(ctx, req.RunId)\n   413→\tif err != nil {\n   414→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   415→\t}\n   416→\n   417→\tresp := &pb.GetStatusResponse{\n   418→\t\tRunId:        run.ID,\n   419→\t\tWorkflowName: run.WorkflowName,\n   420→\t\tState:        string(run.State),\n   421→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   422→\t\tErrorMessage: run.ErrorMessage,\n   423→\t\tContainerId:  run.ContainerID,\n   424→\t\tTitle:        run.Title,\n   425→\t\tIsHost:       run.IsHost,\n   426→\t}\n   427→\n   428→\t// Check container liveness\n   429→\tif run.ContainerID != \"\" && s.container != nil {\n   430→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   431→\t\t\tresp.ContainerAlive = cs.Running\n   432→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   433→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   434→\t\t\t}\n   435→\t\t}\n   436→\t}\n   437→\n   438→\t// Load step executions from captures store if available\n   439→\tif s.captures != nil {\n   440→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   441→\t\tif err == nil {\n   442→\t\t\tfor _, exec := range captures {\n   443→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   444→\t\t\t\t\tStepName:    exec.StepName,\n   445→\t\t\t\t\tResult:      exec.Result,\n   446→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   447→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   448→\t\t\t\t})\n   449→\t\t\t}\n   450→\t\t}\n   451→\t} else {\n   452→\t\tfor _, exec := range run.StepExecutions {\n   453→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   454→\t\t\t\tStepName:    exec.StepName,\n   455→\t\t\t\tResult:      exec.Result,\n   456→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   457→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   458→\t\t\t})\n   459→\t\t}\n   460→\t}\n   461→\n   462→\treturn resp, nil\n   463→}\n   464→\n   465→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   466→\tctx := stream.Context()\n   467→\n   468→\t// Verify run exists\n   469→\trun, err := s.store.GetRun(ctx, req.RunId)\n   470→\tif err != nil {\n   471→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   472→\t}\n   473→\n   474→\t// If step_name or log_type filter is set, serve content directly from the log index\n   475→\tif req.StepName != \"\" || req.LogType != \"\" {\n   476→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   477→\t}\n   478→\n   479→\t// For active runs, stream live from the broadcaster so callers can tail output.\n   480→\tif (run.State == domain.RunStateRunning || run.State == domain.RunStatePending) && s.logBroadcast != nil {\n   481→\t\treturn s.streamLiveLogs(req.RunId, stream)\n   482→\t}\n   483→\n   484→\tif s.captures == nil {\n   485→\t\treturn fmt.Errorf(\"captures store not configured\")\n   486→\t}\n   487→\n   488→\t// Check for full.log first — if it exists, serve it as the unified log\n   489→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   490→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   491→\t\tif err := stream.Send(&pb.LogEntry{\n   492→\t\t\tType:    \"full_log\",\n   493→\t\t\tMessage: string(data),\n   494→\t\t}); err != nil {\n   495→\t\t\treturn err\n   496→\t\t}\n   497→\t\t// Still send run completion entry\n   498→\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   499→\t\t\tif err := stream.Send(&pb.LogEntry{\n   500→\t\t\t\tType:      \"run_completed\",\n   501→\t\t\t\tResult:    string(run.State),\n   502→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   503→\t\t\t\tMessage:   run.ErrorMessage,\n   504→\t\t\t}); err != nil {\n   505→\t\t\t\treturn err\n   506→\t\t\t}\n   507→\t\t}\n   508→\t\treturn nil\n   509→\t}\n   510→\n   511→\t// Fall back to capture-based streaming\n   512→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   513→\tif err != nil {\n   514→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   515→\t}\n   516→\n   517→\tfor _, exec := range captures {\n   518→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   519→\t\t// and one for step_completed (has Result).\n   520→\t\tif exec.Result == \"\" {\n   521→\t\t\tentry := &pb.LogEntry{\n   522→\t\t\t\tType:      \"step_started\",\n   523→\t\t\t\tStepName:  exec.StepName,\n   524→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   525→\t\t\t}\n   526→\t\t\tif err := stream.Send(entry); err != nil {\n   527→\t\t\t\treturn err\n   528→\t\t\t}\n   529→\t\t} else {\n   530→\t\t\t// Read step output from per-step log file.\n   531→\t\t\t// Do NOT fall back to container.log — it contains unfiltered output\n   532→\t\t\t// from ALL steps and would show wrong content for this step.\n   533→\t\t\tvar output string\n   534→\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   535→\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   536→\t\t\t\toutput = string(data)\n   537→\t\t\t}\n   538→\t\t\tentry := &pb.LogEntry{\n   539→\t\t\t\tType:      \"step_completed\",\n   540→\t\t\t\tStepName:  exec.StepName,\n   541→\t\t\t\tResult:    exec.Result,\n   542→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   543→\t\t\t\tMessage:   output,\n   544→\t\t\t}\n   545→\t\t\tif err := stream.Send(entry); err != nil {\n   546→\t\t\t\treturn err\n   547→\t\t\t}\n   548→\t\t}\n   549→\t}\n   550→\n   551→\t// Send run completion entry\n   552→\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   553→\t\tif err := stream.Send(&pb.LogEntry{\n   554→\t\t\tType:      \"run_completed\",\n   555→\t\t\tResult:    string(run.State),\n   556→\t\t\tTimestamp: run.CompletedAt.String(),\n   557→\t\t\tMessage:   run.ErrorMessage,\n   558→\t\t}); err != nil {\n   559→\t\t\treturn err\n   560→\t\t}\n   561→\t}\n   562→\n   563→\treturn nil\n   564→}\n   565→\n   566→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   567→// It uses the log index when available, falling back to file path conventions.\n   568→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   569→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   570→\n   571→\t// Try log index first\n   572→\tif s.logStore != nil {\n   573→\t\tvar logFiles []*ports.LogFileEntry\n   574→\t\tvar err error\n   575→\n   576→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   577→\t\t\t// Filter by both step and type\n   578→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   579→\t\t\tif err == nil {\n   580→\t\t\t\tfiltered := logFiles[:0]\n   581→\t\t\t\tfor _, lf := range logFiles {\n   582→\t\t\t\t\tif lf.FileType == req.LogType {\n   583→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   584→\t\t\t\t\t}\n   585→\t\t\t\t}\n   586→\t\t\t\tlogFiles = filtered\n   587→\t\t\t}\n   588→\t\t} else if req.StepName != \"\" {\n   589→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   590→\t\t} else {\n   591→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   592→\t\t}\n   593→\n   594→\t\tif err == nil && len(logFiles) > 0 {\n   595→\t\t\tfor _, lf := range logFiles {\n   596→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   597→\t\t\t\tif readErr != nil {\n   598→\t\t\t\t\tcontinue\n   599→\t\t\t\t}"}]},"parent_tool_use_id":"toolu_01VgKT2HRKQWwdGh23Lxewca","session_id":"7e0bd824-184f-4257-9f99-c6d8b7efff47","uuid":"09949171-25b9-4345-8bc4-745764c32337"}
