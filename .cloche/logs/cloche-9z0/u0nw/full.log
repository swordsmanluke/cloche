[2026-03-13T17:40:25Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013vfFrbW1seRmKqpdbZCXWK","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"net/http\"\n     8→\t\"net/http/httptest\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"testing\"\n    14→\t\"time\"\n    15→\n    16→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    17→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    18→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    19→\t\"github.com/stretchr/testify/assert\"\n    20→\t\"github.com/stretchr/testify/require\"\n    21→)\n    22→\n    23→// mockContainerManager implements ContainerManager for testing.\n    24→type mockContainerManager struct {\n    25→\tcontainers map[string]bool // containerID -> exists\n    26→\trunning    map[string]bool // containerID -> running\n    27→\tremoved    []string\n    28→\tstopped    []string\n    29→}\n    30→\n    31→func newMockContainerManager() *mockContainerManager {\n    32→\treturn &mockContainerManager{\n    33→\t\tcontainers: map[string]bool{},\n    34→\t\trunning:    map[string]bool{},\n    35→\t}\n    36→}\n    37→\n    38→func (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n    39→\treturn \"mock logs\", nil\n    40→}\n    41→\n    42→func (m *mockContainerManager) Stop(_ context.Context, containerID string) error {\n    43→\tif !m.containers[containerID] {\n    44→\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n    45→\t}\n    46→\tm.running[containerID] = false\n    47→\tm.stopped = append(m.stopped, containerID)\n    48→\treturn nil\n    49→}\n    50→\n    51→func (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n    52→\tif !m.containers[containerID] {\n    53→\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n    54→\t}\n    55→\tdelete(m.containers, containerID)\n    56→\tm.removed = append(m.removed, containerID)\n    57→\treturn nil\n    58→}\n    59→\n    60→func (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n    61→\tif !m.containers[containerID] {\n    62→\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n    63→\t}\n    64→\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n    65→}\n    66→\n    67→func setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n    68→\tt.Helper()\n    69→\tstore, err := sqlite.NewStore(\":memory:\")\n    70→\trequire.NoError(t, err)\n    71→\tt.Cleanup(func() { store.Close() })\n    72→\n    73→\th, err := NewHandler(store, store)\n    74→\trequire.NoError(t, err)\n    75→\treturn h, store\n    76→}\n    77→\n    78→func seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n    79→\tt.Helper()\n    80→\tseedRunWithProject(t, store, id, workflow, state, \"\")\n    81→}\n    82→\n    83→func seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n    84→\tt.Helper()\n    85→\tctx := context.Background()\n    86→\trun := domain.NewRun(id, workflow)\n    87→\trun.ProjectDir = projectDir\n    88→\tif state != domain.RunStatePending {\n    89→\t\trun.Start()\n    90→\t\trun.ContainerID = \"abc123def456789\"\n    91→\t}\n    92→\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n    93→\t\trun.Complete(state)\n    94→\t}\n    95→\tif state == domain.RunStateFailed {\n    96→\t\trun.ErrorMessage = \"something went wrong\"\n    97→\t}\n    98→\trequire.NoError(t, store.CreateRun(ctx, run))\n    99→}\n   100→\n   101→func TestRunsList_WithRuns(t *testing.T) {\n   102→\th, store := setupHandler(t)\n   103→\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n   104→\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n   105→\n   106→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   107→\tw := httptest.NewRecorder()\n   108→\th.ServeHTTP(w, req)\n   109→\n   110→\tassert.Equal(t, http.StatusOK, w.Code)\n   111→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   112→\tbody := w.Body.String()\n   113→\tassert.Contains(t, body, \"test-run-1\")\n   114→\tassert.Contains(t, body, \"test-run-2\")\n   115→\tassert.Contains(t, body, \"badge-running\")\n   116→\tassert.Contains(t, body, \"badge-succeeded\")\n   117→\tassert.Contains(t, body, \"develop\")\n   118→\tassert.Contains(t, body, \"deploy\")\n   119→}\n   120→\n   121→func TestRunsList_Empty(t *testing.T) {\n   122→\th, _ := setupHandler(t)\n   123→\n   124→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   125→\tw := httptest.NewRecorder()\n   126→\th.ServeHTTP(w, req)\n   127→\n   128→\tassert.Equal(t, http.StatusOK, w.Code)\n   129→\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n   130→}\n   131→\n   132→func TestRunDetail_WithCaptures(t *testing.T) {\n   133→\th, store := setupHandler(t)\n   134→\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n   135→\n   136→\tctx := context.Background()\n   137→\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n   138→\t\tStepName:    \"implement\",\n   139→\t\tResult:      \"success\",\n   140→\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n   141→\t\tCompletedAt: time.Now(),\n   142→\t}))\n   143→\n   144→\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n   145→\tw := httptest.NewRecorder()\n   146→\th.ServeHTTP(w, req)\n   147→\n   148→\tassert.Equal(t, http.StatusOK, w.Code)\n   149→\tbody := w.Body.String()\n   150→\tassert.Contains(t, body, \"run-detail-1\")\n   151→\tassert.Contains(t, body, \"implement\")\n   152→}\n   153→\n   154→func TestRunDetail_AccordionStatePreserved(t *testing.T) {\n   155→\t// Verify the rendered page includes JavaScript that preserves accordion state\n   156→\t// during SSE polling updates (captures open/closed state before DOM rebuild).\n   157→\th, store := setupHandler(t)\n   158→\tseedRun(t, store, \"run-accordion-1\", \"develop\", domain.RunStateRunning)\n   159→\n   160→\tctx := context.Background()\n   161→\trequire.NoError(t, store.SaveCapture(ctx, \"run-accordion-1\", &domain.StepExecution{\n   162→\t\tStepName:    \"build\",\n   163→\t\tResult:      \"success\",\n   164→\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n   165→\t\tCompletedAt: time.Now(),\n   166→\t}))\n   167→\n   168→\treq := httptest.NewRequest(\"GET\", \"/runs/run-accordion-1\", nil)\n   169→\tw := httptest.NewRecorder()\n   170→\th.ServeHTTP(w, req)\n   171→\n   172→\tassert.Equal(t, http.StatusOK, w.Code)\n   173→\tbody := w.Body.String()\n   174→\n   175→\t// The poll function should capture accordion state before rebuilding the DOM\n   176→\tassert.Contains(t, body, \"openAccordions\")\n   177→\tassert.Contains(t, body, \"loadedOutputs\")\n   178→\t// Verify it restores loaded output content after DOM rebuild\n   179→\tassert.Contains(t, body, \"loadedOutputs[key]\")\n   180→}\n   181→\n   182→func TestRunDetail_LogScrollStabilization(t *testing.T) {\n   183→\t// Verify the rendered page stabilizes scroll position when SSE log events\n   184→\t// arrive: saves scrollTop before append, auto-scrolls only when at bottom,\n   185→\t// and restores position otherwise.\n   186→\th, store := setupHandler(t)\n   187→\tseedRun(t, store, \"run-scroll-1\", \"develop\", domain.RunStateRunning)\n   188→\n   189→\treq := httptest.NewRequest(\"GET\", \"/runs/run-scroll-1\", nil)\n   190→\tw := httptest.NewRecorder()\n   191→\th.ServeHTTP(w, req)\n   192→\n   193→\tassert.Equal(t, http.StatusOK, w.Code)\n   194→\tbody := w.Body.String()\n   195→\n   196→\t// Must capture scroll position before DOM mutation\n   197→\tassert.Contains(t, body, \"savedScrollTop\")\n   198→\t// Must check if at bottom before appending content\n   199→\tassert.Contains(t, body, \"var atBottom = logViewer.scrollHeight - savedScrollTop - logViewer.clientHeight < 40\")\n   200→\t// Must restore scroll position when not at bottom"}]},"parent_tool_use_id":"toolu_01EN2btuzFKJQ3rtujmZfjq7","session_id":"abc320af-34b7-429f-bd37-e8e770017e8e","uuid":"85a8c408-6eb3-423e-89ae-5fb28e97bc0d"}
