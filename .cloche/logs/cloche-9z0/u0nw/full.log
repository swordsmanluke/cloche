 : (entry.is_parent ? 'run-parent-row' : '');\n   121→                    var timing = r.timing || '';\n   122→                    var wfName = r.workflow_name || '';\n   123→                    var state = r.state || '';\n   124→                    html += '<tr class=\"' + rowClass + '\">' +\n   125→                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n   126→                        '<td>' + escapeHtml(title) + '</td>' +\n   127→                        '<td>' + escapeHtml(r.project_label || '') + '</td>' +\n   128→                        '<td>' + wfName + '</td>' +\n   129→                        '<td>' + runType + '</td>' +\n   130→                        '<td><span class=\"badge badge-' + state + '\">' + state + '</span></td>' +\n   131→                        '<td>' + escapeHtml(timing) + '</td>' +\n   132→                        '<td class=\"mono\">' + cid + '</td>' +\n   133→                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n   134→                        '</tr>';\n   135→                }\n   136→                tbody.innerHTML = html;\n   137→            })\n   138→            .catch(function() {});\n   139→    }\n   140→    function escapeHtml(s) {\n   141→        var d = document.createElement('div');\n   142→        d.appendChild(document.createTextNode(s));\n   143→        return d.innerHTML;\n   144→    }\n   145→    setInterval(poll, 3000);\n   146→})();\n   147→</script>\n   148→{{end}}\n   149→"}]},"parent_tool_use_id":null,"session_id":"abc320af-34b7-429f-bd37-e8e770017e8e","uuid":"6acc4f3e-4cfc-4ad4-a8cd-d5e08c2c5bca","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/runs.html","content":"{{define \"content\"}}\n<h1>Runs</h1>\n{{if .Projects}}\n<div class=\"project-filter\">\n    <label for=\"project-select\">Project:</label>\n    <select id=\"project-select\" onchange=\"filterByProject(this.value)\">\n        <option value=\"\">All projects</option>\n        {{range .Projects}}\n        <option value=\"{{.Dir}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>\n        {{end}}\n    </select>\n    {{if .TotalContainerCount}}\n    <button class=\"btn btn-danger btn-sm\" id=\"cleanup-containers-btn\" onclick=\"cleanupContainers()\" style=\"margin-left:0.5rem\">Clean up {{.TotalContainerCount}} old container{{if gt .TotalContainerCount 1}}s{{end}}</button>\n    {{end}}\n</div>\n{{end}}\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Run ID</th>\n            <th>Title</th>\n            <th>Project</th>\n            <th>Workflow</th>\n            <th>Type</th>\n            <th>State</th>\n            <th>Timing</th>\n            <th>Container</th>\n            <th>Error</th>\n        </tr>\n    </thead>\n    <tbody id=\"runs-body\">\n    {{if .GroupedRuns}}\n        {{range .GroupedRuns}}\n        {{if .TaskHeader}}\n        <tr class=\"run-task-header\"><td colspan=\"9\">Task: {{.TaskID}} <span class=\"badge badge-{{.TaskStatus}}\">{{.TaskStatus}}</span></td></tr>\n        {{else if .Run}}\n        <tr class=\"{{if .IsChild}}run-child-row{{else if .IsParent}}run-parent-row{{end}}\">\n            <td><a href=\"/runs/{{.Run.ID}}\">{{.Run.ID}}</a></td>\n            <td>{{truncate .Run.Title 50}}</td>\n            <td>{{.Run.ProjectLabel}}</td>\n            <td>{{.Run.WorkflowName}}</td>\n            <td>{{if .Run.IsHost}}host{{else}}container{{end}}</td>\n            <td><span class=\"badge badge-{{.Run.State}}\">{{.Run.State}}</span></td>\n            <td>{{.Run.Timing}}</td>\n            <td class=\"mono\">{{shortContainerID .Run.ContainerID}}</td>\n            <td class=\"error-cell\">{{truncate .Run.ErrorMessage 80}}</td>\n        </tr>\n        {{end}}\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var currentProject = '{{.ProjectFilter}}';\n\n    function filterByProject(dir) {\n        if (dir) {\n            window.location.href = '/runs?project=' + encodeURIComponent(dir);\n        } else {\n            window.location.href = '/runs';\n        }\n    }\n    window.filterByProject = filterByProject;\n\n    window.cleanupContainers = function() {\n        var btn = document.getElementById('cleanup-containers-btn');\n        if (btn) btn.disabled = true;\n        fetch('/api/containers', { method: 'DELETE' })\n            .then(function(r) { return r.json(); })\n            .then(function(data) {\n                if (btn) {\n                    btn.textContent = 'Cleaned up ' + data.deleted + ' container' + (data.deleted !== 1 ? 's' : '');\n                }\n            })\n            .catch(function() {\n                if (btn) {\n                    btn.textContent = 'Cleanup failed';\n                    btn.disabled = false;\n                }\n            });\n    };\n\n    function poll() {\n        var url = '/api/runs';\n        if (currentProject) {\n            url += '?project=' + encodeURIComponent(currentProject);\n        }\n        fetch(url)\n            .then(function(r) { return r.json(); })\n            .then(function(entries) {\n                var tbody = document.getElementById('runs-body');\n                if (!entries || entries.length === 0) {\n                    tbody.innerHTML = '<tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>';\n                    return;\n                }\n\n                var html = '';\n                for (var i = 0; i < entries.length; i++) {\n                    var entry = entries[i];\n                    if (entry.task_header) {\n                        var ts = entry.task_status || 'pending';\n                        html += '<tr class=\"run-task-header\"><td colspan=\"9\">Task: ' + escapeHtml(entry.task_id) + ' <span class=\"badge badge-' + ts + '\">' + ts + '</span></td></tr>';\n                        continue;\n                    }\n                    var r = entry.run;\n                    if (!r) continue;\n                    var cid = r.container_id || '';\n                    if (cid.length > 12) cid = cid.substring(0, 12);\n                    var err = r.error_message || '';\n                    if (err.length > 80) err = err.substring(0, 80) + '...';\n                    var title = r.title || '';\n                    if (title.length > 50) title = title.substring(0, 47) + '...';\n                    var runType = r.is_host ? 'host' : 'container';\n                    var rowClass = entry.is_child ? 'run-child-row' : (entry.is_parent ? 'run-parent-row' : '');\n                    var timing = r.timing || '';\n                    var wfName = r.workflow_name || '';\n                    var state = r.state || '';\n                    html += '<tr class=\"' + rowClass + '\">' +\n                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n                        '<td>' + escapeHtml(title) + '</td>' +\n                        '<td>' + escapeHtml(r.project_label || '') + '</td>' +\n                        '<td>' + wfName + '</td>' +\n                        '<td>' + runType + '</td>' +\n                        '<td><span class=\"badge badge-' + state + '\">' + state + '</span></td>' +\n                        '<td>' + escapeHtml(timing) + '</td>' +\n                        '<td class=\"mono\">' + cid + '</td>' +\n                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                        '</tr>';\n                }\n                tbody.innerHTML = html;\n            })\n            .catch(function() {});\n    }\n    function escapeHtml(s) {\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n    setInterval(poll, 3000);\n})();\n</script>\n{{end}}\n","numLines":149,"startLine":1,"totalLines":149}}}
