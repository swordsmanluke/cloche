\"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   440→\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   441→\n   442→\t// Without filter: all runs\n   443→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   444→\tw := httptest.NewRecorder()\n   445→\th.ServeHTTP(w, req)\n   446→\tassert.Equal(t, http.StatusOK, w.Code)\n   447→\n   448→\tvar allEntries []apiGroupedEntry\n   449→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allEntries))\n   450→\t// 2 ungrouped runs (no task_id)\n   451→\tassert.Len(t, allEntries, 2)\n   452→\n   453→\t// With filter: only matching\n   454→\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n   455→\tw = httptest.NewRecorder()\n   456→\th.ServeHTTP(w, req)\n   457→\tassert.Equal(t, http.StatusOK, w.Code)\n   458→\n   459→\tvar filtered []apiGroupedEntry\n   460→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n   461→\tassert.Len(t, filtered, 1)\n   462→\trequire.NotNil(t, filtered[0].Run)\n   463→\tassert.Equal(t, \"api-a1\", filtered[0].Run.ID)\n   464→\tassert.Equal(t, \"/home/user/alpha\", filtered[0].Run.ProjectDir)\n   465→\tassert.Equal(t, \"alpha\", filtered[0].Run.ProjectLabel)\n   466→}\n   467→\n   468→func setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n   469→\tt.Helper()\n   470→\tstore, err := sqlite.NewStore(\":memory:\")\n   471→\trequire.NoError(t, err)\n   472→\tt.Cleanup(func() { store.Close() })\n   473→\n   474→\tmgr := newMockContainerManager()\n   475→\th, err := NewHandler(store, store, WithContainerManager(mgr))\n   476→\trequire.NoError(t, err)\n   477→\treturn h, store, mgr\n   478→}\n   479→"}]},"parent_tool_use_id":null,"session_id":"abc320af-34b7-429f-bd37-e8e770017e8e","uuid":"d5b4ed73-645f-4264-96ff-32e0856c7340","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler_test.go","content":"\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs shown\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-b1\")\n\n\t// With project filter: only matching runs\n\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody = w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-a2\")\n\tassert.NotContains(t, body, \"run-b1\")\n}\n\nfunc TestRunsList_ProjectColumn(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"myproject\")\n\tassert.Contains(t, body, \"Project\")\n}\n\nfunc TestAPIRuns_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar allEntries []apiGroupedEntry\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allEntries))\n\t// 2 ungrouped runs (no task_id)\n\tassert.Len(t, allEntries, 2)\n\n\t// With filter: only matching\n\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar filtered []apiGroupedEntry\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n\tassert.Len(t, filtered, 1)\n\trequire.NotNil(t, filtered[0].Run)\n\tassert.Equal(t, \"api-a1\", filtered[0].Run.ID)\n\tassert.Equal(t, \"/home/user/alpha\", filtered[0].Run.ProjectDir)\n\tassert.Equal(t, \"alpha\", filtered[0].Run.ProjectLabel)\n}\n\nfunc setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\tmgr := newMockContainerManager()\n\th, err := NewHandler(store, store, WithContainerManager(mgr))\n\trequire.NoError(t, err)\n\treturn h, store, mgr\n}\n","numLines":80,"startLine":400,"totalLines":2312}}}
