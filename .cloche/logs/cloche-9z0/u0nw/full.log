erID:  r.ContainerID,\n   485→\t\tErrorMessage: r.ErrorMessage,\n   486→\t\tTitle:        r.Title,\n   487→\t\tIsHost:       r.IsHost,\n   488→\t\tParentRunID:  r.ParentRunID,\n   489→\t\tTaskID:       r.TaskID,\n   490→\t}\n   491→}"}]},"parent_tool_use_id":"toolu_01EN2btuzFKJQ3rtujmZfjq7","session_id":"abc320af-34b7-429f-bd37-e8e770017e8e","uuid":"aca27d6a-9179-4fa1-ba8f-6e7511b179f2"}
