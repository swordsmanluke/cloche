[2026-03-18T21:56:02Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012SD3UomFSCBQR9VzGuSbW6","type":"tool_result","content":"     1→package sqlite\n     2→\n     3→import (\n     4→\t\"database/sql\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"sort\"\n    10→\t\"strings\"\n    11→\t\"time\"\n    12→\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→)\n    15→\n    16→// migrateV2 creates the tasks and attempts tables, populates them from\n    17→// existing run records, and moves log files to the new directory layout.\n    18→// It is idempotent: a _migrations table tracks whether it has already run.\n    19→func migrateV2(db *sql.DB) error {\n    20→\t// Create migration tracking table\n    21→\tdb.Exec(`CREATE TABLE IF NOT EXISTS _migrations (\n    22→\t\tid TEXT PRIMARY KEY,\n    23→\t\tapplied_at TEXT NOT NULL\n    24→\t)`)\n    25→\n    26→\t// Check if already applied\n    27→\tvar count int\n    28→\trow := db.QueryRow(`SELECT COUNT(*) FROM _migrations WHERE id = 'v2-task-oriented'`)\n    29→\tif err := row.Scan(&count); err == nil && count > 0 {\n    30→\t\treturn nil // already migrated\n    31→\t}\n    32→\n    33→\t// Create new tables\n    34→\tif _, err := db.Exec(`CREATE TABLE IF NOT EXISTS tasks (\n    35→\t\tid TEXT PRIMARY KEY,\n    36→\t\ttitle TEXT NOT NULL DEFAULT '',\n    37→\t\tsource TEXT NOT NULL DEFAULT 'external',\n    38→\t\tproject_dir TEXT NOT NULL DEFAULT '',\n    39→\t\tcreated_at TEXT NOT NULL DEFAULT ''\n    40→\t)`); err != nil {\n    41→\t\treturn fmt.Errorf(\"creating tasks table: %w\", err)\n    42→\t}\n    43→\n    44→\tif _, err := db.Exec(`CREATE TABLE IF NOT EXISTS attempts (\n    45→\t\tid TEXT PRIMARY KEY,\n    46→\t\ttask_id TEXT NOT NULL REFERENCES tasks(id),\n    47→\t\tstarted_at TEXT NOT NULL DEFAULT '',\n    48→\t\tended_at TEXT,\n    49→\t\tresult TEXT NOT NULL DEFAULT 'running',\n    50→\t\tproject_dir TEXT NOT NULL DEFAULT ''\n    51→\t)`); err != nil {\n    52→\t\treturn fmt.Errorf(\"creating attempts table: %w\", err)\n    53→\t}\n    54→\n    55→\t// Add attempt_id column to runs (idempotent)\n    56→\tdb.Exec(`ALTER TABLE runs ADD COLUMN attempt_id TEXT NOT NULL DEFAULT ''`)\n    57→\n    58→\t// Query all existing runs, grouped by task_id\n    59→\trows, err := db.Query(`SELECT id, workflow_name, state, started_at, completed_at,\n    60→\t\tproject_dir, task_id, task_title, is_host, parent_run_id\n    61→\t\tFROM runs ORDER BY started_at ASC`)\n    62→\tif err != nil {\n    63→\t\treturn fmt.Errorf(\"querying runs: %w\", err)\n    64→\t}\n    65→\tdefer rows.Close()\n    66→\n    67→\ttype runRecord struct {\n    68→\t\tid           string\n    69→\t\tworkflow     string\n    70→\t\tstate        string\n    71→\t\tstartedAt    string\n    72→\t\tcompletedAt  string\n    73→\t\tprojectDir   string\n    74→\t\ttaskID       string\n    75→\t\ttaskTitle    string\n    76→\t\tisHost       bool\n    77→\t\tparentRunID  string\n    78→\t}\n    79→\n    80→\tvar allRuns []runRecord\n    81→\tfor rows.Next() {\n    82→\t\tvar r runRecord\n    83→\t\tvar isHost int\n    84→\t\tvar completedAt sql.NullString\n    85→\t\tif err := rows.Scan(&r.id, &r.workflow, &r.state, &r.startedAt,\n    86→\t\t\t&completedAt, &r.projectDir, &r.taskID, &r.taskTitle,\n    87→\t\t\t&isHost, &r.parentRunID); err != nil {\n    88→\t\t\tlog.Printf(\"v2 migration: skipping run (scan error): %v\", err)\n    89→\t\t\tcontinue\n    90→\t\t}\n    91→\t\tr.isHost = isHost == 1\n    92→\t\tif completedAt.Valid {\n    93→\t\t\tr.completedAt = completedAt.String\n    94→\t\t}\n    95→\t\tallRuns = append(allRuns, r)\n    96→\t}\n    97→\n    98→\tif len(allRuns) == 0 {\n    99→\t\t// No runs to migrate — skip marking as done so migration\n   100→\t\t// re-checks on next startup (cheap, handles upgrades where\n   101→\t\t// the daemon starts before any runs exist).\n   102→\t\treturn nil\n   103→\t}\n   104→\n   105→\t// Build parent→child mapping\n   106→\tchildrenOf := map[string][]string{}\n   107→\trunByID := map[string]*runRecord{}\n   108→\tfor i := range allRuns {\n   109→\t\trunByID[allRuns[i].id] = &allRuns[i]\n   110→\t\tif allRuns[i].parentRunID != \"\" {\n   111→\t\t\tchildrenOf[allRuns[i].parentRunID] = append(childrenOf[allRuns[i].parentRunID], allRuns[i].id)\n   112→\t\t}\n   113→\t}\n   114→\n   115→\t// Identify top-level runs (no parent, or parent not in DB)\n   116→\tvar topLevel []runRecord\n   117→\tfor _, r := range allRuns {\n   118→\t\tif r.parentRunID == \"\" || runByID[r.parentRunID] == nil {\n   119→\t\t\ttopLevel = append(topLevel, r)\n   120→\t\t}\n   121→\t}\n   122→\n   123→\t// Group top-level runs by task_id. Each top-level run becomes an attempt.\n   124→\t// Runs without a task_id get a generated user-initiated task.\n   125→\ttaskCreated := map[string]bool{}\n   126→\tuserTaskCounter := 0\n   127→\n   128→\t// Sort by started_at for stable attempt numbering\n   129→\tsort.SliceStable(topLevel, func(i, j int) bool {\n   130→\t\treturn topLevel[i].startedAt < topLevel[j].startedAt\n   131→\t})\n   132→\n   133→\ttx, err := db.Begin()\n   134→\tif err != nil {\n   135→\t\treturn fmt.Errorf(\"starting transaction: %w\", err)\n   136→\t}\n   137→\tdefer tx.Rollback()\n   138→\n   139→\tfor _, r := range topLevel {\n   140→\t\ttaskID := r.taskID\n   141→\t\ttaskTitle := r.taskTitle\n   142→\t\ttaskSource := \"external\"\n   143→\n   144→\t\t// Create a user-initiated task for runs without a task ID\n   145→\t\tif taskID == \"\" {\n   146→\t\t\tuserTaskCounter++\n   147→\t\t\ttaskID = fmt.Sprintf(\"user-%s\", domain.GenerateAttemptID())\n   148→\t\t\ttaskSource = \"user-initiated\"\n   149→\t\t\tif taskTitle == \"\" {\n   150→\t\t\t\ttaskTitle = r.workflow + \" (user-initiated)\"\n   151→\t\t\t}\n   152→\t\t}\n   153→\n   154→\t\t// Create task record if not yet created\n   155→\t\tif !taskCreated[taskID] {\n   156→\t\t\t_, err := tx.Exec(`INSERT OR IGNORE INTO tasks (id, title, source, project_dir, created_at)\n   157→\t\t\t\tVALUES (?, ?, ?, ?, ?)`,\n   158→\t\t\t\ttaskID, taskTitle, taskSource, r.projectDir, r.startedAt)\n   159→\t\t\tif err != nil {\n   160→\t\t\t\tlog.Printf(\"v2 migration: failed to create task %s: %v\", taskID, err)\n   161→\t\t\t\tcontinue\n   162→\t\t\t}\n   163→\t\t\ttaskCreated[taskID] = true\n   164→\t\t}\n   165→\n   166→\t\t// Create attempt from this top-level run\n   167→\t\tattemptID := domain.GenerateAttemptID()\n   168→\t\tattemptResult := mapRunStateToAttemptResult(r.state)\n   169→\n   170→\t\t_, err := tx.Exec(`INSERT INTO attempts (id, task_id, started_at, ended_at, result, project_dir)\n   171→\t\t\tVALUES (?, ?, ?, ?, ?, ?)`,\n   172→\t\t\tattemptID, taskID, r.startedAt, nullIfEmpty(r.completedAt), attemptResult, r.projectDir)\n   173→\t\tif err != nil {\n   174→\t\t\tlog.Printf(\"v2 migration: failed to create attempt for run %s: %v\", r.id, err)\n   175→\t\t\tcontinue\n   176→\t\t}\n   177→\n   178→\t\t// Link this run and its children to the attempt\n   179→\t\trunIDs := []string{r.id}\n   180→\t\tfor _, childID := range childrenOf[r.id] {\n   181→\t\t\trunIDs = append(runIDs, childID)\n   182→\t\t}\n   183→\n   184→\t\tfor _, runID := range runIDs {\n   185→\t\t\ttx.Exec(`UPDATE runs SET attempt_id = ?, task_id = ? WHERE id = ?`, attemptID, taskID, runID)\n   186→\t\t}\n   187→\n   188→\t\t// Move log files on disk\n   189→\t\tmoveRunLogs(r.projectDir, r.id, taskID, attemptID, r.workflow)\n   190→\t\tfor _, childID := range childrenOf[r.id] {\n   191→\t\t\tchildRun := runByID[childID]\n   192→\t\t\tif childRun != nil {\n   193→\t\t\t\tmoveRunLogs(childRun.projectDir, childID, taskID, attemptID, childRun.workflow)\n   194→\t\t\t}\n   195→\t\t}\n   196→\t}\n   197→\n   198→\tif err := tx.Commit(); err != nil {\n   199→\t\treturn fmt.Errorf(\"committing migration: %w\", err)\n   200→\t}\n   201→\n   202→\t// Mark migration as complete\n   203→\tdb.Exec(`INSERT INTO _migrations (id, applied_at) VALUES ('v2-task-oriented', ?)`,\n   204→\t\ttime.Now().UTC().Format(time.RFC3339))\n   205→\n   206→\tlog.Printf(\"v2 migration: migrated %d top-level runs into tasks and attempts\", len(topLevel))\n   207→\treturn nil\n   208→}\n   209→\n   210→// moveRunLogs moves log files from .cloche/<run-id>/output/ to\n   211→// .cloche/logs/<task-id>/<attempt-id>/. Files are renamed from\n   212→// <step>.log to <workflow>-<step>.log.\n   213→func moveRunLogs(projectDir, runID, taskID, attemptID, workflow string) {\n   214→\tsrcDir := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   215→\tif _, err := os.Stat(srcDir); err != nil {\n   216→\t\treturn // no output directory\n   217→\t}\n   218→\n   219→\tdstDir := filepath.Join(projectDir, \".cloche\", \"logs\", taskID, attemptID)\n   220→\tif err := os.MkdirAll(dstDir, 0755); err != nil {\n   221→\t\tlog.Printf(\"v2 migration: failed to create log dir %s: %v\", dstDir, err)\n   222→\t\treturn\n   223→\t}\n   224→\n   225→\tentries, err := os.ReadDir(srcDir)\n   226→\tif err != nil {\n   227→\t\treturn\n   228→\t}\n   229→\n   230→\tfor _, entry := range entries {\n   231→\t\tif entry.IsDir() {\n   232→\t\t\tcontinue\n   233→\t\t}\n   234→\t\tsrcPath := filepath.Join(srcDir, entry.Name())\n   235→\t\t// Rename: full.log stays as full.log, others get workflow prefix\n   236→\t\tdstName := entry.Name()\n   237→\t\tif dstName != \"full.log\" && dstName != \"container.log\" {\n   238→\t\t\t// step.log → workflow-step.log\n   239→\t\t\tdstName = workflow + \"-\" + dstName\n   240→\t\t}\n   241→\t\tdstPath := filepath.Join(dstDir, dstName)\n   242→\n   243→\t\t// Copy (not rename, to handle cross-device) then remove\n   244→\t\tdata, err := os.ReadFile(srcPath)\n   245→\t\tif err != nil {\n   246→\t\t\tcontinue\n   247→\t\t}\n   248→\t\tif err := os.WriteFile(dstPath, data, 0644); err != nil {\n   249→\t\t\tlog.Printf(\"v2 migration: failed to write %s: %v\", dstPath, err)\n   250→\t\t\tcontinue\n   251→\t\t}\n   252→\t}\n   253→\n   254→\t// Remove old output directory after successful copy\n   255→\tos.RemoveAll(srcDir)\n   256→\n   257→\t// Remove old run directory if now empty\n   258→\trunDir := filepath.Join(projectDir, \".cloche\", runID)\n   259→\tremoveIfEmpty(runDir)\n   260→}\n   261→\n   262→// removeIfEmpty removes a directory if it contains no files.\n   263→func removeIfEmpty(dir string) {\n   264→\tentries, err := os.ReadDir(dir)\n   265→\tif err != nil {\n   266→\t\treturn\n   267→\t}\n   268→\tif len(entries) == 0 {\n   269→\t\tos.Remove(dir)\n   270→\t}\n   271→}\n   272→\n   273→func mapRunStateToAttemptResult(state string) string {\n   274→\tswitch state {\n   275→\tcase \"succeeded\":\n   276→\t\treturn \"succeeded\"\n   277→\tcase \"failed\":\n   278→\t\treturn \"failed\"\n   279→\tcase \"cancelled\":\n   280→\t\treturn \"cancelled\"\n   281→\tcase \"running\", \"pending\":\n   282→\t\treturn \"running\"\n   283→\tdefault:\n   284→\t\treturn \"failed\"\n   285→\t}\n   286→}\n   287→\n   288→func nullIfEmpty(s string) interface{} {\n   289→\tif s == \"\" {\n   290→\t\treturn nil\n   291→\t}\n   292→\t// Also treat zero time as null\n   293→\tif strings.HasPrefix(s, \"0001-01-01\") {\n   294→\t\treturn nil\n   295→\t}\n   296→\treturn s\n   297→}\n   298→"}]},"parent_tool_use_id":null,"session_id":"2dbae28e-0bf0-425e-bc1b-65ee06862096","uuid":"5214ffc8-551d-4707-bbcb-c6fe6d0cc77c","timestamp":"2026-03-18T21:55:59.003Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/sqlite/migrate_v2.go","content":"package sqlite\n\nimport (\n\t\"database/sql\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n)\n\n// migrateV2 creates the tasks and attempts tables, populates them from\n// existing run records, and moves log files to the new directory layout.\n// It is idempotent: a _migrations table tracks whether it has already run.\nfunc migrateV2(db *sql.DB) error {\n\t// Create migration tracking table\n\tdb.Exec(`CREATE TABLE IF NOT EXISTS _migrations (\n\t\tid TEXT PRIMARY KEY,\n\t\tapplied_at TEXT NOT NULL\n\t)`)\n\n\t// Check if already applied\n\tvar count int\n\trow := db.QueryRow(`SELECT COUNT(*) FROM _migrations WHERE id = 'v2-task-oriented'`)\n\tif err := row.Scan(&count); err == nil && count > 0 {\n\t\treturn nil // already migrated\n\t}\n\n\t// Create new tables\n\tif _, err := db.Exec(`CREATE TABLE IF NOT EXISTS tasks (\n\t\tid TEXT PRIMARY KEY,\n\t\ttitle TEXT NOT NULL DEFAULT '',\n\t\tsource TEXT NOT NULL DEFAULT 'external',\n\t\tproject_dir TEXT NOT NULL DEFAULT '',\n\t\tcreated_at TEXT NOT NULL DEFAULT ''\n\t)`); err != nil {\n\t\treturn fmt.Errorf(\"creating tasks table: %w\", err)\n\t}\n\n\tif _, err := db.Exec(`CREATE TABLE IF NOT EXISTS attempts (\n\t\tid TEXT PRIMARY KEY,\n\t\ttask_id TEXT NOT NULL REFERENCES tasks(id),\n\t\tstarted_at TEXT NOT NULL DEFAULT '',\n\t\tended_at TEXT,\n\t\tresult TEXT NOT NULL DEFAULT 'running',\n\t\tproject_dir TEXT NOT NULL DEFAULT ''\n\t)`); err != nil {\n\t\treturn fmt.Errorf(\"creating attempts table: %w\", err)\n\t}\n\n\t// Add attempt_id column to runs (idempotent)\n\tdb.Exec(`ALTER TABLE runs ADD COLUMN attempt_id TEXT NOT NULL DEFAULT ''`)\n\n\t// Query all existing runs, grouped by task_id\n\trows, err := db.Query(`SELECT id, workflow_name, state, started_at, completed_at,\n\t\tproject_dir, task_id, task_title, is_host, parent_run_id\n\t\tFROM runs ORDER BY started_at ASC`)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"querying runs: %w\", err)\n\t}\n\tdefer rows.Close()\n\n\ttype runRecord struct {\n\t\tid           string\n\t\tworkflow     string\n\t\tstate        string\n\t\tstartedAt    string\n\t\tcompletedAt  string\n\t\tprojectDir   string\n\t\ttaskID       string\n\t\ttaskTitle    string\n\t\tisHost       bool\n\t\tparentRunID  string\n\t}\n\n\tvar allRuns []runRecord\n\tfor rows.Next() {\n\t\tvar r runRecord\n\t\tvar isHost int\n\t\tvar completedAt sql.NullString\n\t\tif err := rows.Scan(&r.id, &r.workflow, &r.state, &r.startedAt,\n\t\t\t&completedAt, &r.projectDir, &r.taskID, &r.taskTitle,\n\t\t\t&isHost, &r.parentRunID); err != nil {\n\t\t\tlog.Printf(\"v2 migration: skipping run (scan error): %v\", err)\n\t\t\tcontinue\n\t\t}\n\t\tr.isHost = isHost == 1\n\t\tif completedAt.Valid {\n\t\t\tr.completedAt = completedAt.String\n\t\t}\n\t\tallRuns = append(allRuns, r)\n\t}\n\n\tif len(allRuns) == 0 {\n\t\t// No runs to migrate — skip marking as done so migration\n\t\t// re-checks on next startup (cheap, handles upgrades where\n\t\t// the daemon starts before any runs exist).\n\t\treturn nil\n\t}\n\n\t// Build parent→child mapping\n\tchildrenOf := map[string][]string{}\n\trunByID := map[string]*runRecord{}\n\tfor i := range allRuns {\n\t\trunByID[allRuns[i].id] = &allRuns[i]\n\t\tif allRuns[i].parentRunID != \"\" {\n\t\t\tchildrenOf[allRuns[i].parentRunID] = append(childrenOf[allRuns[i].parentRunID], allRuns[i].id)\n\t\t}\n\t}\n\n\t// Identify top-level runs (no parent, or parent not in DB)\n\tvar topLevel []runRecord\n\tfor _, r := range allRuns {\n\t\tif r.parentRunID == \"\" || runByID[r.parentRunID] == nil {\n\t\t\ttopLevel = append(topLevel, r)\n\t\t}\n\t}\n\n\t// Group top-level runs by task_id. Each top-level run becomes an attempt.\n\t// Runs without a task_id get a generated user-initiated task.\n\ttaskCreated := map[string]bool{}\n\tuserTaskCounter := 0\n\n\t// Sort by started_at for stable attempt numbering\n\tsort.SliceStable(topLevel, func(i, j int) bool {\n\t\treturn topLevel[i].startedAt < topLevel[j].startedAt\n\t})\n\n\ttx, err := db.Begin()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"starting transaction: %w\", err)\n\t}\n\tdefer tx.Rollback()\n\n\tfor _, r := range topLevel {\n\t\ttaskID := r.taskID\n\t\ttaskTitle := r.taskTitle\n\t\ttaskSource := \"external\"\n\n\t\t// Create a user-initiated task for runs without a task ID\n\t\tif taskID == \"\" {\n\t\t\tuserTaskCounter++\n\t\t\ttaskID = fmt.Sprintf(\"user-%s\", domain.GenerateAttemptID())\n\t\t\ttaskSource = \"user-initiated\"\n\t\t\tif taskTitle == \"\" {\n\t\t\t\ttaskTitle = r.workflow + \" (user-initiated)\"\n\t\t\t}\n\t\t}\n\n\t\t// Create task record if not yet created\n\t\tif !taskCreated[taskID] {\n\t\t\t_, err := tx.Exec(`INSERT OR IGNORE INTO tasks (id, title, source, project_dir, created_at)\n\t\t\t\tVALUES (?, ?, ?, ?, ?)`,\n\t\t\t\ttaskID, taskTitle, taskSource, r.projectDir, r.startedAt)\n\t\t\tif err != nil {\n\t\t\t\tlog.Printf(\"v2 migration: failed to create task %s: %v\", taskID, err)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\ttaskCreated[taskID] = true\n\t\t}\n\n\t\t// Create attempt from this top-level run\n\t\tattemptID := domain.GenerateAttemptID()\n\t\tattemptResult := mapRunStateToAttemptResult(r.state)\n\n\t\t_, err := tx.Exec(`INSERT INTO attempts (id, task_id, started_at, ended_at, result, project_dir)\n\t\t\tVALUES (?, ?, ?, ?, ?, ?)`,\n\t\t\tattemptID, taskID, r.startedAt, nullIfEmpty(r.completedAt), attemptResult, r.projectDir)\n\t\tif err != nil {\n\t\t\tlog.Printf(\"v2 migration: failed to create attempt for run %s: %v\", r.id, err)\n\t\t\tcontinue\n\t\t}\n\n\t\t// Link this run and its children to the attempt\n\t\trunIDs := []string{r.id}\n\t\tfor _, childID := range childrenOf[r.id] {\n\t\t\trunIDs = append(runIDs, childID)\n\t\t}\n\n\t\tfor _, runID := range runIDs {\n\t\t\ttx.Exec(`UPDATE runs SET attempt_id = ?, task_id = ? WHERE id = ?`, attemptID, taskID, runID)\n\t\t}\n\n\t\t// Move log files on disk\n\t\tmoveRunLogs(r.projectDir, r.id, taskID, attemptID, r.workflow)\n\t\tfor _, childID := range childrenOf[r.id] {\n\t\t\tchildRun := runByID[childID]\n\t\t\tif childRun != nil {\n\t\t\t\tmoveRunLogs(childRun.projectDir, childID, taskID, attemptID, childRun.workflow)\n\t\t\t}\n\t\t}\n\t}\n\n\tif err := tx.Commit(); err != nil {\n\t\treturn fmt.Errorf(\"committing migration: %w\", err)\n\t}\n\n\t// Mark migration as complete\n\tdb.Exec(`INSERT INTO _migrations (id, applied_at) VALUES ('v2-task-oriented', ?)`,\n\t\ttime.Now().UTC().Format(time.RFC3339))\n\n\tlog.Printf(\"v2 migration: migrated %d top-level runs into tasks and attempts\", len(topLevel))\n\treturn nil\n}\n\n// moveRunLogs moves log files from .cloche/<run-id>/output/ to\n// .cloche/logs/<task-id>/<attempt-id>/. Files are renamed from\n// <step>.log to <workflow>-<step>.log.\nfunc moveRunLogs(projectDir, runID, taskID, attemptID, workflow string) {\n\tsrcDir := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n\tif _, err := os.Stat(srcDir); err != nil {\n\t\treturn // no output directory\n\t}\n\n\tdstDir := filepath.Join(projectDir, \".cloche\", \"logs\", taskID, attemptID)\n\tif err := os.MkdirAll(dstDir, 0755); err != nil {\n\t\tlog.Printf(\"v2 migration: failed to create log dir %s: %v\", dstDir, err)\n\t\treturn\n\t}\n\n\tentries, err := os.ReadDir(srcDir)\n\tif err != nil {\n\t\treturn\n\t}\n\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tsrcPath := filepath.Join(srcDir, entry.Name())\n\t\t// Rename: full.log stays as full.log, others get workflow prefix\n\t\tdstName := entry.Name()\n\t\tif dstName != \"full.log\" && dstName != \"container.log\" {\n\t\t\t// step.log → workflow-step.log\n\t\t\tdstName = workflow + \"-\" + dstName\n\t\t}\n\t\tdstPath := filepath.Join(dstDir, dstName)\n\n\t\t// Copy (not rename, to handle cross-device) then remove\n\t\tdata, err := os.ReadFile(srcPath)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif err := os.WriteFile(dstPath, data, 0644); err != nil {\n\t\t\tlog.Printf(\"v2 migration: failed to write %s: %v\", dstPath, err)\n\t\t\tcontinue\n\t\t}\n\t}\n\n\t// Remove old output directory after successful copy\n\tos.RemoveAll(srcDir)\n\n\t// Remove old run directory if now empty\n\trunDir := filepath.Join(projectDir, \".cloche\", runID)\n\tremoveIfEmpty(runDir)\n}\n\n// removeIfEmpty removes a directory if it contains no files.\nfunc removeIfEmpty(dir string) {\n\tentries, err := os.ReadDir(dir)\n\tif err != nil {\n\t\treturn\n\t}\n\tif len(entries) == 0 {\n\t\tos.Remove(dir)\n\t}\n}\n\nfunc mapRunStateToAttemptResult(state string) string {\n\tswitch state {\n\tcase \"succeeded\":\n\t\treturn \"succeeded\"\n\tcase \"failed\":\n\t\treturn \"failed\"\n\tcase \"cancelled\":\n\t\treturn \"cancelled\"\n\tcase \"running\", \"pending\":\n\t\treturn \"running\"\n\tdefault:\n\t\treturn \"failed\"\n\t}\n}\n\nfunc nullIfEmpty(s string) interface{} {\n\tif s == \"\" {\n\t\treturn nil\n\t}\n\t// Also treat zero time as null\n\tif strings.HasPrefix(s, \"0001-01-01\") {\n\t\treturn nil\n\t}\n\treturn s\n}\n","numLines":298,"startLine":1,"totalLines":298}}}
