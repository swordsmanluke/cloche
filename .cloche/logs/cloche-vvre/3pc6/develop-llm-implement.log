{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W4u8684XkZUtzTXQzpLo2V","type":"tool_result","content":"     1→package sqlite\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"database/sql\"\n     6→\t\"fmt\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11→\t_ \"modernc.org/sqlite\"\n    12→)\n    13→\n    14→type Store struct {\n    15→\tdb *sql.DB\n    16→}\n    17→\n    18→func NewStore(dsn string) (*Store, error) {\n    19→\tdb, err := sql.Open(\"sqlite\", dsn)\n    20→\tif err != nil {\n    21→\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n    22→\t}\n    23→\n    24→\t// Enable WAL mode for concurrent read/write access\n    25→\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n    26→\n    27→\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n    28→\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n    29→\n    30→\t// Serialize all Go-side access through a single connection so SQLite\n    31→\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n    32→\tdb.SetMaxOpenConns(1)\n    33→\n    34→\tif err := migrate(db); err != nil {\n    35→\t\tdb.Close()\n    36→\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n    37→\t}\n    38→\n    39→\treturn &Store{db: db}, nil\n    40→}\n    41→\n    42→func (s *Store) Close() error {\n    43→\treturn s.db.Close()\n    44→}\n    45→\n    46→func migrate(db *sql.DB) error {\n    47→\t_, err := db.Exec(`\n    48→\t\tCREATE TABLE IF NOT EXISTS runs (\n    49→\t\t\tid TEXT PRIMARY KEY,\n    50→\t\t\tworkflow_name TEXT NOT NULL,\n    51→\t\t\tstate TEXT NOT NULL,\n    52→\t\t\tactive_steps TEXT,\n    53→\t\t\tstarted_at TEXT,\n    54→\t\t\tcompleted_at TEXT\n    55→\t\t);\n    56→\t\tCREATE TABLE IF NOT EXISTS step_executions (\n    57→\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    58→\t\t\trun_id TEXT NOT NULL,\n    59→\t\t\tstep_name TEXT NOT NULL,\n    60→\t\t\tresult TEXT,\n    61→\t\t\tstarted_at TEXT NOT NULL,\n    62→\t\t\tcompleted_at TEXT,\n    63→\t\t\tlogs TEXT,\n    64→\t\t\tgit_ref TEXT,\n    65→\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    66→\t\t);\n    67→\t`)\n    68→\tif err != nil {\n    69→\t\treturn err\n    70→\t}\n    71→\n    72→\t// Evolution schema additions (idempotent)\n    73→\talterStmts := []string{\n    74→\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n    75→\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n    76→\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n    77→\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n    78→\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n    79→\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n    80→\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n    81→\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n    82→\t\t`ALTER TABLE runs ADD COLUMN title TEXT NOT NULL DEFAULT ''`,\n    83→\t\t`ALTER TABLE runs ADD COLUMN is_host INTEGER NOT NULL DEFAULT 0`,\n    84→\t\t`ALTER TABLE runs ADD COLUMN parent_run_id TEXT NOT NULL DEFAULT ''`,\n    85→\t\t`ALTER TABLE runs ADD COLUMN task_id TEXT NOT NULL DEFAULT ''`,\n    86→\t\t`ALTER TABLE runs ADD COLUMN task_title TEXT NOT NULL DEFAULT ''`,\n    87→\t}\n    88→\tfor _, stmt := range alterStmts {\n    89→\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n    90→\t}\n    91→\n    92→\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n    93→\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    94→\t\trun_id TEXT NOT NULL,\n    95→\t\tstep_name TEXT,\n    96→\t\tfile_type TEXT NOT NULL,\n    97→\t\tfile_path TEXT NOT NULL,\n    98→\t\tfile_size INTEGER,\n    99→\t\tcreated_at TEXT NOT NULL,\n   100→\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n   101→\t)`)\n   102→\tif errLog != nil {\n   103→\t\treturn errLog\n   104→\t}\n   105→\n   106→\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n   107→\t\trun_id TEXT PRIMARY KEY,\n   108→\t\tbranch TEXT NOT NULL,\n   109→\t\tproject TEXT NOT NULL,\n   110→\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n   111→\t\tenqueued_at TEXT NOT NULL,\n   112→\t\tcompleted_at TEXT\n   113→\t)`)\n   114→\tif errMQ != nil {\n   115→\t\treturn errMQ\n   116→\t}\n   117→\n   118→\t// v2: Task-oriented migration — creates tasks/attempts tables,\n   119→\t// populates from existing runs, moves log files.\n   120→\tif err := migrateV2(db); err != nil {\n   121→\t\treturn fmt.Errorf(\"v2 migration: %w\", err)\n   122→\t}\n   123→\n   124→\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n   125→\t\tid TEXT PRIMARY KEY,\n   126→\t\tproject_dir TEXT NOT NULL,\n   127→\t\tworkflow_name TEXT NOT NULL,\n   128→\t\ttrigger_run_id TEXT NOT NULL,\n   129→\t\tcreated_at TEXT NOT NULL,\n   130→\t\tclassification TEXT,\n   131→\t\tchanges_json TEXT NOT NULL,\n   132→\t\tknowledge_delta TEXT\n   133→\t)`)\n   134→\tif err2 != nil {\n   135→\t\treturn err2\n   136→\t}\n   137→\n   138→\treturn nil\n   139→}\n   140→\n   141→func (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n   142→\t_, err := s.db.ExecContext(ctx,\n   143→\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept, title, is_host, parent_run_id, task_id, task_title)\n   144→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   145→\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n   146→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, truncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID, run.TaskTitle,\n   147→\t)\n   148→\treturn err\n   149→}\n   150→\n   151→// runSelectCols is the standard column list for scanning a Run row.\n   152→const runSelectCols = `id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,''), COALESCE(is_host,0), COALESCE(parent_run_id,''), COALESCE(task_id,''), COALESCE(task_title,'')`\n   153→\n   154→// scanRun scans a single row into a *domain.Run.\n   155→func scanRun(scanner interface{ Scan(...any) error }) (*domain.Run, error) {\n   156→\trun := &domain.Run{}\n   157→\tvar activeSteps, startedAt, completedAt string\n   158→\tvar containerKept, isHost int\n   159→\terr := scanner.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title, &isHost, &run.ParentRunID, &run.TaskID, &run.TaskTitle)\n   160→\tif err != nil {\n   161→\t\treturn nil, err\n   162→\t}\n   163→\trun.SetActiveStepsFromString(activeSteps)\n   164→\trun.StartedAt = parseTime(startedAt)\n   165→\trun.CompletedAt = parseTime(completedAt)\n   166→\trun.ContainerKept = containerKept != 0\n   167→\trun.IsHost = isHost != 0\n   168→\treturn run, nil\n   169→}\n   170→\n   171→func (s *Store) GetRun(ctx context.Context, id string) (*domain.Run, error) {\n   172→\trow := s.db.QueryRowContext(ctx,\n   173→\t\t`SELECT `+runSelectCols+` FROM runs WHERE id = ?`, id)\n   174→\n   175→\trun, err := scanRun(row)\n   176→\tif err == sql.ErrNoRows {\n   177→\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n   178→\t}\n   179→\treturn run, err\n   180→}\n   181→\n   182→func (s *Store) UpdateRun(ctx context.Context, run *domain.Run) error {\n   183→\t_, err := s.db.ExecContext(ctx,\n   184→\t\t`UPDATE runs SET state = ?, active_steps = ?, started_at = ?, completed_at = ?, error_message = ?, container_id = ?, base_sha = ?, container_kept = ?, title = ?, is_host = ?, parent_run_id = ?, task_id = ?, task_title = ? WHERE id = ?`,\n   185→\t\tstring(run.State), run.ActiveStepsString(),\n   186→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt),\n   187→\t\ttruncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID, run.TaskTitle, run.ID,\n   188→\t)\n   189→\treturn err\n   190→}\n   191→\n   192→func (s *Store) DeleteRun(ctx context.Context, id string) error {\n   193→\t_, err := s.db.ExecContext(ctx, `DELETE FROM step_executions WHERE run_id = ?`, id)\n   194→\tif err != nil {\n   195→\t\treturn err\n   196→\t}\n   197→\t_, err = s.db.ExecContext(ctx, `DELETE FROM runs WHERE id = ?`, id)\n   198→\treturn err\n   199→}\n   200→\n   201→func (s *Store) ListRuns(ctx context.Context, since time.Time) ([]*domain.Run, error) {\n   202→\tvar rows *sql.Rows\n   203→\tvar err error\n   204→\tif since.IsZero() {\n   205→\t\trows, err = s.db.QueryContext(ctx,\n   206→\t\t\t`SELECT `+runSelectCols+` FROM runs ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`)\n   207→\t} else {\n   208→\t\trows, err = s.db.QueryContext(ctx,\n   209→\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   210→\t\t\tformatTime(since))\n   211→\t}\n   212→\tif err != nil {\n   213→\t\treturn nil, err\n   214→\t}\n   215→\tdefer rows.Close()\n   216→\treturn scanRuns(rows)\n   217→}\n   218→\n   219→// scanRuns scans all rows into a []*domain.Run slice.\n   220→func scanRuns(rows *sql.Rows) ([]*domain.Run, error) {\n   221→\tvar runs []*domain.Run\n   222→\tfor rows.Next() {\n   223→\t\trun, err := scanRun(rows)\n   224→\t\tif err != nil {\n   225→\t\t\treturn nil, err\n   226→\t\t}\n   227→\t\truns = append(runs, run)\n   228→\t}\n   229→\treturn runs, rows.Err()\n   230→}\n   231→\n   232→func (s *Store) ListRunsByProject(ctx context.Context, projectDir string, since time.Time) ([]*domain.Run, error) {\n   233→\tvar rows *sql.Rows\n   234→\tvar err error\n   235→\tif since.IsZero() {\n   236→\t\trows, err = s.db.QueryContext(ctx,\n   237→\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   238→\t\t\tprojectDir)\n   239→\t} else {\n   240→\t\trows, err = s.db.QueryContext(ctx,\n   241→\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? AND started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   242→\t\t\tprojectDir, formatTime(since))\n   243→\t}\n   244→\tif err != nil {\n   245→\t\treturn nil, err\n   246→\t}\n   247→\tdefer rows.Close()\n   248→\treturn scanRuns(rows)\n   249→}\n   250→\n   251→func (s *Store) ListRunsFiltered(ctx context.Context, filter domain.RunListFilter) ([]*domain.Run, error) {\n   252→\tquery := `SELECT ` + runSelectCols + ` FROM runs WHERE 1=1`\n   253→\tvar args []interface{}\n   254→\n   255→\tif filter.ProjectDir != \"\" {\n   256→\t\tquery += ` AND project_dir = ?`\n   257→\t\targs = append(args, filter.ProjectDir)\n   258→\t}\n   259→\tif filter.State != \"\" {\n   260→\t\tquery += ` AND state = ?`\n   261→\t\targs = append(args, string(filter.State))\n   262→\t}\n   263→\tif filter.TaskID != \"\" {\n   264→\t\tquery += ` AND task_id = ?`\n   265→\t\targs = append(args, filter.TaskID)\n   266→\t}\n   267→\tif !filter.Since.IsZero() {\n   268→\t\tquery += ` AND (completed_at >= ? OR state IN ('running', 'pending'))`\n   269→\t\targs = append(args, formatTime(filter.Since))\n   270→\t}\n   271→\n   272→\tquery += ` ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`\n   273→\n   274→\tif filter.Limit > 0 {\n   275→\t\tquery += fmt.Sprintf(` LIMIT %d`, filter.Limit)\n   276→\t}\n   277→\n   278→\trows, err := s.db.QueryContext(ctx, query, args...)\n   279→\tif err != nil {\n   280→\t\treturn nil, err\n   281→\t}\n   282→\tdefer rows.Close()\n   283→\treturn scanRuns(rows)\n   284→}\n   285→\n   286→func (s *Store) ListProjects(ctx context.Context) ([]string, error) {\n   287→\trows, err := s.db.QueryContext(ctx,\n   288→\t\t`SELECT DISTINCT project_dir FROM runs WHERE project_dir != '' ORDER BY project_dir`)\n   289→\tif err != nil {\n   290→\t\treturn nil, err\n   291→\t}\n   292→\tdefer rows.Close()\n   293→\n   294→\tvar projects []string\n   295→\tfor rows.Next() {\n   296→\t\tvar dir string\n   297→\t\tif err := rows.Scan(&dir); err != nil {\n   298→\t\t\treturn nil, err\n   299→\t\t}\n   300→\t\tprojects = append(projects, dir)\n   301→\t}\n   302→\treturn projects, rows.Err()\n   303→}\n   304→\n   305→func (s *Store) ListChildRuns(ctx context.Context, parentRunID string) ([]*domain.Run, error) {\n   306→\trows, err := s.db.QueryContext(ctx,\n   307→\t\t`SELECT `+runSelectCols+` FROM runs WHERE parent_run_id = ? ORDER BY started_at ASC`,\n   308→\t\tparentRunID)\n   309→\tif err != nil {\n   310→\t\treturn nil, err\n   311→\t}\n   312→\tdefer rows.Close()\n   313→\treturn scanRuns(rows)\n   314→}\n   315→\n   316→func (s *Store) SaveCapture(ctx context.Context, runID string, exec *domain.StepExecution) error {\n   317→\t_, err := s.db.ExecContext(ctx,\n   318→\t\t`INSERT INTO step_executions (run_id, step_name, result, started_at, completed_at, logs, git_ref)\n   319→\t\t VALUES (?, ?, ?, ?, ?, ?, ?)`,\n   320→\t\trunID, exec.StepName, exec.Result,\n   321→\t\tformatTime(exec.StartedAt), formatTime(exec.CompletedAt),\n   322→\t\texec.Logs, exec.GitRef,\n   323→\t)\n   324→\treturn err\n   325→}\n   326→\n   327→func (s *Store) GetCaptures(ctx context.Context, runID string) ([]*domain.StepExecution, error) {\n   328→\trows, err := s.db.QueryContext(ctx,\n   329→\t\t`SELECT step_name, result, started_at, completed_at, COALESCE(logs,''), COALESCE(git_ref,'')\n   330→\t\t FROM step_executions WHERE run_id = ? ORDER BY id`, runID)\n   331→\tif err != nil {\n   332→\t\treturn nil, err\n   333→\t}\n   334→\tdefer rows.Close()\n   335→\n   336→\tvar execs []*domain.StepExecution\n   337→\tfor rows.Next() {\n   338→\t\te := &domain.StepExecution{}\n   339→\t\tvar startedAt, completedAt string\n   340→\t\tif err := rows.Scan(&e.StepName, &e.Result, &startedAt, &completedAt, &e.Logs, &e.GitRef); err != nil {\n   341→\t\t\treturn nil, err\n   342→\t\t}\n   343→\t\te.StartedAt = parseTime(startedAt)\n   344→\t\te.CompletedAt = parseTime(completedAt)\n   345→\t\texecs = append(execs, e)\n   346→\t}\n   347→\treturn execs, rows.Err()\n   348→}\n   349→\n   350→func (s *Store) SaveLogFile(ctx context.Context, entry *ports.LogFileEntry) error {\n   351→\t_, err := s.db.ExecContext(ctx,\n   352→\t\t`INSERT INTO log_files (run_id, step_name, file_type, file_path, file_size, created_at)\n   353→\t\t VALUES (?, ?, ?, ?, ?, ?)`,\n   354→\t\tentry.RunID, entry.StepName, entry.FileType, entry.FilePath, entry.FileSize,\n   355→\t\tformatTime(entry.CreatedAt),\n   356→\t)\n   357→\treturn err\n   358→}\n   359→\n   360→func (s *Store) GetLogFiles(ctx context.Context, runID string) ([]*ports.LogFileEntry, error) {\n   361→\trows, err := s.db.QueryContext(ctx,\n   362→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   363→\t\t FROM log_files WHERE run_id = ? ORDER BY id`, runID)\n   364→\tif err != nil {\n   365→\t\treturn nil, err\n   366→\t}\n   367→\tdefer rows.Close()\n   368→\treturn scanLogFiles(rows)\n   369→}\n   370→\n   371→func (s *Store) GetLogFilesByStep(ctx context.Context, runID, stepName string) ([]*ports.LogFileEntry, error) {\n   372→\trows, err := s.db.QueryContext(ctx,\n   373→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   374→\t\t FROM log_files WHERE run_id = ? AND step_name = ? ORDER BY id`, runID, stepName)\n   375→\tif err != nil {\n   376→\t\treturn nil, err\n   377→\t}\n   378→\tdefer rows.Close()\n   379→\treturn scanLogFiles(rows)\n   380→}\n   381→\n   382→func (s *Store) GetLogFileByType(ctx context.Context, runID, fileType string) ([]*ports.LogFileEntry, error) {\n   383→\trows, err := s.db.QueryContext(ctx,\n   384→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   385→\t\t FROM log_files WHERE run_id = ? AND file_type = ? ORDER BY id`, runID, fileType)\n   386→\tif err != nil {\n   387→\t\treturn nil, err\n   388→\t}\n   389→\tdefer rows.Close()\n   390→\treturn scanLogFiles(rows)\n   391→}\n   392→\n   393→func scanLogFiles(rows *sql.Rows) ([]*ports.LogFileEntry, error) {\n   394→\tvar entries []*ports.LogFileEntry\n   395→\tfor rows.Next() {\n   396→\t\te := &ports.LogFileEntry{}\n   397→\t\tvar createdAt string\n   398→\t\tif err := rows.Scan(&e.ID, &e.RunID, &e.StepName, &e.FileType, &e.FilePath, &e.FileSize, &createdAt); err != nil {\n   399→\t\t\treturn nil, err\n   400→\t\t}\n   401→\t\te.CreatedAt = parseTime(createdAt)\n   402→\t\tentries = append(entries, e)\n   403→\t}\n   404→\treturn entries, rows.Err()\n   405→}\n   406→\n   407→func (s *Store) SaveEvolution(ctx context.Context, entry *ports.EvolutionEntry) error {\n   408→\t_, err := s.db.ExecContext(ctx,\n   409→\t\t`INSERT INTO evolution_log (id, project_dir, workflow_name, trigger_run_id, created_at, classification, changes_json, knowledge_delta)\n   410→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,\n   411→\t\tentry.ID, entry.ProjectDir, entry.WorkflowName, entry.TriggerRunID,\n   412→\t\tformatTime(entry.CreatedAt), entry.Classification, entry.ChangesJSON, entry.KnowledgeDelta,\n   413→\t)\n   414→\treturn err\n   415→}\n   416→\n   417→func (s *Store) GetLastEvolution(ctx context.Context, projectDir, workflowName string) (*ports.EvolutionEntry, error) {\n   418→\trow := s.db.QueryRowContext(ctx,\n   419→\t\t`SELECT id, project_dir, workflow_name, trigger_run_id, created_at, COALESCE(classification,''), changes_json, COALESCE(knowledge_delta,'')\n   420→\t\t FROM evolution_log WHERE project_dir = ? AND workflow_name = ? ORDER BY created_at DESC LIMIT 1`,\n   421→\t\tprojectDir, workflowName)\n   422→\n   423→\tentry := &ports.EvolutionEntry{}\n   424→\tvar createdAt string\n   425→\terr := row.Scan(&entry.ID, &entry.ProjectDir, &entry.WorkflowName, &entry.TriggerRunID,\n   426→\t\t&createdAt, &entry.Classification, &entry.ChangesJSON, &entry.KnowledgeDelta)\n   427→\tif err == sql.ErrNoRows {\n   428→\t\treturn nil, nil\n   429→\t}\n   430→\tif err != nil {\n   431→\t\treturn nil, err\n   432→\t}\n   433→\tentry.CreatedAt = parseTime(createdAt)\n   434→\treturn entry, nil\n   435→}\n   436→\n   437→func (s *Store) ListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error) {\n   438→\tvar rows *sql.Rows\n   439→\tvar err error\n   440→\n   441→\tif sinceRunID == \"\" {\n   442→\t\trows, err = s.db.QueryContext(ctx,\n   443→\t\t\t`SELECT `+runSelectCols+`\n   444→\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? ORDER BY started_at ASC`,\n   445→\t\t\tprojectDir, workflowName)\n   446→\t} else {\n   447→\t\trows, err = s.db.QueryContext(ctx,\n   448→\t\t\t`SELECT `+runSelectCols+`\n   449→\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? AND started_at > (SELECT started_at FROM runs WHERE id = ?)\n   450→\t\t\t ORDER BY started_at ASC`,\n   451→\t\t\tprojectDir, workflowName, sinceRunID)\n   452→\t}\n   453→\tif err != nil {\n   454→\t\treturn nil, err\n   455→\t}\n   456→\tdefer rows.Close()\n   457→\treturn scanRuns(rows)\n   458→}\n   459→\n   460→\n   461→func (s *Store) FailStaleRuns(ctx context.Context) (int64, error) {\n   462→\tnow := formatTime(time.Now())\n   463→\tres, err := s.db.ExecContext(ctx,\n   464→\t\t`UPDATE runs SET state = 'failed', completed_at = ?, error_message = 'daemon restarted while run was active'\n   465→\t\t WHERE state IN ('pending', 'running')`,\n   466→\t\tnow,\n   467→\t)\n   468→\tif err != nil {\n   469→\t\treturn 0, err\n   470→\t}\n   471→\treturn res.RowsAffected()\n   472→}\n   473→\n   474→func formatTime(t time.Time) string {\n   475→\tif t.IsZero() {\n   476→\t\treturn \"\"\n   477→\t}\n   478→\treturn t.Format(time.RFC3339Nano)\n   479→}\n   480→\n   481→func parseTime(s string) time.Time {\n   482→\tif s == \"\" {\n   483→\t\treturn time.Time{}\n   484→\t}\n   485→\tt, _ := time.Parse(time.RFC3339Nano, s)\n   486→\treturn t\n   487→}\n   488→\n   489→func boolToInt(b bool) int {\n   490→\tif b {\n   491→\t\treturn 1\n   492→\t}\n   493→\treturn 0\n   494→}\n   495→\n   496→const maxErrorMessageLen = 1000\n   497→\n   498→// truncateErrorMessage caps s to maxErrorMessageLen characters to prevent\n   499→// oversized agent output dumps from bloating the database. Full error\n   500→// details remain available in step logs.\n   501→func truncateErrorMessage(s string) string {\n   502→\tif len(s) <= maxErrorMessageLen {\n   503→\t\treturn s\n   504→\t}\n   505→\treturn s[:maxErrorMessageLen] + \"... (truncated)\"\n   506→}\n   507→"}]},"parent_tool_use_id":null,"session_id":"2dbae28e-0bf0-425e-bc1b-65ee06862096","uuid":"a92aeea6-1047-4dde-a8af-4333bf0e9e33","timestamp":"2026-03-18T21:55:59.946Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/sqlite/store.go","content":"package sqlite\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t_ \"modernc.org/sqlite\"\n)\n\ntype Store struct {\n\tdb *sql.DB\n}\n\nfunc NewStore(dsn string) (*Store, error) {\n\tdb, err := sql.Open(\"sqlite\", dsn)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n\t}\n\n\t// Enable WAL mode for concurrent read/write access\n\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n\n\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n\n\t// Serialize all Go-side access through a single connection so SQLite\n\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n\tdb.SetMaxOpenConns(1)\n\n\tif err := migrate(db); err != nil {\n\t\tdb.Close()\n\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n\t}\n\n\treturn &Store{db: db}, nil\n}\n\nfunc (s *Store) Close() error {\n\treturn s.db.Close()\n}\n\nfunc migrate(db *sql.DB) error {\n\t_, err := db.Exec(`\n\t\tCREATE TABLE IF NOT EXISTS runs (\n\t\t\tid TEXT PRIMARY KEY,\n\t\t\tworkflow_name TEXT NOT NULL,\n\t\t\tstate TEXT NOT NULL,\n\t\t\tactive_steps TEXT,\n\t\t\tstarted_at TEXT,\n\t\t\tcompleted_at TEXT\n\t\t);\n\t\tCREATE TABLE IF NOT EXISTS step_executions (\n\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n\t\t\trun_id TEXT NOT NULL,\n\t\t\tstep_name TEXT NOT NULL,\n\t\t\tresult TEXT,\n\t\t\tstarted_at TEXT NOT NULL,\n\t\t\tcompleted_at TEXT,\n\t\t\tlogs TEXT,\n\t\t\tgit_ref TEXT,\n\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n\t\t);\n\t`)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// Evolution schema additions (idempotent)\n\talterStmts := []string{\n\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n\t\t`ALTER TABLE runs ADD COLUMN title TEXT NOT NULL DEFAULT ''`,\n\t\t`ALTER TABLE runs ADD COLUMN is_host INTEGER NOT NULL DEFAULT 0`,\n\t\t`ALTER TABLE runs ADD COLUMN parent_run_id TEXT NOT NULL DEFAULT ''`,\n\t\t`ALTER TABLE runs ADD COLUMN task_id TEXT NOT NULL DEFAULT ''`,\n\t\t`ALTER TABLE runs ADD COLUMN task_title TEXT NOT NULL DEFAULT ''`,\n\t}\n\tfor _, stmt := range alterStmts {\n\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n\t}\n\n\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n\t\trun_id TEXT NOT NULL,\n\t\tstep_name TEXT,\n\t\tfile_type TEXT NOT NULL,\n\t\tfile_path TEXT NOT NULL,\n\t\tfile_size INTEGER,\n\t\tcreated_at TEXT NOT NULL,\n\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n\t)`)\n\tif errLog != nil {\n\t\treturn errLog\n\t}\n\n\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n\t\trun_id TEXT PRIMARY KEY,\n\t\tbranch TEXT NOT NULL,\n\t\tproject TEXT NOT NULL,\n\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n\t\tenqueued_at TEXT NOT NULL,\n\t\tcompleted_at TEXT\n\t)`)\n\tif errMQ != nil {\n\t\treturn errMQ\n\t}\n\n\t// v2: Task-oriented migration — creates tasks/attempts tables,\n\t// populates from existing runs, moves log files.\n\tif err := migrateV2(db); err != nil {\n\t\treturn fmt.Errorf(\"v2 migration: %w\", err)\n\t}\n\n\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n\t\tid TEXT PRIMARY KEY,\n\t\tproject_dir TEXT NOT NULL,\n\t\tworkflow_name TEXT NOT NULL,\n\t\ttrigger_run_id TEXT NOT NULL,\n\t\tcreated_at TEXT NOT NULL,\n\t\tclassification TEXT,\n\t\tchanges_json TEXT NOT NULL,\n\t\tknowledge_delta TEXT\n\t)`)\n\tif err2 != nil {\n\t\treturn err2\n\t}\n\n\treturn nil\n}\n\nfunc (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n\t_, err := s.db.ExecContext(ctx,\n\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept, title, is_host, parent_run_id, task_id, task_title)\n\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, truncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID, run.TaskTitle,\n\t)\n\treturn err\n}\n\n// runSelectCols is the standard column list for scanning a Run row.\nconst runSelectCols = `id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,''), COALESCE(is_host,0), COALESCE(parent_run_id,''), COALESCE(task_id,''), COALESCE(task_title,'')`\n\n// scanRun scans a single row into a *domain.Run.\nfunc scanRun(scanner interface{ Scan(...any) error }) (*domain.Run, error) {\n\trun := &domain.Run{}\n\tvar activeSteps, startedAt, completedAt string\n\tvar containerKept, isHost int\n\terr := scanner.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title, &isHost, &run.ParentRunID, &run.TaskID, &run.TaskTitle)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\trun.SetActiveStepsFromString(activeSteps)\n\trun.StartedAt = parseTime(startedAt)\n\trun.CompletedAt = parseTime(completedAt)\n\trun.ContainerKept = containerKept != 0\n\trun.IsHost = isHost != 0\n\treturn run, nil\n}\n\nfunc (s *Store) GetRun(ctx context.Context, id string) (*domain.Run, error) {\n\trow := s.db.QueryRowContext(ctx,\n\t\t`SELECT `+runSelectCols+` FROM runs WHERE id = ?`, id)\n\n\trun, err := scanRun(row)\n\tif err == sql.ErrNoRows {\n\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n\t}\n\treturn run, err\n}\n\nfunc (s *Store) UpdateRun(ctx context.Context, run *domain.Run) error {\n\t_, err := s.db.ExecContext(ctx,\n\t\t`UPDATE runs SET state = ?, active_steps = ?, started_at = ?, completed_at = ?, error_message = ?, container_id = ?, base_sha = ?, container_kept = ?, title = ?, is_host = ?, parent_run_id = ?, task_id = ?, task_title = ? WHERE id = ?`,\n\t\tstring(run.State), run.ActiveStepsString(),\n\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt),\n\t\ttruncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID, run.TaskTitle, run.ID,\n\t)\n\treturn err\n}\n\nfunc (s *Store) DeleteRun(ctx context.Context, id string) error {\n\t_, err := s.db.ExecContext(ctx, `DELETE FROM step_executions WHERE run_id = ?`, id)\n\tif err != nil {\n\t\treturn err\n\t}\n\t_, err = s.db.ExecContext(ctx, `DELETE FROM runs WHERE id = ?`, id)\n\treturn err\n}\n\nfunc (s *Store) ListRuns(ctx context.Context, since time.Time) ([]*domain.Run, error) {\n\tvar rows *sql.Rows\n\tvar err error\n\tif since.IsZero() {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT `+runSelectCols+` FROM runs ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`)\n\t} else {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n\t\t\tformatTime(since))\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanRuns(rows)\n}\n\n// scanRuns scans all rows into a []*domain.Run slice.\nfunc scanRuns(rows *sql.Rows) ([]*domain.Run, error) {\n\tvar runs []*domain.Run\n\tfor rows.Next() {\n\t\trun, err := scanRun(rows)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\truns = append(runs, run)\n\t}\n\treturn runs, rows.Err()\n}\n\nfunc (s *Store) ListRunsByProject(ctx context.Context, projectDir string, since time.Time) ([]*domain.Run, error) {\n\tvar rows *sql.Rows\n\tvar err error\n\tif since.IsZero() {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n\t\t\tprojectDir)\n\t} else {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? AND started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n\t\t\tprojectDir, formatTime(since))\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanRuns(rows)\n}\n\nfunc (s *Store) ListRunsFiltered(ctx context.Context, filter domain.RunListFilter) ([]*domain.Run, error) {\n\tquery := `SELECT ` + runSelectCols + ` FROM runs WHERE 1=1`\n\tvar args []interface{}\n\n\tif filter.ProjectDir != \"\" {\n\t\tquery += ` AND project_dir = ?`\n\t\targs = append(args, filter.ProjectDir)\n\t}\n\tif filter.State != \"\" {\n\t\tquery += ` AND state = ?`\n\t\targs = append(args, string(filter.State))\n\t}\n\tif filter.TaskID != \"\" {\n\t\tquery += ` AND task_id = ?`\n\t\targs = append(args, filter.TaskID)\n\t}\n\tif !filter.Since.IsZero() {\n\t\tquery += ` AND (completed_at >= ? OR state IN ('running', 'pending'))`\n\t\targs = append(args, formatTime(filter.Since))\n\t}\n\n\tquery += ` ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`\n\n\tif filter.Limit > 0 {\n\t\tquery += fmt.Sprintf(` LIMIT %d`, filter.Limit)\n\t}\n\n\trows, err := s.db.QueryContext(ctx, query, args...)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanRuns(rows)\n}\n\nfunc (s *Store) ListProjects(ctx context.Context) ([]string, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT DISTINCT project_dir FROM runs WHERE project_dir != '' ORDER BY project_dir`)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\n\tvar projects []string\n\tfor rows.Next() {\n\t\tvar dir string\n\t\tif err := rows.Scan(&dir); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tprojects = append(projects, dir)\n\t}\n\treturn projects, rows.Err()\n}\n\nfunc (s *Store) ListChildRuns(ctx context.Context, parentRunID string) ([]*domain.Run, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT `+runSelectCols+` FROM runs WHERE parent_run_id = ? ORDER BY started_at ASC`,\n\t\tparentRunID)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanRuns(rows)\n}\n\nfunc (s *Store) SaveCapture(ctx context.Context, runID string, exec *domain.StepExecution) error {\n\t_, err := s.db.ExecContext(ctx,\n\t\t`INSERT INTO step_executions (run_id, step_name, result, started_at, completed_at, logs, git_ref)\n\t\t VALUES (?, ?, ?, ?, ?, ?, ?)`,\n\t\trunID, exec.StepName, exec.Result,\n\t\tformatTime(exec.StartedAt), formatTime(exec.CompletedAt),\n\t\texec.Logs, exec.GitRef,\n\t)\n\treturn err\n}\n\nfunc (s *Store) GetCaptures(ctx context.Context, runID string) ([]*domain.StepExecution, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT step_name, result, started_at, completed_at, COALESCE(logs,''), COALESCE(git_ref,'')\n\t\t FROM step_executions WHERE run_id = ? ORDER BY id`, runID)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\n\tvar execs []*domain.StepExecution\n\tfor rows.Next() {\n\t\te := &domain.StepExecution{}\n\t\tvar startedAt, completedAt string\n\t\tif err := rows.Scan(&e.StepName, &e.Result, &startedAt, &completedAt, &e.Logs, &e.GitRef); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\te.StartedAt = parseTime(startedAt)\n\t\te.CompletedAt = parseTime(completedAt)\n\t\texecs = append(execs, e)\n\t}\n\treturn execs, rows.Err()\n}\n\nfunc (s *Store) SaveLogFile(ctx context.Context, entry *ports.LogFileEntry) error {\n\t_, err := s.db.ExecContext(ctx,\n\t\t`INSERT INTO log_files (run_id, step_name, file_type, file_path, file_size, created_at)\n\t\t VALUES (?, ?, ?, ?, ?, ?)`,\n\t\tentry.RunID, entry.StepName, entry.FileType, entry.FilePath, entry.FileSize,\n\t\tformatTime(entry.CreatedAt),\n\t)\n\treturn err\n}\n\nfunc (s *Store) GetLogFiles(ctx context.Context, runID string) ([]*ports.LogFileEntry, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n\t\t FROM log_files WHERE run_id = ? ORDER BY id`, runID)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanLogFiles(rows)\n}\n\nfunc (s *Store) GetLogFilesByStep(ctx context.Context, runID, stepName string) ([]*ports.LogFileEntry, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n\t\t FROM log_files WHERE run_id = ? AND step_name = ? ORDER BY id`, runID, stepName)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanLogFiles(rows)\n}\n\nfunc (s *Store) GetLogFileByType(ctx context.Context, runID, fileType string) ([]*ports.LogFileEntry, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n\t\t FROM log_files WHERE run_id = ? AND file_type = ? ORDER BY id`, runID, fileType)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanLogFiles(rows)\n}\n\nfunc scanLogFiles(rows *sql.Rows) ([]*ports.LogFileEntry, error) {\n\tvar entries []*ports.LogFileEntry\n\tfor rows.Next() {\n\t\te := &ports.LogFileEntry{}\n\t\tvar createdAt string\n\t\tif err := rows.Scan(&e.ID, &e.RunID, &e.StepName, &e.FileType, &e.FilePath, &e.FileSize, &createdAt); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\te.CreatedAt = parseTime(createdAt)\n\t\tentries = append(entries, e)\n\t}\n\treturn entries, rows.Err()\n}\n\nfunc (s *Store) SaveEvolution(ctx context.Context, entry *ports.EvolutionEntry) error {\n\t_, err := s.db.ExecContext(ctx,\n\t\t`INSERT INTO evolution_log (id, project_dir, workflow_name, trigger_run_id, created_at, classification, changes_json, knowledge_delta)\n\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,\n\t\tentry.ID, entry.ProjectDir, entry.WorkflowName, entry.TriggerRunID,\n\t\tformatTime(entry.CreatedAt), entry.Classification, entry.ChangesJSON, entry.KnowledgeDelta,\n\t)\n\treturn err\n}\n\nfunc (s *Store) GetLastEvolution(ctx context.Context, projectDir, workflowName string) (*ports.EvolutionEntry, error) {\n\trow := s.db.QueryRowContext(ctx,\n\t\t`SELECT id, project_dir, workflow_name, trigger_run_id, created_at, COALESCE(classification,''), changes_json, COALESCE(knowledge_delta,'')\n\t\t FROM evolution_log WHERE project_dir = ? AND workflow_name = ? ORDER BY created_at DESC LIMIT 1`,\n\t\tprojectDir, workflowName)\n\n\tentry := &ports.EvolutionEntry{}\n\tvar createdAt string\n\terr := row.Scan(&entry.ID, &entry.ProjectDir, &entry.WorkflowName, &entry.TriggerRunID,\n\t\t&createdAt, &entry.Classification, &entry.ChangesJSON, &entry.KnowledgeDelta)\n\tif err == sql.ErrNoRows {\n\t\treturn nil, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tentry.CreatedAt = parseTime(createdAt)\n\treturn entry, nil\n}\n\nfunc (s *Store) ListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error) {\n\tvar rows *sql.Rows\n\tvar err error\n\n\tif sinceRunID == \"\" {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT `+runSelectCols+`\n\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? ORDER BY started_at ASC`,\n\t\t\tprojectDir, workflowName)\n\t} else {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT `+runSelectCols+`\n\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? AND started_at > (SELECT started_at FROM runs WHERE id = ?)\n\t\t\t ORDER BY started_at ASC`,\n\t\t\tprojectDir, workflowName, sinceRunID)\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanRuns(rows)\n}\n\n\nfunc (s *Store) FailStaleRuns(ctx context.Context) (int64, error) {\n\tnow := formatTime(time.Now())\n\tres, err := s.db.ExecContext(ctx,\n\t\t`UPDATE runs SET state = 'failed', completed_at = ?, error_message = 'daemon restarted while run was active'\n\t\t WHERE state IN ('pending', 'running')`,\n\t\tnow,\n\t)\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\treturn res.RowsAffected()\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(time.RFC3339Nano)\n}\n\nfunc parseTime(s string) time.Time {\n\tif s == \"\" {\n\t\treturn time.Time{}\n\t}\n\tt, _ := time.Parse(time.RFC3339Nano, s)\n\treturn t\n}\n\nfunc boolToInt(b bool) int {\n\tif b {\n\t\treturn 1\n\t}\n\treturn 0\n}\n\nconst maxErrorMessageLen = 1000\n\n// truncateErrorMessage caps s to maxErrorMessageLen characters to prevent\n// oversized agent output dumps from bloating the database. Full error\n// details remain available in step logs.\nfunc truncateErrorMessage(s string) string {\n\tif len(s) <= maxErrorMessageLen {\n\t\treturn s\n\t}\n\treturn s[:maxErrorMessageLen] + \"... (truncated)\"\n}\n","numLines":507,"startLine":1,"totalLines":507}}}
