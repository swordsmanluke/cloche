{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Dugorf641Q9ReevxEK7gN5","type":"tool_result","content":"     1→package domain\n     2→\n     3→import (\n     4→\t\"strings\"\n     5→\t\"time\"\n     6→)\n     7→\n     8→type RunState string\n     9→\n    10→const (\n    11→\tRunStatePending   RunState = \"pending\"\n    12→\tRunStateRunning   RunState = \"running\"\n    13→\tRunStateSucceeded RunState = \"succeeded\"\n    14→\tRunStateFailed    RunState = \"failed\"\n    15→\tRunStateCancelled RunState = \"cancelled\"\n    16→)\n    17→\n    18→// RunListFilter holds optional filters for listing runs.\n    19→type RunListFilter struct {\n    20→\tProjectDir string\n    21→\tState      RunState\n    22→\tTaskID     string\n    23→\tLimit      int\n    24→\tSince      time.Time\n    25→}\n    26→\n    27→type StepExecution struct {\n    28→\tStepName    string\n    29→\tResult      string\n    30→\tStartedAt   time.Time\n    31→\tCompletedAt time.Time\n    32→\tLogs        string\n    33→\tGitRef      string // output state\n    34→}\n    35→\n    36→func (e *StepExecution) Duration() time.Duration {\n    37→\treturn e.CompletedAt.Sub(e.StartedAt)\n    38→}\n    39→\n    40→type Run struct {\n    41→\tID             string\n    42→\tWorkflowName   string\n    43→\tState          RunState\n    44→\tActiveSteps    []string\n    45→\tStepExecutions []*StepExecution\n    46→\tStartedAt      time.Time\n    47→\tCompletedAt    time.Time\n    48→\tProjectDir     string\n    49→\tErrorMessage   string\n    50→\tContainerID    string\n    51→\tBaseSHA        string // Git HEAD at run start, for result branch creation\n    52→\tContainerKept  bool   // true when the container was retained after run completion\n    53→\tTitle          string // One-line summary of the work being done\n    54→\tIsHost         bool   // true for host workflow runs (vs container runs)\n    55→\tParentRunID    string // ID of the parent (host) run, empty for top-level runs\n    56→\tTaskID         string // optional task ID this run is associated with\n    57→\tTaskTitle      string // title from the task tracker, for display after the task leaves the active snapshot\n    58→}\n    59→\n    60→func NewRun(id, workflowName string) *Run {\n    61→\treturn &Run{\n    62→\t\tID:           id,\n    63→\t\tWorkflowName: workflowName,\n    64→\t\tState:        RunStatePending,\n    65→\t}\n    66→}\n    67→\n    68→func (r *Run) Start() {\n    69→\tr.State = RunStateRunning\n    70→\tr.StartedAt = time.Now()\n    71→}\n    72→\n    73→func (r *Run) RecordStepStart(stepName string) {\n    74→\tr.ActiveSteps = append(r.ActiveSteps, stepName)\n    75→\tr.StepExecutions = append(r.StepExecutions, &StepExecution{\n    76→\t\tStepName:  stepName,\n    77→\t\tStartedAt: time.Now(),\n    78→\t})\n    79→}\n    80→\n    81→func (r *Run) RecordStepComplete(stepName, result string) {\n    82→\t// Remove from active steps\n    83→\tfor i, name := range r.ActiveSteps {\n    84→\t\tif name == stepName {\n    85→\t\t\tr.ActiveSteps = append(r.ActiveSteps[:i], r.ActiveSteps[i+1:]...)\n    86→\t\t\tbreak\n    87→\t\t}\n    88→\t}\n    89→\t// Mark execution complete\n    90→\tfor i := len(r.StepExecutions) - 1; i >= 0; i-- {\n    91→\t\tif r.StepExecutions[i].StepName == stepName && r.StepExecutions[i].CompletedAt.IsZero() {\n    92→\t\t\tr.StepExecutions[i].Result = result\n    93→\t\t\tr.StepExecutions[i].CompletedAt = time.Now()\n    94→\t\t\treturn\n    95→\t\t}\n    96→\t}\n    97→}\n    98→\n    99→// ActiveStepsString returns a comma-separated representation of active steps\n   100→// for backward-compatible serialization.\n   101→func (r *Run) ActiveStepsString() string {\n   102→\treturn strings.Join(r.ActiveSteps, \",\")\n   103→}\n   104→\n   105→// SetActiveStepsFromString parses a comma-separated string into ActiveSteps.\n   106→func (r *Run) SetActiveStepsFromString(s string) {\n   107→\tif s == \"\" {\n   108→\t\tr.ActiveSteps = nil\n   109→\t\treturn\n   110→\t}\n   111→\tr.ActiveSteps = strings.Split(s, \",\")\n   112→}\n   113→\n   114→func (r *Run) Complete(state RunState) {\n   115→\tr.State = state\n   116→\tr.CompletedAt = time.Now()\n   117→}\n   118→\n   119→func (r *Run) Fail(msg string) {\n   120→\tr.State = RunStateFailed\n   121→\tr.CompletedAt = time.Now()\n   122→\tr.ErrorMessage = msg\n   123→}\n   124→\n   125→// FindFirstFailedStep returns the name of the first step that produced a\n   126→// failure result (fail/error) in the run's step executions.\n   127→// Returns empty string if no failed step is found.\n   128→func (r *Run) FindFirstFailedStep() string {\n   129→\tfor _, exec := range r.StepExecutions {\n   130→\t\tif exec.Result == \"fail\" || exec.Result == \"error\" {\n   131→\t\t\treturn exec.StepName\n   132→\t\t}\n   133→\t}\n   134→\treturn \"\"\n   135→}\n   136→\n   137→// stateSeverity returns a severity score for terminal RunStates.\n   138→// Higher values indicate worse outcomes.\n   139→func stateSeverity(s RunState) int {\n   140→\tswitch s {\n   141→\tcase RunStateSucceeded:\n   142→\t\treturn 0\n   143→\tcase RunStateCancelled:\n   144→\t\treturn 1\n   145→\tcase RunStateFailed:\n   146→\t\treturn 2\n   147→\tdefault:\n   148→\t\treturn -1\n   149→\t}\n   150→}\n   151→\n   152→// WorseState returns the more severe of two terminal RunStates.\n   153→// Failed is worse than cancelled, which is worse than succeeded.\n   154→func WorseState(a, b RunState) RunState {\n   155→\tif stateSeverity(b) > stateSeverity(a) {\n   156→\t\treturn b\n   157→\t}\n   158→\treturn a\n   159→}\n   160→\n   161→// TaskAggregateStatus computes the aggregate status for a group of runs\n   162→// representing attempts at a task. Active statuses (running, pending) outweigh\n   163→// terminal ones. Among terminal runs, host runs (which represent the full\n   164→// attempt including finalize) take precedence over child container runs.\n   165→// If no host runs exist, the most recently started run determines the result.\n   166→func TaskAggregateStatus(runs []*Run) RunState {\n   167→\tif len(runs) == 0 {\n   168→\t\treturn RunStatePending\n   169→\t}\n   170→\n   171→\t// Active statuses outweigh terminal ones. Prefer running over pending.\n   172→\thasRunning := false\n   173→\thasPending := false\n   174→\tfor _, r := range runs {\n   175→\t\tswitch r.State {\n   176→\t\tcase RunStateRunning:\n   177→\t\t\thasRunning = true\n   178→\t\tcase RunStatePending:\n   179→\t\t\thasPending = true\n   180→\t\t}\n   181→\t}\n   182→\tif hasRunning {\n   183→\t\treturn RunStateRunning\n   184→\t}\n   185→\tif hasPending {\n   186→\t\treturn RunStatePending\n   187→\t}\n   188→\n   189→\t// All runs are terminal. Prefer the most recently started host run,\n   190→\t// since it reflects the full attempt outcome (including finalize).\n   191→\t// Child container runs start after their parent, so naive most-recent\n   192→\t// selection would incorrectly pick a succeeded child over a failed host.\n   193→\tvar latestHost *Run\n   194→\tvar latest *Run\n   195→\tfor _, r := range runs {\n   196→\t\tif r.IsHost && (latestHost == nil || r.StartedAt.After(latestHost.StartedAt)) {\n   197→\t\t\tlatestHost = r\n   198→\t\t}\n   199→\t\tif latest == nil || r.StartedAt.After(latest.StartedAt) {\n   200→\t\t\tlatest = r\n   201→\t\t}\n   202→\t}\n   203→\tif latestHost != nil {\n   204→\t\treturn latestHost.State\n   205→\t}\n   206→\treturn latest.State\n   207→}\n   208→"}]},"parent_tool_use_id":null,"session_id":"626b953b-834b-408b-8546-061c6822e958","uuid":"d43d5699-3f9e-42d7-b0fb-57b3dbca14d3","timestamp":"2026-03-18T18:20:01.162Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/domain/run.go","content":"package domain\n\nimport (\n\t\"strings\"\n\t\"time\"\n)\n\ntype RunState string\n\nconst (\n\tRunStatePending   RunState = \"pending\"\n\tRunStateRunning   RunState = \"running\"\n\tRunStateSucceeded RunState = \"succeeded\"\n\tRunStateFailed    RunState = \"failed\"\n\tRunStateCancelled RunState = \"cancelled\"\n)\n\n// RunListFilter holds optional filters for listing runs.\ntype RunListFilter struct {\n\tProjectDir string\n\tState      RunState\n\tTaskID     string\n\tLimit      int\n\tSince      time.Time\n}\n\ntype StepExecution struct {\n\tStepName    string\n\tResult      string\n\tStartedAt   time.Time\n\tCompletedAt time.Time\n\tLogs        string\n\tGitRef      string // output state\n}\n\nfunc (e *StepExecution) Duration() time.Duration {\n\treturn e.CompletedAt.Sub(e.StartedAt)\n}\n\ntype Run struct {\n\tID             string\n\tWorkflowName   string\n\tState          RunState\n\tActiveSteps    []string\n\tStepExecutions []*StepExecution\n\tStartedAt      time.Time\n\tCompletedAt    time.Time\n\tProjectDir     string\n\tErrorMessage   string\n\tContainerID    string\n\tBaseSHA        string // Git HEAD at run start, for result branch creation\n\tContainerKept  bool   // true when the container was retained after run completion\n\tTitle          string // One-line summary of the work being done\n\tIsHost         bool   // true for host workflow runs (vs container runs)\n\tParentRunID    string // ID of the parent (host) run, empty for top-level runs\n\tTaskID         string // optional task ID this run is associated with\n\tTaskTitle      string // title from the task tracker, for display after the task leaves the active snapshot\n}\n\nfunc NewRun(id, workflowName string) *Run {\n\treturn &Run{\n\t\tID:           id,\n\t\tWorkflowName: workflowName,\n\t\tState:        RunStatePending,\n\t}\n}\n\nfunc (r *Run) Start() {\n\tr.State = RunStateRunning\n\tr.StartedAt = time.Now()\n}\n\nfunc (r *Run) RecordStepStart(stepName string) {\n\tr.ActiveSteps = append(r.ActiveSteps, stepName)\n\tr.StepExecutions = append(r.StepExecutions, &StepExecution{\n\t\tStepName:  stepName,\n\t\tStartedAt: time.Now(),\n\t})\n}\n\nfunc (r *Run) RecordStepComplete(stepName, result string) {\n\t// Remove from active steps\n\tfor i, name := range r.ActiveSteps {\n\t\tif name == stepName {\n\t\t\tr.ActiveSteps = append(r.ActiveSteps[:i], r.ActiveSteps[i+1:]...)\n\t\t\tbreak\n\t\t}\n\t}\n\t// Mark execution complete\n\tfor i := len(r.StepExecutions) - 1; i >= 0; i-- {\n\t\tif r.StepExecutions[i].StepName == stepName && r.StepExecutions[i].CompletedAt.IsZero() {\n\t\t\tr.StepExecutions[i].Result = result\n\t\t\tr.StepExecutions[i].CompletedAt = time.Now()\n\t\t\treturn\n\t\t}\n\t}\n}\n\n// ActiveStepsString returns a comma-separated representation of active steps\n// for backward-compatible serialization.\nfunc (r *Run) ActiveStepsString() string {\n\treturn strings.Join(r.ActiveSteps, \",\")\n}\n\n// SetActiveStepsFromString parses a comma-separated string into ActiveSteps.\nfunc (r *Run) SetActiveStepsFromString(s string) {\n\tif s == \"\" {\n\t\tr.ActiveSteps = nil\n\t\treturn\n\t}\n\tr.ActiveSteps = strings.Split(s, \",\")\n}\n\nfunc (r *Run) Complete(state RunState) {\n\tr.State = state\n\tr.CompletedAt = time.Now()\n}\n\nfunc (r *Run) Fail(msg string) {\n\tr.State = RunStateFailed\n\tr.CompletedAt = time.Now()\n\tr.ErrorMessage = msg\n}\n\n// FindFirstFailedStep returns the name of the first step that produced a\n// failure result (fail/error) in the run's step executions.\n// Returns empty string if no failed step is found.\nfunc (r *Run) FindFirstFailedStep() string {\n\tfor _, exec := range r.StepExecutions {\n\t\tif exec.Result == \"fail\" || exec.Result == \"error\" {\n\t\t\treturn exec.StepName\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// stateSeverity returns a severity score for terminal RunStates.\n// Higher values indicate worse outcomes.\nfunc stateSeverity(s RunState) int {\n\tswitch s {\n\tcase RunStateSucceeded:\n\t\treturn 0\n\tcase RunStateCancelled:\n\t\treturn 1\n\tcase RunStateFailed:\n\t\treturn 2\n\tdefault:\n\t\treturn -1\n\t}\n}\n\n// WorseState returns the more severe of two terminal RunStates.\n// Failed is worse than cancelled, which is worse than succeeded.\nfunc WorseState(a, b RunState) RunState {\n\tif stateSeverity(b) > stateSeverity(a) {\n\t\treturn b\n\t}\n\treturn a\n}\n\n// TaskAggregateStatus computes the aggregate status for a group of runs\n// representing attempts at a task. Active statuses (running, pending) outweigh\n// terminal ones. Among terminal runs, host runs (which represent the full\n// attempt including finalize) take precedence over child container runs.\n// If no host runs exist, the most recently started run determines the result.\nfunc TaskAggregateStatus(runs []*Run) RunState {\n\tif len(runs) == 0 {\n\t\treturn RunStatePending\n\t}\n\n\t// Active statuses outweigh terminal ones. Prefer running over pending.\n\thasRunning := false\n\thasPending := false\n\tfor _, r := range runs {\n\t\tswitch r.State {\n\t\tcase RunStateRunning:\n\t\t\thasRunning = true\n\t\tcase RunStatePending:\n\t\t\thasPending = true\n\t\t}\n\t}\n\tif hasRunning {\n\t\treturn RunStateRunning\n\t}\n\tif hasPending {\n\t\treturn RunStatePending\n\t}\n\n\t// All runs are terminal. Prefer the most recently started host run,\n\t// since it reflects the full attempt outcome (including finalize).\n\t// Child container runs start after their parent, so naive most-recent\n\t// selection would incorrectly pick a succeeded child over a failed host.\n\tvar latestHost *Run\n\tvar latest *Run\n\tfor _, r := range runs {\n\t\tif r.IsHost && (latestHost == nil || r.StartedAt.After(latestHost.StartedAt)) {\n\t\t\tlatestHost = r\n\t\t}\n\t\tif latest == nil || r.StartedAt.After(latest.StartedAt) {\n\t\t\tlatest = r\n\t\t}\n\t}\n\tif latestHost != nil {\n\t\treturn latestHost.State\n\t}\n\treturn latest.State\n}\n","numLines":208,"startLine":1,"totalLines":208}}}
