{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019pb1Nr5ofjjNdE42UnWorU","type":"tool_result","content":"     1→package config\n     2→\n     3→import (\n     4→\t\"os\"\n     5→\t\"path/filepath\"\n     6→\n     7→\t\"github.com/BurntSushi/toml\"\n     8→)\n     9→\n    10→type DaemonConfig struct {\n    11→\tListen     string `toml:\"listen\"`\n    12→\tHTTP       string `toml:\"http\"`\n    13→\tImage      string `toml:\"image\"`\n    14→\tDB         string `toml:\"db\"`\n    15→\tRuntime    string `toml:\"runtime\"`\n    16→\tAgentPath  string `toml:\"agent_path\"`\n    17→\tLLMCommand string `toml:\"llm_command\"`\n    18→}\n    19→\n    20→type EvolutionConfig struct {\n    21→\tEnabled          bool   `toml:\"enabled\"`\n    22→\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n    23→\tMinConfidence    string `toml:\"min_confidence\"`\n    24→\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n    25→}\n    26→\n    27→type OrchestrationConfig struct {\n    28→\tEnabled     bool   `toml:\"enabled\"`\n    29→\tTracker     string `toml:\"tracker\"`\n    30→\tConcurrency int    `toml:\"concurrency\"`\n    31→\tWorkflow    string `toml:\"workflow\"`\n    32→}\n    33→\n    34→type Config struct {\n    35→\tDaemon        DaemonConfig        `toml:\"daemon\"`\n    36→\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n    37→\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n    38→}\n    39→\n    40→func defaults() Config {\n    41→\treturn Config{\n    42→\t\tEvolution: EvolutionConfig{\n    43→\t\t\tEnabled:          true,\n    44→\t\t\tDebounceSeconds:  30,\n    45→\t\t\tMinConfidence:    \"medium\",\n    46→\t\t\tMaxPromptBullets: 50,\n    47→\t\t},\n    48→\t\tOrchestration: OrchestrationConfig{\n    49→\t\t\tTracker:     \"beads\",\n    50→\t\t\tConcurrency: 1,\n    51→\t\t\tWorkflow:     \"develop\",\n    52→\t\t},\n    53→\t}\n    54→}\n    55→\n    56→// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    57→func Load(projectDir string) (*Config, error) {\n    58→\tcfg := defaults()\n    59→\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    60→\n    61→\tdata, err := os.ReadFile(path)\n    62→\tif os.IsNotExist(err) {\n    63→\t\treturn &cfg, nil\n    64→\t}\n    65→\tif err != nil {\n    66→\t\treturn nil, err\n    67→\t}\n    68→\n    69→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    70→\t\treturn nil, err\n    71→\t}\n    72→\treturn &cfg, nil\n    73→}\n    74→\n    75→// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n    76→// Returns defaults if the file does not exist.\n    77→func LoadGlobal() (*Config, error) {\n    78→\tcfg := defaults()\n    79→\n    80→\thome, err := os.UserHomeDir()\n    81→\tif err != nil {\n    82→\t\treturn &cfg, nil\n    83→\t}\n    84→\n    85→\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n    86→\tdata, err := os.ReadFile(path)\n    87→\tif os.IsNotExist(err) {\n    88→\t\treturn &cfg, nil\n    89→\t}\n    90→\tif err != nil {\n    91→\t\treturn nil, err\n    92→\t}\n    93→\n    94→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    95→\t\treturn nil, err\n    96→\t}\n    97→\treturn &cfg, nil\n    98→}\n    99→\n   100→// LoadGlobalFrom reads the global config from a specific path.\n   101→// Useful for testing.\n   102→func LoadGlobalFrom(path string) (*Config, error) {\n   103→\tcfg := defaults()\n   104→\n   105→\tdata, err := os.ReadFile(path)\n   106→\tif os.IsNotExist(err) {\n   107→\t\treturn &cfg, nil\n   108→\t}\n   109→\tif err != nil {\n   110→\t\treturn nil, err\n   111→\t}\n   112→\n   113→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   114→\t\treturn nil, err\n   115→\t}\n   116→\treturn &cfg, nil\n   117→}\n   118→"}]},"parent_tool_use_id":"toolu_0171or8tuBAMTNuu4D5KCz9Y","session_id":"3aec74ac-2937-4d7c-8866-02d0d682f058","uuid":"3b1c2ab3-245f-4b4c-88a0-5a9652f41daa"}
