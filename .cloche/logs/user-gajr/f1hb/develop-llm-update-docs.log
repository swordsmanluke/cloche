{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HajUgL9id4JMZ191D9Kyt1","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"os/exec\"\n    14→\t\"path/filepath\"\n    15→\t\"regexp\"\n    16→\t\"sort\"\n    17→\t\"strconv\"\n    18→\t\"strings\"\n    19→\t\"time\"\n    20→\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→)\n    26→\n    27→// HandlerOption configures optional Handler dependencies.\n    28→type HandlerOption func(*Handler)\n    29→\n    30→// WithContainerLogger sets the container runtime for fetching live logs.\n    31→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32→\treturn func(h *Handler) { h.container = c }\n    33→}\n    34→\n    35→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36→func WithContainerManager(c ContainerManager) HandlerOption {\n    37→\treturn func(h *Handler) { h.container = c }\n    38→}\n    39→\n    40→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42→\treturn func(h *Handler) { h.logBroadcast = b }\n    43→}\n    44→\n    45→// WithLogStore sets the log store for indexed log file lookups.\n    46→func WithLogStore(ls ports.LogStore) HandlerOption {\n    47→\treturn func(h *Handler) { h.logStore = ls }\n    48→}\n    49→\n    50→// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    51→func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    52→\treturn func(h *Handler) { h.orchestrateFn = fn }\n    53→}\n    54→\n    55→// OrchestratorController provides per-project orchestrator control.\n    56→type OrchestratorController interface {\n    57→\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    58→\tSetEnabled(dir string, enabled bool)\n    59→\tSetConcurrency(dir string, concurrency int)\n    60→}\n    61→\n    62→// WithOrchestrator sets the orchestrator controller for project-level control.\n    63→func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    64→\treturn func(h *Handler) { h.orchestrator = oc }\n    65→}\n    66→\n    67→//go:embed templates/*.html static/*\n    68→var content embed.FS\n    69→\n    70→// Handler serves the web dashboard.\n    71→// ContainerLogger can retrieve logs from a container by ID.\n    72→type ContainerLogger interface {\n    73→\tLogs(ctx context.Context, containerID string) (string, error)\n    74→}\n    75→\n    76→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    77→type ContainerManager interface {\n    78→\tContainerLogger\n    79→\tRemove(ctx context.Context, containerID string) error\n    80→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    81→}\n    82→\n    83→type Handler struct {\n    84→\tstore         ports.RunStore\n    85→\tcaptures      ports.CaptureStore\n    86→\tlogStore      ports.LogStore\n    87→\tcontainer     ContainerLogger\n    88→\tlogBroadcast  *logstream.Broadcaster\n    89→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    90→\torchestrator  OrchestratorController\n    91→\tpages         map[string]*template.Template\n    92→\tmux           *http.ServeMux\n    93→}\n    94→\n    95→// NewHandler creates a web dashboard handler.\n    96→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    97→\tfuncMap := template.FuncMap{\n    98→\t\t\"stateColor\":       stateColor,\n    99→\t\t\"healthColor\":      healthColor,\n   100→\t\t\"formatTime\":       formatTime,\n   101→\t\t\"formatDuration\":   formatDuration,\n   102→\t\t\"truncate\":         truncate,\n   103→\t\t\"shortContainerID\": shortContainerID,\n   104→\t}\n   105→\n   106→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   107→\tif err != nil {\n   108→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   109→\t}\n   110→\n   111→\tpages := map[string]*template.Template{}\n   112→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   113→\t\tclone, err := base.Clone()\n   114→\t\tif err != nil {\n   115→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   116→\t\t}\n   117→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   118→\t\tif err != nil {\n   119→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   120→\t\t}\n   121→\t\tpages[page] = clone\n   122→\t}\n   123→\n   124→\th := &Handler{\n   125→\t\tstore:    store,\n   126→\t\tcaptures: captures,\n   127→\t\tpages:    pages,\n   128→\t\tmux:      http.NewServeMux(),\n   129→\t}\n   130→\tfor _, opt := range opts {\n   131→\t\topt(h)\n   132→\t}\n   133→\n   134→\tstaticFS, err := fs.Sub(content, \"static\")\n   135→\tif err != nil {\n   136→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   137→\t}\n   138→\n   139→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   140→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   141→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   142→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   143→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   144→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   145→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   146→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   147→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   148→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   149→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   150→\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   151→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   152→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   153→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   154→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   155→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   156→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   157→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   158→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   159→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   160→\n   161→\treturn h, nil\n   162→}\n   163→\n   164→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   165→\th.mux.ServeHTTP(w, r)\n   166→}\n   167→\n   168→// --- HTML handlers ---\n   169→\n   170→// projectOverviewEntry holds data for a single project card on the landing page.\n   171→type projectOverviewEntry struct {\n   172→\tDir         string\n   173→\tLabel       string\n   174→\tHealth      domain.HealthResult\n   175→\tRecentRuns  []recentRunDot\n   176→\tActiveCount int\n   177→}\n   178→\n   179→// recentRunDot is a minimal representation of a run for the mini history display.\n   180→type recentRunDot struct {\n   181→\tID    string\n   182→\tState string\n   183→}\n   184→\n   185→const healthWindowSize = 10\n   186→\n   187→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   188→\tprojects, _ := h.store.ListProjects(r.Context())\n   189→\tlabels := projectLabels(projects)\n   190→\n   191→\tvar entries []projectOverviewEntry\n   192→\tfor _, dir := range projects {\n   193→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   194→\t\tif err != nil {\n   195→\t\t\tcontinue\n   196→\t\t}\n   197→\n   198→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   199→\t\trunValues := make([]domain.Run, len(runs))\n   200→\t\tfor i, rr := range runs {\n   201→\t\t\trunValues[i] = *rr\n   202→\t\t}\n   203→\n   204→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   205→\n   206→\t\t// Take the last N runs for the mini history (most recent first).\n   207→\t\tn := healthWindowSize\n   208→\t\tif n > len(runs) {\n   209→\t\t\tn = len(runs)\n   210→\t\t}\n   211→\t\tdots := make([]recentRunDot, n)\n   212→\t\tfor i := 0; i < n; i++ {\n   213→\t\t\tdots[i] = recentRunDot{\n   214→\t\t\t\tID:    runs[i].ID,\n   215→\t\t\t\tState: string(runs[i].State),\n   216→\t\t\t}\n   217→\t\t}\n   218→\n   219→\t\tvar activeCount int\n   220→\t\tfor _, rr := range runs {\n   221→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   222→\t\t\t\tactiveCount++\n   223→\t\t\t}\n   224→\t\t}\n   225→\n   226→\t\tentries = append(entries, projectOverviewEntry{\n   227→\t\t\tDir:         dir,\n   228→\t\t\tLabel:       labels[dir],\n   229→\t\t\tHealth:      health,\n   230→\t\t\tRecentRuns:  dots,\n   231→\t\t\tActiveCount: activeCount,\n   232→\t\t})\n   233→\t}\n   234→\n   235→\tsort.Slice(entries, func(i, j int) bool {\n   236→\t\treturn entries[i].Label < entries[j].Label\n   237→\t})\n   238→\n   239→\tdata := map[string]any{\n   240→\t\t\"Title\":    \"Projects\",\n   241→\t\t\"Projects\": entries,\n   242→\t}\n   243→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   244→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   245→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   246→\t}\n   247→}\n   248→\n   249→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   250→\tprojectFilter := r.URL.Query().Get(\"project\")\n   251→\n   252→\tvar runs []*domain.Run\n   253→\tvar err error\n   254→\tif projectFilter != \"\" {\n   255→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   256→\t} else {\n   257→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   258→\t}\n   259→\tif err != nil {\n   260→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   261→\t\treturn\n   262→\t}\n   263→\n   264→\tprojects, _ := h.store.ListProjects(r.Context())\n   265→\tlabels := projectLabels(projects)\n   266→\n   267→\t// Count retained containers per project\n   268→\tcontainerCounts := map[string]int{}\n   269→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   270→\tfor _, run := range allRuns {\n   271→\t\tif run.ContainerKept {\n   272→\t\t\tcontainerCounts[run.ProjectDir]++\n   273→\t\t}\n   274→\t}\n   275→\n   276→\tvar projectList []projectEntry\n   277→\tfor _, dir := range projects {\n   278→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   279→\t}\n   280→\tsort.Slice(projectList, func(i, j int) bool {\n   281→\t\treturn projectList[i].Label < projectList[j].Label\n   282→\t})\n   283→\n   284→\tdata := map[string]any{\n   285→\t\t\"Title\":         \"Runs\",\n   286→\t\t\"Runs\":          runs,\n   287→\t\t\"Projects\":      projectList,\n   288→\t\t\"ProjectFilter\": projectFilter,\n   289→\t\t\"ProjectLabels\": labels,\n   290→\t}\n   291→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   292→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   293→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   294→\t}\n   295→}\n   296→\n   297→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   298→\tdir, label, ok := h.resolveProjectDir(w, r)\n   299→\tif !ok {\n   300→\t\treturn\n   301→\t}\n   302→\n   303→\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   304→\tif err != nil {\n   305→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   306→\t\treturn\n   307→\t}\n   308→\n   309→\tprojects, _ := h.store.ListProjects(r.Context())\n   310→\tlabels := projectLabels(projects)\n   311→\n   312→\t// Count retained containers per project\n   313→\tcontainerCounts := map[string]int{}\n   314→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   315→\tfor _, run := range allRuns {\n   316→\t\tif run.ContainerKept {\n   317→\t\t\tcontainerCounts[run.ProjectDir]++\n   318→\t\t}\n   319→\t}\n   320→\n   321→\tvar projectList []projectEntry\n   322→\tfor _, d := range projects {\n   323→\t\tprojectList = append(projectList, projectEntry{Dir: d, Label: labels[d], ContainerCount: containerCounts[d]})\n   324→\t}\n   325→\tsort.Slice(projectList, func(i, j int) bool {\n   326→\t\treturn projectList[i].Label < projectList[j].Label\n   327→\t})\n   328→\n   329→\tdata := map[string]any{\n   330→\t\t\"Title\":         \"Runs — \" + label,\n   331→\t\t\"Runs\":          runs,\n   332→\t\t\"Projects\":      projectList,\n   333→\t\t\"ProjectFilter\": dir,\n   334→\t\t\"ProjectLabels\": labels,\n   335→\t}\n   336→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   337→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   338→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   339→\t}\n   340→}\n   341→\n   342→// stepEntry is a merged view of a step execution for the template.\n   343→type stepEntry struct {\n   344→\tIndex     int\n   345→\tStepName  string\n   346→\tResult    string\n   347→\tStartedAt time.Time\n   348→\tDuration  string\n   349→}\n   350→\n   351→// mergeCaptures collapses started/completed capture pairs into single entries.\n   352→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   353→\tvar entries []stepEntry\n   354→\t// Track pending started rows by step name (LIFO for retries)\n   355→\tpending := map[string]*domain.StepExecution{}\n   356→\n   357→\tfor _, c := range caps {\n   358→\t\tif c.Result == \"\" {\n   359→\t\t\t// step_started row\n   360→\t\t\tpending[c.StepName] = c\n   361→\t\t\tcontinue\n   362→\t\t}\n   363→\t\t// step_completed row — merge with pending started if available\n   364→\t\tstartedAt := c.StartedAt\n   365→\t\tif started := pending[c.StepName]; started != nil {\n   366→\t\t\tstartedAt = started.StartedAt\n   367→\t\t\tdelete(pending, c.StepName)\n   368→\t\t}\n   369→\t\tentries = append(entries, stepEntry{\n   370→\t\t\tIndex:     len(entries),\n   371→\t\t\tStepName:  c.StepName,\n   372→\t\t\tResult:    c.Result,\n   373→\t\t\tStartedAt: startedAt,\n   374→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   375→\t\t})\n   376→\t}\n   377→\n   378→\t// Append any started-but-not-completed steps (still running)\n   379→\tfor _, c := range caps {\n   380→\t\tif c.Result == \"\" {\n   381→\t\t\tif _, used := pending[c.StepName]; !used {\n   382→\t\t\t\tcontinue\n   383→\t\t\t}\n   384→\t\t\tentries = append(entries, stepEntry{\n   385→\t\t\t\tIndex:     len(entries),\n   386→\t\t\t\tStepName:  c.StepName,\n   387→\t\t\t\tStartedAt: c.StartedAt,\n   388→\t\t\t})\n   389→\t\t\tdelete(pending, c.StepName)\n   390→\t\t}\n   391→\t}\n   392→\n   393→\treturn entries\n   394→}\n   395→\n   396→// containerState inspects the container for a run and returns one of:\n   397→//   - \"running\"   – container exists and is running\n   398→//   - \"stopped\"   – container exists, not running, not kept\n   399→//   - \"available\" – container exists, not running, kept (can be deleted)\n   400→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   401→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   402→\tif run.ContainerID == \"\" {\n   403→\t\treturn \"removed\"\n   404→\t}\n   405→\tmgr, ok := h.container.(ContainerManager)\n   406→\tif !ok {\n   407→\t\treturn \"removed\"\n   408→\t}\n   409→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   410→\tif err != nil {\n   411→\t\treturn \"removed\"\n   412→\t}\n   413→\tif status.Running {\n   414→\t\treturn \"running\"\n   415→\t}\n   416→\tif run.ContainerKept {\n   417→\t\treturn \"available\"\n   418→\t}\n   419→\treturn \"stopped\"\n   420→}\n   421→\n   422→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   423→\tid := r.PathValue(\"id\")\n   424→\n   425→\trun, err := h.store.GetRun(r.Context(), id)\n   426→\tif err != nil {\n   427→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   428→\t\treturn\n   429→\t}\n   430→\n   431→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   432→\tif err != nil {\n   433→\t\tcaps = nil // non-fatal\n   434→\t}\n   435→\n   436→\tsteps := mergeCaptures(caps)\n   437→\n   438→\tdata := map[string]any{\n   439→\t\t\"Title\":          \"Run \" + run.ID,\n   440→\t\t\"Run\":            run,\n   441→\t\t\"Steps\":          steps,\n   442→\t\t\"Page\":           \"detail\",\n   443→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   444→\t}\n   445→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   446→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   447→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   448→\t}\n   449→}\n   450→\n   451→// --- JSON API handlers ---\n   452→\n   453→type apiRun struct {\n   454→\tID           string `json:\"id\"`\n   455→\tWorkflowName string `json:\"workflow_name\"`\n   456→\tProjectDir   string `json:\"project_dir\"`\n   457→\tProjectLabel string `json:\"project_label\"`\n   458→\tState        string `json:\"state\"`\n   459→\tStartedAt    string `json:\"started_at\"`\n   460→\tCompletedAt  string `json:\"completed_at\"`\n   461→\tContainerID  string `json:\"container_id\"`\n   462→\tErrorMessage string `json:\"error_message\"`\n   463→}\n   464→\n   465→type apiStep struct {\n   466→\tStepName    string `json:\"step_name\"`\n   467→\tResult      string `json:\"result\"`\n   468→\tStartedAt   string `json:\"started_at\"`\n   469→\tCompletedAt string `json:\"completed_at\"`\n   470→\tDuration    string `json:\"duration\"`\n   471→}\n   472→\n   473→type apiRunDetail struct {\n   474→\tapiRun\n   475→\tContainerState string    `json:\"container_state\"`\n   476→\tSteps          []apiStep `json:\"steps\"`\n   477→}\n   478→\n   479→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   480→\treturn apiRun{\n   481→\t\tID:           r.ID,\n   482→\t\tWorkflowName: r.WorkflowName,\n   483→\t\tProjectDir:   r.ProjectDir,\n   484→\t\tProjectLabel: labels[r.ProjectDir],\n   485→\t\tState:        string(r.State),\n   486→\t\tStartedAt:    formatTime(r.StartedAt),\n   487→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   488→\t\tContainerID:  r.ContainerID,\n   489→\t\tErrorMessage: r.ErrorMessage,\n   490→\t}\n   491→}\n   492→\n   493→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   494→\tprojectFilter := r.URL.Query().Get(\"project\")\n   495→\n   496→\tvar runs []*domain.Run\n   497→\tvar err error\n   498→\tif projectFilter != \"\" {\n   499→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   500→\t} else {\n   501→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   502→\t}\n   503→\tif err != nil {\n   504→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   505→\t\treturn\n   506→\t}\n   507→\n   508→\tprojects, _ := h.store.ListProjects(r.Context())\n   509→\tlabels := projectLabels(projects)\n   510→\n   511→\tresult := make([]apiRun, len(runs))\n   512→\tfor i, run := range runs {\n   513→\t\tresult[i] = toAPIRun(run, labels)\n   514→\t}\n   515→\n   516→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   517→\tjson.NewEncoder(w).Encode(result)\n   518→}\n   519→\n   520→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   521→\tprojects, err := h.store.ListProjects(r.Context())\n   522→\tif err != nil {\n   523→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   524→\t\treturn\n   525→\t}\n   526→\tlabels := projectLabels(projects)\n   527→\n   528→\ttype apiHealth struct {\n   529→\t\tStatus string `json:\"status\"`\n   530→\t\tPassed int    `json:\"passed\"`\n   531→\t\tFailed int    `json:\"failed\"`\n   532→\t\tTotal  int    `json:\"total\"`\n   533→\t}\n   534→\ttype apiProject struct {\n   535→\t\tDir         string    `json:\"dir\"`\n   536→\t\tLabel       string    `json:\"label\"`\n   537→\t\tHealth      apiHealth `json:\"health\"`\n   538→\t\tActiveCount int       `json:\"active_count\"`\n   539→\t}\n   540→\tresult := make([]apiProject, len(projects))\n   541→\tfor i, dir := range projects {\n   542→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   543→\t\trunValues := make([]domain.Run, len(runs))\n   544→\t\tfor j, rr := range runs {\n   545→\t\t\trunValues[j] = *rr\n   546→\t\t}\n   547→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   548→\t\tvar activeCount int\n   549→\t\tfor _, rr := range runs {\n   550→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   551→\t\t\t\tactiveCount++\n   552→\t\t\t}\n   553→\t\t}\n   554→\t\tresult[i] = apiProject{\n   555→\t\t\tDir:   dir,\n   556→\t\t\tLabel: labels[dir],\n   557→\t\t\tHealth: apiHealth{\n   558→\t\t\t\tStatus: string(health.Status),\n   559→\t\t\t\tPassed: health.Passed,\n   560→\t\t\t\tFailed: health.Failed,\n   561→\t\t\t\tTotal:  health.Total,\n   562→\t\t\t},\n   563→\t\t\tActiveCount: activeCount,\n   564→\t\t}\n   565→\t}\n   566→\n   567→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   568→\tjson.NewEncoder(w).Encode(result)\n   569→}\n   570→\n   571→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   572→\tid := r.PathValue(\"id\")\n   573→\n   574→\trun, err := h.store.GetRun(r.Context(), id)\n   575→\tif err != nil {\n   576→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   577→\t\treturn\n   578→\t}\n   579→\n   580→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   581→\tif err != nil {\n   582→\t\tcaps = nil\n   583→\t}\n   584→\n   585→\tprojects, _ := h.store.ListProjects(r.Context())\n   586→\tlabels := projectLabels(projects)\n   587→\n   588→\tmerged := mergeCaptures(caps)\n   589→\tsteps := make([]apiStep, len(merged))\n   590→\tfor i, e := range merged {\n   591→\t\tsteps[i] = apiStep{\n   592→\t\t\tStepName:  e.StepName,\n   593→\t\t\tResult:    e.Result,\n   594→\t\t\tStartedAt: formatTime(e.StartedAt),\n   595→\t\t\tDuration:  e.Duration,\n   596→\t\t}\n   597→\t}\n   598→\n   599→\tdetail := apiRunDetail{\n   600→\t\tapiRun:         toAPIRun(run, labels),\n   601→\t\tContainerState: h.containerState(r.Context(), run),\n   602→\t\tSteps:          steps,\n   603→\t}\n   604→\n   605→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   606→\tjson.NewEncoder(w).Encode(detail)\n   607→}\n   608→\n   609→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   610→\tid := r.PathValue(\"id\")\n   611→\tstep := r.PathValue(\"step\")\n   612→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   613→\n   614→\trun, err := h.store.GetRun(r.Context(), id)\n   615→\tif err != nil {\n   616→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   617→\t\treturn\n   618→\t}\n   619→\n   620→\t// Try log index first for fast lookup\n   621→\tif h.logStore != nil {\n   622→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   623→\t\tif err == nil && len(logFiles) > 0 {\n   624→\t\t\t// If type filter specified, narrow results\n   625→\t\t\tfor _, lf := range logFiles {\n   626→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   627→\t\t\t\t\tcontinue\n   628→\t\t\t\t}\n   629→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   630→\t\t\t\tif readErr == nil && len(data) > 0 {\n   631→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   632→\t\t\t\t\tw.Write(data)\n   633→\t\t\t\t\treturn\n   634→\t\t\t\t}\n   635→\t\t\t}\n   636→\t\t}\n   637→\t}\n   638→\n   639→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   640→\n   641→\t// Fall back to file path conventions\n   642→\t// If type is \"llm\", try llm-<step>.log\n   643→\tif logType == \"llm\" {\n   644→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   645→\t\tdata, err := os.ReadFile(llmPath)\n   646→\t\tif err == nil && len(data) > 0 {\n   647→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   648→\t\t\tw.Write(data)\n   649→\t\t\treturn\n   650→\t\t}\n   651→\t}\n   652→\n   653→\t// Try per-step output first, fall back to container.log, then live docker logs\n   654→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   655→\tdata, err := os.ReadFile(outputPath)\n   656→\tif err == nil && len(data) > 0 {\n   657→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   658→\t\tw.Write(data)\n   659→\t\treturn\n   660→\t}\n   661→\n   662→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   663→\tdata, err = os.ReadFile(containerLog)\n   664→\tif err == nil && len(data) > 0 {\n   665→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   666→\t\tw.Write(data)\n   667→\t\treturn\n   668→\t}\n   669→\n   670→\t// Last resort: try live docker logs from still-existing container\n   671→\tif h.container != nil && run.ContainerID != \"\" {\n   672→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   673→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   674→\t\t\tw.Write([]byte(logs))\n   675→\t\t\treturn\n   676→\t\t}\n   677→\t}\n   678→\n   679→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   680→}\n   681→\n   682→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   683→\tid := r.PathValue(\"id\")\n   684→\n   685→\trun, err := h.store.GetRun(r.Context(), id)\n   686→\tif err != nil {\n   687→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   688→\t\tw.WriteHeader(http.StatusNotFound)\n   689→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   690→\t\treturn\n   691→\t}\n   692→\n   693→\tmgr, ok := h.container.(ContainerManager)\n   694→\tif !ok || run.ContainerID == \"\" {\n   695→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   696→\t\tw.WriteHeader(http.StatusBadRequest)\n   697→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   698→\t\treturn\n   699→\t}\n   700→\n   701→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   702→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   703→\t\tw.WriteHeader(http.StatusInternalServerError)\n   704→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   705→\t\treturn\n   706→\t}\n   707→\n   708→\trun.ContainerKept = false\n   709→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   710→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   711→\t\tw.WriteHeader(http.StatusInternalServerError)\n   712→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   713→\t\treturn\n   714→\t}\n   715→\n   716→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   717→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   718→}\n   719→\n   720→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   721→\tlabel := r.PathValue(\"name\")\n   722→\n   723→\t// Resolve label back to project directory via the store.\n   724→\tprojects, _ := h.store.ListProjects(r.Context())\n   725→\tlabels := projectLabels(projects)\n   726→\tvar projectDir string\n   727→\tfor dir, l := range labels {\n   728→\t\tif l == label {\n   729→\t\t\tprojectDir = dir\n   730→\t\t\tbreak\n   731→\t\t}\n   732→\t}\n   733→\tif projectDir == \"\" {\n   734→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   735→\t\tw.WriteHeader(http.StatusNotFound)\n   736→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   737→\t\treturn\n   738→\t}\n   739→\n   740→\tif h.orchestrateFn == nil {\n   741→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   742→\t\tw.WriteHeader(http.StatusNotImplemented)\n   743→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   744→\t\treturn\n   745→\t}\n   746→\n   747→\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   748→\tif err != nil {\n   749→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   750→\t\tw.WriteHeader(http.StatusInternalServerError)\n   751→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   752→\t\treturn\n   753→\t}\n   754→\n   755→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   756→\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   757→}\n   758→\n   759→// handleAPIStream serves an SSE stream of log lines for a run.\n   760→// For active runs, it subscribes to the live broadcaster.\n   761→// For completed runs, it serves the archived full.log then closes.\n   762→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   763→\tid := r.PathValue(\"id\")\n   764→\n   765→\trun, err := h.store.GetRun(r.Context(), id)\n   766→\tif err != nil {\n   767→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   768→\t\treturn\n   769→\t}\n   770→\n   771→\tflusher, ok := w.(http.Flusher)\n   772→\tif !ok {\n   773→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   774→\t\treturn\n   775→\t}\n   776→\n   777→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   778→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   779→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   780→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   781→\n   782→\tisComplete := run.State == domain.RunStateSucceeded ||\n   783→\t\trun.State == domain.RunStateFailed ||\n   784→\t\trun.State == domain.RunStateCancelled\n   785→\n   786→\tif isComplete {\n   787→\t\t// Serve archived full.log\n   788→\t\th.streamFullLog(w, flusher, run)\n   789→\t\t// Send done event\n   790→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   791→\t\tflusher.Flush()\n   792→\t\treturn\n   793→\t}\n   794→\n   795→\t// Active run: subscribe to live broadcaster\n   796→\tif h.logBroadcast == nil {\n   797→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   798→\t\treturn\n   799→\t}\n   800→\n   801→\tsub := h.logBroadcast.Subscribe(id)\n   802→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   803→\n   804→\tctx := r.Context()\n   805→\tfor {\n   806→\t\tselect {\n   807→\t\tcase <-ctx.Done():\n   808→\t\t\treturn\n   809→\t\tcase line, ok := <-sub.C:\n   810→\t\t\tif !ok {\n   811→\t\t\t\t// Stream finished (run completed)\n   812→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   813→\t\t\t\tflusher.Flush()\n   814→\t\t\t\treturn\n   815→\t\t\t}\n   816→\t\t\tdata, _ := json.Marshal(line)\n   817→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   818→\t\t\tflusher.Flush()\n   819→\t\t}\n   820→\t}\n   821→}\n   822→\n   823→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   824→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   825→\n   826→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   827→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   828→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   829→\tf, err := os.Open(logPath)\n   830→\tif err != nil {\n   831→\t\treturn\n   832→\t}\n   833→\tdefer f.Close()\n   834→\n   835→\tscanner := bufio.NewScanner(f)\n   836→\tfor scanner.Scan() {\n   837→\t\ttext := scanner.Text()\n   838→\t\tline := parseFullLogLine(text)\n   839→\t\tdata, _ := json.Marshal(line)\n   840→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   841→\t\tflusher.Flush()\n   842→\t}\n   843→}\n   844→\n   845→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   846→func parseFullLogLine(text string) logstream.LogLine {\n   847→\tm := logLineRegex.FindStringSubmatch(text)\n   848→\tif m == nil {\n   849→\t\treturn logstream.LogLine{\n   850→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   851→\t\t\tType:      \"script\",\n   852→\t\t\tContent:   text,\n   853→\t\t}\n   854→\t}\n   855→\treturn logstream.LogLine{\n   856→\t\tTimestamp: m[1],\n   857→\t\tType:      m[2],\n   858→\t\tContent:   m[3],\n   859→\t}\n   860→}\n   861→\n   862→// --- Project detail handlers ---\n   863→\n   864→// resolveProjectDir resolves a project label from the URL to its directory path.\n   865→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   866→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   867→\tlabel := r.PathValue(\"name\")\n   868→\tprojects, _ := h.store.ListProjects(r.Context())\n   869→\tlabels := projectLabels(projects)\n   870→\tfor dir, l := range labels {\n   871→\t\tif l == label {\n   872→\t\t\treturn dir, label, true\n   873→\t\t}\n   874→\t}\n   875→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   876→\tw.WriteHeader(http.StatusNotFound)\n   877→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   878→\treturn \"\", \"\", false\n   879→}\n   880→\n   881→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   882→\tdir, label, ok := h.resolveProjectDir(w, r)\n   883→\tif !ok {\n   884→\t\treturn\n   885→\t}\n   886→\n   887→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   888→\tn := 10\n   889→\tif n > len(runs) {\n   890→\t\tn = len(runs)\n   891→\t}\n   892→\tdots := make([]recentRunDot, n)\n   893→\tfor i := 0; i < n; i++ {\n   894→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   895→\t}\n   896→\n   897→\tdata := map[string]any{\n   898→\t\t\"Title\":      label,\n   899→\t\t\"Label\":      label,\n   900→\t\t\"Dir\":        dir,\n   901→\t\t\"RecentRuns\": dots,\n   902→\t}\n   903→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   904→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   905→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   906→\t}\n   907→}\n   908→\n   909→func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   910→\tdir, _, ok := h.resolveProjectDir(w, r)\n   911→\tif !ok {\n   912→\t\treturn\n   913→\t}\n   914→\tif h.orchestrator == nil {\n   915→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   916→\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   917→\t\treturn\n   918→\t}\n   919→\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   920→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   921→\tjson.NewEncoder(w).Encode(map[string]any{\n   922→\t\t\"enabled\":     enabled,\n   923→\t\t\"in_flight\":   inFlight,\n   924→\t\t\"concurrency\": concurrency,\n   925→\t})\n   926→}\n   927→\n   928→func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   929→\tdir, _, ok := h.resolveProjectDir(w, r)\n   930→\tif !ok {\n   931→\t\treturn\n   932→\t}\n   933→\tif h.orchestrator == nil {\n   934→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   935→\t\tw.WriteHeader(http.StatusNotImplemented)\n   936→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   937→\t\treturn\n   938→\t}\n   939→\th.orchestrator.SetEnabled(dir, true)\n   940→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   941→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   942→}\n   943→\n   944→func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   945→\tdir, _, ok := h.resolveProjectDir(w, r)\n   946→\tif !ok {\n   947→\t\treturn\n   948→\t}\n   949→\tif h.orchestrator == nil {\n   950→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   951→\t\tw.WriteHeader(http.StatusNotImplemented)\n   952→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   953→\t\treturn\n   954→\t}\n   955→\th.orchestrator.SetEnabled(dir, false)\n   956→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   957→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   958→}\n   959→\n   960→func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   961→\tdir, _, ok := h.resolveProjectDir(w, r)\n   962→\tif !ok {\n   963→\t\treturn\n   964→\t}\n   965→\tif h.orchestrator == nil {\n   966→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   967→\t\tw.WriteHeader(http.StatusNotImplemented)\n   968→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   969→\t\treturn\n   970→\t}\n   971→\tvar body struct {\n   972→\t\tConcurrency int `json:\"concurrency\"`\n   973→\t}\n   974→\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n   975→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   976→\t\tw.WriteHeader(http.StatusBadRequest)\n   977→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n   978→\t\treturn\n   979→\t}\n   980→\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n   981→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   982→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   983→}\n   984→\n   985→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   986→\tdir, _, ok := h.resolveProjectDir(w, r)\n   987→\tif !ok {\n   988→\t\treturn\n   989→\t}\n   990→\n   991→\t// Docker image: read FROM line from Dockerfile\n   992→\tdockerImage := \"\"\n   993→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   994→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   995→\t\t// Find the last FROM line (final stage)\n   996→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   997→\t\t\ttrimmed := strings.TrimSpace(line)\n   998→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   999→\t\t\t\tparts := strings.Fields(trimmed)\n  1000→\t\t\t\tif len(parts) >= 2 {\n  1001→\t\t\t\t\tdockerImage = parts[1]\n  1002→\t\t\t\t}\n  1003→\t\t\t}\n  1004→\t\t}\n  1005→\t}\n  1006→\n  1007→\t// Version\n  1008→\tversion := 0\n  1009→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n  1010→\tif data, err := os.ReadFile(versionPath); err == nil {\n  1011→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n  1012→\t\t\tversion = v\n  1013→\t\t}\n  1014→\t}\n  1015→\n  1016→\t// Prompt files history\n  1017→\ttype commitEntry struct {\n  1018→\t\tSHA     string `json:\"sha\"`\n  1019→\t\tDate    string `json:\"date\"`\n  1020→\t\tMessage string `json:\"message\"`\n  1021→\t}\n  1022→\ttype promptFile struct {\n  1023→\t\tPath    string        `json:\"path\"`\n  1024→\t\tHistory []commitEntry `json:\"history\"`\n  1025→\t}\n  1026→\n  1027→\tvar promptFiles []promptFile\n  1028→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n  1029→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n  1030→\t\tfor _, e := range entries {\n  1031→\t\t\tif e.IsDir() {\n  1032→\t\t\t\tcontinue\n  1033→\t\t\t}\n  1034→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n  1035→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n  1036→\t\t\tcmd.Dir = dir\n  1037→\t\t\tout, err := cmd.Output()\n  1038→\t\t\tif err != nil {\n  1039→\t\t\t\tcontinue\n  1040→\t\t\t}\n  1041→\t\t\tvar history []commitEntry\n  1042→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n  1043→\t\t\t\tif line == \"\" {\n  1044→\t\t\t\t\tcontinue\n  1045→\t\t\t\t}\n  1046→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1047→\t\t\t\tif len(parts) < 3 {\n  1048→\t\t\t\t\tcontinue\n  1049→\t\t\t\t}\n  1050→\t\t\t\t// Parse date to short form\n  1051→\t\t\t\tdateStr := parts[1]\n  1052→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1053→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1054→\t\t\t\t}\n  1055→\t\t\t\thistory = append(history, commitEntry{\n  1056→\t\t\t\t\tSHA:     parts[0][:7],\n  1057→\t\t\t\t\tDate:    dateStr,\n  1058→\t\t\t\t\tMessage: parts[2],\n  1059→\t\t\t\t})\n  1060→\t\t\t}\n  1061→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1062→\t\t}\n  1063→\t}\n  1064→\n  1065→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1066→\tjson.NewEncoder(w).Encode(map[string]any{\n  1067→\t\t\"docker_image\": dockerImage,\n  1068→\t\t\"version\":      version,\n  1069→\t\t\"prompt_files\": promptFiles,\n  1070→\t})\n  1071→}\n  1072→\n  1073→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1074→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1075→\tif !ok {\n  1076→\t\treturn\n  1077→\t}\n  1078→\tfile := r.URL.Query().Get(\"file\")\n  1079→\tsha := r.URL.Query().Get(\"sha\")\n  1080→\tif file == \"\" || sha == \"\" {\n  1081→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1082→\t\treturn\n  1083→\t}\n  1084→\n  1085→\t// Validate sha is alphanumeric to prevent injection\n  1086→\tfor _, c := range sha {\n  1087→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1088→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1089→\t\t\treturn\n  1090→\t\t}\n  1091→\t}\n  1092→\n  1093→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1094→\tcmd.Dir = dir\n  1095→\tout, err := cmd.Output()\n  1096→\tif err != nil {\n  1097→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1098→\t\treturn\n  1099→\t}\n  1100→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1101→\tw.Write(out)\n  1102→}\n  1103→\n  1104→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1105→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1106→\tif !ok {\n  1107→\t\treturn\n  1108→\t}\n  1109→\n  1110→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1111→\tentries, err := os.ReadDir(clocheDir)\n  1112→\tif err != nil {\n  1113→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1114→\t\tjson.NewEncoder(w).Encode([]any{})\n  1115→\t\treturn\n  1116→\t}\n  1117→\n  1118→\ttype apiWire struct {\n  1119→\t\tFrom   string `json:\"from\"`\n  1120→\t\tResult string `json:\"result\"`\n  1121→\t\tTo     string `json:\"to\"`\n  1122→\t}\n  1123→\ttype apiStepDef struct {\n  1124→\t\tName    string            `json:\"name\"`\n  1125→\t\tType    string            `json:\"type\"`\n  1126→\t\tResults []string          `json:\"results\"`\n  1127→\t\tConfig  map[string]string `json:\"config\"`\n  1128→\t}\n  1129→\ttype apiWorkflow struct {\n  1130→\t\tName      string       `json:\"name\"`\n  1131→\t\tFile      string       `json:\"file\"`\n  1132→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1133→\t\tWires     []apiWire    `json:\"wires\"`\n  1134→\t\tEntryStep string       `json:\"entry_step\"`\n  1135→\t}\n  1136→\n  1137→\tvar workflows []apiWorkflow\n  1138→\tfor _, e := range entries {\n  1139→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1140→\t\t\tcontinue\n  1141→\t\t}\n  1142→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1143→\t\tif err != nil {\n  1144→\t\t\tcontinue\n  1145→\t\t}\n  1146→\t\twf, err := dsl.Parse(string(data))\n  1147→\t\tif err != nil {\n  1148→\t\t\tcontinue\n  1149→\t\t}\n  1150→\t\tvar steps []apiStepDef\n  1151→\t\tfor _, s := range wf.Steps {\n  1152→\t\t\tsteps = append(steps, apiStepDef{\n  1153→\t\t\t\tName:    s.Name,\n  1154→\t\t\t\tType:    string(s.Type),\n  1155→\t\t\t\tResults: s.Results,\n  1156→\t\t\t\tConfig:  s.Config,\n  1157→\t\t\t})\n  1158→\t\t}\n  1159→\t\t// Sort steps by name for consistent ordering\n  1160→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1161→\n  1162→\t\tvar wires []apiWire\n  1163→\t\tfor _, wire := range wf.Wiring {\n  1164→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1165→\t\t}\n  1166→\n  1167→\t\tworkflows = append(workflows, apiWorkflow{\n  1168→\t\t\tName:      wf.Name,\n  1169→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1170→\t\t\tSteps:     steps,\n  1171→\t\t\tWires:     wires,\n  1172→\t\t\tEntryStep: wf.EntryStep,\n  1173→\t\t})\n  1174→\t}\n  1175→\n  1176→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1177→\tjson.NewEncoder(w).Encode(workflows)\n  1178→}\n  1179→\n  1180→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1181→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1182→\tif !ok {\n  1183→\t\treturn\n  1184→\t}\n  1185→\tworkflowName := r.PathValue(\"workflow\")\n  1186→\tstepName := r.PathValue(\"step\")\n  1187→\n  1188→\t// Find the workflow file\n  1189→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1190→\tvar wf *domain.Workflow\n  1191→\tentries, _ := os.ReadDir(clocheDir)\n  1192→\tfor _, e := range entries {\n  1193→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1194→\t\t\tcontinue\n  1195→\t\t}\n  1196→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1197→\t\tif err != nil {\n  1198→\t\t\tcontinue\n  1199→\t\t}\n  1200→\t\tparsed, err := dsl.Parse(string(data))\n  1201→\t\tif err != nil {\n  1202→\t\t\tcontinue\n  1203→\t\t}\n  1204→\t\tif parsed.Name == workflowName {\n  1205→\t\t\twf = parsed\n  1206→\t\t\tbreak\n  1207→\t\t}\n  1208→\t}\n  1209→\tif wf == nil {\n  1210→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1211→\t\treturn\n  1212→\t}\n  1213→\n  1214→\tstep, ok := wf.Steps[stepName]\n  1215→\tif !ok {\n  1216→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1217→\t\treturn\n  1218→\t}\n  1219→\n  1220→\t// Try to read the referenced file from step config\n  1221→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1222→\n  1223→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1224→\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1225→\t\tif err == nil {\n  1226→\t\t\tw.Write(data)\n  1227→\t\t\treturn\n  1228→\t\t}\n  1229→\t}\n  1230→\tif script := step.Config[\"command\"]; script != \"\" {\n  1231→\t\tw.Write([]byte(script))\n  1232→\t\treturn\n  1233→\t}\n  1234→\tif script := step.Config[\"script\"]; script != \"\" {\n  1235→\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1236→\t\tif err == nil {\n  1237→\t\t\tw.Write(data)\n  1238→\t\t\treturn\n  1239→\t\t}\n  1240→\t\tw.Write([]byte(script))\n  1241→\t\treturn\n  1242→\t}\n  1243→\n  1244→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1245→}\n  1246→\n  1247→// --- Template helpers ---\n  1248→\n  1249→func stateColor(state domain.RunState) string {\n  1250→\tswitch state {\n  1251→\tcase domain.RunStatePending:\n  1252→\t\treturn \"pending\"\n  1253→\tcase domain.RunStateRunning:\n  1254→\t\treturn \"running\"\n  1255→\tcase domain.RunStateSucceeded:\n  1256→\t\treturn \"succeeded\"\n  1257→\tcase domain.RunStateFailed:\n  1258→\t\treturn \"failed\"\n  1259→\tcase domain.RunStateCancelled:\n  1260→\t\treturn \"cancelled\"\n  1261→\tdefault:\n  1262→\t\treturn \"pending\"\n  1263→\t}\n  1264→}\n  1265→\n  1266→func healthColor(status domain.HealthStatus) string {\n  1267→\tswitch status {\n  1268→\tcase domain.HealthGreen:\n  1269→\t\treturn \"green\"\n  1270→\tcase domain.HealthYellow:\n  1271→\t\treturn \"yellow\"\n  1272→\tcase domain.HealthRed:\n  1273→\t\treturn \"red\"\n  1274→\tcase domain.HealthBlue:\n  1275→\t\treturn \"blue\"\n  1276→\tdefault:\n  1277→\t\treturn \"grey\"\n  1278→\t}\n  1279→}\n  1280→\n  1281→func formatTime(t time.Time) string {\n  1282→\tif t.IsZero() {\n  1283→\t\treturn \"\"\n  1284→\t}\n  1285→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1286→}\n  1287→\n  1288→func formatDuration(start, end time.Time) string {\n  1289→\tif start.IsZero() || end.IsZero() {\n  1290→\t\treturn \"\"\n  1291→\t}\n  1292→\td := end.Sub(start)\n  1293→\tif d < time.Second {\n  1294→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1295→\t}\n  1296→\tif d < time.Minute {\n  1297→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1298→\t}\n  1299→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1300→}\n  1301→\n  1302→func truncate(s string, n int) string {\n  1303→\tif len(s) <= n {\n  1304→\t\treturn s\n  1305→\t}\n  1306→\treturn s[:n] + \"...\"\n  1307→}\n  1308→\n  1309→func shortContainerID(id string) string {\n  1310→\tif len(id) > 12 {\n  1311→\t\treturn id[:12]\n  1312→\t}\n  1313→\treturn id\n  1314→}\n  1315→\n  1316→// projectLabels builds a mapping from full project directory paths to short\n  1317→// display labels. Each label is the final directory component (e.g.\n  1318→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1319→// the same final name, the parent directory is prepended to disambiguate\n  1320→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1321→func projectLabels(dirs []string) map[string]string {\n  1322→\tlabels := make(map[string]string, len(dirs))\n  1323→\t// Group dirs by their base name to detect conflicts.\n  1324→\tbyBase := map[string][]string{}\n  1325→\tfor _, d := range dirs {\n  1326→\t\tbase := filepath.Base(d)\n  1327→\t\tbyBase[base] = append(byBase[base], d)\n  1328→\t}\n  1329→\tfor base, paths := range byBase {\n  1330→\t\tif len(paths) == 1 {\n  1331→\t\t\tlabels[paths[0]] = base\n  1332→\t\t} else {\n  1333→\t\t\tfor _, p := range paths {\n  1334→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1335→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1336→\t\t\t}\n  1337→\t\t}\n  1338→\t}\n  1339→\treturn labels\n  1340→}\n  1341→\n  1342→type projectEntry struct {\n  1343→\tDir            string\n  1344→\tLabel          string\n  1345→\tContainerCount int\n  1346→}\n  1347→"}]},"parent_tool_use_id":null,"session_id":"30600f3b-4971-4e4f-98cf-c3a658c29a94","uuid":"cb0b5265-1802-4b94-9ac1-ffa05ead9813","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\nfunc WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n\treturn func(h *Handler) { h.orchestrateFn = fn }\n}\n\n// OrchestratorController provides per-project orchestrator control.\ntype OrchestratorController interface {\n\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n\tSetEnabled(dir string, enabled bool)\n\tSetConcurrency(dir string, concurrency int)\n}\n\n// WithOrchestrator sets the orchestrator controller for project-level control.\nfunc WithOrchestrator(oc OrchestratorController) HandlerOption {\n\treturn func(h *Handler) { h.orchestrator = oc }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore         ports.RunStore\n\tcaptures      ports.CaptureStore\n\tlogStore      ports.LogStore\n\tcontainer     ContainerLogger\n\tlogBroadcast  *logstream.Broadcaster\n\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n\torchestrator  OrchestratorController\n\tpages         map[string]*template.Template\n\tmux           *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, d := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: d, Label: labels[d], ContainerCount: containerCounts[d]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs — \" + label,\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": dir,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\n\t// Resolve label back to project directory via the store.\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tvar projectDir string\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\tprojectDir = dir\n\t\t\tbreak\n\t\t}\n\t}\n\tif projectDir == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\t\treturn\n\t}\n\n\tif h.orchestrateFn == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\n\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n\t\treturn\n\t}\n\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"enabled\":     enabled,\n\t\t\"in_flight\":   inFlight,\n\t\t\"concurrency\": concurrency,\n\t})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, true)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, false)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\tvar body struct {\n\t\tConcurrency int `json:\"concurrency\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n\t\treturn\n\t}\n\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\tif script := step.Config[\"command\"]; script != \"\" {\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1347,"startLine":1,"totalLines":1347}}}
