.String()\n  1381→\tassert.Contains(t, body, \"parent-host-1\")\n  1382→\tassert.Contains(t, body, `href=\"/runs/parent-host-1\"`)\n  1383→\tassert.Contains(t, body, \"Parent Run\")\n  1384→\n  1385→\t// Check parent's detail page shows child runs section\n  1386→\treq = httptest.NewRequest(\"GET\", \"/runs/parent-host-1\", nil)\n  1387→\tw = httptest.NewRecorder()\n  1388→\th.ServeHTTP(w, req)\n  1389→\n  1390→\tassert.Equal(t, http.StatusOK, w.Code)\n  1391→\tbody = w.Body.String()\n  1392→\tassert.Contains(t, body, \"Child Runs\")\n  1393→\tassert.Contains(t, body, \"child-run-1\")\n  1394→\tassert.Contains(t, body, `href=\"/runs/child-run-1\"`)\n  1395→\tassert.Contains(t, body, \"Implement feature X\")\n  1396→}\n  1397→\n  1398→func TestRunDetail_NoParentChild(t *testing.T) {\n  1399→\th, store := setupHandler(t)\n  1400→\tseedRun(t, store, \"standalone-1\", \"develop\", domain.RunStateRunning)\n  1401→\n  1402→\treq := httptest.NewRequest(\"GET\", \"/runs/standalone-1\", nil)\n  1403→\tw := httptest.NewRecorder()\n  1404→\th.ServeHTTP(w, req)\n  1405→\n  1406→\tassert.Equal(t, http.StatusOK, w.Code)\n  1407→\tbody := w.Body.String()\n  1408→\tassert.NotContains(t, body, \"Parent Run\")\n  1409→\tassert.NotContains(t, body, \"Child Runs\")\n  1410→}\n  1411→\n  1412→func TestAPIRunDetail_ChildRuns(t *testing.T) {\n  1413→\th, store := setupHandler(t)\n  1414→\tctx := context.Background()\n  1415→\n  1416→\t// Create parent run\n  1417→\tparent := domain.NewRun(\"api-parent-1\", \"main\")\n  1418→\tparent.IsHost = true\n  1419→\tparent.ProjectDir = \"/project\"\n  1420→\tparent.Start()\n  1421→\trequire.NoError(t, store.CreateRun(ctx, parent))\n  1422→\n  1423→\t// Create child runs\n  1424→\tchild1 := domain.NewRun(\"api-child-1\", \"develop\")\n  1425→\tchild1.ProjectDir = \"/project\"\n  1426→\tchild1.ParentRunID = \"api-parent-1\"\n  1427→\tchild1.Start()\n  1428→\trequire.NoError(t, store.CreateRun(ctx, child1))\n  1429→"}]},"parent_tool_use_id":null,"sess