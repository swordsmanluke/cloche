= padL * 2 + numLayers * nodeW + (numLayers - 1) * layerGap;\n   295→    var svgH = padT * 2 + totalLayerH;\n   296→\n   297→    // --- Generate SVG ---\n   298→    var svg = '<svg class=\"dag-svg\" width=\"' + svgW + '\" height=\"' + svgH + '\">';\n   299→    svg += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';"}]},"parent_tool_use_id":null,"session_id":"4c63b3e9-21a0-4a0c-87f3-97db17cd05ef","uuid":"b302386d-4948-48bc-b674-d64de7df9168","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/project_detail.html","content":"function showWorkflow(wf) {\n    var dagEl = document.getElementById('workflow-dag');\n\n    if (!wf.steps || wf.steps.length === 0) {\n        dagEl.innerHTML = '<p class=\"empty\">No steps defined</p>';\n        return;\n    }\n\n    var stepMap = {};\n    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n\n    var wires = wf.wires || [];\n\n    // Collect terminal targets\n    var terminals = {};\n    wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n    });\n\n    // Build adjacency maps\n    var adj = {};    // from -> [wire]\n    var revAdj = {}; // to -> [from] (unique)\n    wires.forEach(function(wire) {\n        if (!adj[wire.from]) adj[wire.from] = [];\n        adj[wire.from].push(wire);\n        if (!revAdj[wire.to]) revAdj[wire.to] = [];\n        if (revAdj[wire.to].indexOf(wire.from) === -1) revAdj[wire.to].push(wire.from);\n    });\n\n    // --- Layer assignment via longest path (Sugiyama-style) ---\n    var stepNames = wf.steps.map(function(s) { return s.name; });\n\n    // Topological sort (Kahn's algorithm)\n    var inDeg = {};\n    stepNames.forEach(function(n) { inDeg[n] = 0; });\n    wires.forEach(function(wire) {\n        if (inDeg[wire.to] !== undefined) inDeg[wire.to]++;\n    });\n\n    var queue = [];\n    stepNames.forEach(function(n) { if (inDeg[n] === 0) queue.push(n); });\n\n    var topoOrder = [];\n    while (queue.length > 0) {\n        var n = queue.shift();\n        topoOrder.push(n);\n        (adj[n] || []).forEach(function(wire) {\n            if (inDeg[wire.to] !== undefined) {\n                inDeg[wire.to]--;\n                if (inDeg[wire.to] === 0) queue.push(wire.to);\n            }\n        });\n    }\n    // Add remaining steps (cycles or disconnected)\n    stepNames.forEach(function(n) { if (topoOrder.indexOf(n) === -1) topoOrder.push(n); });\n\n    // Assign layers: longest path from any source\n    var layerOf = {};\n    topoOrder.forEach(function(n) {\n        var maxParent = -1;\n        (revAdj[n] || []).forEach(function(p) {\n            if (layerOf[p] !== undefined && layerOf[p] > maxParent) maxParent = layerOf[p];\n        });\n        layerOf[n] = maxParent + 1;\n    });\n\n    var maxLayer = 0;\n    stepNames.forEach(function(n) { if (layerOf[n] > maxLayer) maxLayer = layerOf[n]; });\n\n    // Terminals in rightmost layer\n    var termLayer = maxLayer + 1;\n    for (var t in terminals) { layerOf[t] = termLayer; }\n    var numLayers = termLayer + 1;\n\n    // --- Build layer arrays ---\n    var layers = [];\n    for (var i = 0; i < numLayers; i++) layers.push([]);\n    topoOrder.forEach(function(n) { layers[layerOf[n]].push(n); });\n    for (var t in terminals) { layers[termLayer].push(t); }\n\n    // --- Barycenter ordering to minimize edge crossings ---\n    for (var pass = 0; pass < 4; pass++) {\n        // Forward pass\n        for (var li = 1; li < numLayers; li++) {\n            var bary = {};\n            layers[li].forEach(function(n) {\n                var pars = revAdj[n] || [];\n                var sum = 0, cnt = 0;\n                pars.forEach(function(p) {\n                    var idx = layers[li - 1].indexOf(p);\n                    if (idx >= 0) { sum += idx; cnt++; }\n                });\n                bary[n] = cnt > 0 ? sum / cnt : 999;\n            });\n            layers[li].sort(function(a, b) { return bary[a] - bary[b]; });\n        }\n        // Backward pass\n        for (var li = numLayers - 2; li >= 0; li--) {\n            var baryB = {};\n            layers[li].forEach(function(n) {\n                var children = (adj[n] || []).map(function(w) { return w.to; });\n                var sum = 0, cnt = 0;\n                children.forEach(function(c) {\n                    var idx = layers[li + 1].indexOf(c);\n                    if (idx >= 0) { sum += idx; cnt++; }\n                });\n                baryB[n] = cnt > 0 ? sum / cnt : 999;\n            });\n            layers[li].sort(function(a, b) { return baryB[a] - baryB[b]; });\n        }\n    }\n\n    // --- Position calculation ---\n    var nodeW = 180, nodeH = 48;\n    var layerGap = 120; // horizontal gap between layers\n    var nodeGap = 28;   // vertical gap between nodes in same layer\n    var padL = 30, padT = 30;\n\n    var maxInLayer = 1;\n    layers.forEach(function(l) { if (l.length > maxInLayer) maxInLayer = l.length; });\n    var totalLayerH = maxInLayer * nodeH + (maxInLayer - 1) * nodeGap;\n\n    var positions = {};\n    layers.forEach(function(layer, li) {\n        var lh = layer.length * nodeH + (layer.length - 1) * nodeGap;\n        var offsetY = (totalLayerH - lh) / 2;\n        layer.forEach(function(name, ni) {\n            positions[name] = {\n                x: padL + li * (nodeW + layerGap),\n                y: padT + offsetY + ni * (nodeH + nodeGap)\n            };\n        });\n    });\n\n    var svgW = padL * 2 + numLayers * nodeW + (numLayers - 1) * layerGap;\n    var svgH = padT * 2 + totalLayerH;\n\n    // --- Generate SVG ---\n    var svg = '<svg class=\"dag-svg\" width=\"' + svgW + '\" height=\"' + svgH + '\">';\n    svg += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';","numLines":140,"startLine":160,"totalLines":470}}}
