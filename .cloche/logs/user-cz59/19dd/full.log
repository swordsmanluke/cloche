[2026-03-09T15:22:21Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HCL1DAizyu4AhNgp41dkVa","type":"tool_result","content":"The file /workspace/internal/adapters/web/templates/project_detail.html has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"a346eea4-4e18-48f2-a8ae-0b723dbadd29","uuid":"106fb24a-4312-4aba-b2af-30971a3f3b87","tool_use_result":{"filePath":"/workspace/internal/adapters/web/templates/project_detail.html","oldString":"    <a href=\"/runs?project={{.Dir}}\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>","newString":"    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>","originalFile":"{{define \"content\"}}\n<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n\n<div class=\"run-history\" style=\"margin-bottom:1rem\">\n    {{range .RecentRuns}}\n    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n    {{end}}\n    <a href=\"/runs?project={{.Dir}}\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n</div>\n\n<!-- Panel 1: Orchestrator Control -->\n<div class=\"panel\" id=\"orchestrator-panel\">\n    <div class=\"panel-header\">Orchestrator Control</div>\n    <div class=\"panel-body\">\n        <div id=\"orch-status\" class=\"orch-status\">Loading...</div>\n        <div class=\"orch-controls\" style=\"margin-top:0.75rem;display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap\">\n            <button id=\"orch-toggle\" class=\"btn btn-primary btn-sm\" onclick=\"toggleOrchestrator()\">Enable</button>\n            <span style=\"margin-left:1rem;color:var(--text-muted);font-size:0.85rem\">Concurrency:</span>\n            <input type=\"number\" id=\"orch-concurrency\" min=\"1\" max=\"20\" value=\"1\" style=\"width:60px;padding:0.2em 0.4em;border:1px solid var(--border);border-radius:var(--radius);background:var(--bg);color:var(--text);font-size:0.85rem\">\n            <button class=\"btn btn-secondary btn-sm\" onclick=\"applyConcurrency()\">Apply</button>\n        </div>\n    </div>\n</div>\n\n<!-- Panel 2: Project Info -->\n<div class=\"panel\" id=\"info-panel\">\n    <div class=\"panel-header\">Project Info</div>\n    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n</div>\n\n<!-- Panel 3: Workflow View -->\n<div class=\"panel\" id=\"workflow-panel\">\n    <div class=\"panel-header\">Workflows</div>\n    <div class=\"panel-body\">\n        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-dag\"></div>\n    </div>\n</div>\n\n<!-- Step Drawer -->\n<div class=\"drawer\" id=\"step-drawer\">\n    <div class=\"drawer-header\">\n        <span id=\"drawer-title\"></span>\n        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    </div>\n    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n</div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\nvar projectLabel = {{.Label}};\nvar orchEnabled = false;\n\nfunction loadOrchestratorStatus() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/orchestrator')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            orchEnabled = data.enabled;\n            var statusEl = document.getElementById('orch-status');\n            var toggleBtn = document.getElementById('orch-toggle');\n            var concInput = document.getElementById('orch-concurrency');\n            statusEl.innerHTML = '<span class=\"badge ' + (data.enabled ? 'badge-succeeded' : 'badge-stopped') + '\">' +\n                (data.enabled ? 'Enabled' : 'Disabled') + '</span>' +\n                '&nbsp; In-flight: <strong>' + data.in_flight + '</strong>' +\n                '&nbsp; Concurrency: <strong>' + data.concurrency + '</strong>';\n            toggleBtn.textContent = data.enabled ? 'Disable' : 'Enable';\n            toggleBtn.className = 'btn btn-sm ' + (data.enabled ? 'btn-danger' : 'btn-primary');\n            concInput.value = data.concurrency;\n        });\n}\n\nfunction toggleOrchestrator() {\n    var action = orchEnabled ? 'stop' : 'start';\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/orchestrator/' + action, {method: 'POST'})\n        .then(function() { loadOrchestratorStatus(); });\n}\n\nfunction applyConcurrency() {\n    var val = parseInt(document.getElementById('orch-concurrency').value, 10);\n    if (val < 1) return;\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/orchestrator/concurrency', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({concurrency: val})\n    }).then(function() { loadOrchestratorStatus(); });\n}\n\nfunction loadProjectInfo() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n            html += '</dl>';\n\n            if (data.prompt_files && data.prompt_files.length > 0) {\n                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n                data.prompt_files.forEach(function(pf) {\n                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n                    if (pf.history && pf.history.length > 0) {\n                        html += '<div style=\"margin:0.5rem 0\">';\n                        pf.history.forEach(function(h) {\n                            html += '<div class=\"prompt-commit\" data-file=\"' + pf.path + '\" data-sha=\"' + h.sha + '\" onclick=\"toggleDiff(this)\" style=\"cursor:pointer;padding:0.25rem 0;font-size:0.85rem\">';\n                            html += '<span class=\"mono\" style=\"color:var(--link)\">' + h.sha + '</span> ';\n                            html += '<span style=\"color:var(--text-muted)\">' + h.date + '</span> ';\n                            html += h.message;\n                            html += '</div>';\n                        });\n                        html += '</div>';\n                    } else {\n                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">No history</p>';\n                    }\n                    html += '</details>';\n                });\n            }\n\n            document.getElementById('project-info').innerHTML = html;\n        });\n}\n\nfunction toggleDiff(el) {\n    var existing = el.nextElementSibling;\n    if (existing && existing.classList.contains('diff-block')) {\n        existing.remove();\n        return;\n    }\n    var file = el.getAttribute('data-file');\n    var sha = el.getAttribute('data-sha');\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n        .then(function(r) { return r.text(); })\n        .then(function(text) {\n            var pre = document.createElement('pre');\n            pre.className = 'diff-block';\n            pre.textContent = text || '(no diff available)';\n            el.parentNode.insertBefore(pre, el.nextSibling);\n        });\n}\n\nvar workflowsData = [];\nfunction loadWorkflows() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            workflowsData = data || [];\n            if (workflowsData.length === 0) {\n                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n                return;\n            }\n            var tabs = document.getElementById('workflow-tabs');\n            if (workflowsData.length > 1) {\n                var html = '';\n                workflowsData.forEach(function(wf, i) {\n                    html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showWorkflow(' + i + ')\">' + wf.name + '</button>';\n                });\n                tabs.innerHTML = html;\n            }\n            showWorkflow(0);\n        });\n}\n\nfunction showWorkflow(idx) {\n    var btns = document.querySelectorAll('.tab-btn');\n    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n\n    var wf = workflowsData[idx];\n    var dagEl = document.getElementById('workflow-dag');\n\n    // Build step order via topological sort from entry\n    var ordered = [];\n    var visited = {};\n    function visit(name) {\n        if (visited[name] || name === 'done' || name === 'abort') return;\n        visited[name] = true;\n        ordered.push(name);\n        wf.wires.forEach(function(wire) {\n            if (wire.from === name) visit(wire.to);\n        });\n    }\n    if (wf.entry_step) visit(wf.entry_step);\n    // Add any unvisited steps\n    wf.steps.forEach(function(s) { if (!visited[s.name]) { ordered.push(s.name); visited[s.name] = true; } });\n\n    // Collect terminal targets\n    var terminals = {};\n    wf.wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n    });\n\n    var stepMap = {};\n    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n\n    var nodeH = 48, nodeW = 180, gapY = 24, gapX = 40, padTop = 20, padLeft = 30;\n\n    // Assign positions\n    var positions = {};\n    ordered.forEach(function(name, i) {\n        positions[name] = {x: padLeft, y: padTop + i * (nodeH + gapY)};\n    });\n    var termIdx = ordered.length;\n    for (var t in terminals) {\n        positions[t] = {x: padLeft, y: padTop + termIdx * (nodeH + gapY)};\n        termIdx++;\n    }\n\n    var totalH = padTop + termIdx * (nodeH + gapY) + 10;\n    var totalW = padLeft + nodeW + gapX + 80;\n\n    var html = '<svg class=\"dag-svg\" width=\"' + totalW + '\" height=\"' + totalH + '\">';\n    html += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n\n    // Draw wires\n    wf.wires.forEach(function(wire) {\n        var from = positions[wire.from];\n        var to = positions[wire.to];\n        if (!from || !to) return;\n        var x1 = from.x + nodeW;\n        var y1 = from.y + nodeH / 2;\n        var x2 = to.x;\n        var y2 = to.y + nodeH / 2;\n        var cx = x1 + gapX / 2;\n        html += '<path d=\"M' + x1 + ' ' + y1 + ' C' + cx + ' ' + y1 + ' ' + cx + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n        var lx = (x1 + x2) / 2, ly = (y1 + y2) / 2 - 6;\n        html += '<text x=\"' + lx + '\" y=\"' + ly + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n    });\n\n    // Draw step nodes\n    ordered.forEach(function(name) {\n        var pos = positions[name];\n        var s = stepMap[name];\n        var icon = s && s.type === 'agent' ? '\\u{1F916}' : '\\u{1F4DC}';\n        html += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + name + '\\')\" style=\"cursor:pointer\">';\n        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n        html += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + name + '</text>';\n        html += '</g>';\n    });\n\n    // Draw terminal nodes\n    for (var t in terminals) {\n        var pos = positions[t];\n        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n        html += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n    }\n\n    html += '</svg>';\n    dagEl.innerHTML = html;\n}\n\nfunction openDrawer(workflowName, stepName) {\n    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n    if (!wf) return;\n    var step = wf.steps.find(function(s) { return s.name === stepName; });\n    if (!step) return;\n\n    document.getElementById('drawer-title').textContent = stepName;\n    var body = '<dl class=\"run-meta\">';\n    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n    if (step.config) {\n        for (var k in step.config) {\n            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script') {\n                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n            }\n        }\n    }\n    body += '</dl>';\n    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n\n    document.getElementById('drawer-body').innerHTML = body;\n    document.getElementById('step-drawer').classList.add('drawer-open');\n\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n        .then(function(r) { if (r.ok) return r.text(); return ''; })\n        .then(function(text) {\n            var el = document.getElementById('drawer-content');\n            if (text) {\n                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n            } else {\n                el.innerHTML = '<p style=\"color:var(--text-muted)\">No content available</p>';\n            }\n        });\n}\n\nfunction closeDrawer() {\n    document.getElementById('step-drawer').classList.remove('drawer-open');\n}\n\ndocument.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') closeDrawer();\n});\n\n// Load all panels\nloadOrchestratorStatus();\nloadProjectInfo();\nloadWorkflows();\n</script>\n{{end}}\n","structuredPatch":[{"oldStart":5,"oldLines":7,"newStart":5,"newLines":7,"lines":["     {{range .RecentRuns}}","     <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>","     {{end}}","-    <a href=\"/runs?project={{.Dir}}\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>","+    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>"," </div>"," "," <!-- Panel 1: Orchestrator Control -->"]}],"userModified":false,"replaceAll":false}}
