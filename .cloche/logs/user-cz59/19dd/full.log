runs yet.</td></tr>\n    43→    {{end}}\n    44→    </tbody>\n    45→</table>\n    46→{{end}}\n    47→\n    48→{{define \"scripts\"}}\n    49→<script>\n    50→(function() {\n    51→    var currentProject = '{{.ProjectFilter}}';\n    52→    var currentLabel = '{{.ProjectLabel}}';\n    53→\n    54→    function filterByProject(label) {\n    55→        if (label) {\n    56→            window.location.href = '/projects/' + encodeURIComponent(label) + '/runs';\n    57→        } else {\n    58→            window.location.href = '/runs';\n    59→        }\n    60→    }\n    61→    window.filterByProject = filterByProject;\n    62→\n    63→    function poll() {\n    64→        var url = '/api/runs';\n    65→        if (currentProject) {\n    66→            url += '?project=' + encodeURIComponent(currentProject);\n    67→        }\n    68→        fetch(url)\n    69→            .then(function(r) { return r.json(); })\n    70→            .then(function(runs) {\n    71→                var tbody = document.getElementById('runs-body');\n    72→                if (!runs || runs.length === 0) {\n    73→                    tbody.innerHTML = '<tr><td colspan=\"8\" class=\"empty\">No runs yet.</td></tr>';\n    74→                    return;\n    75→                }\n    76→                var html = '';\n    77→                for (var i = 0; i < runs.length; i++) {\n    78→                    var r = runs[i];\n    79→                    var cid = r.container_id || '';\n    80→                    if (cid.length > 12) cid = cid.substring(0, 12);\n    81→                    var err = r.error_message || '';\n    82→                    if (err.length > 80) err = err.substring(0, 80) + '...';\n    83→                    var proj = r.project_label || '';\n    84→                    html += '<tr>' +\n    85→                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n    86→                        '<td>' + escapeHtml(proj) + '</td>' +\n    87→                        '<td>' + r.workflow_name + '</td>' +\n    88→                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n    89→                        '<td>' + r.started_at + '</td>' +\n    90→                        '<td>' + r.completed_at + '</td>' +\n    91→                        '<td class=\"mono\">' + cid + '</td>' +\n    92→                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n    93→                        '</tr>';\n    94→                }\n    95→                tbody.innerHTML = html;\n    96→            })\n    97→            .catch(function() {});\n    98→    }\n    99→    function escapeHtml(s) {\n   100→        var d = document.createElement('div');\n   101→        d.appendChild(document.createTextNode(s));\n   102→        return d.innerHTML;\n   103→    }\n   104→    setInterval(poll, 3000);\n   105→})();\n   106→</script>\n   107→{{end}}\n   108→"}]},"parent_tool_use_id":null,"session_id":"c16914ec-d525-4d0c-bd76-a1f22ab0c976","uuid":"1ce8ea37-d8da-4ed0-9a4c-69dd6490df6d","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/runs.html","content":"{{define \"content\"}}\n<h1>Runs</h1>\n{{if .Projects}}\n<div class=\"project-filter\">\n    <label for=\"project-select\">Project:</label>\n    <select id=\"project-select\" onchange=\"filterByProject(this.value)\">\n        <option value=\"\">All projects</option>\n        {{range .Projects}}\n        <option value=\"{{.Label}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>\n        {{end}}\n    </select>\n</div>\n{{end}}\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Run ID</th>\n            <th>Project</th>\n            <th>Workflow</th>\n            <th>State</th>\n            <th>Started</th>\n            <th>Completed</th>\n            <th>Container</th>\n            <th>Error</th>\n        </tr>\n    </thead>\n    <tbody id=\"runs-body\">\n    {{if .Runs}}\n        {{range .Runs}}\n        <tr>\n            <td><a href=\"/runs/{{.ID}}\">{{.ID}}</a></td>\n            <td>{{index $.ProjectLabels .ProjectDir}}</td>\n            <td>{{.WorkflowName}}</td>\n            <td><span class=\"badge badge-{{stateColor .State}}\">{{.State}}</span></td>\n            <td>{{formatTime .StartedAt}}</td>\n            <td>{{formatTime .CompletedAt}}</td>\n            <td class=\"mono\">{{shortContainerID .ContainerID}}</td>\n            <td class=\"error-cell\">{{truncate .ErrorMessage 80}}</td>\n        </tr>\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"8\" class=\"empty\">No runs yet.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var currentProject = '{{.ProjectFilter}}';\n    var currentLabel = '{{.ProjectLabel}}';\n\n    function filterByProject(label) {\n        if (label) {\n            window.location.href = '/projects/' + encodeURIComponent(label) + '/runs';\n        } else {\n            window.location.href = '/runs';\n        }\n    }\n    window.filterByProject = filterByProject;\n\n    function poll() {\n        var url = '/api/runs';\n        if (currentProject) {\n            url += '?project=' + encodeURIComponent(currentProject);\n        }\n        fetch(url)\n            .then(function(r) { return r.json(); })\n            .then(function(runs) {\n                var tbody = document.getElementById('runs-body');\n                if (!runs || runs.length === 0) {\n                    tbody.innerHTML = '<tr><td colspan=\"8\" class=\"empty\">No runs yet.</td></tr>';\n                    return;\n                }\n                var html = '';\n                for (var i = 0; i < runs.length; i++) {\n                    var r = runs[i];\n                    var cid = r.container_id || '';\n                    if (cid.length > 12) cid = cid.substring(0, 12);\n                    var err = r.error_message || '';\n                    if (err.length > 80) err = err.substring(0, 80) + '...';\n                    var proj = r.project_label || '';\n                    html += '<tr>' +\n                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n                        '<td>' + escapeHtml(proj) + '</td>' +\n                        '<td>' + r.workflow_name + '</td>' +\n                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n                        '<td>' + r.started_at + '</td>' +\n                        '<td>' + r.completed_at + '</td>' +\n                        '<td class=\"mono\">' + cid + '</td>' +\n                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                        '</tr>';\n                }\n                tbody.innerHTML = html;\n            })\n            .catch(function() {});\n    }\n    function escapeHtml(s) {\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n    setInterval(poll, 3000);\n})();\n</script>\n{{end}}\n","numLines":108,"startLine":1,"totalLines":108}}}
