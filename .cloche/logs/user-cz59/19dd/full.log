[2026-03-09T15:23:43Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016NmcD1xojs89tVqt8EKiXy","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"os/exec\"\n    14→\t\"path/filepath\"\n    15→\t\"regexp\"\n    16→\t\"sort\"\n    17→\t\"strconv\"\n    18→\t\"strings\"\n    19→\t\"time\"\n    20→\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→)\n    26→\n    27→// HandlerOption configures optional Handler dependencies.\n    28→type HandlerOption func(*Handler)\n    29→\n    30→// WithContainerLogger sets the container runtime for fetching live logs.\n    31→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32→\treturn func(h *Handler) { h.container = c }\n    33→}\n    34→\n    35→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36→func WithContainerManager(c ContainerManager) HandlerOption {\n    37→\treturn func(h *Handler) { h.container = c }\n    38→}\n    39→\n    40→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42→\treturn func(h *Handler) { h.logBroadcast = b }\n    43→}\n    44→\n    45→// WithLogStore sets the log store for indexed log file lookups.\n    46→func WithLogStore(ls ports.LogStore) HandlerOption {\n    47→\treturn func(h *Handler) { h.logStore = ls }\n    48→}\n    49→\n    50→// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    51→func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    52→\treturn func(h *Handler) { h.orchestrateFn = fn }\n    53→}\n    54→\n    55→// OrchestratorController provides per-project orchestrator control.\n    56→type OrchestratorController interface {\n    57→\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    58→\tSetEnabled(dir string, enabled bool)\n    59→\tSetConcurrency(dir string, concurrency int)\n    60→}\n    61→\n    62→// WithOrchestrator sets the orchestrator controller for project-level control.\n    63→func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    64→\treturn func(h *Handler) { h.orchestrator = oc }\n    65→}\n    66→\n    67→//go:embed templates/*.html static/*\n    68→var content embed.FS\n    69→\n    70→// Handler serves the web dashboard.\n    71→// ContainerLogger can retrieve logs from a container by ID.\n    72→type ContainerLogger interface {\n    73→\tLogs(ctx context.Context, containerID string) (string, error)\n    74→}\n    75→\n    76→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    77→type ContainerManager interface {\n    78→\tContainerLogger\n    79→\tRemove(ctx context.Context, containerID string) error\n    80→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    81→}\n    82→\n    83→type Handler struct {\n    84→\tstore         ports.RunStore\n    85→\tcaptures      ports.CaptureStore\n    86→\tlogStore      ports.LogStore\n    87→\tcontainer     ContainerLogger\n    88→\tlogBroadcast  *logstream.Broadcaster\n    89→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    90→\torchestrator  OrchestratorController\n    91→\tpages         map[string]*template.Template\n    92→\tmux           *http.ServeMux\n    93→}\n    94→\n    95→// NewHandler creates a web dashboard handler.\n    96→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    97→\tfuncMap := template.FuncMap{\n    98→\t\t\"stateColor\":       stateColor,\n    99→\t\t\"healthColor\":      healthColor,\n   100→\t\t\"formatTime\":       formatTime,\n   101→\t\t\"formatDuration\":   formatDuration,\n   102→\t\t\"truncate\":         truncate,\n   103→\t\t\"shortContainerID\": shortContainerID,\n   104→\t}\n   105→\n   106→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   107→\tif err != nil {\n   108→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   109→\t}\n   110→\n   111→\tpages := map[string]*template.Template{}\n   112→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   113→\t\tclone, err := base.Clone()\n   114→\t\tif err != nil {\n   115→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   116→\t\t}\n   117→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   118→\t\tif err != nil {\n   119→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   120→\t\t}\n   121→\t\tpages[page] = clone\n   122→\t}\n   123→\n   124→\th := &Handler{\n   125→\t\tstore:    store,\n   126→\t\tcaptures: captures,\n   127→\t\tpages:    pages,\n   128→\t\tmux:      http.NewServeMux(),\n   129→\t}\n   130→\tfor _, opt := range opts {\n   131→\t\topt(h)\n   132→\t}\n   133→\n   134→\tstaticFS, err := fs.Sub(content, \"static\")\n   135→\tif err != nil {\n   136→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   137→\t}\n   138→\n   139→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   140→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   141→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   142→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   143→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   144→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   145→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   146→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   147→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   148→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   149→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   150→\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   151→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   152→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   153→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   154→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   155→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   156→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   157→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   158→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   159→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   160→\n   161→\treturn h, nil\n   162→}\n   163→\n   164→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   165→\th.mux.ServeHTTP(w, r)\n   166→}\n   167→\n   168→// --- HTML handlers ---\n   169→\n   170→// projectOverviewEntry holds data for a single project card on the landing page.\n   171→type projectOverviewEntry struct {\n   172→\tDir         string\n   173→\tLabel       string\n   174→\tHealth      domain.HealthResult\n   175→\tRecentRuns  []recentRunDot\n   176→\tActiveCount int\n   177→}\n   178→\n   179→// recentRunDot is a minimal representation of a run for the mini history display.\n   180→type recentRunDot struct {\n   181→\tID    string\n   182→\tState string\n   183→}\n   184→\n   185→const healthWindowSize = 10\n   186→\n   187→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   188→\tprojects, _ := h.store.ListProjects(r.Context())\n   189→\tlabels := projectLabels(projects)\n   190→\n   191→\tvar entries []projectOverviewEntry\n   192→\tfor _, dir := range projects {\n   193→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   194→\t\tif err != nil {\n   195→\t\t\tcontinue\n   196→\t\t}\n   197→\n   198→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   199→\t\trunValues := make([]domain.Run, len(runs))\n   200→\t\tfor i, rr := range runs {\n   201→\t\t\trunValues[i] = *rr\n   202→\t\t}\n   203→\n   204→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   205→\n   206→\t\t// Take the last N runs for the mini history (most recent first).\n   207→\t\tn := healthWindowSize\n   208→\t\tif n > len(runs) {\n   209→\t\t\tn = len(runs)\n   210→\t\t}\n   211→\t\tdots := make([]recentRunDot, n)\n   212→\t\tfor i := 0; i < n; i++ {\n   213→\t\t\tdots[i] = recentRunDot{\n   214→\t\t\t\tID:    runs[i].ID,\n   215→\t\t\t\tState: string(runs[i].State),\n   216→\t\t\t}\n   217→\t\t}\n   218→\n   219→\t\tvar activeCount int\n   220→\t\tfor _, rr := range runs {\n   221→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   222→\t\t\t\tactiveCount++\n   223→\t\t\t}\n   224→\t\t}\n   225→\n   226→\t\tentries = append(entries, projectOverviewEntry{\n   227→\t\t\tDir:         dir,\n   228→\t\t\tLabel:       labels[dir],\n   229→\t\t\tHealth:      health,\n   230→\t\t\tRecentRuns:  dots,\n   231→\t\t\tActiveCount: activeCount,\n   232→\t\t})\n   233→\t}\n   234→\n   235→\tsort.Slice(entries, func(i, j int) bool {\n   236→\t\treturn entries[i].Label < entries[j].Label\n   237→\t})\n   238→\n   239→\tdata := map[string]any{\n   240→\t\t\"Title\":    \"Projects\",\n   241→\t\t\"Projects\": entries,\n   242→\t}\n   243→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   244→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   245→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   246→\t}\n   247→}\n   248→\n   249→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   250→\tprojectFilter := r.URL.Query().Get(\"project\")\n   251→\n   252→\tvar runs []*domain.Run\n   253→\tvar err error\n   254→\tif projectFilter != \"\" {\n   255→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   256→\t} else {\n   257→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   258→\t}\n   259→\tif err != nil {\n   260→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   261→\t\treturn\n   262→\t}\n   263→\n   264→\tprojects, _ := h.store.ListProjects(r.Context())\n   265→\tlabels := projectLabels(projects)\n   266→\n   267→\t// Count retained containers per project\n   268→\tcontainerCounts := map[string]int{}\n   269→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   270→\tfor _, run := range allRuns {\n   271→\t\tif run.ContainerKept {\n   272→\t\t\tcontainerCounts[run.ProjectDir]++\n   273→\t\t}\n   274→\t}\n   275→\n   276→\tvar projectList []projectEntry\n   277→\tfor _, dir := range projects {\n   278→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   279→\t}\n   280→\tsort.Slice(projectList, func(i, j int) bool {\n   281→\t\treturn projectList[i].Label < projectList[j].Label\n   282→\t})\n   283→\n   284→\t// Resolve project label for filtered view.\n   285→\tvar projectLabel string\n   286→\tif projectFilter != \"\" {\n   287→\t\tprojectLabel = labels[projectFilter]\n   288→\t}\n   289→\n   290→\tdata := map[string]any{\n   291→\t\t\"Title\":         \"Runs\",\n   292→\t\t\"Runs\":          runs,\n   293→\t\t\"Projects\":      projectList,\n   294→\t\t\"ProjectFilter\": projectFilter,\n   295→\t\t\"ProjectLabel\":  projectLabel,\n   296→\t\t\"ProjectLabels\": labels,\n   297→\t}\n   298→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   299→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   300→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   301→\t}\n   302→}\n   303→\n   304→// stepEntry is a merged view of a step execution for the template.\n   305→type stepEntry struct {\n   306→\tIndex     int\n   307→\tStepName  string\n   308→\tResult    string\n   309→\tStartedAt time.Time\n   310→\tDuration  string\n   311→}\n   312→\n   313→// mergeCaptures collapses started/completed capture pairs into single entries.\n   314→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   315→\tvar entries []stepEntry\n   316→\t// Track pending started rows by step name (LIFO for retries)\n   317→\tpending := map[string]*domain.StepExecution{}\n   318→\n   319→\tfor _, c := range caps {\n   320→\t\tif c.Result == \"\" {\n   321→\t\t\t// step_started row\n   322→\t\t\tpending[c.StepName] = c\n   323→\t\t\tcontinue\n   324→\t\t}\n   325→\t\t// step_completed row — merge with pending started if available\n   326→\t\tstartedAt := c.StartedAt\n   327→\t\tif started := pending[c.StepName]; started != nil {\n   328→\t\t\tstartedAt = started.StartedAt\n   329→\t\t\tdelete(pending, c.StepName)\n   330→\t\t}\n   331→\t\tentries = append(entries, stepEntry{\n   332→\t\t\tIndex:     len(entries),\n   333→\t\t\tStepName:  c.StepName,\n   334→\t\t\tResult:    c.Result,\n   335→\t\t\tStartedAt: startedAt,\n   336→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   337→\t\t})\n   338→\t}\n   339→\n   340→\t// Append any started-but-not-completed steps (still running)\n   341→\tfor _, c := range caps {\n   342→\t\tif c.Result == \"\" {\n   343→\t\t\tif _, used := pending[c.StepName]; !used {\n   344→\t\t\t\tcontinue\n   345→\t\t\t}\n   346→\t\t\tentries = append(entries, stepEntry{\n   347→\t\t\t\tIndex:     len(entries),\n   348→\t\t\t\tStepName:  c.StepName,\n   349→\t\t\t\tStartedAt: c.StartedAt,\n   350→\t\t\t})\n   351→\t\t\tdelete(pending, c.StepName)\n   352→\t\t}\n   353→\t}\n   354→\n   355→\treturn entries\n   356→}\n   357→\n   358→// containerState inspects the container for a run and returns one of:\n   359→//   - \"running\"   – container exists and is running\n   360→//   - \"stopped\"   – container exists, not running, not kept\n   361→//   - \"available\" – container exists, not running, kept (can be deleted)\n   362→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   363→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   364→\tif run.ContainerID == \"\" {\n   365→\t\treturn \"removed\"\n   366→\t}\n   367→\tmgr, ok := h.container.(ContainerManager)\n   368→\tif !ok {\n   369→\t\treturn \"removed\"\n   370→\t}\n   371→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   372→\tif err != nil {\n   373→\t\treturn \"removed\"\n   374→\t}\n   375→\tif status.Running {\n   376→\t\treturn \"running\"\n   377→\t}\n   378→\tif run.ContainerKept {\n   379→\t\treturn \"available\"\n   380→\t}\n   381→\treturn \"stopped\"\n   382→}\n   383→\n   384→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   385→\tid := r.PathValue(\"id\")\n   386→\n   387→\trun, err := h.store.GetRun(r.Context(), id)\n   388→\tif err != nil {\n   389→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   390→\t\treturn\n   391→\t}\n   392→\n   393→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   394→\tif err != nil {\n   395→\t\tcaps = nil // non-fatal\n   396→\t}\n   397→\n   398→\tsteps := mergeCaptures(caps)\n   399→\n   400→\tdata := map[string]any{\n   401→\t\t\"Title\":          \"Run \" + run.ID,\n   402→\t\t\"Run\":            run,\n   403→\t\t\"Steps\":          steps,\n   404→\t\t\"Page\":           \"detail\",\n   405→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   406→\t}\n   407→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   408→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   409→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   410→\t}\n   411→}\n   412→\n   413→// --- JSON API handlers ---\n   414→\n   415→type apiRun struct {\n   416→\tID           string `json:\"id\"`\n   417→\tWorkflowName string `json:\"workflow_name\"`\n   418→\tProjectDir   string `json:\"project_dir\"`\n   419→\tProjectLabel string `json:\"project_label\"`\n   420→\tState        string `json:\"state\"`\n   421→\tStartedAt    string `json:\"started_at\"`\n   422→\tCompletedAt  string `json:\"completed_at\"`\n   423→\tContainerID  string `json:\"container_id\"`\n   424→\tErrorMessage string `json:\"error_message\"`\n   425→}\n   426→\n   427→type apiStep struct {\n   428→\tStepName    string `json:\"step_name\"`\n   429→\tResult      string `json:\"result\"`\n   430→\tStartedAt   string `json:\"started_at\"`\n   431→\tCompletedAt string `json:\"completed_at\"`\n   432→\tDuration    string `json:\"duration\"`\n   433→}\n   434→\n   435→type apiRunDetail struct {\n   436→\tapiRun\n   437→\tContainerState string    `json:\"container_state\"`\n   438→\tSteps          []apiStep `json:\"steps\"`\n   439→}\n   440→\n   441→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   442→\treturn apiRun{\n   443→\t\tID:           r.ID,\n   444→\t\tWorkflowName: r.WorkflowName,\n   445→\t\tProjectDir:   r.ProjectDir,\n   446→\t\tProjectLabel: labels[r.ProjectDir],\n   447→\t\tState:        string(r.State),\n   448→\t\tStartedAt:    formatTime(r.StartedAt),\n   449→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   450→\t\tContainerID:  r.ContainerID,\n   451→\t\tErrorMessage: r.ErrorMessage,\n   452→\t}\n   453→}\n   454→\n   455→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   456→\tprojectFilter := r.URL.Query().Get(\"project\")\n   457→\n   458→\tvar runs []*domain.Run\n   459→\tvar err error\n   460→\tif projectFilter != \"\" {\n   461→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   462→\t} else {\n   463→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   464→\t}\n   465→\tif err != nil {\n   466→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   467→\t\treturn\n   468→\t}\n   469→\n   470→\tprojects, _ := h.store.ListProjects(r.Context())\n   471→\tlabels := projectLabels(projects)\n   472→\n   473→\tresult := make([]apiRun, len(runs))\n   474→\tfor i, run := range runs {\n   475→\t\tresult[i] = toAPIRun(run, labels)\n   476→\t}\n   477→\n   478→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   479→\tjson.NewEncoder(w).Encode(result)\n   480→}\n   481→\n   482→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   483→\tprojects, err := h.store.ListProjects(r.Context())\n   484→\tif err != nil {\n   485→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   486→\t\treturn\n   487→\t}\n   488→\tlabels := projectLabels(projects)\n   489→\n   490→\ttype apiHealth struct {\n   491→\t\tStatus string `json:\"status\"`\n   492→\t\tPassed int    `json:\"passed\"`\n   493→\t\tFailed int    `json:\"failed\"`\n   494→\t\tTotal  int    `json:\"total\"`\n   495→\t}\n   496→\ttype apiProject struct {\n   497→\t\tDir         string    `json:\"dir\"`\n   498→\t\tLabel       string    `json:\"label\"`\n   499→\t\tHealth      apiHealth `json:\"health\"`\n   500→\t\tActiveCount int       `json:\"active_count\"`\n   501→\t}\n   502→\tresult := make([]apiProject, len(projects))\n   503→\tfor i, dir := range projects {\n   504→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   505→\t\trunValues := make([]domain.Run, len(runs))\n   506→\t\tfor j, rr := range runs {\n   507→\t\t\trunValues[j] = *rr\n   508→\t\t}\n   509→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   510→\t\tvar activeCount int\n   511→\t\tfor _, rr := range runs {\n   512→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   513→\t\t\t\tactiveCount++\n   514→\t\t\t}\n   515→\t\t}\n   516→\t\tresult[i] = apiProject{\n   517→\t\t\tDir:   dir,\n   518→\t\t\tLabel: labels[dir],\n   519→\t\t\tHealth: apiHealth{\n   520→\t\t\t\tStatus: string(health.Status),\n   521→\t\t\t\tPassed: health.Passed,\n   522→\t\t\t\tFailed: health.Failed,\n   523→\t\t\t\tTotal:  health.Total,\n   524→\t\t\t},\n   525→\t\t\tActiveCount: activeCount,\n   526→\t\t}\n   527→\t}\n   528→\n   529→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   530→\tjson.NewEncoder(w).Encode(result)\n   531→}\n   532→\n   533→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   534→\tid := r.PathValue(\"id\")\n   535→\n   536→\trun, err := h.store.GetRun(r.Context(), id)\n   537→\tif err != nil {\n   538→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   539→\t\treturn\n   540→\t}\n   541→\n   542→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   543→\tif err != nil {\n   544→\t\tcaps = nil\n   545→\t}\n   546→\n   547→\tprojects, _ := h.store.ListProjects(r.Context())\n   548→\tlabels := projectLabels(projects)\n   549→\n   550→\tmerged := mergeCaptures(caps)\n   551→\tsteps := make([]apiStep, len(merged))\n   552→\tfor i, e := range merged {\n   553→\t\tsteps[i] = apiStep{\n   554→\t\t\tStepName:  e.StepName,\n   555→\t\t\tResult:    e.Result,\n   556→\t\t\tStartedAt: formatTime(e.StartedAt),\n   557→\t\t\tDuration:  e.Duration,\n   558→\t\t}\n   559→\t}\n   560→\n   561→\tdetail := apiRunDetail{\n   562→\t\tapiRun:         toAPIRun(run, labels),\n   563→\t\tContainerState: h.containerState(r.Context(), run),\n   564→\t\tSteps:          steps,\n   565→\t}\n   566→\n   567→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   568→\tjson.NewEncoder(w).Encode(detail)\n   569→}\n   570→\n   571→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   572→\tid := r.PathValue(\"id\")\n   573→\tstep := r.PathValue(\"step\")\n   574→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   575→\n   576→\trun, err := h.store.GetRun(r.Context(), id)\n   577→\tif err != nil {\n   578→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   579→\t\treturn\n   580→\t}\n   581→\n   582→\t// Try log index first for fast lookup\n   583→\tif h.logStore != nil {\n   584→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   585→\t\tif err == nil && len(logFiles) > 0 {\n   586→\t\t\t// If type filter specified, narrow results\n   587→\t\t\tfor _, lf := range logFiles {\n   588→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   589→\t\t\t\t\tcontinue\n   590→\t\t\t\t}\n   591→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   592→\t\t\t\tif readErr == nil && len(data) > 0 {\n   593→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   594→\t\t\t\t\tw.Write(data)\n   595→\t\t\t\t\treturn\n   596→\t\t\t\t}\n   597→\t\t\t}\n   598→\t\t}\n   599→\t}\n   600→\n   601→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   602→\n   603→\t// Fall back to file path conventions\n   604→\t// If type is \"llm\", try llm-<step>.log\n   605→\tif logType == \"llm\" {\n   606→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   607→\t\tdata, err := os.ReadFile(llmPath)\n   608→\t\tif err == nil && len(data) > 0 {\n   609→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   610→\t\t\tw.Write(data)\n   611→\t\t\treturn\n   612→\t\t}\n   613→\t}\n   614→\n   615→\t// Try per-step output first, fall back to container.log, then live docker logs\n   616→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   617→\tdata, err := os.ReadFile(outputPath)\n   618→\tif err == nil && len(data) > 0 {\n   619→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   620→\t\tw.Write(data)\n   621→\t\treturn\n   622→\t}\n   623→\n   624→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   625→\tdata, err = os.ReadFile(containerLog)\n   626→\tif err == nil && len(data) > 0 {\n   627→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   628→\t\tw.Write(data)\n   629→\t\treturn\n   630→\t}\n   631→\n   632→\t// Last resort: try live docker logs from still-existing container\n   633→\tif h.container != nil && run.ContainerID != \"\" {\n   634→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   635→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   636→\t\t\tw.Write([]byte(logs))\n   637→\t\t\treturn\n   638→\t\t}\n   639→\t}\n   640→\n   641→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   642→}\n   643→\n   644→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   645→\tid := r.PathValue(\"id\")\n   646→\n   647→\trun, err := h.store.GetRun(r.Context(), id)\n   648→\tif err != nil {\n   649→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   650→\t\tw.WriteHeader(http.StatusNotFound)\n   651→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   652→\t\treturn\n   653→\t}\n   654→\n   655→\tmgr, ok := h.container.(ContainerManager)\n   656→\tif !ok || run.ContainerID == \"\" {\n   657→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   658→\t\tw.WriteHeader(http.StatusBadRequest)\n   659→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   660→\t\treturn\n   661→\t}\n   662→\n   663→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   664→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   665→\t\tw.WriteHeader(http.StatusInternalServerError)\n   666→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   667→\t\treturn\n   668→\t}\n   669→\n   670→\trun.ContainerKept = false\n   671→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   672→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   673→\t\tw.WriteHeader(http.StatusInternalServerError)\n   674→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   675→\t\treturn\n   676→\t}\n   677→\n   678→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   679→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   680→}\n   681→\n   682→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   683→\tlabel := r.PathValue(\"name\")\n   684→\n   685→\t// Resolve label back to project directory via the store.\n   686→\tprojects, _ := h.store.ListProjects(r.Context())\n   687→\tlabels := projectLabels(projects)\n   688→\tvar projectDir string\n   689→\tfor dir, l := range labels {\n   690→\t\tif l == label {\n   691→\t\t\tprojectDir = dir\n   692→\t\t\tbreak\n   693→\t\t}\n   694→\t}\n   695→\tif projectDir == \"\" {\n   696→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   697→\t\tw.WriteHeader(http.StatusNotFound)\n   698→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   699→\t\treturn\n   700→\t}\n   701→\n   702→\tif h.orchestrateFn == nil {\n   703→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   704→\t\tw.WriteHeader(http.StatusNotImplemented)\n   705→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   706→\t\treturn\n   707→\t}\n   708→\n   709→\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   710→\tif err != nil {\n   711→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   712→\t\tw.WriteHeader(http.StatusInternalServerError)\n   713→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   714→\t\treturn\n   715→\t}\n   716→\n   717→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   718→\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   719→}\n   720→\n   721→// handleAPIStream serves an SSE stream of log lines for a run.\n   722→// For active runs, it subscribes to the live broadcaster.\n   723→// For completed runs, it serves the archived full.log then closes.\n   724→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   725→\tid := r.PathValue(\"id\")\n   726→\n   727→\trun, err := h.store.GetRun(r.Context(), id)\n   728→\tif err != nil {\n   729→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   730→\t\treturn\n   731→\t}\n   732→\n   733→\tflusher, ok := w.(http.Flusher)\n   734→\tif !ok {\n   735→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   736→\t\treturn\n   737→\t}\n   738→\n   739→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   740→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   741→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   742→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   743→\n   744→\tisComplete := run.State == domain.RunStateSucceeded ||\n   745→\t\trun.State == domain.RunStateFailed ||\n   746→\t\trun.State == domain.RunStateCancelled\n   747→\n   748→\tif isComplete {\n   749→\t\t// Serve archived full.log\n   750→\t\th.streamFullLog(w, flusher, run)\n   751→\t\t// Send done event\n   752→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   753→\t\tflusher.Flush()\n   754→\t\treturn\n   755→\t}\n   756→\n   757→\t// Active run: subscribe to live broadcaster\n   758→\tif h.logBroadcast == nil {\n   759→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   760→\t\treturn\n   761→\t}\n   762→\n   763→\tsub := h.logBroadcast.Subscribe(id)\n   764→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   765→\n   766→\tctx := r.Context()\n   767→\tfor {\n   768→\t\tselect {\n   769→\t\tcase <-ctx.Done():\n   770→\t\t\treturn\n   771→\t\tcase line, ok := <-sub.C:\n   772→\t\t\tif !ok {\n   773→\t\t\t\t// Stream finished (run completed)\n   774→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   775→\t\t\t\tflusher.Flush()\n   776→\t\t\t\treturn\n   777→\t\t\t}\n   778→\t\t\tdata, _ := json.Marshal(line)\n   779→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   780→\t\t\tflusher.Flush()\n   781→\t\t}\n   782→\t}\n   783→}\n   784→\n   785→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   786→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   787→\n   788→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   789→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   790→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   791→\tf, err := os.Open(logPath)\n   792→\tif err != nil {\n   793→\t\treturn\n   794→\t}\n   795→\tdefer f.Close()\n   796→\n   797→\tscanner := bufio.NewScanner(f)\n   798→\tfor scanner.Scan() {\n   799→\t\ttext := scanner.Text()\n   800→\t\tline := parseFullLogLine(text)\n   801→\t\tdata, _ := json.Marshal(line)\n   802→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   803→\t\tflusher.Flush()\n   804→\t}\n   805→}\n   806→\n   807→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   808→func parseFullLogLine(text string) logstream.LogLine {\n   809→\tm := logLineRegex.FindStringSubmatch(text)\n   810→\tif m == nil {\n   811→\t\treturn logstream.LogLine{\n   812→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   813→\t\t\tType:      \"script\",\n   814→\t\t\tContent:   text,\n   815→\t\t}\n   816→\t}\n   817→\treturn logstream.LogLine{\n   818→\t\tTimestamp: m[1],\n   819→\t\tType:      m[2],\n   820→\t\tContent:   m[3],\n   821→\t}\n   822→}\n   823→\n   824→// --- Project detail handlers ---\n   825→\n   826→// resolveProjectDir resolves a project label from the URL to its directory path.\n   827→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   828→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   829→\tlabel := r.PathValue(\"name\")\n   830→\tprojects, _ := h.store.ListProjects(r.Context())\n   831→\tlabels := projectLabels(projects)\n   832→\tfor dir, l := range labels {\n   833→\t\tif l == label {\n   834→\t\t\treturn dir, label, true\n   835→\t\t}\n   836→\t}\n   837→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   838→\tw.WriteHeader(http.StatusNotFound)\n   839→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   840→\treturn \"\", \"\", false\n   841→}\n   842→\n   843→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   844→\tdir, label, ok := h.resolveProjectDir(w, r)\n   845→\tif !ok {\n   846→\t\treturn\n   847→\t}\n   848→\n   849→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   850→\tn := 10\n   851→\tif n > len(runs) {\n   852→\t\tn = len(runs)\n   853→\t}\n   854→\tdots := make([]recentRunDot, n)\n   855→\tfor i := 0; i < n; i++ {\n   856→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   857→\t}\n   858→\n   859→\tdata := map[string]any{\n   860→\t\t\"Title\":      label,\n   861→\t\t\"Label\":      label,\n   862→\t\t\"Dir\":        dir,\n   863→\t\t\"RecentRuns\": dots,\n   864→\t}\n   865→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   866→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   867→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   868→\t}\n   869→}\n   870→\n   871→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   872→\tdir, label, ok := h.resolveProjectDir(w, r)\n   873→\tif !ok {\n   874→\t\treturn\n   875→\t}\n   876→\n   877→\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   878→\tif err != nil {\n   879→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   880→\t\treturn\n   881→\t}\n   882→\n   883→\tprojects, _ := h.store.ListProjects(r.Context())\n   884→\tlabels := projectLabels(projects)\n   885→\n   886→\tcontainerCounts := map[string]int{}\n   887→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   888→\tfor _, run := range allRuns {\n   889→\t\tif run.ContainerKept {\n   890→\t\t\tcontainerCounts[run.ProjectDir]++\n   891→\t\t}\n   892→\t}\n   893→\n   894→\tvar projectList []projectEntry\n   895→\tfor _, d := range projects {\n   896→\t\tprojectList = append(projectList, projectEntry{Dir: d, Label: labels[d], ContainerCount: containerCounts[d]})\n   897→\t}\n   898→\tsort.Slice(projectList, func(i, j int) bool {\n   899→\t\treturn projectList[i].Label < projectList[j].Label\n   900→\t})\n   901→\n   902→\tdata := map[string]any{\n   903→\t\t\"Title\":         \"Runs\",\n   904→\t\t\"Runs\":          runs,\n   905→\t\t\"Projects\":      projectList,\n   906→\t\t\"ProjectFilter\": dir,\n   907→\t\t\"ProjectLabel\":  label,\n   908→\t\t\"ProjectLabels\": labels,\n   909→\t}\n   910→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   911→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   912→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   913→\t}\n   914→}\n   915→\n   916→func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   917→\tdir, _, ok := h.resolveProjectDir(w, r)\n   918→\tif !ok {\n   919→\t\treturn\n   920→\t}\n   921→\tif h.orchestrator == nil {\n   922→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   923→\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   924→\t\treturn\n   925→\t}\n   926→\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   927→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   928→\tjson.NewEncoder(w).Encode(map[string]any{\n   929→\t\t\"enabled\":     enabled,\n   930→\t\t\"in_flight\":   inFlight,\n   931→\t\t\"concurrency\": concurrency,\n   932→\t})\n   933→}\n   934→\n   935→func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   936→\tdir, _, ok := h.resolveProjectDir(w, r)\n   937→\tif !ok {\n   938→\t\treturn\n   939→\t}\n   940→\tif h.orchestrator == nil {\n   941→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   942→\t\tw.WriteHeader(http.StatusNotImplemented)\n   943→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   944→\t\treturn\n   945→\t}\n   946→\th.orchestrator.SetEnabled(dir, true)\n   947→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   948→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   949→}\n   950→\n   951→func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   952→\tdir, _, ok := h.resolveProjectDir(w, r)\n   953→\tif !ok {\n   954→\t\treturn\n   955→\t}\n   956→\tif h.orchestrator == nil {\n   957→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   958→\t\tw.WriteHeader(http.StatusNotImplemented)\n   959→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   960→\t\treturn\n   961→\t}\n   962→\th.orchestrator.SetEnabled(dir, false)\n   963→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   964→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   965→}\n   966→\n   967→func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   968→\tdir, _, ok := h.resolveProjectDir(w, r)\n   969→\tif !ok {\n   970→\t\treturn\n   971→\t}\n   972→\tif h.orchestrator == nil {\n   973→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   974→\t\tw.WriteHeader(http.StatusNotImplemented)\n   975→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   976→\t\treturn\n   977→\t}\n   978→\tvar body struct {\n   979→\t\tConcurrency int `json:\"concurrency\"`\n   980→\t}\n   981→\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n   982→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   983→\t\tw.WriteHeader(http.StatusBadRequest)\n   984→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n   985→\t\treturn\n   986→\t}\n   987→\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n   988→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   989→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   990→}\n   991→\n   992→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   993→\tdir, _, ok := h.resolveProjectDir(w, r)\n   994→\tif !ok {\n   995→\t\treturn\n   996→\t}\n   997→\n   998→\t// Docker image: read FROM line from Dockerfile\n   999→\tdockerImage := \"\"\n  1000→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n  1001→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n  1002→\t\t// Find the last FROM line (final stage)\n  1003→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n  1004→\t\t\ttrimmed := strings.TrimSpace(line)\n  1005→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n  1006→\t\t\t\tparts := strings.Fields(trimmed)\n  1007→\t\t\t\tif len(parts) >= 2 {\n  1008→\t\t\t\t\tdockerImage = parts[1]\n  1009→\t\t\t\t}\n  1010→\t\t\t}\n  1011→\t\t}\n  1012→\t}\n  1013→\n  1014→\t// Version\n  1015→\tversion := 0\n  1016→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n  1017→\tif data, err := os.ReadFile(versionPath); err == nil {\n  1018→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n  1019→\t\t\tversion = v\n  1020→\t\t}\n  1021→\t}\n  1022→\n  1023→\t// Prompt files history\n  1024→\ttype commitEntry struct {\n  1025→\t\tSHA     string `json:\"sha\"`\n  1026→\t\tDate    string `json:\"date\"`\n  1027→\t\tMessage string `json:\"message\"`\n  1028→\t}\n  1029→\ttype promptFile struct {\n  1030→\t\tPath    string        `json:\"path\"`\n  1031→\t\tHistory []commitEntry `json:\"history\"`\n  1032→\t}\n  1033→\n  1034→\tvar promptFiles []promptFile\n  1035→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n  1036→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n  1037→\t\tfor _, e := range entries {\n  1038→\t\t\tif e.IsDir() {\n  1039→\t\t\t\tcontinue\n  1040→\t\t\t}\n  1041→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n  1042→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n  1043→\t\t\tcmd.Dir = dir\n  1044→\t\t\tout, err := cmd.Output()\n  1045→\t\t\tif err != nil {\n  1046→\t\t\t\tcontinue\n  1047→\t\t\t}\n  1048→\t\t\tvar history []commitEntry\n  1049→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n  1050→\t\t\t\tif line == \"\" {\n  1051→\t\t\t\t\tcontinue\n  1052→\t\t\t\t}\n  1053→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1054→\t\t\t\tif len(parts) < 3 {\n  1055→\t\t\t\t\tcontinue\n  1056→\t\t\t\t}\n  1057→\t\t\t\t// Parse date to short form\n  1058→\t\t\t\tdateStr := parts[1]\n  1059→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1060→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1061→\t\t\t\t}\n  1062→\t\t\t\thistory = append(history, commitEntry{\n  1063→\t\t\t\t\tSHA:     parts[0][:7],\n  1064→\t\t\t\t\tDate:    dateStr,\n  1065→\t\t\t\t\tMessage: parts[2],\n  1066→\t\t\t\t})\n  1067→\t\t\t}\n  1068→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1069→\t\t}\n  1070→\t}\n  1071→\n  1072→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1073→\tjson.NewEncoder(w).Encode(map[string]any{\n  1074→\t\t\"docker_image\": dockerImage,\n  1075→\t\t\"version\":      version,\n  1076→\t\t\"prompt_files\": promptFiles,\n  1077→\t})\n  1078→}\n  1079→\n  1080→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1081→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1082→\tif !ok {\n  1083→\t\treturn\n  1084→\t}\n  1085→\tfile := r.URL.Query().Get(\"file\")\n  1086→\tsha := r.URL.Query().Get(\"sha\")\n  1087→\tif file == \"\" || sha == \"\" {\n  1088→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1089→\t\treturn\n  1090→\t}\n  1091→\n  1092→\t// Validate sha is alphanumeric to prevent injection\n  1093→\tfor _, c := range sha {\n  1094→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1095→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1096→\t\t\treturn\n  1097→\t\t}\n  1098→\t}\n  1099→\n  1100→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1101→\tcmd.Dir = dir\n  1102→\tout, err := cmd.Output()\n  1103→\tif err != nil {\n  1104→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1105→\t\treturn\n  1106→\t}\n  1107→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1108→\tw.Write(out)\n  1109→}\n  1110→\n  1111→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1112→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1113→\tif !ok {\n  1114→\t\treturn\n  1115→\t}\n  1116→\n  1117→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1118→\tentries, err := os.ReadDir(clocheDir)\n  1119→\tif err != nil {\n  1120→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1121→\t\tjson.NewEncoder(w).Encode([]any{})\n  1122→\t\treturn\n  1123→\t}\n  1124→\n  1125→\ttype apiWire struct {\n  1126→\t\tFrom   string `json:\"from\"`\n  1127→\t\tResult string `json:\"result\"`\n  1128→\t\tTo     string `json:\"to\"`\n  1129→\t}\n  1130→\ttype apiStepDef struct {\n  1131→\t\tName    string            `json:\"name\"`\n  1132→\t\tType    string            `json:\"type\"`\n  1133→\t\tResults []string          `json:\"results\"`\n  1134→\t\tConfig  map[string]string `json:\"config\"`\n  1135→\t}\n  1136→\ttype apiWorkflow struct {\n  1137→\t\tName      string       `json:\"name\"`\n  1138→\t\tFile      string       `json:\"file\"`\n  1139→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1140→\t\tWires     []apiWire    `json:\"wires\"`\n  1141→\t\tEntryStep string       `json:\"entry_step\"`\n  1142→\t}\n  1143→\n  1144→\tvar workflows []apiWorkflow\n  1145→\tfor _, e := range entries {\n  1146→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1147→\t\t\tcontinue\n  1148→\t\t}\n  1149→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1150→\t\tif err != nil {\n  1151→\t\t\tcontinue\n  1152→\t\t}\n  1153→\t\twf, err := dsl.Parse(string(data))\n  1154→\t\tif err != nil {\n  1155→\t\t\tcontinue\n  1156→\t\t}\n  1157→\t\tvar steps []apiStepDef\n  1158→\t\tfor _, s := range wf.Steps {\n  1159→\t\t\tsteps = append(steps, apiStepDef{\n  1160→\t\t\t\tName:    s.Name,\n  1161→\t\t\t\tType:    string(s.Type),\n  1162→\t\t\t\tResults: s.Results,\n  1163→\t\t\t\tConfig:  s.Config,\n  1164→\t\t\t})\n  1165→\t\t}\n  1166→\t\t// Sort steps by name for consistent ordering\n  1167→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1168→\n  1169→\t\tvar wires []apiWire\n  1170→\t\tfor _, wire := range wf.Wiring {\n  1171→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1172→\t\t}\n  1173→\n  1174→\t\tworkflows = append(workflows, apiWorkflow{\n  1175→\t\t\tName:      wf.Name,\n  1176→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1177→\t\t\tSteps:     steps,\n  1178→\t\t\tWires:     wires,\n  1179→\t\t\tEntryStep: wf.EntryStep,\n  1180→\t\t})\n  1181→\t}\n  1182→\n  1183→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1184→\tjson.NewEncoder(w).Encode(workflows)\n  1185→}\n  1186→\n  1187→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1188→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1189→\tif !ok {\n  1190→\t\treturn\n  1191→\t}\n  1192→\tworkflowName := r.PathValue(\"workflow\")\n  1193→\tstepName := r.PathValue(\"step\")\n  1194→\n  1195→\t// Find the workflow file\n  1196→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1197→\tvar wf *domain.Workflow\n  1198→\tentries, _ := os.ReadDir(clocheDir)\n  1199→\tfor _, e := range entries {\n  1200→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1201→\t\t\tcontinue\n  1202→\t\t}\n  1203→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1204→\t\tif err != nil {\n  1205→\t\t\tcontinue\n  1206→\t\t}\n  1207→\t\tparsed, err := dsl.Parse(string(data))\n  1208→\t\tif err != nil {\n  1209→\t\t\tcontinue\n  1210→\t\t}\n  1211→\t\tif parsed.Name == workflowName {\n  1212→\t\t\twf = parsed\n  1213→\t\t\tbreak\n  1214→\t\t}\n  1215→\t}\n  1216→\tif wf == nil {\n  1217→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1218→\t\treturn\n  1219→\t}\n  1220→\n  1221→\tstep, ok := wf.Steps[stepName]\n  1222→\tif !ok {\n  1223→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1224→\t\treturn\n  1225→\t}\n  1226→\n  1227→\t// Try to read the referenced file from step config\n  1228→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1229→\n  1230→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1231→\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1232→\t\tif err == nil {\n  1233→\t\t\tw.Write(data)\n  1234→\t\t\treturn\n  1235→\t\t}\n  1236→\t}\n  1237→\tif script := step.Config[\"command\"]; script != \"\" {\n  1238→\t\tw.Write([]byte(script))\n  1239→\t\treturn\n  1240→\t}\n  1241→\tif script := step.Config[\"script\"]; script != \"\" {\n  1242→\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1243→\t\tif err == nil {\n  1244→\t\t\tw.Write(data)\n  1245→\t\t\treturn\n  1246→\t\t}\n  1247→\t\tw.Write([]byte(script))\n  1248→\t\treturn\n  1249→\t}\n  1250→\n  1251→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1252→}\n  1253→\n  1254→// --- Template helpers ---\n  1255→\n  1256→func stateColor(state domain.RunState) string {\n  1257→\tswitch state {\n  1258→\tcase domain.RunStatePending:\n  1259→\t\treturn \"pending\"\n  1260→\tcase domain.RunStateRunning:\n  1261→\t\treturn \"running\"\n  1262→\tcase domain.RunStateSucceeded:\n  1263→\t\treturn \"succeeded\"\n  1264→\tcase domain.RunStateFailed:\n  1265→\t\treturn \"failed\"\n  1266→\tcase domain.RunStateCancelled:\n  1267→\t\treturn \"cancelled\"\n  1268→\tdefault:\n  1269→\t\treturn \"pending\"\n  1270→\t}\n  1271→}\n  1272→\n  1273→func healthColor(status domain.HealthStatus) string {\n  1274→\tswitch status {\n  1275→\tcase domain.HealthGreen:\n  1276→\t\treturn \"green\"\n  1277→\tcase domain.HealthYellow:\n  1278→\t\treturn \"yellow\"\n  1279→\tcase domain.HealthRed:\n  1280→\t\treturn \"red\"\n  1281→\tcase domain.HealthBlue:\n  1282→\t\treturn \"blue\"\n  1283→\tdefault:\n  1284→\t\treturn \"grey\"\n  1285→\t}\n  1286→}\n  1287→\n  1288→func formatTime(t time.Time) string {\n  1289→\tif t.IsZero() {\n  1290→\t\treturn \"\"\n  1291→\t}\n  1292→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1293→}\n  1294→\n  1295→func formatDuration(start, end time.Time) string {\n  1296→\tif start.IsZero() || end.IsZero() {\n  1297→\t\treturn \"\"\n  1298→\t}\n  1299→\td := end.Sub(start)\n  1300→\tif d < time.Second {\n  1301→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1302→\t}\n  1303→\tif d < time.Minute {\n  1304→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1305→\t}\n  1306→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1307→}\n  1308→\n  1309→func truncate(s string, n int) string {\n  1310→\tif len(s) <= n {\n  1311→\t\treturn s\n  1312→\t}\n  1313→\treturn s[:n] + \"...\"\n  1314→}\n  1315→\n  1316→func shortContainerID(id string) string {\n  1317→\tif len(id) > 12 {\n  1318→\t\treturn id[:12]\n  1319→\t}\n  1320→\treturn id\n  1321→}\n  1322→\n  1323→// projectLabels builds a mapping from full project directory paths to short\n  1324→// display labels. Each label is the final directory component (e.g.\n  1325→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1326→// the same final name, the parent directory is prepended to disambiguate\n  1327→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1328→func projectLabels(dirs []string) map[string]string {\n  1329→\tlabels := make(map[string]string, len(dirs))\n  1330→\t// Group dirs by their base name to detect conflicts.\n  1331→\tbyBase := map[string][]string{}\n  1332→\tfor _, d := range dirs {\n  1333→\t\tbase := filepath.Base(d)\n  1334→\t\tbyBase[base] = append(byBase[base], d)\n  1335→\t}\n  1336→\tfor base, paths := range byBase {\n  1337→\t\tif len(paths) == 1 {\n  1338→\t\t\tlabels[paths[0]] = base\n  1339→\t\t} else {\n  1340→\t\t\tfor _, p := range paths {\n  1341→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1342→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1343→\t\t\t}\n  1344→\t\t}\n  1345→\t}\n  1346→\treturn labels\n  1347→}\n  1348→\n  1349→type projectEntry struct {\n  1350→\tDir            string\n  1351→\tLabel          string\n  1352→\tContainerCount int\n  1353→}\n  1354→"}]},"parent_tool_use_id":null,"session_id":"c16914ec-d525-4d0c-bd76-a1f22ab0c976","uuid":"4820a8aa-e977-4047-ae28-35d4d64af698","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\nfunc WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n\treturn func(h *Handler) { h.orchestrateFn = fn }\n}\n\n// OrchestratorController provides per-project orchestrator control.\ntype OrchestratorController interface {\n\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n\tSetEnabled(dir string, enabled bool)\n\tSetConcurrency(dir string, concurrency int)\n}\n\n// WithOrchestrator sets the orchestrator controller for project-level control.\nfunc WithOrchestrator(oc OrchestratorController) HandlerOption {\n\treturn func(h *Handler) { h.orchestrator = oc }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore         ports.RunStore\n\tcaptures      ports.CaptureStore\n\tlogStore      ports.LogStore\n\tcontainer     ContainerLogger\n\tlogBroadcast  *logstream.Broadcaster\n\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n\torchestrator  OrchestratorController\n\tpages         map[string]*template.Template\n\tmux           *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\t// Resolve project label for filtered view.\n\tvar projectLabel string\n\tif projectFilter != \"\" {\n\t\tprojectLabel = labels[projectFilter]\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabel\":  projectLabel,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\n\t// Resolve label back to project directory via the store.\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tvar projectDir string\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\tprojectDir = dir\n\t\t\tbreak\n\t\t}\n\t}\n\tif projectDir == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\t\treturn\n\t}\n\n\tif h.orchestrateFn == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\n\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, d := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: d, Label: labels[d], ContainerCount: containerCounts[d]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": dir,\n\t\t\"ProjectLabel\":  label,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n\t\treturn\n\t}\n\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"enabled\":     enabled,\n\t\t\"in_flight\":   inFlight,\n\t\t\"concurrency\": concurrency,\n\t})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, true)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, false)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\tvar body struct {\n\t\tConcurrency int `json:\"concurrency\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n\t\treturn\n\t}\n\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\tif script := step.Config[\"command\"]; script != \"\" {\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1354,"startLine":1,"totalLines":1354}}}
[2026-03-09T15:23:43Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018TD3L3KhTsLs7Gxcn62bWJ","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"net/http\"\n     8→\t\"net/http/httptest\"\n     9→\t\"testing\"\n    10→\t\"time\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    15→\t\"github.com/stretchr/testify/assert\"\n    16→\t\"github.com/stretchr/testify/require\"\n    17→)\n    18→\n    19→// mockContainerManager implements ContainerManager for testing.\n    20→type mockContainerManager struct {\n    21→\tcontainers map[string]bool // containerID -> exists\n    22→\trunning    map[string]bool // containerID -> running\n    23→\tremoved    []string\n    24→}\n    25→\n    26→func newMockContainerManager() *mockContainerManager {\n    27→\treturn &mockContainerManager{\n    28→\t\tcontainers: map[string]bool{},\n    29→\t\trunning:    map[string]bool{},\n    30→\t}\n    31→}\n    32→\n    33→func (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n    34→\treturn \"mock logs\", nil\n    35→}\n    36→\n    37→func (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n    38→\tif !m.containers[containerID] {\n    39→\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n    40→\t}\n    41→\tdelete(m.containers, containerID)\n    42→\tm.removed = append(m.removed, containerID)\n    43→\treturn nil\n    44→}\n    45→\n    46→func (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n    47→\tif !m.containers[containerID] {\n    48→\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n    49→\t}\n    50→\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n    51→}\n    52→\n    53→func setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n    54→\tt.Helper()\n    55→\tstore, err := sqlite.NewStore(\":memory:\")\n    56→\trequire.NoError(t, err)\n    57→\tt.Cleanup(func() { store.Close() })\n    58→\n    59→\th, err := NewHandler(store, store)\n    60→\trequire.NoError(t, err)\n    61→\treturn h, store\n    62→}\n    63→\n    64→func seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n    65→\tt.Helper()\n    66→\tseedRunWithProject(t, store, id, workflow, state, \"\")\n    67→}\n    68→\n    69→func seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n    70→\tt.Helper()\n    71→\tctx := context.Background()\n    72→\trun := domain.NewRun(id, workflow)\n    73→\trun.ProjectDir = projectDir\n    74→\tif state != domain.RunStatePending {\n    75→\t\trun.Start()\n    76→\t\trun.ContainerID = \"abc123def456789\"\n    77→\t}\n    78→\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n    79→\t\trun.Complete(state)\n    80→\t}\n    81→\tif state == domain.RunStateFailed {\n    82→\t\trun.ErrorMessage = \"something went wrong\"\n    83→\t}\n    84→\trequire.NoError(t, store.CreateRun(ctx, run))\n    85→}\n    86→\n    87→func TestRunsList_WithRuns(t *testing.T) {\n    88→\th, store := setupHandler(t)\n    89→\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n    90→\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n    91→\n    92→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n    93→\tw := httptest.NewRecorder()\n    94→\th.ServeHTTP(w, req)\n    95→\n    96→\tassert.Equal(t, http.StatusOK, w.Code)\n    97→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n    98→\tbody := w.Body.String()\n    99→\tassert.Contains(t, body, \"test-run-1\")\n   100→\tassert.Contains(t, body, \"test-run-2\")\n   101→\tassert.Contains(t, body, \"badge-running\")\n   102→\tassert.Contains(t, body, \"badge-succeeded\")\n   103→\tassert.Contains(t, body, \"develop\")\n   104→\tassert.Contains(t, body, \"deploy\")\n   105→}\n   106→\n   107→func TestRunsList_Empty(t *testing.T) {\n   108→\th, _ := setupHandler(t)\n   109→\n   110→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   111→\tw := httptest.NewRecorder()\n   112→\th.ServeHTTP(w, req)\n   113→\n   114→\tassert.Equal(t, http.StatusOK, w.Code)\n   115→\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n   116→}\n   117→\n   118→func TestRunDetail_WithCaptures(t *testing.T) {\n   119→\th, store := setupHandler(t)\n   120→\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n   121→\n   122→\tctx := context.Background()\n   123→\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n   124→\t\tStepName:    \"implement\",\n   125→\t\tResult:      \"success\",\n   126→\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n   127→\t\tCompletedAt: time.Now(),\n   128→\t}))\n   129→\n   130→\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n   131→\tw := httptest.NewRecorder()\n   132→\th.ServeHTTP(w, req)\n   133→\n   134→\tassert.Equal(t, http.StatusOK, w.Code)\n   135→\tbody := w.Body.String()\n   136→\tassert.Contains(t, body, \"run-detail-1\")\n   137→\tassert.Contains(t, body, \"implement\")\n   138→}\n   139→\n   140→func TestRunDetail_NotFound(t *testing.T) {\n   141→\th, _ := setupHandler(t)\n   142→\n   143→\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n   144→\tw := httptest.NewRecorder()\n   145→\th.ServeHTTP(w, req)\n   146→\n   147→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   148→}\n   149→\n   150→func TestAPIRuns(t *testing.T) {\n   151→\th, store := setupHandler(t)\n   152→\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n   153→\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n   154→\n   155→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   156→\tw := httptest.NewRecorder()\n   157→\th.ServeHTTP(w, req)\n   158→\n   159→\tassert.Equal(t, http.StatusOK, w.Code)\n   160→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   161→\n   162→\tvar runs []apiRun\n   163→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n   164→\tassert.Len(t, runs, 2)\n   165→\n   166→\tids := map[string]bool{}\n   167→\tfor _, r := range runs {\n   168→\t\tids[r.ID] = true\n   169→\t}\n   170→\tassert.True(t, ids[\"api-run-1\"])\n   171→\tassert.True(t, ids[\"api-run-2\"])\n   172→}\n   173→\n   174→func TestAPIRunDetail(t *testing.T) {\n   175→\th, store := setupHandler(t)\n   176→\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n   177→\n   178→\tctx := context.Background()\n   179→\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n   180→\t\tStepName:    \"build\",\n   181→\t\tResult:      \"success\",\n   182→\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n   183→\t\tCompletedAt: time.Now(),\n   184→\t}))\n   185→\n   186→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n   187→\tw := httptest.NewRecorder()\n   188→\th.ServeHTTP(w, req)\n   189→\n   190→\tassert.Equal(t, http.StatusOK, w.Code)\n   191→\n   192→\tvar detail apiRunDetail\n   193→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   194→\tassert.Equal(t, \"api-detail-1\", detail.ID)\n   195→\tassert.Equal(t, \"running\", detail.State)\n   196→\tassert.Len(t, detail.Steps, 1)\n   197→\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n   198→\tassert.NotEmpty(t, detail.Steps[0].Duration)\n   199→}\n   200→\n   201→func TestStaticCSS(t *testing.T) {\n   202→\th, _ := setupHandler(t)\n   203→\n   204→\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n   205→\tw := httptest.NewRecorder()\n   206→\th.ServeHTTP(w, req)\n   207→\n   208→\tassert.Equal(t, http.StatusOK, w.Code)\n   209→\tassert.Contains(t, w.Body.String(), \":root\")\n   210→\tassert.Contains(t, w.Body.String(), \"badge-running\")\n   211→}\n   212→\n   213→func TestHelpers(t *testing.T) {\n   214→\tt.Run(\"stateColor\", func(t *testing.T) {\n   215→\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n   216→\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n   217→\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n   218→\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n   219→\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n   220→\t})\n   221→\n   222→\tt.Run(\"formatTime\", func(t *testing.T) {\n   223→\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n   224→\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n   225→\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n   226→\t})\n   227→\n   228→\tt.Run(\"formatDuration\", func(t *testing.T) {\n   229→\t\tnow := time.Now()\n   230→\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n   231→\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n   232→\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n   233→\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n   234→\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n   235→\t})\n   236→\n   237→\tt.Run(\"truncate\", func(t *testing.T) {\n   238→\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n   239→\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n   240→\t})\n   241→\n   242→\tt.Run(\"shortContainerID\", func(t *testing.T) {\n   243→\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n   244→\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n   245→\t})\n   246→\n   247→\tt.Run(\"projectLabels\", func(t *testing.T) {\n   248→\t\t// No conflict: show base name only\n   249→\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n   250→\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n   251→\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n   252→\n   253→\t\t// Conflict: two dirs share the same base name\n   254→\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n   255→\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n   256→\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n   257→\n   258→\t\t// Mixed: some conflict, some don't\n   259→\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n   260→\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n   261→\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n   262→\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n   263→\n   264→\t\t// Empty list\n   265→\t\tlabels = projectLabels(nil)\n   266→\t\tassert.Empty(t, labels)\n   267→\t})\n   268→}\n   269→\n   270→func TestRunsList_ProjectFilter(t *testing.T) {\n   271→\th, store := setupHandler(t)\n   272→\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   273→\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   274→\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   275→\n   276→\t// Without filter: all runs shown\n   277→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   278→\tw := httptest.NewRecorder()\n   279→\th.ServeHTTP(w, req)\n   280→\tassert.Equal(t, http.StatusOK, w.Code)\n   281→\tbody := w.Body.String()\n   282→\tassert.Contains(t, body, \"run-a1\")\n   283→\tassert.Contains(t, body, \"run-b1\")\n   284→\n   285→\t// With project filter: only matching runs\n   286→\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n   287→\tw = httptest.NewRecorder()\n   288→\th.ServeHTTP(w, req)\n   289→\tassert.Equal(t, http.StatusOK, w.Code)\n   290→\tbody = w.Body.String()\n   291→\tassert.Contains(t, body, \"run-a1\")\n   292→\tassert.Contains(t, body, \"run-a2\")\n   293→\tassert.NotContains(t, body, \"run-b1\")\n   294→}\n   295→\n   296→func TestRunsList_ProjectColumn(t *testing.T) {\n   297→\th, store := setupHandler(t)\n   298→\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n   299→\n   300→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   301→\tw := httptest.NewRecorder()\n   302→\th.ServeHTTP(w, req)\n   303→\tassert.Equal(t, http.StatusOK, w.Code)\n   304→\tbody := w.Body.String()\n   305→\tassert.Contains(t, body, \"myproject\")\n   306→\tassert.Contains(t, body, \"Project\")\n   307→}\n   308→\n   309→func TestAPIRuns_ProjectFilter(t *testing.T) {\n   310→\th, store := setupHandler(t)\n   311→\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   312→\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   313→\n   314→\t// Without filter: all runs\n   315→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   316→\tw := httptest.NewRecorder()\n   317→\th.ServeHTTP(w, req)\n   318→\tassert.Equal(t, http.StatusOK, w.Code)\n   319→\n   320→\tvar allRuns []apiRun\n   321→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n   322→\tassert.Len(t, allRuns, 2)\n   323→\n   324→\t// With filter: only matching\n   325→\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n   326→\tw = httptest.NewRecorder()\n   327→\th.ServeHTTP(w, req)\n   328→\tassert.Equal(t, http.StatusOK, w.Code)\n   329→\n   330→\tvar filtered []apiRun\n   331→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n   332→\tassert.Len(t, filtered, 1)\n   333→\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n   334→\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n   335→\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n   336→}\n   337→\n   338→func setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n   339→\tt.Helper()\n   340→\tstore, err := sqlite.NewStore(\":memory:\")\n   341→\trequire.NoError(t, err)\n   342→\tt.Cleanup(func() { store.Close() })\n   343→\n   344→\tmgr := newMockContainerManager()\n   345→\th, err := NewHandler(store, store, WithContainerManager(mgr))\n   346→\trequire.NoError(t, err)\n   347→\treturn h, store, mgr\n   348→}\n   349→\n   350→func seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n   351→\tt.Helper()\n   352→\tctx := context.Background()\n   353→\trun := domain.NewRun(id, workflow)\n   354→\trun.ProjectDir = projectDir\n   355→\trun.Start()\n   356→\trun.ContainerID = containerID\n   357→\trun.ContainerKept = kept\n   358→\trun.Complete(domain.RunStateSucceeded)\n   359→\trequire.NoError(t, store.CreateRun(ctx, run))\n   360→\tif kept {\n   361→\t\tmgr.containers[containerID] = true\n   362→\t}\n   363→}\n   364→\n   365→func TestRunDetail_ContainerRunning(t *testing.T) {\n   366→\th, store, mgr := setupHandlerWithContainerManager(t)\n   367→\n   368→\tctx := context.Background()\n   369→\trun := domain.NewRun(\"run-cr\", \"develop\")\n   370→\trun.ProjectDir = \"/proj\"\n   371→\trun.Start()\n   372→\trun.ContainerID = \"cid-running\"\n   373→\trequire.NoError(t, store.CreateRun(ctx, run))\n   374→\tmgr.containers[\"cid-running\"] = true\n   375→\tmgr.running[\"cid-running\"] = true\n   376→\n   377→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n   378→\tw := httptest.NewRecorder()\n   379→\th.ServeHTTP(w, req)\n   380→\n   381→\tassert.Equal(t, http.StatusOK, w.Code)\n   382→\tbody := w.Body.String()\n   383→\tassert.Contains(t, body, \"Container running\")\n   384→\tassert.Contains(t, body, `badge-running\">Container running`)\n   385→}\n   386→\n   387→func TestRunDetail_ContainerStopped(t *testing.T) {\n   388→\th, store, mgr := setupHandlerWithContainerManager(t)\n   389→\n   390→\tctx := context.Background()\n   391→\trun := domain.NewRun(\"run-cs\", \"develop\")\n   392→\trun.ProjectDir = \"/proj\"\n   393→\trun.Start()\n   394→\trun.ContainerID = \"cid-stopped\"\n   395→\trun.ContainerKept = false\n   396→\trun.Complete(domain.RunStateSucceeded)\n   397→\trequire.NoError(t, store.CreateRun(ctx, run))\n   398→\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n   399→\n   400→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n   401→\tw := httptest.NewRecorder()\n   402→\th.ServeHTTP(w, req)\n   403→\n   404→\tassert.Equal(t, http.StatusOK, w.Code)\n   405→\tbody := w.Body.String()\n   406→\tassert.Contains(t, body, \"Container stopped\")\n   407→\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n   408→}\n   409→\n   410→func TestRunDetail_ContainerAvailable(t *testing.T) {\n   411→\th, store, mgr := setupHandlerWithContainerManager(t)\n   412→\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n   413→\n   414→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n   415→\tw := httptest.NewRecorder()\n   416→\th.ServeHTTP(w, req)\n   417→\n   418→\tassert.Equal(t, http.StatusOK, w.Code)\n   419→\tbody := w.Body.String()\n   420→\tassert.Contains(t, body, \"Container available\")\n   421→\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n   422→\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n   423→}\n   424→\n   425→func TestRunDetail_ContainerRemoved(t *testing.T) {\n   426→\th, store, _ := setupHandlerWithContainerManager(t)\n   427→\n   428→\tctx := context.Background()\n   429→\trun := domain.NewRun(\"run-c2\", \"develop\")\n   430→\trun.ProjectDir = \"/proj\"\n   431→\trun.Start()\n   432→\trun.ContainerID = \"cid-gone\"\n   433→\trun.ContainerKept = false\n   434→\trun.Complete(domain.RunStateSucceeded)\n   435→\trequire.NoError(t, store.CreateRun(ctx, run))\n   436→\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n   437→\n   438→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n   439→\tw := httptest.NewRecorder()\n   440→\th.ServeHTTP(w, req)\n   441→\n   442→\tassert.Equal(t, http.StatusOK, w.Code)\n   443→\tbody := w.Body.String()\n   444→\tassert.Contains(t, body, \"Container removed\")\n   445→\tassert.Contains(t, body, `badge-pending\">Container removed`)\n   446→}\n   447→\n   448→func TestAPIDeleteContainer_Success(t *testing.T) {\n   449→\th, store, mgr := setupHandlerWithContainerManager(t)\n   450→\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n   451→\n   452→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n   453→\tw := httptest.NewRecorder()\n   454→\th.ServeHTTP(w, req)\n   455→\n   456→\tassert.Equal(t, http.StatusOK, w.Code)\n   457→\n   458→\tvar resp map[string]string\n   459→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n   460→\tassert.Equal(t, \"ok\", resp[\"status\"])\n   461→\n   462→\t// Verify container was removed\n   463→\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n   464→\n   465→\t// Verify run was updated\n   466→\trun, err := store.GetRun(context.Background(), \"run-del1\")\n   467→\trequire.NoError(t, err)\n   468→\tassert.False(t, run.ContainerKept)\n   469→}\n   470→\n   471→func TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n   472→\th, _, _ := setupHandlerWithContainerManager(t)\n   473→\n   474→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n   475→\tw := httptest.NewRecorder()\n   476→\th.ServeHTTP(w, req)\n   477→\n   478→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   479→}\n   480→\n   481→func TestAPIDeleteContainer_NoManager(t *testing.T) {\n   482→\th, store := setupHandler(t) // no container manager\n   483→\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n   484→\n   485→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n   486→\tw := httptest.NewRecorder()\n   487→\th.ServeHTTP(w, req)\n   488→\n   489→\tassert.Equal(t, http.StatusBadRequest, w.Code)\n   490→}\n   491→\n   492→func TestAPIRunDetail_ContainerState(t *testing.T) {\n   493→\th, store, mgr := setupHandlerWithContainerManager(t)\n   494→\n   495→\t// Seed a running container\n   496→\tctx := context.Background()\n   497→\trun := domain.NewRun(\"api-cs1\", \"develop\")\n   498→\trun.ProjectDir = \"/proj\"\n   499→\trun.Start()\n   500→\trun.ContainerID = \"cid-api-running\"\n   501→\trequire.NoError(t, store.CreateRun(ctx, run))\n   502→\tmgr.containers[\"cid-api-running\"] = true\n   503→\tmgr.running[\"cid-api-running\"] = true\n   504→\n   505→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n   506→\tw := httptest.NewRecorder()\n   507→\th.ServeHTTP(w, req)\n   508→\n   509→\tassert.Equal(t, http.StatusOK, w.Code)\n   510→\n   511→\tvar detail apiRunDetail\n   512→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   513→\tassert.Equal(t, \"running\", detail.ContainerState)\n   514→\n   515→\t// Now stop it\n   516→\tmgr.running[\"cid-api-running\"] = false\n   517→\n   518→\tw = httptest.NewRecorder()\n   519→\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n   520→\n   521→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   522→\tassert.Equal(t, \"stopped\", detail.ContainerState)\n   523→}\n   524→\n   525→func TestProjectRuns(t *testing.T) {\n   526→\th, store := setupHandler(t)\n   527→\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   528→\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   529→\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   530→\n   531→\t// GET /projects/alpha/runs shows only alpha runs\n   532→\treq := httptest.NewRequest(\"GET\", \"/projects/alpha/runs\", nil)\n   533→\tw := httptest.NewRecorder()\n   534→\th.ServeHTTP(w, req)\n   535→\tassert.Equal(t, http.StatusOK, w.Code)\n   536→\tbody := w.Body.String()\n   537→\tassert.Contains(t, body, \"run-a1\")\n   538→\tassert.Contains(t, body, \"run-a2\")\n   539→\tassert.NotContains(t, body, \"run-b1\")\n   540→}\n   541→\n   542→func TestProjectRuns_NotFound(t *testing.T) {\n   543→\th, _ := setupHandler(t)\n   544→\n   545→\treq := httptest.NewRequest(\"GET\", \"/projects/nonexistent/runs\", nil)\n   546→\tw := httptest.NewRecorder()\n   547→\th.ServeHTTP(w, req)\n   548→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   549→}\n   550→\n   551→func TestRunsList_ContainerCount(t *testing.T) {\n   552→\th, store, mgr := setupHandlerWithContainerManager(t)\n   553→\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n   554→\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n   555→\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n   556→\n   557→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   558→\tw := httptest.NewRecorder()\n   559→\th.ServeHTTP(w, req)\n   560→\n   561→\tassert.Equal(t, http.StatusOK, w.Code)\n   562→\tbody := w.Body.String()\n   563→\t// alpha has 2 retained containers\n   564→\tassert.Contains(t, body, \"2 containers\")\n   565→\t// beta has 0, so no count should appear\n   566→\tassert.NotContains(t, body, \"0 container\")\n   567→}\n   568→\n   569→func TestAPIProjects(t *testing.T) {\n   570→\th, store := setupHandler(t)\n   571→\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   572→\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   573→\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   574→\n   575→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   576→\tw := httptest.NewRecorder()\n   577→\th.ServeHTTP(w, req)\n   578→\tassert.Equal(t, http.StatusOK, w.Code)\n   579→\n   580→\ttype apiHealth struct {\n   581→\t\tStatus string `json:\"status\"`\n   582→\t\tPassed int    `json:\"passed\"`\n   583→\t\tFailed int    `json:\"failed\"`\n   584→\t\tTotal  int    `json:\"total\"`\n   585→\t}\n   586→\ttype project struct {\n   587→\t\tDir         string    `json:\"dir\"`\n   588→\t\tLabel       string    `json:\"label\"`\n   589→\t\tHealth      apiHealth `json:\"health\"`\n   590→\t\tActiveCount int       `json:\"active_count\"`\n   591→\t}\n   592→\tvar projects []project\n   593→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   594→\tassert.Len(t, projects, 2)\n   595→\n   596→\tbyDir := map[string]project{}\n   597→\tfor _, p := range projects {\n   598→\t\tbyDir[p.Dir] = p\n   599→\t}\n   600→\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n   601→\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n   602→\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n   603→\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n   604→\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n   605→\t// beta has 1 running = blue (all in-progress), 1 active\n   606→\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n   607→\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n   608→}\n   609→\n   610→func TestProjectOverview_WithProjects(t *testing.T) {\n   611→\th, store := setupHandler(t)\n   612→\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   613→\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   614→\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   615→\n   616→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   617→\tw := httptest.NewRecorder()\n   618→\th.ServeHTTP(w, req)\n   619→\n   620→\tassert.Equal(t, http.StatusOK, w.Code)\n   621→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   622→\tbody := w.Body.String()\n   623→\t// Project cards should be present\n   624→\tassert.Contains(t, body, \"project-card\")\n   625→\tassert.Contains(t, body, \"alpha\")\n   626→\tassert.Contains(t, body, \"beta\")\n   627→\t// Health dots\n   628→\tassert.Contains(t, body, \"health-dot\")\n   629→\t// Run history dots\n   630→\tassert.Contains(t, body, \"run-dot\")\n   631→\t// Quick actions\n   632→\tassert.Contains(t, body, \"View Runs\")\n   633→\tassert.Contains(t, body, \"Trigger Orchestrator\")\n   634→}\n   635→\n   636→func TestProjectOverview_Empty(t *testing.T) {\n   637→\th, _ := setupHandler(t)\n   638→\n   639→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   640→\tw := httptest.NewRecorder()\n   641→\th.ServeHTTP(w, req)\n   642→\n   643→\tassert.Equal(t, http.StatusOK, w.Code)\n   644→\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n   645→}\n   646→\n   647→func TestAPITriggerOrchestrator_NoOrchestrator(t *testing.T) {\n   648→\th, store := setupHandler(t)\n   649→\tseedRunWithProject(t, store, \"orch-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   650→\n   651→\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n   652→\tw := httptest.NewRecorder()\n   653→\th.ServeHTTP(w, req)\n   654→\n   655→\tassert.Equal(t, http.StatusNotImplemented, w.Code)\n   656→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   657→\n   658→\tvar result map[string]string\n   659→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   660→\tassert.Equal(t, \"orchestrator not configured\", result[\"error\"])\n   661→}\n   662→\n   663→func TestAPITriggerOrchestrator_Success(t *testing.T) {\n   664→\tstore, err := sqlite.NewStore(\":memory:\")\n   665→\trequire.NoError(t, err)\n   666→\tt.Cleanup(func() { store.Close() })\n   667→\n   668→\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   669→\t\tassert.Equal(t, \"/home/user/myproject\", projectDir)\n   670→\t\treturn 3, nil\n   671→\t}))\n   672→\trequire.NoError(t, err)\n   673→\n   674→\tseedRunWithProject(t, store, \"orch-2\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   675→\n   676→\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n   677→\tw := httptest.NewRecorder()\n   678→\th.ServeHTTP(w, req)\n   679→\n   680→\tassert.Equal(t, http.StatusOK, w.Code)\n   681→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   682→\n   683→\tvar result map[string]any\n   684→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   685→\tassert.Equal(t, \"ok\", result[\"status\"])\n   686→\tassert.Equal(t, \"myproject\", result[\"project\"])\n   687→\tassert.Equal(t, float64(3), result[\"dispatched\"])\n   688→}\n   689→\n   690→func TestAPITriggerOrchestrator_ProjectNotFound(t *testing.T) {\n   691→\tstore, err := sqlite.NewStore(\":memory:\")\n   692→\trequire.NoError(t, err)\n   693→\tt.Cleanup(func() { store.Close() })\n   694→\n   695→\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   696→\t\treturn 0, nil\n   697→\t}))\n   698→\trequire.NoError(t, err)\n   699→\n   700→\treq := httptest.NewRequest(\"POST\", \"/api/projects/nonexistent/trigger\", nil)\n   701→\tw := httptest.NewRecorder()\n   702→\th.ServeHTTP(w, req)\n   703→\n   704→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   705→\n   706→\tvar result map[string]string\n   707→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   708→\tassert.Equal(t, \"project not found\", result[\"error\"])\n   709→}\n   710→\n   711→func TestAPITriggerOrchestrator_Error(t *testing.T) {\n   712→\tstore, err := sqlite.NewStore(\":memory:\")\n   713→\trequire.NoError(t, err)\n   714→\tt.Cleanup(func() { store.Close() })\n   715→\n   716→\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   717→\t\treturn 0, fmt.Errorf(\"orchestration failed\")\n   718→\t}))\n   719→\trequire.NoError(t, err)\n   720→\n   721→\tseedRunWithProject(t, store, \"orch-3\", \"develop\", domain.RunStateSucceeded, \"/home/user/errproject\")\n   722→\n   723→\treq := httptest.NewRequest(\"POST\", \"/api/projects/errproject/trigger\", nil)\n   724→\tw := httptest.NewRecorder()\n   725→\th.ServeHTTP(w, req)\n   726→\n   727→\tassert.Equal(t, http.StatusInternalServerError, w.Code)\n   728→\n   729→\tvar result map[string]string\n   730→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   731→\tassert.Equal(t, \"orchestration failed\", result[\"error\"])\n   732→}\n   733→\n   734→func TestHealthColor(t *testing.T) {\n   735→\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n   736→\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n   737→\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n   738→\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n   739→\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n   740→\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n   741→}\n   742→\n   743→func TestAPIProjects_HealthData(t *testing.T) {\n   744→\th, store := setupHandler(t)\n   745→\t// alpha: 3 succeeded, 1 failed → yellow\n   746→\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   747→\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   748→\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   749→\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   750→\n   751→\t// beta: all succeeded → green\n   752→\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   753→\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   754→\n   755→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   756→\tw := httptest.NewRecorder()\n   757→\th.ServeHTTP(w, req)\n   758→\tassert.Equal(t, http.StatusOK, w.Code)\n   759→\n   760→\ttype health struct {\n   761→\t\tStatus string `json:\"status\"`\n   762→\t\tPassed int    `json:\"passed\"`\n   763→\t\tFailed int    `json:\"failed\"`\n   764→\t\tTotal  int    `json:\"total\"`\n   765→\t}\n   766→\ttype project struct {\n   767→\t\tDir    string `json:\"dir\"`\n   768→\t\tLabel  string `json:\"label\"`\n   769→\t\tHealth health `json:\"health\"`\n   770→\t}\n   771→\tvar projects []project\n   772→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   773→\tassert.Len(t, projects, 2)\n   774→\n   775→\tbyDir := map[string]project{}\n   776→\tfor _, p := range projects {\n   777→\t\tbyDir[p.Dir] = p\n   778→\t}\n   779→\n   780→\talpha := byDir[\"/home/user/alpha\"]\n   781→\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n   782→\tassert.Equal(t, 3, alpha.Health.Passed)\n   783→\tassert.Equal(t, 1, alpha.Health.Failed)\n   784→\tassert.Equal(t, 4, alpha.Health.Total)\n   785→\n   786→\tbeta := byDir[\"/home/user/beta\"]\n   787→\tassert.Equal(t, \"green\", beta.Health.Status)\n   788→\tassert.Equal(t, 2, beta.Health.Passed)\n   789→\tassert.Equal(t, 0, beta.Health.Failed)\n   790→\tassert.Equal(t, 2, beta.Health.Total)\n   791→}\n   792→\n   793→func TestAPIProjects_HealthNoRuns(t *testing.T) {\n   794→\th, _ := setupHandler(t)\n   795→\n   796→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   797→\tw := httptest.NewRecorder()\n   798→\th.ServeHTTP(w, req)\n   799→\tassert.Equal(t, http.StatusOK, w.Code)\n   800→\n   801→\t// No projects means empty array\n   802→\ttype project struct {\n   803→\t\tDir   string `json:\"dir\"`\n   804→\t\tLabel string `json:\"label\"`\n   805→\t}\n   806→\tvar projects []project\n   807→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   808→\tassert.Empty(t, projects)\n   809→}\n   810→"}]},"parent_tool_use_id":null,"session_id":"c16914ec-d525-4d0c-bd76-a1f22ab0c976","uuid":"21d861c3-4e74-4f1d-9099-326a20354a1c","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler_test.go","content":"package web\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// mockContainerManager implements ContainerManager for testing.\ntype mockContainerManager struct {\n\tcontainers map[string]bool // containerID -> exists\n\trunning    map[string]bool // containerID -> running\n\tremoved    []string\n}\n\nfunc newMockContainerManager() *mockContainerManager {\n\treturn &mockContainerManager{\n\t\tcontainers: map[string]bool{},\n\t\trunning:    map[string]bool{},\n\t}\n}\n\nfunc (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n\treturn \"mock logs\", nil\n}\n\nfunc (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n\tif !m.containers[containerID] {\n\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\tdelete(m.containers, containerID)\n\tm.removed = append(m.removed, containerID)\n\treturn nil\n}\n\nfunc (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n\tif !m.containers[containerID] {\n\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n}\n\nfunc setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store)\n\trequire.NoError(t, err)\n\treturn h, store\n}\n\nfunc seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n\tt.Helper()\n\tseedRunWithProject(t, store, id, workflow, state, \"\")\n}\n\nfunc seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\tif state != domain.RunStatePending {\n\t\trun.Start()\n\t\trun.ContainerID = \"abc123def456789\"\n\t}\n\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n\t\trun.Complete(state)\n\t}\n\tif state == domain.RunStateFailed {\n\t\trun.ErrorMessage = \"something went wrong\"\n\t}\n\trequire.NoError(t, store.CreateRun(ctx, run))\n}\n\nfunc TestRunsList_WithRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"test-run-1\")\n\tassert.Contains(t, body, \"test-run-2\")\n\tassert.Contains(t, body, \"badge-running\")\n\tassert.Contains(t, body, \"badge-succeeded\")\n\tassert.Contains(t, body, \"develop\")\n\tassert.Contains(t, body, \"deploy\")\n}\n\nfunc TestRunsList_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n}\n\nfunc TestRunDetail_WithCaptures(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"implement\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-detail-1\")\n\tassert.Contains(t, body, \"implement\")\n}\n\nfunc TestRunDetail_NotFound(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar runs []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n\tassert.Len(t, runs, 2)\n\n\tids := map[string]bool{}\n\tfor _, r := range runs {\n\t\tids[r.ID] = true\n\t}\n\tassert.True(t, ids[\"api-run-1\"])\n\tassert.True(t, ids[\"api-run-2\"])\n}\n\nfunc TestAPIRunDetail(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"build\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"api-detail-1\", detail.ID)\n\tassert.Equal(t, \"running\", detail.State)\n\tassert.Len(t, detail.Steps, 1)\n\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n\tassert.NotEmpty(t, detail.Steps[0].Duration)\n}\n\nfunc TestStaticCSS(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \":root\")\n\tassert.Contains(t, w.Body.String(), \"badge-running\")\n}\n\nfunc TestHelpers(t *testing.T) {\n\tt.Run(\"stateColor\", func(t *testing.T) {\n\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n\t})\n\n\tt.Run(\"formatTime\", func(t *testing.T) {\n\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n\t})\n\n\tt.Run(\"formatDuration\", func(t *testing.T) {\n\t\tnow := time.Now()\n\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n\t})\n\n\tt.Run(\"truncate\", func(t *testing.T) {\n\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n\t})\n\n\tt.Run(\"shortContainerID\", func(t *testing.T) {\n\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n\t})\n\n\tt.Run(\"projectLabels\", func(t *testing.T) {\n\t\t// No conflict: show base name only\n\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n\n\t\t// Conflict: two dirs share the same base name\n\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n\n\t\t// Mixed: some conflict, some don't\n\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n\n\t\t// Empty list\n\t\tlabels = projectLabels(nil)\n\t\tassert.Empty(t, labels)\n\t})\n}\n\nfunc TestRunsList_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs shown\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-b1\")\n\n\t// With project filter: only matching runs\n\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody = w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-a2\")\n\tassert.NotContains(t, body, \"run-b1\")\n}\n\nfunc TestRunsList_ProjectColumn(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"myproject\")\n\tassert.Contains(t, body, \"Project\")\n}\n\nfunc TestAPIRuns_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar allRuns []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n\tassert.Len(t, allRuns, 2)\n\n\t// With filter: only matching\n\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar filtered []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n\tassert.Len(t, filtered, 1)\n\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n}\n\nfunc setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\tmgr := newMockContainerManager()\n\th, err := NewHandler(store, store, WithContainerManager(mgr))\n\trequire.NoError(t, err)\n\treturn h, store, mgr\n}\n\nfunc seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\trun.Start()\n\trun.ContainerID = containerID\n\trun.ContainerKept = kept\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tif kept {\n\t\tmgr.containers[containerID] = true\n\t}\n}\n\nfunc TestRunDetail_ContainerRunning(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cr\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-running\"] = true\n\tmgr.running[\"cid-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container running\")\n\tassert.Contains(t, body, `badge-running\">Container running`)\n}\n\nfunc TestRunDetail_ContainerStopped(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cs\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-stopped\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container stopped\")\n\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n}\n\nfunc TestRunDetail_ContainerAvailable(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container available\")\n\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n}\n\nfunc TestRunDetail_ContainerRemoved(t *testing.T) {\n\th, store, _ := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-c2\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-gone\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container removed\")\n\tassert.Contains(t, body, `badge-pending\">Container removed`)\n}\n\nfunc TestAPIDeleteContainer_Success(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"ok\", resp[\"status\"])\n\n\t// Verify container was removed\n\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n\n\t// Verify run was updated\n\trun, err := store.GetRun(context.Background(), \"run-del1\")\n\trequire.NoError(t, err)\n\tassert.False(t, run.ContainerKept)\n}\n\nfunc TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n\th, _, _ := setupHandlerWithContainerManager(t)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIDeleteContainer_NoManager(t *testing.T) {\n\th, store := setupHandler(t) // no container manager\n\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusBadRequest, w.Code)\n}\n\nfunc TestAPIRunDetail_ContainerState(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\t// Seed a running container\n\tctx := context.Background()\n\trun := domain.NewRun(\"api-cs1\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-api-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-api-running\"] = true\n\tmgr.running[\"cid-api-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"running\", detail.ContainerState)\n\n\t// Now stop it\n\tmgr.running[\"cid-api-running\"] = false\n\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"stopped\", detail.ContainerState)\n}\n\nfunc TestProjectRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// GET /projects/alpha/runs shows only alpha runs\n\treq := httptest.NewRequest(\"GET\", \"/projects/alpha/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-a2\")\n\tassert.NotContains(t, body, \"run-b1\")\n}\n\nfunc TestProjectRuns_NotFound(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/projects/nonexistent/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestRunsList_ContainerCount(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\t// alpha has 2 retained containers\n\tassert.Contains(t, body, \"2 containers\")\n\t// beta has 0, so no count should appear\n\tassert.NotContains(t, body, \"0 container\")\n}\n\nfunc TestAPIProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n\t// beta has 1 running = blue (all in-progress), 1 active\n\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n}\n\nfunc TestProjectOverview_WithProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\t// Project cards should be present\n\tassert.Contains(t, body, \"project-card\")\n\tassert.Contains(t, body, \"alpha\")\n\tassert.Contains(t, body, \"beta\")\n\t// Health dots\n\tassert.Contains(t, body, \"health-dot\")\n\t// Run history dots\n\tassert.Contains(t, body, \"run-dot\")\n\t// Quick actions\n\tassert.Contains(t, body, \"View Runs\")\n\tassert.Contains(t, body, \"Trigger Orchestrator\")\n}\n\nfunc TestProjectOverview_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n}\n\nfunc TestAPITriggerOrchestrator_NoOrchestrator(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"orch-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotImplemented, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar result map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"orchestrator not configured\", result[\"error\"])\n}\n\nfunc TestAPITriggerOrchestrator_Success(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\tassert.Equal(t, \"/home/user/myproject\", projectDir)\n\t\treturn 3, nil\n\t}))\n\trequire.NoError(t, err)\n\n\tseedRunWithProject(t, store, \"orch-2\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar result map[string]any\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"ok\", result[\"status\"])\n\tassert.Equal(t, \"myproject\", result[\"project\"])\n\tassert.Equal(t, float64(3), result[\"dispatched\"])\n}\n\nfunc TestAPITriggerOrchestrator_ProjectNotFound(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\treturn 0, nil\n\t}))\n\trequire.NoError(t, err)\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/nonexistent/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n\n\tvar result map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"project not found\", result[\"error\"])\n}\n\nfunc TestAPITriggerOrchestrator_Error(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\treturn 0, fmt.Errorf(\"orchestration failed\")\n\t}))\n\trequire.NoError(t, err)\n\n\tseedRunWithProject(t, store, \"orch-3\", \"develop\", domain.RunStateSucceeded, \"/home/user/errproject\")\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/errproject/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusInternalServerError, w.Code)\n\n\tvar result map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"orchestration failed\", result[\"error\"])\n}\n\nfunc TestHealthColor(t *testing.T) {\n\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n}\n\nfunc TestAPIProjects_HealthData(t *testing.T) {\n\th, store := setupHandler(t)\n\t// alpha: 3 succeeded, 1 failed → yellow\n\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\t// beta: all succeeded → green\n\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype health struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir    string `json:\"dir\"`\n\t\tLabel  string `json:\"label\"`\n\t\tHealth health `json:\"health\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\n\talpha := byDir[\"/home/user/alpha\"]\n\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n\tassert.Equal(t, 3, alpha.Health.Passed)\n\tassert.Equal(t, 1, alpha.Health.Failed)\n\tassert.Equal(t, 4, alpha.Health.Total)\n\n\tbeta := byDir[\"/home/user/beta\"]\n\tassert.Equal(t, \"green\", beta.Health.Status)\n\tassert.Equal(t, 2, beta.Health.Passed)\n\tassert.Equal(t, 0, beta.Health.Failed)\n\tassert.Equal(t, 2, beta.Health.Total)\n}\n\nfunc TestAPIProjects_HealthNoRuns(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\t// No projects means empty array\n\ttype project struct {\n\t\tDir   string `json:\"dir\"`\n\t\tLabel string `json:\"label\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Empty(t, projects)\n}\n","numLines":810,"startLine":1,"totalLines":810}}}
