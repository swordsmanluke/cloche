[2026-03-12T15:46:39Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HQmHxnwLStoK84Xai4w9AF","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"sync\"\n     6→\t\"sync/atomic\"\n     7→\t\"testing\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11→\t\"github.com/stretchr/testify/assert\"\n    12→)\n    13→\n    14→func TestLoop_StartStop(t *testing.T) {\n    15→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    16→\tvar called atomic.Int32\n    17→\n    18→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    19→\t\tcalled.Add(1)\n    20→\t\t// Simulate a run that finds no work (failed = aborted).\n    21→\t\ttime.Sleep(50 * time.Millisecond)\n    22→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    23→\t}\n    24→\n    25→\tloop := NewLoop(LoopConfig{\n    26→\t\tProjectDir:    \"/tmp/test-project\",\n    27→\t\tMaxConcurrent: 1,\n    28→\t}, store, runFn)\n    29→\n    30→\tif loop.Running() {\n    31→\t\tt.Fatal(\"loop should not be running before Start\")\n    32→\t}\n    33→\n    34→\tloop.Start()\n    35→\tif !loop.Running() {\n    36→\t\tt.Fatal(\"loop should be running after Start\")\n    37→\t}\n    38→\n    39→\t// Wait enough time for at least one run to happen.\n    40→\ttime.Sleep(200 * time.Millisecond)\n    41→\tloop.Stop()\n    42→\n    43→\tif loop.Running() {\n    44→\t\tt.Fatal(\"loop should not be running after Stop\")\n    45→\t}\n    46→\n    47→\tif called.Load() < 1 {\n    48→\t\tt.Fatal(\"expected at least one run to be launched\")\n    49→\t}\n    50→}\n    51→\n    52→func TestLoop_RampsUpOnSuccess(t *testing.T) {\n    53→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    54→\tvar called atomic.Int32\n    55→\n    56→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    57→\t\tn := called.Add(1)\n    58→\t\ttime.Sleep(20 * time.Millisecond)\n    59→\t\t// First 3 succeed, then fail (no more work).\n    60→\t\tif n <= 3 {\n    61→\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n    62→\t\t}\n    63→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    64→\t}\n    65→\n    66→\tloop := NewLoop(LoopConfig{\n    67→\t\tProjectDir:    \"/tmp/test-project\",\n    68→\t\tMaxConcurrent: 1,\n    69→\t}, store, runFn)\n    70→\n    71→\tloop.Start()\n    72→\t// With no backoff between successes, 3 successful + 1 failed should happen fast.\n    73→\ttime.Sleep(300 * time.Millisecond)\n    74→\tloop.Stop()\n    75→\n    76→\tif called.Load() < 4 {\n    77→\t\tt.Fatalf(\"expected at least 4 runs, got %d\", called.Load())\n    78→\t}\n    79→}\n    80→\n    81→func TestLoop_DoubleStartIsNoop(t *testing.T) {\n    82→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    83→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    84→\t\ttime.Sleep(100 * time.Millisecond)\n    85→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    86→\t}\n    87→\n    88→\tloop := NewLoop(LoopConfig{\n    89→\t\tProjectDir:    \"/tmp/test-project\",\n    90→\t\tMaxConcurrent: 1,\n    91→\t}, store, runFn)\n    92→\n    93→\tloop.Start()\n    94→\tloop.Start() // Should be a no-op.\n    95→\tloop.Stop()\n    96→}\n    97→\n    98→// fakeTaskAssigner implements TaskAssigner for testing.\n    99→type fakeTaskAssigner struct {\n   100→\tmu    sync.Mutex\n   101→\ttasks []Task\n   102→\tcalls int\n   103→}\n   104→\n   105→func (f *fakeTaskAssigner) ListTasks(_ context.Context, _ string) ([]Task, error) {\n   106→\tf.mu.Lock()\n   107→\tdefer f.mu.Unlock()\n   108→\tf.calls++\n   109→\tresult := make([]Task, len(f.tasks))\n   110→\tcopy(result, f.tasks)\n   111→\treturn result, nil\n   112→}\n   113→\n   114→func TestLoop_TaskAssigner_PassesTaskID(t *testing.T) {\n   115→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   116→\n   117→\tassigner := &fakeTaskAssigner{\n   118→\t\ttasks: []Task{\n   119→\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n   120→\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n   121→\t\t},\n   122→\t}\n   123→\n   124→\tvar receivedTaskIDs []string\n   125→\tvar mu sync.Mutex\n   126→\n   127→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   128→\t\tmu.Lock()\n   129→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   130→\t\tmu.Unlock()\n   131→\t\ttime.Sleep(20 * time.Millisecond)\n   132→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   133→\t}\n   134→\n   135→\tloop := NewLoop(LoopConfig{\n   136→\t\tProjectDir:    \"/tmp/test-project\",\n   137→\t\tMaxConcurrent: 1,\n   138→\t\tDedupTimeout:  1 * time.Second,\n   139→\t}, store, runFn)\n   140→\tloop.SetTaskAssigner(assigner)\n   141→\n   142→\tloop.Start()\n   143→\ttime.Sleep(200 * time.Millisecond)\n   144→\tloop.Stop()\n   145→\n   146→\tmu.Lock()\n   147→\tdefer mu.Unlock()\n   148→\t// Should have received task-1 first, then task-2 (task-1 is deduped).\n   149→\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2)\n   150→\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   151→\tassert.Equal(t, \"task-2\", receivedTaskIDs[1])\n   152→}\n   153→\n   154→func TestLoop_TaskAssigner_DedupPreventsReassignment(t *testing.T) {\n   155→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   156→\n   157→\tassigner := &fakeTaskAssigner{\n   158→\t\ttasks: []Task{{ID: \"task-1\"}},\n   159→\t}\n   160→\n   161→\tvar receivedTaskIDs []string\n   162→\tvar mu sync.Mutex\n   163→\n   164→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   165→\t\tmu.Lock()\n   166→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   167→\t\tmu.Unlock()\n   168→\t\ttime.Sleep(20 * time.Millisecond)\n   169→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   170→\t}\n   171→\n   172→\tloop := NewLoop(LoopConfig{\n   173→\t\tProjectDir:    \"/tmp/test-project\",\n   174→\t\tMaxConcurrent: 1,\n   175→\t\tDedupTimeout:  2 * time.Second, // long enough that task-1 won't be reassigned during test\n   176→\t}, store, runFn)\n   177→\tloop.SetTaskAssigner(assigner)\n   178→\n   179→\tloop.Start()\n   180→\ttime.Sleep(200 * time.Millisecond)\n   181→\tloop.Stop()\n   182→\n   183→\tmu.Lock()\n   184→\tdefer mu.Unlock()\n   185→\t// Only one run should have been launched since task-1 is deduped after first assignment.\n   186→\tassert.Equal(t, 1, len(receivedTaskIDs))\n   187→\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   188→}\n   189→\n   190→func TestLoop_TaskAssigner_DedupExpires(t *testing.T) {\n   191→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   192→\n   193→\tassigner := &fakeTaskAssigner{\n   194→\t\ttasks: []Task{{ID: \"task-1\"}},\n   195→\t}\n   196→\n   197→\tvar receivedTaskIDs []string\n   198→\tvar mu sync.Mutex\n   199→\n   200→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   201→\t\tmu.Lock()\n   202→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   203→\t\tmu.Unlock()\n   204→\t\t// Run takes longer than dedup timeout, so by the time the run\n   205→\t\t// completes the dedup window has already expired and pickTask\n   206→\t\t// can re-assign immediately without hitting capacityPollInterval.\n   207→\t\ttime.Sleep(100 * time.Millisecond)\n   208→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   209→\t}\n   210→\n   211→\tloop := NewLoop(LoopConfig{\n   212→\t\tProjectDir:    \"/tmp/test-project\",\n   213→\t\tMaxConcurrent: 1,\n   214→\t\tDedupTimeout:  50 * time.Millisecond,\n   215→\t}, store, runFn)\n   216→\tloop.SetTaskAssigner(assigner)\n   217→\n   218→\tloop.Start()\n   219→\ttime.Sleep(500 * time.Millisecond)\n   220→\tloop.Stop()\n   221→\n   222→\tmu.Lock()\n   223→\tdefer mu.Unlock()\n   224→\t// With 50ms dedup and 100ms run time, dedup expires before run completes,\n   225→\t// so task-1 should be assigned multiple times.\n   226→\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2, \"dedup should have expired, allowing reassignment\")\n   227→\tfor _, id := range receivedTaskIDs {\n   228→\t\tassert.Equal(t, \"task-1\", id)\n   229→\t}\n   230→}\n   231→\n   232→func TestLoop_TaskAssigner_NoTasks_BacksOff(t *testing.T) {\n   233→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   234→\n   235→\tassigner := &fakeTaskAssigner{\n   236→\t\ttasks: nil, // no tasks available\n   237→\t}\n   238→\n   239→\tvar called atomic.Int32\n   240→\n   241→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   242→\t\tcalled.Add(1)\n   243→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   244→\t}\n   245→\n   246→\tloop := NewLoop(LoopConfig{\n   247→\t\tProjectDir:    \"/tmp/test-project\",\n   248→\t\tMaxConcurrent: 1,\n   249→\t}, store, runFn)\n   250→\tloop.SetTaskAssigner(assigner)\n   251→\n   252→\tloop.Start()\n   253→\ttime.Sleep(200 * time.Millisecond)\n   254→\tloop.Stop()\n   255→\n   256→\t// With no tasks, no runs should have been launched.\n   257→\tassert.Equal(t, int32(0), called.Load())\n   258→}\n   259→\n   260→func TestLoop_NoTaskAssigner_EmptyTaskID(t *testing.T) {\n   261→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   262→\n   263→\tvar receivedTaskID string\n   264→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   265→\t\treceivedTaskID = taskID\n   266→\t\ttime.Sleep(20 * time.Millisecond)\n   267→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   268→\t}\n   269→\n   270→\tloop := NewLoop(LoopConfig{\n   271→\t\tProjectDir:    \"/tmp/test-project\",\n   272→\t\tMaxConcurrent: 1,\n   273→\t}, store, runFn)\n   274→\t// No SetTaskAssigner call — backward compatible mode.\n   275→\n   276→\tloop.Start()\n   277→\ttime.Sleep(200 * time.Millisecond)\n   278→\tloop.Stop()\n   279→\n   280→\t// Without a task assigner, taskID should be empty.\n   281→\tassert.Empty(t, receivedTaskID)\n   282→}\n   283→\n   284→// --- Three-phase (NewPhaseLoop) tests ---\n   285→\n   286→func TestPhaseLoop_BasicFlow(t *testing.T) {\n   287→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   288→\n   289→\tvar mainCalls, finalizeCalls atomic.Int32\n   290→\tvar receivedTaskIDs []string\n   291→\tvar mu sync.Mutex\n   292→\n   293→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   294→\t\treturn []Task{\n   295→\t\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n   296→\t\t\t{ID: \"task-2\", Status: \"closed\", Title: \"Done task\"},\n   297→\t\t}, nil\n   298→\t}\n   299→\n   300→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   301→\t\tmainCalls.Add(1)\n   302→\t\tmu.Lock()\n   303→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   304→\t\tmu.Unlock()\n   305→\t\ttime.Sleep(20 * time.Millisecond)\n   306→\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n   307→\t}\n   308→\n   309→\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n   310→\t\tfinalizeCalls.Add(1)\n   311→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   312→\t}\n   313→\n   314→\tloop := NewPhaseLoop(LoopConfig{\n   315→\t\tProjectDir:    \"/tmp/test-project\",\n   316→\t\tMaxConcurrent: 1,\n   317→\t\tDedupTimeout:  2 * time.Second,\n   318→\t}, store, listTasksFn, mainFn, finalizeFn)\n   319→\n   320→\tloop.Start()\n   321→\ttime.Sleep(300 * time.Millisecond)\n   322→\tloop.Stop()\n   323→\n   324→\t// Should have picked task-1 (open) and skipped task-2 (closed).\n   325→\tmu.Lock()\n   326→\tdefer mu.Unlock()\n   327→\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n   328→\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   329→\n   330→\t// Finalize should have run for each main completion.\n   331→\tassert.Equal(t, mainCalls.Load(), finalizeCalls.Load())\n   332→}\n   333→\n   334→func TestPhaseLoop_SkipsClosedTasks(t *testing.T) {\n   335→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   336→\n   337→\tvar mainCalls atomic.Int32\n   338→\n   339→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   340→\t\treturn []Task{\n   341→\t\t\t{ID: \"task-1\", Status: \"closed\"},\n   342→\t\t\t{ID: \"task-2\", Status: \"in-progress\"},\n   343→\t\t}, nil\n   344→\t}\n   345→\n   346→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   347→\t\tmainCalls.Add(1)\n   348→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   349→\t}\n   350→\n   351→\tloop := NewPhaseLoop(LoopConfig{\n   352→\t\tProjectDir:    \"/tmp/test-project\",\n   353→\t\tMaxConcurrent: 1,\n   354→\t}, store, listTasksFn, mainFn, nil)\n   355→\n   356→\tloop.Start()\n   357→\ttime.Sleep(200 * time.Millisecond)\n   358→\tloop.Stop()\n   359→\n   360→\t// No open tasks → no main runs.\n   361→\tassert.Equal(t, int32(0), mainCalls.Load())\n   362→}\n   363→\n   364→func TestPhaseLoop_FinalizeRunsOnFailure(t *testing.T) {\n   365→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   366→\n   367→\tvar finalizeOutcome string\n   368→\tvar mu sync.Mutex\n   369→\n   370→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   371→\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n   372→\t}\n   373→\n   374→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   375→\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateFailed}, nil\n   376→\t}\n   377→\n   378→\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n   379→\t\tmu.Lock()\n   380→\t\tfinalizeOutcome = string(mainResult.State)\n   381→\t\tmu.Unlock()\n   382→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   383→\t}\n   384→\n   385→\tloop := NewPhaseLoop(LoopConfig{\n   386→\t\tProjectDir:    \"/tmp/test-project\",\n   387→\t\tMaxConcurrent: 1,\n   388→\t\tDedupTimeout:  2 * time.Second,\n   389→\t}, store, listTasksFn, mainFn, finalizeFn)\n   390→\n   391→\tloop.Start()\n   392→\ttime.Sleep(300 * time.Millisecond)\n   393→\tloop.Stop()\n   394→\n   395→\t// Finalize should have received the failed state.\n   396→\tmu.Lock()\n   397→\tdefer mu.Unlock()\n   398→\tassert.Equal(t, \"failed\", finalizeOutcome)\n   399→}\n   400→\n   401→func TestPhaseLoop_NoFinalize(t *testing.T) {\n   402→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   403→\n   404→\tvar mainCalls atomic.Int32\n   405→\n   406→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   407→\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n   408→\t}\n   409→\n   410→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   411→\t\tmainCalls.Add(1)\n   412→\t\ttime.Sleep(20 * time.Millisecond)\n   413→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   414→\t}\n   415→\n   416→\t// nil finalize — should be skipped without error\n   417→\tloop := NewPhaseLoop(LoopConfig{\n   418→\t\tProjectDir:    \"/tmp/test-project\",\n   419→\t\tMaxConcurrent: 1,\n   420→\t\tDedupTimeout:  2 * time.Second,\n   421→\t}, store, listTasksFn, mainFn, nil)\n   422→\n   423→\tloop.Start()\n   424→\ttime.Sleep(200 * time.Millisecond)\n   425→\tloop.Stop()\n   426→\n   427→\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n   428→}\n   429→\n   430→func TestPhaseLoop_DedupFiltersOpenTasks(t *testing.T) {\n   431→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   432→\n   433→\tvar receivedTaskIDs []string\n   434→\tvar mu sync.Mutex\n   435→\n   436→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   437→\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n   438→\t}\n   439→\n   440→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   441→\t\tmu.Lock()\n   442→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   443→\t\tmu.Unlock()\n   444→\t\ttime.Sleep(20 * time.Millisecond)\n   445→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   446→\t}\n   447→\n   448→\tloop := NewPhaseLoop(LoopConfig{\n   449→\t\tProjectDir:    \"/tmp/test-project\",\n   450→\t\tMaxConcurrent: 1,\n   451→\t\tDedupTimeout:  2 * time.Second,\n   452→\t}, store, listTasksFn, mainFn, nil)\n   453→\n   454→\tloop.Start()\n   455→\ttime.Sleep(200 * time.Millisecond)\n   456→\tloop.Stop()\n   457→\n   458→\tmu.Lock()\n   459→\tdefer mu.Unlock()\n   460→\t// With 2s dedup, task-1 should only be assigned once.\n   461→\tassert.Equal(t, 1, len(receivedTaskIDs))\n   462→}\n   463→\n   464→// --- GetTaskSnapshot tests ---\n   465→\n   466→func TestLoop_GetTaskSnapshot_Empty(t *testing.T) {\n   467→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   468→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   469→\t\ttime.Sleep(100 * time.Millisecond)\n   470→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   471→\t}\n   472→\n   473→\tloop := NewLoop(LoopConfig{\n   474→\t\tProjectDir:    \"/tmp/test-project\",\n   475→\t\tMaxConcurrent: 1,\n   476→\t}, store, runFn)\n   477→\n   478→\tsnapshot := loop.GetTaskSnapshot()\n   479→\tassert.Empty(t, snapshot, \"snapshot should be empty when no tasks fetched\")\n   480→}\n   481→\n   482→func TestLoop_GetTaskSnapshot_ReturnsLastTasks(t *testing.T) {\n   483→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   484→\n   485→\ttasks := []Task{\n   486→\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n   487→\t\t{ID: \"task-2\", Status: \"closed\", Title: \"Done task\"},\n   488→\t\t{ID: \"task-3\", Status: \"open\", Title: \"Add feature\"},\n   489→\t}\n   490→\n   491→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   492→\t\treturn tasks, nil\n   493→\t}\n   494→\n   495→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   496→\t\ttime.Sleep(50 * time.Millisecond)\n   497→\t\treturn &RunResult{RunID: \"run-\" + taskID, State: domain.RunStateSucceeded}, nil\n   498→\t}\n   499→\n   500→\tloop := NewPhaseLoop(LoopConfig{\n   501→\t\tProjectDir:    \"/tmp/test-project\",\n   502→\t\tMaxConcurrent: 1,\n   503→\t\tDedupTimeout:  2 * time.Second,\n   504→\t}, store, listTasksFn, mainFn, nil)\n   505→\n   506→\tloop.Start()\n   507→\ttime.Sleep(300 * time.Millisecond)\n   508→\tloop.Stop()\n   509→\n   510→\tsnapshot := loop.GetTaskSnapshot()\n   511→\tassert.Len(t, snapshot, 3, \"should return all 3 tasks\")\n   512→\n   513→\t// task-1 should be assigned (it's open and was picked).\n   514→\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n   515→\tassert.True(t, snapshot[0].Assigned, \"task-1 should be assigned\")\n   516→\tassert.NotEmpty(t, snapshot[0].RunID, \"task-1 should have a run ID\")\n   517→\n   518→\t// task-2 is closed — should not be assigned.\n   519→\tassert.Equal(t, \"task-2\", snapshot[1].Task.ID)\n   520→\tassert.False(t, snapshot[1].Assigned, \"task-2 (closed) should not be assigned\")\n   521→\n   522→\t// task-3 should be assigned (it's open and would be picked after task-1).\n   523→\tassert.Equal(t, \"task-3\", snapshot[2].Task.ID)\n   524→\tassert.True(t, snapshot[2].Assigned, \"task-3 should be assigned\")\n   525→}\n   526→\n   527→func TestLoop_GetTaskSnapshot_LegacyWithAssigner(t *testing.T) {\n   528→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   529→\n   530→\tassigner := &fakeTaskAssigner{\n   531→\t\ttasks: []Task{\n   532→\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n   533→\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n   534→\t\t},\n   535→\t}\n   536→\n   537→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   538→\t\ttime.Sleep(20 * time.Millisecond)\n   539→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   540→\t}\n   541→\n   542→\tloop := NewLoop(LoopConfig{\n   543→\t\tProjectDir:    \"/tmp/test-project\",\n   544→\t\tMaxConcurrent: 1,\n   545→\t\tDedupTimeout:  2 * time.Second,\n   546→\t}, store, runFn)\n   547→\tloop.SetTaskAssigner(assigner)\n   548→\n   549→\tloop.Start()\n   550→\ttime.Sleep(200 * time.Millisecond)\n   551→\tloop.Stop()\n   552→\n   553→\tsnapshot := loop.GetTaskSnapshot()\n   554→\tassert.Len(t, snapshot, 2, \"should return tasks from assigner\")\n   555→\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n   556→\tassert.True(t, snapshot[0].Assigned, \"task-1 should be assigned\")\n   557→\tassert.Equal(t, \"task-2\", snapshot[1].Task.ID)\n   558→\tassert.True(t, snapshot[1].Assigned, \"task-2 should be assigned\")\n   559→}\n   560→\n   561→func TestLoop_GetTaskSnapshot_DedupExpired(t *testing.T) {\n   562→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   563→\n   564→\ttasks := []Task{\n   565→\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n   566→\t}\n   567→\n   568→\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n   569→\t\treturn tasks, nil\n   570→\t}\n   571→\n   572→\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   573→\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n   574→\t}\n   575→\n   576→\tloop := NewPhaseLoop(LoopConfig{\n   577→\t\tProjectDir:    \"/tmp/test-project\",\n   578→\t\tMaxConcurrent: 1,\n   579→\t\tDedupTimeout:  10 * time.Millisecond, // very short dedup\n   580→\t}, store, listTasksFn, mainFn, nil)\n   581→\n   582→\tloop.Start()\n   583→\ttime.Sleep(200 * time.Millisecond)\n   584→\tloop.Stop()\n   585→\n   586→\tsnapshot := loop.GetTaskSnapshot()\n   587→\tassert.Len(t, snapshot, 1)\n   588→\t// After dedup expires, the task should show as unassigned in the snapshot\n   589→\t// (the dedup check in GetTaskSnapshot uses current time).\n   590→\t// But the run ID may still be recorded from a previous assignment.\n   591→\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n   592→}\n   593→"}]},"parent_tool_use_id":null,"session_id":"88adcd43-a2b6-4c68-8f0c-4f6b9fedf8a8","uuid":"06f7fd25-9929-4d95-b287-5d80de7b18b5","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/loop_test.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"sync/atomic\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/stretchr/testify/assert\"\n)\n\nfunc TestLoop_StartStop(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tcalled.Add(1)\n\t\t// Simulate a run that finds no work (failed = aborted).\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\tif loop.Running() {\n\t\tt.Fatal(\"loop should not be running before Start\")\n\t}\n\n\tloop.Start()\n\tif !loop.Running() {\n\t\tt.Fatal(\"loop should be running after Start\")\n\t}\n\n\t// Wait enough time for at least one run to happen.\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tif loop.Running() {\n\t\tt.Fatal(\"loop should not be running after Stop\")\n\t}\n\n\tif called.Load() < 1 {\n\t\tt.Fatal(\"expected at least one run to be launched\")\n\t}\n}\n\nfunc TestLoop_RampsUpOnSuccess(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tn := called.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\t// First 3 succeed, then fail (no more work).\n\t\tif n <= 3 {\n\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t\t}\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\t// With no backoff between successes, 3 successful + 1 failed should happen fast.\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\tif called.Load() < 4 {\n\t\tt.Fatalf(\"expected at least 4 runs, got %d\", called.Load())\n\t}\n}\n\nfunc TestLoop_DoubleStartIsNoop(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\tloop.Start()\n\tloop.Start() // Should be a no-op.\n\tloop.Stop()\n}\n\n// fakeTaskAssigner implements TaskAssigner for testing.\ntype fakeTaskAssigner struct {\n\tmu    sync.Mutex\n\ttasks []Task\n\tcalls int\n}\n\nfunc (f *fakeTaskAssigner) ListTasks(_ context.Context, _ string) ([]Task, error) {\n\tf.mu.Lock()\n\tdefer f.mu.Unlock()\n\tf.calls++\n\tresult := make([]Task, len(f.tasks))\n\tcopy(result, f.tasks)\n\treturn result, nil\n}\n\nfunc TestLoop_TaskAssigner_PassesTaskID(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tassigner := &fakeTaskAssigner{\n\t\ttasks: []Task{\n\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n\t\t},\n\t}\n\n\tvar receivedTaskIDs []string\n\tvar mu sync.Mutex\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmu.Lock()\n\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n\t\tmu.Unlock()\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  1 * time.Second,\n\t}, store, runFn)\n\tloop.SetTaskAssigner(assigner)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tmu.Lock()\n\tdefer mu.Unlock()\n\t// Should have received task-1 first, then task-2 (task-1 is deduped).\n\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2)\n\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n\tassert.Equal(t, \"task-2\", receivedTaskIDs[1])\n}\n\nfunc TestLoop_TaskAssigner_DedupPreventsReassignment(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tassigner := &fakeTaskAssigner{\n\t\ttasks: []Task{{ID: \"task-1\"}},\n\t}\n\n\tvar receivedTaskIDs []string\n\tvar mu sync.Mutex\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmu.Lock()\n\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n\t\tmu.Unlock()\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second, // long enough that task-1 won't be reassigned during test\n\t}, store, runFn)\n\tloop.SetTaskAssigner(assigner)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tmu.Lock()\n\tdefer mu.Unlock()\n\t// Only one run should have been launched since task-1 is deduped after first assignment.\n\tassert.Equal(t, 1, len(receivedTaskIDs))\n\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n}\n\nfunc TestLoop_TaskAssigner_DedupExpires(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tassigner := &fakeTaskAssigner{\n\t\ttasks: []Task{{ID: \"task-1\"}},\n\t}\n\n\tvar receivedTaskIDs []string\n\tvar mu sync.Mutex\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmu.Lock()\n\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n\t\tmu.Unlock()\n\t\t// Run takes longer than dedup timeout, so by the time the run\n\t\t// completes the dedup window has already expired and pickTask\n\t\t// can re-assign immediately without hitting capacityPollInterval.\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  50 * time.Millisecond,\n\t}, store, runFn)\n\tloop.SetTaskAssigner(assigner)\n\n\tloop.Start()\n\ttime.Sleep(500 * time.Millisecond)\n\tloop.Stop()\n\n\tmu.Lock()\n\tdefer mu.Unlock()\n\t// With 50ms dedup and 100ms run time, dedup expires before run completes,\n\t// so task-1 should be assigned multiple times.\n\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2, \"dedup should have expired, allowing reassignment\")\n\tfor _, id := range receivedTaskIDs {\n\t\tassert.Equal(t, \"task-1\", id)\n\t}\n}\n\nfunc TestLoop_TaskAssigner_NoTasks_BacksOff(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tassigner := &fakeTaskAssigner{\n\t\ttasks: nil, // no tasks available\n\t}\n\n\tvar called atomic.Int32\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tcalled.Add(1)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\tloop.SetTaskAssigner(assigner)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\t// With no tasks, no runs should have been launched.\n\tassert.Equal(t, int32(0), called.Load())\n}\n\nfunc TestLoop_NoTaskAssigner_EmptyTaskID(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar receivedTaskID string\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treceivedTaskID = taskID\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\t// No SetTaskAssigner call — backward compatible mode.\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\t// Without a task assigner, taskID should be empty.\n\tassert.Empty(t, receivedTaskID)\n}\n\n// --- Three-phase (NewPhaseLoop) tests ---\n\nfunc TestPhaseLoop_BasicFlow(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar mainCalls, finalizeCalls atomic.Int32\n\tvar receivedTaskIDs []string\n\tvar mu sync.Mutex\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{\n\t\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n\t\t\t{ID: \"task-2\", Status: \"closed\", Title: \"Done task\"},\n\t\t}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\tmu.Lock()\n\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n\t\tmu.Unlock()\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n\t}\n\n\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n\t\tfinalizeCalls.Add(1)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, finalizeFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\t// Should have picked task-1 (open) and skipped task-2 (closed).\n\tmu.Lock()\n\tdefer mu.Unlock()\n\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n\n\t// Finalize should have run for each main completion.\n\tassert.Equal(t, mainCalls.Load(), finalizeCalls.Load())\n}\n\nfunc TestPhaseLoop_SkipsClosedTasks(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar mainCalls atomic.Int32\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{\n\t\t\t{ID: \"task-1\", Status: \"closed\"},\n\t\t\t{ID: \"task-2\", Status: \"in-progress\"},\n\t\t}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\t// No open tasks → no main runs.\n\tassert.Equal(t, int32(0), mainCalls.Load())\n}\n\nfunc TestPhaseLoop_FinalizeRunsOnFailure(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar finalizeOutcome string\n\tvar mu sync.Mutex\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateFailed}, nil\n\t}\n\n\tfinalizeFn := func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error) {\n\t\tmu.Lock()\n\t\tfinalizeOutcome = string(mainResult.State)\n\t\tmu.Unlock()\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, finalizeFn)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\t// Finalize should have received the failed state.\n\tmu.Lock()\n\tdefer mu.Unlock()\n\tassert.Equal(t, \"failed\", finalizeOutcome)\n}\n\nfunc TestPhaseLoop_NoFinalize(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar mainCalls atomic.Int32\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmainCalls.Add(1)\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\t// nil finalize — should be skipped without error\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tassert.GreaterOrEqual(t, int(mainCalls.Load()), 1)\n}\n\nfunc TestPhaseLoop_DedupFiltersOpenTasks(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tvar receivedTaskIDs []string\n\tvar mu sync.Mutex\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn []Task{{ID: \"task-1\", Status: \"open\"}}, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\tmu.Lock()\n\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n\t\tmu.Unlock()\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tmu.Lock()\n\tdefer mu.Unlock()\n\t// With 2s dedup, task-1 should only be assigned once.\n\tassert.Equal(t, 1, len(receivedTaskIDs))\n}\n\n// --- GetTaskSnapshot tests ---\n\nfunc TestLoop_GetTaskSnapshot_Empty(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t}, store, runFn)\n\n\tsnapshot := loop.GetTaskSnapshot()\n\tassert.Empty(t, snapshot, \"snapshot should be empty when no tasks fetched\")\n}\n\nfunc TestLoop_GetTaskSnapshot_ReturnsLastTasks(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\ttasks := []Task{\n\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n\t\t{ID: \"task-2\", Status: \"closed\", Title: \"Done task\"},\n\t\t{ID: \"task-3\", Status: \"open\", Title: \"Add feature\"},\n\t}\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn tasks, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\treturn &RunResult{RunID: \"run-\" + taskID, State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(300 * time.Millisecond)\n\tloop.Stop()\n\n\tsnapshot := loop.GetTaskSnapshot()\n\tassert.Len(t, snapshot, 3, \"should return all 3 tasks\")\n\n\t// task-1 should be assigned (it's open and was picked).\n\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n\tassert.True(t, snapshot[0].Assigned, \"task-1 should be assigned\")\n\tassert.NotEmpty(t, snapshot[0].RunID, \"task-1 should have a run ID\")\n\n\t// task-2 is closed — should not be assigned.\n\tassert.Equal(t, \"task-2\", snapshot[1].Task.ID)\n\tassert.False(t, snapshot[1].Assigned, \"task-2 (closed) should not be assigned\")\n\n\t// task-3 should be assigned (it's open and would be picked after task-1).\n\tassert.Equal(t, \"task-3\", snapshot[2].Task.ID)\n\tassert.True(t, snapshot[2].Assigned, \"task-3 should be assigned\")\n}\n\nfunc TestLoop_GetTaskSnapshot_LegacyWithAssigner(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\tassigner := &fakeTaskAssigner{\n\t\ttasks: []Task{\n\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n\t\t},\n\t}\n\n\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\ttime.Sleep(20 * time.Millisecond)\n\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  2 * time.Second,\n\t}, store, runFn)\n\tloop.SetTaskAssigner(assigner)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tsnapshot := loop.GetTaskSnapshot()\n\tassert.Len(t, snapshot, 2, \"should return tasks from assigner\")\n\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n\tassert.True(t, snapshot[0].Assigned, \"task-1 should be assigned\")\n\tassert.Equal(t, \"task-2\", snapshot[1].Task.ID)\n\tassert.True(t, snapshot[1].Assigned, \"task-2 should be assigned\")\n}\n\nfunc TestLoop_GetTaskSnapshot_DedupExpired(t *testing.T) {\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\ttasks := []Task{\n\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\"},\n\t}\n\n\tlistTasksFn := func(ctx context.Context, projectDir string) ([]Task, error) {\n\t\treturn tasks, nil\n\t}\n\n\tmainFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n\t\treturn &RunResult{RunID: \"run-1\", State: domain.RunStateSucceeded}, nil\n\t}\n\n\tloop := NewPhaseLoop(LoopConfig{\n\t\tProjectDir:    \"/tmp/test-project\",\n\t\tMaxConcurrent: 1,\n\t\tDedupTimeout:  10 * time.Millisecond, // very short dedup\n\t}, store, listTasksFn, mainFn, nil)\n\n\tloop.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tloop.Stop()\n\n\tsnapshot := loop.GetTaskSnapshot()\n\tassert.Len(t, snapshot, 1)\n\t// After dedup expires, the task should show as unassigned in the snapshot\n\t// (the dedup check in GetTaskSnapshot uses current time).\n\t// But the run ID may still be recorded from a previous assignment.\n\tassert.Equal(t, \"task-1\", snapshot[0].Task.ID)\n}\n","numLines":593,"startLine":1,"totalLines":593}}}
