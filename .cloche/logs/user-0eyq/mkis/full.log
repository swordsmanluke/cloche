(ctx, projectDir, \"list-tasks\")\n\tif err != nil {\n\t\treturn nil, nil, err\n\t}\n\tif result.State != domain.RunStateSucceeded {\n\t\treturn nil, result, fmt.Errorf(\"list-tasks workflow failed with state %s\", result.State)\n\t}\n\ttasks, err := ReadListTasksOutput(result.OutputDir)\n\tif err != nil {\n\t\treturn nil, result, err\n\t}\n\t// When list-tasks returns no tasks, remove the run record to keep the\n\t// run history focused on runs where actual work was attempted.\n\tif len(tasks) == 0 && result.RunID != \"\" {\n\t\t_ = runner.Store.DeleteRun(ctx, result.RunID)\n\t}\n\treturn tasks, result, nil\n}","numLines":25,"startLine":149,"totalLines":205}}}
[2026-03-12T15:46:39Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_012ZJG9aYKqqk7A4EawySoGD","type":"message","role":"assistant","content":[{"type":"text","text":"The implementation is complete. Here's a summary of the changes:\n\n**Problem:** The list-tasks workflow phase always created a run record via `Runner.RunNamed()`, even when no tasks were found. This cluttered the run history with empty list-tasks entries.\n\n**Solution:**\n\n1. **`internal/host/runner.go`** — Added `RunListTasksWorkflow()` helper that wraps running the list-tasks workflow. After a successful run with zero tasks returned, it deletes the run record from the store via `DeleteRun`.\n\n2. **`internal/adapters/grpc/server.go`** — Updated `createPhaseLoop`'s `listTasksFn` closure to use the new `RunListTasksWorkflow()` instead of manually calling `RunNamed` + `ReadListTasksOutput`.\n\n3. **`internal/host/executor_test.go`** — Added two tests:\n   - `TestRunListTasksWorkflow_EmptyResult_DeletesRun` — verifies the run record is deleted when list-tasks returns no tasks\n   - `TestRunListTasksWorkflow_WithTasks_KeepsRun` — verifies the run record is preserved when tasks are found\n\nCLOCHE_RESULT:success"}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":494,"cache_read_input_tokens":59854,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":494},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"88adcd43-a2b6-4c68-8f0c-4f6b9fedf8a8","uuid":"19f61cf4-f16c-42b3-861f-dbd38b799971"}
