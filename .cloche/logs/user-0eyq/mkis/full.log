[2026-03-12T15:46:39Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TYtWXEujTctBodU5XhwSrx","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"sync\"\n     6→\t\"sync/atomic\"\n     7→\t\"testing\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11→\t\"github.com/stretchr/testify/assert\"\n    12→)\n    13→\n    14→func TestLoop_StartStop(t *testing.T) {\n    15→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    16→\tvar called atomic.Int32\n    17→\n    18→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    19→\t\tcalled.Add(1)\n    20→\t\t// Simulate a run that finds no work (failed = aborted).\n    21→\t\ttime.Sleep(50 * time.Millisecond)\n    22→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    23→\t}\n    24→\n    25→\tloop := NewLoop(LoopConfig{\n    26→\t\tProjectDir:    \"/tmp/test-project\",\n    27→\t\tMaxConcurrent: 1,\n    28→\t}, store, runFn)\n    29→\n    30→\tif loop.Running() {\n    31→\t\tt.Fatal(\"loop should not be running before Start\")\n    32→\t}\n    33→\n    34→\tloop.Start()\n    35→\tif !loop.Running() {\n    36→\t\tt.Fatal(\"loop should be running after Start\")\n    37→\t}\n    38→\n    39→\t// Wait enough time for at least one run to happen.\n    40→\ttime.Sleep(200 * time.Millisecond)\n    41→\tloop.Stop()\n    42→\n    43→\tif loop.Running() {\n    44→\t\tt.Fatal(\"loop should not be running after Stop\")\n    45→\t}\n    46→\n    47→\tif called.Load() < 1 {\n    48→\t\tt.Fatal(\"expected at least one run to be launched\")\n    49→\t}\n    50→}\n    51→\n    52→func TestLoop_RampsUpOnSuccess(t *testing.T) {\n    53→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    54→\tvar called atomic.Int32\n    55→\n    56→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    57→\t\tn := called.Add(1)\n    58→\t\ttime.Sleep(20 * time.Millisecond)\n    59→\t\t// First 3 succeed, then fail (no more work).\n    60→\t\tif n <= 3 {\n    61→\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n    62→\t\t}\n    63→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    64→\t}\n    65→\n    66→\tloop := NewLoop(LoopConfig{\n    67→\t\tProjectDir:    \"/tmp/test-project\",\n    68→\t\tMaxConcurrent: 1,\n    69→\t}, store, runFn)\n    70→\n    71→\tloop.Start()\n    72→\t// With no backoff between successes, 3 successful + 1 failed should happen fast.\n    73→\ttime.Sleep(300 * time.Millisecond)\n    74→\tloop.Stop()\n    75→\n    76→\tif called.Load() < 4 {\n    77→\t\tt.Fatalf(\"expected at least 4 runs, got %d\", called.Load())\n    78→\t}\n    79→}\n    80→\n    81→func TestLoop_DoubleStartIsNoop(t *testing.T) {\n    82→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    83→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    84→\t\ttime.Sleep(100 * time.Millisecond)\n    85→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    86→\t}\n    87→\n    88→\tloop := NewLoop(LoopConfig{\n    89→\t\tProjectDir:    \"/tmp/test-project\",\n    90→\t\tMaxConcurrent: 1,\n    91→\t}, store, runFn)\n    92→\n    93→\tloop.Start()\n    94→\tloop.Start() // Should be a no-op.\n    95→\tloop.Stop()\n    96→}\n    97→\n    98→// fakeTaskAssigner implements TaskAssigner for testing.\n    99→type fakeTaskAssigner struct {\n   100→\tmu    sync.Mutex\n   101→\ttasks []Task\n   102→\tcalls int\n   103→}\n   104→\n   105→func (f *fakeTaskAssigner) ListTasks(_ context.Context, _ string) ([]Task, error) {\n   106→\tf.mu.Lock()\n   107→\tdefer f.mu.Unlock()\n   108→\tf.calls++\n   109→\tresult := make([]Task, len(f.tasks))\n   110→\tcopy(result, f.tasks)\n   111→\treturn result, nil\n   112→}\n   113→\n   114→func TestLoop_TaskAssigner_PassesTaskID(t *testing.T) {\n   115→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   116→\n   117→\tassigner := &fakeTaskAssigner{\n   118→\t\ttasks: []Task{\n   119→\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n   120→\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n   121→\t\t},\n   122→\t}\n   123→\n   124→\tvar receivedTaskIDs []string\n   125→\tvar mu sync.Mutex\n   126→\n   127→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   128→\t\tmu.Lock()\n   129→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   130→\t\tmu.Unlock()\n   131→\t\ttime.Sleep(20 * time.Millisecond)\n   132→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   133→\t}\n   134→\n   135→\tloop := NewLoop(LoopConfig{\n   136→\t\tProjectDir:    \"/tmp/test-project\",\n   137→\t\tMaxConcurrent: 1,\n   138→\t\tDedupTimeout:  1 * time.Second,\n   139→\t}, store, runFn)\n   140→\tloop.SetTaskAssigner(assigner)\n   141→\n   142→\tloop.Start()\n   143→\ttime.Sleep(200 * time.Millisecond)\n   144→\tloop.Stop()\n   145→\n   146→\tmu.Lock()\n   147→\tdefer mu.Unlock()\n   148→\t// Should have received task-1 first, then task-2 (task-1 is deduped).\n   149→\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2)\n   150→\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   151→\tassert.Equal(t, \"task-2\", receivedTaskIDs[1])\n   152→}\n   153→\n   154→func TestLoop_TaskAssigner_DedupPreventsReassignment(t *testing.T) {\n   155→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   156→\n   157→\tassigner := &fakeTaskAssigner{\n   158→\t\ttasks: []Task{{ID: \"task-1\"}},\n   159→\t}\n   160→\n   161→\tvar receivedTaskIDs []string\n   162→\tvar mu sync.Mutex\n   163→\n   164→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   165→\t\tmu.Lock()\n   166→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   167→\t\tmu.Unlock()\n   168→\t\ttime.Sleep(20 * time.Millisecond)\n   169→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   170→\t}\n   171→\n   172→\tloop := NewLoop(LoopConfig{\n   173→\t\tProjectDir:    \"/tmp/test-project\",\n   174→\t\tMaxConcurrent: 1,\n   175→\t\tDedupTimeout:  2 * time.Second, // long enough that task-1 won't be reassigned during test\n   176→\t}, store, runFn)\n   177→\tloop.SetTaskAssigner(assigner)\n   178→\n   179→\tloop.Start()\n   180→\ttime.Sleep(200 * time.Millisecond)\n   181→\tloop.Stop()\n   182→\n   183→\tmu.Lock()\n   184→\tdefer mu.Unlock()\n   185→\t// Only one run should have been launched since task-1 is deduped after first assignment.\n   186→\tassert.Equal(t, 1, len(receivedTaskIDs))\n   187→\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   188→}\n   189→\n   190→func TestLoop_TaskAssigner_DedupExpires(t *testing.T) {\n   191→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   192→\n   193→\tassigner := &fakeTaskAssigner{\n   194→\t\ttasks: []Task{{ID: \"task-1\"}},\n   195→\t}\n   196→\n   197→\tvar receivedTaskIDs []string\n   198→\tvar mu sync.Mutex\n   199→\n   200→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {"}]},"parent_tool_use_id":"toolu_01M5zerrENuK39Cn9Y311Bzn","session_id":"88adcd43-a2b6-4c68-8f0c-4f6b9fedf8a8","uuid":"40ed9982-82a1-43d9-b316-89c648140d86"}
