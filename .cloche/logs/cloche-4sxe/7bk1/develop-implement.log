{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F1WN9mLAp9vor4zbn3vQa7","type":"tool_result","content":"   370→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   371→\tctx := context.Background()\n   372→\n   373→\t// Register run in broadcaster so IsActive returns true for live-stream callers.\n   374→\tif s.logBroadcast != nil {\n   375→\t\ts.logBroadcast.Start(runID)\n   376→\t}\n   377→\n   378→\t// Attach to agent output\n   379→\treader, err := s.container.AttachOutput(ctx, containerID)\n   380→\tif err != nil {\n   381→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   382→\t\t\treturn\n   383→\t}\n   384→\n   385→\t// Parse JSON-lines status messages\n   386→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   387→\tvar reportedError string  // captured from MsgError, used to set ErrorMessage on failed runs\n   388→\tscanner := bufio.NewScanner(reader)\n   389→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   390→\tfor scanner.Scan() {\n   391→\t\tvar msg protocol.StatusMessage\n   392→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   393→\t\t\tcontinue\n   394→\t\t}\n   395→\n   396→\t\t// Fast path: log messages don't need store interaction.\n   397→\t\tif msg.Type == protocol.MsgLog {\n   398→\t\t\tif s.logBroadcast != nil {\n   399→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   400→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   401→\t\t\t\t\tType:      \"llm\",\n   402→\t\t\t\t\tContent:   msg.Message,\n   403→\t\t\t\t\tStepName:  msg.StepName,\n   404→\t\t\t\t})\n   405→\t\t\t}\n   406→\t\t\tcontinue\n   407→\t\t}\n   408→\n   409→\t\trun, err := s.store.GetRun(ctx, runID)\n   410→\t\tif err != nil {\n   411→\t\t\tcontinue\n   412→\t\t}\n   413→\n   414→\t\tswitch msg.Type {\n   415→\t\tcase protocol.MsgStepStarted:\n   416→\t\t\trun.RecordStepStart(msg.StepName)\n   417→\t\t\tif s.captures != nil {\n   418→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   419→\t\t\t\t\tStepName:  msg.StepName,\n   420→\t\t\t\t\tStartedAt: msg.Timestamp,\n   421→\t\t\t\t})\n   422→\t\t\t}\n   423→\t\t\tif s.logBroadcast != nil {\n   424→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   425→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   426→\t\t\t\t\tType:      \"status\",\n   427→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   428→\t\t\t\t\tStepName:  msg.StepName,\n   429→\t\t\t\t})\n   430→\t\t\t}\n   431→\t\tcase protocol.MsgStepCompleted:\n   432→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   433→\t\t\tif s.captures != nil {\n   434→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   435→\t\t\t\t\tStepName:    msg.StepName,\n   436→\t\t\t\t\tResult:      msg.Result,\n   437→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   438→\t\t\t\t})\n   439→\t\t\t}\n   440→\t\t\tif s.logBroadcast != nil {\n   441→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   442→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   443→\t\t\t\t\tType:      \"status\",\n   444→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   445→\t\t\t\t\tStepName:  msg.StepName,\n   446→\t\t\t\t})\n   447→\t\t\t}\n   448→\t\tcase protocol.MsgRunTitle:\n   449→\t\t\tif run.Title == \"\" {\n   450→\t\t\t\trun.Title = msg.Message\n   451→\t\t\t}\n   452→\t\tcase protocol.MsgError:\n   453→\t\t\treportedError = msg.Message\n   454→\t\t\tcontinue // Don't persist; used during finalization\n   455→\t\tcase protocol.MsgRunCompleted:\n   456→\t\t\treportedResult = msg.Result\n   457→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   458→\t\t}\n   459→\n   460→\t\t_ = s.store.UpdateRun(ctx, run)\n   461→\t}\n   462→\treader.Close()\n   463→\n   464→\t// Wait for process exit\n   465→\texitCode, err := s.container.Wait(ctx, containerID)\n   466→\tif err != nil {\n   467→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   468→\t}\n   469→\n   470→\t// Extract step output files from container before it's removed\n   471→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   472→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   473→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   474→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   475→\t\t}\n   476→\t}\n   477→\n   478→\t// Capture full container stdout/stderr before the container is removed\n   479→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   480→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   481→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   482→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   483→\t\t}\n   484→\t}\n   485→\n   486→\t// Index extracted log files in the log store\n   487→\tif s.logStore != nil {\n   488→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   489→\t}\n   490→\n   491→\t// Extract results to git branch BEFORE finalizing state, so that\n   492→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   493→\t// before the run is marked complete.\n   494→\tresultLabel := reportedResult\n   495→\tif resultLabel == \"\" {\n   496→\t\tif exitCode == 0 {\n   497→\t\t\tresultLabel = \"succeeded\"\n   498→\t\t} else {\n   499→\t\t\tresultLabel = \"failed\"\n   500→\t\t}\n   501→\t}\n   502→\t{\n   503→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   504→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   505→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   506→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   507→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   508→\t\t\t} else {\n   509→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   510→\t\t\t}\n   511→\t\t} else {\n   512→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   513→\t\t}\n   514→\t}\n   515→\n   516→\t// Now finalize run state\n   517→\trun, err := s.store.GetRun(ctx, runID)\n   518→\tif err != nil {\n   519→\t\treturn\n   520→\t}\n   521→\tif run.State == domain.RunStateRunning {\n   522→\t\tif reportedResult == \"succeeded\" {\n   523→\t\t\trun.Complete(domain.RunStateSucceeded)\n   524→\t\t} else if reportedResult != \"\" {\n   525→\t\t\tif reportedError != \"\" {\n   526→\t\t\t\trun.Fail(reportedError)\n   527→\t\t\t} else {\n   528→\t\t\t\trun.Complete(domain.RunStateFailed)\n   529→\t\t\t}\n   530→\t\t} else if exitCode == 0 {\n   531→\t\t\trun.Complete(domain.RunStateSucceeded)\n   532→\t\t} else {\n   533→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   534→\t\t}\n   535→\t\t_ = s.store.UpdateRun(ctx, run)\n   536→\t}\n   537→\n   538→\t// Signal live-stream subscribers that this run is done. This must happen\n   539→\t// AFTER the state update so that subscribers see the final state when\n   540→\t// their channel closes (prevents a race where the channel closes but\n   541→\t// the store still says \"running\", causing StreamLogs to return empty).\n   542→\tif s.logBroadcast != nil {\n   543→\t\ts.logBroadcast.Finish(runID)\n   544→\t}\n   545→\n   546→\t// Fire evolution trigger if configured\n   547→\tif s.evolution != nil {\n   548→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   549→\t}\n   550→\n   551→\t// Merge is handled as a workflow step in host.cloche, not here.\n   552→\n   553→\t// Container retention policy:\n   554→\t// - Failed runs: always keep the container for debugging\n   555→\t// - Successful runs + --keep-container: keep the container\n   556→\t// - Successful runs without --keep-container: remove the container\n   557→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   558→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   559→\n   560→\tif keepContainer || runFailed {\n   561→\t\treason := \"--keep-container\"\n   562→\t\tif runFailed {\n   563→\t\t\treason = \"run failed\"\n   564→\t\t}\n   565→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   566→\t\tif runFinal != nil {\n   567→\t\t\trunFinal.ContainerKept = true\n   568→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   569→\t\t}"}]},"parent_tool_use_id":"toolu_01CHsGfHFbwJREmYZ4LmDQS2","session_id":"20d5adfa-ca6e-4c90-b84e-e05e5aa65257","uuid":"b0ee2b9e-d85d-493f-8c4d-f54ebee011a2","timestamp":"2026-03-17T14:07:45.007Z"}
