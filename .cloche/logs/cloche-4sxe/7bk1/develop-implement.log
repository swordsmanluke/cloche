{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N2dSA43ZPaJyvdrgnmr5b3","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→\t\"testing\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    13→\t\"github.com/stretchr/testify/assert\"\n    14→\t\"github.com/stretchr/testify/require\"\n    15→)\n    16→\n    17→// fakeLLM returns a fixed response for testing.\n    18→type fakeLLM struct {\n    19→\tresponse string\n    20→}\n    21→\n    22→func (f *fakeLLM) Complete(ctx context.Context, system, user string) (string, error) {\n    23→\treturn f.response, nil\n    24→}\n    25→\n    26→// --- Collector tests ---\n    27→\n    28→func TestCollectorGathersData(t *testing.T) {\n    29→\tdir := t.TempDir()\n    30→\n    31→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n    32→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n    33→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.jsonl\"),\n    34→\t\t[]byte(`{\"id\":\"L000\",\"insight\":\"existing lesson\"}`+\"\\n\"), 0644)\n    35→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n    36→\t\t[]byte(\"Write good code\"), 0644)\n    37→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n    38→\t\t[]byte(`workflow \"develop\" {\n    39→  step impl {\n    40→    prompt = file(\".cloche/prompts/implement.md\")\n    41→    results = [success]\n    42→  }\n    43→  impl:success -> done\n    44→}`), 0644)\n    45→\n    46→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n    47→\tdata, err := c.Collect(context.Background(), nil, nil)\n    48→\trequire.NoError(t, err)\n    49→\n    50→\tassert.Contains(t, data.KnowledgeBase, \"existing lesson\")\n    51→\tassert.Contains(t, data.CurrentPrompts, \".cloche/prompts/implement.md\")\n    52→\tassert.Equal(t, \"Write good code\", data.CurrentPrompts[\".cloche/prompts/implement.md\"])\n    53→\tassert.NotEmpty(t, data.CurrentWorkflow)\n    54→\tassert.Equal(t, dir, data.ProjectDir)\n    55→\tassert.Equal(t, \"develop\", data.WorkflowName)\n    56→}\n    57→\n    58→func TestCollectorNoKnowledgeBase(t *testing.T) {\n    59→\tdir := t.TempDir()\n    60→\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n    61→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n    62→\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n    63→\n    64→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n    65→\tdata, err := c.Collect(context.Background(), nil, nil)\n    66→\trequire.NoError(t, err)\n    67→\tassert.Empty(t, data.KnowledgeBase)\n    68→}\n    69→\n    70→func TestExtractPromptFiles(t *testing.T) {\n    71→\tworkflow := `step impl { prompt = file(\".cloche/prompts/implement.md\") }\n    72→step fix { prompt = file(\".cloche/prompts/fix.md\") }\n    73→step test { run = \"make test\" }`\n    74→\n    75→\tfiles := extractPromptFiles(workflow)\n    76→\tassert.Len(t, files, 2)\n    77→\tassert.Contains(t, files, \".cloche/prompts/implement.md\")\n    78→\tassert.Contains(t, files, \".cloche/prompts/fix.md\")\n    79→}\n    80→\n    81→// --- Classifier tests ---\n    82→\n    83→func TestClassifierCategorizesRun(t *testing.T) {\n    84→\ttests := []struct {\n    85→\t\tname     string\n    86→\t\tresponse string\n    87→\t\texpected string\n    88→\t}{\n    89→\t\t{\"bug\", `{\"classification\": \"bug\"}`, \"bug\"},\n    90→\t\t{\"feature\", `{\"classification\": \"feature\"}`, \"feature\"},\n    91→\t\t{\"feedback\", `{\"classification\": \"feedback\"}`, \"feedback\"},\n    92→\t\t{\"enhancement\", `{\"classification\": \"enhancement\"}`, \"enhancement\"},\n    93→\t\t{\"chore\", `{\"classification\": \"chore\"}`, \"chore\"},\n    94→\t\t{\"invalid defaults to feature\", `{\"classification\": \"unknown\"}`, \"feature\"},\n    95→\t\t{\"malformed JSON defaults to feature\", `not json`, \"feature\"},\n    96→\t}\n    97→\n    98→\tfor _, tt := range tests {\n    99→\t\tt.Run(tt.name, func(t *testing.T) {\n   100→\t\t\tllm := &fakeLLM{response: tt.response}\n   101→\t\t\tc := &Classifier{LLM: llm}\n   102→\t\t\tresult, err := c.Classify(context.Background(), \"some prompt\")\n   103→\t\t\trequire.NoError(t, err)\n   104→\t\t\tassert.Equal(t, tt.expected, result)\n   105→\t\t})\n   106→\t}\n   107→}\n   108→\n   109→// --- Reflector tests ---\n   110→\n   111→func TestReflectorExtractsLessons(t *testing.T) {\n   112→\tlessonsJSON, _ := json.Marshal(map[string]any{\n   113→\t\t\"lessons\": []map[string]any{\n   114→\t\t\t{\n   115→\t\t\t\t\"id\":               \"lesson-001\",\n   116→\t\t\t\t\"category\":         \"prompt_improvement\",\n   117→\t\t\t\t\"target\":           \".cloche/prompts/implement.md\",\n   118→\t\t\t\t\"insight\":          \"Agent produces unsanitized HTML\",\n   119→\t\t\t\t\"suggested_action\": \"Add sanitization rule\",\n   120→\t\t\t\t\"evidence\":         []string{\"run-1\", \"run-2\"},\n   121→\t\t\t\t\"confidence\":       \"high\",\n   122→\t\t\t},\n   123→\t\t},\n   124→\t})\n   125→\n   126→\tllm := &fakeLLM{response: string(lessonsJSON)}\n   127→\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n   128→\n   129→\tdata := &CollectedData{WorkflowName: \"develop\", KnowledgeBase: \"# KB\\n\"}\n   130→\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n   131→\trequire.NoError(t, err)\n   132→\trequire.Len(t, lessons, 1)\n   133→\tassert.Equal(t, \"prompt_improvement\", lessons[0].Category)\n   134→\tassert.Equal(t, \"high\", lessons[0].Confidence)\n   135→}\n   136→\n   137→func TestReflectorFiltersLowConfidence(t *testing.T) {\n   138→\tlessonsJSON, _ := json.Marshal(map[string]any{\n   139→\t\t\"lessons\": []map[string]any{\n   140→\t\t\t{\"id\": \"L1\", \"category\": \"new_step\", \"confidence\": \"low\"},\n   141→\t\t\t{\"id\": \"L2\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n   142→\t\t},\n   143→\t})\n   144→\n   145→\tllm := &fakeLLM{response: string(lessonsJSON)}\n   146→\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n   147→\n   148→\tlessons, err := r.Reflect(context.Background(), &CollectedData{}, \"bug\")\n   149→\trequire.NoError(t, err)\n   150→\tassert.Len(t, lessons, 1)\n   151→\tassert.Equal(t, \"L2\", lessons[0].ID)\n   152→}\n   153→\n   154→func TestConfidenceLevel(t *testing.T) {\n   155→\tassert.Equal(t, 3, confidenceLevel(\"high\"))\n   156→\tassert.Equal(t, 2, confidenceLevel(\"medium\"))\n   157→\tassert.Equal(t, 1, confidenceLevel(\"low\"))\n   158→\tassert.Equal(t, 0, confidenceLevel(\"\"))\n   159→}\n   160→\n   161→// --- Audit Logger tests ---\n   162→\n   163→func TestAuditLoggerAppendsJSONL(t *testing.T) {\n   164→\tdir := t.TempDir()\n   165→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\"), 0755)\n   166→\n   167→\tlogger := &AuditLogger{ProjectDir: dir}\n   168→\n   169→\tresult1 := &EvolutionResult{\n   170→\t\tID:           \"evo-1\",\n   171→\t\tWorkflowName: \"develop\",\n   172→\t\tChanges:      []Change{{Type: \"prompt_update\", File: \".cloche/prompts/impl.md\"}},\n   173→\t}\n   174→\trequire.NoError(t, logger.Log(result1))\n   175→\n   176→\tresult2 := &EvolutionResult{\n   177→\t\tID:           \"evo-2\",\n   178→\t\tWorkflowName: \"develop\",\n   179→\t\tChanges:      []Change{{Type: \"add_step\", File: \".cloche/develop.cloche\"}},\n   180→\t}\n   181→\trequire.NoError(t, logger.Log(result2))\n   182→\n   183→\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n   184→\trequire.NoError(t, err)\n   185→\n   186→\tlines := strings.Split(strings.TrimSpace(string(content)), \"\\n\")\n   187→\tassert.Len(t, lines, 2)\n   188→\n   189→\tvar entry1 EvolutionResult\n   190→\trequire.NoError(t, json.Unmarshal([]byte(lines[0]), &entry1))\n   191→\tassert.Equal(t, \"evo-1\", entry1.ID)\n   192→}\n   193→\n   194→func TestAuditLoggerSnapshot(t *testing.T) {\n   195→\tdir := t.TempDir()\n   196→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   197→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   198→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"original content\"), 0644)\n   199→\n   200→\tlogger := &AuditLogger{ProjectDir: dir}\n   201→\tsnapName, err := logger.Snapshot(\".cloche/prompts/implement.md\")\n   202→\trequire.NoError(t, err)\n   203→\tassert.NotEmpty(t, snapName)\n   204→\n   205→\tsnapPath := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\", snapName)\n   206→\tcontent, err := os.ReadFile(snapPath)\n   207→\trequire.NoError(t, err)\n   208→\tassert.Equal(t, \"original content\", string(content))\n   209→}\n   210→\n   211→func TestAuditLoggerUpdatesKnowledge(t *testing.T) {\n   212→\tdir := t.TempDir()\n   213→\tkbDir := filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\")\n   214→\tos.MkdirAll(kbDir, 0755)\n   215→\n   216→\tlogger := &AuditLogger{ProjectDir: dir}\n   217→\tlessons := []Lesson{\n   218→\t\t{\n   219→\t\t\tID:              \"P001\",\n   220→\t\t\tCategory:        \"prompt_improvement\",\n   221→\t\t\tConfidence:      \"high\",\n   222→\t\t\tInsight:         \"Always sanitize HTML inputs\",\n   223→\t\t\tSuggestedAction: \"Add rule to implement prompt\",\n   224→\t\t\tEvidence:        []string{\"run-1\", \"run-2\"},\n   225→\t\t},\n   226→\t}\n   227→\n   228→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", lessons))\n   229→\n   230→\tcontent, err := os.ReadFile(filepath.Join(kbDir, \"develop.jsonl\"))\n   231→\trequire.NoError(t, err)\n   232→\tassert.Contains(t, string(content), \"P001\")\n   233→\tassert.Contains(t, string(content), \"sanitize HTML\")\n   234→\tassert.Contains(t, string(content), \"run-1\")\n   235→}\n   236→\n   237→func TestAuditLoggerDeduplicatesLessons(t *testing.T) {\n   238→\tdir := t.TempDir()\n   239→\tlogger := &AuditLogger{ProjectDir: dir}\n   240→\n   241→\tlesson := Lesson{\n   242→\t\tID:       \"L001\",\n   243→\t\tCategory: \"prompt_improvement\",\n   244→\t\tInsight:  \"Original insight\",\n   245→\t}\n   246→\n   247→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{lesson}))\n   248→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{lesson}))\n   249→\n   250→\t// Read back and verify only one entry\n   251→\tlessons, err := readKnowledge(logger.KnowledgePath(\"develop\"))\n   252→\trequire.NoError(t, err)\n   253→\tassert.Len(t, lessons, 1)\n   254→\tassert.Equal(t, \"L001\", lessons[0].ID)\n   255→}\n   256→\n   257→func TestAuditLoggerUpdatesExistingLesson(t *testing.T) {\n   258→\tdir := t.TempDir()\n   259→\tlogger := &AuditLogger{ProjectDir: dir}\n   260→\n   261→\toriginal := Lesson{ID: \"L001\", Insight: \"Original insight\"}\n   262→\tupdated := Lesson{ID: \"L001\", Insight: \"Updated insight\"}\n   263→\n   264→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{original}))\n   265→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{updated}))\n   266→\n   267→\tlessons, err := readKnowledge(logger.KnowledgePath(\"develop\"))\n   268→\trequire.NoError(t, err)\n   269→\tassert.Len(t, lessons, 1)\n   270→\tassert.Equal(t, \"Updated insight\", lessons[0].Insight)\n   271→}\n   272→\n   273→func TestAuditLoggerPrunesWithMaxPromptBullets(t *testing.T) {\n   274→\tdir := t.TempDir()\n   275→\tlogger := &AuditLogger{ProjectDir: dir, MaxPromptBullets: 5}\n   276→\n   277→\t// Add 10 lessons\n   278→\tfor i := 0; i < 10; i++ {\n   279→\t\tlesson := Lesson{\n   280→\t\t\tID:      fmt.Sprintf(\"L%03d\", i),\n   281→\t\t\tInsight: fmt.Sprintf(\"Insight %d\", i),\n   282→\t\t}\n   283→\t\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", []Lesson{lesson}))\n   284→\t}\n   285→\n   286→\tlessons, err := readKnowledge(logger.KnowledgePath(\"develop\"))\n   287→\trequire.NoError(t, err)\n   288→\tassert.Len(t, lessons, 5)\n   289→\t// Should keep the most recent 5 (L005-L009)\n   290→\tassert.Equal(t, \"L005\", lessons[0].ID)\n   291→\tassert.Equal(t, \"L009\", lessons[4].ID)\n   292→}\n   293→\n   294→// --- LLM Client tests ---\n   295→\n   296→// --- Curator tests ---\n   297→\n   298→func TestCuratorUpdatesPrompt(t *testing.T) {\n   299→\tdir := t.TempDir()\n   300→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   301→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   302→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   303→\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   304→\n   305→\tupdatedContent := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"\n   306→\tllm := &fakeLLM{response: updatedContent}\n   307→\n   308→\taudit := &AuditLogger{ProjectDir: dir}\n   309→\tc := &Curator{LLM: llm, Audit: audit}\n   310→\tlesson := &Lesson{\n   311→\t\tID:              \"lesson-001\",\n   312→\t\tCategory:        \"prompt_improvement\",\n   313→\t\tTarget:          \".cloche/prompts/implement.md\",\n   314→\t\tInsight:         \"XSS vulnerabilities in form handlers\",\n   315→\t\tSuggestedAction: \"Add sanitization rule\",\n   316→\t}\n   317→\n   318→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   319→\trequire.NoError(t, err)\n   320→\tassert.Equal(t, \"prompt_update\", change.Type)\n   321→\tassert.Equal(t, \".cloche/prompts/implement.md\", change.File)\n   322→\tassert.NotEmpty(t, change.Snapshot)\n   323→\n   324→\tcontent, err := os.ReadFile(promptPath)\n   325→\trequire.NoError(t, err)\n   326→\tassert.Contains(t, string(content), \"sanitize user inputs\")\n   327→}\n   328→\n   329→// --- stripCodeFences tests ---\n   330→\n   331→func TestStripCodeFences(t *testing.T) {\n   332→\ttests := []struct {\n   333→\t\tname     string\n   334→\t\tinput    string\n   335→\t\texpected string\n   336→\t}{\n   337→\t\t{\n   338→\t\t\tname:     \"no fences returns as-is\",\n   339→\t\t\tinput:    \"# Prompt\\n\\nDo good work.\\n\",\n   340→\t\t\texpected: \"# Prompt\\n\\nDo good work.\",\n   341→\t\t},\n   342→\t\t{\n   343→\t\t\tname:     \"plain code fence\",\n   344→\t\t\tinput:    \"```\\n# Prompt\\n\\nDo good work.\\n```\",\n   345→\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   346→\t\t},\n   347→\t\t{\n   348→\t\t\tname:     \"code fence with language hint\",\n   349→\t\t\tinput:    \"```markdown\\n# Prompt\\n\\nDo good work.\\n```\",\n   350→\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   351→\t\t},\n   352→\t\t{\n   353→\t\t\tname:     \"commentary before and after fence\",\n   354→\t\t\tinput:    \"Here's the updated prompt:\\n\\n```markdown\\n# Prompt\\n\\nDo good work.\\n```\\n\\nI've added the rule as requested.\",\n   355→\t\t\texpected: \"# Prompt\\n\\nDo good work.\\n\",\n   356→\t\t},\n   357→\t\t{\n   358→\t\t\tname:     \"no closing fence returns as-is\",\n   359→\t\t\tinput:    \"```markdown\\n# Prompt\\n\",\n   360→\t\t\texpected: \"```markdown\\n# Prompt\",\n   361→\t\t},\n   362→\t}\n   363→\n   364→\tfor _, tt := range tests {\n   365→\t\tt.Run(tt.name, func(t *testing.T) {\n   366→\t\t\tassert.Equal(t, tt.expected, stripCodeFences(tt.input))\n   367→\t\t})\n   368→\t}\n   369→}\n   370→\n   371→func TestCuratorStripsCodeFencesFromResponse(t *testing.T) {\n   372→\tdir := t.TempDir()\n   373→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   374→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   375→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   376→\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   377→\n   378→\t// LLM returns content wrapped in code fences with commentary\n   379→\tfencedResponse := \"Here is the updated prompt:\\n\\n```markdown\\n# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n```\\n\\nI added the validation rule.\"\n   380→\tllm := &fakeLLM{response: fencedResponse}\n   381→\n   382→\taudit := &AuditLogger{ProjectDir: dir}\n   383→\tc := &Curator{LLM: llm, Audit: audit}\n   384→\tlesson := &Lesson{\n   385→\t\tTarget:          \".cloche/prompts/implement.md\",\n   386→\t\tInsight:         \"Missing input validation\",\n   387→\t\tSuggestedAction: \"Add validation rule\",\n   388→\t}\n   389→\n   390→\t_, err := c.Apply(context.Background(), dir, lesson)\n   391→\trequire.NoError(t, err)\n   392→\n   393→\tcontent, err := os.ReadFile(promptPath)\n   394→\trequire.NoError(t, err)\n   395→\n   396→\t// Should contain the actual prompt content, not the commentary\n   397→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   398→\tassert.Contains(t, string(content), \"Always validate inputs\")\n   399→\tassert.NotContains(t, string(content), \"Here is the updated prompt\")\n   400→\tassert.NotContains(t, string(content), \"I added the validation rule\")\n   401→\tassert.NotContains(t, string(content), \"```\")\n   402→}\n   403→\n   404→func TestCuratorRejectsConversationalMetaText(t *testing.T) {\n   405→\tdir := t.TempDir()\n   406→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"fix.md\")\n   407→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   408→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   409→\toriginal := \"# Fix Prompt\\n\\nFix bugs carefully.\\n\"\n   410→\tos.WriteFile(promptPath, []byte(original), 0644)\n   411→\n   412→\t// LLM returns conversational meta-text\n   413→\tllm := &fakeLLM{response: \"I need write permission to update the file. Could you grant access to .cloche/prompts/fix.md?\"}\n   414→\taudit := &AuditLogger{ProjectDir: dir}\n   415→\tc := &Curator{LLM: llm, Audit: audit}\n   416→\tlesson := &Lesson{\n   417→\t\tTarget:          \".cloche/prompts/fix.md\",\n   418→\t\tInsight:         \"Missing error context\",\n   419→\t\tSuggestedAction: \"Wrap errors with context\",\n   420→\t}\n   421→\n   422→\t_, err := c.Apply(context.Background(), dir, lesson)\n   423→\trequire.NoError(t, err)\n   424→\n   425→\tcontent, err := os.ReadFile(promptPath)\n   426→\trequire.NoError(t, err)\n   427→\t// Must NOT contain the conversational text\n   428→\tassert.NotContains(t, string(content), \"I need write permission\")\n   429→\tassert.NotContains(t, string(content), \"Could you grant access\")\n   430→\t// Should contain the original content and the lesson appended directly\n   431→\tassert.Contains(t, string(content), \"# Fix Prompt\")\n   432→\tassert.Contains(t, string(content), \"Missing error context\")\n   433→}\n   434→\n   435→func TestCuratorRejectsUnfencedConversationalPrefix(t *testing.T) {\n   436→\tdir := t.TempDir()\n   437→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   438→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   439→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   440→\toriginal := \"# Implementation Prompt\\n\\nWrite good code.\\n\"\n   441→\tos.WriteFile(promptPath, []byte(original), 0644)\n   442→\n   443→\t// LLM returns \"Here is the updated prompt:\" with NO code fences\n   444→\tllm := &fakeLLM{response: \"Here is the updated prompt:\\n\\n# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Validate inputs\\n\"}\n   445→\taudit := &AuditLogger{ProjectDir: dir}\n   446→\tc := &Curator{LLM: llm, Audit: audit}\n   447→\tlesson := &Lesson{\n   448→\t\tTarget:          \".cloche/prompts/implement.md\",\n   449→\t\tInsight:         \"Missing validation\",\n   450→\t\tSuggestedAction: \"Add input validation\",\n   451→\t}\n   452→\n   453→\t_, err := c.Apply(context.Background(), dir, lesson)\n   454→\trequire.NoError(t, err)\n   455→\n   456→\tcontent, err := os.ReadFile(promptPath)\n   457→\trequire.NoError(t, err)\n   458→\t// The conversational prefix must not appear\n   459→\tassert.NotContains(t, string(content), \"Here is the updated prompt\")\n   460→\t// Original content preserved, lesson appended via fallback\n   461→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   462→\tassert.Contains(t, string(content), \"Missing validation\")\n   463→}\n   464→\n   465→func TestCuratorAcceptsValidPromptWithoutFences(t *testing.T) {\n   466→\tdir := t.TempDir()\n   467→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   468→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   469→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   470→\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   471→\n   472→\t// LLM returns valid prompt content without code fences\n   473→\tvalidResponse := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always validate inputs\\n\"\n   474→\tllm := &fakeLLM{response: validResponse}\n   475→\taudit := &AuditLogger{ProjectDir: dir}\n   476→\tc := &Curator{LLM: llm, Audit: audit}\n   477→\tlesson := &Lesson{\n   478→\t\tTarget:          \".cloche/prompts/implement.md\",\n   479→\t\tInsight:         \"Missing validation\",\n   480→\t\tSuggestedAction: \"Add validation rule\",\n   481→\t}\n   482→\n   483→\t_, err := c.Apply(context.Background(), dir, lesson)\n   484→\trequire.NoError(t, err)\n   485→\n   486→\tcontent, err := os.ReadFile(promptPath)\n   487→\trequire.NoError(t, err)\n   488→\t// Should write the LLM response (after stripCodeFences trimming) since it's valid prompt content\n   489→\tassert.Contains(t, string(content), \"Always validate inputs\")\n   490→\tassert.Contains(t, string(content), \"# Implementation Prompt\")\n   491→\tassert.NotContains(t, string(content), \"Missing validation\")\n   492→}\n   493→\n   494→func TestIsConversationalResponse(t *testing.T) {\n   495→\ttests := []struct {\n   496→\t\tname     string\n   497→\t\tinput    string\n   498→\t\texpected bool\n   499→\t}{\n   500→\t\t{\"permission request\", \"I need write permission to update the file\", true},\n   501→\t\t{\"grant request\", \"Could you grant access to the file?\", true},\n   502→\t\t{\"blocked message\", \"Permission blocked by sandbox\", true},\n   503→\t\t{\"here is updated\", \"Here is the updated prompt:\\n\\n# Prompt\", true},\n   504→\t\t{\"heres updated\", \"Here's the updated prompt:\\n\\n# Prompt\", true},\n   505→\t\t{\"ive updated\", \"I've updated the prompt with the new rule\", true},\n   506→\t\t{\"let me\", \"Let me update the file for you\", true},\n   507→\t\t{\"valid markdown heading\", \"# Prompt\\n\\nDo good work.\", false},\n   508→\t\t{\"valid bullet list\", \"- Rule one\\n- Rule two\", false},\n   509→\t\t{\"empty string\", \"\", true},\n   510→\t\t{\"valid content no heading\", \"Write good code and test everything.\", false},\n   511→\t}\n   512→\n   513→\tfor _, tt := range tests {\n   514→\t\tt.Run(tt.name, func(t *testing.T) {\n   515→\t\t\tassert.Equal(t, tt.expected, isConversationalResponse(tt.input))\n   516→\t\t})\n   517→\t}\n   518→}\n   519→\n   520→func TestAppendLessonDirectly(t *testing.T) {\n   521→\tt.Run(\"creates learned rules section\", func(t *testing.T) {\n   522→\t\tresult := appendLessonDirectly(\"# Prompt\\n\\nDo good work.\\n\", &Lesson{\n   523→\t\t\tInsight:         \"Missing validation\",\n   524→\t\t\tSuggestedAction: \"Add validation\",\n   525→\t\t})\n   526→\t\tassert.Contains(t, result, \"## Learned Rules\")\n   527→\t\tassert.Contains(t, result, \"Missing validation: Add validation\")\n   528→\t})\n   529→\n   530→\tt.Run(\"appends to existing learned rules\", func(t *testing.T) {\n   531→\t\texisting := \"# Prompt\\n\\n## Learned Rules\\n\\n- Existing rule\\n\"\n   532→\t\tresult := appendLessonDirectly(existing, &Lesson{\n   533→\t\t\tInsight:         \"New insight\",\n   534→\t\t\tSuggestedAction: \"New action\",\n   535→\t\t})\n   536→\t\tassert.Contains(t, result, \"- Existing rule\")\n   537→\t\tassert.Contains(t, result, \"- New insight: New action\")\n   538→\t\t// Should not create a duplicate section\n   539→\t\tassert.Equal(t, 1, strings.Count(result, \"## Learned Rules\"))\n   540→\t})\n   541→}\n   542→\n   543→// --- Script Generator tests ---\n   544→\n   545→func TestScriptGeneratorCreatesScript(t *testing.T) {\n   546→\tdir := t.TempDir()\n   547→\n   548→\tllm := &fakeLLM{response: `{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`}\n   549→\tg := &ScriptGenerator{LLM: llm}\n   550→\n   551→\tlesson := &Lesson{\n   552→\t\tID:              \"lesson-001\",\n   553→\t\tCategory:        \"new_step\",\n   554→\t\tStepType:        \"script\",\n   555→\t\tInsight:         \"No security scanning\",\n   556→\t\tSuggestedAction: \"Add gosec security scan\",\n   557→\t}\n   558→\n   559→\tresult, err := g.Generate(context.Background(), dir, lesson)\n   560→\trequire.NoError(t, err)\n   561→\tassert.Equal(t, \"scripts/security-scan.sh\", result.Path)\n   562→\n   563→\tcontent, err := os.ReadFile(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n   564→\trequire.NoError(t, err)\n   565→\tassert.Contains(t, string(content), \"gosec\")\n   566→\n   567→\tinfo, err := os.Stat(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n   568→\trequire.NoError(t, err)\n   569→\tassert.Zero(t, info.Mode()&0111) // non-executable; workflow engine handles execution\n   570→}\n   571→\n   572→// --- LLM Client tests ---\n   573→\n   574→func TestCommandLLMClientPrintMode(t *testing.T) {\n   575→\t// Use a shell script that dumps its args and stdin so we can verify\n   576→\t// that the client passes the right flags and prompt separation.\n   577→\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   578→\tos.WriteFile(script, []byte(`#!/bin/sh\n   579→echo \"ARGS:$*\"\n   580→echo \"STDIN:$(cat)\"\n   581→`), 0755)\n   582→\n   583→\tc := &CommandLLMClient{Command: script, Args: []string{}}\n   584→\tresult, err := c.Complete(context.Background(), \"You are a helpful assistant.\", \"Summarize this text\")\n   585→\trequire.NoError(t, err)\n   586→\n   587→\t// Should include -p flag for print/non-interactive mode\n   588→\tassert.Contains(t, result, \"-p\")\n   589→\n   590→\t// Should pass system prompt via --system-prompt flag\n   591→\tassert.Contains(t, result, \"--system-prompt\")\n   592→\tassert.Contains(t, result, \"You are a helpful assistant.\")\n   593→\n   594→\t// Should pass --output-format text\n   595→\tassert.Contains(t, result, \"--output-format text\")\n   596→\n   597→\t// Stdin should contain only the user prompt, not the system prompt\n   598→\tassert.Contains(t, result, \"STDIN:Summarize this text\")\n   599→\tassert.NotContains(t, result, \"STDIN:You are a helpful assistant\")\n   600→}\n   601→\n   602→func TestCommandLLMClientEmptySystemPrompt(t *testing.T) {\n   603→\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   604→\tos.WriteFile(script, []byte(`#!/bin/sh\n   605→echo \"ARGS:$*\"\n   606→echo \"STDIN:$(cat)\"\n   607→`), 0755)\n   608→\n   609→\tc := &CommandLLMClient{Command: script, Args: []string{}}\n   610→\tresult, err := c.Complete(context.Background(), \"\", \"just user prompt\")\n   611→\trequire.NoError(t, err)\n   612→\n   613→\t// Should NOT include --system-prompt when system prompt is empty\n   614→\tassert.NotContains(t, result, \"--system-prompt\")\n   615→\t// Should still have -p and --output-format\n   616→\tassert.Contains(t, result, \"-p\")\n   617→\tassert.Contains(t, result, \"--output-format text\")\n   618→\tassert.Contains(t, result, \"STDIN:just user prompt\")\n   619→}\n   620→\n   621→func TestCommandLLMClientExtraArgs(t *testing.T) {\n   622→\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   623→\tos.WriteFile(script, []byte(`#!/bin/sh\n   624→echo \"ARGS:$*\"\n   625→echo \"STDIN:$(cat)\"\n   626→`), 0755)\n   627→\n   628→\tc := &CommandLLMClient{Command: script, Args: []string{\"--model\", \"sonnet\"}}\n   629→\tresult, err := c.Complete(context.Background(), \"sys\", \"usr\")\n   630→\trequire.NoError(t, err)\n   631→\n   632→\t// Extra args should appear before the appended flags\n   633→\tassert.Contains(t, result, \"--model sonnet\")\n   634→\tassert.Contains(t, result, \"-p\")\n   635→}\n   636→\n   637→func TestCommandLLMClientDoesNotMutateArgs(t *testing.T) {\n   638→\tscript := filepath.Join(t.TempDir(), \"fake-claude.sh\")\n   639→\tos.WriteFile(script, []byte(\"#!/bin/sh\\ncat\\n\"), 0755)\n   640→\n   641→\toriginal := []string{\"--verbose\"}\n   642→\tc := &CommandLLMClient{Command: script, Args: original}\n   643→\t_, err := c.Complete(context.Background(), \"sys\", \"usr\")\n   644→\trequire.NoError(t, err)\n   645→\n   646→\t// The original Args slice should not be modified between calls.\n   647→\tassert.Equal(t, []string{\"--verbose\"}, original)\n   648→}\n   649→\n   650→// --- Orchestrator tests ---\n   651→\n   652→// scriptedLLM returns responses in order.\n   653→type scriptedLLM struct {\n   654→\tresponses []string\n   655→\tidx       int\n   656→}\n   657→\n   658→func (s *scriptedLLM) Complete(ctx context.Context, system, user string) (string, error) {\n   659→\tresp := s.responses[s.idx]\n   660→\ts.idx++\n   661→\treturn resp, nil\n   662→}\n   663→\n   664→func TestOrchestratorEndToEnd(t *testing.T) {\n   665→\tdir := t.TempDir()\n   666→\n   667→\t// Set up project structure\n   668→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   669→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   670→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   671→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n   672→\t\t[]byte(\"Write good code.\\n\"), 0644)\n   673→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   674→\t\t[]byte(`workflow \"develop\" {\n   675→  step implement {\n   676→    prompt = file(\".cloche/prompts/implement.md\")\n   677→    results = [success, fail]\n   678→  }\n   679→  step test {\n   680→    run = \"make test\"\n   681→    results = [success, fail]\n   682→  }\n   683→  implement:success -> test\n   684→  test:success -> done\n   685→  test:fail -> abort\n   686→}`), 0644)\n   687→\n   688→\t// Fake LLM that returns appropriate responses per stage\n   689→\tllm := &scriptedLLM{\n   690→\t\tresponses: []string{\n   691→\t\t\t// Classifier\n   692→\t\t\t`{\"classification\": \"bug\"}`,\n   693→\t\t\t// Reflector\n   694→\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n   695→\t\t\t// Curator\n   696→\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n   697→\t\t},\n   698→\t}\n   699→\n   700→\torch := NewOrchestrator(OrchestratorConfig{\n   701→\t\tProjectDir:    dir,\n   702→\t\tWorkflowName:  \"develop\",\n   703→\t\tLLM:           llm,\n   704→\t\tMinConfidence: \"medium\",\n   705→\t})\n   706→\n   707→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   708→\trequire.NoError(t, err)\n   709→\tassert.Equal(t, \"bug\", result.Classification)\n   710→\trequire.Len(t, result.Changes, 1)\n   711→\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n   712→\n   713→\t// Verify prompt was actually updated\n   714→\tcontent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n   715→\tassert.Contains(t, string(content), \"sanitize user inputs\")\n   716→\n   717→\t// Verify audit log was written\n   718→\tlogContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n   719→\tassert.Contains(t, string(logContent), \"prompt_update\")\n   720→\tassert.Contains(t, string(logContent), \"XSS pattern\")\n   721→\n   722→\t// Verify knowledge base was updated (JSONL format)\n   723→\tkbContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.jsonl\"))\n   724→\tassert.Contains(t, string(kbContent), \"L001\")\n   725→}\n   726→\n   727→func TestOrchestratorNewStepWiredIntoGraph(t *testing.T) {\n   728→\tdir := t.TempDir()\n   729→\n   730→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   731→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   732→\t// Knowledge base uses JSONL format (created automatically by UpdateKnowledge)\n   733→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   734→\t\t[]byte(`workflow \"develop\" {\n   735→  step implement {\n   736→    prompt = file(\".cloche/prompts/implement.md\")\n   737→    results = [success, fail]\n   738→  }\n   739→  step test {\n   740→    run = \"make test\"\n   741→    results = [success, fail]\n   742→  }\n   743→  implement:success -> test\n   744→  implement:fail -> abort\n   745→  test:success -> done\n   746→  test:fail -> abort\n   747→}`), 0644)\n   748→\n   749→\tllm := &scriptedLLM{\n   750→\t\tresponses: []string{\n   751→\t\t\t// Classifier\n   752→\t\t\t`{\"classification\": \"enhancement\"}`,\n   753→\t\t\t// Reflector\n   754→\t\t\t`{\"lessons\": [{\"id\": \"L002\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"No security scanning\", \"suggested_action\": \"Add gosec scan\", \"evidence\": [\"run-2\"], \"confidence\": \"high\"}]}`,\n   755→\t\t\t// ScriptGenerator\n   756→\t\t\t`{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`,\n   757→\t\t},\n   758→\t}\n   759→\n   760→\torch := NewOrchestrator(OrchestratorConfig{\n   761→\t\tProjectDir:    dir,\n   762→\t\tWorkflowName:  \"develop\",\n   763→\t\tLLM:           llm,\n   764→\t\tMinConfidence: \"medium\",\n   765→\t})\n   766→\n   767→\tresult, err := orch.Run(context.Background(), \"run-2\", nil, nil)\n   768→\trequire.NoError(t, err)\n   769→\trequire.Len(t, result.Changes, 2) // add_script + add_step\n   770→\tassert.Equal(t, \"add_script\", result.Changes[0].Type)\n   771→\tassert.Equal(t, \"add_step\", result.Changes[1].Type)\n   772→\n   773→\t// Read the updated workflow and verify the new step is reachable\n   774→\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   775→\trequire.NoError(t, err)\n   776→\n   777→\twfStr := string(wfContent)\n   778→\t// The new step should be wired into the graph\n   779→\tassert.Contains(t, wfStr, \"step security-scan\")\n   780→\t// An existing step should wire to the new step (rewired from -> done)\n   781→\tassert.Contains(t, wfStr, \"test:success -> security-scan\")\n   782→\t// The new step should wire its results to terminals\n   783→\tassert.Contains(t, wfStr, \"security-scan:success -> done\")\n   784→\tassert.Contains(t, wfStr, \"security-scan:fail -> abort\")\n   785→\n   786→\t// Verify the workflow parses and validates\n   787→\twf, err := dsl.Parse(wfStr)\n   788→\trequire.NoError(t, err)\n   789→\trequire.NoError(t, wf.Validate())\n   790→}\n   791→\n   792→func TestHandleNewStepSkipsDuplicate(t *testing.T) {\n   793→\tdir := t.TempDir()\n   794→\n   795→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   796→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   797→\n   798→\t// Workflow already contains a step named \"security-scan\"\n   799→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   800→\t\t[]byte(`workflow \"develop\" {\n   801→  step implement {\n   802→    prompt = file(\".cloche/prompts/implement.md\")\n   803→    results = [success, fail]\n   804→  }\n   805→  step security-scan {\n   806→    run = \"scripts/security-scan.sh\"\n   807→    results = [success, fail]\n   808→  }\n   809→  implement:success -> security-scan\n   810→  implement:fail -> abort\n   811→  security-scan:success -> done\n   812→  security-scan:fail -> abort\n   813→}`), 0644)\n   814→\n   815→\tllm := &scriptedLLM{\n   816→\t\tresponses: []string{\n   817→\t\t\t// Classifier\n   818→\t\t\t`{\"classification\": \"enhancement\"}`,\n   819→\t\t\t// Reflector — lesson wants to add \"security-scan\" again\n   820→\t\t\t`{\"lessons\": [{\"id\": \"L003\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add security scanning\", \"suggested_action\": \"Add gosec scan\", \"evidence\": [\"run-3\"], \"confidence\": \"high\"}]}`,\n   821→\t\t\t// ScriptGenerator\n   822→\t\t\t`{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`,\n   823→\t\t},\n   824→\t}\n   825→\n   826→\torch := NewOrchestrator(OrchestratorConfig{\n   827→\t\tProjectDir:    dir,\n   828→\t\tWorkflowName:  \"develop\",\n   829→\t\tLLM:           llm,\n   830→\t\tMinConfidence: \"medium\",\n   831→\t})\n   832→\n   833→\tresult, err := orch.Run(context.Background(), \"run-3\", nil, nil)\n   834→\trequire.NoError(t, err)\n   835→\n   836→\t// Should have add_script change but NOT add_step (skipped as duplicate)\n   837→\tstepChanges := 0\n   838→\tfor _, c := range result.Changes {\n   839→\t\tif c.Type == \"add_step\" {\n   840→\t\t\tstepChanges++\n   841→\t\t}\n   842→\t}\n   843→\tassert.Equal(t, 0, stepChanges, \"should not add a duplicate step\")\n   844→\n   845→\t// Workflow should be unchanged — still valid, no duplicates\n   846→\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   847→\trequire.NoError(t, err)\n   848→\twf, err := dsl.Parse(string(wfContent))\n   849→\trequire.NoError(t, err)\n   850→\trequire.NoError(t, wf.Validate())\n   851→\tassert.Equal(t, 2, len(wf.Steps), \"should still have exactly 2 steps\")\n   852→}\n   853→\n   854→func TestHandleNewStepNoDoneEdge(t *testing.T) {\n   855→\tdir := t.TempDir()\n   856→\n   857→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   858→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   859→\n   860→\t// Workflow has no -> done edges (all go to abort)\n   861→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   862→\t\t[]byte(`workflow \"develop\" {\n   863→  step implement {\n   864→    prompt = file(\".cloche/prompts/implement.md\")\n   865→    results = [success, fail]\n   866→  }\n   867→  implement:success -> done\n   868→  implement:fail -> abort\n   869→}`), 0644)\n   870→\n   871→\tllm := &scriptedLLM{\n   872→\t\tresponses: []string{\n   873→\t\t\t`{\"classification\": \"enhancement\"}`,\n   874→\t\t\t`{\"lessons\": [{\"id\": \"L004\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add linting\", \"suggested_action\": \"Add lint step\", \"evidence\": [\"run-4\"], \"confidence\": \"high\"}]}`,\n   875→\t\t\t`{\"path\": \"scripts/lint.sh\", \"content\": \"#!/bin/bash\\ngolangci-lint run\"}`,\n   876→\t\t},\n   877→\t}\n   878→\n   879→\torch := NewOrchestrator(OrchestratorConfig{\n   880→\t\tProjectDir:    dir,\n   881→\t\tWorkflowName:  \"develop\",\n   882→\t\tLLM:           llm,\n   883→\t\tMinConfidence: \"medium\",\n   884→\t})\n   885→\n   886→\tresult, err := orch.Run(context.Background(), \"run-4\", nil, nil)\n   887→\trequire.NoError(t, err)\n   888→\n   889→\t// The new step should be added and the resulting workflow must validate\n   890→\twfContent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"))\n   891→\trequire.NoError(t, err)\n   892→\twf, err := dsl.Parse(string(wfContent))\n   893→\trequire.NoError(t, err)\n   894→\trequire.NoError(t, wf.Validate(), \"resulting workflow should have no orphaned steps\")\n   895→\n   896→\t// The new step should be reachable\n   897→\t_, hasStep := wf.Steps[\"lint\"]\n   898→\tassert.True(t, hasStep, \"lint step should exist\")\n   899→\n   900→\t// Verify add_step change was recorded\n   901→\thasAddStep := false\n   902→\tfor _, c := range result.Changes {\n   903→\t\tif c.Type == \"add_step\" {\n   904→\t\t\thasAddStep = true\n   905→\t\t}\n   906→\t}\n   907→\tassert.True(t, hasAddStep, \"should have recorded add_step change\")\n   908→}\n   909→\n   910→func TestHandleNewStepValidatesResultingWorkflow(t *testing.T) {\n   911→\tdir := t.TempDir()\n   912→\n   913→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   914→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   915→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   916→\t\t[]byte(`workflow \"develop\" {\n   917→  step implement {\n   918→    prompt = file(\".cloche/prompts/implement.md\")\n   919→    results = [success, fail]\n   920→  }\n   921→  step test {\n   922→    run = \"make test\"\n   923→    results = [success, fail]\n   924→  }\n   925→  implement:success -> test\n   926→  implement:fail -> abort\n   927→  test:success -> done\n   928→  test:fail -> abort\n   929→}`), 0644)\n   930→\n   931→\tllm := &scriptedLLM{\n   932→\t\tresponses: []string{\n   933→\t\t\t`{\"classification\": \"enhancement\"}`,\n   934→\t\t\t`{\"lessons\": [{\"id\": \"L005\", \"category\": \"new_step\", \"step_type\": \"script\", \"insight\": \"Add formatting check\", \"suggested_action\": \"Add gofmt check\", \"evidence\": [\"run-5\"], \"confidence\": \"high\"}]}`,\n   935→\t\t\t`{\"path\": \"scripts/format-check.sh\", \"content\": \"#!/bin/bash\\ngofmt -l .\"}`,\n   936→\t\t},\n   937→\t}\n   938→\n   939→\torch := NewOrchestrator(OrchestratorConfig