{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017zk1rEm3sDNCdn6in6B7TF","type":"tool_result","content":"     1→package config\n     2→\n     3→import (\n     4→\t\"os\"\n     5→\t\"path/filepath\"\n     6→\n     7→\t\"github.com/BurntSushi/toml\"\n     8→)\n     9→\n    10→type DaemonConfig struct {\n    11→\tListen     string `toml:\"listen\"`\n    12→\tHTTP       string `toml:\"http\"`\n    13→\tImage      string `toml:\"image\"`\n    14→\tDB         string `toml:\"db\"`\n    15→\tRuntime    string `toml:\"runtime\"`\n    16→\tAgentPath  string `toml:\"agent_path\"`\n    17→\tLLMCommand string `toml:\"llm_command\"`\n    18→}\n    19→\n    20→type EvolutionConfig struct {\n    21→\tEnabled          bool   `toml:\"enabled\"`\n    22→\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n    23→\tMinConfidence    string `toml:\"min_confidence\"`\n    24→\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n    25→}\n    26→\n    27→type OrchestrationConfig struct {\n    28→\tConcurrency            int     `toml:\"concurrency\"`\n    29→\tStaggerSeconds         float64 `toml:\"stagger_seconds\"`\n    30→\tListTasksCommand       string  `toml:\"list_tasks_command\"`       // shell command to list open tasks (JSON array output)\n    31→\tDedupSeconds           float64 `toml:\"dedup_seconds\"`            // dedup window for task assignment (default: 300)\n    32→\tStopOnError            bool    `toml:\"stop_on_error\"`            // halt orchestration loop on unrecovered error\n    33→\tMaxConsecutiveFailures int     `toml:\"max_consecutive_failures\"` // halt loop after N consecutive failures (default: 3, must be > 0)\n    34→}\n    35→\n    36→type Config struct {\n    37→\tActive        bool                `toml:\"active\"`\n    38→\tDaemon        DaemonConfig        `toml:\"daemon\"`\n    39→\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n    40→\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n    41→}\n    42→\n    43→func defaults() Config {\n    44→\treturn Config{\n    45→\t\tEvolution: EvolutionConfig{\n    46→\t\t\tEnabled:          true,\n    47→\t\t\tDebounceSeconds:  30,\n    48→\t\t\tMinConfidence:    \"medium\",\n    49→\t\t\tMaxPromptBullets: 50,\n    50→\t\t},\n    51→\t\tOrchestration: OrchestrationConfig{\n    52→\t\t\tConcurrency:            1,\n    53→\t\t\tStaggerSeconds:         1.0,\n    54→\t\t\tMaxConsecutiveFailures: 3,\n    55→\t\t},\n    56→\t}\n    57→}\n    58→\n    59→// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    60→func Load(projectDir string) (*Config, error) {\n    61→\tcfg := defaults()\n    62→\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    63→\n    64→\tdata, err := os.ReadFile(path)\n    65→\tif os.IsNotExist(err) {\n    66→\t\treturn &cfg, nil\n    67→\t}\n    68→\tif err != nil {\n    69→\t\treturn nil, err\n    70→\t}\n    71→\n    72→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    73→\t\treturn nil, err\n    74→\t}\n    75→\treturn &cfg, nil\n    76→}\n    77→\n    78→// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n    79→// Returns defaults if the file does not exist.\n    80→func LoadGlobal() (*Config, error) {\n    81→\tcfg := defaults()\n    82→\n    83→\thome, err := os.UserHomeDir()\n    84→\tif err != nil {\n    85→\t\treturn &cfg, nil\n    86→\t}\n    87→\n    88→\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n    89→\tdata, err := os.ReadFile(path)\n    90→\tif os.IsNotExist(err) {\n    91→\t\treturn &cfg, nil\n    92→\t}\n    93→\tif err != nil {\n    94→\t\treturn nil, err\n    95→\t}\n    96→\n    97→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    98→\t\treturn nil, err\n    99→\t}\n   100→\treturn &cfg, nil\n   101→}\n   102→\n   103→// StateDir returns the path to ~/.config/cloche/ and ensures it exists.\n   104→// Falls back to a temp directory if the home directory cannot be determined.\n   105→func StateDir() string {\n   106→\thome, err := os.UserHomeDir()\n   107→\tif err != nil {\n   108→\t\treturn filepath.Join(os.TempDir(), \"cloche\")\n   109→\t}\n   110→\treturn filepath.Join(home, \".config\", \"cloche\")\n   111→}\n   112→\n   113→// EnsureStateDir creates the state directory if it doesn't exist.\n   114→func EnsureStateDir() (string, error) {\n   115→\tdir := StateDir()\n   116→\tif err := os.MkdirAll(dir, 0755); err != nil {\n   117→\t\treturn \"\", err\n   118→\t}\n   119→\treturn dir, nil\n   120→}\n   121→\n   122→// DefaultDBPath returns the default database path: ~/.config/cloche/cloche.db\n   123→func DefaultDBPath() string {\n   124→\treturn filepath.Join(StateDir(), \"cloche.db\")\n   125→}\n   126→\n   127→// DefaultSocketAddr returns the default Unix socket address: unix://~/.config/cloche/cloche.sock\n   128→func DefaultSocketAddr() string {\n   129→\treturn \"unix://\" + filepath.Join(StateDir(), \"cloche.sock\")\n   130→}\n   131→\n   132→// LoadGlobalFrom reads the global config from a specific path.\n   133→// Useful for testing.\n   134→func LoadGlobalFrom(path string) (*Config, error) {\n   135→\tcfg := defaults()\n   136→\n   137→\tdata, err := os.ReadFile(path)\n   138→\tif os.IsNotExist(err) {\n   139→\t\treturn &cfg, nil\n   140→\t}\n   141→\tif err != nil {\n   142→\t\treturn nil, err\n   143→\t}\n   144→\n   145→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   146→\t\treturn nil, err\n   147→\t}\n   148→\treturn &cfg, nil\n   149→}\n   150→"}]},"parent_tool_use_id":"toolu_01CHsGfHFbwJREmYZ4LmDQS2","session_id":"20d5adfa-ca6e-4c90-b84e-e05e5aa65257","uuid":"ed407180-e3c3-4d6d-a23c-6a8533e17dd9","timestamp":"2026-03-17T14:07:53.657Z"}
