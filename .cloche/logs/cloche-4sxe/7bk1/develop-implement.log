1\", Content: \"candidate content\"}\n\tassignment, err := pop.ApplyCandidate(candidate, \".cloche/prompts/implement.md\", \"run-456\")\n\trequire.NoError(t, err)\n\n\t// Restore\n\trequire.NoError(t, pop.RestoreSnapshot(assignment))\n\n\tcontent, err := os.ReadFile(filepath.Join(promptDir, \"implement.md\"))\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"original\", string(content))\n}\n\nfunc TestPopulationScoreAndPromote(t *testing.T) {\n\tdir := t.TempDir()\n\n\tpromptDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\trequire.NoError(t, os.MkdirAll(promptDir, 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(promptDir, \"implement.md\"), []byte(\"base prompt\"), 0644))\n\n\tpop := NewPopulation(PopulationConfig{\n\t\tEnabled:            true,\n\t\tSize:               5,\n\t\tPromotionThreshold: 0.8,\n\t}, dir, \"develop\")\n\n\t// Save a candidate with high fitness (1 run succeeded already → fitness 1.0)\n\tcandidates := []Candidate{\n\t\t{ID: \"c1\", Content: \"great prompt\", Fitness: 1.0, Runs: 1, Generation: 1},\n\t}\n\trequire.NoError(t, pop.SaveCandidates(candidates))\n\n\t// Record assignment\n\tpop.RecordAssignment(\"run-789\", &Assignment{\n\t\tRunID:       \"run-789\",\n\t\tCandidateID: \"c1\",\n\t\tPromptPath:  \".cloche/prompts/implement.md\",\n\t})\n\n\t// Score with success → should promote (fitness stays 1.0, runs becomes 2)\n\tcandidate, promoted, err := pop.ScoreAndPromote(\"run-789\", true)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, candidate)\n\tassert.True(t, promoted)\n\tassert.Equal(t, 1.0, candidate.Fitness)\n\tassert.Equal(t, 2, candidate.Runs)\n\tassert.True(t, candidate.Promoted)\n\n\t// Verify promoted content was written to prompt path\n\tcontent, err := os.ReadFile(filepath.Join(promptDir, \"implement.md\"))\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"great prompt\", string(content))\n}\n\nfunc TestPopulationScoreNoPromotion(t *testing.T) {\n\tdir := t.TempDir()\n\n\tpop := NewPopulation(PopulationConfig{\n\t\tEnabled:            true,\n\t\tSize:               5,\n\t\tPromotionThreshold: 0.8,\n\t}, dir, \"develop\")\n\n\tcandidates := []Candidate{\n\t\t{ID: \"c1\", Content: \"mediocre prompt\", Fitness: 0.0, Runs: 0, Generation: 1},\n\t}\n\trequire.NoError(t, pop.SaveCandidates(candidates))\n\n\tpop.RecordAssignment(\"run-100\", &Assignment{\n\t\tRunID:       \"run-100\",\n\t\tCandidateID: \"c1\",\n\t\tPromptPath:  \".cloche/prompts/implement.md\",\n\t})\n\n\t// Score with failure\n\tcandidate, promoted, err := pop.ScoreAndPromote(\"run-100\", false)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, candidate)\n\tassert.False(t, promoted)\n\tassert.Equal(t, 0.0, candidate.Fitness)\n\tassert.Equal(t, 1, candidate.Runs)\n}\n\nfunc TestPopulationScoreNoAssignment(t *testing.T) {\n\tdir := t.TempDir()\n\n\tpop := NewPopulation(PopulationConfig{Enabled: true, Size: 5}, dir, \"develop\")\n\n\t// No assignment recorded → no-op\n\tcandidate, promoted, err := pop.ScoreAndPromote(\"run-999\", true)\n\trequire.NoError(t, err)\n\tassert.Nil(t, candidate)\n\tassert.False(t, promoted)\n}\n\nfunc TestFirstPromptPath(t *testing.T) {\n\tdir := t.TempDir()\n\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"), []byte(`workflow \"develop\" {\n  step impl {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success]\n  }\n  impl:success -> done\n}`), 0644))\n\n\tpath := FirstPromptPath(dir, \"develop\")\n\tassert.Equal(t, \".cloche/prompts/implement.md\", path)\n}\n\nfunc TestFirstPromptPathNoWorkflow(t *testing.T) {\n\tdir := t.TempDir()\n\tpath := FirstPromptPath(dir, \"develop\")\n\tassert.Equal(t, \"\", path)\n}\n\n// TestPopulationEndToEnd exercises the full pre-run selection → run → post-run scoring cycle.\nfunc TestPopulationEndToEnd(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Set up project structure with workflow and prompt\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755))\n\toriginalPrompt := \"You are a coding assistant. Implement the feature.\"\n\trequire.NoError(t, os.WriteFile(\n\t\tfilepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(originalPrompt), 0644,\n\t))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"), []byte(`workflow \"develop\" {\n  step impl {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  impl:success -> done\n  impl:fail -> abort\n}`), 0644))\n\n\t// Create population with 3 candidates\n\tpop := NewPopulation(PopulationConfig{\n\t\tEnabled:            true,\n\t\tSize:               5,\n\t\tPromotionThreshold: 0.8,\n\t}, dir, \"develop\")\n\n\tcandidates := []Candidate{\n\t\t{ID: \"alpha\", Content: \"Alpha prompt: focus on tests first\", Fitness: 0.0, Runs: 0, Generation: 1, CreatedAt: \"2026-03-17T00:00:00Z\"},\n\t\t{ID: \"beta\", Content: \"Beta prompt: focus on design first\", Fitness: 0.0, Runs: 0, Generation: 1, CreatedAt: \"2026-03-17T00:00:00Z\"},\n\t\t{ID: \"gamma\", Content: \"Gamma prompt: focus on simplicity\", Fitness: 0.0, Runs: 0, Generation: 1, CreatedAt: \"2026-03-17T00:00:00Z\"},\n\t}\n\trequire.NoError(t, pop.SaveCandidates(candidates))\n\n\t// === Simulate 4 runs ===\n\n\tpromptPath := FirstPromptPath(dir, \"develop\")\n\trequire.Equal(t, \".cloche/prompts/implement.md\", promptPath)\n\n\ttype runResult struct {\n\t\trunID     string\n\t\tsucceeded bool\n\t}\n\n\truns := []runResult{\n\t\t{\"run-001\", true},  // first run succeeds\n\t\t{\"run-002\", true},  // second run succeeds\n\t\t{\"run-003\", false}, // third run fails\n\t\t{\"run-004\", true},  // fourth run succeeds\n\t}\n\n\tfor _, rr := range runs {\n\t\t// Pre-run: select and apply candidate\n\t\tcandidate, err := pop.SelectCandidate()\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, candidate, \"expected a candidate for run %s\", rr.runID)\n\n\t\tassignment, err := pop.ApplyCandidate(candidate, promptPath, rr.runID)\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, assignment)\n\n\t\t// Verify prompt was overwritten with candidate content\n\t\tcontent, err := os.ReadFile(filepath.Join(dir, promptPath))\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, candidate.Content, string(content))\n\n\t\t// Post-run: score and check promotion\n\t\tscored, promoted, err := pop.ScoreAndPromote(rr.runID, rr.succeeded)\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, scored)\n\t\tassert.Equal(t, candidate.ID, scored.ID)\n\n\t\t// Restore original prompt if not promoted\n\t\tif !promoted {\n\t\t\trequire.NoError(t, pop.RestoreSnapshot(assignment))\n\t\t\trestored, _ := os.ReadFile(filepath.Join(dir, promptPath))\n\t\t\tassert.Equal(t, originalPrompt, string(restored))\n\t\t}\n\t}\n\n\t// Verify final state: all candidates should have been tested\n\tfinalCandidates, err := pop.LoadCandidates()\n\trequire.NoError(t, err)\n\n\ttotalRuns := 0\n\tfor _, c := range finalCandidates {\n\t\ttotalRuns += c.Runs\n\t\t// Fitness should be between 0 and 1\n\t\tassert.GreaterOrEqual(t, c.Fitness, 0.0)\n\t\tassert.LessOrEqual(t, c.Fitness, 1.0)\n\t}\n\tassert.Equal(t, 4, totalRuns, \"all 4 runs should have been scored\")\n}\n","structuredPatch":[],"originalFile":null}}
