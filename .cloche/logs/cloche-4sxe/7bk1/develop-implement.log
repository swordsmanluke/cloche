tent, string(content))\n\n\t\t// Post-run: score and check promotion\n\t\tscored, promoted, err := pop.ScoreAndPromote(rr.runID, rr.succeeded)\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, scored)\n\t\tassert.Equal(t, candidate.ID, scored.ID)\n\n\t\tif promoted {\n\t\t\t// Promotion writes candidate content to the prompt; this becomes the new baseline\n\t\t\tcurrentPrompt = candidate.Content\n\t\t} else {\n\t\t\t// Restore pre-candidate prompt when not promoted\n\t\t\trequire.NoError(t, pop.RestoreSnapshot(assignment))\n\t\t\trestored, _ := os.ReadFile(filepath.Join(dir, promptPath))\n\t\t\tassert.Equal(t, currentPrompt, string(restored))\n\t\t}\n\t}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1196,"cache_read_input_tokens":62664,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1196},"output_tokens":10,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"20d5adfa-ca6e-4c90-b84e-e05e5aa65257","uuid":"74cd97d1-0b86-4fcb-8a17-bead394b857a"}
