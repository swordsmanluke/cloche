nil {\n\t\tif _, isHost := hostWFs[req.WorkflowName]; isHost {\n\t\t\treturn s.runHostWorkflow(ctx, req)\n\t\t}\n\t}\n\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")","numLines":50,"startLine":55,"totalLines":1536}}}
