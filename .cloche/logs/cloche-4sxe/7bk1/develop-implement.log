ontinue\n   394→\t\t}\n   395→\n   396→\t\t// Fast path: log messages don't need store interaction.\n   397→\t\tif msg.Type == protocol.MsgLog {\n   398→\t\t\tif s.logBroadcast != nil {\n   399→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   400→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   401→\t\t\t\t\tType:      \"llm\",\n   402→\t\t\t\t\tContent:   msg.Message,\n   403→\t\t\t\t\tStepName:  msg.StepName,\n   404→\t\t\t\t})\n   405→\t\t\t}\n   406→\t\t\tcontinue\n   407→\t\t}\n   408→\n   409→\t\trun, err := s.store.GetRun(ctx, runID)\n   410→\t\tif err != nil {\n   411→\t\t\tcontinue\n   412→\t\t}\n   413→\n   414→\t\tswitch msg.Type {\n   415→\t\tcase protocol.MsgStepStarted:\n   416→\t\t\trun.RecordStepStart(msg.StepName)\n   417→\t\t\tif s.captures != nil {\n   418→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   419→\t\t\t\t\tStepName:  msg.StepName,\n   420→\t\t\t\t\tStartedAt: msg.Timestamp,\n   421→\t\t\t\t})\n   422→\t\t\t}\n   423→\t\t\tif s.logBroadcast != nil {\n   424→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   425→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   426→\t\t\t\t\tType:      \"status\",\n   427→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   428→\t\t\t\t\tStepName:  msg.StepName,\n   429→\t\t\t\t})\n   430→\t\t\t}\n   431→\t\tcase protocol.MsgStepCompleted:\n   432→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   433→\t\t\tif s.captures != nil {\n   434→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   435→\t\t\t\t\tStepName:    msg.StepName,\n   436→\t\t\t\t\tResult:      msg.Result,\n   437→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   438→\t\t\t\t})\n   439→\t\t\t}\n   440→\t\t\tif s.logBroadcast != nil {\n   441→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   442→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   443→\t\t\t\t\tType:      \"status\",\n   444→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   445→\t\t\t\t\tStepName:  msg.StepName,\n   446→\t\t\t\t})\n   447→\t\t\t}\n   448→\t\tcase protocol.MsgRunTitle:\n   449→\t\t\tif run.Title == \"\" {\n   450→\t\t\t\trun.Title = msg.Message\n   451→\t\t\t}\n   452→\t\tcase protocol.MsgError:\n   453→\t\t\treportedError = msg.Message\n   454→\t\t\tcontinue // Don't persist; used during finalization\n   455→\t\tcase protocol.MsgRunCompleted:\n   456→\t\t\treportedResult = msg.Result\n   457→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   458→\t\t}\n   459→\n   460→\t\t_ = s.store.UpdateRun(ctx, run)\n   461→\t}\n   462→\treader.Close()\n   463→\n   464→\t// Wait for process exit\n   465→\texitCode, err := s.container.Wait(ctx, containerID)\n   466→\tif err != nil {\n   467→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   468→\t}\n   469→\n   470→\t// Extract step output files from container before it's removed\n   471→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   472→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   473→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   474→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   475→\t\t}\n   476→\t}\n   477→\n   478→\t// Capture full container stdout/stderr before the container is removed\n   479→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   480→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   481→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   482→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   483→\t\t}\n   484→\t}\n   485→\n   486→\t// Index extracted log files in the log store\n   487→\tif s.logStore != nil {\n   488→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   489→\t}\n   4