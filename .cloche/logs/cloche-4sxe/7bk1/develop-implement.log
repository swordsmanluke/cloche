{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UiR9Xsw7HVWzCroqjQjJFg","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"strings\"\n     9→\t\"time\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    12→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    13→)\n    14→\n    15→// OrchestratorConfig configures the evolution pipeline.\n    16→type OrchestratorConfig struct {\n    17→\tProjectDir       string\n    18→\tWorkflowName     string\n    19→\tLLM              LLMClient\n    20→\tMinConfidence    string\n    21→\tMaxPromptBullets int\n    22→}\n    23→\n    24→// Orchestrator wires all evolution pipeline stages together.\n    25→type Orchestrator struct {\n    26→\tcfg        OrchestratorConfig\n    27→\tcollector  *Collector\n    28→\tclassifier *Classifier\n    29→\treflector  *Reflector\n    30→\tcurator    *Curator\n    31→\tscriptGen  *ScriptGenerator\n    32→\tmutator    *dsl.Mutator\n    33→\taudit      *AuditLogger\n    34→}\n    35→\n    36→// NewOrchestrator creates a fully wired evolution pipeline.\n    37→func NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n    38→\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir, MaxPromptBullets: cfg.MaxPromptBullets}\n    39→\treturn &Orchestrator{\n    40→\t\tcfg:        cfg,\n    41→\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n    42→\t\tclassifier: &Classifier{LLM: cfg.LLM},\n    43→\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n    44→\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n    45→\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n    46→\t\tmutator:    &dsl.Mutator{},\n    47→\t\taudit:      audit,\n    48→\t}\n    49→}\n    50→\n    51→// Run executes the full evolution pipeline.\n    52→func (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n    53→\t// Stage 1: Collect\n    54→\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n    55→\tif err != nil {\n    56→\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n    57→\t}\n    58→\n    59→\t// Stage 2: Classify the triggering run\n    60→\tclassification, err := o.classifier.Classify(ctx, \"\")\n    61→\tif err != nil {\n    62→\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n    63→\t}\n    64→\n    65→\t// Stage 3: Reflect\n    66→\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n    67→\tif err != nil {\n    68→\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n    69→\t}\n    70→\n    71→\t// Filter out lessons whose IDs are already recorded in the knowledge base.\n    72→\t// This guards against the Reflector re-surfacing previously applied lessons.\n    73→\tif data.KnowledgeBase != \"\" {\n    74→\t\tvar fresh []Lesson\n    75→\t\tfor _, l := range lessons {\n    76→\t\t\tif l.ID != \"\" && strings.Contains(data.KnowledgeBase, l.ID) {\n    77→\t\t\t\tcontinue\n    78→\t\t\t}\n    79→\t\t\tfresh = append(fresh, l)\n    80→\t\t}\n    81→\t\tlessons = fresh\n    82→\t}\n    83→\n    84→\tresult := &EvolutionResult{\n    85→\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n    86→\t\tProjectDir:     o.cfg.ProjectDir,\n    87→\t\tWorkflowName:   o.cfg.WorkflowName,\n    88→\t\tTriggerRunID:   triggerRunID,\n    89→\t\tTimestamp:      time.Now().Format(time.RFC3339),\n    90→\t\tClassification: classification,\n    91→\t}\n    92→\n    93→\tif len(lessons) == 0 {\n    94→\t\t// No actionable lessons — log and return\n    95→\t\to.audit.Log(result)\n    96→\t\treturn result, nil\n    97→\t}\n    98→\n    99→\t// Stage 4: Execute branches based on lesson category\n   100→\tfor _, lesson := range lessons {\n   101→\t\tswitch lesson.Category {\n   102→\t\tcase \"prompt_improvement\":\n   103→\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n   104→\t\t\tif err != nil {\n   105→\t\t\t\tcontinue // log but don't fail the whole pipeline\n   106→\t\t\t}\n   107→\t\t\tif change == nil {\n   108→\t\t\t\tcontinue // lesson already present in prompt — no change needed\n   109→\t\t\t}\n   110→\t\t\tresult.Changes = append(result.Changes, *change)\n   111→\n   112→\t\tcase \"new_step\":\n   113→\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n   114→\t\t\t\tcontinue\n   115→\t\t\t}\n   116→\t\t}\n   117→\t}\n   118→\n   119→\t// Stage 5: Audit\n   120→\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n   121→\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n   122→\to.audit.Log(result)\n   123→\n   124→\t// Save to store if available\n   125→\tif evoStore != nil {\n   126→\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n   127→\t\t\tID:             result.ID,\n   128→\t\t\tProjectDir:     result.ProjectDir,\n   129→\t\t\tWorkflowName:   result.WorkflowName,\n   130→\t\t\tTriggerRunID:   result.TriggerRunID,\n   131→\t\t\tCreatedAt:      time.Now(),\n   132→\t\t\tClassification: result.Classification,\n   133→\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n   134→\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n   135→\t\t})\n   136→\t}\n   137→\n   138→\treturn result, nil\n   139→}\n   140→\n   141→// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\n   142→func (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n   143→\t// Generate the script or prompt file\n   144→\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n   145→\tif err != nil {\n   146→\t\treturn err\n   147→\t}\n   148→\n   149→\tresult.Changes = append(result.Changes, Change{\n   150→\t\tType:   \"add_script\",\n   151→\t\tFile:   generated.Path,\n   152→\t\tReason: lesson.Insight,\n   153→\t})\n   154→\n   155→\t// Add step and wiring to the workflow file\n   156→\tif data.WorkflowPath == \"\" {\n   157→\t\treturn nil\n   158→\t}\n   159→\n   160→\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n   161→\tif err != nil {\n   162→\t\treturn err\n   163→\t}\n   164→\n   165→\t// Snapshot the workflow\n   166→\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n   167→\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n   168→\toriginal := string(workflowContent)\n   169→\n   170→\t// Derive step name from the script path\n   171→\tstepName := filepath.Base(generated.Path)\n   172→\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n   173→\n   174→\t// Check if a step with this name already exists — skip if so\n   175→\texistingWf, parseErr := dsl.Parse(original)\n   176→\tif parseErr == nil {\n   177→\t\tif _, exists := existingWf.Steps[stepName]; exists {\n   178→\t\t\treturn nil\n   179→\t\t}\n   180→\t}\n   181→\n   182→\t// Determine the config based on step type\n   183→\tconfig := map[string]string{}\n   184→\tswitch lesson.StepType {\n   185→\tcase \"agent\":\n   186→\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n   187→\tdefault: // script\n   188→\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n   189→\t}\n   190→\n   191→\t// Add the step\n   192→\tupdated, err := o.mutator.AddStep(original, dsl.StepDef{\n   193→\t\tName:    stepName,\n   194→\t\tType:    lesson.StepType,\n   195→\t\tConfig:  config,\n   196→\t\tResults: []string{\"success\", \"fail\"},\n   197→\t})\n   198→\tif err != nil {\n   199→\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n   200→\t}\n   201→\n   202→\t// Wire the new step into the existing graph by finding a wire\n   203→\t// that currently goes to \"done\" and rerouting it through the new step.\n   204→\twf, parseErr := dsl.Parse(updated)\n   205→\tif parseErr == nil {\n   206→\t\tfor _, wire := range wf.Wiring {\n   207→\t\t\tif wire.To == \"done\" {\n   208→\t\t\t\trewired, rewireErr := o.mutator.RewireResult(updated, wire.From, wire.Result, \"done\", stepName)\n   209→\t\t\t\tif rewireErr == nil {\n   210→\t\t\t\t\tupdated = rewired\n   211→\t\t\t\t\tbreak\n   212→\t\t\t\t}\n   213→\t\t\t}\n   214→\t\t}\n   215→\t}\n   216→\n   217→\t// Wire the new step's results to terminals\n   218→\twires := []dsl.WireDef{\n   219→\t\t{From: stepName, Result: \"success\", To: \"done\"},\n   220→\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n   221→\t}\n   222→\tupdated, err = o.mutator.AddWiring(updated, wires)\n   223→\tif err != nil {\n   224→\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n   225→\t}\n   226→\n   227→\t// Validate the final workflow graph — roll back on failure\n   228→\tfinalWf, parseErr := dsl.Parse(updated)\n   229→\tif parseErr != nil {\n   230→\t\treturn fmt.Errorf(\"parsing updated workflow: %w\", parseErr)\n   231→\t}\n   232→\tif valErr := finalWf.Validate(); valErr != nil {\n   233→\t\treturn fmt.Errorf(\"workflow validation failed after adding step %q: %w\", stepName, valErr)\n   234→\t}\n   235→\n   236→\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n   237→\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n   238→\t}\n   239→\n   240→\tresult.Changes = append(result.Changes, Change{\n   241→\t\tType:     \"add_step\",\n   242→\t\tFile:     wfRelPath,\n   243→\t\tReason:   lesson.Insight,\n   244→\t\tSnapshot: snapName,\n   245→\t})\n   246→\n   247→\treturn nil\n   248→}\n   249→"}]},"parent_tool_use_id":"toolu_01CHsGfHFbwJREmYZ4LmDQS2","session_id":"20d5adfa-ca6e-4c90-b84e-e05e5aa65257","uuid":"ff20a786-cc61-4412-b2d1-67cef546b990","timestamp":"2026-03-17T14:07:38.029Z"}
