{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BnyrbwhNqUYBS97VCGSiGX","type":"tool_result","content":"     1→package config\n     2→\n     3→import (\n     4→\t\"os\"\n     5→\t\"path/filepath\"\n     6→\n     7→\t\"github.com/BurntSushi/toml\"\n     8→)\n     9→\n    10→type DaemonConfig struct {\n    11→\tListen     string `toml:\"listen\"`\n    12→\tHTTP       string `toml:\"http\"`\n    13→\tImage      string `toml:\"image\"`\n    14→\tDB         string `toml:\"db\"`\n    15→\tRuntime    string `toml:\"runtime\"`\n    16→\tAgentPath  string `toml:\"agent_path\"`\n    17→\tLLMCommand string `toml:\"llm_command\"`\n    18→}\n    19→\n    20→type PopulationConfig struct {\n    21→\tEnabled            bool    `toml:\"enabled\"`\n    22→\tSize               int     `toml:\"size\"`                // number of candidates to maintain\n    23→\tPromotionThreshold float64 `toml:\"promotion_threshold\"` // fitness score to promote (0.0-1.0)\n    24→}\n    25→\n    26→type EvolutionConfig struct {\n    27→\tEnabled          bool             `toml:\"enabled\"`\n    28→\tDebounceSeconds  int              `toml:\"debounce_seconds\"`\n    29→\tMinConfidence    string           `toml:\"min_confidence\"`\n    30→\tMaxPromptBullets int              `toml:\"max_prompt_bullets\"`\n    31→\tPopulation       PopulationConfig `toml:\"population\"`\n    32→}\n    33→\n    34→type OrchestrationConfig struct {\n    35→\tConcurrency            int     `toml:\"concurrency\"`\n    36→\tStaggerSeconds         float64 `toml:\"stagger_seconds\"`\n    37→\tListTasksCommand       string  `toml:\"list_tasks_command\"`       // shell command to list open tasks (JSON array output)\n    38→\tDedupSeconds           float64 `toml:\"dedup_seconds\"`            // dedup window for task assignment (default: 300)\n    39→\tStopOnError            bool    `toml:\"stop_on_error\"`            // halt orchestration loop on unrecovered error\n    40→\tMaxConsecutiveFailures int     `toml:\"max_consecutive_failures\"` // halt loop after N consecutive failures (default: 3, must be > 0)\n    41→}\n    42→\n    43→type Config struct {\n    44→\tActive        bool                `toml:\"active\"`\n    45→\tDaemon        DaemonConfig        `toml:\"daemon\"`\n    46→\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n    47→\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n    48→}\n    49→\n    50→func defaults() Config {\n    51→\treturn Config{\n    52→\t\tEvolution: EvolutionConfig{\n    53→\t\t\tEnabled:          true,\n    54→\t\t\tDebounceSeconds:  30,\n    55→\t\t\tMinConfidence:    \"medium\",\n    56→\t\t\tMaxPromptBullets: 50,\n    57→\t\t},\n    58→\t\tOrchestration: OrchestrationConfig{\n    59→\t\t\tConcurrency:            1,\n    60→\t\t\tStaggerSeconds:         1.0,\n    61→\t\t\tMaxConsecutiveFailures: 3,\n    62→\t\t},\n    63→\t}\n    64→}\n    65→\n    66→// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    67→func Load(projectDir string) (*Config, error) {\n    68→\tcfg := defaults()\n    69→\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    70→\n    71→\tdata, err := os.ReadFile(path)\n    72→\tif os.IsNotExist(err) {\n    73→\t\treturn &cfg, nil\n    74→\t}\n    75→\tif err != nil {\n    76→\t\treturn nil, err\n    77→\t}\n    78→\n    79→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    80→\t\treturn nil, err\n    81→\t}\n    82→\treturn &cfg, nil\n    83→}\n    84→\n    85→// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n    86→// Returns defaults if the file does not exist.\n    87→func LoadGlobal() (*Config, error) {\n    88→\tcfg := defaults()\n    89→\n    90→\thome, err := os.UserHomeDir()\n    91→\tif err != nil {\n    92→\t\treturn &cfg, nil\n    93→\t}\n    94→\n    95→\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n    96→\tdata, err := os.ReadFile(path)\n    97→\tif os.IsNotExist(err) {\n    98→\t\treturn &cfg, nil\n    99→\t}\n   100→\tif err != nil {\n   101→\t\treturn nil, err\n   102→\t}\n   103→\n   104→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   105→\t\treturn nil, err\n   106→\t}\n   107→\treturn &cfg, nil\n   108→}\n   109→\n   110→// StateDir returns the path to ~/.config/cloche/ and ensures it exists.\n   111→// Falls back to a temp directory if the home directory cannot be determined.\n   112→func StateDir() string {\n   113→\thome, err := os.UserHomeDir()\n   114→\tif err != nil {\n   115→\t\treturn filepath.Join(os.TempDir(), \"cloche\")\n   116→\t}\n   117→\treturn filepath.Join(home, \".config\", \"cloche\")\n   118→}\n   119→\n   120→// EnsureStateDir creates the state directory if it doesn't exist.\n   121→func EnsureStateDir() (string, error) {\n   122→\tdir := StateDir()\n   123→\tif err := os.MkdirAll(dir, 0755); err != nil {\n   124→\t\treturn \"\", err\n   125→\t}\n   126→\treturn dir, nil\n   127→}\n   128→\n   129→// DefaultDBPath returns the default database path: ~/.config/cloche/cloche.db\n   130→func DefaultDBPath() string {\n   131→\treturn filepath.Join(StateDir(), \"cloche.db\")\n   132→}\n   133→\n   134→// DefaultSocketAddr returns the default Unix socket address: unix://~/.config/cloche/cloche.sock\n   135→func DefaultSocketAddr() string {\n   136→\treturn \"unix://\" + filepath.Join(StateDir(), \"cloche.sock\")\n   137→}\n   138→\n   139→// LoadGlobalFrom reads the global config from a specific path.\n   140→// Useful for testing.\n   141→func LoadGlobalFrom(path string) (*Config, error) {\n   142→\tcfg := defaults()\n   143→\n   144→\tdata, err := os.ReadFile(path)\n   145→\tif os.IsNotExist(err) {\n   146→\t\treturn &cfg, nil\n   147→\t}\n   148→\tif err != nil {\n   149→\t\treturn nil, err\n   150→\t}\n   151→\n   152→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   153→\t\treturn nil, err\n   154→\t}\n   155→\treturn &cfg, nil\n   156→}\n   157→"}]},"parent_tool_use_id":"toolu_