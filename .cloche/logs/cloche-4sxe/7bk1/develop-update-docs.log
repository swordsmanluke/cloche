{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GKioeNHwBA7sjV6yTtqcja","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"net\"\n     7→\t\"net/http\"\n     8→\t\"os\"\n     9→\t\"os/signal\"\n    10→\t\"path/filepath\"\n    11→\t\"syscall\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    15→\t\"github.com/cloche-dev/cloche/internal/version\"\n    16→\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    20→\t\"github.com/cloche-dev/cloche/internal/config\"\n    21→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    22→\thostpkg \"github.com/cloche-dev/cloche/internal/host\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→\t\"google.golang.org/grpc\"\n    26→)\n    27→\n    28→func main() {\n    29→\tif len(os.Args) >= 2 && (os.Args[1] == \"-v\" || os.Args[1] == \"--version\") {\n    30→\t\tfmt.Printf(\"cloched %s\\n\", version.Version())\n    31→\t\treturn\n    32→\t}\n    33→\n    34→\t// Load global config file (~/.config/cloche/config)\n    35→\tglobalCfg, err := config.LoadGlobal()\n    36→\tif err != nil {\n    37→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n    38→\t\tdefaults := config.Config{}\n    39→\t\tglobalCfg = &defaults\n    40→\t}\n    41→\n    42→\t// Ensure state directory exists (~/.config/cloche/)\n    43→\tif _, err := config.EnsureStateDir(); err != nil {\n    44→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to create state dir: %v\\n\", err)\n    45→\t}\n    46→\n    47→\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, config.DefaultDBPath())\n    48→\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, config.DefaultSocketAddr())\n    49→\n    50→\tstore, err := sqlite.NewStore(dbPath)\n    51→\tif err != nil {\n    52→\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    53→\t\tos.Exit(1)\n    54→\t}\n    55→\tdefer store.Close()\n    56→\n    57→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    58→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    59→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    60→\t} else if n > 0 {\n    61→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    62→\t}\n    63→\n    64→\truntime, err := initRuntime(globalCfg)\n    65→\tif err != nil {\n    66→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    67→\t\tos.Exit(1)\n    68→\t}\n    69→\n    70→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    71→\n    72→\tbroadcaster := logstream.NewBroadcaster()\n    73→\n    74→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    75→\tsrv.SetLogStore(store)\n    76→\tsrv.SetLogBroadcaster(broadcaster)\n    77→\n    78→\t// Set up evolution trigger\n    79→\tevoTrigger := initEvolution(globalCfg, store, store)\n    80→\tif evoTrigger != nil {\n    81→\t\tsrv.SetEvolution(evoTrigger)\n    82→\t}\n    83→\n    84→\t// Set up population if configured\n    85→\tpop := initPopulation(globalCfg)\n    86→\tif pop != nil {\n    87→\t\tsrv.SetPopulation(pop)\n    88→\t}\n    89→\n    90→\tgrpcServer := grpc.NewServer()\n    91→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    92→\n    93→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    94→\n    95→\tlis, err := listen(listenAddr)\n    96→\tif err != nil {\n    97→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    98→\t\tos.Exit(1)\n    99→\t}\n   100→\n   101→\tvar httpServer *http.Server\n   102→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n   103→\t\twebOpts := []web.HandlerOption{\n   104→\t\t\tweb.WithContainerLogger(runtime),\n   105→\t\t\tweb.WithLogStore(store),\n   106→\t\t\tweb.WithLogBroadcaster(broadcaster),\n   107→\t\t\tweb.WithTaskProvider(srv),\n   108→\t\t}\n   109→\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n   110→\t\tif err != nil {\n   111→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n   112→\t\t\tos.Exit(1)\n   113→\t\t}\n   114→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n   115→\t\tgo func() {\n   116→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   117→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   118→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   119→\t\t\t}\n   120→\t\t}()\n   121→\t}\n   122→\n   123→\t// Auto-execute main workflow for active projects\n   124→\tautoRunActiveProjects(store, srv)\n   125→\n   126→\tsigCh := make(chan os.Signal, 1)\n   127→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   128→\tgo func() {\n   129→\t\t<-sigCh\n   130→\t\tif httpServer != nil {\n   131→\t\t\thttpServer.Close()\n   132→\t\t}\n   133→\t\tgrpcServer.GracefulStop()\n   134→\t}()\n   135→\n   136→\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   137→\tif err := grpcServer.Serve(lis); err != nil {\n   138→\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   139→\t\tos.Exit(1)\n   140→\t}\n   141→}\n   142→\n   143→func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   144→\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   145→\n   146→\tswitch runtimeType {\n   147→\tcase \"local\":\n   148→\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   149→\t\tif agentPath == \"\" {\n   150→\t\t\t// Look for cloche-agent next to this binary\n   151→\t\t\texe, err := os.Executable()\n   152→\t\t\tif err == nil {\n   153→\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   154→\t\t\t} else {\n   155→\t\t\t\tagentPath = \"cloche-agent\"\n   156→\t\t\t}\n   157→\t\t}\n   158→\t\treturn local.NewRuntime(agentPath), nil\n   159→\tcase \"docker\":\n   160→\t\treturn docker.NewRuntime()\n   161→\tdefault:\n   162→\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   163→\t}\n   164→}\n   165→\n   166→func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   167→\t// Load config from working directory (daemon-level defaults)\n   168→\tcfg, err := config.Load(\".\")\n   169→\tif err != nil || !cfg.Evolution.Enabled {\n   170→\t\treturn nil\n   171→\t}\n   172→\n   173→\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   174→\tif llmCmd == \"\" {\n   175→\t\treturn nil\n   176→\t}\n   177→\n   178→\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   179→\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   180→\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   181→\t\t\t// Load per-project config for confidence threshold\n   182→\t\t\tprojCfg, err := config.Load(projectDir)\n   183→\t\t\tif err != nil {\n   184→\t\t\t\tprojCfg = cfg // fall back to daemon config\n   185→\t\t\t}\n   186→\n   187→\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   188→\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   189→\t\t\t\tProjectDir:    projectDir,\n   190→\t\t\t\tWorkflowName:  workflowName,\n   191→\t\t\t\tLLM:           llm,\n   192→\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   193→\t\t\t})\n   194→\n   195→\t\t\tctx := context.Background()\n   196→\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   197→\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   198→\t\t\t}\n   199→\t\t},\n   200→\t})\n   201→\n   202→\treturn trigger\n   203→}\n   204→\n   205→func initPopulation(globalCfg *config.Config) *evolution.Population {\n   206→\tcfg, err := config.Load(\".\")\n   207→\tif err != nil || !cfg.Evolution.Population.Enabled {\n   208→\t\treturn nil\n   209→\t}\n   210→\n   211→\tpop := evolution.NewPopulation(\n   212→\t\tevolution.PopulationConfig{\n   213→\t\t\tEnabled:            cfg.Evolution.Population.Enabled,\n   214→\t\t\tSize:               cfg.Evolution.Population.Size,\n   215→\t\t\tPromotionThreshold: cfg.Evolution.Population.PromotionThreshold,\n   216→\t\t},\n   217→\t\t\".\", // daemon working directory; overridden per-project at runtime\n   218→\t\t\"\",  // workflow name set per-run\n   219→\t)\n   220→\treturn pop\n   221→}\n   222→\n   223→func listen(addr string) (net.Listener, error) {\n   224→\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   225→\t\tsockPath := addr[7:]\n   226→\t\tos.Remove(sockPath)\n   227→\t\treturn net.Listen(\"unix\", sockPath)\n   228→\t}\n   229→\treturn net.Listen(\"tcp\", addr)\n   230→}\n   231→\n   232→// autoRunActiveProjects scans known projects for active = true in their config,\n   233→// parses .cloche/host.cloche and executes the full host workflow step by step.\n   234→func autoRunActiveProjects(store ports.RunStore, srv *adaptgrpc.ClocheServer) {\n   235→\tctx := context.Background()\n   236→\tprojects, err := store.ListProjects(ctx)\n   237→\tif err != nil {\n   238→\t\tfmt.Fprintf(os.Stderr, \"startup: failed to list projects: %v\\n\", err)\n   239→\t\treturn\n   240→\t}\n   241→\n   242→\tfor _, projectDir := range projects {\n   243→\t\tcfg, err := config.Load(projectDir)\n   244→\t\tif err != nil || !cfg.Active {\n   245→\t\t\tcontinue\n   246→\t\t}\n   247→\n   248→\t\t// Verify host.cloche exists before launching\n   249→\t\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   250→\t\tif _, err := os.Stat(hostPath); err != nil {\n   251→\t\t\tfmt.Fprintf(os.Stderr, \"startup: skipping active project %s: %v\\n\", projectDir, err)\n   252→\t\t\tcontinue\n   253→\t\t}\n   254→\n   255→\t\tfmt.Fprintf(os.Stderr, \"startup: auto-running host workflow for active project %s\\n\", projectDir)\n   256→\t\tgo func(projDir string) {\n   257→\t\t\trunner := &hostpkg.Runner{\n   258→\t\t\t\tDispatcher: srv,\n   259→\t\t\t\tStore:      store,\n   260→\t\t\t}\n   261→\t\t\tresult, err := runner.Run(context.Background(), projDir)\n   262→\t\t\tif err != nil {\n   263→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow failed for %s: %v\\n\", projDir, err)\n   264→\t\t\t} else {\n   265→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow completed for %s: %s (run %s)\\n\", projDir, result.State, result.RunID)\n   266→\t\t\t}\n   267→\t\t}(projectDir)\n   268→\t}\n   269→}\n   270→\n   271→// envOrConfig returns the env var value if set, otherwise the config file\n   272→// value if non-empty, otherwise the fallback default.\n   273→func envOrConfig(envKey, configVal, fallback string) string {\n   274→\tif v := os.Getenv(envKey); v != \"\" {\n   275→\t\treturn v\n   276→\t}\n   277→\tif configVal != \"\" {\n   278→\t\treturn configVal\n   279→\t}\n   280→\treturn fallback\n   281→}\n   282→"}]},"parent_tool_use_id":"toolu_01BMdsXGwp2tL88vN9stt8Wj","session_id":"bde08716-55af-46e3-8699-03ed6e35c1ab","uuid":"1328ab2d-e506-43dc-ac79-f3351888ff10","timestamp":"2026-03-17T14:16:00.800Z"}
