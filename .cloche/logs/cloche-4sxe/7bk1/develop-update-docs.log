{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XW9HhQ8FBXZbDwdmp1Rj7d","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"encoding/json\"\n     5→\t\"fmt\"\n     6→\t\"math/rand\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"sort\"\n    10→\t\"strings\"\n    11→\t\"sync\"\n    12→\t\"time\"\n    13→)\n    14→\n    15→// PopulationConfig configures population-based prompt evolution.\n    16→type PopulationConfig struct {\n    17→\tEnabled            bool    `toml:\"enabled\"`\n    18→\tSize               int     `toml:\"size\"`                // number of candidates to maintain\n    19→\tPromotionThreshold float64 `toml:\"promotion_threshold\"` // fitness score to promote (0.0-1.0)\n    20→}\n    21→\n    22→// Candidate is a single prompt variant in the population.\n    23→type Candidate struct {\n    24→\tID         string  `json:\"id\"`\n    25→\tContent    string  `json:\"content\"`\n    26→\tFitness    float64 `json:\"fitness\"`\n    27→\tRuns       int     `json:\"runs\"`\n    28→\tGeneration int     `json:\"generation\"`\n    29→\tPromoted   bool    `json:\"promoted\"`\n    30→\tCreatedAt  string  `json:\"created_at\"`\n    31→}\n    32→\n    33→// Assignment records which candidate was used for a run.\n    34→type Assignment struct {\n    35→\tRunID       string `json:\"run_id\"`\n    36→\tCandidateID string `json:\"candidate_id\"`\n    37→\tPromptPath  string `json:\"prompt_path\"`\n    38→\tSnapshot    string `json:\"snapshot\"`\n    39→}\n    40→\n    41→// Population manages candidate prompts for a workflow.\n    42→type Population struct {\n    43→\tConfig       PopulationConfig\n    44→\tProjectDir   string\n    45→\tWorkflowName string\n    46→\tmu           sync.Mutex\n    47→\tassignments  map[string]*Assignment // runID -> assignment\n    48→}\n    49→\n    50→// NewPopulation creates a new population manager.\n    51→func NewPopulation(cfg PopulationConfig, projectDir, workflowName string) *Population {\n    52→\tif cfg.Size <= 0 {\n    53→\t\tcfg.Size = 5\n    54→\t}\n    55→\tif cfg.PromotionThreshold <= 0 {\n    56→\t\tcfg.PromotionThreshold = 0.8\n    57→\t}\n    58→\treturn &Population{\n    59→\t\tConfig:       cfg,\n    60→\t\tProjectDir:   projectDir,\n    61→\t\tWorkflowName: workflowName,\n    62→\t\tassignments:  make(map[string]*Assignment),\n    63→\t}\n    64→}\n    65→\n    66→// populationDir returns the directory for population data.\n    67→func (p *Population) populationDir() string {\n    68→\treturn filepath.Join(p.ProjectDir, \".cloche\", \"evolution\", \"population\", p.WorkflowName)\n    69→}\n    70→\n    71→// candidatesPath returns the path to the candidates JSONL file.\n    72→func (p *Population) candidatesPath() string {\n    73→\treturn filepath.Join(p.populationDir(), \"candidates.jsonl\")\n    74→}\n    75→\n    76→// LoadCandidates reads all candidates from the JSONL file.\n    77→func (p *Population) LoadCandidates() ([]Candidate, error) {\n    78→\tdata, err := os.ReadFile(p.candidatesPath())\n    79→\tif os.IsNotExist(err) {\n    80→\t\treturn nil, nil\n    81→\t}\n    82→\tif err != nil {\n    83→\t\treturn nil, err\n    84→\t}\n    85→\n    86→\tvar candidates []Candidate\n    87→\tfor _, line := range strings.Split(strings.TrimSpace(string(data)), \"\\n\") {\n    88→\t\tline = strings.TrimSpace(line)\n    89→\t\tif line == \"\" {\n    90→\t\t\tcontinue\n    91→\t\t}\n    92→\t\tvar c Candidate\n    93→\t\tif err := json.Unmarshal([]byte(line), &c); err != nil {\n    94→\t\t\tcontinue\n    95→\t\t}\n    96→\t\tcandidates = append(candidates, c)\n    97→\t}\n    98→\treturn candidates, nil\n    99→}\n   100→\n   101→// SaveCandidates writes all candidates to the JSONL file.\n   102→func (p *Population) SaveCandidates(candidates []Candidate) error {\n   103→\tif err := os.MkdirAll(p.populationDir(), 0755); err != nil {\n   104→\t\treturn fmt.Errorf(\"creating population dir: %w\", err)\n   105→\t}\n   106→\n   107→\tvar sb strings.Builder\n   108→\tfor _, c := range candidates {\n   109→\t\tdata, err := json.Marshal(c)\n   110→\t\tif err != nil {\n   111→\t\t\tcontinue\n   112→\t\t}\n   113→\t\tsb.Write(data)\n   114→\t\tsb.WriteByte('\\n')\n   115→\t}\n   116→\treturn os.WriteFile(p.candidatesPath(), []byte(sb.String()), 0644)\n   117→}\n   118→\n   119→// SelectCandidate picks a candidate for the next run using fitness-proportionate\n   120→// selection. Higher-fitness candidates are more likely to be selected, but\n   121→// under-tested candidates (fewer runs) get a boost to ensure exploration.\n   122→func (p *Population) SelectCandidate() (*Candidate, error) {\n   123→\tcandidates, err := p.LoadCandidates()\n   124→\tif err != nil {\n   125→\t\treturn nil, fmt.Errorf(\"loading candidates: %w\", err)\n   126→\t}\n   127→\tif len(candidates) == 0 {\n   128→\t\treturn nil, nil\n   129→\t}\n   130→\n   131→\t// Sort by effective score: fitness + exploration bonus for under-tested candidates\n   132→\ttype scored struct {\n   133→\t\tidx   int\n   134→\t\tscore float64\n   135→\t}\n   136→\tvar scores []scored\n   137→\tfor i, c := range candidates {\n   138→\t\texplorationBonus := 0.0\n   139→\t\tif c.Runs < 3 {\n   140→\t\t\texplorationBonus = 0.2 * float64(3-c.Runs)\n   141→\t\t}\n   142→\t\tscores = append(scores, scored{idx: i, score: c.Fitness + explorationBonus})\n   143→\t}\n   144→\tsort.Slice(scores, func(i, j int) bool {\n   145→\t\treturn scores[i].score > scores[j].score\n   146→\t})\n   147→\n   148→\t// Select from top candidates with some randomness\n   149→\ttopN := len(scores)\n   150→\tif topN > 3 {\n   151→\t\ttopN = 3\n   152→\t}\n   153→\tpick := scores[rand.Intn(topN)]\n   154→\tselected := candidates[pick.idx]\n   155→\treturn &selected, nil\n   156→}\n   157→\n   158→// RecordAssignment records that a candidate was assigned to a run.\n   159→func (p *Population) RecordAssignment(runID string, assignment *Assignment) {\n   160→\tp.mu.Lock()\n   161→\tdefer p.mu.Unlock()\n   162→\tp.assignments[runID] = assignment\n   163→}\n   164→\n   165→// GetAssignment returns the assignment for a run, if any.\n   166→func (p *Population) GetAssignment(runID string) *Assignment {\n   167→\tp.mu.Lock()\n   168→\tdefer p.mu.Unlock()\n   169→\treturn p.assignments[runID]\n   170→}\n   171→\n   172→// ScoreAndPromote records fitness for the candidate that was assigned to this run\n   173→// and checks whether it should be promoted (copied to the base prompt path).\n   174→func (p *Population) ScoreAndPromote(runID string, succeeded bool) (*Candidate, bool, error) {\n   175→\tassignment := p.GetAssignment(runID)\n   176→\tif assignment == nil {\n   177→\t\treturn nil, false, nil\n   178→\t}\n   179→\n   180→\t// Clean up the assignment\n   181→\tp.mu.Lock()\n   182→\tdelete(p.assignments, runID)\n   183→\tp.mu.Unlock()\n   184→\n   185→\tcandidates, err := p.LoadCandidates()\n   186→\tif err != nil {\n   187→\t\treturn nil, false, fmt.Errorf(\"loading candidates: %w\", err)\n   188→\t}\n   189→\n   190→\t// Find and update the candidate\n   191→\tvar updated *Candidate\n   192→\tfor i := range candidates {\n   193→\t\tif candidates[i].ID == assignment.CandidateID {\n   194→\t\t\tc := &candidates[i]\n   195→\t\t\tc.Runs++\n   196→\n   197→\t\t\t// Update fitness as a running average\n   198→\t\t\treward := 0.0\n   199→\t\t\tif succeeded {\n   200→\t\t\t\treward = 1.0\n   201→\t\t\t}\n   202→\t\t\tc.Fitness = (c.Fitness*float64(c.Runs-1) + reward) / float64(c.Runs)\n   203→\n   204→\t\t\tupdated = c\n   205→\t\t\tbreak\n   206→\t\t}\n   207→\t}\n   208→\n   209→\tif updated == nil {\n   210→\t\treturn nil, false, nil\n   211→\t}\n   212→\n   213→\t// Check promotion threshold\n   214→\tpromoted := false\n   215→\tif updated.Fitness >= p.Config.PromotionThreshold && updated.Runs >= 2 && !updated.Promoted {\n   216→\t\t// Promote: copy candidate content to base prompt path\n   217→\t\tpromptFullPath := filepath.Join(p.ProjectDir, assignment.PromptPath)\n   218→\t\tif err := os.WriteFile(promptFullPath, []byte(updated.Content), 0644); err != nil {\n   219→\t\t\treturn updated, false, fmt.Errorf(\"promoting candidate: %w\", err)\n   220→\t\t}\n   221→\t\tupdated.Promoted = true\n   222→\t\tpromoted = true\n   223→\t}\n   224→\n   225→\tif err := p.SaveCandidates(candidates); err != nil {\n   226→\t\treturn updated, promoted, fmt.Errorf(\"saving candidates: %w\", err)\n   227→\t}\n   228→\n   229→\treturn updated, promoted, nil\n   230→}\n   231→\n   232→// ApplyCandidate copies the candidate content to the prompt path and creates\n   233→// a snapshot of the original. Returns the assignment record.\n   234→func (p *Population) ApplyCandidate(candidate *Candidate, promptPath, runID string) (*Assignment, error) {\n   235→\tfullPath := filepath.Join(p.ProjectDir, promptPath)\n   236→\n   237→\t// Create snapshot of original prompt\n   238→\tsnapDir := filepath.Join(p.ProjectDir, \".cloche\", \"evolution\", \"snapshots\")\n   239→\tif err := os.MkdirAll(snapDir, 0755); err != nil {\n   240→\t\treturn nil, fmt.Errorf(\"creating snapshots dir: %w\", err)\n   241→\t}\n   242→\n   243→\tsnapName := \"\"\n   244→\tif original, err := os.ReadFile(fullPath); err == nil {\n   245→\t\tsnapName = fmt.Sprintf(\"%s-pop-%s\", time.Now().Format(\"20060102T150405\"), filepath.Base(promptPath))\n   246→\t\tsnapPath := filepath.Join(snapDir, snapName)\n   247→\t\tif err := os.WriteFile(snapPath, original, 0644); err != nil {\n   248→\t\t\treturn nil, fmt.Errorf(\"creating snapshot: %w\", err)\n   249→\t\t}\n   250→\t}\n   251→\n   252→\t// Copy candidate content to prompt path\n   253→\tif err := os.MkdirAll(filepath.Dir(fullPath), 0755); err != nil {\n   254→\t\treturn nil, fmt.Errorf(\"creating prompt dir: %w\", err)\n   255→\t}\n   256→\tif err := os.WriteFile(fullPath, []byte(candidate.Content), 0644); err != nil {\n   257→\t\treturn nil, fmt.Errorf(\"writing candidate to prompt: %w\", err)\n   258→\t}\n   259→\n   260→\tassignment := &Assignment{\n   261→\t\tRunID:       runID,\n   262→\t\tCandidateID: candidate.ID,\n   263→\t\tPromptPath:  promptPath,\n   264→\t\tSnapshot:    snapName,\n   265→\t}\n   266→\n   267→\tp.RecordAssignment(runID, assignment)\n   268→\treturn assignment, nil\n   269→}\n   270→\n   271→// RestoreSnapshot restores the original prompt from a snapshot after a run completes.\n   272→func (p *Population) RestoreSnapshot(assignment *Assignment) error {\n   273→\tif assignment == nil || assignment.Snapshot == \"\" {\n   274→\t\treturn nil\n   275→\t}\n   276→\n   277→\tsnapDir := filepath.Join(p.ProjectDir, \".cloche\", \"evolution\", \"snapshots\")\n   278→\tsnapPath := filepath.Join(snapDir, assignment.Snapshot)\n   279→\n   280→\tdata, err := os.ReadFile(snapPath)\n   281→\tif err != nil {\n   282→\t\treturn fmt.Errorf(\"reading snapshot %s: %w\", assignment.Snapshot, err)\n   283→\t}\n   284→\n   285→\tfullPath := filepath.Join(p.ProjectDir, assignment.PromptPath)\n   286→\treturn os.WriteFile(fullPath, data, 0644)\n   287→}\n   288→\n   289→// FirstPromptPath returns the first prompt file referenced in the workflow,\n   290→// which is used as the target for candidate selection.\n   291→func FirstPromptPath(projectDir, workflowName string) string {\n   292→\twfPath := filepath.Join(projectDir, \".cloche\", workflowName+\".cloche\")\n   293→\twfContent, err := os.ReadFile(wfPath)\n   294→\tif err != nil {\n   295→\t\treturn \"\"\n   296→\t}\n   297→\trefs := extractPromptFiles(string(wfContent))\n   298→\tif len(refs) == 0 {\n   299→\t\treturn \"\"\n   300→\t}\n   301→\treturn refs[0]\n   302→}\n   303→"}]},"parent_tool_use_id":"toolu_01BMdsXGwp2tL88vN9stt8Wj","session_id":"bde08716-55af-46e3-8699-03ed6e35c1ab","uuid":"88b293ab-6377-4123-ae05-730f8f4cb1d2","timestamp":"2026-03-17T14:16:01.396Z"}
