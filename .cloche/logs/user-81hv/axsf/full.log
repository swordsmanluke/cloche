plate},\n\t}\n\n\tfor _, f := range files {\n\t\tif _, err := os.Stat(f.path); err == nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"  skip %s (already exists)\\n\", f.path)\n\t\t\tcontinue\n\t\t}\n\t\tif err := os.WriteFile(f.path, []byte(f.content), 0644); err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error writing %s: %v\\n\", f.path, err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Fprintf(os.Stderr, \"  create %s\\n\", f.path)\n\t}\n\n\t// Write prepare-prompt.sh with executable permissions\n\tscriptPath := filepath.Join(clocheDir, \"scripts\", \"prepare-prompt.sh\")\n\tif _, err := os.Stat(scriptPath); err == nil {\n\t\tfmt.Fprintf(os.Stderr, \"  skip %s (already exists)\\n\", scriptPath)\n\t} else {\n\t\tif err := os.WriteFile(scriptPath, []byte(preparePromptScript), 0755); err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error writing %s: %v\\n\", scriptPath, err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Fprintf(os.Stderr, \"  create %s\\n\", scriptPath)\n\t}\n\n\taddGitignoreEntries(filepath.Join(baseDir, \".gitignore\"), []string{\n\t\t\"# Cloche runtime artifacts\",\n\t\t\".cloche/*-*-*/\",\n\t\t\".cloche/run-*/\",\n\t\t\".cloche/attempt_count/\",\n\t\t\".gitworktrees/\",\n\t})\n\n\tname := filepath.Base(baseDir)\n\tif baseDir == \".\" {\n\t\tcwd, _ := os.Getwd()\n\t\tname = filepath.Base(cwd)\n\t}\n\tfmt.Fprintf(os.Stderr, \"\\nInitialized Cloche project in %s\\n\", name)\n\tfmt.Fprintf(os.Stderr, \"\\nNext steps:\\n\")\n\tfmt.Fprintf(os.Stderr, \"  1. Edit .cloche/config.toml    — enable orchestration, set concurrency\\n\")\n\tfmt.Fprintf(os.Stderr, \"  2. Edit .cloche/%s.cloche — adjust the test command for your project\\n\", workflow)\n\tfmt.Fprintf(os.Stderr, \"  3. Edit .cloche/Dockerfile     — add your project's dependencies\\n\")\n\tfmt.Fprintf(os.Stderr, \"  4. Edit .cloche/scripts/prepare-prompt.sh — customize prompt generation\\n\")\n\tfmt.Fprintf(os.Stderr, \"  5. Add container-specific overrides to .cloche/overrides/ (e.g. CLAUDE.md)\\n\")\n\tfmt.Fprintf(os.Stderr, \"  6. docker build -t cloche-agent -f .cloche/Dockerfile .\\n\")\n\tfmt.Fprintf(os.Stderr, \"  7. cloche run --workflow %s --prompt \\\"...\\\"\\n\", workflow)\n}\n\n// legacyGitignoreEntries are old patterns that should be removed when found.\nvar legacyGitignoreEntries = []string{\n\t\".cloche/*/\",\n\t\"!.cloche/prompts/\",\n\t\"!.cloche/overrides/\",\n\t\"!.cloche/evolution/\",\n}\n\nfunc addGitignoreEntries(gitignorePath string, entries []string) {\n\texisting, _ := os.ReadFile(gitignorePath)\n\tcontent := string(existing)\n\n\t// Remove legacy entries if present\n\tlegacySet := make(map[string]bool)\n\tfor _, le := range legacyGitignoreEntries {\n\t\tlegacySet[le] = true\n\t}\n\tlines := strings.Split(content, \"\\n\")\n\tvar filtered []string\n\tfor _, line := range lines {\n\t\tif legacySet[strings.TrimSpace(line)] {\n\t\t\tcontinue\n\t\t}\n\t\tfiltered = append(filtered, line)\n\t}\n\tcontent = strings.Join(filtered, \"\\n\")\n\n\tvar toAdd []string\n\tfor _, entry := range entries {\n\t\tif !strings.Contains(content, entry) {\n\t\t\ttoAdd = append(toAdd, entry)\n\t\t}\n\t}\n\tif len(toAdd) == 0 {\n\t\treturn\n\t}\n\n\tif len(content) > 0 && !strings.HasSuffix(content, \"\\n\") {\n\t\tcontent += \"\\n\"\n\t}\n\tcontent += strings.Join(toAdd, \"\\n\") + \"\\n\"\n\n\tif err := os.WriteFile(gitignorePath, []byte(content), 0644); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"warning: could not update .gitignore: %v\\n\", err)\n\t}\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":261,"cache_read_input_tokens":18799,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":261},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"41740985-2837-4203-81cf-9ae8c3365f37","uuid":"e61ed272-494d-44a3-8855-48fc21481039"}
