g` content in the prompt. |\n/workspace/docs/USAGE.md:prompt = file(\".cloche/prompts/implement.md\")","is_error":false}]},"parent_tool_use_id":"toolu_01PB2FoeV4tsuHgPF56K4Qdh","session_id":"87510e8f-028e-4687-9903-d33073502bb8","uuid":"defa8bd4-b74c-4d0e-a3b6-8a2818021e9f"}
