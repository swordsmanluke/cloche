[2026-03-13T14:39:21Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CyuWorSVxcM2vtUhS9dgbh","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# cleanup-run.sh — Remove the worktree and branch left over from a cloche run.\n     3→# Reads child run ID and task ID from run context (set via cloche set).\n     4→set -euo pipefail\n     5→\n     6→RUN_ID=$(cloche get child_run_id) || true\n     7→CLOCHE_TASK_ID=$(cloche get task_id) || true\n     8→PROJECT_DIR=\"${CLOCHE_PROJECT_DIR:-.}\"\n     9→\n    10→if [ -z \"$RUN_ID\" ]; then\n    11→  echo \"warning: child_run_id not found in run context, skipping branch cleanup\" >&2\n    12→else\n    13→  BRANCH=\"cloche/${RUN_ID}\"\n    14→  WORKTREE_DIR=\"$PROJECT_DIR/.gitworktrees/cloche/$RUN_ID\"\n    15→\n    16→  # Remove the extraction worktree if it still exists\n    17→  if [ -d \"$WORKTREE_DIR\" ]; then\n    18→    git -C \"$PROJECT_DIR\" worktree remove --force \"$WORKTREE_DIR\" 2>/dev/null || true\n    19→  fi\n    20→\n    21→  # Prune any stale worktree bookkeeping\n    22→  git -C \"$PROJECT_DIR\" worktree prune 2>/dev/null || true\n    23→\n    24→  # Delete the branch if it still exists (merge may have already removed it)\n    25→  if git -C \"$PROJECT_DIR\" rev-parse --verify \"$BRANCH\" >/dev/null 2>&1; then\n    26→    git -C \"$PROJECT_DIR\" branch -D \"$BRANCH\" 2>/dev/null || true\n    27→  fi\n    28→fi\n    29→\n    30→# Close the task if task_id is set\n    31→if [ -n \"$CLOCHE_TASK_ID\" ]; then\n    32→  bd close \"$CLOCHE_TASK_ID\" 2>/dev/null && echo \"Closed task $CLOCHE_TASK_ID\" || echo \"warning: could not close task $CLOCHE_TASK_ID\" >&2\n    33→fi\n    34→\n    35→echo \"Cleaned up run ${RUN_ID:-unknown}\"\n    36→"}]},"parent_tool_use_id":"toolu_017KD4BC6dAAhyYJNcBhcasQ","session_id":"38a7cbbe-0157-40c7-bcaa-fa1bfb56d343","uuid":"a5a65846-f23b-4d47-b08b-8ea5686d9ee9"}
