ype\":\"task\",\"owner\":\"lucas@perfectlunacy.com\",\"estimated_minutes\":5,\"created_at\":\"2026-03-01T14:52:49.013542724-08:00\",\"created_by\":\"lucas\",\"updated_at\":\"2026-03-01T17:20:53.810393049-08:00\",\"closed_at\":\"2026-03-01T17:20:53.810397037-08:00\",\"dependencies\":[{\"issue_id\":\"cloche-rxi.13\",\"depends_on_id\":\"cloche-rxi\",\"type\":\"parent-child\",\"created_at\":\"2026-03-01T14:52:49.014730638-08:00\",\"created_by\":\"lucas\"},{\"issue_id\":\"cloche-rxi.13\",\"depends_on_id\":\"cloche-rxi.11\",\"type\":\"blocks\",\"created_at\":\"2026-03-01T14:52:49.016492025-08:00\",\"created_by\":\"lucas\"},{\"issue_id\":\"cloche-rxi.13\",\"depends_on_id\":\"cloche-rxi.12\",\"type\":\"blocks\",\"created_at\":\"2026-03-01T14:52:49.018193318-08:00\",\"created_by\":\"lucas\"}]}\n {\"id\":\"cloche-rxi.2\",\"title\":\"Remove git daemon from Docker adapter\",\"description\":\"Remove gitDaemons map from Runtime struct. Remove git daemon start/retry loop from Start(). Remove cleanup(), FindFreePort(), gitRepoRoot(). Remove cleanup calls from Stop() and Wait(). Remove CLOCHE_GIT_REMOTE env var from container args. Remove unused imports (net, sync, syscall, strconv).\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"owner\":\"lucas@perfectlunacy.com\",\"estimated_minutes\":15,\"created_at\":\"2026-03-01T14:51:49.104722399-08:00\",\"created_by\":\"lucas\",\"updated_at\":\"2026-03-01T16:45:37.579202959-08:00\",\"closed_at\":\"2026-03-01T16:45:37.579205584-08:00\",\"dependencies\":[{\"issue_id\":\"cloche-rxi.2\",\"depends_on_id\":\"cloche-rxi\",\"type\":\"parent-child\",\"created_at\":\"2026-03-01T14:51:49.105926232-08:00\",\"created_by\":\"lucas\"},{\"issue_id\":\"cloche-rxi.2\",\"depends_on_id\":\"cloche-rxi.1\",\"type\":\"blocks\",\"created_at\":\"2026-03-01T14:51:49.107487551-08:00\",\"created_by\":\"lucas\"}]}\n {\"id\":\"cloche-rxi.3\",\"title\":\"Remove GitRemote from ContainerConfig and agent push logic\",\"description\":\"Remove GitRemote field from ports.ContainerConfig. Remove GitRemote from agent.RunnerConfig. Delete pushResults(), readUserPrompt(), generateCommitMsg() from agent/runner.go. Remove call to pushResults in Run(). Update cloche-agent main.go to stop reading/unsetting CLOCHE_GIT_REMOTE.\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"owner\":\"lucas@perfectlunacy.com\",\"estimated_minutes\":15,\"created_at\":\"2026-03-01T14:51:55.343306502-08:00\",\"created_by\":\"lucas\",\"updated_at\":\"2026-03-01T16:49:18.121097756-08:00\",\"closed_at\":\"2026-03-01T16:49:18.12110004-08:00\",\"dependencies\":[{\"issue_id\":\"cloche-rxi.3\",\"depends_on_id\":\"cloche-rxi\",\"type\":\"parent-child\",\"created_at\":\"2026-03-01T14:51:55.344371593-08:00\",\"created_by\":\"lucas\"},{\"issue_id\":\"cloche-rxi.3\",\"depends_on_id\":\"cloche-rxi.2\",\"type\":\"blocks\",\"created_at\":\"2026-03-01T14:51:55.346034895-08:00\",\"created_by\":\"lucas\"}]}\n {\"id\":\"cloche-rxi.4\",\"title\":\"Update Docker adapter to copy from ./cloche/ subdirectory\",\"description\":\"Change docker cp source in Start() from cfg.ProjectDir/. to cfg.ProjectDir/cloche/. so only the cloche subdirectory is copied into the container at /workspace/.\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"owner\":\"lucas@perfectlunacy.com\",\"estimated_minutes\":5,\"created_at\":\"2026-03-01T14:51:59.983983578-08:00\",\"created_by\":\"lucas\",\"updated_at\":\"2026-03-01T16:54:06.326457899-08:00\",\"closed_at\":\"2026-03-01T16:54:06.326460895-08:00\",\"dependencies\":[{\"issue_id\":\"cloche-rxi.4\",\"depends_on_id\":\"cloche-rxi\",\"type\":\"parent-child\",\"created_at\":\"2026-03-01T14:51:59.985402217-08:00\",\"created_by\":\"lucas\"},{\"issue_id\":\"cloche-rxi.4\",\"depends_on_id\":\"cloche-rxi.3\",\"type\":\"blocks\",\"created_at\":\"2026-03-01T14:51:59.986955481-08:00\",\"created_by\":\"lucas\"}]}\ndiff --git a/CLAUDE.md b/CLAUDE.md\nindex 7f5090c..5407285 100644\n--- a/CLAUDE.md\n+++ b/CLAUDE.md\n@@ -40,11 +40,27 @@ internal/\n Steps report named results; wiring maps results to next steps. `done` and `abort` are\n built-in terminals. See `docs/workflows.md` for syntax and semantics.\n \n+## Project Layout\n+\n+Cloche-specific files live in `.cloche/` at the project root:\n+\n+```\n+my-project/\n+├── .cloche/\n+│   ├── develop.cloche      # Workflow definition\n+│   ├── Dockerfile           # Container image\n+│   ├── prompts/             # Prompt templates for agent steps\n+│   ├── overrides/           # Files copied on top of /workspace/ in container\n+│   └── <run-id>/            # Runtime state (gitignored)\n+├── src/                     # Existing project source (untouched)\n+└── CLAUDE.md\n+```\n+\n ## Container Model\n \n-One container per workflow run (not per step). Files are copied in; git push extracts\n-results to host on agent-specific branches. Network is allowlisted. Env vars are the\n-image's responsibility.\n+One container per workflow run (not per step). The entire project root is copied into the\n+container at `/workspace/`, then override files from `.cloche/overrides/` are applied on\n+top. Results are extracted to git branches. Network is allowlisted.\n \n ## Agent Support\n \ndiff --git a/cmd/cloche/init.go b/cmd/cloche/init.go\nindex 4489b64..bbfe077 100644\n--- a/cmd/cloche/init.go\n+++ b/cmd/cloche/init.go\n@@ -88,7 +88,7 @@ func cmdInit(args []string) {\n \t\t}\n \t}\n \n-\tclocheDir := \"cloche\"\n+\tclocheDir := \".cloche\"\n \tworkflowFile := filepath.Join(clocheDir, workflow+\".cloche\")\n \n \t// Refuse to overwrite existing workflow\n@@ -98,21 +98,23 @@ func cmdInit(args []string) {\n \t}\n \n \t// Create directories\n-\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n-\t\tfmt.Fprintf(os.Stderr, \"error creating %s/: %v\\n\", clocheDir, err)\n-\t\tos.Exit(1)\n-\t}\n-\tif err := os.MkdirAll(filepath.Join(clocheDir, \".cloche\", \"prompts\"), 0755); err != nil {\n-\t\tfmt.Fprintf(os.Stderr, \"error creating %s: %v\\n\", filepath.Join(clocheDir, \".cloche\", \"prompts\"), err)\n-\t\tos.Exit(1)\n+\tfor _, dir := range []string{\n+\t\tclocheDir,\n+\t\tfilepath.Join(clocheDir, \"prompts\"),\n+\t\tfilepath.Join(clocheDir, \"overrides\"),\n+\t} {\n+\t\tif err := os.MkdirAll(dir, 0755); err != nil {\n+\t\t\tfmt.Fprintf(os.Stderr, \"error creating %s/: %v\\n\", dir, err)\n+\t\t\tos.Exit(1)\n+\t\t}\n \t}\n \n \t// Write all files, skipping any that already exist\n \tfiles := []struct{ path, content string }{\n \t\t{workflowFile, fmt.Sprintf(workflowTemplate, workflow)},\n \t\t{filepath.Join(clocheDir, \"Dockerfile\"), fmt.Sprintf(dockerfileTemplate, image)},\n-\t\t{filepath.Join(clocheDir, \".cloche\", \"prompts\", \"implement.md\"), implementPrompt},\n-\t\t{filepath.Join(clocheDir, \".cloche\", \"prompts\", \"fix.md\"), fixPrompt},\n+\t\t{filepath.Join(clocheDir, \"prompts\", \"implement.md\"), implementPrompt},\n+\t\t{filepath.Join(clocheDir, \"prompts\", \"fix.md\"), fixPrompt},\n \t}\n \n \tfor _, f := range files {\n@@ -127,15 +129,22 @@ func cmdInit(args []string) {\n \t\tfmt.Fprintf(os.Stderr, \"  create %s\\n\", f.path)\n \t}\n \n-\taddGitignoreEntries([]string{\"cloche/.cloche/*/\", \".gitworktrees/\"})\n+\taddGitignoreEntries([]string{\n+\t\t\".cloche/*/\",\n+\t\t\"!.cloche/prompts/\",\n+\t\t\"!.cloche/overrides/\",\n+\t\t\"!.cloche/evolution/\",\n+\t\t\".gitworktrees/\",\n+\t})\n \n \tcwd, _ := os.Getwd()\n \tfmt.Fprintf(os.Stderr, \"\\nInitialized Cloche project in %s\\n\", filepath.Base(cwd))\n \tfmt.Fprintf(os.Stderr, \"\\nNext steps:\\n\")\n \tfmt.Fprintf(os.Stderr, \"  1. Edit %s — change the test command for your project\\n\", workflowFile)\n \tfmt.Fprintf(os.Stderr, \"  2. Edit %s — add your project's dependencies\\n\", filepath.Join(clocheDir, \"Dockerfile\"))\n-\tfmt.Fprintf(os.Stderr, \"  3. docker build -t cloche-agent -f %s .\\n\", filepath.Join(clocheDir, \"Dockerfile\"))\n-\tfmt.Fprintf(os.Stderr, \"  4. cloche run --workflow %s --prompt \\\"...\\\"\\n\", workflow)\n+\tfmt.Fprintf(os.Stderr, \"  3. Add container-specific overrides to %s/ (e.g. CLAUDE.md)\\n\", filepath.Join(clocheDir, \"overrides\"))\n+\tfmt.Fprintf(os.Stderr, \"  4. docker build -t cloche-agent -f %s .\\n\", filepath.Join(clocheDir, \"Dockerfile\"))\n+\tfmt.Fprintf(os.Stderr, \"  5. cloche run --workflow %s --prompt \\\"...\\\"\\n\", workflow)\n }\n \n func addGitignoreEntries(entries []string) {\ndiff --git a/cmd/cloche/init_test.go b/cmd/cloche/init_test.go\nindex 02e2584..eb76b89 100644\n--- a/cmd/cloche/init_test.go","is_error":false}]},"parent_tool_use_id":"toolu_01PB2FoeV4tsuHgPF56K4Qdh","session_id":"87510e8f-028e-4687-9903-d33073502bb8","uuid":"ca0f977a-f281-492b-8e19-f1d828607c7a"}
