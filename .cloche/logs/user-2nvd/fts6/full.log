[2026-03-13T14:43:44Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JJVUmj17QrpvgZYS69PGAn","type":"tool_result","content":"     1→package dsl_test\n     2→\n     3→import (\n     4→\t\"testing\"\n     5→\n     6→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     7→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n     8→\t\"github.com/stretchr/testify/assert\"\n     9→\t\"github.com/stretchr/testify/require\"\n    10→)\n    11→\n    12→func TestParser_FullWorkflow(t *testing.T) {\n    13→\tinput := `workflow \"implement-feature\" {\n    14→  step code {\n    15→    prompt = file(\"prompts/implement.md\")\n    16→    results = [success, fail, retry_with_feedback]\n    17→  }\n    18→\n    19→  step check {\n    20→    run = \"make test && make lint\"\n    21→    results = [pass, fail]\n    22→  }\n    23→\n    24→  code:success -> check\n    25→  code:fail -> abort\n    26→  code:retry_with_feedback -> code\n    27→\n    28→  check:pass -> done\n    29→  check:fail -> code\n    30→}`\n    31→\n    32→\twf, err := dsl.Parse(input)\n    33→\trequire.NoError(t, err)\n    34→\n    35→\tassert.Equal(t, \"implement-feature\", wf.Name)\n    36→\tassert.Len(t, wf.Steps, 2)\n    37→\n    38→\tcode := wf.Steps[\"code\"]\n    39→\trequire.NotNil(t, code)\n    40→\tassert.Equal(t, domain.StepTypeAgent, code.Type)\n    41→\tassert.Equal(t, []string{\"success\", \"fail\", \"retry_with_feedback\"}, code.Results)\n    42→\tassert.Equal(t, `file(\"prompts/implement.md\")`, code.Config[\"prompt\"])\n    43→\n    44→\tcheck := wf.Steps[\"check\"]\n    45→\trequire.NotNil(t, check)\n    46→\tassert.Equal(t, domain.StepTypeScript, check.Type)\n    47→\tassert.Equal(t, \"make test && make lint\", check.Config[\"run\"])\n    48→\n    49→\tassert.Len(t, wf.Wiring, 5)\n    50→\tassert.Equal(t, \"code\", wf.EntryStep)\n    51→}\n    52→\n    53→func TestParser_MinimalWorkflow(t *testing.T) {\n    54→\tinput := `workflow \"simple\" {\n    55→  step build {\n    56→    run = \"make build\"\n    57→    results = [success, fail]\n    58→  }\n    59→\n    60→  build:success -> done\n    61→  build:fail -> abort\n    62→}`\n    63→\n    64→\twf, err := dsl.Parse(input)\n    65→\trequire.NoError(t, err)\n    66→\tassert.Equal(t, \"simple\", wf.Name)\n    67→\tassert.Equal(t, \"build\", wf.EntryStep)\n    68→}\n    69→\n    70→func TestParser_SyntaxError(t *testing.T) {\n    71→\tinput := `workflow { }`\n    72→\t_, err := dsl.Parse(input)\n    73→\tassert.Error(t, err)\n    74→}\n    75→\n    76→func TestParser_ContainerBlock(t *testing.T) {\n    77→\tinput := `workflow \"test\" {\n    78→  step code {\n    79→    prompt = \"do something\"\n    80→    container {\n    81→      image = \"cloche/agent:latest\"\n    82→      network_allow = [\"docs.python.org\", \"internal.example.com\"]\n    83→    }\n    84→    results = [success]\n    85→  }\n    86→  code:success -> done\n    87→}`\n    88→\n    89→\twf, err := dsl.Parse(input)\n    90→\trequire.NoError(t, err)\n    91→\n    92→\tcode := wf.Steps[\"code\"]\n    93→\tassert.Equal(t, \"cloche/agent:latest\", code.Config[\"container.image\"])\n    94→\tassert.Equal(t, \"docs.python.org,internal.example.com\", code.Config[\"container.network_allow\"])\n    95→}\n    96→\n    97→func TestParser_WorkflowContainerBlock(t *testing.T) {\n    98→\tinput := `workflow \"with-image\" {\n    99→  container {\n   100→    image = \"myregistry/myimage:v2\""}]},"parent_tool_use_id":"toolu_01PB2FoeV4tsuHgPF56K4Qdh","session_id":"87510e8f-028e-4687-9903-d33073502bb8","uuid":"85eaf245-477b-48a3-9ac0-2b6427ae5ae3"}
