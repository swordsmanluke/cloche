[2026-03-13T14:43:44Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NoEd7jmN7YvJkg9gcwFn99","type":"tool_result","content":"     1→\"\"\"Score the current working tree diff with speedometer.\n     2→\n     3→Requires SPEEDOMETER_HOME to point at the speedometer checkout\n     4→(defaults to ~/projects/speedometer). Needs pyyaml installed.\n     5→\n     6→Exit protocol: prints CLOCHE_RESULT:success or CLOCHE_RESULT:fail.\n     7→\"\"\"\n     8→\n     9→import os\n    10→import subprocess\n    11→import sys\n    12→\n    13→THRESHOLD = 0.6  # composite score >= this triggers failure\n    14→\n    15→speedometer_home = os.environ.get(\n    16→    \"SPEEDOMETER_HOME\",\n    17→    os.path.expanduser(\"~/projects/speedometer\"),\n    18→)\n    19→sys.path.insert(0, speedometer_home)\n    20→\n    21→from aggregator import score_pr  # noqa: E402\n    22→from metrics.diff_utils import filter_diff  # noqa: E402\n    23→\n    24→\n    25→def main():\n    26→    diff_result = subprocess.run(\n    27→        [\"git\", \"diff\", \"HEAD\"],\n    28→        capture_output=True,\n    29→        text=True,\n    30→    )\n    31→    raw_diff = diff_result.stdout\n    32→\n    33→    if not raw_diff.strip():\n    34→        print(\"No changes to score.\")\n    35→        print(\"CLOCHE_RESULT:success\")\n    36→        return\n    37→\n    38→    diff = filter_diff(raw_diff)\n    39→    if not diff.strip():\n    40→        print(\"All changed files filtered out (generated/vendored). Skipping.\")\n    41→        print(\"CLOCHE_RESULT:success\")\n    42→        return\n    43→\n    44→    added = sum(1 for line in raw_diff.splitlines() if line.startswith(\"+\") and not line.startswith(\"+++\"))\n    45→    removed = sum(1 for line in raw_diff.splitlines() if line.startswith(\"-\") and not line.startswith(\"---\"))\n    46→\n    47→    meta = {\n    48→        \"title\": \"workflow changes\",\n    49→        \"additions\": added,\n    50→        \"deletions\": removed,\n    51→    }\n    52→\n    53→    config_path = os.path.join(speedometer_home, \"config\", \"metrics.yaml\")\n    54→    scores = score_pr(diff, meta, config_path=config_path)\n    55→    composite = scores[\"composite_score\"]\n    56→\n    57→    print(f\"Speedometer composite score: {composite:.3f}\")\n    58→    print(f\"Metrics evaluated: {scores['metrics_run']}\")\n    59→    print()\n    60→\n    61→    ranked = sorted(\n    62→        scores[\"metric_results\"].items(),\n    63→        key=lambda x: x[1][\"score\"] * x[1][\"confidence\"],\n    64→        reverse=True,\n    65→    )\n    66→    for name, v in ranked[:5]:\n    67→        if v[\"score\"] > 0.05:\n    68→            print(f\"  {name}: score={v['score']:.2f} confidence={v['confidence']:.2f}\")\n    69→\n    70→    print()\n    71→    if composite >= THRESHOLD:\n    72→        print(f\"FAIL: composite score {composite:.3f} exceeds threshold {THRESHOLD}\")\n    73→        print(\"CLOCHE_RESULT:fail\")\n    74→    else:\n    75→        print(f\"PASS: composite score {composite:.3f} within threshold {THRESHOLD}\")\n    76→        print(\"CLOCHE_RESULT:success\")\n    77→\n    78→\n    79→if __name__ == \"__main__\":\n    80→    main()\n    81→"}]},"parent_tool_use_id":"toolu_01EAKuUouRmJ3a4iBQWLZ1wd","session_id":"87510e8f-028e-4687-9903-d33073502bb8","uuid":"c1f72270-3e8b-4b06-91e1-f8a4660d0374"}
