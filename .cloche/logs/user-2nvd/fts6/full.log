[2026-03-13T14:39:21Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XSSVSddBD76Zm4vhNwJeB5","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# Returns ready, unclaimed tasks from bd as a JSON array.\n     3→# Usage: ready-tasks.sh [max]\n     4→#   max  — maximum number of IDs to return (default: all)\n     5→set -euo pipefail\n     6→\n     7→max=\"${1:-0}\"\n     8→\n     9→limit_args=()\n    10→if [ \"$max\" -gt 0 ] 2>/dev/null; then\n    11→  limit_args=(--limit \"$max\")\n    12→fi\n    13→\n    14→# Filter to open status only — excludes in_progress (already claimed) tasks.\n    15→json=$(bd list -s open --json \"${limit_args[@]}\" 2>/dev/null) || json=\"[]\"\n    16→\n    17→# Empty array means no work — exit non-zero so the workflow takes the fail path.\n    18→if [ \"$json\" = \"[]\" ] || [ -z \"$json\" ]; then\n    19→  echo \"[]\"\n    20→  exit 1\n    21→fi\n    22→\n    23→# Store first task's data in run context for downstream steps.\n    24→task_id=$(echo \"$json\" | jq -r '.[0].id')\n    25→task_title=$(echo \"$json\" | jq -r '.[0].title')\n    26→task_body=$(echo \"$json\" | jq -r '.[0].description')\n    27→\n    28→cloche set task_id \"$task_id\"\n    29→cloche set task_title \"$task_title\"\n    30→cloche set task_body - <<EOF\n    31→$task_body\n    32→EOF\n    33→\n    34→echo \"$json\"\n    35→"}]},"parent_tool_use_id":"toolu_017KD4BC6dAAhyYJNcBhcasQ","session_id":"38a7cbbe-0157-40c7-bcaa-fa1bfb56d343","uuid":"09d4fe38-5927-4311-8b29-1720cb9e7a36"}
