[2026-03-13T14:39:21Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017h2BSF64yeBVBoyBejYsTo","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# Default prompt generator.\n     3→# Writes the task prompt to stdout and to $CLOCHE_STEP_OUTPUT.\n     4→# Reads task data from run context (set by ready-tasks.sh via cloche set).\n     5→set -euo pipefail\n     6→\n     7→task_title=$(cloche get task_title)\n     8→task_body=$(cloche get task_body)\n     9→\n    10→if [ -z \"$task_title\" ]; then\n    11→  echo \"error: task_title not found in run context\" >&2\n    12→  exit 1\n    13→fi\n    14→\n    15→prompt=\"## Task: ${task_title}\n    16→\n    17→${task_body}\"\n    18→\n    19→echo \"$prompt\"\n    20→[ -n \"${CLOCHE_STEP_OUTPUT:-}\" ] && echo \"$prompt\" > \"$CLOCHE_STEP_OUTPUT\"\n    21→"}]},"parent_tool_use_id":"toolu_017KD4BC6dAAhyYJNcBhcasQ","session_id":"38a7cbbe-0157-40c7-bcaa-fa1bfb56d343","uuid":"d61e44ed-40ea-4adc-8228-3e3e813d66da"}
