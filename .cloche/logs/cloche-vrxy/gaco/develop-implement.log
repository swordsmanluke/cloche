{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E4ptsUgdqLWTVP2A4XM6DN","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"strings\"\n    11→\t\"time\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    17→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    19→\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    20→)\n    21→\n    22→// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    23→// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    24→// strings suitable for adding to a command's environment.\n    25→func (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    26→\tvar env []string\n    27→\tfor _, w := range wires {\n    28→\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    29→\t\t\tcontinue\n    30→\t\t}\n    31→\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    32→\t\tif err != nil {\n    33→\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    34→\t\t}\n    35→\t\tfor _, m := range w.OutputMap {\n    36→\t\t\tval, err := m.Path.Evaluate(data)\n    37→\t\t\tif err != nil {\n    38→\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    39→\t\t\t}\n    40→\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    41→\t\t}\n    42→\t}\n    43→\treturn env, nil\n    44→}\n    45→\n    46→// RunDispatcher dispatches a container workflow run and returns the run ID.\n    47→type RunDispatcher interface {\n    48→\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    49→}\n    50→\n    51→// Executor implements engine.StepExecutor for host workflow steps.\n    52→type Executor struct {\n    53→\tProjectDir    string\n    54→\tMainDir       string         // main branch worktree dir; scripts execute from here\n    55→\tDispatcher    RunDispatcher\n    56→\tStore         ports.RunStore\n    57→\tOutputDir     string         // directory for step output files\n    58→\tWires         []domain.Wire  // workflow wiring (for output mappings)\n    59→\tHostRunID     string         // ID of the parent host run (set on child runs)\n    60→\tAgentCommands []string       // workflow-level agent command fallback chain\n    61→\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n    62→\tTaskID        string         // optional task ID assigned by the daemon loop\n    63→\tExtraEnv      []string       // additional KEY=VALUE env vars for all steps\n    64→\tResumeStep    string         // step being resumed (for prompt conversation resume)\n    65→}\n    66→\n    67→// scriptDir returns the directory from which scripts should execute.\n    68→// Uses MainDir if set, otherwise falls back to ProjectDir.\n    69→func (e *Executor) scriptDir() string {\n    70→\tif e.MainDir != \"\" {\n    71→\t\treturn e.MainDir\n    72→\t}\n    73→\treturn e.ProjectDir\n    74→}\n    75→\n    76→var _ engine.StepExecutor = (*Executor)(nil)\n    77→\n    78→// Execute runs a single host workflow step.\n    79→func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    80→\tswitch step.Type {\n    81→\tcase domain.StepTypeScript:\n    82→\t\treturn e.executeScript(ctx, step)\n    83→\tcase domain.StepTypeWorkflow:\n    84→\t\treturn e.executeWorkflow(ctx, step)\n    85→\tcase domain.StepTypeAgent:\n    86→\t\treturn e.executeAgent(ctx, step)\n    87→\tdefault:\n    88→\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    89→\t}\n    90→}\n    91→\n    92→// executeScript runs a shell command on the host.\n    93→func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    94→\tcmdStr := step.Config[\"run\"]\n    95→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    96→\tcmd.Dir = e.scriptDir()\n    97→\tcmd.Env = append(os.Environ(),\n    98→\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    99→\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n   100→\t)\n   101→\n   102→\t// Pass run ID so steps can access .cloche/<run-id>/ and context.json\n   103→\tif e.HostRunID != \"\" {\n   104→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_RUN_ID=\"+e.HostRunID)\n   105→\t}\n   106→\n   107→\t// Pass daemon-assigned task ID if available\n   108→\tif e.TaskID != \"\" {\n   109→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_TASK_ID=\"+e.TaskID)\n   110→\t}\n   111→\n   112→\t// Pass extra env vars (e.g. finalize phase outcome vars)\n   113→\tif len(e.ExtraEnv) > 0 {\n   114→\t\tcmd.Env = append(cmd.Env, e.ExtraEnv...)\n   115→\t}\n   116→\n   117→\t// Pass previous step output if available\n   118→\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n   119→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n   120→\t}\n   121→\n   122→\t// Resolve output mappings from wires and add as env vars\n   123→\tif len(e.Wires) > 0 {\n   124→\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n   125→\t\tif err != nil {\n   126→\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n   127→\t\t}\n   128→\t\tcmd.Env = append(cmd.Env, mapped...)\n   129→\t}\n   130→\n   131→\toutput, err := cmd.CombinedOutput()\n   132→\n   133→\t// Extract result marker\n   134→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n   135→\n   136→\t// Write output to file\n   137→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   138→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   139→\t}\n   140→\n   141→\tif err != nil {\n   142→\t\tif _, ok := err.(*exec.ExitError); ok {\n   143→\t\t\tresult := \"fail\"\n   144→\t\t\tif found {\n   145→\t\t\t\tresult = markerResult\n   146→\t\t\t}\n   147→\t\t\treturn result, nil\n   148→\t\t}\n   149→\t\treturn \"\", err\n   150→\t}\n   151→\n   152→\tresult := \"success\"\n   153→\tif found {\n   154→\t\tresult = markerResult\n   155→\t}\n   156→\treturn result, nil\n   157→}\n   158→\n   159→// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   160→func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   161→\tworkflowName := step.Config[\"workflow_name\"]\n   162→\tif workflowName == \"\" {\n   163→\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   164→\t}\n   165→\n   166→\t// Read prompt from previous step output or prompt_step override\n   167→\tvar promptContent string\n   168→\tpromptSource := step.Config[\"prompt_step\"]\n   169→\tif promptSource != \"\" {\n   170→\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   171→\t\tif err == nil {\n   172→\t\t\tpromptContent = string(data)\n   173→\t\t}\n   174→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   175→\t\tdata, err := os.ReadFile(prev)\n   176→\t\tif err == nil {\n   177→\t\t\tpromptContent = string(data)\n   178→\t\t}\n   179→\t}\n   180→\n   181→\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   182→\t\tWorkflowName: workflowName,\n   183→\t\tProjectDir:   e.ProjectDir,\n   184→\t\tPrompt:       promptContent,\n   185→\t})\n   186→\tif err != nil {\n   187→\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   188→\t}\n   189→\n   190→\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   191→\n   192→\t// Link child run to parent host run and store in run context\n   193→\tif e.HostRunID != \"\" {\n   194→\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n   195→\t\t\tchildRun.ParentRunID = e.HostRunID\n   196→\t\t\tchildRun.TaskID = e.TaskID\n   197→\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n   198→\t\t}\n   199→\t\t// Store child run ID in context so downstream steps can retrieve it\n   200→\t\t// via \"cloche get child_run_id\"\n   201→\t\t_ = runcontext.Set(e.ProjectDir, e.HostRunID, \"child_run_id\", resp.RunId)\n   202→\t}\n   203→\n   204→\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n   205→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   206→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n   207→\t}\n   208→\n   209→\t// Poll until the run reaches a terminal state\n   210→\tstate, err := e.waitForRun(ctx, resp.RunId)\n   211→\tif err != nil {\n   212→\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   213→\t}\n   214→\n   215→\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   216→\n   217→\t// Map run state to step result\n   218→\tif state == domain.RunStateSucceeded {\n   219→\t\treturn \"success\", nil\n   220→\t}\n   221→\treturn \"fail\", nil\n   222→}\n   223→\n   224→// executeAgent runs an agent command on the host using the prompt adapter.\n   225→func (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n   226→\tadapter := prompt.New()\n   227→\n   228→\t// Apply workflow-level agent config\n   229→\tif len(e.AgentCommands) > 0 {\n   230→\t\tadapter.Commands = e.AgentCommands\n   231→\t}\n   232→\tif len(e.AgentArgs) > 0 {\n   233→\t\tadapter.ExplicitArgs = e.AgentArgs\n   234→\t}\n   235→\n   236→\t// Step-level overrides\n   237→\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   238→\t\tadapter.Commands = prompt.ParseCommands(cmd)\n   239→\t}\n   240→\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   241→\t\tadapter.ExplicitArgs = strings.Fields(args)\n   242→\t}\n   243→\n   244→\tadapter.RunID = e.HostRunID\n   245→\n   246→\t// Resume mode: if this is the step being resumed, use conversation resume\n   247→\tif e.ResumeStep == step.Name {\n   248→\t\tadapter.ResumeConversation = true\n   249→\t}\n   250→\n   251→\t// Write previous step output as user prompt so the adapter can pick it up.\n   252→\tvar promptContent string\n   253→\tpromptSource := step.Config[\"prompt_step\"]\n   254→\tif promptSource != \"\" {\n   255→\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n   256→\t\t\tpromptContent = string(data)\n   257→\t\t}\n   258→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   259→\t\tif data, err := os.ReadFile(prev); err == nil {\n   260→\t\t\tpromptContent = string(data)\n   261→\t\t}\n   262→\t}\n   263→\n   264→\tif promptContent != \"\" {\n   265→\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n   266→\t\t_ = os.MkdirAll(promptDir, 0755)\n   267→\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n   268→\t}\n   269→\n   270→\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n   271→\tif err != nil {\n   272→\t\treturn \"\", err\n   273→\t}\n   274→\n   275→\t// Copy output from adapter's output location to executor's output path\n   276→\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n   277→\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n   278→\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   279→\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n   280→\t\t}\n   281→\t}\n   282→\n   283→\treturn result, nil\n   284→}\n   285→\n   286→// waitForRun polls the store until the run reaches a terminal state.\n   287→func (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   288→\tticker := time.NewTicker(2 * time.Second)\n   289→\tdefer ticker.Stop()\n   290→\n   291→\tfor {\n   292→\t\tselect {\n   293→\t\tcase <-ctx.Done():\n   294→\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   295→\t\tcase <-ticker.C:\n   296→\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   297→\t\t\tif err != nil {\n   298→\t\t\t\tcontinue // transient error, retry\n   299→\t\t\t}\n   300→\t\t\tswitch run.State {\n   301→\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   302→\t\t\t\treturn run.State, nil\n   303→\t\t\t}\n   304→\t\t\t// Still pending or running, continue polling\n   305→\t\t}\n   306→\t}\n   307→}\n   308→\n   309→// stepOutputPath returns the path for a step's output file.\n   310→func (e *Executor) stepOutputPath(stepName string) string {\n   311→\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   312→}\n   313→\n   314→// findPrevOutput finds the output file from the step that wires into this one.\n   315→// It checks prompt_step config first, then walks the wiring graph to find the\n   316→// source step.\n   317→func (e *Executor) findPrevOutput(step *domain.Step) string {\n   318→\t// Explicit prompt_step config takes priority\n   319→\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   320→\t\tpath := e.stepOutputPath(ps)\n   321→\t\tif _, err := os.Stat(path); err == nil {\n   322→\t\t\treturn path\n   323→\t\t}\n   324→\t}\n   325→\n   326→\t// Walk wiring to find the step that feeds into this one\n   327→\tfor _, w := range e.Wires {\n   328→\t\tif w.To == step.Name {\n   329→\t\t\tpath := e.stepOutputPath(w.From)\n   330→\t\t\tif _, err := os.Stat(path); err == nil {\n   331→\t\t\t\treturn path\n   332→\t\t\t}\n   333→\t\t}\n   334→\t}\n   335→\treturn \"\"\n   336→}\n   337→\n   338→// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n   339→// the repository containing projectDir. If projectDir is already the main\n   340→// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n   341→// error (e.g. not a git repo).\n   342→func MainWorktreeDir(projectDir string) string {\n   343→\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n   344→\tout, err := cmd.Output()\n   345→\tif err != nil {\n   346→\t\treturn projectDir\n   347→\t}\n   348→\t// The first \"worktree <path>\" line is always the main worktree.\n   349→\tfor _, line := range strings.Split(string(out), \"\\n\") {\n   350→\t\tif strings.HasPrefix(line, \"worktree \") {\n   351→\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n   352→\t\t}\n   353→\t}\n   354→\treturn projectDir\n   355→}\n   356→"}]},"parent_tool_use_id":null,"session_id":"ab06b6b4-e6b6-4d23-a886-0560ffd72710","uuid":"79e4dce2-d3ed-4d76-96a0-6c1cac58b0a3","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n)\n\n// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n// reads the source step's output, evaluates each mapping path, and returns KEY=value\n// strings suitable for adding to a command's environment.\nfunc (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n\tvar env []string\n\tfor _, w := range wires {\n\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n\t\t}\n\t\tfor _, m := range w.OutputMap {\n\t\t\tval, err := m.Path.Evaluate(data)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n\t\t\t}\n\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n\t\t}\n\t}\n\treturn env, nil\n}\n\n// RunDispatcher dispatches a container workflow run and returns the run ID.\ntype RunDispatcher interface {\n\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n}\n\n// Executor implements engine.StepExecutor for host workflow steps.\ntype Executor struct {\n\tProjectDir    string\n\tMainDir       string         // main branch worktree dir; scripts execute from here\n\tDispatcher    RunDispatcher\n\tStore         ports.RunStore\n\tOutputDir     string         // directory for step output files\n\tWires         []domain.Wire  // workflow wiring (for output mappings)\n\tHostRunID     string         // ID of the parent host run (set on child runs)\n\tAgentCommands []string       // workflow-level agent command fallback chain\n\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n\tTaskID        string         // optional task ID assigned by the daemon loop\n\tExtraEnv      []string       // additional KEY=VALUE env vars for all steps\n\tResumeStep    string         // step being resumed (for prompt conversation resume)\n}\n\n// scriptDir returns the directory from which scripts should execute.\n// Uses MainDir if set, otherwise falls back to ProjectDir.\nfunc (e *Executor) scriptDir() string {\n\tif e.MainDir != \"\" {\n\t\treturn e.MainDir\n\t}\n\treturn e.ProjectDir\n}\n\nvar _ engine.StepExecutor = (*Executor)(nil)\n\n// Execute runs a single host workflow step.\nfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\treturn e.executeScript(ctx, step)\n\tcase domain.StepTypeWorkflow:\n\t\treturn e.executeWorkflow(ctx, step)\n\tcase domain.StepTypeAgent:\n\t\treturn e.executeAgent(ctx, step)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n\t}\n}\n\n// executeScript runs a shell command on the host.\nfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n\tcmdStr := step.Config[\"run\"]\n\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n\tcmd.Dir = e.scriptDir()\n\tcmd.Env = append(os.Environ(),\n\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n\t)\n\n\t// Pass run ID so steps can access .cloche/<run-id>/ and context.json\n\tif e.HostRunID != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_RUN_ID=\"+e.HostRunID)\n\t}\n\n\t// Pass daemon-assigned task ID if available\n\tif e.TaskID != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_TASK_ID=\"+e.TaskID)\n\t}\n\n\t// Pass extra env vars (e.g. finalize phase outcome vars)\n\tif len(e.ExtraEnv) > 0 {\n\t\tcmd.Env = append(cmd.Env, e.ExtraEnv...)\n\t}\n\n\t// Pass previous step output if available\n\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n\t}\n\n\t// Resolve output mappings from wires and add as env vars\n\tif len(e.Wires) > 0 {\n\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n\t\t}\n\t\tcmd.Env = append(cmd.Env, mapped...)\n\t}\n\n\toutput, err := cmd.CombinedOutput()\n\n\t// Extract result marker\n\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n\n\t// Write output to file\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n\t}\n\n\tif err != nil {\n\t\tif _, ok := err.(*exec.ExitError); ok {\n\t\t\tresult := \"fail\"\n\t\t\tif found {\n\t\t\t\tresult = markerResult\n\t\t\t}\n\t\t\treturn result, nil\n\t\t}\n\t\treturn \"\", err\n\t}\n\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, nil\n}\n\n// executeWorkflow dispatches a container workflow run and blocks until it completes.\nfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n\tworkflowName := step.Config[\"workflow_name\"]\n\tif workflowName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n\t}\n\n\t// Read prompt from previous step output or prompt_step override\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tdata, err := os.ReadFile(prev)\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName: workflowName,\n\t\tProjectDir:   e.ProjectDir,\n\t\tPrompt:       promptContent,\n\t})\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n\t}\n\n\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n\n\t// Link child run to parent host run and store in run context\n\tif e.HostRunID != \"\" {\n\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n\t\t\tchildRun.ParentRunID = e.HostRunID\n\t\t\tchildRun.TaskID = e.TaskID\n\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n\t\t}\n\t\t// Store child run ID in context so downstream steps can retrieve it\n\t\t// via \"cloche get child_run_id\"\n\t\t_ = runcontext.Set(e.ProjectDir, e.HostRunID, \"child_run_id\", resp.RunId)\n\t}\n\n\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n\t}\n\n\t// Poll until the run reaches a terminal state\n\tstate, err := e.waitForRun(ctx, resp.RunId)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n\t}\n\n\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n\n\t// Map run state to step result\n\tif state == domain.RunStateSucceeded {\n\t\treturn \"success\", nil\n\t}\n\treturn \"fail\", nil\n}\n\n// executeAgent runs an agent command on the host using the prompt adapter.\nfunc (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n\tadapter := prompt.New()\n\n\t// Apply workflow-level agent config\n\tif len(e.AgentCommands) > 0 {\n\t\tadapter.Commands = e.AgentCommands\n\t}\n\tif len(e.AgentArgs) > 0 {\n\t\tadapter.ExplicitArgs = e.AgentArgs\n\t}\n\n\t// Step-level overrides\n\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n\t\tadapter.Commands = prompt.ParseCommands(cmd)\n\t}\n\tif args := step.Config[\"agent_args\"]; args != \"\" {\n\t\tadapter.ExplicitArgs = strings.Fields(args)\n\t}\n\n\tadapter.RunID = e.HostRunID\n\n\t// Resume mode: if this is the step being resumed, use conversation resume\n\tif e.ResumeStep == step.Name {\n\t\tadapter.ResumeConversation = true\n\t}\n\n\t// Write previous step output as user prompt so the adapter can pick it up.\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tif data, err := os.ReadFile(prev); err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tif promptContent != \"\" {\n\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n\t\t_ = os.MkdirAll(promptDir, 0755)\n\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n\t}\n\n\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\t// Copy output from adapter's output location to executor's output path\n\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\n// waitForRun polls the store until the run reaches a terminal state.\nfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n\tticker := time.NewTicker(2 * time.Second)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n\t\tcase <-ticker.C:\n\t\t\trun, err := e.Store.GetRun(ctx, runID)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // transient error, retry\n\t\t\t}\n\t\t\tswitch run.State {\n\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n\t\t\t\treturn run.State, nil\n\t\t\t}\n\t\t\t// Still pending or running, continue polling\n\t\t}\n\t}\n}\n\n// stepOutputPath returns the path for a step's output file.\nfunc (e *Executor) stepOutputPath(stepName string) string {\n\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n}\n\n// findPrevOutput finds the output file from the step that wires into this one.\n// It checks prompt_step config first, then walks the wiring graph to find the\n// source step.\nfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n\t// Explicit prompt_step config takes priority\n\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n\t\tpath := e.stepOutputPath(ps)\n\t\tif _, err := os.Stat(path); err == nil {\n\t\t\treturn path\n\t\t}\n\t}\n\n\t// Walk wiring to find the step that feeds into this one\n\tfor _, w := range e.Wires {\n\t\tif w.To == step.Name {\n\t\t\tpath := e.stepOutputPath(w.From)\n\t\t\tif _, err := os.Stat(path); err == nil {\n\t\t\t\treturn path\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n// the repository containing projectDir. If projectDir is already the main\n// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n// error (e.g. not a git repo).\nfunc MainWorktreeDir(projectDir string) string {\n\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn projectDir\n\t}\n\t// The first \"worktree <path>\" line is always the main worktree.\n\tfor _, line := range strings.Split(string(out), \"\\n\") {\n\t\tif strings.HasPrefix(line, \"worktree \") {\n\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n\t\t}\n\t}\n\treturn projectDir\n}\n","numLines":356,"startLine":1,"totalLines":356}}}
