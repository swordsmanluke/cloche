{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016P4rTDYRTF7VXtYiBbTR62","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→\t\"time\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    15→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    17→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18→)\n    19→\n    20→// Ensure hostStatusHandler implements engine.StatusHandler.\n    21→var _ engine.StatusHandler = (*hostStatusHandler)(nil)\n    22→\n    23→// Runner executes a host workflow by parsing host.cloche and walking the step graph.\n    24→type Runner struct {\n    25→\tDispatcher    RunDispatcher\n    26→\tStore         ports.RunStore\n    27→\tCaptures      ports.CaptureStore       // optional: saves step captures for cloche logs\n    28→\tLogBroadcast  *logstream.Broadcaster   // optional: publishes live log lines\n    29→\tTaskID        string                   // optional task ID assigned by the daemon loop\n    30→\tExtraEnv      []string                 // additional KEY=VALUE env vars passed to all steps\n    31→\tSkipRunRecord bool                     // when true, don't persist a run record to the store\n    32→}\n    33→\n    34→// RunResult contains the outcome of a host workflow execution.\n    35→type RunResult struct {\n    36→\tRunID     string\n    37→\tState     domain.RunState\n    38→\tOutputDir string // path to the step output directory\n    39→}\n    40→\n    41→// Run parses .cloche/host.cloche from projectDir and executes the \"main\" workflow.\n    42→func (r *Runner) Run(ctx context.Context, projectDir string) (*RunResult, error) {\n    43→\treturn r.RunWithID(ctx, projectDir, domain.GenerateRunID(\"main\"))\n    44→}\n    45→\n    46→// RunWithID is like Run but uses the provided run ID instead of generating one.\n    47→func (r *Runner) RunWithID(ctx context.Context, projectDir string, orchRunID string) (*RunResult, error) {\n    48→\treturn r.runNamedWorkflow(ctx, projectDir, \"main\", orchRunID)\n    49→}\n    50→\n    51→// RunNamed executes a named host workflow, generating a new run ID.\n    52→func (r *Runner) RunNamed(ctx context.Context, projectDir string, workflowName string) (*RunResult, error) {\n    53→\torchRunID := domain.GenerateRunID(workflowName)\n    54→\treturn r.runNamedWorkflow(ctx, projectDir, workflowName, orchRunID)\n    55→}\n    56→\n    57→// RunNamedWithID executes a named host workflow using the provided run ID.\n    58→func (r *Runner) RunNamedWithID(ctx context.Context, projectDir string, workflowName string, runID string) (*RunResult, error) {\n    59→\treturn r.runNamedWorkflow(ctx, projectDir, workflowName, runID)\n    60→}\n    61→\n    62→// runNamedWorkflow is the internal implementation that runs a specific named\n    63→// host workflow. Searches all .cloche files for the workflow.\n    64→func (r *Runner) runNamedWorkflow(ctx context.Context, projectDir string, workflowName string, orchRunID string) (*RunResult, error) {\n    65→\twf, err := findHostWorkflow(projectDir, workflowName)\n    66→\tif err != nil {\n    67→\t\treturn nil, err\n    68→\t}\n    69→\n    70→\t// Create output directory for step outputs\n    71→\toutputDir := filepath.Join(projectDir, \".cloche\", orchRunID, \"output\")\n    72→\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n    73→\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n    74→\t}\n    75→\n    76→\tlog.Printf(\"host workflow: starting %q for project %s (run %s)\", wf.Name, projectDir, orchRunID)\n    77→\n    78→\t// Persist the host run in the store so it appears in list/status/logs.\n    79→\t// When SkipRunRecord is set (e.g. for list-tasks polling), skip creating\n    80→\t// the record to avoid cluttering the run history.\n    81→\tif !r.SkipRunRecord {\n    82→\t\thostRun := domain.NewRun(orchRunID, wf.Name)\n    83→\t\thostRun.ProjectDir = projectDir\n    84→\t\thostRun.IsHost = true\n    85→\t\thostRun.TaskID = r.TaskID\n    86→\t\tif err := r.Store.CreateRun(ctx, hostRun); err != nil {\n    87→\t\t\treturn nil, fmt.Errorf(\"creating host run record: %w\", err)\n    88→\t\t}\n    89→\t\thostRun.Start()\n    90→\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n    91→\t}\n    92→\n    93→\texecutor := &Executor{\n    94→\t\tProjectDir: projectDir,\n    95→\t\tMainDir:    MainWorktreeDir(projectDir),\n    96→\t\tDispatcher: r.Dispatcher,\n    97→\t\tStore:      r.Store,\n    98→\t\tOutputDir:  outputDir,\n    99→\t\tWires:      wf.Wiring,\n   100→\t\tHostRunID:  orchRunID,\n   101→\t\tTaskID:     r.TaskID,\n   102→\t\tExtraEnv:   r.ExtraEnv,\n   103→\t}\n   104→\n   105→\t// Configure agent from workflow-level host config\n   106→\tif cmd := wf.Config[\"host.agent_command\"]; cmd != \"\" {\n   107→\t\texecutor.AgentCommands = prompt.ParseCommands(cmd)\n   108→\t}\n   109→\tif args := wf.Config[\"host.agent_args\"]; args != \"\" {\n   110→\t\texecutor.AgentArgs = strings.Fields(args)\n   111→\t}\n   112→\n   113→\t// Create a logstream.Writer so host runs persist logs to full.log,\n   114→\t// matching container-side behavior where the agent writes full.log.\n   115→\tvar ulog *logstream.Writer\n   116→\tif !r.SkipRunRecord {\n   117→\t\trunDir := filepath.Join(projectDir, \".cloche\", orchRunID)\n   118→\t\tw, err := logstream.New(runDir)\n   119→\t\tif err != nil {\n   120→\t\t\tlog.Printf(\"host workflow [%s]: failed to create log writer: %v\", orchRunID, err)\n   121→\t\t} else {\n   122→\t\t\tulog = w\n   123→\t\t}\n   124→\t}\n   125→\n   126→\teng := engine.New(executor)\n   127→\teng.SetStatusHandler(&hostStatusHandler{\n   128→\t\tprojectDir:   projectDir,\n   129→\t\torchRunID:    orchRunID,\n   130→\t\tstore:        r.Store,\n   131→\t\tcaptures:     r.Captures,\n   132→\t\tlogBroadcast: r.LogBroadcast,\n   133→\t\toutputDir:    outputDir,\n   134→\t\tlogWriter:    ulog,\n   135→\t})\n   136→\n   137→\trun, runErr := eng.Run(ctx, wf)\n   138→\n   139→\tif ulog != nil {\n   140→\t\tulog.Close()\n   141→\t}\n   142→\n   143→\tresult := &RunResult{\n   144→\t\tRunID:     orchRunID,\n   145→\t\tState:     domain.RunStateFailed,\n   146→\t\tOutputDir: outputDir,\n   147→\t}\n   148→\tif run != nil {\n   149→\t\tresult.State = run.State\n   150→\t}\n   151→\n   152→\t// Persist final state.\n   153→\tif !r.SkipRunRecord {\n   154→\t\thostRun, _ := r.Store.GetRun(ctx, orchRunID)\n   155→\t\tif hostRun != nil {\n   156→\t\t\tif runErr != nil {\n   157→\t\t\t\thostRun.Fail(runErr.Error())\n   158→\t\t\t} else {\n   159→\t\t\t\thostRun.Complete(result.State)\n   160→\t\t\t}\n   161→\t\t\thostRun.ActiveSteps = nil\n   162→\t\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n   163→\t\t}\n   164→\t}\n   165→\n   166→\tif runErr != nil {\n   167→\t\tlog.Printf(\"host workflow: %q failed for %s: %v\", wf.Name, projectDir, runErr)\n   168→\t\treturn result, runErr\n   169→\t}\n   170→\n   171→\tlog.Printf(\"host workflow: %q completed for %s with state %s\", wf.Name, projectDir, run.State)\n   172→\treturn result, nil\n   173→}\n   174→\n   175→// ResumeRun resumes a failed host workflow run from a specific step.\n   176→// Steps before resumeFrom are replayed from their stored results.\n   177→func (r *Runner) ResumeRun(ctx context.Context, run *domain.Run, resumeFrom string) (*RunResult, error) {\n   178→\twf, err := findHostWorkflow(run.ProjectDir, run.WorkflowName)\n   179→\tif err != nil {\n   180→\t\treturn nil, err\n   181→\t}\n   182→\n   183→\t// Validate the resume step exists\n   184→\tif _, ok := wf.Steps[resumeFrom]; !ok {\n   185→\t\treturn nil, fmt.Errorf(\"step %q not found in workflow %q\", resumeFrom, run.WorkflowName)\n   186→\t}\n   187→\n   188→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\")\n   189→\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n   190→\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n   191→\t}\n   192→\n   193→\tlog.Printf(\"host workflow: resuming %q from step %q for project %s (run %s)\", wf.Name, resumeFrom, run.ProjectDir, run.ID)\n   194→\n   195→\t// Reset run state\n   196→\trun.State = domain.RunStateRunning\n   197→\trun.ErrorMessage = \"\"\n   198→\trun.CompletedAt = time.Time{}\n   199→\trun.ActiveSteps = nil\n   200→\tif err := r.Store.UpdateRun(ctx, run); err != nil {\n   201→\t\treturn nil, fmt.Errorf(\"updating run state: %w\", err)\n   202→\t}\n   203→\n   204→\texecutor := &Executor{\n   205→\t\tProjectDir: run.ProjectDir,\n   206→\t\tMainDir:    MainWorktreeDir(run.ProjectDir),\n   207→\t\tDispatcher: r.Dispatcher,\n   208→\t\tStore:      r.Store,\n   209→\t\tOutputDir:  outputDir,\n   210→\t\tWires:      wf.Wiring,\n   211→\t\tHostRunID:  run.ID,\n   212→\t\tTaskID:     r.TaskID,\n   213→\t\tExtraEnv:   r.ExtraEnv,\n   214→\t}\n   215→\n   216→\t// Configure agent from workflow-level host config\n   217→\tif cmd := wf.Config[\"host.agent_command\"]; cmd != \"\" {\n   218→\t\texecutor.AgentCommands = prompt.ParseCommands(cmd)\n   219→\t}\n   220→\tif args := wf.Config[\"host.agent_args\"]; args != \"\" {\n   221→\t\texecutor.AgentArgs = strings.Fields(args)\n   222→\t}\n   223→\n   224→\t// Build preloaded results from previously completed steps\n   225→\tpreloaded := buildPreloadedResults(run, wf, resumeFrom)\n   226→\n   227→\t// Configure the executor to know which step is being resumed (for prompt resume)\n   228→\texecutor.ResumeStep = resumeFrom\n   229→\n   230→\tvar ulog *logstream.Writer\n   231→\trunDir := filepath.Join(run.ProjectDir, \".cloche\", run.ID)\n   232→\tw, err := logstream.New(runDir)\n   233→\tif err != nil {\n   234→\t\tlog.Printf(\"host workflow [%s]: failed to create log writer: %v\", run.ID, err)\n   235→\t} else {\n   236→\t\tulog = w\n   237→\t}\n   238→\n   239→\teng := engine.New(executor)\n   240→\teng.SetPreloadedResults(preloaded)\n   241→\teng.SetStatusHandler(&hostStatusHandler{\n   242→\t\tprojectDir:   run.ProjectDir,\n   243→\t\torchRunID:    run.ID,\n   244→\t\tstore:        r.Store,\n   245→\t\tcaptures:     r.Captures,\n   246→\t\tlogBroadcast: r.LogBroadcast,\n   247→\t\toutputDir:    outputDir,\n   248→\t\tlogWriter:    ulog,\n   249→\t})\n   250→\n   251→\tengRun, runErr := eng.Run(ctx, wf)\n   252→\n   253→\tif ulog != nil {\n   254→\t\tulog.Close()\n   255→\t}\n   256→\n   257→\tresult := &RunResult{\n   258→\t\tRunID:     run.ID,\n   259→\t\tState:     domain.RunStateFailed,\n   260→\t\tOutputDir: outputDir,\n   261→\t}\n   262→\tif engRun != nil {\n   263→\t\tresult.State = engRun.State\n   264→\t}\n   265→\n   266→\t// Persist final state\n   267→\thostRun, _ := r.Store.GetRun(ctx, run.ID)\n   268→\tif hostRun != nil {\n   269→\t\tif runErr != nil {\n   270→\t\t\thostRun.Fail(runErr.Error())\n   271→\t\t} else {\n   272→\t\t\thostRun.Complete(result.State)\n   273→\t\t}\n   274→\t\thostRun.ActiveSteps = nil\n   275→\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n   276→\t}\n   277→\n   278→\tif runErr != nil {\n   279→\t\tlog.Printf(\"host workflow: resume of %q failed for %s: %v\", wf.Name, run.ProjectDir, runErr)\n   280→\t\treturn result, runErr\n   281→\t}\n   282→\n   283→\tlog.Printf(\"host workflow: resume of %q completed for %s with state %s\", wf.Name, run.ProjectDir, engRun.State)\n   284→\treturn result, nil\n   285→}\n   286→\n   287→// buildPreloadedResults creates a map of step results for steps that completed\n   288→// before the resume point. It walks the workflow graph from the entry step,\n   289→// collecting results from the run's StepExecutions.\n   290→func buildPreloadedResults(run *domain.Run, wf *domain.Workflow, resumeFrom string) map[string]string {\n   291→\t// Build step result map from the run's executions\n   292→\tstepResults := make(map[string]string)\n   293→\tfor _, exec := range run.StepExecutions {\n   294→\t\tif exec.Result != \"\" && exec.Result != \"error\" {\n   295→\t\t\tstepResults[exec.StepName] = exec.Result\n   296→\t\t}\n   297→\t}\n   298→\n   299→\tpreloaded := make(map[string]string)\n   300→\tvisited := make(map[string]bool)\n   301→\tvar walk func(stepName string)\n   302→\twalk = func(stepName string) {\n   303→\t\tif visited[stepName] || stepName == resumeFrom {\n   304→\t\t\treturn\n   305→\t\t}\n   306→\t\tvisited[stepName] = true\n   307→\n   308→\t\tresult, ok := stepResults[stepName]\n   309→\t\tif !ok {\n   310→\t\t\treturn\n   311→\t\t}\n   312→\t\tpreloaded[stepName] = result\n   313→\n   314→\t\tnextSteps, err := wf.NextSteps(stepName, result)\n   315→\t\tif err != nil {\n   316→\t\t\treturn\n   317→\t\t}\n   318→\t\tfor _, next := range nextSteps {\n   319→\t\t\tif next != domain.StepDone && next != domain.StepAbort {\n   320→\t\t\t\twalk(next)\n   321→\t\t\t}\n   322→\t\t}\n   323→\t}\n   324→\n   325→\twalk(wf.EntryStep)\n   326→\treturn preloaded\n   327→}\n   328→\n   329→// RunListTasksWorkflow executes the list-tasks workflow and returns the\n   330→// discovered tasks. No run record is created for list-tasks executions since\n   331→// they are polling operations that would otherwise clutter the run history.\n   332→func RunListTasksWorkflow(ctx context.Context, runner *Runner, projectDir string) ([]Task, *RunResult, error) {\n   333→\trunner.SkipRunRecord = true\n   334→\tresult, err := runner.RunNamed(ctx, projectDir, \"list-tasks\")\n   335→\tif err != nil {\n   336→\t\treturn nil, nil, err\n   337→\t}\n   338→\tif result.State != domain.RunStateSucceeded {\n   339→\t\treturn nil, result, fmt.Errorf(\"list-tasks workflow failed with state %s\", result.State)\n   340→\t}\n   341→\ttasks, err := ReadListTasksOutput(result.OutputDir)\n   342→\tif err != nil {\n   343→\t\treturn nil, result, err\n   344→\t}\n   345→\treturn tasks, result, nil\n   346→}\n   347→\n   348→// findHostWorkflow searches all .cloche files in a project for a host workflow\n   349→// with the given name. A workflow is a host workflow if it contains a \"host { }\"\n   350→// block in its definition.\n   351→func findHostWorkflow(projectDir, workflowName string) (*domain.Workflow, error) {\n   352→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n   353→\tentries, _ := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n   354→\n   355→\tfor _, path := range entries {\n   356→\t\tdata, err := os.ReadFile(path)\n   357→\t\tif err != nil {\n   358→\t\t\tcontinue\n   359→\t\t}\n   360→\t\tworkflows, err := dsl.ParseAll(string(data))\n   361→\t\tif err != nil {\n   362→\t\t\tcontinue\n   363→\t\t}\n   364→\t\tif wf, ok := workflows[workflowName]; ok && wf.Location == domain.LocationHost {\n   365→\t\t\treturn wf, nil\n   366→\t\t}\n   367→\t}\n   368→\n   369→\treturn nil, fmt.Errorf(\"host workflow %q not found in any .cloche file\", workflowName)\n   370→}\n   371→\n   372→// FindHostWorkflows returns all host workflows across all .cloche files.\n   373→func FindHostWorkflows(projectDir string) (map[string]*domain.Workflow, error) {\n   374→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n   375→\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n   376→\tif err != nil {\n   377→\t\treturn nil, err\n   378→\t}\n   379→\n   380→\tall := make(map[string]*domain.Workflow)\n   381→\tfor _, path := range entries {\n   382→\t\tdata, err := os.ReadFile(path)\n   383→\t\tif err != nil {\n   384→\t\t\tcontinue\n   385→\t\t}\n   386→\t\tworkflows, err := dsl.ParseAll(string(data))\n   387→\t\tif err != nil {\n   388→\t\t\tcontinue\n   389→\t\t}\n   390→\t\tfor name, wf := range workflows {\n   391→\t\t\tif wf.Location == domain.LocationHost {\n   392→\t\t\t\tall[name] = wf\n   393→\t\t\t}\n   394→\t\t}\n   395→\t}\n   396→\n   397→\treturn all, nil\n   398→}\n   399→\n   400→// hostStatusHandler logs host workflow step events and persists them to the store.\n   401→// It mirrors the container-side status pipeline: saving captures and publishing\n   402→// to the log broadcaster so that cloche logs works identically for host runs.\n   403→type hostStatusHandler struct {\n   404→\tprojectDir   string\n   405→\torchRunID    string\n   406→\tstore        ports.RunStore\n   407→\tcaptures     ports.CaptureStore\n   408→\tlogBroadcast *logstream.Broadcaster\n   409→\toutputDir    string\n   410→\tlogWriter    *logstream.Writer // persists log entries to full.log\n   411→}\n   412→\n   413→func (h *hostStatusHandler) OnStepStart(_ *domain.Run, step *domain.Step) {\n   414→\tnow := time.Now()\n   415→\tlog.Printf(\"host workflow [%s]: step %q started\", h.orchRunID, step.Name)\n   416→\tif h.store != nil {\n   417→\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n   418→\t\t\tr.RecordStepStart(step.Name)\n   419→\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n   420→\t\t}\n   421→\t}\n   422→\tif h.captures != nil {\n   423→\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n   424→\t\t\tStepName:  step.Name,\n   425→\t\t\tStartedAt: now,\n   426→\t\t})\n   427→\t}\n   428→\tif h.logWriter != nil {\n   429→\t\th.logWriter.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n   430→\t}\n   431→\tif h.logBroadcast != nil {\n   432→\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n   433→\t\t\tTimestamp: now.Format(time.RFC3339),\n   434→\t\t\tType:      \"status\",\n   435→\t\t\tContent:   \"step_started: \" + step.Name,\n   436→\t\t\tStepName:  step.Name,\n   437→\t\t})\n   438→\t}\n   439→}\n   440→\n   441→func (h *hostStatusHandler) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   442→\tnow := time.Now()\n   443→\tlog.Printf(\"host workflow [%s]: step %q completed with result %q\", h.orchRunID, step.Name, result)\n   444→\tif h.store != nil {\n   445→\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n   446→\t\t\tr.RecordStepComplete(step.Name, result)\n   447→\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n   448→\t\t}\n   449→\t}\n   450→\tif h.captures != nil {\n   451→\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n   452→\t\t\tStepName:    step.Name,\n   453→\t\t\tResult:      result,\n   454→\t\t\tCompletedAt: now,\n   455→\t\t})\n   456→\t}\n   457→\t// Read step output for logging/broadcasting.\n   458→\tvar stepOutput string\n   459→\toutputPath := filepath.Join(h.outputDir, step.Name+\".out\")\n   460→\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   461→\t\tstepOutput = string(data)\n   462→\t}\n   463→\tif h.logWriter != nil {\n   464→\t\tif stepOutput != \"\" {\n   465→\t\t\th.logWriter.Log(logstream.TypeScript, stepOutput)\n   466→\t\t}\n   467→\t\th.logWriter.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n   468→\t}\n   469→\tif h.logBroadcast != nil {\n   470→\t\tif stepOutput != \"\" {\n   471→\t\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n   472→\t\t\t\tTimestamp: now.Format(time.RFC3339),\n   473→\t\t\t\tType:      \"script\",\n   474→\t\t\t\tContent:   stepOutput,\n   475→\t\t\t\tStepName:  step.Name,\n   476→\t\t\t})\n   477→\t\t}\n   478→\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n   479→\t\t\tTimestamp: now.Format(time.RFC3339),\n   480→\t\t\tType:      \"status\",\n   481→\t\t\tContent:   \"step_completed: \" + step.Name + \" -> \" + result,\n   482→\t\t\tStepName:  step.Name,\n   483→\t\t})\n   484→\t}\n   485→}\n   486→\n   487→func (h *hostStatusHandler) OnRunComplete(run *domain.Run) {\n   488→\tlog.Printf(\"host workflow [%s]: run completed with state %s\", h.orchRunID, run.State)\n   489→}\n   490→"}]},"parent_tool_use_id":null,"session_id":"ab06b6b4-e6b6-4d23-a886-0560ffd72710","uuid":"699e1f6b-c7c7-48a7-a3a5-3e62b3ec8e00","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/runner.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// Ensure hostStatusHandler implements engine.StatusHandler.\nvar _ engine.StatusHandler = (*hostStatusHandler)(nil)\n\n// Runner executes a host workflow by parsing host.cloche and walking the step graph.\ntype Runner struct {\n\tDispatcher    RunDispatcher\n\tStore         ports.RunStore\n\tCaptures      ports.CaptureStore       // optional: saves step captures for cloche logs\n\tLogBroadcast  *logstream.Broadcaster   // optional: publishes live log lines\n\tTaskID        string                   // optional task ID assigned by the daemon loop\n\tExtraEnv      []string                 // additional KEY=VALUE env vars passed to all steps\n\tSkipRunRecord bool                     // when true, don't persist a run record to the store\n}\n\n// RunResult contains the outcome of a host workflow execution.\ntype RunResult struct {\n\tRunID     string\n\tState     domain.RunState\n\tOutputDir string // path to the step output directory\n}\n\n// Run parses .cloche/host.cloche from projectDir and executes the \"main\" workflow.\nfunc (r *Runner) Run(ctx context.Context, projectDir string) (*RunResult, error) {\n\treturn r.RunWithID(ctx, projectDir, domain.GenerateRunID(\"main\"))\n}\n\n// RunWithID is like Run but uses the provided run ID instead of generating one.\nfunc (r *Runner) RunWithID(ctx context.Context, projectDir string, orchRunID string) (*RunResult, error) {\n\treturn r.runNamedWorkflow(ctx, projectDir, \"main\", orchRunID)\n}\n\n// RunNamed executes a named host workflow, generating a new run ID.\nfunc (r *Runner) RunNamed(ctx context.Context, projectDir string, workflowName string) (*RunResult, error) {\n\torchRunID := domain.GenerateRunID(workflowName)\n\treturn r.runNamedWorkflow(ctx, projectDir, workflowName, orchRunID)\n}\n\n// RunNamedWithID executes a named host workflow using the provided run ID.\nfunc (r *Runner) RunNamedWithID(ctx context.Context, projectDir string, workflowName string, runID string) (*RunResult, error) {\n\treturn r.runNamedWorkflow(ctx, projectDir, workflowName, runID)\n}\n\n// runNamedWorkflow is the internal implementation that runs a specific named\n// host workflow. Searches all .cloche files for the workflow.\nfunc (r *Runner) runNamedWorkflow(ctx context.Context, projectDir string, workflowName string, orchRunID string) (*RunResult, error) {\n\twf, err := findHostWorkflow(projectDir, workflowName)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Create output directory for step outputs\n\toutputDir := filepath.Join(projectDir, \".cloche\", orchRunID, \"output\")\n\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n\t}\n\n\tlog.Printf(\"host workflow: starting %q for project %s (run %s)\", wf.Name, projectDir, orchRunID)\n\n\t// Persist the host run in the store so it appears in list/status/logs.\n\t// When SkipRunRecord is set (e.g. for list-tasks polling), skip creating\n\t// the record to avoid cluttering the run history.\n\tif !r.SkipRunRecord {\n\t\thostRun := domain.NewRun(orchRunID, wf.Name)\n\t\thostRun.ProjectDir = projectDir\n\t\thostRun.IsHost = true\n\t\thostRun.TaskID = r.TaskID\n\t\tif err := r.Store.CreateRun(ctx, hostRun); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating host run record: %w\", err)\n\t\t}\n\t\thostRun.Start()\n\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n\t}\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tMainDir:    MainWorktreeDir(projectDir),\n\t\tDispatcher: r.Dispatcher,\n\t\tStore:      r.Store,\n\t\tOutputDir:  outputDir,\n\t\tWires:      wf.Wiring,\n\t\tHostRunID:  orchRunID,\n\t\tTaskID:     r.TaskID,\n\t\tExtraEnv:   r.ExtraEnv,\n\t}\n\n\t// Configure agent from workflow-level host config\n\tif cmd := wf.Config[\"host.agent_command\"]; cmd != \"\" {\n\t\texecutor.AgentCommands = prompt.ParseCommands(cmd)\n\t}\n\tif args := wf.Config[\"host.agent_args\"]; args != \"\" {\n\t\texecutor.AgentArgs = strings.Fields(args)\n\t}\n\n\t// Create a logstream.Writer so host runs persist logs to full.log,\n\t// matching container-side behavior where the agent writes full.log.\n\tvar ulog *logstream.Writer\n\tif !r.SkipRunRecord {\n\t\trunDir := filepath.Join(projectDir, \".cloche\", orchRunID)\n\t\tw, err := logstream.New(runDir)\n\t\tif err != nil {\n\t\t\tlog.Printf(\"host workflow [%s]: failed to create log writer: %v\", orchRunID, err)\n\t\t} else {\n\t\t\tulog = w\n\t\t}\n\t}\n\n\teng := engine.New(executor)\n\teng.SetStatusHandler(&hostStatusHandler{\n\t\tprojectDir:   projectDir,\n\t\torchRunID:    orchRunID,\n\t\tstore:        r.Store,\n\t\tcaptures:     r.Captures,\n\t\tlogBroadcast: r.LogBroadcast,\n\t\toutputDir:    outputDir,\n\t\tlogWriter:    ulog,\n\t})\n\n\trun, runErr := eng.Run(ctx, wf)\n\n\tif ulog != nil {\n\t\tulog.Close()\n\t}\n\n\tresult := &RunResult{\n\t\tRunID:     orchRunID,\n\t\tState:     domain.RunStateFailed,\n\t\tOutputDir: outputDir,\n\t}\n\tif run != nil {\n\t\tresult.State = run.State\n\t}\n\n\t// Persist final state.\n\tif !r.SkipRunRecord {\n\t\thostRun, _ := r.Store.GetRun(ctx, orchRunID)\n\t\tif hostRun != nil {\n\t\t\tif runErr != nil {\n\t\t\t\thostRun.Fail(runErr.Error())\n\t\t\t} else {\n\t\t\t\thostRun.Complete(result.State)\n\t\t\t}\n\t\t\thostRun.ActiveSteps = nil\n\t\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n\t\t}\n\t}\n\n\tif runErr != nil {\n\t\tlog.Printf(\"host workflow: %q failed for %s: %v\", wf.Name, projectDir, runErr)\n\t\treturn result, runErr\n\t}\n\n\tlog.Printf(\"host workflow: %q completed for %s with state %s\", wf.Name, projectDir, run.State)\n\treturn result, nil\n}\n\n// ResumeRun resumes a failed host workflow run from a specific step.\n// Steps before resumeFrom are replayed from their stored results.\nfunc (r *Runner) ResumeRun(ctx context.Context, run *domain.Run, resumeFrom string) (*RunResult, error) {\n\twf, err := findHostWorkflow(run.ProjectDir, run.WorkflowName)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Validate the resume step exists\n\tif _, ok := wf.Steps[resumeFrom]; !ok {\n\t\treturn nil, fmt.Errorf(\"step %q not found in workflow %q\", resumeFrom, run.WorkflowName)\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\")\n\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n\t}\n\n\tlog.Printf(\"host workflow: resuming %q from step %q for project %s (run %s)\", wf.Name, resumeFrom, run.ProjectDir, run.ID)\n\n\t// Reset run state\n\trun.State = domain.RunStateRunning\n\trun.ErrorMessage = \"\"\n\trun.CompletedAt = time.Time{}\n\trun.ActiveSteps = nil\n\tif err := r.Store.UpdateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"updating run state: %w\", err)\n\t}\n\n\texecutor := &Executor{\n\t\tProjectDir: run.ProjectDir,\n\t\tMainDir:    MainWorktreeDir(run.ProjectDir),\n\t\tDispatcher: r.Dispatcher,\n\t\tStore:      r.Store,\n\t\tOutputDir:  outputDir,\n\t\tWires:      wf.Wiring,\n\t\tHostRunID:  run.ID,\n\t\tTaskID:     r.TaskID,\n\t\tExtraEnv:   r.ExtraEnv,\n\t}\n\n\t// Configure agent from workflow-level host config\n\tif cmd := wf.Config[\"host.agent_command\"]; cmd != \"\" {\n\t\texecutor.AgentCommands = prompt.ParseCommands(cmd)\n\t}\n\tif args := wf.Config[\"host.agent_args\"]; args != \"\" {\n\t\texecutor.AgentArgs = strings.Fields(args)\n\t}\n\n\t// Build preloaded results from previously completed steps\n\tpreloaded := buildPreloadedResults(run, wf, resumeFrom)\n\n\t// Configure the executor to know which step is being resumed (for prompt resume)\n\texecutor.ResumeStep = resumeFrom\n\n\tvar ulog *logstream.Writer\n\trunDir := filepath.Join(run.ProjectDir, \".cloche\", run.ID)\n\tw, err := logstream.New(runDir)\n\tif err != nil {\n\t\tlog.Printf(\"host workflow [%s]: failed to create log writer: %v\", run.ID, err)\n\t} else {\n\t\tulog = w\n\t}\n\n\teng := engine.New(executor)\n\teng.SetPreloadedResults(preloaded)\n\teng.SetStatusHandler(&hostStatusHandler{\n\t\tprojectDir:   run.ProjectDir,\n\t\torchRunID:    run.ID,\n\t\tstore:        r.Store,\n\t\tcaptures:     r.Captures,\n\t\tlogBroadcast: r.LogBroadcast,\n\t\toutputDir:    outputDir,\n\t\tlogWriter:    ulog,\n\t})\n\n\tengRun, runErr := eng.Run(ctx, wf)\n\n\tif ulog != nil {\n\t\tulog.Close()\n\t}\n\n\tresult := &RunResult{\n\t\tRunID:     run.ID,\n\t\tState:     domain.RunStateFailed,\n\t\tOutputDir: outputDir,\n\t}\n\tif engRun != nil {\n\t\tresult.State = engRun.State\n\t}\n\n\t// Persist final state\n\thostRun, _ := r.Store.GetRun(ctx, run.ID)\n\tif hostRun != nil {\n\t\tif runErr != nil {\n\t\t\thostRun.Fail(runErr.Error())\n\t\t} else {\n\t\t\thostRun.Complete(result.State)\n\t\t}\n\t\thostRun.ActiveSteps = nil\n\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n\t}\n\n\tif runErr != nil {\n\t\tlog.Printf(\"host workflow: resume of %q failed for %s: %v\", wf.Name, run.ProjectDir, runErr)\n\t\treturn result, runErr\n\t}\n\n\tlog.Printf(\"host workflow: resume of %q completed for %s with state %s\", wf.Name, run.ProjectDir, engRun.State)\n\treturn result, nil\n}\n\n// buildPreloadedResults creates a map of step results for steps that completed\n// before the resume point. It walks the workflow graph from the entry step,\n// collecting results from the run's StepExecutions.\nfunc buildPreloadedResults(run *domain.Run, wf *domain.Workflow, resumeFrom string) map[string]string {\n\t// Build step result map from the run's executions\n\tstepResults := make(map[string]string)\n\tfor _, exec := range run.StepExecutions {\n\t\tif exec.Result != \"\" && exec.Result != \"error\" {\n\t\t\tstepResults[exec.StepName] = exec.Result\n\t\t}\n\t}\n\n\tpreloaded := make(map[string]string)\n\tvisited := make(map[string]bool)\n\tvar walk func(stepName string)\n\twalk = func(stepName string) {\n\t\tif visited[stepName] || stepName == resumeFrom {\n\t\t\treturn\n\t\t}\n\t\tvisited[stepName] = true\n\n\t\tresult, ok := stepResults[stepName]\n\t\tif !ok {\n\t\t\treturn\n\t\t}\n\t\tpreloaded[stepName] = result\n\n\t\tnextSteps, err := wf.NextSteps(stepName, result)\n\t\tif err != nil {\n\t\t\treturn\n\t\t}\n\t\tfor _, next := range nextSteps {\n\t\t\tif next != domain.StepDone && next != domain.StepAbort {\n\t\t\t\twalk(next)\n\t\t\t}\n\t\t}\n\t}\n\n\twalk(wf.EntryStep)\n\treturn preloaded\n}\n\n// RunListTasksWorkflow executes the list-tasks workflow and returns the\n// discovered tasks. No run record is created for list-tasks executions since\n// they are polling operations that would otherwise clutter the run history.\nfunc RunListTasksWorkflow(ctx context.Context, runner *Runner, projectDir string) ([]Task, *RunResult, error) {\n\trunner.SkipRunRecord = true\n\tresult, err := runner.RunNamed(ctx, projectDir, \"list-tasks\")\n\tif err != nil {\n\t\treturn nil, nil, err\n\t}\n\tif result.State != domain.RunStateSucceeded {\n\t\treturn nil, result, fmt.Errorf(\"list-tasks workflow failed with state %s\", result.State)\n\t}\n\ttasks, err := ReadListTasksOutput(result.OutputDir)\n\tif err != nil {\n\t\treturn nil, result, err\n\t}\n\treturn tasks, result, nil\n}\n\n// findHostWorkflow searches all .cloche files in a project for a host workflow\n// with the given name. A workflow is a host workflow if it contains a \"host { }\"\n// block in its definition.\nfunc findHostWorkflow(projectDir, workflowName string) (*domain.Workflow, error) {\n\tclocheDir := filepath.Join(projectDir, \".cloche\")\n\tentries, _ := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n\n\tfor _, path := range entries {\n\t\tdata, err := os.ReadFile(path)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tworkflows, err := dsl.ParseAll(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif wf, ok := workflows[workflowName]; ok && wf.Location == domain.LocationHost {\n\t\t\treturn wf, nil\n\t\t}\n\t}\n\n\treturn nil, fmt.Errorf(\"host workflow %q not found in any .cloche file\", workflowName)\n}\n\n// FindHostWorkflows returns all host workflows across all .cloche files.\nfunc FindHostWorkflows(projectDir string) (map[string]*domain.Workflow, error) {\n\tclocheDir := filepath.Join(projectDir, \".cloche\")\n\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tall := make(map[string]*domain.Workflow)\n\tfor _, path := range entries {\n\t\tdata, err := os.ReadFile(path)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tworkflows, err := dsl.ParseAll(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor name, wf := range workflows {\n\t\t\tif wf.Location == domain.LocationHost {\n\t\t\t\tall[name] = wf\n\t\t\t}\n\t\t}\n\t}\n\n\treturn all, nil\n}\n\n// hostStatusHandler logs host workflow step events and persists them to the store.\n// It mirrors the container-side status pipeline: saving captures and publishing\n// to the log broadcaster so that cloche logs works identically for host runs.\ntype hostStatusHandler struct {\n\tprojectDir   string\n\torchRunID    string\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogBroadcast *logstream.Broadcaster\n\toutputDir    string\n\tlogWriter    *logstream.Writer // persists log entries to full.log\n}\n\nfunc (h *hostStatusHandler) OnStepStart(_ *domain.Run, step *domain.Step) {\n\tnow := time.Now()\n\tlog.Printf(\"host workflow [%s]: step %q started\", h.orchRunID, step.Name)\n\tif h.store != nil {\n\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n\t\t\tr.RecordStepStart(step.Name)\n\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n\t\t}\n\t}\n\tif h.captures != nil {\n\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n\t\t\tStepName:  step.Name,\n\t\t\tStartedAt: now,\n\t\t})\n\t}\n\tif h.logWriter != nil {\n\t\th.logWriter.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n\t}\n\tif h.logBroadcast != nil {\n\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n\t\t\tTimestamp: now.Format(time.RFC3339),\n\t\t\tType:      \"status\",\n\t\t\tContent:   \"step_started: \" + step.Name,\n\t\t\tStepName:  step.Name,\n\t\t})\n\t}\n}\n\nfunc (h *hostStatusHandler) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n\tnow := time.Now()\n\tlog.Printf(\"host workflow [%s]: step %q completed with result %q\", h.orchRunID, step.Name, result)\n\tif h.store != nil {\n\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n\t\t\tr.RecordStepComplete(step.Name, result)\n\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n\t\t}\n\t}\n\tif h.captures != nil {\n\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n\t\t\tStepName:    step.Name,\n\t\t\tResult:      result,\n\t\t\tCompletedAt: now,\n\t\t})\n\t}\n\t// Read step output for logging/broadcasting.\n\tvar stepOutput string\n\toutputPath := filepath.Join(h.outputDir, step.Name+\".out\")\n\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\tstepOutput = string(data)\n\t}\n\tif h.logWriter != nil {\n\t\tif stepOutput != \"\" {\n\t\t\th.logWriter.Log(logstream.TypeScript, stepOutput)\n\t\t}\n\t\th.logWriter.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n\t}\n\tif h.logBroadcast != nil {\n\t\tif stepOutput != \"\" {\n\t\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n\t\t\t\tTimestamp: now.Format(time.RFC3339),\n\t\t\t\tType:      \"script\",\n\t\t\t\tContent:   stepOutput,\n\t\t\t\tStepName:  step.Name,\n\t\t\t})\n\t\t}\n\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n\t\t\tTimestamp: now.Format(time.RFC3339),\n\t\t\tType:      \"status\",\n\t\t\tContent:   \"step_completed: \" + step.Name + \" -> \" + result,\n\t\t\tStepName:  step.Name,\n\t\t})\n\t}\n}\n\nfunc (h *hostStatusHandler) OnRunComplete(run *domain.Run) {\n\tlog.Printf(\"host workflow [%s]: run completed with state %s\", h.orchRunID, run.State)\n}\n","numLines":490,"startLine":1,"totalLines":490}}}
