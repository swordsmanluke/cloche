{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GwoBmdaJaiPWWKVq2x57L9","type":"tool_result","content":"   660→\t\t}\n   661→\t}\n   662→\n   663→\treturn resp, nil\n   664→}\n   665→\n   666→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   667→\tctx := stream.Context()\n   668→\n   669→\t_ = followFromContext(ctx) // follow is implicit for active runs\n   670→\tlimit := limitFromContext(ctx)\n   671→\n   672→\t// Verify run exists\n   673→\trun, err := s.store.GetRun(ctx, req.RunId)\n   674→\tif err != nil {\n   675→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   676→\t}\n   677→\n   678→\t// If step_name or log_type filter is set, serve content directly from the log index\n   679→\tif req.StepName != \"\" || req.LogType != \"\" {\n   680→\t\treturn s.streamFilteredLogs(ctx, req, run, stream, limit)\n   681→\t}\n   682→\n   683→\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n   684→\n   685→\t// Active runs always stream live output (follow mode is implicit).\n   686→\t// The -f flag is accepted but redundant for active runs.\n   687→\tif isActive && s.logBroadcast != nil {\n   688→\t\treturn s.streamFollowLogs(req.RunId, run, stream, limit)\n   689→\t}\n   690→\n   691→\t// Check for full.log first — if it exists, serve it as the unified log\n   692→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   693→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   694→\t\tmsg := applyLimit(string(data), limit)\n   695→\t\tif err := stream.Send(&pb.LogEntry{\n   696→\t\t\tType:    \"full_log\",\n   697→\t\t\tMessage: msg,\n   698→\t\t}); err != nil {\n   699→\t\t\treturn err\n   700→\t\t}\n   701→\t\tif !isActive {\n   702→\t\t\tif err := stream.Send(&pb.LogEntry{\n   703→\t\t\t\tType:      \"run_completed\",\n   704→\t\t\t\tResult:    string(run.State),\n   705→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   706→\t\t\t\tMessage:   run.ErrorMessage,\n   707→\t\t\t}); err != nil {\n   708→\t\t\t\treturn err\n   709→\t\t\t}\n   710→\t\t}\n   711→\t\treturn nil\n   712→\t}\n   713→\n   714→\tif s.captures == nil {\n   715→\t\treturn fmt.Errorf(\"captures store not configured\")\n   716→\t}\n   717→\n   718→\t// Fall back to capture-based streaming\n   719→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   720→\tif err != nil {\n   721→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   722→\t}\n   723→\n   724→\tfor _, exec := range captures {\n   725→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   726→\t\t// and one for step_completed (has Result).\n   727→\t\tif exec.Result == \"\" {\n   728→\t\t\tentry := &pb.LogEntry{\n   729→\t\t\t\tType:      \"step_started\",\n   730→\t\t\t\tStepName:  exec.StepName,\n   731→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   732→\t\t\t}\n   733→\t\t\tif err := stream.Send(entry); err != nil {\n   734→\t\t\t\treturn err\n   735→\t\t\t}\n   736→\t\t} else {\n   737→\t\t\t// Read step output from per-step output file.\n   738→\t\t\t// Container runs write .log, host runs write .out — try both.\n   739→\t\t\tvar output string\n   740→\t\t\tfor _, ext := range []string{\".log\", \".out\"} {\n   741→\t\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+ext)\n   742→\t\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   743→\t\t\t\t\toutput = string(data)\n   744→\t\t\t\t\tbreak\n   745→\t\t\t\t}\n   746→\t\t\t}\n   747→\t\t\tentry := &pb.LogEntry{\n   748→\t\t\t\tType:      \"step_completed\",\n   749→\t\t\t\tStepName:  exec.StepName,\n   750→\t\t\t\tResult:    exec.Result,\n   751→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   752→\t\t\t\tMessage:   applyLimit(output, limit),\n   753→\t\t\t}\n   754→\t\t\tif err := stream.Send(entry); err != nil {\n   755→\t\t\t\treturn err\n   756→\t\t\t}\n   757→\t\t}\n   758→\t}\n   759→\n   760→\t// Send run completion entry\n   761→\tif !isActive {\n   762→\t\tif err := stream.Send(&pb.LogEntry{\n   763→\t\t\tType:      \"run_completed\",\n   764→\t\t\tResult:    string(run.State),\n   765→\t\t\tTimestamp: run.CompletedAt.String(),\n   766→\t\t\tMessage:   run.ErrorMessage,\n   767→\t\t}); err != nil {\n   768→\t\t\treturn err\n   769→\t\t}\n   770→\t}\n   771→\n   772→\treturn nil\n   773→}\n   774→\n   775→// followFromContext checks for the follow flag in gRPC metadata.\n   776→func followFromContext(ctx context.Context) bool {\n   777→\tmd, ok := metadata.FromIncomingContext(ctx)\n   778→\tif !ok {\n   779→\t\treturn false\n   780→\t}\n   781→\tvals := md.Get(\"x-cloche-follow\")\n   782→\treturn len(vals) > 0 && vals[0] == \"true\"\n   783→}\n   784→\n   785→// limitFromContext reads the line limit from gRPC metadata.\n   786→// Returns 0 when no limit is set.\n   787→func limitFromContext(ctx context.Context) int {\n   788→\tmd, ok := metadata.FromIncomingContext(ctx)\n   789→\tif !ok {\n   790→\t\treturn 0\n   791→\t}\n   792→\tvals := md.Get(\"x-cloche-limit\")\n   793→\tif len(vals) == 0 {\n   794→\t\treturn 0\n   795→\t}\n   796→\tn, err := strconv.Atoi(vals[0])\n   797→\tif err != nil || n <= 0 {\n   798→\t\treturn 0\n   799→\t}\n   800→\treturn n\n   801→}\n   802→\n   803→// applyLimit returns the last n lines of content. If n <= 0, returns content unchanged.\n   804→func applyLimit(content string, n int) string {\n   805→\tif n <= 0 {\n   806→\t\treturn content\n   807→\t}\n   808→\tlines := strings.Split(content, \"\\n\")\n   809→\t// Remove trailing empty line from final newline\n   810→\tif len(lines) > 0 && lines[len(lines)-1] == \"\" {\n   811→\t\tlines = lines[:len(lines)-1]\n   812→\t}\n   813→\tif len(lines) <= n {\n   814→\t\treturn content\n   815→\t}\n   816→\treturn strings.Join(lines[len(lines)-n:], \"\\n\") + \"\\n\"\n   817→}\n   818→\n   819→// streamFollowLogs sends existing log content then tails live output from the\n   820→// broadcaster. It combines snapshot + live streaming (like tail -f).\n   821→func (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry], limit int) error {\n   822→\t// Subscribe first so we don't miss lines written between read and subscribe.\n   823→\tsub := s.logBroadcast.Subscribe(runID)\n   824→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   825→\n   826→\t// Send existing full.log content if available.\n   827→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n   828→\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n   829→\t\tmsg := applyLimit(string(data), limit)\n   830→\t\tif err := stream.Send(&pb.LogEntry{\n   831→\t\t\tType:    \"full_log\",\n   832→\t\t\tMessage: msg,\n   833→\t\t}); err != nil {\n   834→\t\t\treturn err\n   835→\t\t}\n   836→\t}\n   837→\n   838→\t// Now tail live output from the broadcaster.\n   839→\tctx := stream.Context()\n   840→\tfor {\n   841→\t\tselect {\n   842→\t\tcase <-ctx.Done():\n   843→\t\t\treturn ctx.Err()\n   844→\t\tcase line, ok := <-sub.C:\n   845→\t\t\tif !ok {\n   846→\t\t\t\t// Run completed — send terminal entry.\n   847→\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n   848→\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n   849→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   850→\t\t\t\t\t\tType:      \"run_completed\",\n   851→\t\t\t\t\t\tResult:    string(r.State),\n   852→\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n   853→\t\t\t\t\t\tMessage:   r.ErrorMessage,\n   854→\t\t\t\t\t})\n   855→\t\t\t\t}\n   856→\t\t\t\treturn nil\n   857→\t\t\t}\n   858→\t\t\tif err := stream.Send(&pb.LogEntry{\n   859→\t\t\t\tType:      \"log\",\n   860→\t\t\t\tStepName:  line.StepName,\n   861→\t\t\t\tMessage:   line.Content,\n   862→\t\t\t\tTimestamp: line.Timestamp,\n   863→\t\t\t}); err != nil {\n   864→\t\t\t\treturn err\n   865→\t\t\t}\n   866→\t\t}\n   867→\t}\n   868→}\n   869→\n   870→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   871→// It uses the log index when available, falling back to file path conventions.\n   872→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry], limit int) error {\n   873→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   874→\n   875→\t// Try log index first\n   876→\tif s.logStore != nil {\n   877→\t\tvar logFiles []*ports.LogFileEntry\n   878→\t\tvar err error\n   879→\n   880→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   881→\t\t\t// Filter by both step and type\n   882→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   883→\t\t\tif err == nil {\n   884→\t\t\t\tfiltered := logFiles[:0]\n   885→\t\t\t\tfor _, lf := range logFiles {\n   886→\t\t\t\t\tif lf.FileType == req.LogType {\n   887→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   888→\t\t\t\t\t}\n   889→\t\t\t\t}\n   890→\t\t\t\tlogFiles = filtered\n   891→\t\t\t}\n   892→\t\t} else if req.StepName != \"\" {\n   893→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   894→\t\t} else {\n   895→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   896→\t\t}\n   897→\n   898→\t\tif err == nil && len(logFiles) > 0 {\n   899→\t\t\tfor _, lf := range logFiles {\n   900→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   901→\t\t\t\tif readErr != nil {\n   902→\t\t\t\t\tcontinue\n   903→\t\t\t\t}\n   904→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   905→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   906→\t\t\t\t\tStepName: lf.StepName,\n   907→\t\t\t\t\tMessage:  applyLimit(string(data), limit),\n   908→\t\t\t\t}); err != nil {\n   909→\t\t\t\t\treturn err\n   910→\t\t\t\t}\n   911→\t\t\t}\n   912→\t\t\treturn nil\n   913→\t\t}\n   914→\t}\n   915→\n   916→\t// Fall back to file path conventions\n   917→\tif req.StepName != \"\" {\n   918→\t\tvar logPath string\n   919→\t\tswitch req.LogType {\n   920→\t\tcase \"llm\":\n   921→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   922→\t\tdefault:\n   923→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   924→\t\t}\n   925→\n   926→\t\tdata, err := os.ReadFile(logPath)\n   927→\t\tif err != nil {\n   928→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   929→\t\t}\n   930→\t\treturn stream.Send(&pb.LogEntry{\n   931→\t\t\tType:     \"step_log\",\n   932→\t\t\tStepName: req.StepName,\n   933→\t\t\tMessage:  applyLimit(string(data), limit),\n   934→\t\t})\n   935→\t}\n   936→\n   937→\treturn fmt.Errorf(\"no log files found matching filter\")\n   938→}\n   939→\n   940→// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n   941→// time for an active run. The stream closes when the run completes or the\n   942→// client disconnects.\n   943→func (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   944→\tsub := s.logBroadcast.Subscribe(runID)\n   945→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   946→\n   947→\tctx := stream.Context()\n   948→\tfor {\n   949→\t\tselect {\n   950→\t\tcase <-ctx.Done():\n   951→\t\t\treturn ctx.Err()\n   952→\t\tcase line, ok := <-sub.C:\n   953→\t\t\tif !ok {\n   954→\t\t\t\t// Run completed — send terminal entry.\n   955→\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   956→\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   957→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   958→\t\t\t\t\t\tType:      \"run_completed\",\n   959→\t\t\t\t\t\tResult:    string(run.State),\n   960→\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   961→\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   962→\t\t\t\t\t})\n   963→\t\t\t\t}\n   964→\t\t\t\treturn nil\n   965→\t\t\t}\n   966→\t\t\tif err := stream.Send(&pb.LogEntry{\n   967→\t\t\t\tType:      \"log\",\n   968→\t\t\t\tStepName:  line.StepName,\n   969→\t\t\t\tMessage:   line.Content,\n   970→\t\t\t\tTimestamp: line.Timestamp,\n   971→\t\t\t}); err != nil {\n   972→\t\t\t\treturn err\n   973→\t\t\t}\n   974→\t\t}\n   975→\t}\n   976→}\n   977→\n   978→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   979→\ts.mu.Lock()"}]},"parent_tool_use_id":null,"session_id":"ab06b6b4-e6b6-4d23-a886-0560ffd72710","uuid":"c491f288-54e8-4978-bb81-a74d603b8c3b","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server.go","content":"\t\t}\n\t}\n\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tctx := stream.Context()\n\n\t_ = followFromContext(ctx) // follow is implicit for active runs\n\tlimit := limitFromContext(ctx)\n\n\t// Verify run exists\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n\t}\n\n\t// If step_name or log_type filter is set, serve content directly from the log index\n\tif req.StepName != \"\" || req.LogType != \"\" {\n\t\treturn s.streamFilteredLogs(ctx, req, run, stream, limit)\n\t}\n\n\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n\n\t// Active runs always stream live output (follow mode is implicit).\n\t// The -f flag is accepted but redundant for active runs.\n\tif isActive && s.logBroadcast != nil {\n\t\treturn s.streamFollowLogs(req.RunId, run, stream, limit)\n\t}\n\n\t// Check for full.log first — if it exists, serve it as the unified log\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n\t\tmsg := applyLimit(string(data), limit)\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: msg,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif !isActive {\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"run_completed\",\n\t\t\t\tResult:    string(run.State),\n\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}\n\n\tif s.captures == nil {\n\t\treturn fmt.Errorf(\"captures store not configured\")\n\t}\n\n\t// Fall back to capture-based streaming\n\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n\t}\n\n\tfor _, exec := range captures {\n\t\t// Captures are stored as separate rows: one for step_started (no Result)\n\t\t// and one for step_completed (has Result).\n\t\tif exec.Result == \"\" {\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_started\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tTimestamp: exec.StartedAt.String(),\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t} else {\n\t\t\t// Read step output from per-step output file.\n\t\t\t// Container runs write .log, host runs write .out — try both.\n\t\t\tvar output string\n\t\t\tfor _, ext := range []string{\".log\", \".out\"} {\n\t\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+ext)\n\t\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\t\t\t\toutput = string(data)\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_completed\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tResult:    exec.Result,\n\t\t\t\tTimestamp: exec.CompletedAt.String(),\n\t\t\t\tMessage:   applyLimit(output, limit),\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\t// Send run completion entry\n\tif !isActive {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:      \"run_completed\",\n\t\t\tResult:    string(run.State),\n\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\tMessage:   run.ErrorMessage,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// followFromContext checks for the follow flag in gRPC metadata.\nfunc followFromContext(ctx context.Context) bool {\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif !ok {\n\t\treturn false\n\t}\n\tvals := md.Get(\"x-cloche-follow\")\n\treturn len(vals) > 0 && vals[0] == \"true\"\n}\n\n// limitFromContext reads the line limit from gRPC metadata.\n// Returns 0 when no limit is set.\nfunc limitFromContext(ctx context.Context) int {\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif !ok {\n\t\treturn 0\n\t}\n\tvals := md.Get(\"x-cloche-limit\")\n\tif len(vals) == 0 {\n\t\treturn 0\n\t}\n\tn, err := strconv.Atoi(vals[0])\n\tif err != nil || n <= 0 {\n\t\treturn 0\n\t}\n\treturn n\n}\n\n// applyLimit returns the last n lines of content. If n <= 0, returns content unchanged.\nfunc applyLimit(content string, n int) string {\n\tif n <= 0 {\n\t\treturn content\n\t}\n\tlines := strings.Split(content, \"\\n\")\n\t// Remove trailing empty line from final newline\n\tif len(lines) > 0 && lines[len(lines)-1] == \"\" {\n\t\tlines = lines[:len(lines)-1]\n\t}\n\tif len(lines) <= n {\n\t\treturn content\n\t}\n\treturn strings.Join(lines[len(lines)-n:], \"\\n\") + \"\\n\"\n}\n\n// streamFollowLogs sends existing log content then tails live output from the\n// broadcaster. It combines snapshot + live streaming (like tail -f).\nfunc (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry], limit int) error {\n\t// Subscribe first so we don't miss lines written between read and subscribe.\n\tsub := s.logBroadcast.Subscribe(runID)\n\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n\n\t// Send existing full.log content if available.\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n\t\tmsg := applyLimit(string(data), limit)\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: msg,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\t// Now tail live output from the broadcaster.\n\tctx := stream.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Run completed — send terminal entry.\n\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n\t\t\t\t\t\tType:      \"run_completed\",\n\t\t\t\t\t\tResult:    string(r.State),\n\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n\t\t\t\t\t\tMessage:   r.ErrorMessage,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"log\",\n\t\t\t\tStepName:  line.StepName,\n\t\t\t\tMessage:   line.Content,\n\t\t\t\tTimestamp: line.Timestamp,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n}\n\n// streamFilteredLogs serves log content filtered by step name and/or log type.\n// It uses the log index when available, falling back to file path conventions.\nfunc (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry], limit int) error {\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n\n\t// Try log index first\n\tif s.logStore != nil {\n\t\tvar logFiles []*ports.LogFileEntry\n\t\tvar err error\n\n\t\tif req.StepName != \"\" && req.LogType != \"\" {\n\t\t\t// Filter by both step and type\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t\tif err == nil {\n\t\t\t\tfiltered := logFiles[:0]\n\t\t\t\tfor _, lf := range logFiles {\n\t\t\t\t\tif lf.FileType == req.LogType {\n\t\t\t\t\t\tfiltered = append(filtered, lf)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tlogFiles = filtered\n\t\t\t}\n\t\t} else if req.StepName != \"\" {\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t} else {\n\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n\t\t}\n\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr != nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\t\tType:     lf.FileType + \"_log\",\n\t\t\t\t\tStepName: lf.StepName,\n\t\t\t\t\tMessage:  applyLimit(string(data), limit),\n\t\t\t\t}); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Fall back to file path conventions\n\tif req.StepName != \"\" {\n\t\tvar logPath string\n\t\tswitch req.LogType {\n\t\tcase \"llm\":\n\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n\t\tdefault:\n\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n\t\t}\n\n\t\tdata, err := os.ReadFile(logPath)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n\t\t}\n\t\treturn stream.Send(&pb.LogEntry{\n\t\t\tType:     \"step_log\",\n\t\t\tStepName: req.StepName,\n\t\t\tMessage:  applyLimit(string(data), limit),\n\t\t})\n\t}\n\n\treturn fmt.Errorf(\"no log files found matching filter\")\n}\n\n// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n// time for an active run. The stream closes when the run completes or the\n// client disconnects.\nfunc (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tsub := s.logBroadcast.Subscribe(runID)\n\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n\n\tctx := stream.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Run completed — send terminal entry.\n\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n\t\t\t\t\t\tType:      \"run_completed\",\n\t\t\t\t\t\tResult:    string(run.State),\n\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"log\",\n\t\t\t\tStepName:  line.StepName,\n\t\t\t\tMessage:   line.Content,\n\t\t\t\tTimestamp: line.Timestamp,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n\ts.mu.Lock()","numLines":320,"startLine":660,"totalLines":1506}}}
