{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GWkFLSYjtpSTqk2r2Crr4N","type":"tool_result","content":"     1→package agent\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"io\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n    12→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    15→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    17→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    18→)\n    19→\n    20→type RunnerConfig struct {\n    21→\tWorkflowPath   string\n    22→\tWorkDir        string\n    23→\tStatusOutput   io.Writer\n    24→\tRunID          string\n    25→\tResumeFromStep string // when non-empty, resume the workflow from this step\n    26→}\n    27→\n    28→type Runner struct {\n    29→\tcfg RunnerConfig\n    30→}\n    31→\n    32→func NewRunner(cfg RunnerConfig) *Runner {\n    33→\treturn &Runner{\n    34→\t\tcfg: cfg,\n    35→\t}\n    36→}\n    37→\n    38→func (r *Runner) Run(ctx context.Context) error {\n    39→\tdata, err := os.ReadFile(r.cfg.WorkflowPath)\n    40→\tif err != nil {\n    41→\t\treturn fmt.Errorf(\"reading workflow file: %w\", err)\n    42→\t}\n    43→\n    44→\twf, err := dsl.ParseForContainer(string(data))\n    45→\tif err != nil {\n    46→\t\treturn fmt.Errorf(\"parsing workflow: %w\", err)\n    47→\t}\n    48→\n    49→\tstatusWriter := protocol.NewStatusWriter(r.cfg.StatusOutput)\n    50→\tgenericAdapter := generic.New()\n    51→\tgenericAdapter.RunID = r.cfg.RunID\n    52→\tpromptAdapter := prompt.New()\n    53→\tpromptAdapter.RunID = r.cfg.RunID\n    54→\tpromptAdapter.StatusWriter = statusWriter\n    55→\tif cmd, ok := os.LookupEnv(\"CLOCHE_AGENT_COMMAND\"); ok {\n    56→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    57→\t}\n    58→\tif cmd := wf.Config[\"container.agent_command\"]; cmd != \"\" {\n    59→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    60→\t}\n    61→\tif args := wf.Config[\"container.agent_args\"]; args != \"\" {\n    62→\t\tpromptAdapter.ExplicitArgs = strings.Fields(args)\n    63→\t}\n    64→\n    65→\t// Reset per-run state from any previous run — but preserve outputs when resuming\n    66→\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"attempt_count\"))\n    67→\tif r.cfg.ResumeFromStep == \"\" {\n    68→\t\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"output\"))\n    69→\t}\n    70→\n    71→\t// Create unified log writer\n    72→\tulog, err := logstream.New(r.cfg.WorkDir)\n    73→\tif err != nil {\n    74→\t\treturn fmt.Errorf(\"creating unified log: %w\", err)\n    75→\t}\n    76→\tdefer ulog.Close()\n    77→\n    78→\tgenericAdapter.StatusWriter = statusWriter\n    79→\n    80→\texecutor := &stepExecutor{\n    81→\t\tworkDir:        r.cfg.WorkDir,\n    82→\t\tgeneric:        genericAdapter,\n    83→\t\tprompt:         promptAdapter,\n    84→\t\tlogStream:      ulog,\n    85→\t\tstatusWriter:   statusWriter,\n    86→\t\tresumeFromStep: r.cfg.ResumeFromStep,\n    87→\t}\n    88→\n    89→\teng := engine.New(executor)\n    90→\teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n    91→\n    92→\t// Resume mode: load completed step results and configure engine\n    93→\tif r.cfg.ResumeFromStep != \"\" {\n    94→\t\tpreloaded, err := loadCompletedStepResults(r.cfg.WorkDir, wf, r.cfg.ResumeFromStep)\n    95→\t\tif err != nil {\n    96→\t\t\treturn fmt.Errorf(\"loading completed step results for resume: %w\", err)\n    97→\t\t}\n    98→\t\teng.SetPreloadedResults(preloaded)\n    99→\t}\n   100→\n   101→\t// Generate a run title from the prompt if one was not provided by the caller.\n   102→\t// The daemon sets title from --title; if empty, the agent extracts from prompt.\n   103→\tif title := extractTitle(r.cfg.WorkDir, r.cfg.RunID); title != \"\" {\n   104→\t\tstatusWriter.RunTitle(title)\n   105→\t}\n   106→\n   107→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n   108→\n   109→\trun, runErr := eng.Run(ctx, wf)\n   110→\tif runErr != nil {\n   111→\t\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:failed\")\n   112→\t\tulog.Log(logstream.TypeStatus, \"error: \"+runErr.Error())\n   113→\t\tulog.Log(logstream.TypeStatus, \"run_completed: failed\")\n   114→\t\t// Extract the failed step name from step executions so the daemon\n   115→\t\t// can display which step caused the failure.\n   116→\t\tfailedStep := \"\"\n   117→\t\tif run != nil {\n   118→\t\t\tfor _, se := range run.StepExecutions {\n   119→\t\t\t\tif se.Result == \"error\" || se.Result == \"fail\" {\n   120→\t\t\t\t\tfailedStep = se.StepName\n   121→\t\t\t\t}\n   122→\t\t\t}\n   123→\t\t}\n   124→\t\tstatusWriter.Error(failedStep, runErr.Error())\n   125→\t\tstatusWriter.RunCompleted(\"failed\")\n   126→\t\treturn runErr\n   127→\t}\n   128→\n   129→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:\"+string(run.State))\n   130→\n   131→\tulog.Log(logstream.TypeStatus, \"run_completed: \"+string(run.State))\n   132→\tstatusWriter.RunCompleted(string(run.State))\n   133→\treturn nil\n   134→}\n   135→\n   136→type stepExecutor struct {\n   137→\tworkDir        string\n   138→\tgeneric        *generic.Adapter\n   139→\tprompt         *prompt.Adapter\n   140→\tlogStream      *logstream.Writer\n   141→\tstatusWriter   *protocol.StatusWriter\n   142→\tresumeFromStep string // the step being resumed (for prompt resume mode)\n   143→}\n   144→\n   145→func (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n   146→\tswitch step.Type {\n   147→\tcase domain.StepTypeScript:\n   148→\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   149→\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   150→\t\treturn result, err"}]},"parent_tool_use_id":"toolu_01Qq235q2e7wWvX8zvLYRTqr","session_id":"ab06b6b4-e6b6-4d23-a886-0560ffd72710","uuid":"477d0be8-e8d1-41a6-b870-88e72f46dfb2"}
