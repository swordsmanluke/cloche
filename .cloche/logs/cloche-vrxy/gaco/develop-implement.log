elp(\"health\")\n    63→\t\t\treturn\n    64→\t\t}\n    65→\t\tcmdHealth(os.Args[2:])\n    66→\t\treturn\n    67→\tcase \"get\":\n    68→\t\tif hasHelpFlag(os.Args[2:]) {\n    69→\t\t\tprintSubcommandHelp(\"get\")\n    70→\t\t\treturn\n    71→\t\t}\n    72→\t\tcmdGet(os.Args[2:])\n    73→\t\treturn\n    74→\tcase \"set\":\n    75→\t\tif hasHelpFlag(os.Args[2:]) {\n    76→\t\t\tprintSubcommandHelp(\"set\")\n    77→\t\t\treturn\n    78→\t\t}\n    79→\t\tcmdSet(os.Args[2:])\n    80→\t\treturn\n    81→\tcase \"tasks\":\n    82→\t\tif hasHelpFlag(os.Args[2:]) {\n    83→\t\t\tprintSubcommandHelp(\"tasks\")\n    84→\t\t\treturn\n    85→\t\t}\n    86→\t\tcmdTasks(os.Args[2:])\n    87→\t\treturn\n    88→\tcase \"workflow\":\n    89→\t\tif hasHelpFlag(os.Args[2:]) {\n    90→\t\t\tprintSubcommandHelp(\"workflow\")\n    91→\t\t\treturn\n    92→\t\t}\n    93→\t\tcmdWorkflow(os.Args[2:])\n    94→\t\treturn\n    95→\tcase \"project\":\n    96→\t\tif hasHelpFlag(os.Args[2:]) {\n    97→\t\t\tprintSubcommandHelp(\"project\")\n    98→\t\t\treturn\n    99→\t\t}\n   100→\t\tcmdProject(os.Args[2:])\n   101→\t\treturn\n   102→\tcase \"validate\":\n   103→\t\tif hasHelpFlag(os.Args[2:]) {\n   104→\t\t\tprintSubcommandHelp(\"validate\")\n   105→\t\t\treturn\n   106→\t\t}\n   107→\t\tcmdValidate(os.Args[2:])\n   108→\t\treturn\n   109→\t}\n   110→\n   111→\t// Handle --help for daemon commands before connecting\n   112→\tdaemonCmds := map[string]bool{\n   113→\t\t\"run\": true, \"resume\": true, \"status\": true, \"logs\": true, \"poll\": true,\n   114→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n   115→\t}\n   116→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n   117→\t\tprintSubcommandHelp(os.Args[1])\n   118→\t\treturn\n   119→\t}\n   120→\n   121→\t// Commands that need a daemon connection\n   122→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   123→\tif addr == \"\" {\n   124→\t\taddr = config.DefaultSocketAddr()\n   125→\t}\n   126→\n   127→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   128→\tif err != nil {\n   129→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   130→\t\tos.Exit(1)\n   131→\t}\n   132→\tdefer conn.Close()\n   133→\n   134→\tclient := pb.NewClocheServiceClient(conn)\n   135→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   136→\tdefer cancel()\n   137→\n   138→\tswitch os.Args[1] {\n   139→\tcase \"run\":\n   140→\t\tcmdRun(ctx, client, os.Args[2:])\n   141→\tcase \"resume\":\n   142→\t\tcmdResume(ctx, client, os.Args[2:])\n   143→\tcase \"status\":\n   144→\t\tcmdStatus(ctx, client, os.Args[2:])\n   145→\tcase \"logs\":\n   146→\t\tcmdLogs(client, os.Args[2:])\n   147→\tcase \"poll\":\n   148→\t\tcmdPoll(client, os.Args[2:])\n   149→\tcase \"list\":\n   150→\t\tcmdList(ctx, client, os.Args[2:])\n   151→\tcase \"stop\":\n   152→\t\tcmdStop(ctx, client, os.Args[2:])\n   153→\tcase \"delete\":\n   154→\t\tcmdDelete(ctx, client, os.Args[2:])\n   155→\tcase \"loop\":\n   156→\t\tcmdLoop(ctx, client, os.Args[2:])\n   157→\tcase \"shutdown\":\n   158→\t\tcmdShutdown(ctx, client, os.Args[2:])\n   159→\tdefault:\n   160→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   161→\t\tprintTopLevelHelp()\n   162→\t\tos.Exit(1)\n   163→\t}\n   164→}\n   165→\n   166→\n   167→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   168→\tvar workflow, prompt, title, issueID string\n   169→\tvar keepContainer bool\n   170→\n   171→\tfor i := 0; i < len(args); i++ {\n   172→\t\tswitch args[i] {\n   173→\t\tcase \"--workflow\":\n   174→\t\t\tif i+1 < len(args) {\n   175→\t\t\t\ti++\n   176→\t\t\t\tworkflow = args[i]\n   177→\t\t\t}\n   178→\t\tcase \"--prompt\", \"-p\":\n   179→\t\t\tif i+1 < len(args) {\n   180→\t\t\t\ti++\n   181→\t\t\t\tprompt = args[i]\n   182→\t\t\t}\n   183→\t\tcase \"--title\":\n   184→\t\t\tif i+1 < len(args) {\n   185→\t\t\t\ti++\n   186→\t\t\t\ttitle = args[i]\n   187→\t\t\t}\n   188→\t\tcase \"--issue\", \"-i\":\n   189→\t\t\tif i+1 < len(args) {\n   190→\t\t\t\ti++\n   191→\t\t\t\tissueID = args[i]\n   192→\t\t\t}\n   193→\t\tcase \"--keep-container\":\n   194→\t\t\tkeepContainer = true\n   195→\t\tdefault:\n   196→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   197→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   198→\t\t\t\tworkflow = args[i]\n   199→\t\t\t}\n   200→\t\t}\n   201→\t}\n   202→\n   203→\tif workflow == \"\" {\n   204→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"] [--issue ID]\\n\")\n   205→\t\tos.Exit(1)\n   206→\t}\n   207→\n   208→\tcwd, _ := os.Getwd()\n   209→\n   210→\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n   211→\t// Try loading from any .cloche file; only extract image for container workflows.\n   212→\tvar image string\n   213→\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n   214→\t\timage = wf.Config[\"container.image\"]\n   215→\t}\n   216→\n   217→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   218→\t\tWorkflowName:  workflow,\n   219→\t\tProjectDir:    cwd,\n   220→\t\tImage:         image,\n   221→\t\tPrompt:        prompt,\n   222→\t\tKeepContainer: keepContainer,\n   223→\t\tTitle:         title,\n   224→\t\tIssueId:       issueID,\n   225→\t})\n   226→\tif err != nil {\n   227→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   228→\t\tos.Exit(1)\n   229→\t}\n   230→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   231→}\n   232→\n   233→func cmdResume(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   234→\tif len(args) < 1 {\n   235→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche resume <run-id> [step-name]\\n\")\n   236→\t\tos.Exit(1)\n   237→\t}\n   238→\n   239→\trunID := args[0]\n   240→\tstepName := \"\"\n   241→\tif len(args) > 1 {\n   242→\t\tstepName = args[1]\n   243→\t}\n   244→\n   245→\t// Send resume via gRPC metadata on a RunWorkflow call\n   246→\tmd := metadata.Pairs(\n   247→\t\t\"x-cloche-resume-run-id\", runID,\n   248→\t\t\"x-cloche-resume-step\", stepName,\n   249→\t)\n   250→\tctx = metadata.NewOutgoingContext(ctx, md)\n   251→\n   252→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{})\n   253→\tif err != nil {\n   254→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   255→\t\tos.Exit(1)\n   256→\t}\n   257→\tfmt.Printf(\"Resumed run: %s\\n\", resp.RunId)\n   258→}\n   259→\n   260→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   261→\t// Parse flags to detect --all before checking positional args.\n   262→\tvar all bool\n   263→\tvar positional []string\n   264→\tfor _, arg := range args {\n   265→\t\tif arg == \"--all\" {\n   266→\t\t\tall = true\n   267→\t\t} else {\n   268→\t\t\tpositional = append(positional, arg)\n   269→\t\t}\n   270→\t}\n   271→\n   272→\t// If a run ID is provided, show single-run status.\n   273→\tif len(positional) > 0 {\n   274→\t\tcmdStatusRun(ctx, client, positional[0])\n   275→\t\treturn\n   276→\t}\n   277→\n   278→\t// No run ID: show daemon status overview.\n   279→\tcmdStatusOverview(ctx, client, os.Stdout, all)\n   280→}\n   281→\n   282→func cmdStatusRun(ctx context.Context, client pb.ClocheServiceClient, runID string) {\n   283→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: runID})\n   284→\tif err != nil {\n   285→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   286→\t\tos.Exit(1)\n   287→\t}\n   288→\n   289→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   290→\tif resp.Title != \"\" {\n   291→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   292→\t}\n   293→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   294→\tif resp.IsHost {\n   295→\t\tfmt.Printf(\"Type:      host\\n\")\n   296→\t} else {\n   297→\t\tfmt.Printf(\"Type:      container\\n\")\n   298→\t}\n   299→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   300→\tif resp.ContainerId != \"\" {\n   301→\t\tcid := resp.ContainerId\n   302→\t\tif len(cid) > 12 {\n   303→\t\t\tcid = cid[:12]\n   304→\t\t}\n   305→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   306→\t}\n   307→\tif resp.ErrorMessage != \"\" {\n   308→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   309→\t}\n   310→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   311→\tfor _, exec := range resp.StepExecutions {\n   312→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   313→\t}\n   314→}\n   315→\n   316→func cmdStatusOverview(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, all bool) {\n   317→\t// Get daemon version.\n   318→\tverResp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   319→\tif err != nil {\n   320→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   321→\t\tos.Exit(1)\n   322→\t}\n   323→\tfmt.Fprintf(w, \"Daemon version: %s\\n\", verResp.Version)\n   324→\n   325→\tcwd, _ := os.Getwd()\n   326→\t_, hasClocheDir := os.Stat(filepath.Join(cwd, \".cloche\"))\n   327→\n   328→\tif !all && hasClocheDir == nil {\n   329→\t\t// In a project directory: show project-specific info.\n   330→\t\tcmdStatusProject(ctx, client, w, cwd)\n   331→\t} else {\n   332→\t\t// Not in a project directory or --all: show global overview.\n   333→\t\tcmdStatusGlobal(ctx, client, w)\n   334→\t}\n   335→}\n   336→\n   337→func cmdStatusProject(ctx context.Context, client pb.ClocheServiceClient, w io.Writer, projectDir string) {\n   338→\tinfo, err := client.GetProjectInfo(ctx, &pb.GetProjectInfoRequest{ProjectDir: projectDir})\n   339→\tif err != nil {\n   340→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   341→\t\tos.Exit(1)\n   342→\t}\n   343→\n   344→\tfmt.Fprintf(w, \"Project: %s\\n\", info.Name)\n   345→\tfmt.Fprintf(w, \"Concurrency: %d\\n\", info.Concurrency)\n   346→\n   347→\tloopStatus := \"stopped\"\n   348→\tif info.LoopRunning {\n   349→\t\tif info.ErrorHalted {\n   350→\t\t\tloopStatus = \"halted\"\n   351→\t\t} else {\n   352→\t\t\tloopStatus = \"running\"\n   353→\t\t}\n   354→\t}\n   355→\tfmt.Fprintf(w, \"Orchestration loop: %s\\n\", loopStatus)\n   356→\n   357→\t// Fetch runs for the past hour to compute success rate.\n   358→\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: projectDir})\n   359→\tif err != nil {\n   360→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   361→\t\tos.Exit(1)\n   362→\t}\n   363→\n   364→\tvar succeeded int\n   365→\tfor _, run := range listResp.Runs {\n   366→\t\tif run.State == \"succeeded\" {\n   367→\t\t\tsucceeded++\n   368→\t\t}\n   369→\t}\n   370→\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, len(listResp.Runs))\n   371→\n   372→\t// Active runs from project info.\n   373→\tfmt.Fprintf(w, \"Active runs: %d\\n\", len(info.ActiveRuns))\n   374→\tfor _, run := range info.ActiveRuns {\n   375→\t\tdur := formatDuration(run.StartedAt)\n   376→\t\tfmt.Fprintf(w, \"  %s: %s\\n\", run.RunId, dur)\n   377→\t}\n   378→}\n   379→\n   380→func cmdStatusGlobal(ctx context.Context, client pb.ClocheServiceClient, w io.Writer) {\n   381→\t// Fetch all runs (server defaults to past hour when no project filter and not --all).\n   382→\t// We pass All=true but the server returns everything; we filter client-side to past hour.\n   383→\tlistResp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: true})\n   384→\tif err != nil {\n   385→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   386→\t\tos.Exit(1)\n   387→\t}\n   388→\n   389→\tvar succeeded, total, activeCount int\n   390→\ttype activeRun struct {\n   391→\t\tid        string\n   392→\t\tstartedAt string\n   393→\t}\n   394→\tvar actives []activeRun\n   395→\n   396→\toneHourAgo := time.Now().Add(-1 * time.Hour)\n   397→\tfor _, run := range listResp.Runs {\n   398→\t\tparsed, parseErr := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", run.StartedAt)\n   399→\t\tif parseErr != nil {\n   400→\t\t\t// Fall back: count all runs returned.\n   401→\t\t\tparsed = time.Time{}\n   402→\t\t}\n   403→\t\tif !parsed.IsZero() && parsed.Before(oneHourAgo) {\n   404→\t\t\tcontinue\n   405→\t\t}\n   406→\t\ttotal++\n   407→\t\tif run.State == \"succeeded\" {\n   408→\t\t\tsucceeded++\n   409→\t\t}\n   410→\t\tif run.State == \"running\" || run.State == \"pending\" {\n   411→\t\t\tactiveCount++\n   412→\t\t\tactives = append(actives, activeRun{id: run.RunId, startedAt: run.StartedAt})\n   413→\t\t}\n   414→\t}\n   415→\n   416→\tfmt.Fprintf(w, \"Runs (past hour): %d / %d succeeded\\n\", succeeded, total)\n   417→\tfmt.Fprintf(w, \"Active runs: %d\\n\", activeCount)\n   418→\tfor _, a := range actives {\n   419→\t\tdur := formatDuration(a.startedAt)\n   420→\t\tfmt.Fprintf(w, \"  %s: %s\\n\", a.id, dur)\n   421→\t}\n   422→}\n   423→\n   424→// formatDuration parses a Go time string and returns a human-readable duration since then.\n   425→func formatDuration(startedAt string) string {\n   426→\tparsed, err := time.Parse(\"2006-01-02 15:04:05.999999999 -0700 MST\", startedAt)\n   427→\tif err != nil {\n   428→\t\treturn startedAt\n   429→\t}\n   430→\td := time.Since(parsed)\n   431→\tif d < time.Minute {\n   432→\t\treturn fmt.Sprintf(\"%ds\", int(d.Seconds()))\n   433→\t}\n   434→\tif d < time.Hour {\n   435→\t\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n   436→\t}\n   437→\treturn fmt.Sprintf(\"%dh%dm\", int(d.Hours()), int(d.Minutes())%60)\n   438→}\n   439→\n   440→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   441→\tvar all bool\n   442→\tvar projectDir, stateFilter, issueFilter string\n   443→\tvar limit int32\n   444→\n   445→\tfor i := 0; i < len(args); i++ {\n   446→\t\tswitch args[i] {\n   447→\t\tcase \"--all\":\n   448→\t\t\tall = true\n   449→\t\tcase \"--project\", \"-p\":\n   450→\t\t\tif i+1 < len(args) {\n   451→\t\t\t\ti++\n   452→\t\t\t\tprojectDir = args[i]\n   453→\t\t\t}\n   454→\t\tcase \"--state\", \"-s\":\n   455→\t\t\tif i+1 < len(args) {\n   456→\t\t\t\ti++\n   457→\t\t\t\tstateFilter = args[i]\n   458→\t\t\t}\n   459→\t\tcase \"--limit\", \"-n\":\n   460→\t\t\tif i+1 < len(args) {\n   461→\t\t\t\ti++\n   462→\t\t\t\tn, err := strconv.Atoi(args[i])\n   463→\t\t\t\tif err != nil {\n   464→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   465→\t\t\t\t\tos.Exit(1)\n   466→\t\t\t\t}\n   467→\t\t\t\tlimit = int32(n)\n   468→\t\t\t}\n   469→\t\tcase \"--issue\", \"-i\":\n   470→\t\t\tif i+1 < len(args) {\n   471→\t\t\t\ti++\n   472→\t\t\t\tissueFilter = args[i]\n   473→\t\t\t}\n   474→\t\t}\n   475→\t}\n   476→\n   477→\treq := &pb.ListRunsRequest{\n   478→\t\tState:  stateFilter,\n   479→\t\tLimit:  limit,\n   480→\t\tTaskId: issueFilter,\n   481→\t}\n   482→\tif projectDir != \"\" {\n   483→\t\treq.ProjectDir = projectDir\n   484→\t} else if all {\n   485→\t\treq.All = true\n   486→\t} else {\n   487→\t\t// Default: filter to current project\n   488→\t\tcwd, _ := os.Getwd()\n   489→\t\treq.ProjectDir = cwd\n   490→\t}\n   491→\n   492→\tresp, err := client.ListRuns(ctx, req)\n   493→\tif err != nil {\n   494→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   495→\t\tos.Exit(1)\n   496→\t}\n   497→\n   498→\tif len(resp.Runs) == 0 {\n   499→\t\tfmt.Println(\"No runs found.\")\n   500→\t\treturn\n   501→\t}\n   502→\n   503→\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n   504→\tfmt.Fprintln(w, \"RUN ID\\tWORKFLOW\\tSTATE\\tTYPE\\tTASK ID\\tTITLE\\tCONTAINER\\tERROR\")\n   505→\tfor _, run := range resp.Runs {\n   506→\t\trunType := \"container\"\n   507→\t\tif run.IsHost {\n   508→\t\t\trunType = \"host\"\n   509→\t\t}\n   510→\t\ttitle := run.Title\n   511→\t\tif len(title) > 40 {\n   512→\t\t\ttitle = title[:37] + \"...\"\n   513→\t\t}\n   514→\t\terrMsg := run.ErrorMessage\n   515→\t\tif len(errMsg) > 60 {\n   516→\t\t\terrMsg = errMsg[:57] + \"...\"\n   517→\t\t}\n   518→\t\tfmt.Fprintf(w, \"%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\n\",\n   519→\t\t\trun.RunId, run.WorkflowName, run.State, runType,\n   520→\t\t\trun.TaskId, title, run.ContainerId, errMsg)\n   521→\t}\n   522→\tw.Flush()\n   523→}\n   524→\n   525→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   526→\tif len(args) < 1 {\n   527→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n   528→\t\tos.Exit(1)\n   529→\t}\n   530→\n   531→\tvar stepFilter, typeFilter string\n   532→\tvar follow bool\n   533→\tvar limit int\n   534→\trunID := args[0]\n   535→\n   536→\tfor i := 1; i < len(args); i++ {\n   537→\t\tswitch args[i] {\n   538→\t\tcase \"--step\", \"-s\":\n   539→\t\t\tif i+1 < len(args) {\n   540→\t\t\t\ti++\n   541→\t\t\t\tstepFilter = args[i]\n   542→\t\t\t}\n   543→\t\tcase \"--type\":\n   544→\t\t\tif i+1 < len(args) {\n   545→\t\t\t\ti++\n   546→\t\t\t\ttypeFilter = args[i]\n   547→\t\t\t}\n   548→\t\tcase \"--follow\", \"-f\":\n   549→\t\t\tfollow = true\n   550→\t\tcase \"--limit\", \"-l\":\n   551→\t\t\tif i+1 < len(args) {\n   552→\t\t\t\ti++\n   553→\t\t\t\tn, err := strconv.Atoi(args[i])\n   554→\t\t\t\tif err != nil || n < 0 {\n   555→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n   556→\t\t\t\t\tos.Exit(1)\n   557→\t\t\t\t}\n   558→\t\t\t\tlimit = n\n   559→\t\t\t}\n   560→\t\t}\n   561→\t}\n   562→\n   563→\t// Use background context — log output can be large and follow mode blocks.\n   564→\tctx := context.Background()\n   565→\tvar mdPairs []string\n   566→\tif follow {\n   567→\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n   568→\t}\n   569→\tif limit > 0 {\n   570→\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n   571→\t}\n   572→\tif len(mdPairs) > 0 {\n   573→\t\tmd := metadata.Pairs(mdPairs...)\n   574→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   575→\t}\n   576→\n   577→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   578→\t\tRunId:    runID,\n   579→\t\tStepName: stepFilter,\n   580→\t\tLogType:  typeFilter,\n   581→\t})\n   582→\tif err != nil {\n   583→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   584→\t\tos.Exit(1)\n   585→\t}\n   586→\n   587→\tfor {\n   588→\t\tentry, err := stream.Recv()\n   589→\t\tif err != nil {\n   590→\t\t\tif errors.Is(err, io.EOF) {\n   591→\t\t\t\tbreak\n   592→\t\t\t}\n   593→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   594→\t\t\tos.Exit(1)\n   595→\t\t}\n   596→\n   597→\t\tswitch entry.Type {\n   598→\t\tcase \"step_started\":\n   599→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   600→\t\t\tif entry.Message != \"\" {\n   601→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   602→\t\t\t}\n   603→\t\tcase \"step_completed\":\n   604→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   605→\t\t\tif entry.Message != \"\" {\n   606→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   607→\t\t\t}\n   608→\t\tcase \"run_completed\":\n   609→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   610→\t\t\tif entry.Message != \"\" {\n   611→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   612→\t\t\t}\n   613→\t\tcase \"full_log\":\n   614→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   615→\t\tcase \"log\":\n   616→\t\t\t// Live-streamed log line from an active run.\n   617→\t\t\tfmt.Println(entry.Message)\n   618→\t\tdefault:\n   619→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   620→\t\t\tif entry.StepName != \"\" {\n   621→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   622→\t\t\t}\n   623→\t\t\tif entry.Message != \"\" {\n   624→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   625→\t\t\t}\n   626→\t\t}\n   627→\t}\n   628→}\n   629→\n   630→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   631→\tif len(args) < 1 {\n   632→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   633→\t\tos.Exit(1)\n   634→\t}\n   635→\n   636→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   637→\tif err != nil {\n   638→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   639→\t\tos.Exit(1)\n   640→\t}\n   641→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   642→}\n   643→\n   644→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   645→\tif len(args) < 1 {\n   646→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   647→\t\tos.Exit(1)\n   648→\t}\n   649→\n   650→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   651→\tif err != nil {\n   652→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   653→\t\tos.Exit(1)\n   654→\t}\n   655→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   656→}\n   657→\n   658→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   659→\tcwd, _ := os.Getwd()\n   660→\n   661→\t// Check for \"stop\" subcommand\n   662→\tif len(args) > 0 && args[0] == \"stop\" {\n   663→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   664→\t\tif err != nil {\n   665→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   666→\t\t\tos.Exit(1)\n   667→\t\t}\n   668→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   669→\t\treturn\n   670→\t}\n   671→\n   672→\t// Check for \"resume\" subcommand\n   673→\tif len(args) > 0 && args[0] == \"resume\" {\n   674→\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n   675→\t\tif err != nil {\n   676→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   677→\t\t\tos.Exit(1)\n   678→\t\t}\n   679→\t\tfmt.Println(\"Orchestration loop resumed.\")\n   680→\t\treturn\n   681→\t}\n   682→\n   683→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   684→\tvar maxConcurrent int32\n   685→\tfor i := 0; i < len(args); i++ {\n   686→\t\tswitch args[i] {\n   687→\t\tcase \"--max\":\n   688→\t\t\tif i+1 < len(args) {\n   689→\t\t\t\ti++\n   690→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   691→\t\t\t\tif n != 1 || err != nil {\n   692→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   693→\t\t\t\t\tos.Exit(1)\n   694→\t\t\t\t}\n   695→\t\t\t}\n   696→\t\t}\n   697→\t}\n   698→\n   699→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   700→\t\tProjectDir:    cwd,\n   701→\t\tMaxConcurrent: maxConcurrent,\n   702→\t})\n   703→\tif err != nil {\n   704→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   705→\t\tos.Exit(1)\n   706→\t}\n   707→\tif maxConcurrent > 0 {\n   708→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   709→\t} else {\n   710→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   711→\t}\n   712→}\n   713→\n   714→func cmdTasks(args []string) {\n   715→\t// Determine HTTP address from env\n   716→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   717→\tif httpAddr == \"\" {\n   718→\t\thttpAddr = \"localhost:8080\"\n   719→\t}\n   720→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   721→\n   722→\t// Determine project label from --project flag or current directory\n   723→\tprojectDir := \"\"\n   724→\tfor i := 0; i < len(args); i++ {\n   725→\t\tswitch args[i] {\n   726→\t\tcase \"--project\":\n   727→\t\t\tif i+1 < len(args) {\n   728→\t\t\t\ti++\n   729→\t\t\t\tprojectDir = args[i]\n   730→\t\t\t}\n   731→\t\t}\n   732→\t}\n   733→\n   734→\tif projectDir == \"\" {\n   735→\t\tcwd, _ := os.Getwd()\n   736→\t\tprojectDir = filepath.Base(cwd)\n   737→\t}\n   738→\n   739→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   740→\tresp, err := http.Get(tasksURL)\n   741→\tif err != nil {\n   742→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   743→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   744→\t\tos.Exit(1)\n   745→\t}\n   746→\tdefer resp.Body.Close()\n   747→\n   748→\tif resp.StatusCode != 200 {\n   749→\t\tbody, _ := io.ReadAll(resp.Body)\n   750→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   751→\t\tos.Exit(1)\n   752→\t}\n   753→\n   754→\ttype taskEntry struct {\n   755→\t\tID          string `json:\"id\"`\n   756→\t\tStatus      string `json:\"status\"`\n   757→\t\tTitle       string `json:\"title\"`\n   758→\t\tDescription string `json:\"description\"`\n   759→\t\tAssigned    bool   `json:\"assigned\"`\n   760→\t\tAssignedAt  string `json:\"assigned_at\"`\n   761→\t\tRunID       string `json:\"run_id\"`\n   762→\t}\n   763→\n   764→\tvar tasks []taskEntry\n   765→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   766→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   767→\t\tos.Exit(1)\n   768→\t}\n   769→\n   770→\tif len(tasks) == 0 {\n   771→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   772→\t\treturn\n   773→\t}\n   774→\n   775→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   776→\tfor _, t := range tasks {\n   777→\t\tstatus := t.Status\n   778→\t\tif status == \"\" {\n   779→\t\t\tstatus = \"open\"\n   780→\t\t}\n   781→\t\tassigned := \"-\"\n   782→\t\tif t.Assigned {\n   783→\t\t\tassigned = \"yes\"\n   784→\t\t}\n   785→\t\trunID := \"\"\n   786→\t\tif t.RunID != \"\" {\n   787→\t\t\trunID = t.RunID\n   788→\t\t\tif len(runID) > 30 {\n   789→\t\t\t\trunID = runID[:27] + \"...\"\n   790→\t\t\t}\n   791→\t\t}\n   792→\t\ttitle := t.Title\n   793→\t\tif len(title) > 40 {\n   794→\t\t\ttitle = title[:37] + \"...\"\n   795→\t\t}\n   796→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   797→\t}\n   798→}\n   799→\n   800→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   801→\tvar force bool\n   802→\tfor _, a := range args {\n   803→\t\tif a == \"-f\" || a == \"--force\" {\n   804→\t\t\tforce = true\n   805→\t\t}\n   806→\t}\n   807→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n   808→\tif err != nil {\n   809→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   810→\t\tos.Exit(1)\n   811→\t}\n   812→\tfmt.Println(\"Daemon shutting down.\")\n   813→}\n   814→\n   815→// resolveRunContext returns the project directory and run ID for context\n   816→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   817→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   818→func resolveRunContext() (projectDir, runID string, err error) {\n   819→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   820→\tif runID == \"\" {\n   821→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   822→\t}\n   823→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   824→\tif projectDir == \"\" {\n   825→\t\tprojectDir, err = os.Getwd()\n   826→\t\tif err != nil {\n   827→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   828→\t\t}\n   829→\t}\n   830→\treturn projectDir, runID, nil\n   831→}\n   832→\n   833→func cmdGet(args []string) {\n   834→\tif len(args) < 1 {\n   835→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   836→\t\tos.Exit(1)\n   837→\t}\n   838→\n   839→\tprojectDir, runID, err := resolveRunContext()\n   840→\tif err != nil {\n   841→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   842→\t\tos.Exit(1)\n   843→\t}\n   844→\n   845→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   846→\tif err != nil {\n   847→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   848→\t\tos.Exit(1)\n   849→\t}\n   850→\tif !ok {\n   851→\t\tos.Exit(1)\n   852→\t}\n   853→\tfmt.Println(val)\n   854→}\n   855→\n   856→func cmdSet(args []string) {\n   857→\tif len(args) < 2 {\n   858→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   859→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   860→\t\tos.Exit(1)\n   861→\t}\n   862→\n   863→\tprojectDir, runID, err := resolveRunContext()\n   864→\tif err != nil {\n   865→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   866→\t\tos.Exit(1)\n   867→\t}\n   868→\n   869→\tvalue := args[1]\n   870→\tif value == \"-\" {\n   871→\t\tdata, err := io.ReadAll(os.Stdin)\n   872→\t\tif err != nil {\n   873→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   874→\t\t\tos.Exit(1)\n   875→\t\t}\n   876→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   877→\t}\n   878→\n   879→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   880→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   881→\t\tos.Exit(1)\n   882→\t}\n   883→}\n   884→\n   885→func cmdVersion() {\n   886→\tcliVersion := version.Version()\n   887→\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   888→\n   889→\t// Try to get daemon version via gRPC\n   890→\tdaemonVersion := \"<unavailable>\"\n   891→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   892→\tif addr == \"\" {\n   893→\t\taddr = config.DefaultSocketAddr()\n   894→\t}\n   895→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   896→\tif err == nil {\n   897→\t\tdefer conn.Close()\n   898→\t\tclient := pb.NewClocheServiceClient(conn)\n   899→\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   900→\t\tdefer cancel()\n   901→\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   902→\t\tif err == nil {\n   903→\t\t\tdaemonVersion = resp.Version\n   904→\t\t}\n   905→\t}\n   906→\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   907→\n   908→\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   909→\tagentVersion := \"<unavailable>\"\n   910→\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   911→\tif image == \"\" {\n   912→\t\timage = \"cloche-agent:latest\"\n   913→\t}\n   914→\tout, err := exec.CommandContext(\n   915→\t\tcontext.Background(),\n   916→\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   917→\t).Output()\n   918→\tif err == nil {\n   919→\t\tagentVersion = strings.TrimSpace(string(out))\n   920→\t\t// Strip \"cloche-agent \" prefix if present\n   921→\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n   922→\t}\n   923→\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n   924→\n   925→\t// Warn about version mismatches\n   926→\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n   927→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n   928→\t}\n   929→\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n   930→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n   931→\t}\n   932→}\n   933→"}]},"parent_tool_use_id":"toolu_01Qq235q2e7wWvX8zvLYRTqr","session_id":"ab06b6b4-e6b6-4d23-a886-0560ffd72710","uuid":"4de1f250-a47d-497b-8173-e60d16f541cd"}
