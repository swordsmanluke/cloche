if len(s) <= n {\n  1316→\t\treturn s\n  1317→\t}\n  1318→\treturn s[:n] + \"...\"\n  1319→}\n  1320→\n  1321→func shortContainerID(id string) string {\n  1322→\tif len(id) > 12 {\n  1323→\t\treturn id[:12]\n  1324→\t}\n  1325→\treturn id\n  1326→}\n  1327→\n  1328→// projectLabels builds a mapping from full project directory paths to short\n  1329→// display labels. Each label is the final directory component (e.g.\n  1330→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1331→// the same final name, the parent directory is prepended to disambiguate\n  1332→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1333→func projectLabels(dirs []string) map[string]string {\n  1334→\tlabels := make(map[string]string, len(dirs))\n  1335→\t// Group dirs by their base name to detect conflicts.\n  1336→\tbyBase := map[string][]string{}\n  1337→\tfor _, d := range dirs {\n  1338→\t\tbase := filepath.Base(d)\n  1339→\t\tbyBase[base] = append(byBase[base], d)\n  1340→\t}\n  1341→\tfor base, paths := range byBase {\n  1342→\t\tif len(paths) == 1 {\n  1343→\t\t\tlabels[paths[0]] = base\n  1344→\t\t} else {\n  1345→\t\t\tfor _, p := range paths {\n  1346→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1347→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1348→\t\t\t}\n  1349→\t\t}\n  1350→\t}\n  1351→\treturn labels\n  1352→}\n  1353→\n  1354→type projectEntry struct {\n  1355→\tDir            string\n  1356→\tLabel          string\n  1357→\tContainerCount int\n  1358→}\n  1359→"}]},"parent_tool_use_id":"toolu_015ZDbunJk2ByAxCfhffyCug","session_id":"b04f5a15-d4ab-4e77-b440-71d43d500864","uuid":"c2d4012d-d839-4060-bbde-7843ab663ffb"}
