children.length > 0;\n    92→            result.push({ run: r, isParent: isParent, isChild: false });\n    93→            if (children) {\n    94→                for (var j = 0; j < children.length; j++) {\n    95→                    result.push({ run: children[j], isParent: false, isChild: true });\n    96→                }\n    97→            }\n    98→        }\n    99→\n   100→        // Add orphaned children (parent not in current view)\n   101→        for (var i = 0; i < runs.length; i++) {\n   102→            var r = runs[i];\n   103→            if (r.parent_run_id && !byId[r.parent_run_id]) {\n   104→                result.push({ run: r, isParent: false, isChild: true });\n   105→            }\n   106→        }\n   107→\n   108→        return result;\n   109→    }\n   110→\n   111→    function poll() {\n   112→        var url = '/api/runs';\n   113→        if (currentProject) {\n   114→            url += '?project=' + encodeURIComponent(currentProject);\n   115→        }\n   116→        fetch(url)\n   117→            .then(function(r) { return r.json(); })\n   118→            .then(function(runs) {\n   119→                var tbody = document.getElementById('runs-body');\n   120→                if (!runs || runs.length === 0) {\n   121→                    tbody.innerHTML = '<tr><td colspan=\"10\" class=\"empty\">No runs yet.</td></tr>';\n   122→                    return;\n   123→                }\n   124→\n   125→                var grouped = groupRuns(runs);\n   126→                var html = '';\n   127→                for (var i = 0; i < grouped.length; i++) {\n   128→                    var entry = grouped[i];\n   129→                    var r = entry.run;\n   130→                    var cid = r.container_id || '';\n   131→                    if (cid.length > 12) cid = cid.substring(0, 12);\n   132→                    var err = r.error_message || '';\n   133→                    if (err.length > 80) err = err.substring(0, 80) + '...';\n   134→                    var proj = r.project_label || '';\n   135→                    var title = r.title || '';\n   136→                    if (title.length > 50) title = title.substring(0, 47) + '...';\n   137→                    var runType = r.is_host ? 'host' : 'container';\n   138→                    var rowClass = entry.isChild ? 'run-child-row' : (entry.isParent ? 'run-parent-row' : '');\n   139→                    html += '<tr class=\"' + rowClass + '\">' +\n   140→                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n   141→                        '<td>' + escapeHtml(title) + '</td>' +\n   142→                        '<td>' + escapeHtml(proj) + '</td>' +\n   143→                        '<td>' + r.workflow_name + '</td>' +\n   144→                        '<td>' + runType + '</td>' +\n   145→                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n   146→                        '<td>' + r.started_at + '</td>' +\n   147→                        '<td>' + r.completed_at + '</td>' +\n   148→                        '<td class=\"mono\">' + cid + '</td>' +\n   149→                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n   150→                        '</tr>';\n   151→                }\n   152→                tbody.innerHTML = html;\n   153→            })\n   154→            .catch(function() {});\n   155→    }\n   156→    function escapeHtml(s) {\n   157→        var d = document.createElement('div');\n   158→        d.appendChild(document.createTextNode(s));\n   159→        return d.innerHTML;\n   160→    }\n   161→    setInterval(poll, 3000);\n   162→})();\n   163→</script>\n   164→{{end}}\n   165→"}]},"parent_tool_use_id":null,"session_id":"b04f5a15-d4ab-4e77-b440-71d43d500864","uuid":"5ec99c22-6eb5-45cf-99cd-5a2426215b27","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/runs.html","content":"{{define \"content\"}}\n<h1>Runs</h1>\n{{if .Projects}}\n<div class=\"project-filter\">\n    <label for=\"project-select\">Project:</label>\n    <select id=\"project-select\" onchange=\"filterByProject(this.value)\">\n        <option value=\"\">All projects</option>\n        {{range .Projects}}\n        <option value=\"{{.Dir}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>\n        {{end}}\n    </select>\n</div>\n{{end}}\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Run ID</th>\n            <th>Title</th>\n            <th>Project</th>\n            <th>Workflow</th>\n            <th>Type</th>\n            <th>State</th>\n            <th>Started</th>\n            <th>Completed</th>\n            <th>Container</th>\n            <th>Error</th>\n        </tr>\n    </thead>\n    <tbody id=\"runs-body\">\n    {{if .Runs}}\n        {{range .Runs}}\n        <tr class=\"{{if .ParentRunID}}run-child-row{{else if .IsHost}}run-parent-row{{end}}\">\n            <td><a href=\"/runs/{{.ID}}\">{{.ID}}</a></td>\n            <td>{{truncate .Title 50}}</td>\n            <td>{{index $.ProjectLabels .ProjectDir}}</td>\n            <td>{{.WorkflowName}}</td>\n            <td>{{if .IsHost}}host{{else}}container{{end}}</td>\n            <td><span class=\"badge badge-{{stateColor .State}}\">{{.State}}</span></td>\n            <td>{{formatTime .StartedAt}}</td>\n            <td>{{formatTime .CompletedAt}}</td>\n            <td class=\"mono\">{{shortContainerID .ContainerID}}</td>\n            <td class=\"error-cell\">{{truncate .ErrorMessage 80}}</td>\n        </tr>\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"10\" class=\"empty\">No runs yet.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var currentProject = '{{.ProjectFilter}}';\n\n    function filterByProject(dir) {\n        if (dir) {\n            window.location.href = '/runs?project=' + encodeURIComponent(dir);\n        } else {\n            window.location.href = '/runs';\n        }\n    }\n    window.filterByProject = filterByProject;\n\n    // groupRuns arranges runs so children appear directly after their parent.\n    // Parents are de-emphasized; children (where active work happens) are prominent.\n    function groupRuns(runs) {\n        var parentMap = {};  // parent_run_id -> [children]\n        var topLevel = [];\n        var byId = {};\n\n        for (var i = 0; i < runs.length; i++) {\n            byId[runs[i].id] = runs[i];\n        }\n\n        for (var i = 0; i < runs.length; i++) {\n            var r = runs[i];\n            if (r.parent_run_id && byId[r.parent_run_id]) {\n                if (!parentMap[r.parent_run_id]) parentMap[r.parent_run_id] = [];\n                parentMap[r.parent_run_id].push(r);\n            } else {\n                topLevel.push(r);\n            }\n        }\n\n        var result = [];\n        for (var i = 0; i < topLevel.length; i++) {\n            var r = topLevel[i];\n            var children = parentMap[r.id];\n            var isParent = children && children.length > 0;\n            result.push({ run: r, isParent: isParent, isChild: false });\n            if (children) {\n                for (var j = 0; j < children.length; j++) {\n                    result.push({ run: children[j], isParent: false, isChild: true });\n                }\n            }\n        }\n\n        // Add orphaned children (parent not in current view)\n        for (var i = 0; i < runs.length; i++) {\n            var r = runs[i];\n            if (r.parent_run_id && !byId[r.parent_run_id]) {\n                result.push({ run: r, isParent: false, isChild: true });\n            }\n        }\n\n        return result;\n    }\n\n    function poll() {\n        var url = '/api/runs';\n        if (currentProject) {\n            url += '?project=' + encodeURIComponent(currentProject);\n        }\n        fetch(url)\n            .then(function(r) { return r.json(); })\n            .then(function(runs) {\n                var tbody = document.getElementById('runs-body');\n                if (!runs || runs.length === 0) {\n                    tbody.innerHTML = '<tr><td colspan=\"10\" class=\"empty\">No runs yet.</td></tr>';\n                    return;\n                }\n\n                var grouped = groupRuns(runs);\n                var html = '';\n                for (var i = 0; i < grouped.length; i++) {\n                    var entry = grouped[i];\n                    var r = entry.run;\n                    var cid = r.container_id || '';\n                    if (cid.length > 12) cid = cid.substring(0, 12);\n                    var err = r.error_message || '';\n                    if (err.length > 80) err = err.substring(0, 80) + '...';\n                    var proj = r.project_label || '';\n                    var title = r.title || '';\n                    if (title.length > 50) title = title.substring(0, 47) + '...';\n                    var runType = r.is_host ? 'host' : 'container';\n                    var rowClass = entry.isChild ? 'run-child-row' : (entry.isParent ? 'run-parent-row' : '');\n                    html += '<tr class=\"' + rowClass + '\">' +\n                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n                        '<td>' + escapeHtml(title) + '</td>' +\n                        '<td>' + escapeHtml(proj) + '</td>' +\n                        '<td>' + r.workflow_name + '</td>' +\n                        '<td>' + runType + '</td>' +\n                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n                        '<td>' + r.started_at + '</td>' +\n                        '<td>' + r.completed_at + '</td>' +\n                        '<td class=\"mono\">' + cid + '</td>' +\n                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                        '</tr>';\n                }\n                tbody.innerHTML = html;\n            })\n            .catch(function() {});\n    }\n    function escapeHtml(s) {\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n    setInterval(poll, 3000);\n})();\n</script>\n{{end}}\n","numLines":165,"startLine":1,"totalLines":165}}}
