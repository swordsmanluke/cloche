[2026-03-10T21:33:12Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016ZcjxJDvhvhUe6voMx5fEE","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"net/url\"\n    13→\t\"os\"\n    14→\t\"os/exec\"\n    15→\t\"path/filepath\"\n    16→\t\"regexp\"\n    17→\t\"sort\"\n    18→\t\"strconv\"\n    19→\t\"strings\"\n    20→\t\"time\"\n    21→\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    24→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    25→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    26→)\n    27→\n    28→// HandlerOption configures optional Handler dependencies.\n    29→type HandlerOption func(*Handler)\n    30→\n    31→// WithContainerLogger sets the container runtime for fetching live logs.\n    32→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    33→\treturn func(h *Handler) { h.container = c }\n    34→}\n    35→\n    36→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    37→func WithContainerManager(c ContainerManager) HandlerOption {\n    38→\treturn func(h *Handler) { h.container = c }\n    39→}\n    40→\n    41→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    42→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    43→\treturn func(h *Handler) { h.logBroadcast = b }\n    44→}\n    45→\n    46→// WithLogStore sets the log store for indexed log file lookups.\n    47→func WithLogStore(ls ports.LogStore) HandlerOption {\n    48→\treturn func(h *Handler) { h.logStore = ls }\n    49→}\n    50→\n    51→//go:embed templates/*.html static/*\n    52→var content embed.FS\n    53→\n    54→// Handler serves the web dashboard.\n    55→// ContainerLogger can retrieve logs from a container by ID.\n    56→type ContainerLogger interface {\n    57→\tLogs(ctx context.Context, containerID string) (string, error)\n    58→}\n    59→\n    60→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    61→type ContainerManager interface {\n    62→\tContainerLogger\n    63→\tStop(ctx context.Context, containerID string) error\n    64→\tRemove(ctx context.Context, containerID string) error\n    65→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    66→}\n    67→\n    68→type Handler struct {\n    69→\tstore        ports.RunStore\n    70→\tcaptures     ports.CaptureStore\n    71→\tlogStore     ports.LogStore\n    72→\tcontainer    ContainerLogger\n    73→\tlogBroadcast *logstream.Broadcaster\n    74→\tpages        map[string]*template.Template\n    75→\tmux          *http.ServeMux\n    76→}\n    77→\n    78→// NewHandler creates a web dashboard handler.\n    79→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    80→\tfuncMap := template.FuncMap{\n    81→\t\t\"stateColor\":       stateColor,\n    82→\t\t\"healthColor\":      healthColor,\n    83→\t\t\"formatTime\":       formatTime,\n    84→\t\t\"formatDuration\":   formatDuration,\n    85→\t\t\"truncate\":         truncate,\n    86→\t\t\"shortContainerID\": shortContainerID,\n    87→\t}\n    88→\n    89→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n    90→\tif err != nil {\n    91→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n    92→\t}\n    93→\n    94→\tpages := map[string]*template.Template{}\n    95→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n    96→\t\tclone, err := base.Clone()\n    97→\t\tif err != nil {\n    98→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n    99→\t\t}\n   100→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   101→\t\tif err != nil {\n   102→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   103→\t\t}\n   104→\t\tpages[page] = clone\n   105→\t}\n   106→\n   107→\th := &Handler{\n   108→\t\tstore:    store,\n   109→\t\tcaptures: captures,\n   110→\t\tpages:    pages,\n   111→\t\tmux:      http.NewServeMux(),\n   112→\t}\n   113→\tfor _, opt := range opts {\n   114→\t\topt(h)\n   115→\t}\n   116→\n   117→\tstaticFS, err := fs.Sub(content, \"static\")\n   118→\tif err != nil {\n   119→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   120→\t}\n   121→\n   122→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   123→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   124→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   125→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   126→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   127→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   128→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   129→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   130→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   131→\th.mux.HandleFunc(\"POST /api/runs/{id}/stop\", h.handleAPIStopRun)\n   132→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   133→\th.mux.HandleFunc(\"DELETE /api/projects/{name}/containers\", h.handleAPIDeleteProjectContainers)\n   134→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   135→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   136→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   137→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   138→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   139→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   140→\n   141→\treturn h, nil\n   142→}\n   143→\n   144→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   145→\th.mux.ServeHTTP(w, r)\n   146→}\n   147→\n   148→// --- HTML handlers ---\n   149→\n   150→// projectOverviewEntry holds data for a single project card on the landing page.\n   151→type projectOverviewEntry struct {\n   152→\tDir         string\n   153→\tLabel       string\n   154→\tHealth      domain.HealthResult\n   155→\tRecentRuns  []recentRunDot\n   156→\tActiveCount int\n   157→}\n   158→\n   159→// recentRunDot is a minimal representation of a run for the mini history display.\n   160→type recentRunDot struct {\n   161→\tID    string\n   162→\tState string\n   163→}\n   164→\n   165→const healthWindowSize = 10\n   166→\n   167→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   168→\tprojects, _ := h.store.ListProjects(r.Context())\n   169→\tlabels := projectLabels(projects)\n   170→\n   171→\tvar entries []projectOverviewEntry\n   172→\tfor _, dir := range projects {\n   173→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   174→\t\tif err != nil {\n   175→\t\t\tcontinue\n   176→\t\t}\n   177→\n   178→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   179→\t\trunValues := make([]domain.Run, len(runs))\n   180→\t\tfor i, rr := range runs {\n   181→\t\t\trunValues[i] = *rr\n   182→\t\t}\n   183→\n   184→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   185→\n   186→\t\t// Take the last N runs for the mini history (most recent first).\n   187→\t\tn := healthWindowSize\n   188→\t\tif n > len(runs) {\n   189→\t\t\tn = len(runs)\n   190→\t\t}\n   191→\t\tdots := make([]recentRunDot, n)\n   192→\t\tfor i := 0; i < n; i++ {\n   193→\t\t\tdots[i] = recentRunDot{\n   194→\t\t\t\tID:    runs[i].ID,\n   195→\t\t\t\tState: string(runs[i].State),\n   196→\t\t\t}\n   197→\t\t}\n   198→\n   199→\t\tvar activeCount int\n   200→\t\tfor _, rr := range runs {\n   201→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   202→\t\t\t\tactiveCount++\n   203→\t\t\t}\n   204→\t\t}\n   205→\n   206→\t\tentries = append(entries, projectOverviewEntry{\n   207→\t\t\tDir:         dir,\n   208→\t\t\tLabel:       labels[dir],\n   209→\t\t\tHealth:      health,\n   210→\t\t\tRecentRuns:  dots,\n   211→\t\t\tActiveCount: activeCount,\n   212→\t\t})\n   213→\t}\n   214→\n   215→\tsort.Slice(entries, func(i, j int) bool {\n   216→\t\treturn entries[i].Label < entries[j].Label\n   217→\t})\n   218→\n   219→\tdata := map[string]any{\n   220→\t\t\"Title\":    \"Projects\",\n   221→\t\t\"Projects\": entries,\n   222→\t}\n   223→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   224→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   225→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   226→\t}\n   227→}\n   228→\n   229→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   230→\tprojectFilter := r.URL.Query().Get(\"project\")\n   231→\n   232→\tvar runs []*domain.Run\n   233→\tvar err error\n   234→\tif projectFilter != \"\" {\n   235→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   236→\t} else {\n   237→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   238→\t}\n   239→\tif err != nil {\n   240→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   241→\t\treturn\n   242→\t}\n   243→\n   244→\tprojects, _ := h.store.ListProjects(r.Context())\n   245→\tlabels := projectLabels(projects)\n   246→\n   247→\t// Count retained containers per project\n   248→\tcontainerCounts := map[string]int{}\n   249→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   250→\tfor _, run := range allRuns {\n   251→\t\tif run.ContainerKept {\n   252→\t\t\tcontainerCounts[run.ProjectDir]++\n   253→\t\t}\n   254→\t}\n   255→\n   256→\tvar projectList []projectEntry\n   257→\tfor _, dir := range projects {\n   258→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   259→\t}\n   260→\tsort.Slice(projectList, func(i, j int) bool {\n   261→\t\treturn projectList[i].Label < projectList[j].Label\n   262→\t})\n   263→\n   264→\tdata := map[string]any{\n   265→\t\t\"Title\":         \"Runs\",\n   266→\t\t\"Runs\":          runs,\n   267→\t\t\"Projects\":      projectList,\n   268→\t\t\"ProjectFilter\": projectFilter,\n   269→\t\t\"ProjectLabels\": labels,\n   270→\t}\n   271→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   272→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   273→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   274→\t}\n   275→}\n   276→\n   277→// handleProjectRuns redirects /projects/{name}/runs to /runs?project=<dir>.\n   278→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   279→\tdir, _, ok := h.resolveProjectDir(w, r)\n   280→\tif !ok {\n   281→\t\treturn\n   282→\t}\n   283→\thttp.Redirect(w, r, \"/runs?project=\"+url.QueryEscape(dir), http.StatusFound)\n   284→}\n   285→\n   286→// stepEntry is a merged view of a step execution for the template.\n   287→type stepEntry struct {\n   288→\tIndex     int\n   289→\tStepName  string\n   290→\tResult    string\n   291→\tStartedAt time.Time\n   292→\tDuration  string\n   293→}\n   294→\n   295→// mergeCaptures collapses started/completed capture pairs into single entries.\n   296→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   297→\tvar entries []stepEntry\n   298→\t// Track pending started rows by step name (LIFO for retries)\n   299→\tpending := map[string]*domain.StepExecution{}\n   300→\n   301→\tfor _, c := range caps {\n   302→\t\tif c.Result == \"\" {\n   303→\t\t\t// step_started row\n   304→\t\t\tpending[c.StepName] = c\n   305→\t\t\tcontinue\n   306→\t\t}\n   307→\t\t// step_completed row — merge with pending started if available\n   308→\t\tstartedAt := c.StartedAt\n   309→\t\tif started := pending[c.StepName]; started != nil {\n   310→\t\t\tstartedAt = started.StartedAt\n   311→\t\t\tdelete(pending, c.StepName)\n   312→\t\t}\n   313→\t\tentries = append(entries, stepEntry{\n   314→\t\t\tIndex:     len(entries),\n   315→\t\t\tStepName:  c.StepName,\n   316→\t\t\tResult:    c.Result,\n   317→\t\t\tStartedAt: startedAt,\n   318→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   319→\t\t})\n   320→\t}\n   321→\n   322→\t// Append any started-but-not-completed steps (still running)\n   323→\tfor _, c := range caps {\n   324→\t\tif c.Result == \"\" {\n   325→\t\t\tif _, used := pending[c.StepName]; !used {\n   326→\t\t\t\tcontinue\n   327→\t\t\t}\n   328→\t\t\tentries = append(entries, stepEntry{\n   329→\t\t\t\tIndex:     len(entries),\n   330→\t\t\t\tStepName:  c.StepName,\n   331→\t\t\t\tStartedAt: c.StartedAt,\n   332→\t\t\t})\n   333→\t\t\tdelete(pending, c.StepName)\n   334→\t\t}\n   335→\t}\n   336→\n   337→\treturn entries\n   338→}\n   339→\n   340→// containerState inspects the container for a run and returns one of:\n   341→//   - \"running\"   – container exists and is running\n   342→//   - \"stopped\"   – container exists, not running, not kept\n   343→//   - \"available\" – container exists, not running, kept (can be deleted)\n   344→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   345→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   346→\tif run.ContainerID == \"\" {\n   347→\t\treturn \"removed\"\n   348→\t}\n   349→\tmgr, ok := h.container.(ContainerManager)\n   350→\tif !ok {\n   351→\t\treturn \"removed\"\n   352→\t}\n   353→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   354→\tif err != nil {\n   355→\t\treturn \"removed\"\n   356→\t}\n   357→\tif status.Running {\n   358→\t\treturn \"running\"\n   359→\t}\n   360→\tif run.ContainerKept {\n   361→\t\treturn \"available\"\n   362→\t}\n   363→\treturn \"stopped\"\n   364→}\n   365→\n   366→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   367→\tid := r.PathValue(\"id\")\n   368→\n   369→\trun, err := h.store.GetRun(r.Context(), id)\n   370→\tif err != nil {\n   371→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   372→\t\treturn\n   373→\t}\n   374→\n   375→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   376→\tif err != nil {\n   377→\t\tcaps = nil // non-fatal\n   378→\t}\n   379→\n   380→\tsteps := mergeCaptures(caps)\n   381→\n   382→\t// Fetch parent run if this is a child\n   383→\tvar parentRun *domain.Run\n   384→\tif run.ParentRunID != \"\" {\n   385→\t\tparentRun, _ = h.store.GetRun(r.Context(), run.ParentRunID)\n   386→\t}\n   387→\n   388→\t// Fetch child runs\n   389→\tchildRuns, _ := h.store.ListChildRuns(r.Context(), id)\n   390→\n   391→\tdata := map[string]any{\n   392→\t\t\"Title\":          \"Run \" + run.ID,\n   393→\t\t\"Run\":            run,\n   394→\t\t\"Steps\":          steps,\n   395→\t\t\"Page\":           \"detail\",\n   396→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   397→\t\t\"ParentRun\":      parentRun,\n   398→\t\t\"ChildRuns\":      childRuns,\n   399→\t}\n   400→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   401→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   402→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   403→\t}\n   404→}\n   405→\n   406→// --- JSON API handlers ---\n   407→\n   408→type apiRun struct {\n   409→\tID           string `json:\"id\"`\n   410→\tWorkflowName string `json:\"workflow_name\"`\n   411→\tProjectDir   string `json:\"project_dir\"`\n   412→\tProjectLabel string `json:\"project_label\"`\n   413→\tState        string `json:\"state\"`\n   414→\tStartedAt    string `json:\"started_at\"`\n   415→\tCompletedAt  string `json:\"completed_at\"`\n   416→\tContainerID  string `json:\"container_id\"`\n   417→\tErrorMessage string `json:\"error_message\"`\n   418→\tTitle        string `json:\"title\"`\n   419→\tIsHost       bool   `json:\"is_host\"`\n   420→\tParentRunID  string `json:\"parent_run_id,omitempty\"`\n   421→}\n   422→\n   423→type apiStep struct {\n   424→\tStepName    string `json:\"step_name\"`\n   425→\tResult      string `json:\"result\"`\n   426→\tStartedAt   string `json:\"started_at\"`\n   427→\tCompletedAt string `json:\"completed_at\"`\n   428→\tDuration    string `json:\"duration\"`\n   429→}\n   430→\n   431→type apiRunDetail struct {\n   432→\tapiRun\n   433→\tContainerState string    `json:\"container_state\"`\n   434→\tSteps          []apiStep `json:\"steps\"`\n   435→\tChildRuns      []apiRun  `json:\"child_runs,omitempty\"`\n   436→}\n   437→\n   438→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   439→\treturn apiRun{\n   440→\t\tID:           r.ID,\n   441→\t\tWorkflowName: r.WorkflowName,\n   442→\t\tProjectDir:   r.ProjectDir,\n   443→\t\tProjectLabel: labels[r.ProjectDir],\n   444→\t\tState:        string(r.State),\n   445→\t\tStartedAt:    formatTime(r.StartedAt),\n   446→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   447→\t\tContainerID:  r.ContainerID,\n   448→\t\tErrorMessage: r.ErrorMessage,\n   449→\t\tTitle:        r.Title,\n   450→\t\tIsHost:       r.IsHost,\n   451→\t\tParentRunID:  r.ParentRunID,\n   452→\t}\n   453→}\n   454→\n   455→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   456→\tprojectFilter := r.URL.Query().Get(\"project\")\n   457→\n   458→\tvar runs []*domain.Run\n   459→\tvar err error\n   460→\tif projectFilter != \"\" {\n   461→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   462→\t} else {\n   463→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   464→\t}\n   465→\tif err != nil {\n   466→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   467→\t\treturn\n   468→\t}\n   469→\n   470→\tprojects, _ := h.store.ListProjects(r.Context())\n   471→\tlabels := projectLabels(projects)\n   472→\n   473→\tresult := make([]apiRun, len(runs))\n   474→\tfor i, run := range runs {\n   475→\t\tresult[i] = toAPIRun(run, labels)\n   476→\t}\n   477→\n   478→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   479→\tjson.NewEncoder(w).Encode(result)\n   480→}\n   481→\n   482→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   483→\tprojects, err := h.store.ListProjects(r.Context())\n   484→\tif err != nil {\n   485→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   486→\t\treturn\n   487→\t}\n   488→\tlabels := projectLabels(projects)\n   489→\n   490→\ttype apiHealth struct {\n   491→\t\tStatus string `json:\"status\"`\n   492→\t\tPassed int    `json:\"passed\"`\n   493→\t\tFailed int    `json:\"failed\"`\n   494→\t\tTotal  int    `json:\"total\"`\n   495→\t}\n   496→\ttype apiProject struct {\n   497→\t\tDir         string    `json:\"dir\"`\n   498→\t\tLabel       string    `json:\"label\"`\n   499→\t\tHealth      apiHealth `json:\"health\"`\n   500→\t\tActiveCount int       `json:\"active_count\"`\n   501→\t}\n   502→\tresult := make([]apiProject, len(projects))\n   503→\tfor i, dir := range projects {\n   504→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   505→\t\trunValues := make([]domain.Run, len(runs))\n   506→\t\tfor j, rr := range runs {\n   507→\t\t\trunValues[j] = *rr\n   508→\t\t}\n   509→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   510→\t\tvar activeCount int\n   511→\t\tfor _, rr := range runs {\n   512→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   513→\t\t\t\tactiveCount++\n   514→\t\t\t}\n   515→\t\t}\n   516→\t\tresult[i] = apiProject{\n   517→\t\t\tDir:   dir,\n   518→\t\t\tLabel: labels[dir],\n   519→\t\t\tHealth: apiHealth{\n   520→\t\t\t\tStatus: string(health.Status),\n   521→\t\t\t\tPassed: health.Passed,\n   522→\t\t\t\tFailed: health.Failed,\n   523→\t\t\t\tTotal:  health.Total,\n   524→\t\t\t},\n   525→\t\t\tActiveCount: activeCount,\n   526→\t\t}\n   527→\t}\n   528→\n   529→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   530→\tjson.NewEncoder(w).Encode(result)\n   531→}\n   532→\n   533→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   534→\tid := r.PathValue(\"id\")\n   535→\n   536→\trun, err := h.store.GetRun(r.Context(), id)\n   537→\tif err != nil {\n   538→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   539→\t\treturn\n   540→\t}\n   541→\n   542→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   543→\tif err != nil {\n   544→\t\tcaps = nil\n   545→\t}\n   546→\n   547→\tprojects, _ := h.store.ListProjects(r.Context())\n   548→\tlabels := projectLabels(projects)\n   549→\n   550→\tmerged := mergeCaptures(caps)\n   551→\tsteps := make([]apiStep, len(merged))\n   552→\tfor i, e := range merged {\n   553→\t\tsteps[i] = apiStep{\n   554→\t\t\tStepName:  e.StepName,\n   555→\t\t\tResult:    e.Result,\n   556→\t\t\tStartedAt: formatTime(e.StartedAt),\n   557→\t\t\tDuration:  e.Duration,\n   558→\t\t}\n   559→\t}\n   560→\n   561→\t// Fetch child runs for the API response\n   562→\tvar apiChildren []apiRun\n   563→\tif children, err := h.store.ListChildRuns(r.Context(), id); err == nil {\n   564→\t\tfor _, c := range children {\n   565→\t\t\tapiChildren = append(apiChildren, toAPIRun(c, labels))\n   566→\t\t}\n   567→\t}\n   568→\n   569→\tdetail := apiRunDetail{\n   570→\t\tapiRun:         toAPIRun(run, labels),\n   571→\t\tContainerState: h.containerState(r.Context(), run),\n   572→\t\tSteps:          steps,\n   573→\t\tChildRuns:      apiChildren,\n   574→\t}\n   575→\n   576→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   577→\tjson.NewEncoder(w).Encode(detail)\n   578→}\n   579→\n   580→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   581→\tid := r.PathValue(\"id\")\n   582→\tstep := r.PathValue(\"step\")\n   583→\tlogType := r.URL.Query().Get(\"type\")   // optional: \"script\", \"llm\"\n   584→\tformat := r.URL.Query().Get(\"format\")  // optional: \"raw\" to skip parsing\n   585→\n   586→\trun, err := h.store.GetRun(r.Context(), id)\n   587→\tif err != nil {\n   588→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   589→\t\treturn\n   590→\t}\n   591→\n   592→\twriteOutput := func(data []byte) {\n   593→\t\tif format != \"raw\" {\n   594→\t\t\tdata = logstream.ParseClaudeStream(data)\n   595→\t\t}\n   596→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   597→\t\tw.Write(data)\n   598→\t}\n   599→\n   600→\t// Try log index first for fast lookup\n   601→\tif h.logStore != nil {\n   602→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   603→\t\tif err == nil && len(logFiles) > 0 {\n   604→\t\t\t// If type filter specified, narrow results\n   605→\t\t\tfor _, lf := range logFiles {\n   606→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   607→\t\t\t\t\tcontinue\n   608→\t\t\t\t}\n   609→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   610→\t\t\t\tif readErr == nil && len(data) > 0 {\n   611→\t\t\t\t\twriteOutput(data)\n   612→\t\t\t\t\treturn\n   613→\t\t\t\t}\n   614→\t\t\t}\n   615→\t\t}\n   616→\t}\n   617→\n   618→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   619→\n   620→\t// Fall back to file path conventions\n   621→\t// If type is \"llm\", try llm-<step>.log\n   622→\tif logType == \"llm\" {\n   623→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   624→\t\tdata, err := os.ReadFile(llmPath)\n   625→\t\tif err == nil && len(data) > 0 {\n   626→\t\t\twriteOutput(data)\n   627→\t\t\treturn\n   628→\t\t}\n   629→\t}\n   630→\n   631→\t// Try per-step output first, fall back to container.log, then live docker logs\n   632→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   633→\tdata, err := os.ReadFile(outputPath)\n   634→\tif err == nil && len(data) > 0 {\n   635→\t\twriteOutput(data)\n   636→\t\treturn\n   637→\t}\n   638→\n   639→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   640→\tdata, err = os.ReadFile(containerLog)\n   641→\tif err == nil && len(data) > 0 {\n   642→\t\twriteOutput(data)\n   643→\t\treturn\n   644→\t}\n   645→\n   646→\t// Last resort: try live docker logs from still-existing container\n   647→\tif h.container != nil && run.ContainerID != \"\" {\n   648→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   649→\t\t\twriteOutput([]byte(logs))\n   650→\t\t\treturn\n   651→\t\t}\n   652→\t}\n   653→\n   654→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   655→}\n   656→\n   657→func (h *Handler) handleAPIStopRun(w http.ResponseWriter, r *http.Request) {\n   658→\tid := r.PathValue(\"id\")\n   659→\n   660→\trun, err := h.store.GetRun(r.Context(), id)\n   661→\tif err != nil {\n   662→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   663→\t\tw.WriteHeader(http.StatusNotFound)\n   664→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   665→\t\treturn\n   666→\t}\n   667→\n   668→\t// Only allow stopping active runs\n   669→\tif run.State != domain.RunStatePending && run.State != domain.RunStateRunning {\n   670→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   671→\t\tw.WriteHeader(http.StatusBadRequest)\n   672→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run is not active\"})\n   673→\t\treturn\n   674→\t}\n   675→\n   676→\tmgr, ok := h.container.(ContainerManager)\n   677→\tif !ok || run.ContainerID == \"\" {\n   678→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   679→\t\tw.WriteHeader(http.StatusBadRequest)\n   680→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   681→\t\treturn\n   682→\t}\n   683→\n   684→\tif err := mgr.Stop(r.Context(), run.ContainerID); err != nil {\n   685→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   686→\t\tw.WriteHeader(http.StatusInternalServerError)\n   687→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to stop run: %v\", err)})\n   688→\t\treturn\n   689→\t}\n   690→\n   691→\trun.Complete(domain.RunStateCancelled)\n   692→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   693→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   694→\t\tw.WriteHeader(http.StatusInternalServerError)\n   695→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   696→\t\treturn\n   697→\t}\n   698→\n   699→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   700→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   701→}\n   702→\n   703→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   704→\tid := r.PathValue(\"id\")\n   705→\n   706→\trun, err := h.store.GetRun(r.Context(), id)\n   707→\tif err != nil {\n   708→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   709→\t\tw.WriteHeader(http.StatusNotFound)\n   710→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   711→\t\treturn\n   712→\t}\n   713→\n   714→\tmgr, ok := h.container.(ContainerManager)\n   715→\tif !ok || run.ContainerID == \"\" {\n   716→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   717→\t\tw.WriteHeader(http.StatusBadRequest)\n   718→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   719→\t\treturn\n   720→\t}\n   721→\n   722→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   723→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   724→\t\tw.WriteHeader(http.StatusInternalServerError)\n   725→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   726→\t\treturn\n   727→\t}\n   728→\n   729→\trun.ContainerKept = false\n   730→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   731→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   732→\t\tw.WriteHeader(http.StatusInternalServerError)\n   733→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   734→\t\treturn\n   735→\t}\n   736→\n   737→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   738→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   739→}\n   740→\n   741→// handleAPIDeleteProjectContainers mass-deletes all retained/exited containers for a project.\n   742→func (h *Handler) handleAPIDeleteProjectContainers(w http.ResponseWriter, r *http.Request) {\n   743→\tdir, _, ok := h.resolveProjectDir(w, r)\n   744→\tif !ok {\n   745→\t\treturn\n   746→\t}\n   747→\n   748→\tmgr, ok := h.container.(ContainerManager)\n   749→\tif !ok {\n   750→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   751→\t\tw.WriteHeader(http.StatusBadRequest)\n   752→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   753→\t\treturn\n   754→\t}\n   755→\n   756→\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   757→\tif err != nil {\n   758→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   759→\t\tw.WriteHeader(http.StatusInternalServerError)\n   760→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"failed to list runs\"})\n   761→\t\treturn\n   762→\t}\n   763→\n   764→\tvar deleted int\n   765→\tvar errors []string\n   766→\tfor _, run := range runs {\n   767→\t\tif !run.ContainerKept || run.ContainerID == \"\" {\n   768→\t\t\tcontinue\n   769→\t\t}\n   770→\t\t// Check container is not running\n   771→\t\tstatus, err := mgr.Inspect(r.Context(), run.ContainerID)\n   772→\t\tif err != nil {\n   773→\t\t\t// Container already gone — just clear the flag\n   774→\t\t\trun.ContainerKept = false\n   775→\t\t\th.store.UpdateRun(r.Context(), run)\n   776→\t\t\tdeleted++\n   777→\t\t\tcontinue\n   778→\t\t}\n   779→\t\tif status.Running {\n   780→\t\t\tcontinue // skip running containers\n   781→\t\t}\n   782→\t\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   783→\t\t\terrors = append(errors, fmt.Sprintf(\"%s: %v\", run.ID, err))\n   784→\t\t\tcontinue\n   785→\t\t}\n   786→\t\trun.ContainerKept = false\n   787→\t\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   788→\t\t\terrors = append(errors, fmt.Sprintf(\"%s: update failed: %v\", run.ID, err))\n   789→\t\t\tcontinue\n   790→\t\t}\n   791→\t\tdeleted++\n   792→\t}\n   793→\n   794→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   795→\tresp := map[string]any{\"deleted\": deleted}\n   796→\tif len(errors) > 0 {\n   797→\t\tresp[\"errors\"] = errors\n   798→\t}\n   799→\tjson.NewEncoder(w).Encode(resp)\n   800→}\n   801→\n   802→// handleAPIStream serves an SSE stream of log lines for a run.\n   803→// For active runs, it subscribes to the live broadcaster.\n   804→// For completed runs, it serves the archived full.log then closes.\n   805→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   806→\tid := r.PathValue(\"id\")\n   807→\n   808→\trun, err := h.store.GetRun(r.Context(), id)\n   809→\tif err != nil {\n   810→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   811→\t\treturn\n   812→\t}\n   813→\n   814→\tflusher, ok := w.(http.Flusher)\n   815→\tif !ok {\n   816→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   817→\t\treturn\n   818→\t}\n   819→\n   820→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   821→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   822→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   823→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   824→\n   825→\tisComplete := run.State == domain.RunStateSucceeded ||\n   826→\t\trun.State == domain.RunStateFailed ||\n   827→\t\trun.State == domain.RunStateCancelled\n   828→\n   829→\tif isComplete {\n   830→\t\t// Serve archived full.log\n   831→\t\th.streamFullLog(w, flusher, run)\n   832→\t\t// Send done event\n   833→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   834→\t\tflusher.Flush()\n   835→\t\treturn\n   836→\t}\n   837→\n   838→\t// Active run: subscribe to live broadcaster\n   839→\tif h.logBroadcast == nil {\n   840→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   841→\t\treturn\n   842→\t}\n   843→\n   844→\tsub := h.logBroadcast.Subscribe(id)\n   845→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   846→\n   847→\tctx := r.Context()\n   848→\tfor {\n   849→\t\tselect {\n   850→\t\tcase <-ctx.Done():\n   851→\t\t\treturn\n   852→\t\tcase line, ok := <-sub.C:\n   853→\t\t\tif !ok {\n   854→\t\t\t\t// Stream finished (run completed)\n   855→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   856→\t\t\t\tflusher.Flush()\n   857→\t\t\t\treturn\n   858→\t\t\t}\n   859→\t\t\tline = parseLLMLogLine(line)\n   860→\t\t\tif line.Type == \"\" {\n   861→\t\t\t\tcontinue // skip protocol-only llm lines\n   862→\t\t\t}\n   863→\t\t\tdata, _ := json.Marshal(line)\n   864→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   865→\t\t\tflusher.Flush()\n   866→\t\t}\n   867→\t}\n   868→}\n   869→\n   870→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   871→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   872→\n   873→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   874→// LLM-type lines are parsed from raw Claude JSON into human-readable text.\n   875→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   876→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   877→\tf, err := os.Open(logPath)\n   878→\tif err != nil {\n   879→\t\treturn\n   880→\t}\n   881→\tdefer f.Close()\n   882→\n   883→\tscanner := bufio.NewScanner(f)\n   884→\tfor scanner.Scan() {\n   885→\t\ttext := scanner.Text()\n   886→\t\tline := parseFullLogLine(text)\n   887→\t\tline = parseLLMLogLine(line)\n   888→\t\tif line.Type == \"\" {\n   889→\t\t\tcontinue // skip protocol-only llm lines\n   890→\t\t}\n   891→\t\tdata, _ := json.Marshal(line)\n   892→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   893→\t\tflusher.Flush()\n   894→\t}\n   895→}\n   896→\n   897→// parseLLMLogLine parses a LogLine whose type is \"llm\". If the content is\n   898→// Claude stream JSON, it extracts the human-readable text. Protocol-only\n   899→// events return a LogLine with an empty Type (caller should skip it).\n   900→// Non-llm lines are returned unchanged.\n   901→func parseLLMLogLine(line logstream.LogLine) logstream.LogLine {\n   902→\tif line.Type != \"llm\" {\n   903→\t\treturn line\n   904→\t}\n   905→\ttext, ok := logstream.ParseClaudeLine([]byte(line.Content))\n   906→\tif !ok {\n   907→\t\treturn logstream.LogLine{} // signal to skip\n   908→\t}\n   909→\tline.Content = text\n   910→\treturn line\n   911→}\n   912→\n   913→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   914→func parseFullLogLine(text string) logstream.LogLine {\n   915→\tm := logLineRegex.FindStringSubmatch(text)\n   916→\tif m == nil {\n   917→\t\treturn logstream.LogLine{\n   918→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   919→\t\t\tType:      \"script\",\n   920→\t\t\tContent:   text,\n   921→\t\t}\n   922→\t}\n   923→\treturn logstream.LogLine{\n   924→\t\tTimestamp: m[1],\n   925→\t\tType:      m[2],\n   926→\t\tContent:   m[3],\n   927→\t}\n   928→}\n   929→\n   930→// --- Project detail handlers ---\n   931→\n   932→// resolveProjectDir resolves a project label from the URL to its directory path.\n   933→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   934→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   935→\tlabel := r.PathValue(\"name\")\n   936→\tprojects, _ := h.store.ListProjects(r.Context())\n   937→\tlabels := projectLabels(projects)\n   938→\tfor dir, l := range labels {\n   939→\t\tif l == label {\n   940→\t\t\treturn dir, label, true\n   941→\t\t}\n   942→\t}\n   943→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   944→\tw.WriteHeader(http.StatusNotFound)\n   945→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   946→\treturn \"\", \"\", false\n   947→}\n   948→\n   949→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   950→\tdir, label, ok := h.resolveProjectDir(w, r)\n   951→\tif !ok {\n   952→\t\treturn\n   953→\t}\n   954→\n   955→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   956→\tn := 10\n   957→\tif n > len(runs) {\n   958→\t\tn = len(runs)\n   959→\t}\n   960→\tdots := make([]recentRunDot, n)\n   961→\tfor i := 0; i < n; i++ {\n   962→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   963→\t}\n   964→\n   965→\tvar containerCount int\n   966→\tfor _, run := range runs {\n   967→\t\tif run.ContainerKept {\n   968→\t\t\tcontainerCount++\n   969→\t\t}\n   970→\t}\n   971→\n   972→\tdata := map[string]any{\n   973→\t\t\"Title\":          label,\n   974→\t\t\"Label\":          label,\n   975→\t\t\"Dir\":            dir,\n   976→\t\t\"RecentRuns\":     dots,\n   977→\t\t\"ContainerCount\": containerCount,\n   978→\t}\n   979→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   980→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   981→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   982→\t}\n   983→}\n   984→\n   985→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   986→\tdir, _, ok := h.resolveProjectDir(w, r)\n   987→\tif !ok {\n   988→\t\treturn\n   989→\t}\n   990→\n   991→\t// Docker image: read FROM line from Dockerfile\n   992→\tdockerImage := \"\"\n   993→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   994→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   995→\t\t// Find the last FROM line (final stage)\n   996→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   997→\t\t\ttrimmed := strings.TrimSpace(line)\n   998→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   999→\t\t\t\tparts := strings.Fields(trimmed)\n  1000→\t\t\t\tif len(parts) >= 2 {\n  1001→\t\t\t\t\tdockerImage = parts[1]\n  1002→\t\t\t\t}\n  1003→\t\t\t}\n  1004→\t\t}\n  1005→\t}\n  1006→\n  1007→\t// Version\n  1008→\tversion := 0\n  1009→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n  1010→\tif data, err := os.ReadFile(versionPath); err == nil {\n  1011→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n  1012→\t\t\tversion = v\n  1013→\t\t}\n  1014→\t}\n  1015→\n  1016→\t// Prompt files history\n  1017→\ttype commitEntry struct {\n  1018→\t\tSHA     string `json:\"sha\"`\n  1019→\t\tDate    string `json:\"date\"`\n  1020→\t\tMessage string `json:\"message\"`\n  1021→\t}\n  1022→\ttype promptFile struct {\n  1023→\t\tPath    string        `json:\"path\"`\n  1024→\t\tHistory []commitEntry `json:\"history\"`\n  1025→\t}\n  1026→\n  1027→\tvar promptFiles []promptFile\n  1028→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n  1029→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n  1030→\t\tfor _, e := range entries {\n  1031→\t\t\tif e.IsDir() {\n  1032→\t\t\t\tcontinue\n  1033→\t\t\t}\n  1034→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n  1035→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n  1036→\t\t\tcmd.Dir = dir\n  1037→\t\t\tout, err := cmd.Output()\n  1038→\t\t\tif err != nil {\n  1039→\t\t\t\tcontinue\n  1040→\t\t\t}\n  1041→\t\t\tvar history []commitEntry\n  1042→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n  1043→\t\t\t\tif line == \"\" {\n  1044→\t\t\t\t\tcontinue\n  1045→\t\t\t\t}\n  1046→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1047→\t\t\t\tif len(parts) < 3 {\n  1048→\t\t\t\t\tcontinue\n  1049→\t\t\t\t}\n  1050→\t\t\t\t// Parse date to short form\n  1051→\t\t\t\tdateStr := parts[1]\n  1052→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1053→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1054→\t\t\t\t}\n  1055→\t\t\t\thistory = append(history, commitEntry{\n  1056→\t\t\t\t\tSHA:     parts[0][:7],\n  1057→\t\t\t\t\tDate:    dateStr,\n  1058→\t\t\t\t\tMessage: parts[2],\n  1059→\t\t\t\t})\n  1060→\t\t\t}\n  1061→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1062→\t\t}\n  1063→\t}\n  1064→\n  1065→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1066→\tjson.NewEncoder(w).Encode(map[string]any{\n  1067→\t\t\"docker_image\": dockerImage,\n  1068→\t\t\"version\":      version,\n  1069→\t\t\"prompt_files\": promptFiles,\n  1070→\t})\n  1071→}\n  1072→\n  1073→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1074→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1075→\tif !ok {\n  1076→\t\treturn\n  1077→\t}\n  1078→\tfile := r.URL.Query().Get(\"file\")\n  1079→\tsha := r.URL.Query().Get(\"sha\")\n  1080→\tif file == \"\" || sha == \"\" {\n  1081→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1082→\t\treturn\n  1083→\t}\n  1084→\n  108