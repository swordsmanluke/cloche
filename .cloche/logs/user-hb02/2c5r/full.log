ies {\n  1139→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1140→\t\t\tcontinue\n  1141→\t\t}\n  1142→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1143→\t\tif err != nil {\n  1144→\t\t\tcontinue\n  1145→\t\t}\n  1146→\t\twf, err := dsl.ParseForContainer(string(data))\n  1147→\t\tif err != nil {\n  1148→\t\t\tcontinue\n  1149→\t\t}\n  1150→\t\tvar steps []apiStepDef\n  1151→\t\tfor _, s := range wf.Steps {\n  1152→\t\t\tsteps = append(steps, apiStepDef{\n  1153→\t\t\t\tName:    s.Name,\n  1154→\t\t\t\tType:    string(s.Type),\n  1155→\t\t\t\tResults: s.Results,\n  1156→\t\t\t\tConfig:  s.Config,\n  1157→\t\t\t})\n  1158→\t\t}\n  1159→\t\t// Sort steps by name for consistent ordering\n  1160→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1161→\n  1162→\t\tvar wires []apiWire\n  1163→\t\tfor _, wire := range wf.Wiring {\n  1164→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1165→\t\t}\n  1166→\n  1167→\t\tworkflows = append(workflows, apiWorkflow{\n  1168→\t\t\tName:      wf.Name,\n  1169→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1170→\t\t\tSteps:     steps,\n  1171→\t\t\tWires:     wires,\n  1172→\t\t\tEntryStep: wf.EntryStep,\n  1173→\t\t})\n  1174→\t}\n  1175→\n  1176→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1177→\tjson.NewEncoder(w).Encode(workflows)\n  1178→}\n  1179→\n  1180→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1181→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1182→\tif !ok {\n  1183→\t\treturn\n  1184→\t}\n  1185→\tworkflowName := r.PathValue(\"workflow\")\n  1186→\tstepName := r.PathValue(\"step\")\n  1187→\n  1188→\t// Find the workflow file\n  1189→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1190→\tvar wf *domain.Workflow\n  1191→\tentries, _ := os.ReadDir(clocheDir)\n  1192→\tfor _, e := range entries {\n  1193→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1194→\t\t\tcontinue\n  1195→\t\t}\n  1196→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1197→\t\tif err != nil {\n  1198→\t\t\tcontinue\n  1199→\t\t}\n  1200→\t\tparsed, err := dsl.ParseForContainer(string(data))\n  1201→\t\tif err != nil {\n  1202→\t\t\tcontinue\n  1203→\t\t}\n  1204→\t\tif parsed.Name == workflowName {\n  1205→\t\t\twf = parsed\n  1206→\t\t\tbreak\n  1207→\t\t}\n  1208→\t}\n  1209→\tif wf == nil {\n  1210→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1211→\t\treturn\n  1212→\t}\n  1213→\n  1214→\tstep, ok := wf.Steps[stepName]\n  1215→\tif !ok {\n  1216→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1217→\t\treturn\n  1218→\t}\n  1219→\n  1220→\t// Try to read the referenced file from step config\n  1221→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1222→\n  1223→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1224→\t\tcontent, err := resolveFileRef(prompt, dir)\n  1225→\t\tif err == nil {\n  1226→\t\t\tw.Write([]byte(content))\n  1227→\t\t\treturn\n  1228→\t\t}\n  1229→\t}\n  1230→\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n  1231→\t\tcontent, _ := resolveFileRef(cmd, dir)\n  1232→\t\tw.Write([]byte(content))\n  1233→\t\treturn\n  1234→\t}\n  1235→\tif script := step.Config[\"script\"]; script != \"\" {\n  1236→\t\tcontent, _ := resolveFileRef(script, dir)\n  1237→\t\tw.Write([]byte(content))\n  1238→\t\treturn\n  1239→\t}\n  1240→\n  1241→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1242→}\n  1243→\n  1244→// --- Template helpers ---\n  1245→\n  1246→// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n  1247→// If the value uses file() syntax, the referenced file is read from disk.\n  1248→// Otherwise the value is returned as-is.\n  1249→func resolveFileRef(value, baseDir string) (string, error) {\n  1250→