0m, 10m ago\", formatRunTimingAt(domain.RunStateFailed, started, completed, now))\n+\n+\t\t// Cancelled: \"duration, X ago\"\n+\t\tlongAgo := now.Add(-3 * time.Hour)\n+\t\tassert.Equal(t, \"2h50m, 10m ago\", formatRunTimingAt(domain.RunStateCancelled, longAgo, completed, now))\n+\n+\t\t// Completed but no completedAt: empty\n+\t\tassert.Equal(t, \"\", formatRunTimingAt(domain.RunStateSucceeded, started, time.Time{}, now))\n+\t})\n+\n \tt.Run(\"projectLabels\", func(t *testing.T) {\n \t\t// No conflict: show base name only\n \t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\ndiff --git a/internal/adapters/web/templates/runs.html b/internal/adapters/web/templates/runs.html\nindex a6edd19..a24940d 100644\n--- a/internal/adapters/web/templates/runs.html\n+++ b/internal/adapters/web/templates/runs.html\n@@ -20,8 +20,7 @@\n             <th>Workflow</th>\n             <th>Type</th>\n             <th>State</th>\n-            <th>Started</th>\n-            <th>Completed</th>\n+            <th>Timing</th>\n             <th>Container</th>\n             <th>Error</th>\n         </tr>\n@@ -36,14 +35,13 @@\n             <td>{{.WorkflowName}}</td>\n             <td>{{if .IsHost}}host{{else}}container{{end}}</td>\n             <td><span class=\"badge badge-{{stateColor .State}}\">{{.State}}</span></td>\n-            <td>{{formatTime .StartedAt}}</td>\n-            <td>{{formatTime .CompletedAt}}</td>\n+            <td>{{formatRunTiming .State .StartedAt .CompletedAt}}</td>\n             <td class=\"mono\">{{shortContainerID .ContainerID}}</td>\n             <td class=\"error-cell\">{{truncate .ErrorMessage 80}}</td>\n         </tr>\n         {{end}}\n     {{else}}\n-        <tr><td colspan=\"10\" class=\"empty\">No runs yet.</td></tr>\n+        <tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>\n     {{end}}\n     </tbody>\n </table>\n@@ -118,7 +116,7 @@\n             .then(function(runs) {\n                 var tbody = document.getElementById('runs-body');\n                 if (!runs || runs.length === 0) {\n-                    tbody.innerHTML = '<tr><td colspan=\"10\" class=\"empty\">No runs yet.</td></tr>';\n+                    tbody.innerHTML = '<tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>';\n                     return;\n                 }\n \n@@ -136,6 +134,7 @@\n                     if (title.length > 50) title = title.substring(0, 47) + '...';\n                     var runType = r.is_host ? 'host' : 'container';\n                     var rowClass = entry.isChild ? 'run-child-row' : (entry.isParent ? 'run-parent-row' : '');\n+                    var timing = r.timing || '';\n                     html += '<tr class=\"' + rowClass + '\">' +\n                         '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n                         '<td>' + escapeHtml(title) + '</td>' +\n@@ -143,8 +142,7 @@\n                         '<td>' + r.workflow_name + '</td>' +\n                         '<td>' + runType + '</td>' +\n                         '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n-                        '<td>' + r.started_at + '</td>' +\n-                        '<td>' + r.completed_at + '</td>' +\n+                        '<td>' + escapeHtml(timing) + '</td>' +\n                         '<td class=\"mono\">' + cid + '</td>' +\n                         '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                         '</tr>';","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
