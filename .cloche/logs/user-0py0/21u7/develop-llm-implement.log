>' +\n                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                        '</tr>';\n                }\n                tbody.innerHTML = html;\n            })\n            .catch(function() {});\n    }\n    function escapeHtml(s) {\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n    setInterval(poll, 3000);\n})();\n</script>\n{{end}}\n","structuredPatch":[{"oldStart":6,"oldLines":7,"newStart":6,"newLines":7,"lines":["     <select id=\"project-select\" onchange=\"filterByProject(this.value)\">","         <option value=\"\">All projects</option>","         {{range .Projects}}","-        <option value=\"{{.Dir}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>","+        <option value=\"{{.Label}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>","         {{end}}","     </select>"," </div>"]},{"oldStart":48,"oldLines":11,"newStart":48,"newLines":11,"lines":[" {{define \"scripts\"}}"," <script>"," (function() {","-    var currentProject = '{{.ProjectFilter}}';","+    var currentProjectLabel = '{{.ProjectLabel}}';"," ","-    function filterByProject(dir) {","-        if (dir) {","-            window.location.href = '/runs?project=' + encodeURIComponent(dir);","+    function filterByProject(label) {","+        if (label) {","+            window.location.href = '/projects/' + encodeURIComponent(label) + '/runs';","         } else {","             window.location.href = '/runs';","         }"]},{"oldStart":61,"oldLines":8,"newStart":61,"newLines":8,"lines":[" ","     function poll() {","         var url = '/api/runs';","-        if (currentProject) {","-            url += '?project=' + encodeURIComponent(currentProject);"