[2026-03-09T00:56:41Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015r9d3tQ7RvSqwwyhVYEKTz","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    19→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    20→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    21→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    22→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    23→\trpcgrpc \"google.golang.org/grpc\"\n    24→)\n    25→\n    26→// OnRunCompleteFunc is called after a workflow run finishes.\n    27→// It receives the project directory, run ID, and the final run state.\n    28→type OnRunCompleteFunc func(ctx context.Context, projectDir string, runID string, state domain.RunState)\n    29→\n    30→type ClocheServer struct {\n    31→\tpb.UnimplementedClocheServiceServer\n    32→\tstore         ports.RunStore\n    33→\tcaptures      ports.CaptureStore\n    34→\tlogStore      ports.LogStore\n    35→\tcontainer     ports.ContainerRuntime\n    36→\tdefaultImage  string\n    37→\tevolution     *evolution.Trigger\n    38→\tlogBroadcast  *logstream.Broadcaster\n    39→\tshutdownFn    func()\n    40→\tonRunComplete OnRunCompleteFunc\n    41→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    42→\tmu            sync.Mutex\n    43→\trunIDs        map[string]string // run_id -> container_id\n    44→}\n    45→\n    46→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    47→\treturn &ClocheServer{\n    48→\t\tstore:     store,\n    49→\t\tcontainer: container,\n    50→\t\trunIDs:    make(map[string]string),\n    51→\t}\n    52→}\n    53→\n    54→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    55→\treturn &ClocheServer{\n    56→\t\tstore:        store,\n    57→\t\tcaptures:     captures,\n    58→\t\tcontainer:    container,\n    59→\t\tdefaultImage: defaultImage,\n    60→\t\trunIDs:       make(map[string]string),\n    61→\t}\n    62→}\n    63→\n    64→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    65→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    66→\ts.logStore = ls\n    67→}\n    68→\n    69→\n    70→// SetEvolution attaches an evolution trigger to the server.\n    71→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    72→\ts.evolution = trigger\n    73→}\n    74→\n    75→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    76→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    77→\ts.logBroadcast = b\n    78→}\n    79→\n    80→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    81→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    82→\ts.shutdownFn = fn\n    83→}\n    84→\n    85→// SetOnRunComplete sets a callback invoked after each workflow run completes.\n    86→func (s *ClocheServer) SetOnRunComplete(fn OnRunCompleteFunc) {\n    87→\ts.onRunComplete = fn\n    88→}\n    89→\n    90→\n    91→// SetOrchestrateFunc sets the function invoked by the Orchestrate RPC.\n    92→func (s *ClocheServer) SetOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) {\n    93→\ts.orchestrateFn = fn\n    94→}\n    95→\n    96→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    97→\tif s.container == nil {\n    98→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    99→\t}\n   100→\n   101→\t// Generate a unique run ID, retrying on collision\n   102→\tvar runID string\n   103→\tfor attempts := 0; attempts < 10; attempts++ {\n   104→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n   105→\t\texisting, err := s.store.GetRun(ctx, runID)\n   106→\t\tif err != nil {\n   107→\t\t\tbreak // ID is free\n   108→\t\t}\n   109→\t\t// Reuse if completed more than 1 hour ago\n   110→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   111→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   112→\t\t\tbreak\n   113→\t\t}\n   114→\t}\n   115→\n   116→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   117→\tif req.Prompt != \"\" {\n   118→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   119→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   120→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   121→\t\t}\n   122→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   123→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   124→\t\t}\n   125→\t}\n   126→\trun := domain.NewRun(runID, req.WorkflowName)\n   127→\trun.ProjectDir = req.ProjectDir\n   128→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   129→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   130→\t}\n   131→\n   132→\t// Resolve image: request-level override, then server default\n   133→\timage := req.Image\n   134→\tif image == \"\" {\n   135→\t\timage = s.defaultImage\n   136→\t}\n   137→\n   138→\t// Launch container start + tracking in background so the RPC returns immediately.\n   139→\t// The run stays in \"pending\" state until the container is up.\n   140→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   141→\n   142→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   143→}\n   144→\n   145→// launchAndTrack starts the container and then tracks it to completion.\n   146→// It runs in a background goroutine with its own context, independent of the\n   147→// RPC context which may be cancelled after RunWorkflow returns.\n   148→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   149→\tctx := context.Background()\n   150→\n   151→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   152→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   153→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   154→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   155→\t\t\tif run != nil {\n   156→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   157→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   158→\t\t\t}\n   159→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   160→\t\t\treturn\n   161→\t\t}\n   162→\t}\n   163→\n   164→\tbaseSHA := gitHEAD(req.ProjectDir)\n   165→\n   166→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   167→\t\tImage:        image,\n   168→\t\tWorkflowName: req.WorkflowName,\n   169→\t\tProjectDir:   req.ProjectDir,\n   170→\t\tRunID:        runID,\n   171→\t\tNetworkAllow: []string{\"*\"},\n   172→\t})\n   173→\tif err != nil {\n   174→\t\trun, _ := s.store.GetRun(ctx, runID)\n   175→\t\tif run != nil {\n   176→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   177→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   178→\t\t}\n   179→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   180→\t\treturn\n   181→\t}\n   182→\n   183→\ts.mu.Lock()\n   184→\ts.runIDs[runID] = containerID\n   185→\ts.mu.Unlock()\n   186→\n   187→\trun, _ := s.store.GetRun(ctx, runID)\n   188→\tif run != nil {\n   189→\t\trun.Start()\n   190→\t\trun.ContainerID = containerID\n   191→\t\trun.BaseSHA = baseSHA\n   192→\t\t_ = s.store.UpdateRun(ctx, run)\n   193→\t}\n   194→\n   195→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   196→}\n   197→\n   198→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   199→\tctx := context.Background()\n   200→\n   201→\t// Attach to agent output\n   202→\treader, err := s.container.AttachOutput(ctx, containerID)\n   203→\tif err != nil {\n   204→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   205→\t\treturn\n   206→\t}\n   207→\n   208→\t// Parse JSON-lines status messages\n   209→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   210→\tscanner := bufio.NewScanner(reader)\n   211→\tfor scanner.Scan() {\n   212→\t\tvar msg protocol.StatusMessage\n   213→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   214→\t\t\tcontinue\n   215→\t\t}\n   216→\n   217→\t\t// Fast path: log messages don't need store interaction.\n   218→\t\tif msg.Type == protocol.MsgLog {\n   219→\t\t\tif s.logBroadcast != nil {\n   220→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   221→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   222→\t\t\t\t\tType:      \"llm\",\n   223→\t\t\t\t\tContent:   msg.Message,\n   224→\t\t\t\t})\n   225→\t\t\t}\n   226→\t\t\tcontinue\n   227→\t\t}\n   228→\n   229→\t\trun, err := s.store.GetRun(ctx, runID)\n   230→\t\tif err != nil {\n   231→\t\t\tcontinue\n   232→\t\t}\n   233→\n   234→\t\tswitch msg.Type {\n   235→\t\tcase protocol.MsgStepStarted:\n   236→\t\t\trun.RecordStepStart(msg.StepName)\n   237→\t\t\tif s.captures != nil {\n   238→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   239→\t\t\t\t\tStepName:  msg.StepName,\n   240→\t\t\t\t\tStartedAt: msg.Timestamp,\n   241→\t\t\t\t})\n   242→\t\t\t}\n   243→\t\tcase protocol.MsgStepCompleted:\n   244→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   245→\t\t\tif s.captures != nil {\n   246→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   247→\t\t\t\t\tStepName:    msg.StepName,\n   248→\t\t\t\t\tResult:      msg.Result,\n   249→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   250→\t\t\t\t})\n   251→\t\t\t}\n   252→\t\tcase protocol.MsgRunCompleted:\n   253→\t\t\treportedResult = msg.Result\n   254→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   255→\t\t}\n   256→\n   257→\t\t_ = s.store.UpdateRun(ctx, run)\n   258→\t}\n   259→\treader.Close()\n   260→\n   261→\t// Signal live-stream subscribers that this run is done.\n   262→\tif s.logBroadcast != nil {\n   263→\t\ts.logBroadcast.Finish(runID)\n   264→\t}\n   265→\n   266→\t// Wait for process exit\n   267→\texitCode, err := s.container.Wait(ctx, containerID)\n   268→\tif err != nil {\n   269→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   270→\t}\n   271→\n   272→\t// Extract step output files from container before it's removed\n   273→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   274→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   275→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   276→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   277→\t\t}\n   278→\t}\n   279→\n   280→\t// Capture full container stdout/stderr before the container is removed\n   281→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   282→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   283→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   284→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   285→\t\t}\n   286→\t}\n   287→\n   288→\t// Index extracted log files in the log store\n   289→\tif s.logStore != nil {\n   290→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   291→\t}\n   292→\n   293→\t// Extract results to git branch BEFORE finalizing state, so that\n   294→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   295→\t// before the run is marked complete.\n   296→\tresultLabel := reportedResult\n   297→\tif resultLabel == \"\" {\n   298→\t\tif exitCode == 0 {\n   299→\t\t\tresultLabel = \"succeeded\"\n   300→\t\t} else {\n   301→\t\t\tresultLabel = \"failed\"\n   302→\t\t}\n   303→\t}\n   304→\t{\n   305→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   306→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   307→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   308→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   309→\t\t\t}\n   310→\t\t}\n   311→\t}\n   312→\n   313→\t// Now finalize run state\n   314→\trun, err := s.store.GetRun(ctx, runID)\n   315→\tif err != nil {\n   316→\t\treturn\n   317→\t}\n   318→\tif run.State == domain.RunStateRunning {\n   319→\t\tif reportedResult == \"succeeded\" {\n   320→\t\t\trun.Complete(domain.RunStateSucceeded)\n   321→\t\t} else if reportedResult != \"\" {\n   322→\t\t\trun.Complete(domain.RunStateFailed)\n   323→\t\t} else if exitCode == 0 {\n   324→\t\t\trun.Complete(domain.RunStateSucceeded)\n   325→\t\t} else {\n   326→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   327→\t\t}\n   328→\t\t_ = s.store.UpdateRun(ctx, run)\n   329→\t}\n   330→\n   331→\t// Fire evolution trigger if configured\n   332→\tif s.evolution != nil {\n   333→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   334→\t}\n   335→\n   336→\t// Fire on-run-complete callback (orchestrator trigger)\n   337→\tif s.onRunComplete != nil {\n   338→\t\trunForCallback, _ := s.store.GetRun(ctx, runID)\n   339→\t\tif runForCallback != nil {\n   340→\t\t\ts.onRunComplete(ctx, projectDir, runID, runForCallback.State)\n   341→\t\t}\n   342→\t}\n   343→\n   344→\t// Merge is handled as a workflow step in host.cloche, not here.\n   345→\n   346→\t// Container retention policy:\n   347→\t// - Failed runs: always keep the container for debugging\n   348→\t// - Successful runs + --keep-container: keep the container\n   349→\t// - Successful runs without --keep-container: remove the container\n   350→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   351→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   352→\n   353→\tif keepContainer || runFailed {\n   354→\t\treason := \"--keep-container\"\n   355→\t\tif runFailed {\n   356→\t\t\treason = \"run failed\"\n   357→\t\t}\n   358→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   359→\t\tif runFinal != nil {\n   360→\t\t\trunFinal.ContainerKept = true\n   361→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   362→\t\t}\n   363→\t} else {\n   364→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   365→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   366→\t\t} else {\n   367→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   368→\t\t}\n   369→\t}\n   370→\n   371→\t// Cleanup mapping\n   372→\ts.mu.Lock()\n   373→\tdelete(s.runIDs, runID)\n   374→\ts.mu.Unlock()\n   375→}\n   376→\n   377→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   378→\tvar since time.Time\n   379→\tif !req.All {\n   380→\t\tsince = time.Now().Add(-1 * time.Hour)\n   381→\t}\n   382→\truns, err := s.store.ListRuns(ctx, since)\n   383→\tif err != nil {\n   384→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   385→\t}\n   386→\n   387→\tresp := &pb.ListRunsResponse{}\n   388→\tfor _, run := range runs {\n   389→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   390→\t\t\tRunId:        run.ID,\n   391→\t\t\tWorkflowName: run.WorkflowName,\n   392→\t\t\tState:        string(run.State),\n   393→\t\t\tStartedAt:    run.StartedAt.String(),\n   394→\t\t\tErrorMessage: run.ErrorMessage,\n   395→\t\t\tContainerId:  run.ContainerID,\n   396→\t\t})\n   397→\t}\n   398→\treturn resp, nil\n   399→}\n   400→\n   401→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   402→\trun, err := s.store.GetRun(ctx, req.RunId)\n   403→\tif err != nil {\n   404→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   405→\t}\n   406→\n   407→\tresp := &pb.GetStatusResponse{\n   408→\t\tRunId:        run.ID,\n   409→\t\tWorkflowName: run.WorkflowName,\n   410→\t\tState:        string(run.State),\n   411→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   412→\t\tErrorMessage: run.ErrorMessage,\n   413→\t\tContainerId:  run.ContainerID,\n   414→\t}\n   415→\n   416→\t// Check container liveness\n   417→\tif run.ContainerID != \"\" && s.container != nil {\n   418→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   419→\t\t\tresp.ContainerAlive = cs.Running\n   420→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   421→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   422→\t\t\t}\n   423→\t\t}\n   424→\t}\n   425→\n   426→\t// Load step executions from captures store if available\n   427→\tif s.captures != nil {\n   428→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   429→\t\tif err == nil {\n   430→\t\t\tfor _, exec := range captures {\n   431→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   432→\t\t\t\t\tStepName:    exec.StepName,\n   433→\t\t\t\t\tResult:      exec.Result,\n   434→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   435→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   436→\t\t\t\t})\n   437→\t\t\t}\n   438→\t\t}\n   439→\t} else {\n   440→\t\tfor _, exec := range run.StepExecutions {\n   441→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   442→\t\t\t\tStepName:    exec.StepName,\n   443→\t\t\t\tResult:      exec.Result,\n   444→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   445→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   446→\t\t\t})\n   447→\t\t}\n   448→\t}\n   449→\n   450→\treturn resp, nil\n   451→}\n   452→\n   453→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   454→\tctx := stream.Context()\n   455→\n   456→\t// Verify run exists\n   457→\trun, err := s.store.GetRun(ctx, req.RunId)\n   458→\tif err != nil {\n   459→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   460→\t}\n   461→\n   462→\t// If step_name or log_type filter is set, serve content directly from the log index\n   463→\tif req.StepName != \"\" || req.LogType != \"\" {\n   464→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   465→\t}\n   466→\n   467→\tif s.captures == nil {\n   468→\t\treturn fmt.Errorf(\"captures store not configured\")\n   469→\t}\n   470→\n   471→\t// Check for full.log first — if it exists, serve it as the unified log\n   472→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   473→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   474→\t\tif err := stream.Send(&pb.LogEntry{\n   475→\t\t\tType:    \"full_log\",\n   476→\t\t\tMessage: string(data),\n   477→\t\t}); err != nil {\n   478→\t\t\treturn err\n   479→\t\t}\n   480→\t\t// Still send run completion entry\n   481→\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   482→\t\t\tif err := stream.Send(&pb.LogEntry{\n   483→\t\t\t\tType:      \"run_completed\",\n   484→\t\t\t\tResult:    string(run.State),\n   485→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   486→\t\t\t\tMessage:   run.ErrorMessage,\n   487→\t\t\t}); err != nil {\n   488→\t\t\t\treturn err\n   489→\t\t\t}\n   490→\t\t}\n   491→\t\treturn nil\n   492→\t}\n   493→\n   494→\t// Fall back to capture-based streaming\n   495→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   496→\tif err != nil {\n   497→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   498→\t}\n   499→\n   500→\tfor _, exec := range captures {\n   501→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   502→\t\t// and one for step_completed (has Result).\n   503→\t\tif exec.Result == \"\" {\n   504→\t\t\tentry := &pb.LogEntry{\n   505→\t\t\t\tType:      \"step_started\",\n   506→\t\t\t\tStepName:  exec.StepName,\n   507→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   508→\t\t\t}\n   509→\t\t\tif err := stream.Send(entry); err != nil {\n   510→\t\t\t\treturn err\n   511→\t\t\t}\n   512→\t\t} else {\n   513→\t\t\t// Read step output from file, falling back to container.log\n   514→\t\t\tvar output string\n   515→\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   516→\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   517→\t\t\t\toutput = string(data)\n   518→\t\t\t} else {\n   519→\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n   520→\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n   521→\t\t\t\t\toutput = string(data)\n   522→\t\t\t\t}\n   523→\t\t\t}\n   524→\t\t\tentry := &pb.LogEntry{\n   525→\t\t\t\tType:      \"step_completed\",\n   526→\t\t\t\tStepName:  exec.StepName,\n   527→\t\t\t\tResult:    exec.Result,\n   528→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   529→\t\t\t\tMessage:   output,\n   530→\t\t\t}\n   531→\t\t\tif err := stream.Send(entry); err != nil {\n   532→\t\t\t\treturn err\n   533→\t\t\t}\n   534→\t\t}\n   535→\t}\n   536→\n   537→\t// Send run completion entry\n   538→\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   539→\t\tif err := stream.Send(&pb.LogEntry{\n   540→\t\t\tType:      \"run_completed\",\n   541→\t\t\tResult:    string(run.State),\n   542→\t\t\tTimestamp: run.CompletedAt.String(),\n   543→\t\t\tMessage:   run.ErrorMessage,\n   544→\t\t}); err != nil {\n   545→\t\t\treturn err\n   546→\t\t}\n   547→\t}\n   548→\n   549→\treturn nil\n   550→}\n   551→\n   552→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   553→// It uses the log index when available, falling back to file path conventions.\n   554→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   555→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   556→\n   557→\t// Try log index first\n   558→\tif s.logStore != nil {\n   559→\t\tvar logFiles []*ports.LogFileEntry\n   560→\t\tvar err error\n   561→\n   562→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   563→\t\t\t// Filter by both step and type\n   564→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   565→\t\t\tif err == nil {\n   566→\t\t\t\tfiltered := logFiles[:0]\n   567→\t\t\t\tfor _, lf := range logFiles {\n   568→\t\t\t\t\tif lf.FileType == req.LogType {\n   569→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   570→\t\t\t\t\t}\n   571→\t\t\t\t}\n   572→\t\t\t\tlogFiles = filtered\n   573→\t\t\t}\n   574→\t\t} else if req.StepName != \"\" {\n   575→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   576→\t\t} else {\n   577→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   578→\t\t}\n   579→\n   580→\t\tif err == nil && len(logFiles) > 0 {\n   581→\t\t\tfor _, lf := range logFiles {\n   582→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   583→\t\t\t\tif readErr != nil {\n   584→\t\t\t\t\tcontinue\n   585→\t\t\t\t}\n   586→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   587→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   588→\t\t\t\t\tStepName: lf.StepName,\n   589→\t\t\t\t\tMessage:  string(data),\n   590→\t\t\t\t}); err != nil {\n   591→\t\t\t\t\treturn err\n   592→\t\t\t\t}\n   593→\t\t\t}\n   594→\t\t\treturn nil\n   595→\t\t}\n   596→\t}\n   597→\n   598→\t// Fall back to file path conventions\n   599→\tif req.StepName != \"\" {\n   600→\t\tvar logPath string\n   601→\t\tswitch req.LogType {\n   602→\t\tcase \"llm\":\n   603→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   604→\t\tdefault:\n   605→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   606→\t\t}\n   607→\n   608→\t\tdata, err := os.ReadFile(logPath)\n   609→\t\tif err != nil {\n   610→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   611→\t\t}\n   612→\t\treturn stream.Send(&pb.LogEntry{\n   613→\t\t\tType:     \"step_log\",\n   614→\t\t\tStepName: req.StepName,\n   615→\t\t\tMessage:  string(data),\n   616→\t\t})\n   617→\t}\n   618→\n   619→\treturn fmt.Errorf(\"no log files found matching filter\")\n   620→}\n   621→\n   622→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   623→\ts.mu.Lock()\n   624→\tcontainerID, ok := s.runIDs[req.RunId]\n   625→\ts.mu.Unlock()\n   626→\n   627→\tif !ok {\n   628→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   629→\t}\n   630→\n   631→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   632→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   633→\t}\n   634→\n   635→\t// Mark as cancelled in store\n   636→\trun, err := s.store.GetRun(ctx, req.RunId)\n   637→\tif err == nil {\n   638→\t\trun.Complete(domain.RunStateCancelled)\n   639→\t\t_ = s.store.UpdateRun(ctx, run)\n   640→\t}\n   641→\n   642→\treturn &pb.StopRunResponse{}, nil\n   643→}\n   644→\n   645→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   646→\tif s.container == nil {\n   647→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   648→\t}\n   649→\n   650→\tid := req.Id\n   651→\tif id == \"\" {\n   652→\t\treturn nil, fmt.Errorf(\"id is required\")\n   653→\t}\n   654→\n   655→\t// Try to resolve as a run ID first\n   656→\tcontainerID := id\n   657→\trun, err := s.store.GetRun(ctx, id)\n   658→\tif err == nil {\n   659→\t\t// It's a run ID — use the container ID from the run record\n   660→\t\tif run.ContainerID == \"\" {\n   661→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   662→\t\t}\n   663→\t\tcontainerID = run.ContainerID\n   664→\t}\n   665→\n   666→\t// Remove the container\n   667→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   668→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   669→\t}\n   670→\n   671→\t// If we resolved a run, clear the container_kept flag\n   672→\tif run != nil {\n   673→\t\trun.ContainerKept = false\n   674→\t\t_ = s.store.UpdateRun(ctx, run)\n   675→\t}\n   676→\n   677→\treturn &pb.DeleteContainerResponse{}, nil\n   678→}\n   679→\n   680→func (s *ClocheServer) Orchestrate(ctx context.Context, req *pb.OrchestrateRequest) (*pb.OrchestrateResponse, error) {\n   681→\tif s.orchestrateFn == nil {\n   682→\t\treturn nil, fmt.Errorf(\"orchestrator not configured\")\n   683→\t}\n   684→\tdispatched, err := s.orchestrateFn(ctx, req.ProjectDir)\n   685→\tif err != nil {\n   686→\t\treturn nil, fmt.Errorf(\"orchestration failed: %w\", err)\n   687→\t}\n   688→\treturn &pb.OrchestrateResponse{Dispatched: int32(dispatched)}, nil\n   689→}\n   690→\n   691→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n   692→\tif s.shutdownFn == nil {\n   693→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n   694→\t}\n   695→\tgo s.shutdownFn()\n   696→\treturn &pb.ShutdownResponse{}, nil\n   697→}\n   698→\n   699→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n   700→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n   701→\tentries, err := os.ReadDir(outputDir)\n   702→\tif err != nil {\n   703→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n   704→\t\treturn\n   705→\t}\n   706→\n   707→\tnow := time.Now()\n   708→\tfor _, entry := range entries {\n   709→\t\tif entry.IsDir() {\n   710→\t\t\tcontinue\n   711→\t\t}\n   712→\t\tname := entry.Name()\n   713→\t\tif !strings.HasSuffix(name, \".log\") {\n   714→\t\t\tcontinue\n   715→\t\t}\n   716→\n   717→\t\tvar fileType, stepName string\n   718→\t\tbase := strings.TrimSuffix(name, \".log\")\n   719→\n   720→\t\tswitch {\n   721→\t\tcase name == \"full.log\":\n   722→\t\t\tfileType = \"full\"\n   723→\t\tcase name == \"container.log\":\n   724→\t\t\t// container.log is internal, not indexed as a user-facing log type\n   725→\t\t\tcontinue\n   726→\t\tcase strings.HasPrefix(name, \"llm-\"):\n   727→\t\t\tfileType = \"llm\"\n   728→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n   729→\t\tdefault:\n   730→\t\t\tfileType = \"script\"\n   731→\t\t\tstepName = base\n   732→\t\t}\n   733→\n   734→\t\tinfo, _ := entry.Info()\n   735→\t\tvar fileSize int64\n   736→\t\tif info != nil {\n   737→\t\t\tfileSize = info.Size()\n   738→\t\t}\n   739→\n   740→\t\tlogEntry := &ports.LogFileEntry{\n   741→\t\t\tRunID:     runID,\n   742→\t\t\tStepName:  stepName,\n   743→\t\t\tFileType:  fileType,\n   744→\t\t\tFilePath:  filepath.Join(outputDir, name),\n   745→\t\t\tFileSize:  fileSize,\n   746→\t\t\tCreatedAt: now,\n   747→\t\t}\n   748→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n   749→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n   750→\t\t}\n   751→\t}\n   752→}\n   753→\n   754→func gitHEAD(dir string) string {\n   755→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n   756→\tcmd.Dir = dir\n   757→\tout, err := cmd.Output()\n   758→\tif err != nil {\n   759→\t\treturn \"\"\n   760→\t}\n   761→\treturn strings.TrimSpace(string(out))\n   762→}\n   763→"}]},"parent_tool_use_id":"toolu_0197oennsBHKizQuxwaDa5tR","session_id":"f1f0669a-686a-4b6d-807c-ce617681ff1b","uuid":"cbc6c786-bf33-40d1-b65f-ae1dc902ebaa"}
