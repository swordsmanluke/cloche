{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011KAnUvJM6CQwQJZ2U7sedY","type":"tool_result","content":"     1→package sqlite\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"database/sql\"\n     6→\t\"fmt\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11→\t_ \"modernc.org/sqlite\"\n    12→)\n    13→\n    14→type Store struct {\n    15→\tdb *sql.DB\n    16→}\n    17→\n    18→func NewStore(dsn string) (*Store, error) {\n    19→\tdb, err := sql.Open(\"sqlite\", dsn)\n    20→\tif err != nil {\n    21→\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n    22→\t}\n    23→\n    24→\t// Enable WAL mode for concurrent read/write access\n    25→\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n    26→\n    27→\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n    28→\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n    29→\n    30→\t// Serialize all Go-side access through a single connection so SQLite\n    31→\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n    32→\tdb.SetMaxOpenConns(1)\n    33→\n    34→\tif err := migrate(db); err != nil {\n    35→\t\tdb.Close()\n    36→\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n    37→\t}\n    38→\n    39→\treturn &Store{db: db}, nil\n    40→}\n    41→\n    42→func (s *Store) Close() error {\n    43→\treturn s.db.Close()\n    44→}\n    45→\n    46→func migrate(db *sql.DB) error {\n    47→\t_, err := db.Exec(`\n    48→\t\tCREATE TABLE IF NOT EXISTS runs (\n    49→\t\t\tid TEXT PRIMARY KEY,\n    50→\t\t\tworkflow_name TEXT NOT NULL,\n    51→\t\t\tstate TEXT NOT NULL,\n    52→\t\t\tactive_steps TEXT,\n    53→\t\t\tstarted_at TEXT,\n    54→\t\t\tcompleted_at TEXT\n    55→\t\t);\n    56→\t\tCREATE TABLE IF NOT EXISTS step_executions (\n    57→\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    58→\t\t\trun_id TEXT NOT NULL,\n    59→\t\t\tstep_name TEXT NOT NULL,\n    60→\t\t\tresult TEXT,\n    61→\t\t\tstarted_at TEXT NOT NULL,\n    62→\t\t\tcompleted_at TEXT,\n    63→\t\t\tlogs TEXT,\n    64→\t\t\tgit_ref TEXT,\n    65→\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    66→\t\t);\n    67→\t`)\n    68→\tif err != nil {\n    69→\t\treturn err\n    70→\t}\n    71→\n    72→\t// Evolution schema additions (idempotent)\n    73→\talterStmts := []string{\n    74→\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n    75→\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n    76→\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n    77→\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n    78→\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n    79→\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n    80→\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n    81→\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n    82→\t\t`ALTER TABLE runs ADD COLUMN title TEXT NOT NULL DEFAULT ''`,\n    83→\t\t`ALTER TABLE runs ADD COLUMN is_host INTEGER NOT NULL DEFAULT 0`,\n    84→\t\t`ALTER TABLE runs ADD COLUMN parent_run_id TEXT NOT NULL DEFAULT ''`,\n    85→\t\t`ALTER TABLE runs ADD COLUMN task_id TEXT NOT NULL DEFAULT ''`,\n    86→\t\t`ALTER TABLE runs ADD COLUMN task_title TEXT NOT NULL DEFAULT ''`,\n    87→\t}\n    88→\tfor _, stmt := range alterStmts {\n    89→\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n    90→\t}\n    91→\n    92→\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n    93→\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    94→\t\trun_id TEXT NOT NULL,\n    95→\t\tstep_name TEXT,\n    96→\t\tfile_type TEXT NOT NULL,\n    97→\t\tfile_path TEXT NOT NULL,\n    98→\t\tfile_size INTEGER,\n    99→\t\tcreated_at TEXT NOT NULL,\n   100→\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n   101→\t)`)\n   102→\tif errLog != nil {\n   103→\t\treturn errLog\n   104→\t}\n   105→\n   106→\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n   107→\t\trun_id TEXT PRIMARY KEY,\n   108→\t\tbranch TEXT NOT NULL,\n   109→\t\tproject TEXT NOT NULL,\n   110→\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n   111→\t\tenqueued_at TEXT NOT NULL,\n   112→\t\tcompleted_at TEXT\n   113→\t)`)\n   114→\tif errMQ != nil {\n   115→\t\treturn errMQ\n   116→\t}\n   117→\n   118→\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n   119→\t\tid TEXT PRIMARY KEY,\n   120→\t\tproject_dir TEXT NOT NULL,\n   121→\t\tworkflow_name TEXT NOT NULL,\n   122→\t\ttrigger_run_id TEXT NOT NULL,\n   123→\t\tcreated_at TEXT NOT NULL,\n   124→\t\tclassification TEXT,\n   125→\t\tchanges_json TEXT NOT NULL,\n   126→\t\tknowledge_delta TEXT\n   127→\t)`)\n   128→\tif err2 != nil {\n   129→\t\treturn err2\n   130→\t}\n   131→\n   132→\treturn nil\n   133→}\n   134→\n   135→func (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n   136→\t_, err := s.db.ExecContext(ctx,\n   137→\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept, title, is_host, parent_run_id, task_id, task_title)\n   138→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   139→\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n   140→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, truncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID, run.TaskTitle,\n   141→\t)\n   142→\treturn err\n   143→}\n   144→\n   145→// runSelectCols is the standard column list for scanning a Run row.\n   146→const runSelectCols = `id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,''), COALESCE(is_host,0), COALESCE(parent_run_id,''), COALESCE(task_id,''), COALESCE(task_title,'')`\n   147→\n   148→// scanRun scans a single row into a *domain.Run.\n   149→func scanRun(scanner interface{ Scan(...any) error }) (*domain.Run, error) {\n   150→\trun := &domain.Run{}\n   151→\tvar activeSteps, startedAt, completedAt string\n   152→\tvar containerKept, isHost int\n   153→\terr := scanner.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title, &isHost, &run.ParentRunID, &run.TaskID, &run.TaskTitle)\n   154→\tif err != nil {\n   155→\t\treturn nil, err\n   156→\t}\n   157→\trun.SetActiveStepsFromString(activeSteps)\n   158→\trun.StartedAt = parseTime(startedAt)\n   159→\trun.CompletedAt = parseTime(completedAt)\n   160→\trun.ContainerKept = containerKept != 0\n   161→\trun.IsHost = isHost != 0\n   162→\treturn run, nil\n   163→}\n   164→\n   165→func (s *Store) GetRun(ctx context.Context, id string) (*domain.Run, error) {\n   166→\trow := s.db.QueryRowContext(ctx,\n   167→\t\t`SELECT `+runSelectCols+` FROM runs WHERE id = ?`, id)\n   168→\n   169→\trun, err := scanRun(row)\n   170→\tif err == sql.ErrNoRows {\n   171→\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n   172→\t}\n   173→\treturn run, err\n   174→}\n   175→\n   176→func (s *Store) UpdateRun(ctx context.Context, run *domain.Run) error {\n   177→\t_, err := s.db.ExecContext(ctx,\n   178→\t\t`UPDATE runs SET state = ?, active_steps = ?, started_at = ?, completed_at = ?, error_message = ?, container_id = ?, base_sha = ?, container_kept = ?, title = ?, is_host = ?, parent_run_id = ?, task_id = ?, task_title = ? WHERE id = ?`,\n   179→\t\tstring(run.State), run.ActiveStepsString(),\n   180→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt),\n   181→\t\ttruncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID, run.TaskTitle, run.ID,\n   182→\t)\n   183→\treturn err\n   184→}\n   185→\n   186→func (s *Store) DeleteRun(ctx context.Context, id string) error {\n   187→\t_, err := s.db.ExecContext(ctx, `DELETE FROM step_executions WHERE run_id = ?`, id)\n   188→\tif err != nil {\n   189→\t\treturn err\n   190→\t}\n   191→\t_, err = s.db.ExecContext(ctx, `DELETE FROM runs WHERE id = ?`, id)\n   192→\treturn err\n   193→}\n   194→\n   195→func (s *Store) ListRuns(ctx context.Context, since time.Time) ([]*domain.Run, error) {\n   196→\tvar rows *sql.Rows\n   197→\tvar err error\n   198→\tif since.IsZero() {\n   199→\t\trows, err = s.db.QueryContext(ctx,\n   200→\t\t\t`SELECT `+runSelectCols+` FROM runs ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`)\n   201→\t} else {\n   202→\t\trows, err = s.db.QueryContext(ctx,\n   203→\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   204→\t\t\tformatTime(since))\n   205→\t}\n   206→\tif err != nil {\n   207→\t\treturn nil, err\n   208→\t}\n   209→\tdefer rows.Close()\n   210→\treturn scanRuns(rows)\n   211→}\n   212→\n   213→// scanRuns scans all rows into a []*domain.Run slice.\n   214→func scanRuns(rows *sql.Rows) ([]*domain.Run, error) {\n   215→\tvar runs []*domain.Run\n   216→\tfor rows.Next() {\n   217→\t\trun, err := scanRun(rows)\n   218→\t\tif err != nil {\n   219→\t\t\treturn nil, err\n   220→\t\t}\n   221→\t\truns = append(runs, run)\n   222→\t}\n   223→\treturn runs, rows.Err()\n   224→}\n   225→\n   226→func (s *Store) ListRunsByProject(ctx context.Context, projectDir string, since time.Time) ([]*domain.Run, error) {\n   227→\tvar rows *sql.Rows\n   228→\tvar err error\n   229→\tif since.IsZero() {\n   230→\t\trows, err = s.db.QueryContext(ctx,\n   231→\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   232→\t\t\tprojectDir)\n   233→\t} else {\n   234→\t\trows, err = s.db.QueryContext(ctx,\n   235→\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? AND started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   236→\t\t\tprojectDir, formatTime(since))\n   237→\t}\n   238→\tif err != nil {\n   239→\t\treturn nil, err\n   240→\t}\n   241→\tdefer rows.Close()\n   242→\treturn scanRuns(rows)\n   243→}\n   244→\n   245→func (s *Store) ListRunsFiltered(ctx context.Context, filter domain.RunListFilter) ([]*domain.Run, error) {\n   246→\tquery := `SELECT ` + runSelectCols + ` FROM runs WHERE 1=1`\n   247→\tvar args []interface{}\n   248→\n   249→\tif filter.ProjectDir != \"\" {\n   250→\t\tquery += ` AND project_dir = ?`\n   251→\t\targs = append(args, filter.ProjectDir)\n   252→\t}\n   253→\tif filter.State != \"\" {\n   254→\t\tquery += ` AND state = ?`\n   255→\t\targs = append(args, string(filter.State))\n   256→\t}\n   257→\tif filter.TaskID != \"\" {\n   258→\t\tquery += ` AND task_id = ?`\n   259→\t\targs = append(args, filter.TaskID)\n   260→\t}\n   261→\tif !filter.Since.IsZero() {\n   262→\t\tquery += ` AND (completed_at >= ? OR state IN ('running', 'pending'))`\n   263→\t\targs = append(args, formatTime(filter.Since))\n   264→\t}\n   265→\n   266→\tquery += ` ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`\n   267→\n   268→\tif filter.Limit > 0 {\n   269→\t\tquery += fmt.Sprintf(` LIMIT %d`, filter.Limit)\n   270→\t}\n   271→\n   272→\trows, err := s.db.QueryContext(ctx, query, args...)\n   273→\tif err != nil {\n   274→\t\treturn nil, err\n   275→\t}\n   276→\tdefer rows.Close()\n   277→\treturn scanRuns(rows)\n   278→}\n   279→\n   280→func (s *Store) ListProjects(ctx context.Context) ([]string, error) {\n   281→\trows, err := s.db.QueryContext(ctx,\n   282→\t\t`SELECT DISTINCT project_dir FROM runs WHERE project_dir != '' ORDER BY project_dir`)\n   283→\tif err != nil {\n   284→\t\treturn nil, err\n   285→\t}\n   286→\tdefer rows.Close()\n   287→\n   288→\tvar projects []string\n   289→\tfor rows.Next() {\n   290→\t\tvar dir string\n   291→\t\tif err := rows.Scan(&dir); err != nil {\n   292→\t\t\treturn nil, err\n   293→\t\t}\n   294→\t\tprojects = append(projects, dir)\n   295→\t}\n   296→\treturn projects, rows.Err()\n   297→}\n   298→\n   299→func (s *Store) ListChildRuns(ctx context.Context, parentRunID string) ([]*domain.Run, error) {\n   300→\trows, err := s.db.QueryContext(ctx,\n   301→\t\t`SELECT `+runSelectCols+` FROM runs WHERE parent_run_id = ? ORDER BY started_at ASC`,\n   302→\t\tparentRunID)\n   303→\tif err != nil {\n   304→\t\treturn nil, err\n   305→\t}\n   306→\tdefer rows.Close()\n   307→\treturn scanRuns(rows)\n   308→}\n   309→\n   310→func (s *Store) SaveCapture(ctx context.Context, runID string, exec *domain.StepExecution) error {\n   311→\t_, err := s.db.ExecContext(ctx,\n   312→\t\t`INSERT INTO step_executions (run_id, step_name, result, started_at, completed_at, logs, git_ref)\n   313→\t\t VALUES (?, ?, ?, ?, ?, ?, ?)`,\n   314→\t\trunID, exec.StepName, exec.Result,\n   315→\t\tformatTime(exec.StartedAt), formatTime(exec.CompletedAt),\n   316→\t\texec.Logs, exec.GitRef,\n   317→\t)\n   318→\treturn err\n   319→}\n   320→\n   321→func (s *Store) GetCaptures(ctx context.Context, runID string) ([]*domain.StepExecution, error) {\n   322→\trows, err := s.db.QueryContext(ctx,\n   323→\t\t`SELECT step_name, result, started_at, completed_at, COALESCE(logs,''), COALESCE(git_ref,'')\n   324→\t\t FROM step_executions WHERE run_id = ? ORDER BY id`, runID)\n   325→\tif err != nil {\n   326→\t\treturn nil, err\n   327→\t}\n   328→\tdefer rows.Close()\n   329→\n   330→\tvar execs []*domain.StepExecution\n   331→\tfor rows.Next() {\n   332→\t\te := &domain.StepExecution{}\n   333→\t\tvar startedAt, completedAt string\n   334→\t\tif err := rows.Scan(&e.StepName, &e.Result, &startedAt, &completedAt, &e.Logs, &e.GitRef); err != nil {\n   335→\t\t\treturn nil, err\n   336→\t\t}\n   337→\t\te.StartedAt = parseTime(startedAt)\n   338→\t\te.CompletedAt = parseTime(completedAt)\n   339→\t\texecs = append(execs, e)\n   340→\t}\n   341→\treturn execs, rows.Err()\n   342→}\n   343→\n   344→func (s *Store) SaveLogFile(ctx context.Context, entry *ports.LogFileEntry) error {\n   345→\t_, err := s.db.ExecContext(ctx,\n   346→\t\t`INSERT INTO log_files (run_id, step_name, file_type, file_path, file_size, created_at)\n   347→\t\t VALUES (?, ?, ?, ?, ?, ?)`,\n   348→\t\tentry.RunID, entry.StepName, entry.FileType, entry.FilePath, entry.FileSize,\n   349→\t\tformatTime(entry.CreatedAt),\n   350→\t)\n   351→\treturn err\n   352→}\n   353→\n   354→func (s *Store) GetLogFiles(ctx context.Context, runID string) ([]*ports.LogFileEntry, error) {\n   355→\trows, err := s.db.QueryContext(ctx,\n   356→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   357→\t\t FROM log_files WHERE run_id = ? ORDER BY id`, runID)\n   358→\tif err != nil {\n   359→\t\treturn nil, err\n   360→\t}\n   361→\tdefer rows.Close()\n   362→\treturn scanLogFiles(rows)\n   363→}\n   364→\n   365→func (s *Store) GetLogFilesByStep(ctx context.Context, runID, stepName string) ([]*ports.LogFileEntry, error) {\n   366→\trows, err := s.db.QueryContext(ctx,\n   367→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   368→\t\t FROM log_files WHERE run_id = ? AND step_name = ? ORDER BY id`, runID, stepName)\n   369→\tif err != nil {\n   370→\t\treturn nil, err\n   371→\t}\n   372→\tdefer rows.Close()\n   373→\treturn scanLogFiles(rows)\n   374→}\n   375→\n   376→func (s *Store) GetLogFileByType(ctx context.Context, runID, fileType string) ([]*ports.LogFileEntry, error) {\n   377→\trows, err := s.db.QueryContext(ctx,\n   378→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   379→\t\t FROM log_files WHERE run_id = ? AND file_type = ? ORDER BY id`, runID, fileType)\n   380→\tif err != nil {\n   381→\t\treturn nil, err\n   382→\t}\n   383→\tdefer rows.Close()\n   384→\treturn scanLogFiles(rows)\n   385→}\n   386→\n   387→func scanLogFiles(rows *sql.Rows) ([]*ports.LogFileEntry, error) {\n   388→\tvar entries []*ports.LogFileEntry\n   389→\tfor rows.Next() {\n   390→\t\te := &ports.LogFileEntry{}\n   391→\t\tvar createdAt string\n   392→\t\tif err := rows.Scan(&e.ID, &e.RunID, &e.StepName, &e.FileType, &e.FilePath, &e.FileSize, &createdAt); err != nil {\n   393→\t\t\treturn nil, err\n   394→\t\t}\n   395→\t\te.CreatedAt = parseTime(createdAt)\n   396→\t\tentries = append(entries, e)\n   397→\t}\n   398→\treturn entries, rows.Err()\n   399→}\n   400→\n   401→func (s *Store) SaveEvolution(ctx context.Context, entry *ports.EvolutionEntry) error {\n   402→\t_, err := s.db.ExecContext(ctx,\n   403→\t\t`INSERT INTO evolution_log (id, project_dir, workflow_name, trigger_run_id, created_at, classification, changes_json, knowledge_delta)\n   404→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,\n   405→\t\tentry.ID, entry.ProjectDir, entry.WorkflowName, entry.TriggerRunID,\n   406→\t\tformatTime(entry.CreatedAt), entry.Classification, entry.ChangesJSON, entry.KnowledgeDelta,\n   407→\t)\n   408→\treturn err\n   409→}\n   410→\n   411→func (s *Store) GetLastEvolution(ctx context.Context, projectDir, workflowName string) (*ports.EvolutionEntry, error) {\n   412→\trow := s.db.QueryRowContext(ctx,\n   413→\t\t`SELECT id, project_dir, workflow_name, trigger_run_id, created_at, COALESCE(classification,''), changes_json, COALESCE(knowledge_delta,'')\n   414→\t\t FROM evolution_log WHERE project_dir = ? AND workflow_name = ? ORDER BY created_at DESC LIMIT 1`,\n   415→\t\tprojectDir, workflowName)\n   416→\n   417→\tentry := &ports.EvolutionEntry{}\n   418→\tvar createdAt string\n   419→\terr := row.Scan(&entry.ID, &entry.ProjectDir, &entry.WorkflowName, &entry.TriggerRunID,\n   420→\t\t&createdAt, &entry.Classification, &entry.ChangesJSON, &entry.KnowledgeDelta)\n   421→\tif err == sql.ErrNoRows {\n   422→\t\treturn nil, nil\n   423→\t}\n   424→\tif err != nil {\n   425→\t\treturn nil, err\n   426→\t}\n   427→\tentry.CreatedAt = parseTime(createdAt)\n   428→\treturn entry, nil\n   429→}\n   430→\n   431→func (s *Store) ListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error) {\n   432→\tvar rows *sql.Rows\n   433→\tvar err error\n   434→\n   435→\tif sinceRunID == \"\" {\n   436→\t\trows, err = s.db.QueryContext(ctx,\n   437→\t\t\t`SELECT `+runSelectCols+`\n   438→\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? ORDER BY started_at ASC`,\n   439→\t\t\tprojectDir, workflowName)\n   440→\t} else {\n   441→\t\trows, err = s.db.QueryContext(ctx,\n   442→\t\t\t`SELECT `+runSelectCols+`\n   443→\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? AND started_at > (SELECT started_at FROM runs WHERE id = ?)\n   444→\t\t\t ORDER BY started_at ASC`,\n   445→\t\t\tprojectDir, workflowName, sinceRunID)\n   446→\t}\n   447→\tif err != nil {\n   448→\t\treturn nil, err\n   449→\t}\n   450→\tdefer rows.Close()\n   451→\treturn scanRuns(rows)\n   452→}\n   453→\n   454→\n   455→func (s *Store) FailStaleRuns(ctx context.Context) (int64, error) {\n   456→\tnow := formatTime(time.Now())\n   457→\tres, err := s.db.ExecContext(ctx,\n   458→\t\t`UPDATE runs SET state = 'failed', completed_at = ?, error_message = 'daemon restarted while run was active'\n   459→\t\t WHERE state IN ('pending', 'running')`,\n   460→\t\tnow,\n   461→\t)\n   462→\tif err != nil {\n   463→\t\treturn 0, err\n   464→\t}\n   465→\treturn res.RowsAffected()\n   466→}\n   467→\n   468→func formatTime(t time.Time) string {\n   469→\tif t.IsZero() {\n   470→\t\treturn \"\"\n   471→\t}\n   472→\treturn t.Format(time.RFC3339Nano)\n   473→}\n   474→\n   475→func parseTime(s string) time.Time {\n   476→\tif s == \"\" {\n   477→\t\treturn time.Time{}\n   478→\t}\n   479→\tt, _ := time.Parse(time.RFC3339Nano, s)\n   480→\treturn t\n   481→}\n   482→\n   483→func boolToInt(b bool) int {\n   484→\tif b {\n   485→\t\treturn 1\n   486→\t}\n   487→\treturn 0\n   488→}\n   489→\n   490→const maxErrorMessageLen = 1000\n   491→\n   492→// truncateErrorMessage caps s to maxErrorMessageLen characters to prevent\n   493→// oversized agent output dumps from bloating the database. Full error\n   494→// details remain available in step logs.\n   495→func truncateErrorMessage(s string) string {\n   496→\tif len(s) <= maxErrorMessageLen {\n   497→\t\treturn s\n   498→\t}\n   499→\treturn s[:maxErrorMessageLen] + \"... (truncated)\"\n   500→}\n   501→"}]},"parent_tool_use_id":null,"session_id":"0ab910fd-6732-4b9f-8c0d-5f6d04bd9ebf","uuid":"f036b353-60dc-41dd-80f4-e9b645020731","timestamp":"2026-03-18T19:05:46.626Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/sqlite/store.go","content":"package sqlite\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t_ \"modernc.org/sqlite\"\n)\n\ntype Store struct {\n\tdb *sql.DB\n}\n\nfunc NewStore(dsn string) (*Store, error) {\n\tdb, err := sql.Open(\"sqlite\", dsn)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n\t}\n\n\t// Enable WAL mode for concurrent read/write access\n\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n\n\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n\n\t// Serialize all Go-side access through a single connection so SQLite\n\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n\tdb.SetMaxOpenConns(1)\n\n\tif err := migrate(db); err != nil {\n\t\tdb.Close()\n\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n\t}\n\n\treturn &Store{db: db}, nil\n}\n\nfunc (s *Store) Close() error {\n\treturn s.db.Close()\n}\n\nfunc migrate(db *sql.DB) error {\n\t_, err := db.Exec(`\n\t\tCREATE TABLE IF NOT EXISTS runs (\n\t\t\tid TEXT PRIMARY KEY,\n\t\t\tworkflow_name TEXT NOT NULL,\n\t\t\tstate TEXT NOT NULL,\n\t\t\tactive_steps TEXT,\n\t\t\tstarted_at TEXT,\n\t\t\tcompleted_at TEXT\n\t\t);\n\t\tCREATE TABLE IF NOT EXISTS step_executions (\n\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n\t\t\trun_id TEXT NOT NULL,\n\t\t\tstep_name TEXT NOT NULL,\n\t\t\tresult TEXT,\n\t\t\tstarted_at TEXT NOT NULL,\n\t\t\tcompleted_at TEXT,\n\t\t\tlogs TEXT,\n\t\t\tgit_ref TEXT,\n\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n\t\t);\n\t`)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// Evolution schema additions (idempotent)\n\talterStmts := []string{\n\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n\t\t`ALTER TABLE runs ADD COLUMN title TEXT NOT NULL DEFAULT ''`,\n\t\t`ALTER TABLE runs ADD COLUMN is_host INTEGER NOT NULL DEFAULT 0`,\n\t\t`ALTER TABLE runs ADD COLUMN parent_run_id TEXT NOT NULL DEFAULT ''`,\n\t\t`ALTER TABLE runs ADD COLUMN task_id TEXT NOT NULL DEFAULT ''`,\n\t\t`ALTER TABLE runs ADD COLUMN task_title TEXT NOT NULL DEFAULT ''`,\n\t}\n\tfor _, stmt := range alterStmts {\n\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n\t}\n\n\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n\t\trun_id TEXT NOT NULL,\n\t\tstep_name TEXT,\n\t\tfile_type TEXT NOT NULL,\n\t\tfile_path TEXT NOT NULL,\n\t\tfile_size INTEGER,\n\t\tcreated_at TEXT NOT NULL,\n\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n\t)`)\n\tif errLog != nil {\n\t\treturn errLog\n\t}\n\n\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n\t\trun_id TEXT PRIMARY KEY,\n\t\tbranch TEXT NOT NULL,\n\t\tproject TEXT NOT NULL,\n\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n\t\tenqueued_at TEXT NOT NULL,\n\t\tcompleted_at TEXT\n\t)`)\n\tif errMQ != nil {\n\t\treturn errMQ\n\t}\n\n\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n\t\tid TEXT PRIMARY KEY,\n\t\tproject_dir TEXT NOT NULL,\n\t\tworkflow_name TEXT NOT NULL,\n\t\ttrigger_run_id TEXT NOT NULL,\n\t\tcreated_at TEXT NOT NULL,\n\t\tclassification TEXT,\n\t\tchanges_json TEXT NOT NULL,\n\t\tknowledge_delta TEXT\n\t)`)\n\tif err2 != nil {\n\t\treturn err2\n\t}\n\n\treturn nil\n}\n\nfunc (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n\t_, err := s.db.ExecContext(ctx,\n\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept, title, is_host, parent_run_id, task_id, task_title)\n\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, truncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID, run.TaskTitle,\n\t)\n\treturn err\n}\n\n// runSelectCols is the standard column list for scanning a Run row.\nconst runSelectCols = `id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,''), COALESCE(is_host,0), COALESCE(parent_run_id,''), COALESCE(task_id,''), COALESCE(task_title,'')`\n\n// scanRun scans a single row into a *domain.Run.\nfunc scanRun(scanner interface{ Scan(...any) error }) (*domain.Run, error) {\n\trun := &domain.Run{}\n\tvar activeSteps, startedAt, completedAt string\n\tvar containerKept, isHost int\n\terr := scanner.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title, &isHost, &run.ParentRunID, &run.TaskID, &run.TaskTitle)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\trun.SetActiveStepsFromString(activeSteps)\n\trun.StartedAt = parseTime(startedAt)\n\trun.CompletedAt = parseTime(completedAt)\n\trun.ContainerKept = containerKept != 0\n\trun.IsHost = isHost != 0\n\treturn run, nil\n}\n\nfunc (s *Store) GetRun(ctx context.Context, id string) (*domain.Run, error) {\n\trow := s.db.QueryRowContext(ctx,\n\t\t`SELECT `+runSelectCols+` FROM runs WHERE id = ?`, id)\n\n\trun, err := scanRun(row)\n\tif err == sql.ErrNoRows {\n\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n\t}\n\treturn run, err\n}\n\nfunc (s *Store) UpdateRun(ctx context.Context, run *domain.Run) error {\n\t_, err := s.db.ExecContext(ctx,\n\t\t`UPDATE runs SET state = ?, active_steps = ?, started_at = ?, completed_at = ?, error_message = ?, container_id = ?, base_sha = ?, container_kept = ?, title = ?, is_host = ?, parent_run_id = ?, task_id = ?, task_title = ? WHERE id = ?`,\n\t\tstring(run.State), run.ActiveStepsString(),\n\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt),\n\t\ttruncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID, run.TaskTitle, run.ID,\n\t)\n\treturn err\n}\n\nfunc (s *Store) DeleteRun(ctx context.Context, id string) error {\n\t_, err := s.db.ExecContext(ctx, `DELETE FROM step_executions WHERE run_id = ?`, id)\n\tif err != nil {\n\t\treturn err\n\t}\n\t_, err = s.db.ExecContext(ctx, `DELETE FROM runs WHERE id = ?`, id)\n\treturn err\n}\n\nfunc (s *Store) ListRuns(ctx context.Context, since time.Time) ([]*domain.Run, error) {\n\tvar rows *sql.Rows\n\tvar err error\n\tif since.IsZero() {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT `+runSelectCols+` FROM runs ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`)\n\t} else {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n\t\t\tformatTime(since))\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanRuns(rows)\n}\n\n// scanRuns scans all rows into a []*domain.Run slice.\nfunc scanRuns(rows *sql.Rows) ([]*domain.Run, error) {\n\tvar runs []*domain.Run\n\tfor rows.Next() {\n\t\trun, err := scanRun(rows)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\truns = append(runs, run)\n\t}\n\treturn runs, rows.Err()\n}\n\nfunc (s *Store) ListRunsByProject(ctx context.Context, projectDir string, since time.Time) ([]*domain.Run, error) {\n\tvar rows *sql.Rows\n\tvar err error\n\tif since.IsZero() {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n\t\t\tprojectDir)\n\t} else {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? AND started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n\t\t\tprojectDir, formatTime(since))\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanRuns(rows)\n}\n\nfunc (s *Store) ListRunsFiltered(ctx context.Context, filter domain.RunListFilter) ([]*domain.Run, error) {\n\tquery := `SELECT ` + runSelectCols + ` FROM runs WHERE 1=1`\n\tvar args []interface{}\n\n\tif filter.ProjectDir != \"\" {\n\t\tquery += ` AND project_dir = ?`\n\t\targs = append(args, filter.ProjectDir)\n\t}\n\tif filter.State != \"\" {\n\t\tquery += ` AND state = ?`\n\t\targs = append(args, string(filter.State))\n\t}\n\tif filter.TaskID != \"\" {\n\t\tquery += ` AND task_id = ?`\n\t\targs = append(args, filter.TaskID)\n\t}\n\tif !filter.Since.IsZero() {\n\t\tquery += ` AND (completed_at >= ? OR state IN ('running', 'pending'))`\n\t\targs = append(args, formatTime(filter.Since))\n\t}\n\n\tquery += ` ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`\n\n\tif filter.Limit > 0 {\n\t\tquery += fmt.Sprintf(` LIMIT %d`, filter.Limit)\n\t}\n\n\trows, err := s.db.QueryContext(ctx, query, args...)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanRuns(rows)\n}\n\nfunc (s *Store) ListProjects(ctx context.Context) ([]string, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT DISTINCT project_dir FROM runs WHERE project_dir != '' ORDER BY project_dir`)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\n\tvar projects []string\n\tfor rows.Next() {\n\t\tvar dir string\n\t\tif err := rows.Scan(&dir); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tprojects = append(projects, dir)\n\t}\n\treturn projects, rows.Err()\n}\n\nfunc (s *Store) ListChildRuns(ctx context.Context, parentRunID string) ([]*domain.Run, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT `+runSelectCols+` FROM runs WHERE parent_run_id = ? ORDER BY started_at ASC`,\n\t\tparentRunID)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanRuns(rows)\n}\n\nfunc (s *Store) SaveCapture(ctx context.Context, runID string, exec *domain.StepExecution) error {\n\t_, err := s.db.ExecContext(ctx,\n\t\t`INSERT INTO step_executions (run_id, step_name, result, started_at, completed_at, logs, git_ref)\n\t\t VALUES (?, ?, ?, ?, ?, ?, ?)`,\n\t\trunID, exec.StepName, exec.Result,\n\t\tformatTime(exec.StartedAt), formatTime(exec.CompletedAt),\n\t\texec.Logs, exec.GitRef,\n\t)\n\treturn err\n}\n\nfunc (s *Store) GetCaptures(ctx context.Context, runID string) ([]*domain.StepExecution, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT step_name, result, started_at, completed_at, COALESCE(logs,''), COALESCE(git_ref,'')\n\t\t FROM step_executions WHERE run_id = ? ORDER BY id`, runID)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\n\tvar execs []*domain.StepExecution\n\tfor rows.Next() {\n\t\te := &domain.StepExecution{}\n\t\tvar startedAt, completedAt string\n\t\tif err := rows.Scan(&e.StepName, &e.Result, &startedAt, &completedAt, &e.Logs, &e.GitRef); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\te.StartedAt = parseTime(startedAt)\n\t\te.CompletedAt = parseTime(completedAt)\n\t\texecs = append(execs, e)\n\t}\n\treturn execs, rows.Err()\n}\n\nfunc (s *Store) SaveLogFile(ctx context.Context, entry *ports.LogFileEntry) error {\n\t_, err := s.db.ExecContext(ctx,\n\t\t`INSERT INTO log_files (run_id, step_name, file_type, file_path, file_size, created_at)\n\t\t VALUES (?, ?, ?, ?, ?, ?)`,\n\t\tentry.RunID, entry.StepName, entry.FileType, entry.FilePath, entry.FileSize,\n\t\tformatTime(entry.CreatedAt),\n\t)\n\treturn err\n}\n\nfunc (s *Store) GetLogFiles(ctx context.Context, runID string) ([]*ports.LogFileEntry, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n\t\t FROM log_files WHERE run_id = ? ORDER BY id`, runID)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanLogFiles(rows)\n}\n\nfunc (s *Store) GetLogFilesByStep(ctx context.Context, runID, stepName string) ([]*ports.LogFileEntry, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n\t\t FROM log_files WHERE run_id = ? AND step_name = ? ORDER BY id`, runID, stepName)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanLogFiles(rows)\n}\n\nfunc (s *Store) GetLogFileByType(ctx context.Context, runID, fileType string) ([]*ports.LogFileEntry, error) {\n\trows, err := s.db.QueryContext(ctx,\n\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n\t\t FROM log_files WHERE run_id = ? AND file_type = ? ORDER BY id`, runID, fileType)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanLogFiles(rows)\n}\n\nfunc scanLogFiles(rows *sql.Rows) ([]*ports.LogFileEntry, error) {\n\tvar entries []*ports.LogFileEntry\n\tfor rows.Next() {\n\t\te := &ports.LogFileEntry{}\n\t\tvar createdAt string\n\t\tif err := rows.Scan(&e.ID, &e.RunID, &e.StepName, &e.FileType, &e.FilePath, &e.FileSize, &createdAt); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\te.CreatedAt = parseTime(createdAt)\n\t\tentries = append(entries, e)\n\t}\n\treturn entries, rows.Err()\n}\n\nfunc (s *Store) SaveEvolution(ctx context.Context, entry *ports.EvolutionEntry) error {\n\t_, err := s.db.ExecContext(ctx,\n\t\t`INSERT INTO evolution_log (id, project_dir, workflow_name, trigger_run_id, created_at, classification, changes_json, knowledge_delta)\n\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,\n\t\tentry.ID, entry.ProjectDir, entry.WorkflowName, entry.TriggerRunID,\n\t\tformatTime(entry.CreatedAt), entry.Classification, entry.ChangesJSON, entry.KnowledgeDelta,\n\t)\n\treturn err\n}\n\nfunc (s *Store) GetLastEvolution(ctx context.Context, projectDir, workflowName string) (*ports.EvolutionEntry, error) {\n\trow := s.db.QueryRowContext(ctx,\n\t\t`SELECT id, project_dir, workflow_name, trigger_run_id, created_at, COALESCE(classification,''), changes_json, COALESCE(knowledge_delta,'')\n\t\t FROM evolution_log WHERE project_dir = ? AND workflow_name = ? ORDER BY created_at DESC LIMIT 1`,\n\t\tprojectDir, workflowName)\n\n\tentry := &ports.EvolutionEntry{}\n\tvar createdAt string\n\terr := row.Scan(&entry.ID, &entry.ProjectDir, &entry.WorkflowName, &entry.TriggerRunID,\n\t\t&createdAt, &entry.Classification, &entry.ChangesJSON, &entry.KnowledgeDelta)\n\tif err == sql.ErrNoRows {\n\t\treturn nil, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tentry.CreatedAt = parseTime(createdAt)\n\treturn entry, nil\n}\n\nfunc (s *Store) ListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error) {\n\tvar rows *sql.Rows\n\tvar err error\n\n\tif sinceRunID == \"\" {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT `+runSelectCols+`\n\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? ORDER BY started_at ASC`,\n\t\t\tprojectDir, workflowName)\n\t} else {\n\t\trows, err = s.db.QueryContext(ctx,\n\t\t\t`SELECT `+runSelectCols+`\n\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? AND started_at > (SELECT started_at FROM runs WHERE id = ?)\n\t\t\t ORDER BY started_at ASC`,\n\t\t\tprojectDir, workflowName, sinceRunID)\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\treturn scanRuns(rows)\n}\n\n\nfunc (s *Store) FailStaleRuns(ctx context.Context) (int64, error) {\n\tnow := formatTime(time.Now())\n\tres, err := s.db.ExecContext(ctx,\n\t\t`UPDATE runs SET state = 'failed', completed_at = ?, error_message = 'daemon restarted while run was active'\n\t\t WHERE state IN ('pending', 'running')`,\n\t\tnow,\n\t)\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\treturn res.RowsAffected()\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(time.RFC3339Nano)\n}\n\nfunc parseTime(s string) time.Time {\n\tif s == \"\" {\n\t\treturn time.Time{}\n\t}\n\tt, _ := time.Parse(time.RFC3339Nano, s)\n\treturn t\n}\n\nfunc boolToInt(b bool) int {\n\tif b {\n\t\treturn 1\n\t}\n\treturn 0\n}\n\nconst maxErrorMessageLen = 1000\n\n// truncateErrorMessage caps s to maxErrorMessageLen characters to prevent\n// oversized agent output dumps from bloating the database. Full error\n// details remain available in step logs.\nfunc truncateErrorMessage(s string) string {\n\tif len(s) <= maxErrorMessageLen {\n\t\treturn 