{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XXKxRBaNkcsj43gx7gLRxJ","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"os\"\n     6→\t\"path/filepath\"\n     7→\t\"sort\"\n     8→\t\"strings\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/config\"\n    11→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    12→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    13→)\n    14→\n    15→func cmdValidate(args []string) {\n    16→\tvar projectDir, workflowFilter string\n    17→\tfor i := 0; i < len(args); i++ {\n    18→\t\tswitch args[i] {\n    19→\t\tcase \"--project\":\n    20→\t\t\tif i+1 < len(args) {\n    21→\t\t\t\ti++\n    22→\t\t\t\tprojectDir = args[i]\n    23→\t\t\t}\n    24→\t\tcase \"--workflow\":\n    25→\t\t\tif i+1 < len(args) {\n    26→\t\t\t\ti++\n    27→\t\t\t\tworkflowFilter = args[i]\n    28→\t\t\t}\n    29→\t\t}\n    30→\t}\n    31→\n    32→\tif projectDir == \"\" {\n    33→\t\tprojectDir, _ = os.Getwd()\n    34→\t} else {\n    35→\t\tabs, err := filepath.Abs(projectDir)\n    36→\t\tif err == nil {\n    37→\t\t\tprojectDir = abs\n    38→\t\t}\n    39→\t}\n    40→\n    41→\terrs := validateProject(projectDir, workflowFilter)\n    42→\tif len(errs) > 0 {\n    43→\t\tfor _, e := range errs {\n    44→\t\t\tfmt.Fprintln(os.Stderr, e)\n    45→\t\t}\n    46→\t\tos.Exit(1)\n    47→\t}\n    48→\n    49→\tfmt.Println(\"All configuration valid.\")\n    50→}\n    51→\n    52→// validateProject performs all validation checks and returns a list of errors.\n    53→func validateProject(projectDir, workflowFilter string) []string {\n    54→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n    55→\n    56→\tinfo, err := os.Stat(clocheDir)\n    57→\tif err != nil || !info.IsDir() {\n    58→\t\treturn []string{fmt.Sprintf(\"%s: .cloche directory not found\", projectDir)}\n    59→\t}\n    60→\n    61→\tvar errs []string\n    62→\n    63→\t// 1. Validate config.toml\n    64→\tconfigErrs := validateConfig(projectDir)\n    65→\terrs = append(errs, configErrs...)\n    66→\n    67→\t// 2. Parse and validate workflow files\n    68→\tworkflows, parseErrs := parseAllWorkflowFiles(clocheDir)\n    69→\terrs = append(errs, parseErrs...)\n    70→\n    71→\t// Filter to specific workflow if requested\n    72→\tif workflowFilter != \"\" {\n    73→\t\tfiltered := make(map[string]*workflowFileInfo)\n    74→\t\tfor key, wfi := range workflows {\n    75→\t\t\tif wfi.workflow.Name == workflowFilter {\n    76→\t\t\t\tfiltered[key] = wfi\n    77→\t\t\t}\n    78→\t\t}\n    79→\t\tif len(filtered) == 0 {\n    80→\t\t\terrs = append(errs, fmt.Sprintf(\"workflow %q not found\", workflowFilter))\n    81→\t\t\treturn errs\n    82→\t\t}\n    83→\t\tworkflows = filtered\n    84→\t}\n    85→\n    86→\t// Validate each workflow\n    87→\tfor _, wfi := range workflows {\n    88→\t\twfErrs := validateWorkflow(wfi, clocheDir)\n    89→\t\terrs = append(errs, wfErrs...)\n    90→\t}\n    91→\n    92→\t// 3. Cross-file consistency (only when not filtering)\n    93→\tif workflowFilter == \"\" {\n    94→\t\tcrossErrs := validateCrossFile(projectDir, workflows)\n    95→\t\terrs = append(errs, crossErrs...)\n    96→\t}\n    97→\n    98→\treturn errs\n    99→}\n   100→\n   101→type workflowFileInfo struct {\n   102→\tworkflow *domain.Workflow\n   103→\tfile     string // filename relative to .cloche/\n   104→}\n   105→\n   106→// parseAllWorkflowFiles parses all .cloche files and returns workflows keyed by name.\n   107→func parseAllWorkflowFiles(clocheDir string) (map[string]*workflowFileInfo, []string) {\n   108→\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n   109→\tif err != nil {\n   110→\t\treturn nil, []string{fmt.Sprintf(\"%s: %v\", clocheDir, err)}\n   111→\t}\n   112→\n   113→\tworkflows := make(map[string]*workflowFileInfo)\n   114→\tvar errs []string\n   115→\n   116→\tfor _, path := range entries {\n   117→\t\tdata, err := os.ReadFile(path)\n   118→\t\tif err != nil {\n   119→\t\t\terrs = append(errs, fmt.Sprintf(\"%s: %v\", filepath.Base(path), err))\n   120→\t\t\tcontinue\n   121→\t\t}\n   122→\n   123→\t\twfs, err := dsl.ParseAll(string(data))\n   124→\t\tif err != nil {\n   125→\t\t\terrs = append(errs, fmt.Sprintf(\"%s: %v\", filepath.Base(path), err))\n   126→\t\t\tcontinue\n   127→\t\t}\n   128→\n   129→\t\tfilename := filepath.Base(path)\n   130→\t\tfor name, wf := range wfs {\n   131→\t\t\tif existing, ok := workflows[name]; ok {\n   132→\t\t\t\terrs = append(errs, fmt.Sprintf(\n   133→\t\t\t\t\t\"%s: workflow %q already defined in %s\",\n   134→\t\t\t\t\tfilename, name, existing.file))\n   135→\t\t\t\tcontinue\n   136→\t\t\t}\n   137→\t\t\tworkflows[name] = &workflowFileInfo{workflow: wf, file: filename}\n   138→\t\t}\n   139→\t}\n   140→\n   141→\treturn workflows, errs\n   142→}\n   143→\n   144→// validateConfig checks that config.toml parses and is valid.\n   145→func validateConfig(projectDir string) []string {\n   146→\tconfigPath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n   147→\tif _, err := os.Stat(configPath); os.IsNotExist(err) {\n   148→\t\t// config.toml is optional — defaults are used\n   149→\t\treturn nil\n   150→\t}\n   151→\n   152→\t_, err := config.Load(projectDir)\n   153→\tif err != nil {\n   154→\t\treturn []string{fmt.Sprintf(\"config.toml: %v\", err)}\n   155→\t}\n   156→\n   157→\treturn nil\n   158→}\n   159→\n   160→// validateWorkflow validates a single workflow's structure.\n   161→func validateWorkflow(wfi *workflowFileInfo, clocheDir string) []string {\n   162→\twf := wfi.workflow\n   163→\tvar errs []string\n   164→\n   165→\t// Run domain validation (entry step, wiring, orphans, output mappings)\n   166→\tif err := wf.Validate(); err != nil {\n   167→\t\terrs = append(errs, fmt.Sprintf(\"%s: %v\", wfi.file, err))\n   168→\t}\n   169→\n   170→\t// Location validation\n   171→\tif err := wf.ValidateLocation(); err != nil {\n   172→\t\terrs = append(errs, fmt.Sprintf(\"%s: %v\", wfi.file, err))\n   173→\t}\n   174→\n   175→\t// Config key warnings (treat as errors for validate command)\n   176→\tfor _, w := range wf.ValidateConfig() {\n   177→\t\terrs = append(errs, fmt.Sprintf(\"%s: %v\", wfi.file, w))\n   178→\t}\n   179→\n   180→\t// Terminal coverage: every path must eventually reach done or abort\n   181→\ttermErrs := validateTerminalCoverage(wf, wfi.file)\n   182→\terrs = append(errs, termErrs...)\n   183→\n   184→\t// Prompt and script file references\n   185→\trefErrs := validateFileReferences(wf, wfi.file, clocheDir)\n   186→\terrs = append(errs, refErrs...)\n   187→\n   188→\treturn errs\n   189→}\n   190→\n   191→// validateTerminalCoverage checks that every path through the workflow reaches done or abort.\n   192→func validateTerminalCoverage(wf *domain.Workflow, filename string) []string {\n   193→\tif wf.EntryStep == \"\" {\n   194→\t\treturn nil // already reported by Validate()\n   195→\t}\n   196→\n   197→\t// Build adjacency: step+result -> list of target steps\n   198→\ttype stepResult struct{ step, result string }\n   199→\tadj := make(map[stepResult][]string)\n   200→\tfor _, wire := range wf.Wiring {\n   201→\t\tsr := stepResult{wire.From, wire.Result}\n   202→\t\tadj[sr] = append(adj[sr], wire.To)\n   203→\t}\n   204→\tfor _, c := range wf.Collects {\n   205→\t\tfor _, cond := range c.Conditions {\n   206→\t\t\tsr := stepResult{cond.Step, cond.Result}\n   207→\t\t\tadj[sr] = append(adj[sr], c.To)\n   208→\t\t}\n   209→\t}\n   210→\n   211→\t// DFS from entry step. A step is \"terminal-safe\" if all its results lead\n   212→\t// (directly or transitively) to done/abort. Track visited to handle cycles.\n   213→\tvar errs []string\n   214→\t// Use memoization: true = reaches terminal, false = doesn't\n   215→\tmemo := make(map[string]*bool)\n   216→\n   217→\tvar reaches func(stepName string, visiting map[string]bool) bool\n   218→\treaches = func(stepName string, visiting map[string]bool) bool {\n   219→\t\tif stepName == domain.StepDone || stepName == domain.StepAbort {\n   220→\t\t\treturn true\n   221→\t\t}\n   222→\t\tif _, ok := wf.Steps[stepName]; !ok {\n   223→\t\t\treturn false\n   224→\t\t}\n   225→\t\tif visiting[stepName] {\n   226→\t\t\t// Cycle — not terminal on its own, but the other branch might be\n   227→\t\t\treturn false\n   228→\t\t}\n   229→\t\tif v, ok := memo[stepName]; ok {\n   230→\t\t\treturn *v\n   231→\t\t}\n   232→\n   233→\t\tvisiting[stepName] = true\n   234→\t\tstep := wf.Steps[stepName]\n   235→\t\tallReach := true\n   236→\t\tfor _, result := range step.Results {\n   237→\t\t\tsr := stepResult{stepName, result}\n   238→\t\t\ttargets := adj[sr]\n   239→\t\t\tif len(targets) == 0 {\n   240→\t\t\t\tallReach = false\n   241→\t\t\t\tcontinue\n   242→\t\t\t}\n   243→\t\t\t// At least one target must reach terminal\n   244→\t\t\tanyReach := false\n   245→\t\t\tfor _, t := range targets {\n   246→\t\t\t\tif reaches(t, visiting) {\n   247→\t\t\t\t\tanyReach = true\n   248→\t\t\t\t\tbreak\n   249→\t\t\t\t}\n   250→\t\t\t}\n   251→\t\t\tif !anyReach {\n   252→\t\t\t\tallReach = false\n   253→\t\t\t}\n   254→\t\t}\n   255→\t\tdelete(visiting, stepName)\n   256→\n   257→\t\tmemo[stepName] = &allReach\n   258→\t\treturn allReach\n   259→\t}\n   260→\n   261→\t// Check each step\n   262→\tfor name, step := range wf.Steps {\n   263→\t\tfor _, result := range step.Results {\n   264→\t\t\tsr := stepResult{name, result}\n   265→\t\t\ttargets := adj[sr]\n   266→\t\t\tif len(targets) == 0 {\n   267→\t\t\t\tcontinue // unwired results are caught by Validate()\n   268→\t\t\t}\n   269→\t\t\tanyTerminal := false\n   270→\t\t\tfor _, t := range targets {\n   271→\t\t\t\tif reaches(t, make(map[string]bool)) {\n   272→\t\t\t\t\tanyTerminal = true\n   273→\t\t\t\t\tbreak\n   274→\t\t\t\t}\n   275→\t\t\t}\n   276→\t\t\tif !anyTerminal {\n   277→\t\t\t\terrs = append(errs, fmt.Sprintf(\n   278→\t\t\t\t\t\"%s: workflow %q: step %q result %q does not reach a terminal (done/abort)\",\n   279→\t\t\t\t\tfilename, wf.Name, name, result))\n   280→\t\t\t}\n   281→\t\t}\n   282→\t}\n   283→\n   284→\treturn errs\n   285→}\n   286→\n   287→// validateFileReferences checks that prompt file() and script run references exist.\n   288→func validateFileReferences(wf *domain.Workflow, filename, clocheDir string) []string {\n   289→\tvar errs []string\n   290→\n   291→\tfor _, step := range wf.Steps {\n   292→\t\t// Check prompt file references: file(\"prompts/foo.md\")\n   293→\t\tif promptVal, ok := step.Config[\"prompt\"]; ok {\n   294→\t\t\tif ref := extractFileRef(promptVal); ref != \"\" {\n   295→\t\t\t\tpath := filepath.Join(clocheDir, ref)\n   296→\t\t\t\tif _, err := os.Stat(path); os.IsNotExist(err) {\n   297→\t\t\t\t\terrs = append(errs, fmt.Sprintf(\n   298→\t\t\t\t\t\t\"%s: workflow %q: step %q references missing file %q\",\n   299→\t\t\t\t\t\tfilename, wf.Name, step.Name, ref))\n   300→\t\t\t\t}\n   301→\t\t\t}\n   302→\t\t}\n   303→\n   304→\t\t// Check script run references that point to .cloche/scripts/\n   305→\t\tif runVal, ok := step.Config[\"run\"]; ok {\n   306→\t\t\tscriptRef := extractScriptRef(runVal)\n   307→\t\t\tif scriptRef != \"\" {\n   308→\t\t\t\tpath := filepath.Join(filepath.Dir(clocheDir), scriptRef)\n   309→\t\t\t\tif _, err := os.Stat(path); os.IsNotExist(err) {\n   310→\t\t\t\t\terrs = append(errs, fmt.Sprintf(\n   311→\t\t\t\t\t\t\"%s: workflow %q: step %q references missing script %q\",\n   312→\t\t\t\t\t\tfilename, wf.Name, step.Name, scriptRef))\n   313→\t\t\t\t}\n   314→\t\t\t}\n   315→\t\t}\n   316→\t}\n   317→\n   318→\treturn errs\n   319→}\n   320→\n   321→// extractFileRef extracts the path from file(\"path\") syntax.\n   322→func extractFileRef(val string) string {\n   323→\tif !strings.HasPrefix(val, `file(\"`) || !strings.HasSuffix(val, `\")`) {\n   324→\t\treturn \"\"\n   325→\t}\n   326→\treturn val[6 : len(val)-2]\n   327→}\n   328→\n   329→// extractScriptRef extracts .cloche/scripts/ references from run commands.\n   330→// Returns the relative path if the run value references a .cloche/scripts/ file.\n   331→func extractScriptRef(val string) string {\n   332→\t// Look for .cloche/scripts/ references in the run command\n   333→\t// Common patterns: \"bash .cloche/scripts/foo.sh\" or \".cloche/scripts/foo.sh\"\n   334→\tparts := strings.Fields(val)\n   335→\tfor _, part := range parts {\n   336→\t\tif strings.HasPrefix(part, \".cloche/scripts/\") {\n   337→\t\t\treturn part\n   338→\t\t}\n   339→\t}\n   340→\treturn \"\"\n   341→}\n   342→\n   343→// validateCrossFile checks that workflows referenced in config exist as files and vice versa.\n   344→func validateCrossFile(projectDir string, workflows map[string]*workflowFileInfo) []string {\n   345→\tconfigPath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n   346→\tif _, err := os.Stat(configPath); os.IsNotExist(err) {\n   347→\t\treturn nil\n   348→\t}\n   349→\n   350→\t// Check that workflow steps (workflow_name references) point to existing workflows\n   351→\tvar errs []string\n   352→\tworkflowNames := make(map[string]bool)\n   353→\tfor name := range workflows {\n   354→\t\tworkflowNames[name] = true\n   355→\t}\n   356→\n   357→\tfor _, wfi := range workflows {\n   358→\t\tfor _, step := range wfi.workflow.Steps {\n   359→\t\t\tif step.Type == domain.StepTypeWorkflow {\n   360→\t\t\t\trefName := step.Config[\"workflow_name\"]\n   361→\t\t\t\tif refName != \"\" && !workflowNames[refName] {\n   362→\t\t\t\t\terrs = append(errs, fmt.Sprintf(\n   363→\t\t\t\t\t\t\"%s: workflow %q: step %q references undefined workflow %q\",\n   364→\t\t\t\t\t\twfi.file, wfi.workflow.Name, step.Name, refName))\n   365→\t\t\t\t}\n   366→\t\t\t}\n   367→\t\t}\n   368→\t}\n   369→\n   370→\t// Sort errors for deterministic output\n   371→\tsort.Strings(errs)\n   372→\n   373→\treturn errs\n   374→}\n   375→"}]},"parent_tool_use_id":null,"session_id":"3e2d37ae-91e3-456c-960e-fc7d9d2422da","uuid":"9e7c4d70-0141-4cce-a09f-3275dbf2a829","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/validate.go","content":"package main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n)\n\nfunc cmdValidate(args []string) {\n\tvar projectDir, workflowFilter string\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflowFilter = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tprojectDir, _ = os.Getwd()\n\t} else {\n\t\tabs, err := filepath.Abs(projectDir)\n\t\tif err == nil {\n\t\t\tprojectDir = abs\n\t\t}\n\t}\n\n\terrs := validateProject(projectDir, workflowFilter)\n\tif len(errs) > 0 {\n\t\tfor _, e := range errs {\n\t\t\tfmt.Fprintln(os.Stderr, e)\n\t\t}\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Println(\"All configuration valid.\")\n}\n\n// validateProject performs all validation checks and returns a list of errors.\nfunc validateProject(projectDir, workflowFilter string) []string {\n\tclocheDir := filepath.Join(projectDir, \".cloche\")\n\n\tinfo, err := os.Stat(clocheDir)\n\tif err != nil || !info.IsDir() {\n\t\treturn []string{fmt.Sprintf(\"%s: .cloche directory not found\", projectDir)}\n\t}\n\n\tvar errs []string\n\n\t// 1. Validate config.toml\n\tconfigErrs := validateConfig(projectDir)\n\terrs = append(errs, configErrs...)\n\n\t// 2. Parse and validate workflow files\n\tworkflows, parseErrs := parseAllWorkflowFiles(clocheDir)\n\terrs = append(errs, parseErrs...)\n\n\t// Filter to specific workflow if requested\n\tif workflowFilter != \"\" {\n\t\tfiltered := make(map[string]*workflowFileInfo)\n\t\tfor key, wfi := range workflows {\n\t\t\tif wfi.workflow.Name == workflowFilter {\n\t\t\t\tfiltered[key] = wfi\n\t\t\t}\n\t\t}\n\t\tif len(filtered) == 0 {\n\t\t\terrs = append(errs, fmt.Sprintf(\"workflow %q not found\", workflowFilter))\n\t\t\treturn errs\n\t\t}\n\t\tworkflows = filtered\n\t}\n\n\t// Validate each workflow\n\tfor _, wfi := range workflows {\n\t\twfErrs := validateWorkflow(wfi, clocheDir)\n\t\terrs = append(errs, wfErrs...)\n\t}\n\n\t// 3. Cross-file consistency (only when not filtering)\n\tif workflowFilter == \"\" {\n\t\tcrossErrs := validateCrossFile(projectDir, workflows)\n\t\terrs = append(errs, crossErrs...)\n\t}\n\n\treturn errs\n}\n\ntype workflowFileInfo struct {\n\tworkflow *domain.Workflow\n\tfile     string // filename relative to .cloche/\n}\n\n// parseAllWorkflowFiles parses all .cloche files and returns workflows keyed by name.\nfunc parseAllWorkflowFiles(clocheDir string) (map[string]*workflowFileInfo, []string) {\n\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n\tif err != nil {\n\t\treturn nil, []string{fmt.Sprintf(\"%s: %v\", clocheDir, err)}\n\t}\n\n\tworkflows := make(map[string]*workflowFileInfo)\n\tvar errs []string\n\n\tfor _, path := range entries {\n\t\tdata, err := os.ReadFile(path)\n\t\tif err != nil {\n\t\t\terrs = append(errs, fmt.Sprintf(\"%s: %v\", filepath.Base(path), err))\n\t\t\tcontinue\n\t\t}\n\n\t\twfs, err := dsl.ParseAll(string(data))\n\t\tif err != nil {\n\t\t\terrs = append(errs, fmt.Sprintf(\"%s: %v\", filepath.Base(path), err))\n\t\t\tcontinue\n\t\t}\n\n\t\tfilename := filepath.Base(path)\n\t\tfor name, wf := range wfs {\n\t\t\tif existing, ok := workflows[name]; ok {\n\t\t\t\terrs = append(errs, fmt.Sprintf(\n\t\t\t\t\t\"%s: workflow %q already defined in %s\",\n\t\t\t\t\tfilename, name, existing.file))\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tworkflows[name] = &workflowFileInfo{workflow: wf, file: filename}\n\t\t}\n\t}\n\n\treturn workflows, errs\n}\n\n// validateConfig checks that config.toml parses and is valid.\nfunc validateConfig(projectDir string) []string {\n\tconfigPath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n\tif _, err := os.Stat(configPath); os.IsNotExist(err) {\n\t\t// config.toml is optional — defaults are used\n\t\treturn nil\n\t}\n\n\t_, err := config.Load(projectDir)\n\tif err != nil {\n\t\treturn []string{fmt.Sprintf(\"config.toml: %v\", err)}\n\t}\n\n\treturn nil\n}\n\n// validateWorkflow validates a single workflow's structure.\nfunc validateWorkflow(wfi *workflowFileInfo, clocheDir string) []string {\n\twf := wfi.workflow\n\tvar errs []string\n\n\t// Run domain validation (entry step, wiring, orphans, output mappings)\n\tif err := wf.Validate(); err != nil {\n\t\terrs = append(errs, fmt.Sprintf(\"%s: %v\", wfi.file, err))\n\t}\n\n\t// Location validation\n\tif err := wf.ValidateLocation(); err != nil {\n\t\terrs = append(errs, fmt.Sprintf(\"%s: %v\", wfi.file, err))\n\t}\n\n\t// Config key warnings (treat as errors for validate command)\n\tfor _, w := range wf.ValidateConfig() {\n\t\terrs = append(errs, fmt.Sprintf(\"%s: %v\", wfi.file, w))\n\t}\n\n\t// Terminal coverage: every path must eventually reach done or abort\n\ttermErrs := validateTerminalCoverage(wf, wfi.file)\n\terrs = append(errs, termErrs...)\n\n\t// Prompt and script file references\n\trefErrs := validateFileReferences(wf, wfi.file, clocheDir)\n\terrs = append(errs, refErrs...)\n\n\treturn errs\n}\n\n// validateTerminalCoverage checks that every path through the workflow reaches done or abort.\nfunc validateTerminalCoverage(wf *domain.Workflow, filename string) []string {\n\tif wf.EntryStep == \"\" {\n\t\treturn nil // already reported by Validate()\n\t}\n\n\t// Build adjacency: step+result -> list of target steps\n\ttype stepResult struct{ step, result string }\n\tadj := make(map[stepResult][]string)\n\tfor _, wire := range wf.Wiring {\n\t\tsr := stepResult{wire.From, wire.Result}\n\t\tadj[sr] = append(adj[sr], wire.To)\n\t}\n\tfor _, c := range wf.Collects {\n\t\tfor _, cond := range c.Conditions {\n\t\t\tsr := stepResult{cond.Step, cond.Result}\n\t\t\tadj[sr] = append(adj[sr], c.To)\n\t\t}\n\t}\n\n\t// DFS from entry step. A step is \"terminal-safe\" if all its results lead\n\t// (directly or transitively) to done/abort. Track visited to handle cycles.\n\tvar errs []string\n\t// Use memoization: true = reaches terminal, false = doesn't\n\tmemo := make(map[string]*bool)\n\n\tvar reaches func(stepName string, visiting map[string]bool) bool\n\treaches = func(stepName string, visiting map[string]bool) bool {\n\t\tif stepName == domain.StepDone || stepName == domain.StepAbort {\n\t\t\treturn true\n\t\t}\n\t\tif _, ok := wf.Steps[stepName]; !ok {\n\t\t\treturn false\n\t\t}\n\t\tif visiting[stepName] {\n\t\t\t// Cycle — not terminal on its own, but the other branch might be\n\t\t\treturn false\n\t\t}\n\t\tif v, ok := memo[stepName]; ok {\n\t\t\treturn *v\n\t\t}\n\n\t\tvisiting[stepName] = true\n\t\tstep := wf.Steps[stepName]\n\t\tallReach := true\n\t\tfor _, result := range step.Results {\n\t\t\tsr := stepResult{stepName, result}\n\t\t\ttargets := adj[sr]\n\t\t\tif len(targets) == 0 {\n\t\t\t\tallReach = false\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\t// At least one target must reach terminal\n\t\t\tanyReach := false\n\t\t\tfor _, t := range targets {\n\t\t\t\tif reaches(t, visiting) {\n\t\t\t\t\tanyReach = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !anyReach {\n\t\t\t\tallReach = false\n\t\t\t}\n\t\t}\n\t\tdelete(visiting, stepName)\n\n\t\tmemo[stepName] = &allReach\n\t\treturn allReach\n\t}\n\n\t// Check each step\n\tfor name, step := range wf.Steps {\n\t\tfor _, result := range step.Results {\n\t\t\tsr := stepResult{name, result}\n\t\t\ttargets := adj[sr]\n\t\t\tif len(targets) == 0 {\n\t\t\t\tcontinue // unwired results are caught by Validate()\n\t\t\t}\n\t\t\tanyTerminal := false\n\t\t\tfor _, t := range targets {\n\t\t\t\tif reaches(t, make(map[string]bool)) {\n\t\t\t\t\tanyTerminal = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !anyTerminal {\n\t\t\t\terrs = append(errs, fmt.Sprintf(\n\t\t\t\t\t\"%s: workflow %q: step %q result %q does not reach a terminal (done/abort)\",\n\t\t\t\t\tfilename, wf.Name, name, result))\n\t\t\t}\n\t\t}\n\t}\n\n\treturn errs\n}\n\n// validateFileReferences checks that prompt file() and script run references exist.\nfunc validateFileReferences(wf *domain.Workflow, filename, clocheDir string) []string {\n\tvar errs []string\n\n\tfor _, step := range wf.Steps {\n\t\t// Check prompt file references: file(\"prompts/foo.md\")\n\t\tif promptVal, ok := step.Config[\"prompt\"]; ok {\n\t\t\tif ref := extractFileRef(promptVal); ref != \"\" {\n\t\t\t\tpath := filepath.Join(clocheDir, ref)\n\t\t\t\tif _, err := os.Stat(path); os.IsNotExist(err) {\n\t\t\t\t\terrs = append(errs, fmt.Sprintf(\n\t\t\t\t\t\t\"%s: workflow %q: step %q references missing file %q\",\n\t\t\t\t\t\tfilename, wf.Name, step.Name, ref))\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\t// Check script run references that point to .cloche/scripts/\n\t\tif runVal, ok := step.Config[\"run\"]; ok {\n\t\t\tscriptRef := extractScriptRef(runVal)\n\t\t\tif scriptRef != \"\" {\n\t\t\t\tpath := filepath.Join(filepath.Dir(clocheDir), scriptRef)\n\t\t\t\tif _, err := os.Stat(path); os.IsNotExist(err) {\n\t\t\t\t\terrs = append(errs, fmt.Sprintf(\n\t\t\t\t\t\t\"%s: workflow %q: step %q references missing script %q\",\n\t\t\t\t\t\tfilename, wf.Name, step.Name, scriptRef))\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn errs\n}\n\n// extractFileRef extracts the path from file(\"path\") syntax.\nfunc extractFileRef(val string) string {\n\tif !strings.HasPrefix(val, `file(\"`) || !strings.HasSuffix(val, `\")`) {\n\t\treturn \"\"\n\t}\n\treturn val[6 : len(val)-2]\n}\n\n// extractScriptRef extracts .cloche/scripts/ references from run commands.\n// Returns the relative path if the run value references a .cloche/scripts/ file.\nfunc extractScriptRef(val string) string {\n\t// Look for .cloche/scripts/ references in the run command\n\t// Common patterns: \"bash .cloche/scripts/foo.sh\" or \".cloche/scripts/foo.sh\"\n\tparts := strings.Fields(val)\n\tfor _, part := range parts {\n\t\tif strings.HasPrefix(part, \".cloche/scripts/\") {\n\t\t\treturn part\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// validateCrossFile checks that workflows referenced in config exist as files and vice versa.\nfunc validateCrossFile(projectDir string, workflows map[string]*workflowFileInfo) []string {\n\tconfigPath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n\tif _, err := os.Stat(configPath); os.IsNotExist(err) {\n\t\treturn nil\n\t}\n\n\t// Check that workflow steps (workflow_name references) point to existing workflows\n\tvar errs []string\n\tworkflowNames := make(map[string]bool)\n\tfor name := range workflows {\n\t\tworkflowNames[name] = true\n\t}\n\n\tfor _, wfi := range workflows {\n\t\tfor _, step := range wfi.workflow.Steps {\n\t\t\tif step.Type == domain.StepTypeWorkflow {\n\t\t\t\trefName := step.Config[\"workflow_name\"]\n\t\t\t\tif refName != \"\" && !workflowNames[refName] {\n\t\t\t\t\terrs = append(errs, fmt.Sprintf(\n\t\t\t\t\t\t\"%s: workflow %q: step %q references undefined workflow %q\",\n\t\t\t\t\t\twfi.file, wfi.workflow.Name, step.Name, refName))\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Sort errors for deterministic output\n\tsort.Strings(errs)\n\n\treturn errs\n}\n","numLines":375,"startLine":1,"totalLines":375}}}
