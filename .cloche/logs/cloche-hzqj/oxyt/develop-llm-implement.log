{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YMrjabZ6vxd1XijXMTwNEE","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"time\"\n     8→\n     9→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    10→\t\"google.golang.org/grpc\"\n    11→\t\"google.golang.org/grpc/credentials/insecure\"\n    12→)\n    13→\n    14→func cmdProject(args []string) {\n    15→\tvar name string\n    16→\n    17→\tfor i := 0; i < len(args); i++ {\n    18→\t\tswitch args[i] {\n    19→\t\tcase \"--name\":\n    20→\t\t\tif i+1 < len(args) {\n    21→\t\t\t\ti++\n    22→\t\t\t\tname = args[i]\n    23→\t\t\t}\n    24→\t\t}\n    25→\t}\n    26→\n    27→\t// Connect to daemon.\n    28→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    29→\tif addr == \"\" {\n    30→\t\taddr = \"unix:///tmp/cloche.sock\"\n    31→\t}\n    32→\n    33→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n    34→\tif err != nil {\n    35→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n    36→\t\tos.Exit(1)\n    37→\t}\n    38→\tdefer conn.Close()\n    39→\n    40→\tclient := pb.NewClocheServiceClient(conn)\n    41→\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n    42→\tdefer cancel()\n    43→\n    44→\treq := &pb.GetProjectInfoRequest{}\n    45→\tif name != \"\" {\n    46→\t\treq.Name = name\n    47→\t} else {\n    48→\t\tcwd, _ := os.Getwd()\n    49→\t\treq.ProjectDir = cwd\n    50→\t}\n    51→\n    52→\tresp, err := client.GetProjectInfo(ctx, req)\n    53→\tif err != nil {\n    54→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    55→\t\tos.Exit(1)\n    56→\t}\n    57→\n    58→\t// Display project info.\n    59→\tfmt.Printf(\"Project:     %s\\n\", resp.Name)\n    60→\tfmt.Printf(\"Directory:   %s\\n\", resp.ProjectDir)\n    61→\tfmt.Println()\n    62→\n    63→\t// Config settings.\n    64→\tfmt.Println(\"Config:\")\n    65→\tfmt.Printf(\"  active:             %v\\n\", resp.Active)\n    66→\tfmt.Printf(\"  concurrency:        %d\\n\", resp.Concurrency)\n    67→\tif resp.StaggerSeconds > 0 {\n    68→\t\tfmt.Printf(\"  stagger_seconds:    %.1f\\n\", resp.StaggerSeconds)\n    69→\t}\n    70→\tif resp.DedupSeconds > 0 {\n    71→\t\tfmt.Printf(\"  dedup_seconds:      %.0f\\n\", resp.DedupSeconds)\n    72→\t}\n    73→\tfmt.Printf(\"  stop_on_error:      %v\\n\", resp.StopOnError)\n    74→\tfmt.Printf(\"  evolution:          %v\\n\", resp.EvolutionEnabled)\n    75→\tfmt.Println()\n    76→\n    77→\t// Orchestrator loop state.\n    78→\tloopState := \"stopped\"\n    79→\tif resp.LoopRunning {\n    80→\t\tif resp.ErrorHalted {\n    81→\t\t\tloopState = \"halted\"\n    82→\t\t} else {\n    83→\t\t\tloopState = \"running\"\n    84→\t\t}\n    85→\t}\n    86→\tfmt.Printf(\"Loop:        %s\\n\", loopState)\n    87→\tif resp.ErrorHalted {\n    88→\t\tfmt.Printf(\"Halt error:  %s\\n\", resp.HaltError)\n    89→\t}\n    90→\tfmt.Println()\n    91→\n    92→\t// Active runs.\n    93→\tif len(resp.ActiveRuns) > 0 {\n    94→\t\tfmt.Printf(\"Active runs: %d\\n\", len(resp.ActiveRuns))\n    95→\t\tfor _, run := range resp.ActiveRuns {\n    96→\t\t\trunType := \"container\"\n    97→\t\t\tif run.IsHost {\n    98→\t\t\t\trunType = \"host\"\n    99→\t\t\t}\n   100→\t\t\tline := fmt.Sprintf(\"  %s  %-20s  %-10s  %s\", run.RunId, run.WorkflowName, run.State, runType)\n   101→\t\t\tif run.Title != \"\" {\n   102→\t\t\t\tt := run.Title\n   103→\t\t\t\tif len(t) > 40 {\n   104→\t\t\t\t\tt = t[:37] + \"...\"\n   105→\t\t\t\t}\n   106→\t\t\t\tline += \"  \" + t\n   107→\t\t\t}\n   108→\t\t\tfmt.Println(line)\n   109→\t\t}\n   110→\t} else {\n   111→\t\tfmt.Println(\"Active runs: none\")\n   112→\t}\n   113→\tfmt.Println()\n   114→\n   115→\t// Workflows.\n   116→\tif len(resp.ContainerWorkflows) > 0 {\n   117→\t\tfmt.Println(\"Container workflows:\")\n   118→\t\tfor _, wfName := range resp.ContainerWorkflows {\n   119→\t\t\tfmt.Printf(\"  %s\\n\", wfName)\n   120→\t\t}\n   121→\t} else {\n   122→\t\tfmt.Println(\"Container workflows: none\")\n   123→\t}\n   124→\n   125→\tif len(resp.HostWorkflows) > 0 {\n   126→\t\tfmt.Println(\"Host workflows:\")\n   127→\t\tfor _, wfName := range resp.HostWorkflows {\n   128→\t\t\tfmt.Printf(\"  %s\\n\", wfName)\n   129→\t\t}\n   130→\t} else {\n   131→\t\tfmt.Println(\"Host workflows: none\")\n   132→\t}\n   133→}\n   134→"}]},"parent_tool_use_id":"toolu_01YBDNVBTQUf847DxND28odt","session_id":"955b2dd5-cc52-456b-afc0-0035f6eae0d8","uuid":"8cd461f4-a170-4d05-9d25-336e34fdde54"}
