   64→\t\treturn\n    65→\tcase \"get\":\n    66→\t\tif hasHelpFlag(os.Args[2:]) {\n    67→\t\t\tprintSubcommandHelp(\"get\")\n    68→\t\t\treturn\n    69→\t\t}\n    70→\t\tcmdGet(os.Args[2:])\n    71→\t\treturn\n    72→\tcase \"set\":\n    73→\t\tif hasHelpFlag(os.Args[2:]) {\n    74→\t\t\tprintSubcommandHelp(\"set\")\n    75→\t\t\treturn\n    76→\t\t}\n    77→\t\tcmdSet(os.Args[2:])\n    78→\t\treturn\n    79→\tcase \"tasks\":\n    80→\t\tif hasHelpFlag(os.Args[2:]) {\n    81→\t\t\tprintSubcommandHelp(\"tasks\")\n    82→\t\t\treturn\n    83→\t\t}\n    84→\t\tcmdTasks(os.Args[2:])\n    85→\t\treturn\n    86→\tcase \"workflow\":\n    87→\t\tif hasHelpFlag(os.Args[2:]) {\n    88→\t\t\tprintSubcommandHelp(\"workflow\")\n    89→\t\t\treturn\n    90→\t\t}\n    91→\t\tcmdWorkflow(os.Args[2:])\n    92→\t\treturn\n    93→\tcase \"project\":\n    94→\t\tif hasHelpFlag(os.Args[2:]) {\n    95→\t\t\tprintSubcommandHelp(\"project\")\n    96→\t\t\treturn\n    97→\t\t}\n    98→\t\tcmdProject(os.Args[2:])\n    99→\t\treturn\n   100→\t}\n   101→\n   102→\t// Handle --help for daemon commands before connecting\n   103→\tdaemonCmds := map[string]bool{\n   104→\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n   105→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n   106→\t}\n   107→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n   108→\t\tprintSubcommandHelp(os.Args[1])\n   109→\t\treturn\n   110→\t}\n   111→\n   112→\t// Commands that need a daemon connection\n   113→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   114→\tif addr == \"\" {\n   115→\t\taddr = \"unix:///tmp/cloche.sock\"\n   116→\t}\n   117→\n   118→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   119→\tif err != nil {\n   120→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   121→\t\tos.Exit(1)\n   122→\t}\n   123→\tdefer conn.Close()\n   124→\n   125→\tclient := pb.NewClocheServiceClient(conn)\n   126→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   127→\tdefer cancel()\n   128→\n   129→\tswitch os.Args[1] {\n   130→\tcase \"run\":\n   131→\t\tcmdRun(ctx, client, os.Args[2:])\n   132→\tcase \"status\":\n   133→\t\tcmdStatus(ctx, client, os.Args[2:])\n   134→\tcase \"logs\":\n   135→\t\tcmdLogs(client, os.Args[2:])\n   136→\tcase \"poll\":\n   137→\t\tcmdPoll(client, os.Args[2:])\n   138→\tcase \"list\":\n   139→\t\tcmdList(ctx, client, os.Args[2:])\n   140→\tcase \"stop\":\n   141→\t\tcmdStop(ctx, client, os.Args[2:])\n   142→\tcase \"delete\":\n   143→\t\tcmdDelete(ctx, client, os.Args[2:])\n   144→\tcase \"loop\":\n   145→\t\tcmdLoop(ctx, client, os.Args[2:])\n   146→\tcase \"shutdown\":\n   147→\t\tcmdShutdown(ctx, client, os.Args[2:])\n   148→\tdefault:\n   149→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   150→\t\tprintTopLevelHelp()\n   151→\t\tos.Exit(1)\n   152→\t}\n   153→}\n   154→\n   155→\n   156→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   157→\tvar workflow, prompt, title string\n   158→\tvar keepContainer bool\n   159→\n   160→\tfor i := 0; i < len(args); i++ {\n   161→\t\tswitch args[i] {\n   162→\t\tcase \"--workflow\":\n   163→\t\t\tif i+1 < len(args) {\n   164→\t\t\t\ti++\n   165→\t\t\t\tworkflow = args[i]\n   166→\t\t\t}\n   167→\t\tcase \"--prompt\", \"-p\":\n   168→\t\t\tif i+1 < len(args) {\n   169→\t\t\t\ti++\n   170→\t\t\t\tprompt = args[i]\n   171→\t\t\t}\n   172→\t\tcase \"--title\":\n   173→\t\t\tif i+1 < len(args) {\n   174→\t\t\t\ti++\n   175→\t\t\t\ttitle = args[i]\n   176→\t\t\t}\n   177→\t\tcase \"--keep-container\":\n   178→\t\t\tkeepContainer = true\n   179→\t\tdefault:\n   180→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   181→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   182→\t\t\t\tworkflow = args[i]\n   183→\t\t\t}\n   184→\t\t}\n   185→\t}\n   186→\n   187→\tif workflow == \"\" {\n   188→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   189→\t\tos.Exit(1)\n   190→\t}\n   191→\n   192→\tcwd, _ := os.Getwd()\n   193→\n   194→\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n   195→\t// Try loading from any .cloche file; only extract image for container workflows.\n   196→\tvar image string\n   197→\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n   198→\t\timage = wf.Config[\"container.image\"]\n   199→\t}\n   200→\n   201→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   202→\t\tWorkflowName:  workflow,\n   203→\t\tProjectDir:    cwd,\n   204→\t\tImage:         image,\n   205→\t\tPrompt:        prompt,\n   206→\t\tKeepContainer: keepContainer,\n   207→\t\tTitle:         title,\n   208→\t})\n   209→\tif err != nil {\n   210→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   211→\t\tos.Exit(1)\n   212→\t}\n   213→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   214→}\n   215→\n   216→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   217→\tif len(args) < 1 {\n   218→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   219→\t\tos.Exit(1)\n   220→\t}\n   221→\n   222→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   223→\tif err != nil {\n   224→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   225→\t\tos.Exit(1)\n   226→\t}\n   227→\n   228→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   229→\tif resp.Title != \"\" {\n   230→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   231→\t}\n   232→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   233→\tif resp.IsHost {\n   234→\t\tfmt.Printf(\"Type:      host\\n\")\n   235→\t} else {\n   236→\t\tfmt.Printf(\"Type:      container\\n\")\n   237→\t}\n   238→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   239→\tif resp.ContainerId != \"\" {\n   240→\t\tcid := resp.ContainerId\n   241→\t\tif len(cid) > 12 {\n   242→\t\t\tcid = cid[:12]\n   243→\t\t}\n   244→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   245→\t}\n   246→\tif resp.ErrorMessage != \"\" {\n   247→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   248→\t}\n   249→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   250→\tfor _, exec := range resp.StepExecutions {\n   251→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   252→\t}\n   253→}\n   254→\n   255→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   256→\tvar all bool\n   257→\tvar projectDir, stateFilter, issueFilter string\n   258→\tvar limit int32\n   259→\n   260→\tfor i := 0; i < len(args); i++ {\n   261→\t\tswitch args[i] {\n   262→\t\tcase \"--all\":\n   263→\t\t\tall = true\n   264→\t\tcase \"--project\", \"-p\":\n   265→\t\t\tif i+1 < len(args) {\n   266→\t\t\t\ti++\n   267→\t\t\t\tprojectDir = args[i]\n   268→\t\t\t}\n   269→\t\tcase \"--state\", \"-s\":\n   270→\t\t\tif i+1 < len(args) {\n   271→\t\t\t\ti++\n   272→\t\t\t\tstateFilter = args[i]\n   273→\t\t\t}\n   274→\t\tcase \"--limit\", \"-n\":\n   275→\t\t\tif i+1 < len(args) {\n   276→\t\t\t\ti++\n   277→\t\t\t\tn, err := strconv.Atoi(args[i])\n   278→\t\t\t\tif err != nil {\n   279→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   280→\t\t\t\t\tos.Exit(1)\n   281→\t\t\t\t}\n   282→\t\t\t\tlimit = int32(n)\n   283→\t\t\t}\n   284→\t\tcase \"--issue\", \"-i\":\n   285→\t\t\tif i+1 < len(args) {\n   286→\t\t\t\ti++\n   287→\t\t\t\tissueFilter = args[i]\n   288→\t\t\t}\n   289→\t\t}\n   290→\t}\n   291→\n   292→\treq := &pb.ListRunsRequest{\n   293→\t\tState:  stateFilter,\n   294→\t\tLimit:  limit,\n   295→\t\tTaskId: issueFilter,\n   296→\t}\n   297→\tif projectDir != \"\" {\n   298→\t\treq.ProjectDir = projectDir\n   299→\t} else if all {\n   300→\t\treq.All = true\n   301→\t} else {\n   302→\t\t// Default: filter to current project\n   303→\t\tcwd, _ := os.Getwd()\n   304→\t\treq.ProjectDir = cwd\n   305→\t}\n   306→\n   307→\tresp, err := client.ListRuns(ctx, req)\n   308→\tif err != nil {\n   309→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   310→\t\tos.Exit(1)\n   311→\t}\n   312→\n   313→\tif len(resp.Runs) == 0 {\n   314→\t\tfmt.Println(\"No runs found.\")\n   315→\t\treturn\n   316→\t}\n   317→\n   318→\tfor _, run := range resp.Runs {\n   319→\t\trunType := \"container\"\n   320→\t\tif run.IsHost {\n   321→\t\t\trunType = \"host\"\n   322→\t\t}\n   323→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   324→\t\tif run.Title != \"\" {\n   325→\t\t\tt := run.Title\n   326→\t\t\tif len(t) > 40 {\n   327→\t\t\t\tt = t[:37] + \"...\"\n   328→\t\t\t}\n   329→\t\t\tline += \"  \" + t\n   330→\t\t}\n   331→\t\tif run.ContainerId != \"\" {\n   332→\t\t\tline += \"  \" + run.ContainerId\n   333→\t\t}\n   334→\t\tif run.ErrorMessage != \"\" {\n   335→\t\t\terrMsg := run.ErrorMessage\n   336→\t\t\tif len(errMsg) > 60 {\n   337→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   338→\t\t\t}\n   339→\t\t\tline += \"  \" + errMsg\n   340→\t\t}\n   341→\t\tfmt.Println(line)\n   342→\t}\n   343→}\n   344→\n   345→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   346→\tif len(args) < 1 {\n   347→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n   348→\t\tos.Exit(1)\n   349→\t}\n   350→\n   351→\tvar stepFilter, typeFilter string\n   352→\tvar follow bool\n   353→\tvar limit int\n   354→\trunID := args[0]\n   355→\n   356→\tfor i := 1; i < len(args); i++ {\n   357→\t\tswitch args[i] {\n   358→\t\tcase \"--step\", \"-s\":\n   359→\t\t\tif i+1 < len(args) {\n   360→\t\t\t\ti++\n   361→\t\t\t\tstepFilter = args[i]\n   362→\t\t\t}\n   363→\t\tcase \"--type\":\n   364→\t\t\tif i+1 < len(args) {\n   365→\t\t\t\ti++\n   366→\t\t\t\ttypeFilter = args[i]\n   367→\t\t\t}\n   368→\t\tcase \"--follow\", \"-f\":\n   369→\t\t\tfollow = true\n   370→\t\tcase \"--limit\", \"-l\":\n   371→\t\t\tif i+1 < len(args) {\n   372→\t\t\t\ti++\n   373→\t\t\t\tn, err := strconv.Atoi(args[i])\n   374→\t\t\t\tif err != nil || n < 0 {\n   375→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n   376→\t\t\t\t\tos.Exit(1)\n   377→\t\t\t\t}\n   378→\t\t\t\tlimit = n\n   379→\t\t\t}\n   380→\t\t}\n   381→\t}\n   382→\n   383→\t// Use background context — log output can be large and follow mode blocks.\n   384→\tctx := context.Background()\n   385→\tvar mdPairs []string\n   386→\tif follow {\n   387→\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n   388→\t}\n   389→\tif limit > 0 {\n   390→\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n   391→\t}\n   392→\tif len(mdPairs) > 0 {\n   393→\t\tmd := metadata.Pairs(mdPairs...)\n   394→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   395→\t}\n   396→\n   397→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   398→\t\tRunId:    runID,\n   399→\t\tStepName: stepFilter,\n   400→\t\tLogType:  typeFilter,\n   401→\t})\n   402→\tif err != nil {\n   403→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   404→\t\tos.Exit(1)\n   405→\t}\n   406→\n   407→\tfor {\n   408→\t\tentry, err := stream.Recv()\n   409→\t\tif err != nil {\n   410→\t\t\tif errors.Is(err, io.EOF) {\n   411→\t\t\t\tbreak\n   412→\t\t\t}\n   413→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   414→\t\t\tos.Exit(1)\n   415→\t\t}\n   416→\n   417→\t\tswitch entry.Type {\n   418→\t\tcase \"step_started\":\n   419→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   420→\t\t\tif entry.Message != \"\" {\n   421→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   422→\t\t\t}\n   423→\t\tcase \"step_completed\":\n   424→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   425→\t\t\tif entry.Message != \"\" {\n   426→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   427→\t\t\t}\n   428→\t\tcase \"run_completed\":\n   429→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   430→\t\t\tif entry.Message != \"\" {\n   431→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   432→\t\t\t}\n   433→\t\tcase \"full_log\":\n   434→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   435→\t\tcase \"log\":\n   436→\t\t\t// Live-streamed log line from an active run.\n   437→\t\t\tfmt.Println(entry.Message)\n   438→\t\tdefault:\n   439→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   440→\t\t\tif entry.StepName != \"\" {\n   441→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   442→\t\t\t}\n   443→\t\t\tif entry.Message != \"\" {\n   444→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   445→\t\t\t}\n   446→\t\t}\n   447→\t}\n   448→}\n   449→\n   450→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   451→\tif len(args) < 1 {\n   452→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   453→\t\tos.Exit(1)\n   454→\t}\n   455→\n   456→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   457→\tif err != nil {\n   458→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   459→\t\tos.Exit(1)\n   460→\t}\n   461→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   462→}\n   463→\n   464→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   465→\tif len(args) < 1 {\n   466→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   467→\t\tos.Exit(1)\n   468→\t}\n   469→\n   470→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   471→\tif err != nil {\n   472→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   473→\t\tos.Exit(1)\n   474→\t}\n   475→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   476→}\n   477→\n   478→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   479→\tcwd, _ := os.Getwd()\n   480→\n   481→\t// Check for \"stop\" subcommand\n   482→\tif len(args) > 0 && args[0] == \"stop\" {\n   483→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   484→\t\tif err != nil {\n   485→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   486→\t\t\tos.Exit(1)\n   487→\t\t}\n   488→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   489→\t\treturn\n   490→\t}\n   491→\n   492→\t// Check for \"resume\" subcommand\n   493→\tif len(args) > 0 && args[0] == \"resume\" {\n   494→\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n   495→\t\tif err != nil {\n   496→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   497→\t\t\tos.Exit(1)\n   498→\t\t}\n   499→\t\tfmt.Println(\"Orchestration loop resumed.\")\n   500→\t\treturn\n   501→\t}\n   502→\n   503→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   504→\tvar maxConcurrent int32\n   505→\tfor i := 0; i < len(args); i++ {\n   506→\t\tswitch args[i] {\n   507→\t\tcase \"--max\":\n   508→\t\t\tif i+1 < len(args) {\n   509→\t\t\t\ti++\n   510→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   511→\t\t\t\tif n != 1 || err != nil {\n   512→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   513→\t\t\t\t\tos.Exit(1)\n   514→\t\t\t\t}\n   515→\t\t\t}\n   516→\t\t}\n   517→\t}\n   518→\n   519→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   520→\t\tProjectDir:    cwd,\n   521→\t\tMaxConcurrent: maxConcurrent,\n   522→\t})\n   523→\tif err != nil {\n   524→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   525→\t\tos.Exit(1)\n   526→\t}\n   527→\tif maxConcurrent > 0 {\n   528→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   529→\t} else {\n   530→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   531→\t}\n   532→}\n   533→\n   534→func cmdTasks(args []string) {\n   535→\t// Determine HTTP address from env\n   536→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   537→\tif httpAddr == \"\" {\n   538→\t\thttpAddr = \"localhost:8080\"\n   539→\t}\n   540→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   541→\n   542→\t// Determine project label from --project flag or current directory\n   543→\tprojectDir := \"\"\n   544→\tfor i := 0; i < len(args); i++ {\n   545→\t\tswitch args[i] {\n   546→\t\tcase \"--project\":\n   547→\t\t\tif i+1 < len(args) {\n   548→\t\t\t\ti++\n   549→\t\t\t\tprojectDir = args[i]\n   550→\t\t\t}\n   551→\t\t}\n   552→\t}\n   553→\n   554→\tif projectDir == \"\" {\n   555→\t\tcwd, _ := os.Getwd()\n   556→\t\tprojectDir = filepath.Base(cwd)\n   557→\t}\n   558→\n   559→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   560→\tresp, err := http.Get(tasksURL)\n   561→\tif err != nil {\n   562→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   563→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   564→\t\tos.Exit(1)\n   565→\t}\n   566→\tdefer resp.Body.Close()\n   567→\n   568→\tif resp.StatusCode != 200 {\n   569→\t\tbody, _ := io.ReadAll(resp.Body)\n   570→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   571→\t\tos.Exit(1)\n   572→\t}\n   573→\n   574→\ttype taskEntry struct {\n   575→\t\tID          string `json:\"id\"`\n   576→\t\tStatus      string `json:\"status\"`\n   577→\t\tTitle       string `json:\"title\"`\n   578→\t\tDescription string `json:\"description\"`\n   579→\t\tAssigned    bool   `json:\"assigned\"`\n   580→\t\tAssignedAt  string `json:\"assigned_at\"`\n   581→\t\tRunID       string `json:\"run_id\"`\n   582→\t}\n   583→\n   584→\tvar tasks []taskEntry\n   585→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   586→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   587→\t\tos.Exit(1)\n   588→\t}\n   589→\n   590→\tif len(tasks) == 0 {\n   591→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   592→\t\treturn\n   593→\t}\n   594→\n   595→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   596→\tfor _, t := range tasks {\n   597→\t\tstatus := t.Status\n   598→\t\tif status == \"\" {\n   599→\t\t\tstatus = \"open\"\n   600→\t\t}\n   601→\t\tassigned := \"-\"\n   602→\t\tif t.Assigned {\n   603→\t\t\tassigned = \"yes\"\n   604→\t\t}\n   605→\t\trunID := \"\"\n   606→\t\tif t.RunID != \"\" {\n   607→\t\t\trunID = t.RunID\n   608→\t\t\tif len(runID) > 30 {\n   609→\t\t\t\trunID = runID[:27] + \"...\"\n   610→\t\t\t}\n   611→\t\t}\n   612→\t\ttitle := t.Title\n   613→\t\tif len(title) > 40 {\n   614→\t\t\ttitle = title[:37] + \"...\"\n   615→\t\t}\n   616→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   617→\t}\n   618→}\n   619→\n   620→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   621→\tvar force bool\n   622→\tfor _, a := range args {\n   623→\t\tif a == \"-f\" || a == \"--force\" {\n   624→\t\t\tforce = true\n   625→\t\t}\n   626→\t}\n   627→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n   628→\tif err != nil {\n   629→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   630→\t\tos.Exit(1)\n   631→\t}\n   632→\tfmt.Println(\"Daemon shutting down.\")\n   633→}\n   634→\n   635→// resolveRunContext returns the project directory and run ID for context\n   636→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   637→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   638→func resolveRunContext() (projectDir, runID string, err error) {\n   639→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   640→\tif runID == \"\" {\n   641→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   642→\t}\n   643→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   644→\tif projectDir == \"\" {\n   645→\t\tprojectDir, err = os.Getwd()\n   646→\t\tif err != nil {\n   647→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   648→\t\t}\n   649→\t}\n   650→\treturn projectDir, runID, nil\n   651→}\n   652→\n   653→func cmdGet(args []string) {\n   654→\tif len(args) < 1 {\n   655→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   656→\t\tos.Exit(1)\n   657→\t}\n   658→\n   659→\tprojectDir, runID, err := resolveRunContext()\n   660→\tif err != nil {\n   661→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   662→\t\tos.Exit(1)\n   663→\t}\n   664→\n   665→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   666→\tif err != nil {\n   667→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   668→\t\tos.Exit(1)\n   669→\t}\n   670→\tif !ok {\n   671→\t\tos.Exit(1)\n   672→\t}\n   673→\tfmt.Println(val)\n   674→}\n   675→\n   676→func cmdSet(args []string) {\n   677→\tif len(args) < 2 {\n   678→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   679→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   680→\t\tos.Exit(1)\n   681→\t}\n   682→\n   683→\tprojectDir, runID, err := resolveRunContext()\n   684→\tif err != nil {\n   685→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   686→\t\tos.Exit(1)\n   687→\t}\n   688→\n   689→\tvalue := args[1]\n   690→\tif value == \"-\" {\n   691→\t\tdata, err := io.ReadAll(os.Stdin)\n   692→\t\tif err != nil {\n   693→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   694→\t\t\tos.Exit(1)\n   695→\t\t}\n   696→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   697→\t}\n   698→\n   699→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   700→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   701→\t\tos.Exit(1)\n   702→\t}\n   703→}\n   704→\n   705→func cmdVersion() {\n   706→\tcliVersion := version.Version()\n   707→\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   708→\n   709→\t// Try to get daemon version via gRPC\n   710→\tdaemonVersion := \"<unavailable>\"\n   711→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   712→\tif addr == \"\" {\n   713→\t\taddr = \"unix:///tmp/cloche.sock\"\n   714→\t}\n   715→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   716→\tif err == nil {\n   717→\t\tdefer conn.Close()\n   718→\t\tclient := pb.NewClocheServiceClient(conn)\n   719→\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   720→\t\tdefer cancel()\n   721→\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   722→\t\tif err == nil {\n   723→\t\t\tdaemonVersion = resp.Version\n   724→\t\t}\n   725→\t}\n   726→\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   727→\n   728→\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   729→\tagentVersion := \"<unavailable>\"\n   730→\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   731→\tif image == \"\" {\n   732→\t\timage = \"cloche-agent:latest\"\n   733→\t}\n   734→\tout, err := exec.CommandContext(\n   735→\t\tcontext.Background(),\n   736→\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   737→\t).Output()\n   738→\tif err == nil {\n   739→\t\tagentVersion = strings.TrimSpace(string(out))\n   740→\t\t// Strip \"cloche-agent \" prefix if present\n   741→\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n   742→\t}\n   743→\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n   744→\n   745→\t// Warn about version mismatches\n   746→\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n   747→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n   748→\t}\n   749→\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n   750→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n   751→\t}\n   752→}\n   753→"}]},"parent_tool_use_id":null,"session_id":"955b2dd5-cc52-456b-afc0-0035f6eae0d8","uuid":"486bd5ed-6541-47ec-b6f4-10db33aa2148","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n\t\"github.com/cloche-dev/cloche/internal/version\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n\n\t// Handle version flags before anything else\n\tif os.Args[1] == \"-v\" || os.Args[1] == \"--version\" {\n\t\tcmdVersion()\n\t\treturn\n\t}\n\n\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n\tswitch os.Args[1] {\n\tcase \"help\":\n\t\tprintHelp(os.Args[2:])\n\t\treturn\n\tcase \"--help\", \"-h\":\n\t\tprintTopLevelHelp()\n\t\treturn\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"init\")\n\t\t\treturn\n\t\t}\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"health\")\n\t\t\treturn\n\t\t}\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\tcase \"get\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"get\")\n\t\t\treturn\n\t\t}\n\t\tcmdGet(os.Args[2:])\n\t\treturn\n\tcase \"set\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"set\")\n\t\t\treturn\n\t\t}\n\t\tcmdSet(os.Args[2:])\n\t\treturn\n\tcase \"tasks\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"tasks\")\n\t\t\treturn\n\t\t}\n\t\tcmdTasks(os.Args[2:])\n\t\treturn\n\tcase \"workflow\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"workflow\")\n\t\t\treturn\n\t\t}\n\t\tcmdWorkflow(os.Args[2:])\n\t\treturn\n\tcase \"project\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"project\")\n\t\t\treturn\n\t\t}\n\t\tcmdProject(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Handle --help for daemon commands before connecting\n\tdaemonCmds := map[string]bool{\n\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n\t}\n\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n\t\tprintSubcommandHelp(os.Args[1])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client, os.Args[2:])\n\tdefault:\n\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n}\n\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n\t// Try loading from any .cloche file; only extract image for container workflows.\n\tvar image string\n\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n\t\timage = wf.Config[\"container.image\"]\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tvar projectDir, stateFilter, issueFilter string\n\tvar limit int32\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--all\":\n\t\t\tall = true\n\t\tcase \"--project\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\tcase \"--state\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstateFilter = args[i]\n\t\t\t}\n\t\tcase \"--limit\", \"-n\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = int32(n)\n\t\t\t}\n\t\tcase \"--issue\", \"-i\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tissueFilter = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\treq := &pb.ListRunsRequest{\n\t\tState:  stateFilter,\n\t\tLimit:  limit,\n\t\tTaskId: issueFilter,\n\t}\n\tif projectDir != \"\" {\n\t\treq.ProjectDir = projectDir\n\t} else if all {\n\t\treq.All = true\n\t} else {\n\t\t// Default: filter to current project\n\t\tcwd, _ := os.Getwd()\n\t\treq.ProjectDir = cwd\n\t}\n\n\tresp, err := client.ListRuns(ctx, req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n\t\tif run.Title != \"\" {\n\t\t\tt := run.Title\n\t\t\tif len(t) > 40 {\n\t\t\t\tt = t[:37] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + t\n\t\t}\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\tvar limit int\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\tcase \"--limit\", \"-l\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil || n < 0 {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = n\n\t\t\t}\n\t\t}\n\t}\n\n\t// Use background context — log output can be large and follow mode blocks.\n\tctx := context.Background()\n\tvar mdPairs []string\n\tif follow {\n\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n\t}\n\tif limit > 0 {\n\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n\t}\n\tif len(mdPairs) > 0 {\n\t\tmd := metadata.Pairs(mdPairs...)\n\t\tctx = metadata.NewOutgoingContext(ctx, md)\n\t}\n\n\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Check for \"resume\" subcommand\n\tif len(args) > 0 && args[0] == \"resume\" {\n\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop resumed.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdTasks(args []string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\t// Determine project label from --project flag or current directory\n\tprojectDir := \"\"\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tcwd, _ := os.Getwd()\n\t\tprojectDir = filepath.Base(cwd)\n\t}\n\n\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n\tresp, err := http.Get(tasksURL)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\ttype taskEntry struct {\n\t\tID          string `json:\"id\"`\n\t\tStatus      string `json:\"status\"`\n\t\tTitle       string `json:\"title\"`\n\t\tDescription string `json:\"description\"`\n\t\tAssigned    bool   `json:\"assigned\"`\n\t\tAssignedAt  string `json:\"assigned_at\"`\n\t\tRunID       string `json:\"run_id\"`\n\t}\n\n\tvar tasks []taskEntry\n\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(tasks) == 0 {\n\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n\t\treturn\n\t}\n\n\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n\tfor _, t := range tasks {\n\t\tstatus := t.Status\n\t\tif status == \"\" {\n\t\t\tstatus = \"open\"\n\t\t}\n\t\tassigned := \"-\"\n\t\tif t.Assigned {\n\t\t\tassigned = \"yes\"\n\t\t}\n\t\trunID := \"\"\n\t\tif t.RunID != \"\" {\n\t\t\trunID = t.RunID\n\t\t\tif len(runID) > 30 {\n\t\t\t\trunID = runID[:27] + \"...\"\n\t\t\t}\n\t\t}\n\t\ttitle := t.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar force bool\n\tfor _, a := range args {\n\t\tif a == \"-f\" || a == \"--force\" {\n\t\t\tforce = true\n\t\t}\n\t}\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n\n// resolveRunContext returns the project directory and run ID for context\n// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n// from CLOCHE_PROJECT_DIR (falling back to cwd).\nfunc resolveRunContext() (projectDir, runID string, err error) {\n\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n\tif runID == \"\" {\n\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n\t}\n\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n\tif projectDir == \"\" {\n\t\tprojectDir, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n\t\t}\n\t}\n\treturn projectDir, runID, nil\n}\n\nfunc cmdGet(args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif !ok {\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(val)\n}\n\nfunc cmdSet(args []string) {\n\tif len(args) < 2 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvalue := args[1]\n\tif value == \"-\" {\n\t\tdata, err := io.ReadAll(os.Stdin)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n\t}\n\n\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n\nfunc cmdVersion() {\n\tcliVersion := version.Version()\n\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n\n\t// Try to get daemon version via gRPC\n\tdaemonVersion := \"<unavailable>\"\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err == nil {\n\t\tdefer conn.Close()\n\t\tclient := pb.NewClocheServiceClient(conn)\n\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n\t\tdefer cancel()\n\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n\t\tif err == nil {\n\t\t\tdaemonVersion = resp.Version\n\t\t}\n\t}\n\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n\n\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n\tagentVersion := \"<unavailable>\"\n\timage := os.Getenv(\"CLOCHE_IMAGE\")\n\tif image == \"\" {\n\t\timage = \"cloche-agent:latest\"\n\t}\n\tout, err := exec.CommandContext(\n\t\tcontext.Background(),\n\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n\t).Output()\n\tif err == nil {\n\t\tagentVersion = strings.TrimSpace(string(out))\n\t\t// Strip \"cloche-agent \" prefix if present\n\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n\t}\n\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n\n\t// Warn about version mismatches\n\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n\t}\n\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n\t}\n}\n","numLines":753,"startLine":1,"totalLines":753}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01UhdnzHfsBwJX5tq823YEKG","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01E62YF5uhWA8xooGfTXuvUQ","name":"Read","input":{"file_path":"/workspace/cmd/cloche/help.go"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4133,"cache_read_input_tokens":16766,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4133},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"955b2dd5-cc52-456b-afc0-0035f6eae0d8","uuid":"1b3cf44c-9fd0-4c16-90e2-4daee5c445b8"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E62YF5uhWA8xooGfTXuvUQ","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"os\"\n     6→)\n     7→\n     8→// subcommandHelp maps each subcommand to its detailed help text.\n     9→// Help text is formatted for LLM consumption: structured, explicit, with examples.\n    10→var subcommandHelp = map[string]string{\n    11→\t\"init\": `cloche init — Initialize a Cloche project\n    12→\n    13→Creates the .cloche/ directory with a workflow definition, Dockerfile,\n    14→prompt templates, and configuration files.\n    15→\n    16→Usage:\n    17→  cloche init [--workflow <name>] [--base-image <image>]\n    18→\n    19→Flags:\n    20→  --workflow <name>       Name for the workflow file (default: \"develop\")\n    21→  --base-image <image>    Base Docker image for the Dockerfile (default: \"cloche-base:latest\")\n    22→\n    23→What it creates:\n    24→  .cloche/<name>.cloche           Workflow definition\n    25→  .cloche/host.cloche             Host orchestration workflow\n    26→  .cloche/Dockerfile              Container image definition\n    27→  .cloche/config.toml             Project configuration\n    28→  .cloche/prompts/implement.md    Prompt for the implement step\n    29→  .cloche/prompts/fix.md          Prompt for the fix step\n    30→  .cloche/prompts/update-docs.md  Prompt for the update-docs step\n    31→  .cloche/scripts/prepare-prompt.sh  Prompt generation script\n    32→  .cloche/version                 Schema version marker\n    33→\n    34→Existing files are never overwritten. Run this command again safely to add\n    35→missing files without losing customizations.\n    36→\n    37→Examples:\n    38→  cloche init\n    39→  cloche init --workflow build --base-image python:3.12\n    40→`,\n    41→\n    42→\t\"health\": `cloche health — Show project health summary\n    43→\n    44→Queries the daemon's HTTP API for a summary of all registered projects\n    45→and their pass/fail test counts.\n    46→\n    47→Usage:\n    48→  cloche health\n    49→\n    50→Environment:\n    51→  CLOCHE_HTTP    Daemon HTTP address (e.g. \"localhost:8080\"). Required.\n    52→\n    53→Examples:\n    54→  export CLOCHE_HTTP=localhost:8080\n    55→  cloche health\n    56→`,\n    57→\n    58→\t\"run\": `cloche run — Launch a workflow run\n    59→\n    60→Starts a new container workflow run. The daemon builds/pulls the container\n    61→image, copies the project into it, and executes the workflow steps.\n    62→\n    63→Usage:\n    64→  cloche run --workflow <name> [--prompt \"...\"] [--title \"...\"] [--keep-container]\n    65→  cloche run <name>              (shorthand: bare positional workflow name)\n    66→\n    67→Flags:\n    68→  --workflow <name>    Name of the workflow to run (required). Must match a\n    69→                       .cloche/<name>.cloche file in the project.\n    70→  --prompt \"...\"       Prompt text passed to agent steps. Also available as\n    71→  -p \"...\"             the short form.\n    72→  --title \"...\"        Human-readable title for the run (shown in status/list).\n    73→  --keep-container     Do not remove the container after the run completes.\n    74→                       Useful for debugging.\n    75→\n    76→The command prints the run ID on success. Use that ID with status, logs,\n    77→poll, and stop.\n    78→\n    79→Examples:\n    80→  cloche run --workflow develop --prompt \"Add a /health endpoint\"\n    81→  cloche run develop -p \"Fix the broken CSV parser\" --title \"CSV fix\"\n    82→  cloche run --workflow build --keep-container\n    83→`,\n    84→\n    85→\t\"status\": `cloche status — Check run status\n    86→\n    87→Shows the current state of a workflow run including its type, active step,\n    88→and the result of each completed step.\n    89→\n    90→Usage:\n    91→  cloche status <run-id>\n    92→\n    93→Arguments:\n    94→  <run-id>    The run identifier returned by \"cloche run\".\n    95→\n    96→Output fields:\n    97→  Run         Run identifier\n    98→  Title       Human-readable title (if set)\n    99→  Workflow    Workflow name\n   100→  Type        \"host\" or \"container\"\n   101→  State       Current state (e.g. running, succeeded, failed, cancelled)\n   102→  Container   Truncated container ID (container runs only)\n   103→  Error       Error message (if failed)\n   104→  Active      Name of the currently executing step\n   105→  Steps       List of completed steps with results and timestamps\n   106→\n   107→Examples:\n   108→  cloche status abc123\n   109→`,\n   110→\n   111→\t\"logs\": `cloche logs — Show logs for a run\n   112→\n   113→Streams or displays log output for a workflow run. Supports filtering by\n   114→step name and log type, limiting output, and following live output.\n   115→\n   116→Usage:\n   117→  cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\n   118→\n   119→Arguments:\n   120→  <run-id>    The run identifier.\n   121→\n   122→Flags:\n   123→  --step, -s <name>              Show logs only for the named step.\n   124→  --type <full|script|llm>       Filter by log type:\n   125→                                   full    — complete unfiltered output\n   126→                                   script  — script/command output only\n   127→                                   llm     — LLM interaction logs only\n   128→  --follow, -f                   Stream logs in real time (blocks until the\n   129→                                 run completes or is stopped).\n   130→  --limit, -l <n>                Display only the last n lines of output.\n   131→\n   132→Flags are combinable: cloche logs run-id -s implement -l 20 -f\n   133→\n   134→Examples:\n   135→  cloche logs abc123\n   136→  cloche logs abc123 -s implement\n   137→  cloche logs abc123 -s implement -l 20\n   138→  cloche logs abc123 -f\n   139→  cloche logs abc123 -s test --type script\n   140→  cloche logs abc123 -s implement -l 20 -f\n   141→`,\n   142→\n   143→\t\"poll\": `cloche poll — Wait for runs to finish\n   144→\n   145→Polls the daemon every 2 seconds until all runs reach a terminal state\n   146→(succeeded, failed, or cancelled).\n   147→\n   148→With a single run ID, prints step-level progress (same as before).\n   149→With multiple run IDs, displays a compact status summary.\n   150→\n   151→Usage:\n   152→  cloche poll <run-id> [run-id...]\n   153→\n   154→Arguments:\n   155→  <run-id>    One or more run identifiers.\n   156→\n   157→Exit codes:\n   158→  0    All runs succeeded.\n   159→  1    Any run failed, was cancelled, or the container died.\n   160→\n   161→Examples:\n   162→  cloche poll abc123\n   163→  cloche poll abc123 def456 ghi789\n   164→  cloche run develop -p \"Fix bug\" && cloche poll \"$(cloche run develop -p 'Fix bug')\"\n   165→`,\n   166→\n   167→\t\"list\": `cloche list — List workflow runs\n   168→\n   169→Shows all runs for the current project, or all runs across all projects\n   170→with --all. Results can be filtered by state, project, issue, or limited\n   171→to a fixed number.\n   172→\n   173→Usage:\n   174→  cloche list [flags]\n   175→\n   176→Flags:\n   177→  --all              Show runs from all projects (default: current project only).\n   178→  --project, -p DIR  Filter by project directory.\n   179→  --state, -s STATE  Filter by run state (pending, running, succeeded, failed, cancelled).\n   180→  --limit, -n NUM    Limit the number of results returned.\n   181→  --issue, -i ID     Filter by issue/task ID.\n   182→\n   183→Output columns: run ID, workflow name, state, type (host/container),\n   184→title, container ID, and error message (if any).\n   185→\n   186→Examples:\n   187→  cloche list\n   188→  cloche list --all\n   189→  cloche list --state running\n   190→  cloche list --limit 10\n   191→  cloche list --all --state failed --limit 5\n   192→  cloche list --issue TASK-123\n   193→  cloche list -p /home/user/project -s succeeded -n 20\n   194→`,\n   195→\n   196→\t\"stop\": `cloche stop — Stop a running workflow\n   197→\n   198→Sends a stop signal to a running workflow. The container is terminated\n   199→and the run state transitions to \"cancelled\".\n   200→\n   201→Usage:\n   202→  cloche stop <run-id>\n   203→\n   204→Arguments:\n   205→  <run-id>    The run identifier.\n   206→\n   207→Examples:\n   208→  cloche stop abc123\n   209→`,\n   210→\n   211→\t\"delete\": `cloche delete — Delete a retained container\n   212→\n   213→Removes a container that was kept after a run (via --keep-container).\n   214→Accepts either a container ID or a run ID.\n   215→\n   216→Usage:\n   217→  cloche delete <container-or-run-id>\n   218→\n   219→Arguments:\n   220→  <container-or-run-id>    Container ID or run ID to delete.\n   221→\n   222→Examples:\n   223→  cloche delete abc123\n   224→`,\n   225→\n   226→\t\"tasks\": `cloche tasks — Show task pipeline and assignment state\n   227→\n   228→Queries the daemon's HTTP API for the current task list, showing which\n   229→tasks are open, assigned, or completed.\n   230→\n   231→Usage:\n   232→  cloche tasks [--project <dir>]\n   233→\n   234→Flags:\n   235→  --project <dir>    Project directory name to query (default: current\n   236→                     directory basename).\n   237→\n   238→Environment:\n   239→  CLOCHE_HTTP    Daemon HTTP address (default: \"localhost:8080\").\n   240→\n   241→Output columns: ID, STATUS, ASSIGNED, RUN, TITLE\n   242→\n   243→Examples:\n   244→  cloche tasks\n   245→  cloche tasks --project my-app\n   246→`,\n   247→\n   248→\t\"loop\": `cloche loop — Manage the orchestration loop\n   249→\n   250→Starts, stops, or resumes the daemon's orchestration loop, which\n   251→automatically picks up and runs tasks from the task pipeline.\n   252→\n   253→Usage:\n   254→  cloche loop [--max <n>]     Start the orchestration loop\n   255→  cloche loop stop            Stop the orchestration loop\n   256→  cloche loop resume          Resume a halted loop (clear error state)\n   257→\n   258→Flags:\n   259→  --max <n>    Maximum number of concurrent runs (default: value from\n   260→               .cloche/config.toml).\n   261→\n   262→When stop_on_error is enabled in .cloche/config.toml, an unrecovered\n   263→error will halt the loop. Use \"cloche loop resume\" to clear the error\n   264→and resume picking up new work.\n   265→\n   266→Examples:\n   267→  cloche loop\n   268→  cloche loop --max 3\n   269→  cloche loop stop\n   270→  cloche loop resume\n   271→`,\n   272→\n   273→\t\"get\": `cloche get — Get a value from the run context store\n   274→\n   275→Reads a key from the run's context.json file. Intended for use inside\n   276→workflow scripts and steps.\n   277→\n   278→Usage:\n   279→  cloche get <key>\n   280→\n   281→Arguments:\n   282→  <key>    The context key to read.\n   283→\n   284→Environment:\n   285→  CLOCHE_RUN_ID        Run identifier (required).\n   286→  CLOCHE_PROJECT_DIR   Project directory (default: current directory).\n   287→\n   288→Exit codes:\n   289→  0    Key exists; value printed to stdout.\n   290→  1    Key not found or error.\n   291→\n   292→Examples:\n   293→  cloche get branch\n   294→  cloche get task_id\n   295→`,\n   296→\n   297→\t\"set\": `cloche set — Set a value in the run context store\n   298→\n   299→Writes a key-value pair to the run's context.json file. Use \"-\" as the\n   300→value to read from stdin (useful for multi-line content).\n   301→\n   302→Usage:\n   303→  cloche set <key> <value>\n   304→  cloche set <key> -          (read value from stdin)\n   305→\n   306→Arguments:\n   307→  <key>      The context key to write.\n   308→  <value>    The value to store, or \"-\" to read from stdin.\n   309→\n   310→Environment:\n   311→  CLOCHE_RUN_ID        Run identifier (required).\n   312→  CLOCHE_PROJECT_DIR   Project directory (default: current directory).\n   313→\n   314→Examples:\n   315→  cloche set branch feature-auth\n   316→  echo \"multi-line content\" | cloche set notes -\n   317→`,\n   318→\n   319→\t\"workflow\": `cloche workflow — View workflow definitions\n   320→\n   321→Lists all workflows in the project or renders a specific workflow as an\n   322→ASCII-art graph showing steps, wiring, and result paths.\n   323→\n   324→Usage:\n   325→  cloche workflow [--project <dir>]          List all workflows\n   326→  cloche workflow <name> [--project <dir>]   Show workflow graph\n   327→\n   328→Arguments:\n   329→  <name>    Name of the workflow to render as a graph.\n   330→\n   331→Flags:\n   332→  --project <dir>, -p <dir>    Project directory (default: current directory).\n   333→\n   334→When listing, workflows are grouped by type (container or host). When\n   335→showing a specific workflow, the output is a graph with step boxes and\n   336→colored wires: green for success, red for fail/failed, and\n   337→blue/yellow/orange/magenta for other result paths. Wires to the same\n   338→destination are merged for readability.\n   339→\n   340→Examples:\n   341→  cloche workflow\n   342→  cloche workflow develop\n   343→  cloche workflow main -p /path/to/project\n   344→  cloche workflow --project ../other-project\n   345→`,\n   346→\n   347→\t\"project\": `cloche project — Show project info and config\n   348→\n   349→Displays project-level information including config settings, orchestrator\n   350→loop state, concurrency, active runs, and known workflows.\n   351→\n   352→By default, looks up the project by the current working directory. Use\n   353→--name to look up a project by its label instead.\n   354→\n   355→Usage:\n   356→  cloche project [--name <label>]\n   357→\n   358→Flags:\n   359→  --name <label>    Look up project by label (e.g. \"cloche\") instead of\n   360→                    the current directory.\n   361→\n   362→Output includes:\n   363→  Config            active, concurrency, stagger, dedup, stop_on_error,\n   364→                    evolution settings\n   365→  Loop              Orchestration loop state (running, stopped, or halted)\n   366→  Active runs       Currently pending or running workflow runs\n   367→  Workflows         Known container and host workflow names\n   368→\n   369→Environment:\n   370→  CLOCHE_ADDR    Daemon gRPC address (default: unix:///tmp/cloche.sock)\n   371→\n   372→Examples:\n   373→  cloche project\n   374→  cloche project --name cloche\n   375→  cloche project --name my-app\n   376→`,\n   377→\n   378→\t\"shutdown\": `cloche shutdown — Shut down the daemon\n   379→\n   380→Sends a shutdown signal to the Cloche daemon. Refuses to shut down if\n   381→there are active runs unless --force is specified.\n   382→\n   383→Usage:\n   384→  cloche shutdown [--force|-f]\n   385→\n   386→Flags:\n   387→  -f, --force   Shut down even if runs are still active.\n   388→\n   389→Examples:\n   390→  cloche shutdown\n   391→  cloche shutdown --force\n   392→`,\n   393→}\n   394→\n   395→// printHelp prints the top-level help or subcommand-specific help.\n   396→// Returns true if help was printed (caller should exit).\n   397→func printHelp(args []string) bool {\n   398→\tif len(args) == 0 {\n   399→\t\tprintTopLevelHelp()\n   400→\t\treturn true\n   401→\t}\n   402→\n   403→\t// \"cloche help <subcommand>\"\n   404→\tcmd := args[0]\n   405→\tif text, ok := subcommandHelp[cmd]; ok {\n   406→\t\tfmt.Fprint(os.Stderr, text)\n   407→\t\treturn true\n   408→\t}\n   409→\n   410→\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", cmd)\n   411→\tprintTopLevelHelp()\n   412→\treturn true\n   413→}\n   414→\n   415→// hasHelpFlag returns true if the args contain --help or -h.\n   416→func hasHelpFlag(args []string) bool {\n   417→\tfor _, arg := range args {\n   418→\t\tif arg == \"--help\" || arg == \"-h\" {\n   419→\t\t\treturn true\n   420→\t\t}\n   421→\t}\n   422→\treturn false\n   423→}\n   424→\n   425→// printSubcommandHelp prints help for a subcommand and exits.\n   426→func printSubcommandHelp(cmd string) {\n   427→\tif text, ok := subcommandHelp[cmd]; ok {\n   428→\t\tfmt.Fprint(os.Stderr, text)\n   429→\t} else {\n   430→\t\tfmt.Fprintf(os.Stderr, \"no help available for %q\\n\", cmd)\n   431→\t}\n   432→}\n   433→\n   434→func printTopLevelHelp() {\n   435→\tfmt.Fprint(os.Stderr, `cloche — Grow-code high quality applications\n   436→\n   437→Cloche provides containerized environments for coding agents, a workflow DSL\n   438→for linking agentic and script-driven tasks, and validated code pipelines.\n   439→\n   440→Usage:\n   441→  cloche <command> [args]\n   442→  cloche help <command>       Show detailed help for a command\n   443→  cloche <command> --help     Same as above\n   444→\n   445→Project Setup:\n   446→  init       Initialize a Cloche project (.cloche/ directory and templates)\n   447→  health     Show project health summary (pass/fail counts)\n   448→  project    Show project info, config, loop state, and workflows\n   449→\n   450→Workflow Info:\n   451→  workflow   List workflows or show a workflow as an ASCII-art graph\n   452→\n   453→Workflow Runs:\n   454→  run        Launch a workflow run in a container\n   455→  status     Check run status (state, steps, errors)\n   456→  logs       Show or stream logs for a run\n   457→  poll       Wait for one or more runs to finish (blocks until terminal)\n   458→  list       List runs for current project (or all projects)\n   459→  stop       Stop a running workflow\n   460→  delete     Delete a retained container\n   461→\n   462→Orchestration:\n   463→  tasks      Show task pipeline and assignment state\n   464→  loop       Start or stop the orchestration loop\n   465→\n   466→Context Store (for use inside workflow steps):\n   467→  get        Get a value from the run context store\n   468→  set        Set a value in the run context store\n   469→\n   470→Daemon:\n   471→  shutdown   Shut down the Cloche daemon\n   472→\n   473→Environment Variables:\n   474→  CLOCHE_ADDR          Daemon gRPC address (default: unix:///tmp/cloche.sock)\n   475→  CLOCHE_HTTP          Daemon HTTP address (for health/tasks commands)\n   476→  CLOCHE_RUN_ID        Run ID for get/set commands (set automatically in steps)\n   477→  CLOCHE_PROJECT_DIR   Project directory override for get/set commands\n   478→\n   479→Examples:\n   480→  cloche init\n   481→  cloche run --workflow develop --prompt \"Add user authentication\"\n   482→  cloche status abc123\n   483→  cloche logs abc123 --follow\n   484→  cloche list\n   485→  cloche loop --max 2\n   486→`)\n   487→}\n   488→"}]},"parent_tool_use_id":null,"session_id":"955b2dd5-cc52-456b-afc0-0035f6eae0d8","uuid":"694b4385-4656-4604-b105-be7b03aa2df6","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/help.go","content":"package main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n)\n\n// subcommandHelp maps each subcommand to its detailed help text.\n// Help text is formatted for LLM consumption: structured, explicit, with examples.\nvar subcommandHelp = map[string]string{\n\t\"init\": `cloche init — Initialize a Cloche project\n\nCreates the .cloche/ directory with a workflow definition, Dockerfile,\nprompt templates, and configuration files.\n\nUsage:\n  cloche init [--workflow <name>] [--base-image <image>]\n\nFlags:\n  --workflow <name>       Name for the workflow file (default: \"develop\")\n  --base-image <image>    Base Docker image for the Dockerfile (default: \"cloche-base:latest\")\n\nWhat it creates:\n  .cloche/<name>.cloche           Workflow definition\n  .cloche/host.cloche             Host orchestration workflow\n  .cloche/Dockerfile              Container image definition\n  .cloche/config.toml             Project configuration\n  .cloche/prompts/implement.md    Prompt for the implement step\n  .cloche/prompts/fix.md          Prompt for the fix step\n  .cloche/prompts/update-docs.md  Prompt for the update-docs step\n  .cloche/scripts/prepare-prompt.sh  Prompt generation script\n  .cloche/version                 Schema version marker\n\nExisting files are never overwritten. Run this command again safely to add\nmissing files without losing customizations.\n\nExamples:\n  cloche init\n  cloche init --workflow build --base-image python:3.12\n`,\n\n\t\"health\": `cloche health — Show project health summary\n\nQueries the daemon's HTTP API for a summary of all registered projects\nand their pass/fail test counts.\n\nUsage:\n  cloche health\n\nEnvironment:\n  CLOCHE_HTTP    Daemon HTTP address (e.g. \"localhost:8080\"). Required.\n\nExamples:\n  export CLOCHE_HTTP=localhost:8080\n  cloche health\n`,\n\n\t\"run\": `cloche run — Launch a workflow run\n\nStarts a new container workflow run. The daemon builds/pulls the container\nimage, copies the project into it, and executes the workflow steps.\n\nUsage:\n  cloche run --workflow <name> [--prompt \"...\"] [--title \"...\"] [--keep-container]\n  cloche run <name>              (shorthand: bare positional workflow name)\n\nFlags:\n  --workflow <name>    Name of the workflow to run (required). Must match a\n                       .cloche/<name>.cloche file in the project.\n  --prompt \"...\"       Prompt text passed to agent steps. Also available as\n  -p \"...\"             the short form.\n  --title \"...\"        Human-readable title for the run (shown in status/list).\n  --keep-container     Do not remove the container after the run completes.\n                       Useful for debugging.\n\nThe command prints the run ID on success. Use that ID with status, logs,\npoll, and stop.\n\nExamples:\n  cloche run --workflow develop --prompt \"Add a /health endpoint\"\n  cloche run develop -p \"Fix the broken CSV parser\" --title \"CSV fix\"\n  cloche run --workflow build --keep-container\n`,\n\n\t\"status\": `cloche status — Check run status\n\nShows the current state of a workflow run including its type, active step,\nand the result of each completed step.\n\nUsage:\n  cloche status <run-id>\n\nArguments:\n  <run-id>    The run identifier returned by \"cloche run\".\n\nOutput fields:\n  Run         Run identifier\n  Title       Human-readable title (if set)\n  Workflow    Workflow name\n  Type        \"host\" or \"container\"\n  State       Current state (e.g. running, succeeded, failed, cancelled)\n  Container   Truncated container ID (container runs only)\n  Error       Error message (if failed)\n  Active      Name of the currently executing step\n  Steps       List of completed steps with results and timestamps\n\nExamples:\n  cloche status abc123\n`,\n\n\t\"logs\": `cloche logs — Show logs for a run\n\nStreams or displays log output for a workflow run. Supports filtering by\nstep name and log type, limiting output, and following live output.\n\nUsage:\n  cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\n\nArguments:\n  <run-id>    The run identifier.\n\nFlags:\n  --step, -s <name>              Show logs only for the named step.\n  --type <full|script|llm>       Filter by log type:\n                                   full    — complete unfiltered output\n                                   script  — script/command output only\n                                   llm     — LLM interaction logs only\n  --follow, -f                   Stream logs in real time (blocks until the\n                                 run completes or is stopped).\n  --limit, -l <n>                Display only the last n lines of output.\n\nFlags are combinable: cloche logs run-id -s implement -l 20 -f\n\nExamples:\n  cloche logs abc123\n  cloche logs abc123 -s implement\n  cloche logs abc123 -s implement -l 20\n  cloche logs abc123 -f\n  cloche logs abc123 -s test --type script\n  cloche logs abc123 -s implement -l 20 -f\n`,\n\n\t\"poll\": `cloche poll — Wait for runs to finish\n\nPolls the daemon every 2 seconds until all runs reach a terminal state\n(succeeded, failed, or cancelled).\n\nWith a single run ID, prints step-level progress (same as before).\nWith multiple run IDs, displays a compact status summary.\n\nUsage:\n  cloche poll <run-id> [run-id...]\n\nArguments:\n  <run-id>    One or more run identifiers.\n\nExit codes:\n  0    All runs succeeded.\n  1    Any run failed, was cancelled, or the container died.\n\nExamples:\n  cloche poll abc123\n  cloche poll abc123 def456 ghi789\n  cloche run develop -p \"Fix bug\" && cloche poll \"$(cloche run develop -p 'Fix bug')\"\n`,\n\n\t\"list\": `cloche list — List workflow runs\n\nShows all runs for the current project, or all runs across all projects\nwith --all. Results can be filtered by state, project, issue, or limited\nto a fixed number.\n\nUsage:\n  cloche list [flags]\n\nFlags:\n  --all              Show runs from all projects (default: current project only).\n  --project, -p DIR  Filter by project directory.\n  --state, -s STATE  Filter by run state (pending, running, succeeded, failed, cancelled).\n  --limit, -n NUM    Limit the number of results returned.\n  --issue, -i ID     Filter by issue/task ID.\n\nOutput columns: run ID, workflow name, state, type (host/container),\ntitle, container ID, and error message (if any).\n\nExamples:\n  cloche list\n  cloche list --all\n  cloche list --state running\n  cloche list --limit 10\n  cloche list --all --state failed --limit 5\n  cloche list --issue TASK-123\n  cloche list -p /home/user/project -s succeeded -n 20\n`,\n\n\t\"stop\": `cloche stop — Stop a running workflow\n\nSends a stop signal to a running workflow. The container is terminated\nand the run state transitions to \"cancelled\".\n\nUsage:\n  cloche stop <run-id>\n\nArguments:\n  <run-id>    The run identifier.\n\nExamples:\n  cloche stop abc123\n`,\n\n\t\"delete\": `cloche delete — Delete a retained container\n\nRemoves a container that was kept after a run (via --keep-container).\nAccepts either a container ID or a run ID.\n\nUsage:\n  cloche delete <container-or-run-id>\n\nArguments:\n  <container-or-run-id>    Container ID or run ID to delete.\n\nExamples:\n  cloche delete abc123\n`,\n\n\t\"tasks\": `cloche tasks — Show task pipeline and assignment state\n\nQueries the daemon's HTTP API for the current task list, showing which\ntasks are open, assigned, or completed.\n\nUsage:\n  cloche tasks [--project <dir>]\n\nFlags:\n  --project <dir>    Project directory name to query (default: current\n                     directory basename).\n\nEnvironment:\n  CLOCHE_HTTP    Daemon HTTP address (default: \"localhost:8080\").\n\nOutput columns: ID, STATUS, ASSIGNED, RUN, TITLE\n\nExamples:\n  cloche tasks\n  cloche tasks --project my-app\n`,\n\n\t\"loop\": `cloche loop — Manage the orchestration loop\n\nStarts, stops, or resumes the daemon's orchestration loop, which\nautomatically picks up and runs tasks from the task pipeline.\n\nUsage:\n  cloche loop [--max <n>]     Start the orchestration loop\n  cloche loop stop            Stop the orchestration loop\n  cloche loop resume          Resume a halted loop (clear error state)\n\nFlags:\n  --max <n>    Maximum number of concurrent runs (default: value from\n               .cloche/config.toml).\n\nWhen stop_on_error is enabled in .cloche/config.toml, an unrecovered\nerror will halt the loop. Use \"cloche loop resume\" to clear the error\nand resume picking up new work.\n\nExamples:\n  cloche loop\n  cloche loop --max 3\n  cloche loop stop\n  cloche loop resume\n`,\n\n\t\"get\": `cloche get — Get a value from the run context store\n\nReads a key from the run's context.json file. Intended for use inside\nworkflow scripts and steps.\n\nUsage:\n  cloche get <key>\n\nArguments:\n  <key>    The context key to read.\n\nEnvironment:\n  CLOCHE_RUN_ID        Run identifier (required).\n  CLOCHE_PROJECT_DIR   Project directory (default: current directory).\n\nExit codes:\n  0    Key exists; value printed to stdout.\n  1    Key not found or error.\n\nExamples:\n  cloche get branch\n  cloche get task_id\n`,\n\n\t\"set\": `cloche set — Set a value in the run context store\n\nWrites a key-value pair to the run's context.json file. Use \"-\" as the\nvalue to read from stdin (useful for multi-line content).\n\nUsage:\n  cloche set <key> <value>\n  cloche set <key> -          (read value from stdin)\n\nArguments:\n  <key>      The context key to write.\n  <value>    The value to store, or \"-\" to read from stdin.\n\nEnvironment:\n  CLOCHE_RUN_ID        Run identifier (required).\n  CLOCHE_PROJECT_DIR   Project directory (default: current directory).\n\nExamples:\n  cloche set branch feature-auth\n  echo \"multi-line content\" | cloche set notes -\n`,\n\n\t\"workflow\": `cloche workflow — View workflow definitions\n\nLists all workflows in the project or renders a specific workflow as an\nASCII-art graph showing steps, wiring, and result paths.\n\nUsage:\n  cloche workflow [--project <dir>]          List all workflows\n  cloche workflow <name> [--project <dir>]   Show workflow graph\n\nArguments:\n  <name>    Name of the workflow to render as a graph.\n\nFlags:\n  --project <dir>, -p <dir>    Project directory (default: current directory).\n\nWhen listing, workflows are grouped by type (container or host). When\nshowing a specific workflow, the output is a graph with step boxes and\ncolored wires: green for success, red for fail/failed, and\nblue/yellow/orange/magenta for other result paths. Wires to the same\ndestination are merged for readability.\n\nExamples:\n  cloche workflow\n  cloche workflow develop\n  cloche workflow main -p /path/to/project\n  cloche workflow --project ../other-project\n`,\n\n\t\"project\": `cloche project — Show project info and config\n\nDisplays project-level information including config settings, orchestrator\nloop state, concurrency, active runs, and known workflows.\n\nBy default, looks up the project by the current working directory. Use\n--name to look up a project by its label instead.\n\nUsage:\n  cloche project [--name <label>]\n\nFlags:\n  --name <label>    Look up project by label (e.g. \"cloche\") instead of\n                    the current directory.\n\nOutput includes:\n  Config            active, concurrency, stagger, dedup, stop_on_error,\n                    evolution settings\n  Loop              Orchestration loop state (running, stopped, or halted)\n  Active runs       Currently pending or running workflow runs\n  Workflows         Known container and host workflow names\n\nEnvironment:\n  CLOCHE_ADDR    Daemon gRPC address (default: unix:///tmp/cloche.sock)\n\nExamples:\n  cloche project\n  cloche project --name cloche\n  cloche project --name my-app\n`,\n\n\t\"shutdown\": `cloche shutdown — Shut down the daemon\n\nSends a shutdown signal to the Cloche daemon. Refuses to shut down if\nthere are active runs unless --force is specified.\n\nUsage:\n  cloche shutdown [--force|-f]\n\nFlags:\n  -f, --force   Shut down even if runs are still active.\n\nExamples:\n  cloche shutdown\n  cloche shutdown --force\n`,\n}\n\n// printHelp prints the top-level help or subcommand-specific help.\n// Returns true if help was printed (caller should exit).\nfunc printHelp(args []string) bool {\n\tif len(args) == 0 {\n\t\tprintTopLevelHelp()\n\t\treturn true\n\t}\n\n\t// \"cloche help <subcommand>\"\n\tcmd := args[0]\n\tif text, ok := subcommandHelp[cmd]; ok {\n\t\tfmt.Fprint(os.Stderr, text)\n\t\treturn true\n\t}\n\n\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", cmd)\n\tprintTopLevelHelp()\n\treturn true\n}\n\n// hasHelpFlag returns true if the args contain --help or -h.\nfunc hasHelpFlag(args []string) bool {\n\tfor _, arg := range args {\n\t\tif arg == \"--help\" || arg == \"-h\" {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\n// printSubcommandHelp prints help for a subcommand and exits.\nfunc printSubcommandHelp(cmd string) {\n\tif text, ok := subcommandHelp[cmd]; ok {\n\t\tfmt.Fprint(os.Stderr, text)\n\t} else {\n\t\tfmt.Fprintf(os.Stderr, \"no help available for %q\\n\", cmd)\n\t}\n}\n\nfunc printTopLevelHelp() {\n\tfmt.Fprint(os.Stderr, `cloche — Grow-code high quality applications\n\nCloche provides containerized environments for coding agents, a workflow DSL\nfor linking agentic and script-driven tasks, and validated code pipelines.\n\nUsage:\n  cloche <command> [args]\n  cloche help <command>       Show detailed help for a command\n  cloche <command> --help     Same as above\n\nProject Setup:\n  init       Initialize a Cloche project (.cloche/ directory and templates)\n  health     Show project health summary (pass/fail counts)\n  project    Show project info, config, loop state, and workflows\n\nWorkflow Info:\n  workflow   List workflows or show a workflow as an ASCII-art graph\n\nWorkflow Runs:\n  run        Launch a workflow run in a container\n  status     Check run status (state, steps, errors)\n  logs       Show or stream logs for a run\n  poll       Wait for one or more runs to finish (blocks until terminal)\n  list       List runs for current project (or all projects)\n  stop       Stop a running workflow\n  delete     Delete a retained container\n\nOrchestration:\n  tasks      Show task pipeline and assignment state\n  loop       Start or stop the orchestration loop\n\nContext Store (for use inside workflow steps):\n  get        Get a value from the run context store\n  set        Set a value in the run context store\n\nDaemon:\n  shutdown   Shut down the Cloche daemon\n\nEnvironment Variables:\n  CLOCHE_ADDR          Daemon gRPC address (default: unix:///tmp/cloche.sock)\n  CLOCHE_HTTP          Daemon HTTP address (for health/tasks commands)\n  CLOCHE_RUN_ID        Run ID for get/set commands (set automatically in steps)\n  CLOCHE_PROJECT_DIR   Project directory override for get/set commands\n\nExamples:\n  cloche init\n  cloche run --workflow develop --prompt \"Add user authentication\"\n  cloche status abc123\n  cloche logs abc123 --follow\n  cloche list\n  cloche loop --max 2\n`)\n}\n","numLines":488,"startLine":1,"totalLines":488}}}
