{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U5xaJGLoPSTBYCwL4X23zu","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"errors\"\n     7→\t\"fmt\"\n     8→\t\"io\"\n     9→\t\"net/http\"\n    10→\t\"os\"\n    11→\t\"os/exec\"\n    12→\t\"path/filepath\"\n    13→\t\"strconv\"\n    14→\t\"strings\"\n    15→\t\"time\"\n    16→\n    17→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    18→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    19→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    20→\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    21→\t\"github.com/cloche-dev/cloche/internal/version\"\n    22→\t\"google.golang.org/grpc\"\n    23→\t\"google.golang.org/grpc/credentials/insecure\"\n    24→\t\"google.golang.org/grpc/metadata\"\n    25→)\n    26→\n    27→func main() {\n    28→\tif len(os.Args) < 2 {\n    29→\t\tprintTopLevelHelp()\n    30→\t\tos.Exit(1)\n    31→\t}\n    32→\n    33→\t// Handle version flags before anything else\n    34→\tif os.Args[1] == \"-v\" || os.Args[1] == \"--version\" {\n    35→\t\tcmdVersion()\n    36→\t\treturn\n    37→\t}\n    38→\n    39→\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n    40→\tswitch os.Args[1] {\n    41→\tcase \"help\":\n    42→\t\tprintHelp(os.Args[2:])\n    43→\t\treturn\n    44→\tcase \"--help\", \"-h\":\n    45→\t\tprintTopLevelHelp()\n    46→\t\treturn\n    47→\t}\n    48→\n    49→\t// Commands that don't need a daemon connection\n    50→\tswitch os.Args[1] {\n    51→\tcase \"init\":\n    52→\t\tif hasHelpFlag(os.Args[2:]) {\n    53→\t\t\tprintSubcommandHelp(\"init\")\n    54→\t\t\treturn\n    55→\t\t}\n    56→\t\tcmdInit(os.Args[2:])\n    57→\t\treturn\n    58→\tcase \"health\":\n    59→\t\tif hasHelpFlag(os.Args[2:]) {\n    60→\t\t\tprintSubcommandHelp(\"health\")\n    61→\t\t\treturn\n    62→\t\t}\n    63→\t\tcmdHealth(os.Args[2:])\n    64→\t\treturn\n    65→\tcase \"get\":\n    66→\t\tif hasHelpFlag(os.Args[2:]) {\n    67→\t\t\tprintSubcommandHelp(\"get\")\n    68→\t\t\treturn\n    69→\t\t}\n    70→\t\tcmdGet(os.Args[2:])\n    71→\t\treturn\n    72→\tcase \"set\":\n    73→\t\tif hasHelpFlag(os.Args[2:]) {\n    74→\t\t\tprintSubcommandHelp(\"set\")\n    75→\t\t\treturn\n    76→\t\t}\n    77→\t\tcmdSet(os.Args[2:])\n    78→\t\treturn\n    79→\tcase \"tasks\":\n    80→\t\tif hasHelpFlag(os.Args[2:]) {\n    81→\t\t\tprintSubcommandHelp(\"tasks\")\n    82→\t\t\treturn\n    83→\t\t}\n    84→\t\tcmdTasks(os.Args[2:])\n    85→\t\treturn\n    86→\tcase \"workflow\":\n    87→\t\tif hasHelpFlag(os.Args[2:]) {\n    88→\t\t\tprintSubcommandHelp(\"workflow\")\n    89→\t\t\treturn\n    90→\t\t}\n    91→\t\tcmdWorkflow(os.Args[2:])\n    92→\t\treturn\n    93→\tcase \"project\":\n    94→\t\tif hasHelpFlag(os.Args[2:]) {\n    95→\t\t\tprintSubcommandHelp(\"project\")\n    96→\t\t\treturn\n    97→\t\t}\n    98→\t\tcmdProject(os.Args[2:])\n    99→\t\treturn\n   100→\t}\n   101→\n   102→\t// Handle --help for daemon commands before connecting\n   103→\tdaemonCmds := map[string]bool{\n   104→\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n   105→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n   106→\t}\n   107→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n   108→\t\tprintSubcommandHelp(os.Args[1])\n   109→\t\treturn\n   110→\t}\n   111→\n   112→\t// Commands that need a daemon connection\n   113→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   114→\tif addr == \"\" {\n   115→\t\taddr = \"unix:///tmp/cloche.sock\"\n   116→\t}\n   117→\n   118→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   119→\tif err != nil {\n   120→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   121→\t\tos.Exit(1)\n   122→\t}\n   123→\tdefer conn.Close()\n   124→\n   125→\tclient := pb.NewClocheServiceClient(conn)\n   126→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   127→\tdefer cancel()\n   128→\n   129→\tswitch os.Args[1] {\n   130→\tcase \"run\":\n   131→\t\tcmdRun(ctx, client, os.Args[2:])\n   132→\tcase \"status\":\n   133→\t\tcmdStatus(ctx, client, os.Args[2:])\n   134→\tcase \"logs\":\n   135→\t\tcmdLogs(client, os.Args[2:])\n   136→\tcase \"poll\":\n   137→\t\tcmdPoll(client, os.Args[2:])\n   138→\tcase \"list\":\n   139→\t\tcmdList(ctx, client, os.Args[2:])\n   140→\tcase \"stop\":\n   141→\t\tcmdStop(ctx, client, os.Args[2:])\n   142→\tcase \"delete\":\n   143→\t\tcmdDelete(ctx, client, os.Args[2:])\n   144→\tcase \"loop\":\n   145→\t\tcmdLoop(ctx, client, os.Args[2:])\n   146→\tcase \"shutdown\":\n   147→\t\tcmdShutdown(ctx, client, os.Args[2:])\n   148→\tdefault:\n   149→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   150→\t\tprintTopLevelHelp()\n   151→\t\tos.Exit(1)\n   152→\t}\n   153→}\n   154→\n   155→\n   156→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   157→\tvar workflow, prompt, title string\n   158→\tvar keepContainer bool\n   159→\n   160→\tfor i := 0; i < len(args); i++ {\n   161→\t\tswitch args[i] {\n   162→\t\tcase \"--workflow\":\n   163→\t\t\tif i+1 < len(args) {\n   164→\t\t\t\ti++\n   165→\t\t\t\tworkflow = args[i]\n   166→\t\t\t}\n   167→\t\tcase \"--prompt\", \"-p\":\n   168→\t\t\tif i+1 < len(args) {\n   169→\t\t\t\ti++\n   170→\t\t\t\tprompt = args[i]\n   171→\t\t\t}\n   172→\t\tcase \"--title\":\n   173→\t\t\tif i+1 < len(args) {\n   174→\t\t\t\ti++\n   175→\t\t\t\ttitle = args[i]\n   176→\t\t\t}\n   177→\t\tcase \"--keep-container\":\n   178→\t\t\tkeepContainer = true\n   179→\t\tdefault:\n   180→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   181→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   182→\t\t\t\tworkflow = args[i]\n   183→\t\t\t}\n   184→\t\t}\n   185→\t}\n   186→\n   187→\tif workflow == \"\" {\n   188→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   189→\t\tos.Exit(1)\n   190→\t}\n   191→\n   192→\tcwd, _ := os.Getwd()\n   193→\n   194→\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n   195→\t// Try loading from any .cloche file; only extract image for container workflows.\n   196→\tvar image string\n   197→\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n   198→\t\timage = wf.Config[\"container.image\"]\n   199→\t}\n   200→\n   201→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   202→\t\tWorkflowName:  workflow,\n   203→\t\tProjectDir:    cwd,\n   204→\t\tImage:         image,\n   205→\t\tPrompt:        prompt,\n   206→\t\tKeepContainer: keepContainer,\n   207→\t\tTitle:         title,\n   208→\t})\n   209→\tif err != nil {\n   210→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   211→\t\tos.Exit(1)\n   212→\t}\n   213→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   214→}\n   215→\n   216→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   217→\tif len(args) < 1 {\n   218→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   219→\t\tos.Exit(1)\n   220→\t}\n   221→\n   222→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   223→\tif err != nil {\n   224→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   225→\t\tos.Exit(1)\n   226→\t}\n   227→\n   228→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   229→\tif resp.Title != \"\" {\n   230→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   231→\t}\n   232→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   233→\tif resp.IsHost {\n   234→\t\tfmt.Printf(\"Type:      host\\n\")\n   235→\t} else {\n   236→\t\tfmt.Printf(\"Type:      container\\n\")\n   237→\t}\n   238→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   239→\tif resp.ContainerId != \"\" {\n   240→\t\tcid := resp.ContainerId\n   241→\t\tif len(cid) > 12 {\n   242→\t\t\tcid = cid[:12]\n   243→\t\t}\n   244→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   245→\t}\n   246→\tif resp.ErrorMessage != \"\" {\n   247→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   248→\t}\n   249→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   250→\tfor _, exec := range resp.StepExecutions {\n   251→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   252→\t}\n   253→}\n   254→\n   255→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   256→\tvar all bool\n   257→\tvar projectDir, stateFilter, issueFilter string\n   258→\tvar limit int32\n   259→\n   260→\tfor i := 0; i < len(args); i++ {\n   261→\t\tswitch args[i] {\n   262→\t\tcase \"--all\":\n   263→\t\t\tall = true\n   264→\t\tcase \"--project\", \"-p\":\n   265→\t\t\tif i+1 < len(args) {\n   266→\t\t\t\ti++\n   267→\t\t\t\tprojectDir = args[i]\n   268→\t\t\t}\n   269→\t\tcase \"--state\", \"-s\":\n   270→\t\t\tif i+1 < len(args) {\n   271→\t\t\t\ti++\n   272→\t\t\t\tstateFilter = args[i]\n   273→\t\t\t}\n   274→\t\tcase \"--limit\", \"-n\":\n   275→\t\t\tif i+1 < len(args) {\n   276→\t\t\t\ti++\n   277→\t\t\t\tn, err := strconv.Atoi(args[i])\n   278→\t\t\t\tif err != nil {\n   279→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   280→\t\t\t\t\tos.Exit(1)\n   281→\t\t\t\t}\n   282→\t\t\t\tlimit = int32(n)\n   283→\t\t\t}\n   284→\t\tcase \"--issue\", \"-i\":\n   285→\t\t\tif i+1 < len(args) {\n   286→\t\t\t\ti++\n   287→\t\t\t\tissueFilter = args[i]\n   288→\t\t\t}\n   289→\t\t}\n   290→\t}\n   291→\n   292→\treq := &pb.ListRunsRequest{\n   293→\t\tState:  stateFilter,\n   294→\t\tLimit:  limit,\n   295→\t\tTaskId: issueFilter,\n   296→\t}\n   297→\tif projectDir != \"\" {\n   298→\t\treq.ProjectDir = projectDir\n   299→\t} else if all {\n   300→\t\treq.All = true\n   301→\t} else {\n   302→\t\t// Default: filter to current project\n   303→\t\tcwd, _ := os.Getwd()\n   304→\t\treq.ProjectDir = cwd\n   305→\t}\n   306→\n   307→\tresp, err := client.ListRuns(ctx, req)\n   308→\tif err != nil {\n   309→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   310→\t\tos.Exit(1)\n   311→\t}\n   312→\n   313→\tif len(resp.Runs) == 0 {\n   314→\t\tfmt.Println(\"No runs found.\")\n   315→\t\treturn\n   316→\t}\n   317→\n   318→\tfor _, run := range resp.Runs {\n   319→\t\trunType := \"container\"\n   320→\t\tif run.IsHost {\n   321→\t\t\trunType = \"host\"\n   322→\t\t}\n   323→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   324→\t\tif run.Title != \"\" {\n   325→\t\t\tt := run.Title\n   326→\t\t\tif len(t) > 40 {\n   327→\t\t\t\tt = t[:37] + \"...\"\n   328→\t\t\t}\n   329→\t\t\tline += \"  \" + t\n   330→\t\t}\n   331→\t\tif run.ContainerId != \"\" {\n   332→\t\t\tline += \"  \" + run.ContainerId\n   333→\t\t}\n   334→\t\tif run.ErrorMessage != \"\" {\n   335→\t\t\terrMsg := run.ErrorMessage\n   336→\t\t\tif len(errMsg) > 60 {\n   337→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   338→\t\t\t}\n   339→\t\t\tline += \"  \" + errMsg\n   340→\t\t}\n   341→\t\tfmt.Println(line)\n   342→\t}\n   343→}\n   344→\n   345→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   346→\tif len(args) < 1 {\n   347→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n   348→\t\tos.Exit(1)\n   349→\t}\n   350→\n   351→\tvar stepFilter, typeFilter string\n   352→\tvar follow bool\n   353→\tvar limit int\n   354→\trunID := args[0]\n   355→\n   356→\tfor i := 1; i < len(args); i++ {\n   357→\t\tswitch args[i] {\n   358→\t\tcase \"--step\", \"-s\":\n   359→\t\t\tif i+1 < len(args) {\n   360→\t\t\t\ti++\n   361→\t\t\t\tstepFilter = args[i]\n   362→\t\t\t}\n   363→\t\tcase \"--type\":\n   364→\t\t\tif i+1 < len(args) {\n   365→\t\t\t\ti++\n   366→\t\t\t\ttypeFilter = args[i]\n   367→\t\t\t}\n   368→\t\tcase \"--follow\", \"-f\":\n   369→\t\t\tfollow = true\n   370→\t\tcase \"--limit\", \"-l\":\n   371→\t\t\tif i+1 < len(args) {\n   372→\t\t\t\ti++\n   373→\t\t\t\tn, err := strconv.Atoi(args[i])\n   374→\t\t\t\tif err != nil || n < 0 {\n   375→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n   376→\t\t\t\t\tos.Exit(1)\n   377→\t\t\t\t}\n   378→\t\t\t\tlimit = n\n   379→\t\t\t}\n   380→\t\t}\n   381→\t}\n   382→\n   383→\t// Use background context — log output can be large and follow mode blocks.\n   384→\tctx := context.Background()\n   385→\tvar mdPairs []string\n   386→\tif follow {\n   387→\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n   388→\t}\n   389→\tif limit > 0 {\n   390→\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n   391→\t}\n   392→\tif len(mdPairs) > 0 {\n   393→\t\tmd := metadata.Pairs(mdPairs...)\n   394→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   395→\t}\n   396→\n   397→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   398→\t\tRunId:    runID,\n   399→\t\tStepName: stepFilter,\n   400→\t\tLogType:  typeFilter,\n   401→\t})\n   402→\tif err != nil {\n   403→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   404→\t\tos.Exit(1)\n   405→\t}\n   406→\n   407→\tfor {\n   408→\t\tentry, err := stream.Recv()\n   409→\t\tif err != nil {\n   410→\t\t\tif errors.Is(err, io.EOF) {\n   411→\t\t\t\tbreak\n   412→\t\t\t}\n   413→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   414→\t\t\tos.Exit(1)\n   415→\t\t}\n   416→\n   417→\t\tswitch entry.Type {\n   418→\t\tcase \"step_started\":\n   419→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   420→\t\t\tif entry.Message != \"\" {\n   421→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   422→\t\t\t}\n   423→\t\tcase \"step_completed\":\n   424→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   425→\t\t\tif entry.Message != \"\" {\n   426→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   427→\t\t\t}\n   428→\t\tcase \"run_completed\":\n   429→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   430→\t\t\tif entry.Message != \"\" {\n   431→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   432→\t\t\t}\n   433→\t\tcase \"full_log\":\n   434→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   435→\t\tcase \"log\":\n   436→\t\t\t// Live-streamed log line from an active run.\n   437→\t\t\tfmt.Println(entry.Message)\n   438→\t\tdefault:\n   439→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   440→\t\t\tif entry.StepName != \"\" {\n   441→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   442→\t\t\t}\n   443→\t\t\tif entry.Message != \"\" {\n   444→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   445→\t\t\t}\n   446→\t\t}\n   447→\t}\n   448→}\n   449→\n   450→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   451→\tif len(args) < 1 {\n   452→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   453→\t\tos.Exit(1)\n   454→\t}\n   455→\n   456→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   457→\tif err != nil {\n   458→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   459→\t\tos.Exit(1)\n   460→\t}\n   461→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   462→}\n   463→\n   464→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   465→\tif len(args) < 1 {\n   466→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   467→\t\tos.Exit(1)\n   468→\t}\n   469→\n   470→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   471→\tif err != nil {\n   472→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   473→\t\tos.Exit(1)\n   474→\t}\n   475→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   476→}\n   477→\n   478→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   479→\tcwd, _ := os.Getwd()\n   480→\n   481→\t// Check for \"stop\" subcommand\n   482→\tif len(args) > 0 && args[0] == \"stop\" {\n   483→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   484→\t\tif err != nil {\n   485→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   486→\t\t\tos.Exit(1)\n   487→\t\t}\n   488→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   489→\t\treturn\n   490→\t}\n   491→\n   492→\t// Check for \"resume\" subcommand\n   493→\tif len(args) > 0 && args[0] == \"resume\" {\n   494→\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n   495→\t\tif err != nil {\n   496→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   497→\t\t\tos.Exit(1)\n   498→\t\t}\n   499→\t\tfmt.Println(\"Orchestration loop resumed.\")\n   500→\t\treturn\n   501→\t}\n   502→\n   503→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   504→\tvar maxConcurrent int32\n   505→\tfor i := 0; i < len(args); i++ {\n   506→\t\tswitch args[i] {\n   507→\t\tcase \"--max\":\n   508→\t\t\tif i+1 < len(args) {\n   509→\t\t\t\ti++\n   510→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   511→\t\t\t\tif n != 1 || err != nil {\n   512→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   513→\t\t\t\t\tos.Exit(1)\n   514→\t\t\t\t}\n   515→\t\t\t}\n   516→\t\t}\n   517→\t}\n   518→\n   519→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   520→\t\tProjectDir:    cwd,\n   521→\t\tMaxConcurrent: maxConcurrent,\n   522→\t})\n   523→\tif err != nil {\n   524→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   525→\t\tos.Exit(1)\n   526→\t}\n   527→\tif maxConcurrent > 0 {\n   528→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   529→\t} else {\n   530→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   531→\t}\n   532→}\n   533→\n   534→func cmdTasks(args []string) {\n   535→\t// Determine HTTP address from env\n   536→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   537→\tif httpAddr == \"\" {\n   538→\t\thttpAddr = \"localhost:8080\"\n   539→\t}\n   540→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   541→\n   542→\t// Determine project label from --project flag or current directory\n   543→\tprojectDir := \"\"\n   544→\tfor i := 0; i < len(args); i++ {\n   545→\t\tswitch args[i] {\n   546→\t\tcase \"--project\":\n   547→\t\t\tif i+1 < len(args) {\n   548→\t\t\t\ti++\n   549→\t\t\t\tprojectDir = args[i]\n   550→\t\t\t}\n   551→\t\t}\n   552→\t}\n   553→\n   554→\tif projectDir == \"\" {\n   555→\t\tcwd, _ := os.Getwd()\n   556→\t\tprojectDir = filepath.Base(cwd)\n   557→\t}\n   558→\n   559→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   560→\tresp, err := http.Get(tasksURL)\n   561→\tif err != nil {\n   562→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   563→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   564→\t\tos.Exit(1)\n   565→\t}\n   566→\tdefer resp.Body.Close()\n   567→\n   568→\tif resp.StatusCode != 200 {\n   569→\t\tbody, _ := io.ReadAll(resp.Body)\n   570→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   571→\t\tos.Exit(1)\n   572→\t}\n   573→\n   574→\ttype taskEntry struct {\n   575→\t\tID          string `json:\"id\"`\n   576→\t\tStatus      string `json:\"status\"`\n   577→\t\tTitle       string `json:\"title\"`\n   578→\t\tDescription string `json:\"description\"`\n   579→\t\tAssigned    bool   `json:\"assigned\"`\n   580→\t\tAssignedAt  string `json:\"assigned_at\"`\n   581→\t\tRunID       string `json:\"run_id\"`\n   582→\t}\n   583→\n   584→\tvar tasks []taskEntry\n   585→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   586→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   587→\t\tos.Exit(1)\n   588→\t}\n   589→\n   590→\tif len(tasks) == 0 {\n   591→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   592→\t\treturn\n   593→\t}\n   594→\n   595→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   596→\tfor _, t := range tasks {\n   597→\t\tstatus := t.Status\n   598→\t\tif status == \"\" {\n   599→\t\t\tstatus = \"open\"\n   600→\t\t}\n   601→\t\tassigned := \"-\"\n   602→\t\tif t.Assigned {\n   603→\t\t\tassigned = \"yes\"\n   604→\t\t}\n   605→\t\trunID := \"\"\n   606→\t\tif t.RunID != \"\" {\n   607→\t\t\trunID = t.RunID\n   608→\t\t\tif len(runID) > 30 {\n   609→\t\t\t\trunID = runID[:27] + \"...\"\n   610→\t\t\t}\n   611→\t\t}\n   612→\t\ttitle := t.Title\n   613→\t\tif len(title) > 40 {\n   614→\t\t\ttitle = title[:37] + \"...\"\n   615→\t\t}\n   616→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   617→\t}\n   618→}\n   619→\n   620→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   621→\tvar force bool\n   622→\tfor _, a := range args {\n   623→\t\tif a == \"-f\" || a == \"--force\" {\n   624→\t\t\tforce = true\n   625→\t\t}\n   626→\t}\n   627→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n   628→\tif err != nil {\n   629→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   630→\t\tos.Exit(1)\n   631→\t}\n   632→\tfmt.Println(\"Daemon shutting down.\")\n   633→}\n   634→\n   635→// resolveRunContext returns the project directory and run ID for context\n   636→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   637→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   638→func resolveRunContext() (projectDir, runID string, err error) {\n   639→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   640→\tif runID == \"\" {\n   641→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   642→\t}\n   643→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   644→\tif projectDir == \"\" {\n   645→\t\tprojectDir, err = os.Getwd()\n   646→\t\tif err != nil {\n   647→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   648→\t\t}\n   649→\t}\n   650→\treturn projectDir, runID, nil\n   651→}\n   652→\n   653→func cmdGet(args []string) {\n   654→\tif len(args) < 1 {\n   655→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   656→\t\tos.Exit(1)\n   657→\t}\n   658→\n   659→\tprojectDir, runID, err := resolveRunContext()\n   660→\tif err != nil {\n   661→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   662→\t\tos.Exit(1)\n   663→\t}\n   664→\n   665→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   666→\tif err != nil {\n   667→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   668→\t\tos.Exit(1)\n   669→\t}\n   670→\tif !ok {\n   671→\t\tos.Exit(1)\n   672→\t}\n   673→\tfmt.Println(val)\n   674→}\n   675→\n   676→func cmdSet(args []string) {\n   677→\tif len(args) < 2 {\n   678→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   679→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   680→\t\tos.Exit(1)\n   681→\t}\n   682→\n   683→\tprojectDir, runID, err := resolveRunContext()\n   684→\tif err != nil {\n   685→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   686→\t\tos.Exit(1)\n   687→\t}\n   688→\n   689→\tvalue := args[1]\n   690→\tif value == \"-\" {\n   691→\t\tdata, err := io.ReadAll(os.Stdin)\n   692→\t\tif err != nil {\n   693→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   694→\t\t\tos.Exit(1)\n   695→\t\t}\n   696→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   697→\t}\n   698→\n   699→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   700→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   701→\t\tos.Exit(1)\n   702→\t}\n   703→}\n   704→\n   705→func cmdVersion() {\n   706→\tcliVersion := version.Version()\n   707→\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   708→\n   709→\t// Try to get daemon version via gRPC\n   710→\tdaemonVersion := \"<unavailable>\"\n   711→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   712→\tif addr == \"\" {\n   713→\t\taddr = \"unix:///tmp/cloche.sock\"\n   714→\t}\n   715→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   716→\tif err == nil {\n   717→\t\tdefer conn.Close()\n   718→\t\tclient := pb.NewClocheServiceClient(conn)\n   719→\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   720→\t\tdefer cancel()\n   721→\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   722→\t\tif err == nil {\n   723→\t\t\tdaemonVersion = resp.Version\n   724→\t\t}\n   725→\t}\n   726→\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   727→\n   728→\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   729→\tagentVersion := \"<unavailable>\"\n   730→\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   731→\tif image == \"\" {\n   732→\t\timage = \"cloche-agent:latest\"\n   733→\t}\n   734→\tout, err := exec.CommandContext(\n   735→\t\tcontext.Background(),\n   736→\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   737→\t).Output()\n   738→\tif err == nil {\n   739→\t\tagentVersion = strings.TrimSpace(string(out))\n   740→\t\t// Strip \"cloche-agent \" prefix if present\n   741→\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n   742→\t}\n   743→\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n   744→\n   745→\t// Warn about version mismatches\n   746→\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n   747→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n   748→\t}\n   749→\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n   750→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n   751→\t}\n   752→}\n   753→"}]},"parent_tool_use_id":"toolu_01YBDNVBTQUf847DxND28odt","session_id":"955b2dd5-cc52-456b-afc0-0035f6eae0d8","uuid":"decde0ef-371b-4a11-8df0-a52786ce7484"}
