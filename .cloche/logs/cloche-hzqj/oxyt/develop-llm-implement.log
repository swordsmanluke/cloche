{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015Evn7MUuwBssQ9r9ZMRr9T","type":"tool_result","content":"     1→package config\n     2→\n     3→import (\n     4→\t\"os\"\n     5→\t\"path/filepath\"\n     6→\n     7→\t\"github.com/BurntSushi/toml\"\n     8→)\n     9→\n    10→type DaemonConfig struct {\n    11→\tListen     string `toml:\"listen\"`\n    12→\tHTTP       string `toml:\"http\"`\n    13→\tImage      string `toml:\"image\"`\n    14→\tDB         string `toml:\"db\"`\n    15→\tRuntime    string `toml:\"runtime\"`\n    16→\tAgentPath  string `toml:\"agent_path\"`\n    17→\tLLMCommand string `toml:\"llm_command\"`\n    18→}\n    19→\n    20→type EvolutionConfig struct {\n    21→\tEnabled          bool   `toml:\"enabled\"`\n    22→\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n    23→\tMinConfidence    string `toml:\"min_confidence\"`\n    24→\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n    25→}\n    26→\n    27→type OrchestrationConfig struct {\n    28→\tConcurrency      int     `toml:\"concurrency\"`\n    29→\tStaggerSeconds   float64 `toml:\"stagger_seconds\"`\n    30→\tListTasksCommand string  `toml:\"list_tasks_command\"` // shell command to list open tasks (JSON array output)\n    31→\tDedupSeconds     float64 `toml:\"dedup_seconds\"`      // dedup window for task assignment (default: 300)\n    32→\tStopOnError      bool    `toml:\"stop_on_error\"`      // halt orchestration loop on unrecovered error\n    33→}\n    34→\n    35→type Config struct {\n    36→\tActive        bool                `toml:\"active\"`\n    37→\tDaemon        DaemonConfig        `toml:\"daemon\"`\n    38→\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n    39→\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n    40→}\n    41→\n    42→func defaults() Config {\n    43→\treturn Config{\n    44→\t\tEvolution: EvolutionConfig{\n    45→\t\t\tEnabled:          true,\n    46→\t\t\tDebounceSeconds:  30,\n    47→\t\t\tMinConfidence:    \"medium\",\n    48→\t\t\tMaxPromptBullets: 50,\n    49→\t\t},\n    50→\t\tOrchestration: OrchestrationConfig{\n    51→\t\t\tConcurrency:    1,\n    52→\t\t\tStaggerSeconds: 1.0,\n    53→\t\t},\n    54→\t}\n    55→}\n    56→\n    57→// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    58→func Load(projectDir string) (*Config, error) {\n    59→\tcfg := defaults()\n    60→\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    61→\n    62→\tdata, err := os.ReadFile(path)\n    63→\tif os.IsNotExist(err) {\n    64→\t\treturn &cfg, nil\n    65→\t}\n    66→\tif err != nil {\n    67→\t\treturn nil, err\n    68→\t}\n    69→\n    70→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    71→\t\treturn nil, err\n    72→\t}\n    73→\treturn &cfg, nil\n    74→}\n    75→\n    76→// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n    77→// Returns defaults if the file does not exist.\n    78→func LoadGlobal() (*Config, error) {\n    79→\tcfg := defaults()\n    80→\n    81→\thome, err := os.UserHomeDir()\n    82→\tif err != nil {\n    83→\t\treturn &cfg, nil\n    84→\t}\n    85→\n    86→\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n    87→\tdata, err := os.ReadFile(path)\n    88→\tif os.IsNotExist(err) {\n    89→\t\treturn &cfg, nil\n    90→\t}\n    91→\tif err != nil {\n    92→\t\treturn nil, err\n    93→\t}\n    94→\n    95→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    96→\t\treturn nil, err\n    97→\t}\n    98→\treturn &cfg, nil\n    99→}\n   100→\n   101→// LoadGlobalFrom reads the global config from a specific path.\n   102→// Useful for testing.\n   103→func LoadGlobalFrom(path string) (*Config, error) {\n   104→\tcfg := defaults()\n   105→\n   106→\tdata, err := os.ReadFile(path)\n   107→\tif os.IsNotExist(err) {\n   108→\t\treturn &cfg, nil\n   109→\t}\n   110→\tif err != nil {\n   111→\t\treturn nil, err\n   112→\t}\n   113→\n   114→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   115→\t\treturn nil, err\n   116→\t}\n   117→\treturn &cfg, nil\n   118→}\n   119→"}]},"parent_tool_use_id":null,"session_id":"955b2dd5-cc52-456b-afc0-0035f6eae0d8","uuid":"ac5ad16e-66a8-4f6c-9934-45b68519d080","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/config/config.go","content":"package config\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\n\t\"github.com/BurntSushi/toml\"\n)\n\ntype DaemonConfig struct {\n\tListen     string `toml:\"listen\"`\n\tHTTP       string `toml:\"http\"`\n\tImage      string `toml:\"image\"`\n\tDB         string `toml:\"db\"`\n\tRuntime    string `toml:\"runtime\"`\n\tAgentPath  string `toml:\"agent_path\"`\n\tLLMCommand string `toml:\"llm_command\"`\n}\n\ntype EvolutionConfig struct {\n\tEnabled          bool   `toml:\"enabled\"`\n\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n\tMinConfidence    string `toml:\"min_confidence\"`\n\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n}\n\ntype OrchestrationConfig struct {\n\tConcurrency      int     `toml:\"concurrency\"`\n\tStaggerSeconds   float64 `toml:\"stagger_seconds\"`\n\tListTasksCommand string  `toml:\"list_tasks_command\"` // shell command to list open tasks (JSON array output)\n\tDedupSeconds     float64 `toml:\"dedup_seconds\"`      // dedup window for task assignment (default: 300)\n\tStopOnError      bool    `toml:\"stop_on_error\"`      // halt orchestration loop on unrecovered error\n}\n\ntype Config struct {\n\tActive        bool                `toml:\"active\"`\n\tDaemon        DaemonConfig        `toml:\"daemon\"`\n\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n}\n\nfunc defaults() Config {\n\treturn Config{\n\t\tEvolution: EvolutionConfig{\n\t\t\tEnabled:          true,\n\t\t\tDebounceSeconds:  30,\n\t\t\tMinConfidence:    \"medium\",\n\t\t\tMaxPromptBullets: 50,\n\t\t},\n\t\tOrchestration: OrchestrationConfig{\n\t\t\tConcurrency:    1,\n\t\t\tStaggerSeconds: 1.0,\n\t\t},\n\t}\n}\n\n// Load reads a per-project config from <projectDir>/.cloche/config.toml.\nfunc Load(projectDir string) (*Config, error) {\n\tcfg := defaults()\n\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n// Returns defaults if the file does not exist.\nfunc LoadGlobal() (*Config, error) {\n\tcfg := defaults()\n\n\thome, err := os.UserHomeDir()\n\tif err != nil {\n\t\treturn &cfg, nil\n\t}\n\n\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadGlobalFrom reads the global config from a specific path.\n// Useful for testing.\nfunc LoadGlobalFrom(path string) (*Config, error) {\n\tcfg := defaults()\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n","numLines":119,"startLine":1,"totalLines":119}}}
