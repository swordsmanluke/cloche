{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012VhRvJe1yZmhRZw8Z5FSip","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"os\"\n     5→\t\"path/filepath\"\n     6→\t\"strings\"\n     7→\t\"testing\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→)\n    11→\n    12→func TestBfsOrder_LinearWorkflow(t *testing.T) {\n    13→\twf := &domain.Workflow{\n    14→\t\tEntryStep: \"a\",\n    15→\t\tSteps: map[string]*domain.Step{\n    16→\t\t\t\"a\": {Name: \"a\", Results: []string{\"ok\"}},\n    17→\t\t\t\"b\": {Name: \"b\", Results: []string{\"ok\"}},\n    18→\t\t\t\"c\": {Name: \"c\", Results: []string{\"ok\"}},\n    19→\t\t},\n    20→\t\tWiring: []domain.Wire{\n    21→\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n    22→\t\t\t{From: \"b\", Result: \"ok\", To: \"c\"},\n    23→\t\t\t{From: \"c\", Result: \"ok\", To: \"done\"},\n    24→\t\t},\n    25→\t}\n    26→\n    27→\torder := bfsOrder(wf)\n    28→\tif len(order) != 3 {\n    29→\t\tt.Fatalf(\"expected 3 steps, got %d: %v\", len(order), order)\n    30→\t}\n    31→\tif order[0] != \"a\" || order[1] != \"b\" || order[2] != \"c\" {\n    32→\t\tt.Errorf(\"expected [a b c], got %v\", order)\n    33→\t}\n    34→}\n    35→\n    36→func TestBfsOrder_WithCycle(t *testing.T) {\n    37→\twf := &domain.Workflow{\n    38→\t\tEntryStep: \"a\",\n    39→\t\tSteps: map[string]*domain.Step{\n    40→\t\t\t\"a\": {Name: \"a\", Results: []string{\"ok\", \"fail\"}},\n    41→\t\t\t\"b\": {Name: \"b\", Results: []string{\"ok\", \"retry\"}},\n    42→\t\t},\n    43→\t\tWiring: []domain.Wire{\n    44→\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n    45→\t\t\t{From: \"a\", Result: \"fail\", To: \"abort\"},\n    46→\t\t\t{From: \"b\", Result: \"ok\", To: \"done\"},\n    47→\t\t\t{From: \"b\", Result: \"retry\", To: \"a\"}, // cycle\n    48→\t\t},\n    49→\t}\n    50→\n    51→\torder := bfsOrder(wf)\n    52→\tif len(order) != 2 {\n    53→\t\tt.Fatalf(\"expected 2 steps (cycle skipped), got %d: %v\", len(order), order)\n    54→\t}\n    55→\tif order[0] != \"a\" || order[1] != \"b\" {\n    56→\t\tt.Errorf(\"expected [a b], got %v\", order)\n    57→\t}\n    58→}\n    59→\n    60→func TestBfsOrder_EmptyWorkflow(t *testing.T) {\n    61→\twf := &domain.Workflow{Steps: map[string]*domain.Step{}}\n    62→\torder := bfsOrder(wf)\n    63→\tif len(order) != 0 {\n    64→\t\tt.Errorf(\"expected empty order, got %v\", order)\n    65→\t}\n    66→}\n    67→\n    68→func TestGroupWiresByDest_Merging(t *testing.T) {\n    69→\twf := &domain.Workflow{\n    70→\t\tWiring: []domain.Wire{\n    71→\t\t\t{From: \"fix\", Result: \"success\", To: \"test\"},\n    72→\t\t\t{From: \"fix\", Result: \"fail\", To: \"abort\"},\n    73→\t\t\t{From: \"fix\", Result: \"give-up\", To: \"abort\"},\n    74→\t\t},\n    75→\t}\n    76→\n    77→\tgroups := groupWiresByDest(wf, \"fix\")\n    78→\tif len(groups) != 2 {\n    79→\t\tt.Fatalf(\"expected 2 groups (test + abort merged), got %d\", len(groups))\n    80→\t}\n    81→\n    82→\t// First group: success -> test\n    83→\tif groups[0].to != \"test\" || len(groups[0].results) != 1 || groups[0].results[0] != \"success\" {\n    84→\t\tt.Errorf(\"expected first group to be success->test, got %+v\", groups[0])\n    85→\t}\n    86→\n    87→\t// Second group: fail,give-up -> abort (merged)\n    88→\tif groups[1].to != \"abort\" || len(groups[1].results) != 2 {\n    89→\t\tt.Errorf(\"expected second group to be fail,give-up->abort, got %+v\", groups[1])\n    90→\t}\n    91→\tif groups[1].results[0] != \"fail\" || groups[1].results[1] != \"give-up\" {\n    92→\t\tt.Errorf(\"expected results [fail give-up], got %v\", groups[1].results)\n    93→\t}\n    94→}\n    95→\n    96→func TestGroupWiresByDest_NoWires(t *testing.T) {\n    97→\twf := &domain.Workflow{\n    98→\t\tWiring: []domain.Wire{\n    99→\t\t\t{From: \"other\", Result: \"ok\", To: \"done\"},\n   100→\t\t},\n   101→\t}\n   102→\n   103→\tgroups := groupWiresByDest(wf, \"step\")\n   104→\tif len(groups) != 0 {\n   105→\t\tt.Errorf(\"expected no groups, got %d\", len(groups))\n   106→\t}\n   107→}\n   108→\n   109→func TestBuildResultColorMap(t *testing.T) {\n   110→\twf := &domain.Workflow{\n   111→\t\tSteps: map[string]*domain.Step{\n   112→\t\t\t\"a\": {Name: \"a\", Results: []string{\"success\", \"fail\", \"retry\", \"skip\"}},\n   113→\t\t},\n   114→\t}\n   115→\n   116→\tcolorMap := buildResultColorMap(wf, []string{\"a\"})\n   117→\n   118→\tif colorMap[\"success\"] != colorGreen {\n   119→\t\tt.Error(\"success should be green\")\n   120→\t}\n   121→\tif colorMap[\"fail\"] != colorRed {\n   122→\t\tt.Error(\"fail should be red\")\n   123→\t}\n   124→\tif colorMap[\"retry\"] == \"\" {\n   125→\t\tt.Error(\"retry should have an assigned color\")\n   126→\t}\n   127→\tif colorMap[\"skip\"] == \"\" {\n   128→\t\tt.Error(\"skip should have an assigned color\")\n   129→\t}\n   130→\tif colorMap[\"retry\"] == colorMap[\"skip\"] {\n   131→\t\tt.Error(\"retry and skip should get different colors\")\n   132→\t}\n   133→}\n   134→\n   135→func TestRenderWorkflowGraph_NoColor(t *testing.T) {\n   136→\twf := &domain.Workflow{\n   137→\t\tName:      \"test-wf\",\n   138→\t\tLocation:  domain.LocationContainer,\n   139→\t\tEntryStep: \"build\",\n   140→\t\tSteps: map[string]*domain.Step{\n   141→\t\t\t\"build\": {Name: \"build\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n   142→\t\t\t\"deploy\": {Name: \"deploy\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   143→\t\t},\n   144→\t\tWiring: []domain.Wire{\n   145→\t\t\t{From: \"build\", Result: \"success\", To: \"deploy\"},\n   146→\t\t\t{From: \"build\", Result: \"fail\", To: \"abort\"},\n   147→\t\t\t{From: \"deploy\", Result: \"success\", To: \"done\"},\n   148→\t\t},\n   149→\t}\n   150→\n   151→\toutput := renderWorkflowGraph(wf, false)\n   152→\n   153→\t// Check header\n   154→\tif !strings.Contains(output, `workflow \"test-wf\" (container)`) {\n   155→\t\tt.Error(\"missing workflow header\")\n   156→\t}\n   157→\n   158→\t// Check step boxes\n   159→\tif !strings.Contains(output, \"build\") {\n   160→\t\tt.Error(\"missing build step\")\n   161→\t}\n   162→\tif !strings.Contains(output, \"deploy\") {\n   163→\t\tt.Error(\"missing deploy step\")\n   164→\t}\n   165→\n   166→\t// Check box drawing characters\n   167→\tif !strings.Contains(output, \"┌\") || !strings.Contains(output, \"┘\") {\n   168→\t\tt.Error(\"missing box drawing characters\")\n   169→\t}\n   170→\n   171→\t// Check entry marker\n   172→\tif !strings.Contains(output, \"◀ entry\") {\n   173→\t\tt.Error(\"missing entry marker\")\n   174→\t}\n   175→\n   176→\t// Check step types\n   177→\tif !strings.Contains(output, \"script\") {\n   178→\t\tt.Error(\"missing step type 'script'\")\n   179→\t}\n   180→\tif !strings.Contains(output, \"agent\") {\n   181→\t\tt.Error(\"missing step type 'agent'\")\n   182→\t}\n   183→\n   184→\t// Check wires\n   185→\tif !strings.Contains(output, \"success ──▶ deploy\") {\n   186→\t\tt.Error(\"missing success wire to deploy\")\n   187→\t}\n   188→\tif !strings.Contains(output, \"fail ──▶ ABORT\") {\n   189→\t\tt.Error(\"missing fail wire to ABORT\")\n   190→\t}\n   191→\tif !strings.Contains(output, \"success ──▶ DONE\") {\n   192→\t\tt.Error(\"missing success wire to DONE\")\n   193→\t}\n   194→\n   195→\t// Check tree branch characters\n   196→\tif !strings.Contains(output, \"├──\") {\n   197→\t\tt.Error(\"missing non-last branch character\")\n   198→\t}\n   199→\tif !strings.Contains(output, \"└──\") {\n   200→\t\tt.Error(\"missing last branch character\")\n   201→\t}\n   202→}\n   203→\n   204→func TestRenderWorkflowGraph_WireMerging(t *testing.T) {\n   205→\twf := &domain.Workflow{\n   206→\t\tName:      \"merge-test\",\n   207→\t\tLocation:  domain.LocationContainer,\n   208→\t\tEntryStep: \"step1\",\n   209→\t\tSteps: map[string]*domain.Step{\n   210→\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\", \"error\"}},\n   211→\t\t},\n   212→\t\tWiring: []domain.Wire{\n   213→\t\t\t{From: \"step1\", Result: \"success\", To: \"done\"},\n   214→\t\t\t{From: \"step1\", Result: \"fail\", To: \"abort\"},\n   215→\t\t\t{From: \"step1\", Result: \"error\", To: \"abort\"},\n   216→\t\t},\n   217→\t}\n   218→\n   219→\toutput := renderWorkflowGraph(wf, false)\n   220→\n   221→\t// fail and error should be merged into one wire to ABORT\n   222→\tif !strings.Contains(output, \"fail, error ──▶ ABORT\") {\n   223→\t\tt.Errorf(\"expected merged wire 'fail, error ──▶ ABORT', got:\\n%s\", output)\n   224→\t}\n   225→\n   226→\t// Should have exactly 2 wire lines (done + merged abort)\n   227→\tlines := strings.Split(output, \"\\n\")\n   228→\twireLines := 0\n   229→\tfor _, line := range lines {\n   230→\t\tif strings.Contains(line, \"──▶\") {\n   231→\t\t\twireLines++\n   232→\t\t}\n   233→\t}\n   234→\tif wireLines != 2 {\n   235→\t\tt.Errorf(\"expected 2 wire lines (1 done + 1 merged abort), got %d\", wireLines)\n   236→\t}\n   237→}\n   238→\n   239→func TestRenderWorkflowGraph_WithColor(t *testing.T) {\n   240→\twf := &domain.Workflow{\n   241→\t\tName:      \"color-test\",\n   242→\t\tLocation:  domain.LocationHost,\n   243→\t\tEntryStep: \"step1\",\n   244→\t\tSteps: map[string]*domain.Step{\n   245→\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n   246→\t\t},\n   247→\t\tWiring: []domain.Wire{\n   248→\t\t\t{From: \"step1\", Result: \"success\", To: \"done\"},\n   249→\t\t\t{From: \"step1\", Result: \"fail\", To: \"abort\"},\n   250→\t\t},\n   251→\t}\n   252→\n   253→\toutput := renderWorkflowGraph(wf, true)\n   254→\n   255→\t// Check ANSI color codes are present\n   256→\tif !strings.Contains(output, colorGreen) {\n   257→\t\tt.Error(\"expected green color code for success\")\n   258→\t}\n   259→\tif !strings.Contains(output, colorRed) {\n   260→\t\tt.Error(\"expected red color code for fail\")\n   261→\t}\n   262→\tif !strings.Contains(output, colorReset) {\n   263→\t\tt.Error(\"expected color reset code\")\n   264→\t}\n   265→}\n   266→\n   267→func TestRenderWorkflowGraph_HostLocation(t *testing.T) {\n   268→\twf := &domain.Workflow{\n   269→\t\tName:      \"host-wf\",\n   270→\t\tLocation:  domain.LocationHost,\n   271→\t\tEntryStep: \"run\",\n   272→\t\tSteps: map[string]*domain.Step{\n   273→\t\t\t\"run\": {Name: \"run\", Type: domain.StepTypeWorkflow, Results: []string{\"success\"}},\n   274→\t\t},\n   275→\t\tWiring: []domain.Wire{\n   276→\t\t\t{From: \"run\", Result: \"success\", To: \"done\"},\n   277→\t\t},\n   278→\t}\n   279→\n   280→\toutput := renderWorkflowGraph(wf, false)\n   281→\tif !strings.Contains(output, \"(host)\") {\n   282→\t\tt.Error(\"expected host location in header\")\n   283→\t}\n   284→\tif !strings.Contains(output, \"workflow\") {\n   285→\t\tt.Error(\"expected workflow step type\")\n   286→\t}\n   287→}\n   288→\n   289→func TestRenderWorkflowGraph_OtherResultColors(t *testing.T) {\n   290→\twf := &domain.Workflow{\n   291→\t\tName:      \"multi-color\",\n   292→\t\tLocation:  domain.LocationContainer,\n   293→\t\tEntryStep: \"step1\",\n   294→\t\tSteps: map[string]*domain.Step{\n   295→\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeAgent, Results: []string{\"retry\", \"skip\", \"timeout\", \"partial\"}},\n   296→\t\t},\n   297→\t\tWiring: []domain.Wire{\n   298→\t\t\t{From: \"step1\", Result: \"retry\", To: \"done\"},\n   299→\t\t\t{From: \"step1\", Result: \"skip\", To: \"done\"},\n   300→\t\t\t{From: \"step1\", Result: \"timeout\", To: \"abort\"},\n   301→\t\t\t{From: \"step1\", Result: \"partial\", To: \"abort\"},\n   302→\t\t},\n   303→\t}\n   304→\n   305→\toutput := renderWorkflowGraph(wf, true)\n   306→\n   307→\t// Each \"other\" result should get a distinct color from the palette\n   308→\tif !strings.Contains(output, colorBlue) {\n   309→\t\tt.Error(\"expected blue color for first other result\")\n   310→\t}\n   311→\tif !strings.Contains(output, colorYellow) {\n   312→\t\tt.Error(\"expected yellow color for second other result\")\n   313→\t}\n   314→\tif !strings.Contains(output, colorOrange) {\n   315→\t\tt.Error(\"expected orange color for third other result\")\n   316→\t}\n   317→\tif !strings.Contains(output, colorMagenta) {\n   318→\t\tt.Error(\"expected magenta color for fourth other result\")\n   319→\t}\n   320→}\n   321→\n   322→func TestRenderWorkflowGraph_ConsistentBoxWidth(t *testing.T) {\n   323→\twf := &domain.Workflow{\n   324→\t\tName:      \"width-test\",\n   325→\t\tLocation:  domain.LocationContainer,\n   326→\t\tEntryStep: \"a\",\n   327→\t\tSteps: map[string]*domain.Step{\n   328→\t\t\t\"a\":             {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n   329→\t\t\t\"long-step-name\": {Name: \"long-step-name\", Type: domain.StepTypeAgent, Results: []string{\"ok\"}},\n   330→\t\t},\n   331→\t\tWiring: []domain.Wire{\n   332→\t\t\t{From: \"a\", Result: \"ok\", To: \"long-step-name\"},\n   333→\t\t\t{From: \"long-step-name\", Result: \"ok\", To: \"done\"},\n   334→\t\t},\n   335→\t}\n   336→\n   337→\toutput := renderWorkflowGraph(wf, false)\n   338→\tlines := strings.Split(output, \"\\n\")\n   339→\n   340→\t// Find border lines (those with ┌ or └)\n   341→\tvar borderLengths []int\n   342→\tfor _, line := range lines {\n   343→\t\tif strings.Contains(line, \"┌\") && strings.Contains(line, \"┐\") {\n   344→\t\t\tborderLengths = append(borderLengths, len(line))\n   345→\t\t}\n   346→\t}\n   347→\n   348→\tif len(borderLengths) < 2 {\n   349→\t\tt.Fatal(\"expected at least 2 border lines\")\n   350→\t}\n   351→\n   352→\t// All borders should have the same length\n   353→\tfor i := 1; i < len(borderLengths); i++ {\n   354→\t\tif borderLengths[i] != borderLengths[0] {\n   355→\t\t\tt.Errorf(\"inconsistent box widths: %d vs %d\", borderLengths[0], borderLengths[i])\n   356→\t\t}\n   357→\t}\n   358→}\n   359→\n   360→func TestDiscoverWorkflows(t *testing.T) {\n   361→\tdir := t.TempDir()\n   362→\tclocheDir := filepath.Join(dir, \".cloche\")\n   363→\tos.MkdirAll(clocheDir, 0755)\n   364→\n   365→\t// Write a container workflow\n   366→\tos.WriteFile(filepath.Join(clocheDir, \"build.cloche\"), []byte(`workflow \"build\" {\n   367→  step compile {\n   368→    run = \"make\"\n   369→    results = [success, fail]\n   370→  }\n   371→  compile:success -> done\n   372→  compile:fail -> abort\n   373→}`), 0644)\n   374→\n   375→\t// Write a host workflow with two workflows\n   376→\tos.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(`workflow \"plan\" {\n   377→  host {}\n   378→  step pick {\n   379→    run = \"echo pick\"\n   380→    results = [success]\n   381→  }\n   382→  pick:success -> done\n   383→}\n   384→\n   385→workflow \"run\" {\n   386→  host {}\n   387→  step exec {\n   388→    run = \"echo run\"\n   389→    results = [success]\n   390→  }\n   391→  exec:success -> done\n   392→}`), 0644)\n   393→\n   394→\tinfos, err := discoverWorkflows(dir)\n   395→\tif err != nil {\n   396→\t\tt.Fatal(err)\n   397→\t}\n   398→\n   399→\t// Should find 3 workflows: 1 container + 2 host\n   400→\tif len(infos) != 3 {\n   401→\t\tt.Fatalf(\"expected 3 workflows, got %d\", len(infos))\n   402→\t}\n   403→\n   404→\tvar containerCount, hostCount int\n   405→\tnames := map[string]bool{}\n   406→\tfor _, info := range infos {\n   407→\t\tnames[info.name] = true\n   408→\t\tswitch info.location {\n   409→\t\tcase domain.LocationContainer:\n   410→\t\t\tcontainerCount++\n   411→\t\tcase domain.LocationHost:\n   412→\t\t\thostCount++\n   413→\t\t}\n   414→\t}\n   415→\n   416→\tif containerCount != 1 {\n   417→\t\tt.Errorf(\"expected 1 container workflow, got %d\", containerCount)\n   418→\t}\n   419→\tif hostCount != 2 {\n   420→\t\tt.Errorf(\"expected 2 host workflows, got %d\", hostCount)\n   421→\t}\n   422→\tfor _, name := range []string{\"build\", \"plan\", \"run\"} {\n   423→\t\tif !names[name] {\n   424→\t\t\tt.Errorf(\"missing workflow %q\", name)\n   425→\t\t}\n   426→\t}\n   427→}\n   428→\n   429→func TestDiscoverWorkflows_NoClocheDir(t *testing.T) {\n   430→\tdir := t.TempDir()\n   431→\n   432→\tinfos, err := discoverWorkflows(dir)\n   433→\tif err != nil {\n   434→\t\tt.Fatal(err)\n   435→\t}\n   436→\tif len(infos) != 0 {\n   437→\t\tt.Errorf(\"expected 0 workflows, got %d\", len(infos))\n   438→\t}\n   439→}\n   440→\n   441→func TestLoadWorkflow_Container(t *testing.T) {\n   442→\tdir := t.TempDir()\n   443→\tclocheDir := filepath.Join(dir, \".cloche\")\n   444→\tos.MkdirAll(clocheDir, 0755)\n   445→\n   446→\tos.WriteFile(filepath.Join(clocheDir, \"deploy.cloche\"), []byte(`workflow \"deploy\" {\n   447→  step ship {\n   448→    run = \"echo ship\"\n   449→    results = [success, fail]\n   450→  }\n   451→  ship:success -> done\n   452→  ship:fail -> abort\n   453→}`), 0644)\n   454→\n   455→\twf, err := loadWorkflow(dir, \"deploy\")\n   456→\tif err != nil {\n   457→\t\tt.Fatal(err)\n   458→\t}\n   459→\tif wf.Name != \"deploy\" {\n   460→\t\tt.Errorf(\"expected name 'deploy', got %q\", wf.Name)\n   461→\t}\n   462→\tif wf.Location != domain.LocationContainer {\n   463→\t\tt.Errorf(\"expected container location, got %q\", wf.Location)\n   464→\t}\n   465→}\n   466→\n   467→func TestLoadWorkflow_Host(t *testing.T) {\n   468→\tdir := t.TempDir()\n   469→\tclocheDir := filepath.Join(dir, \".cloche\")\n   470→\tos.MkdirAll(clocheDir, 0755)\n   471→\n   472→\tos.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(`workflow \"orchestrate\" {\n   473→  host {}\n   474→  step dispatch {\n   475→    run = \"echo go\"\n   476→    results = [success]\n   477→  }\n   478→  dispatch:success -> done\n   479→}`), 0644)\n   480→\n   481→\twf, err := loadWorkflow(dir, \"orchestrate\")\n   482→\tif err != nil {\n   483→\t\tt.Fatal(err)\n   484→\t}\n   485→\tif wf.Name != \"orchestrate\" {\n   486→\t\tt.Errorf(\"expected name 'orchestrate', got %q\", wf.Name)\n   487→\t}\n   488→\tif wf.Location != domain.LocationHost {\n   489→\t\tt.Errorf(\"expected host location, got %q\", wf.Location)\n   490→\t}\n   491→}\n   492→\n   493→func TestLoadWorkflow_NotFound(t *testing.T) {\n   494→\tdir := t.TempDir()\n   495→\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n   496→\n   497→\t_, err := loadWorkflow(dir, \"nonexistent\")\n   498→\tif err == nil {\n   499→\t\tt.Error(\"expected error for nonexistent workflow\")\n   500→\t}\n   501→\tif !strings.Contains(err.Error(), \"not found\") {\n   502→\t\tt.Errorf(\"expected 'not found' error, got: %v\", err)\n   503→\t}\n   504→}\n   505→\n   506→func TestRenderWorkflowGraph_DevelopWorkflow(t *testing.T) {\n   507→\t// Simulate the develop workflow from the project\n   508→\twf := &domain.Workflow{\n   509→\t\tName:      \"develop\",\n   510→\t\tLocation:  domain.LocationContainer,\n   511→\t\tEntryStep: \"implement\",\n   512→\t\tSteps: map[string]*domain.Step{\n   513→\t\t\t\"implement\":   {Name: \"implement\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n   514→\t\t\t\"test\":        {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n   515→\t\t\t\"fix\":         {Name: \"fix\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\", \"give-up\"}},\n   516→\t\t\t\"update-docs\": {Name: \"update-docs\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n   517→\t\t},\n   518→\t\tWiring: []domain.Wire{\n   519→\t\t\t{From: \"implement\", Result: \"success\", To: \"test\"},\n   520→\t\t\t{From: \"implement\", Result: \"fail\", To: \"abort\"},\n   521→\t\t\t{From: \"test\", Result: \"success\", To: \"update-docs\"},\n   522→\t\t\t{From: \"test\", Result: \"fail\", To: \"fix\"},\n   523→\t\t\t{From: \"fix\", Result: \"success\", To: \"test\"},\n   524→\t\t\t{From: \"fix\", Result: \"fail\", To: \"abort\"},\n   525→\t\t\t{From: \"fix\", Result: \"give-up\", To: \"abort\"},\n   526→\t\t\t{From: \"update-docs\", Result: \"success\", To: \"done\"},\n   527→\t\t\t{From: \"update-docs\", Result: \"fail\", To: \"done\"},\n   528→\t\t},\n   529→\t}\n   530→\n   531→\toutput := renderWorkflowGraph(wf, false)\n   532→\n   533→\t// Check BFS order: implement -> test -> update-docs -> fix\n   534→\t// (update-docs before fix because test:success wire comes before test:fail wire)\n   535→\tlines := strings.Split(output, \"\\n\")\n   536→\tstepBoxOrder := []string{}\n   537→\tfor _, line := range lines {\n   538→\t\tif strings.Contains(line, \"│\") && strings.Contains(line, \"◀ entry\") {\n   539→\t\t\tstepBoxOrder = append(stepBoxOrder, \"implement\")\n   540→\t\t} else if strings.Contains(line, \"│\") && strings.Contains(line, \"script\") && strings.Contains(line, \"test\") {\n   541→\t\t\tstepBoxOrder = append(stepBoxOrder, \"test\")\n   542→\t\t} else if strings.Contains(line, \"│\") && strings.Contains(line, \"update-docs\") {\n   543→\t\t\tstepBoxOrder = append(stepBoxOrder, \"update-docs\")\n   544→\t\t} else if strings.Contains(line, \"│\") && strings.Contains(line, \"fix\") && strings.Contains(line, \"agent\") && !strings.Contains(line, \"update\") && !strings.Contains(line, \"implement\") {\n   545→\t\t\tstepBoxOrder = append(stepBoxOrder, \"fix\")\n   546→\t\t}\n   547→\t}\n   548→\n   549→\texpected := []string{\"implement\", \"test\", \"update-docs\", \"fix\"}\n   550→\tif len(stepBoxOrder) != len(expected) {\n   551→\t\tt.Fatalf(\"expected %d step boxes, got %d: %v\", len(expected), len(stepBoxOrder), stepBoxOrder)\n   552→\t}\n   553→\tfor i, name := range expected {\n   554→\t\tif stepBoxOrder[i] != name {\n   555→\t\t\tt.Errorf(\"step %d: expected %q, got %q (order: %v)\", i, name, stepBoxOrder[i], stepBoxOrder)\n   556→\t\t}\n   557→\t}\n   558→\n   559→\t// Check wire merging: fix's fail and give-up should merge to ABORT\n   560→\tif !strings.Contains(output, \"fail, give-up ──▶ ABORT\") {\n   561→\t\tt.Errorf(\"expected merged wire 'fail, give-up ──▶ ABORT' in output:\\n%s\", output)\n   562→\t}\n   563→\n   564→\t// Check wire merging: update-docs success and fail should merge to DONE\n   565→\tif !strings.Contains(output, \"success, fail ──▶ DONE\") {\n   566→\t\tt.Errorf(\"expected merged wire 'success, fail ──▶ DONE' in output:\\n%s\", output)\n   567→\t}\n   568→\n   569→\t// Check cycle reference: fix:success -> test (back reference)\n   570→\tif !strings.Contains(output, \"success ──▶ test\") {\n   571→\t\tt.Error(\"expected fix:success wire to test\")\n   572→\t}\n   573→}\n   574→\n   575→func TestFormatDest(t *testing.T) {\n   576→\ttests := []struct {\n   577→\t\tto       string\n   578→\t\tcolor    bool\n   579→\t\texpected string\n   580→\t}{\n   581→\t\t{\"done\", false, \"DONE\"},\n   582→\t\t{\"abort\", false, \"ABORT\"},\n   583→\t\t{\"step_a\", false, \"step_a\"},\n   584→\t\t{\"done\", true, colorGreen + \"DONE\" + colorReset},\n   585→\t\t{\"abort\", true, colorRed + \"ABORT\" + colorReset},\n   586→\t\t{\"step_a\", true, \"step_a\"},\n   587→\t}\n   588→\n   589→\tfor _, tt := range tests {\n   590→\t\tgot := formatDest(tt.to, tt.color)\n   591→\t\tif got != tt.expected {\n   592→\t\t\tt.Errorf(\"formatDest(%q, %v) = %q, want %q\", tt.to, tt.color, got, tt.expected)\n   593→\t\t}\n   594→\t}\n   595→}\n   596→\n   597→func TestRenderWorkflowGraph_CollectBlock(t *testing.T) {\n   598→\twf := &domain.Workflow{\n   599→\t\tName:      \"collect-test\",\n   600→\t\tLocation:  domain.LocationContainer,\n   601→\t\tEntryStep: \"step1\",\n   602→\t\tSteps: map[string]*domain.Step{\n   603→\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   604→\t\t\t\"step2\": {Name: \"step2\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   605→\t\t\t\"step3\": {Name: \"step3\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   606→\t\t},\n   607→\t\tWiring: []domain.Wire{\n   608→\t\t\t{From: \"step1\", Result: \"success\", To: \"step2\"},\n   609→\t\t\t{From: \"step1\", Result: \"success\", To: \"step3\"},\n   610→\t\t\t{From: \"step3\", Result: \"success\", To: \"done\"},\n   611→\t\t},\n   612→\t\tCollects: []domain.Collect{\n   613→\t\t\t{\n   614→\t\t\t\tMode: domain.CollectAll,\n   615→\t\t\t\tConditions: []domain.WireCondition{\n   616→\t\t\t\t\t{Step: \"step2\", Result: \"success\"},\n   617→\t\t\t\t\t{Step: \"step3\", Result: \"success\"},\n   618→\t\t\t\t},\n   619→\t\t\t\tTo: \"done\",\n   620→\t\t\t},\n   621→\t\t},\n   622→\t}\n   623→\n   624→\toutput := renderWorkflowGraph(wf, false)\n   625→\tif !strings.Contains(output, \"collect all\") {\n   626→\t\tt.Errorf(\"expected collect block in output:\\n%s\", output)\n   627→\t}\n   628→}\n   629→"}]},"parent_tool_use_id":null,"session_id":"955b2dd5-cc52-456b-afc0-0035f6eae0d8","uuid":"9e0f2b3e-891b-4c55-b091-42eb21aeaccb","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/workflow_test.go","content":"package main\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n)\n\nfunc TestBfsOrder_LinearWorkflow(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tEntryStep: \"a\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"a\": {Name: \"a\", Results: []string{\"ok\"}},\n\t\t\t\"b\": {Name: \"b\", Results: []string{\"ok\"}},\n\t\t\t\"c\": {Name: \"c\", Results: []string{\"ok\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n\t\t\t{From: \"b\", Result: \"ok\", To: \"c\"},\n\t\t\t{From: \"c\", Result: \"ok\", To: \"done\"},\n\t\t},\n\t}\n\n\torder := bfsOrder(wf)\n\tif len(order) != 3 {\n\t\tt.Fatalf(\"expected 3 steps, got %d: %v\", len(order), order)\n\t}\n\tif order[0] != \"a\" || order[1] != \"b\" || order[2] != \"c\" {\n\t\tt.Errorf(\"expected [a b c], got %v\", order)\n\t}\n}\n\nfunc TestBfsOrder_WithCycle(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tEntryStep: \"a\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"a\": {Name: \"a\", Results: []string{\"ok\", \"fail\"}},\n\t\t\t\"b\": {Name: \"b\", Results: []string{\"ok\", \"retry\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n\t\t\t{From: \"a\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"b\", Result: \"ok\", To: \"done\"},\n\t\t\t{From: \"b\", Result: \"retry\", To: \"a\"}, // cycle\n\t\t},\n\t}\n\n\torder := bfsOrder(wf)\n\tif len(order) != 2 {\n\t\tt.Fatalf(\"expected 2 steps (cycle skipped), got %d: %v\", len(order), order)\n\t}\n\tif order[0] != \"a\" || order[1] != \"b\" {\n\t\tt.Errorf(\"expected [a b], got %v\", order)\n\t}\n}\n\nfunc TestBfsOrder_EmptyWorkflow(t *testing.T) {\n\twf := &domain.Workflow{Steps: map[string]*domain.Step{}}\n\torder := bfsOrder(wf)\n\tif len(order) != 0 {\n\t\tt.Errorf(\"expected empty order, got %v\", order)\n\t}\n}\n\nfunc TestGroupWiresByDest_Merging(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"fix\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"fix\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"fix\", Result: \"give-up\", To: \"abort\"},\n\t\t},\n\t}\n\n\tgroups := groupWiresByDest(wf, \"fix\")\n\tif len(groups) != 2 {\n\t\tt.Fatalf(\"expected 2 groups (test + abort merged), got %d\", len(groups))\n\t}\n\n\t// First group: success -> test\n\tif groups[0].to != \"test\" || len(groups[0].results) != 1 || groups[0].results[0] != \"success\" {\n\t\tt.Errorf(\"expected first group to be success->test, got %+v\", groups[0])\n\t}\n\n\t// Second group: fail,give-up -> abort (merged)\n\tif groups[1].to != \"abort\" || len(groups[1].results) != 2 {\n\t\tt.Errorf(\"expected second group to be fail,give-up->abort, got %+v\", groups[1])\n\t}\n\tif groups[1].results[0] != \"fail\" || groups[1].results[1] != \"give-up\" {\n\t\tt.Errorf(\"expected results [fail give-up], got %v\", groups[1].results)\n\t}\n}\n\nfunc TestGroupWiresByDest_NoWires(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"other\", Result: \"ok\", To: \"done\"},\n\t\t},\n\t}\n\n\tgroups := groupWiresByDest(wf, \"step\")\n\tif len(groups) != 0 {\n\t\tt.Errorf(\"expected no groups, got %d\", len(groups))\n\t}\n}\n\nfunc TestBuildResultColorMap(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"a\": {Name: \"a\", Results: []string{\"success\", \"fail\", \"retry\", \"skip\"}},\n\t\t},\n\t}\n\n\tcolorMap := buildResultColorMap(wf, []string{\"a\"})\n\n\tif colorMap[\"success\"] != colorGreen {\n\t\tt.Error(\"success should be green\")\n\t}\n\tif colorMap[\"fail\"] != colorRed {\n\t\tt.Error(\"fail should be red\")\n\t}\n\tif colorMap[\"retry\"] == \"\" {\n\t\tt.Error(\"retry should have an assigned color\")\n\t}\n\tif colorMap[\"skip\"] == \"\" {\n\t\tt.Error(\"skip should have an assigned color\")\n\t}\n\tif colorMap[\"retry\"] == colorMap[\"skip\"] {\n\t\tt.Error(\"retry and skip should get different colors\")\n\t}\n}\n\nfunc TestRenderWorkflowGraph_NoColor(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"test-wf\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"build\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"build\": {Name: \"build\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n\t\t\t\"deploy\": {Name: \"deploy\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"build\", Result: \"success\", To: \"deploy\"},\n\t\t\t{From: \"build\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"deploy\", Result: \"success\", To: \"done\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\n\t// Check header\n\tif !strings.Contains(output, `workflow \"test-wf\" (container)`) {\n\t\tt.Error(\"missing workflow header\")\n\t}\n\n\t// Check step boxes\n\tif !strings.Contains(output, \"build\") {\n\t\tt.Error(\"missing build step\")\n\t}\n\tif !strings.Contains(output, \"deploy\") {\n\t\tt.Error(\"missing deploy step\")\n\t}\n\n\t// Check box drawing characters\n\tif !strings.Contains(output, \"┌\") || !strings.Contains(output, \"┘\") {\n\t\tt.Error(\"missing box drawing characters\")\n\t}\n\n\t// Check entry marker\n\tif !strings.Contains(output, \"◀ entry\") {\n\t\tt.Error(\"missing entry marker\")\n\t}\n\n\t// Check step types\n\tif !strings.Contains(output, \"script\") {\n\t\tt.Error(\"missing step type 'script'\")\n\t}\n\tif !strings.Contains(output, \"agent\") {\n\t\tt.Error(\"missing step type 'agent'\")\n\t}\n\n\t// Check wires\n\tif !strings.Contains(output, \"success ──▶ deploy\") {\n\t\tt.Error(\"missing success wire to deploy\")\n\t}\n\tif !strings.Contains(output, \"fail ──▶ ABORT\") {\n\t\tt.Error(\"missing fail wire to ABORT\")\n\t}\n\tif !strings.Contains(output, \"success ──▶ DONE\") {\n\t\tt.Error(\"missing success wire to DONE\")\n\t}\n\n\t// Check tree branch characters\n\tif !strings.Contains(output, \"├──\") {\n\t\tt.Error(\"missing non-last branch character\")\n\t}\n\tif !strings.Contains(output, \"└──\") {\n\t\tt.Error(\"missing last branch character\")\n\t}\n}\n\nfunc TestRenderWorkflowGraph_WireMerging(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"merge-test\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"step1\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\", \"error\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"step1\", Result: \"success\", To: \"done\"},\n\t\t\t{From: \"step1\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"step1\", Result: \"error\", To: \"abort\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\n\t// fail and error should be merged into one wire to ABORT\n\tif !strings.Contains(output, \"fail, error ──▶ ABORT\") {\n\t\tt.Errorf(\"expected merged wire 'fail, error ──▶ ABORT', got:\\n%s\", output)\n\t}\n\n\t// Should have exactly 2 wire lines (done + merged abort)\n\tlines := strings.Split(output, \"\\n\")\n\twireLines := 0\n\tfor _, line := range lines {\n\t\tif strings.Contains(line, \"──▶\") {\n\t\t\twireLines++\n\t\t}\n\t}\n\tif wireLines != 2 {\n\t\tt.Errorf(\"expected 2 wire lines (1 done + 1 merged abort), got %d\", wireLines)\n\t}\n}\n\nfunc TestRenderWorkflowGraph_WithColor(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"color-test\",\n\t\tLocation:  domain.LocationHost,\n\t\tEntryStep: \"step1\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"step1\", Result: \"success\", To: \"done\"},\n\t\t\t{From: \"step1\", Result: \"fail\", To: \"abort\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, true)\n\n\t// Check ANSI color codes are present\n\tif !strings.Contains(output, colorGreen) {\n\t\tt.Error(\"expected green color code for success\")\n\t}\n\tif !strings.Contains(output, colorRed) {\n\t\tt.Error(\"expected red color code for fail\")\n\t}\n\tif !strings.Contains(output, colorReset) {\n\t\tt.Error(\"expected color reset code\")\n\t}\n}\n\nfunc TestRenderWorkflowGraph_HostLocation(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"host-wf\",\n\t\tLocation:  domain.LocationHost,\n\t\tEntryStep: \"run\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"run\": {Name: \"run\", Type: domain.StepTypeWorkflow, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"run\", Result: \"success\", To: \"done\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\tif !strings.Contains(output, \"(host)\") {\n\t\tt.Error(\"expected host location in header\")\n\t}\n\tif !strings.Contains(output, \"workflow\") {\n\t\tt.Error(\"expected workflow step type\")\n\t}\n}\n\nfunc TestRenderWorkflowGraph_OtherResultColors(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"multi-color\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"step1\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeAgent, Results: []string{\"retry\", \"skip\", \"timeout\", \"partial\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"step1\", Result: \"retry\", To: \"done\"},\n\t\t\t{From: \"step1\", Result: \"skip\", To: \"done\"},\n\t\t\t{From: \"step1\", Result: \"timeout\", To: \"abort\"},\n\t\t\t{From: \"step1\", Result: \"partial\", To: \"abort\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, true)\n\n\t// Each \"other\" result should get a distinct color from the palette\n\tif !strings.Contains(output, colorBlue) {\n\t\tt.Error(\"expected blue color for first other result\")\n\t}\n\tif !strings.Contains(output, colorYellow) {\n\t\tt.Error(\"expected yellow color for second other result\")\n\t}\n\tif !strings.Contains(output, colorOrange) {\n\t\tt.Error(\"expected orange color for third other result\")\n\t}\n\tif !strings.Contains(output, colorMagenta) {\n\t\tt.Error(\"expected magenta color for fourth other result\")\n\t}\n}\n\nfunc TestRenderWorkflowGraph_ConsistentBoxWidth(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"width-test\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"a\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"a\":             {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n\t\t\t\"long-step-name\": {Name: \"long-step-name\", Type: domain.StepTypeAgent, Results: []string{\"ok\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"a\", Result: \"ok\", To: \"long-step-name\"},\n\t\t\t{From: \"long-step-name\", Result: \"ok\", To: \"done\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\tlines := strings.Split(output, \"\\n\")\n\n\t// Find border lines (those with ┌ or └)\n\tvar borderLengths []int\n\tfor _, line := range lines {\n\t\tif strings.Contains(line, \"┌\") && strings.Contains(line, \"┐\") {\n\t\t\tborderLengths = append(borderLengths, len(line))\n\t\t}\n\t}\n\n\tif len(borderLengths) < 2 {\n\t\tt.Fatal(\"expected at least 2 border lines\")\n\t}\n\n\t// All borders should have the same length\n\tfor i := 1; i < len(borderLengths); i++ {\n\t\tif borderLengths[i] != borderLengths[0] {\n\t\t\tt.Errorf(\"inconsistent box widths: %d vs %d\", borderLengths[0], borderLengths[i])\n\t\t}\n\t}\n}\n\nfunc TestDiscoverWorkflows(t *testing.T) {\n\tdir := t.TempDir()\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tos.MkdirAll(clocheDir, 0755)\n\n\t// Write a container workflow\n\tos.WriteFile(filepath.Join(clocheDir, \"build.cloche\"), []byte(`workflow \"build\" {\n  step compile {\n    run = \"make\"\n    results = [success, fail]\n  }\n  compile:success -> done\n  compile:fail -> abort\n}`), 0644)\n\n\t// Write a host workflow with two workflows\n\tos.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(`workflow \"plan\" {\n  host {}\n  step pick {\n    run = \"echo pick\"\n    results = [success]\n  }\n  pick:success -> done\n}\n\nworkflow \"run\" {\n  host {}\n  step exec {\n    run = \"echo run\"\n    results = [success]\n  }\n  exec:success -> done\n}`), 0644)\n\n\tinfos, err := discoverWorkflows(dir)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\n\t// Should find 3 workflows: 1 container + 2 host\n\tif len(infos) != 3 {\n\t\tt.Fatalf(\"expected 3 workflows, got %d\", len(infos))\n\t}\n\n\tvar containerCount, hostCount int\n\tnames := map[string]bool{}\n\tfor _, info := range infos {\n\t\tnames[info.name] = true\n\t\tswitch info.location {\n\t\tcase domain.LocationContainer:\n\t\t\tcontainerCount++\n\t\tcase domain.LocationHost:\n\t\t\thostCount++\n\t\t}\n\t}\n\n\tif containerCount != 1 {\n\t\tt.Errorf(\"expected 1 container workflow, got %d\", containerCount)\n\t}\n\tif hostCount != 2 {\n\t\tt.Errorf(\"expected 2 host workflows, got %d\", hostCount)\n\t}\n\tfor _, name := range []string{\"build\", \"plan\", \"run\"} {\n\t\tif !names[name] {\n\t\t\tt.Errorf(\"missing workflow %q\", name)\n\t\t}\n\t}\n}\n\nfunc TestDiscoverWorkflows_NoClocheDir(t *testing.T) {\n\tdir := t.TempDir()\n\n\tinfos, err := discoverWorkflows(dir)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif len(infos) != 0 {\n\t\tt.Errorf(\"expected 0 workflows, got %d\", len(infos))\n\t}\n}\n\nfunc TestLoadWorkflow_Container(t *testing.T) {\n\tdir := t.TempDir()\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tos.MkdirAll(clocheDir, 0755)\n\n\tos.WriteFile(filepath.Join(clocheDir, \"deploy.cloche\"), []byte(`workflow \"deploy\" {\n  step ship {\n    run = \"echo ship\"\n    results = [success, fail]\n  }\n  ship:success -> done\n  ship:fail -> abort\n}`), 0644)\n\n\twf, err := loadWorkflow(dir, \"deploy\")\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif wf.Name != \"deploy\" {\n\t\tt.Errorf(\"expected name 'deploy', got %q\", wf.Name)\n\t}\n\tif wf.Location != domain.LocationContainer {\n\t\tt.Errorf(\"expected container location, got %q\", wf.Location)\n\t}\n}\n\nfunc TestLoadWorkflow_Host(t *testing.T) {\n\tdir := t.TempDir()\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tos.MkdirAll(clocheDir, 0755)\n\n\tos.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(`workflow \"orchestrate\" {\n  host {}\n  step dispatch {\n    run = \"echo go\"\n    results = [success]\n  }\n  dispatch:success -> done\n}`), 0644)\n\n\twf, err := loadWorkflow(dir, \"orchestrate\")\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif wf.Name != \"orchestrate\" {\n\t\tt.Errorf(\"expected name 'orchestrate', got %q\", wf.Name)\n\t}\n\tif wf.Location != domain.LocationHost {\n\t\tt.Errorf(\"expected host location, got %q\", wf.Location)\n\t}\n}\n\nfunc TestLoadWorkflow_NotFound(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n\n\t_, err := loadWorkflow(dir, \"nonexistent\")\n\tif err == nil {\n\t\tt.Error(\"expected error for nonexistent workflow\")\n\t}\n\tif !strings.Contains(err.Error(), \"not found\") {\n\t\tt.Errorf(\"expected 'not found' error, got: %v\", err)\n\t}\n}\n\nfunc TestRenderWorkflowGraph_DevelopWorkflow(t *testing.T) {\n\t// Simulate the develop workflow from the project\n\twf := &domain.Workflow{\n\t\tName:      \"develop\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"implement\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"implement\":   {Name: \"implement\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n\t\t\t\"test\":        {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n\t\t\t\"fix\":         {Name: \"fix\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\", \"give-up\"}},\n\t\t\t\"update-docs\": {Name: \"update-docs\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"implement\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"implement\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"test\", Result: \"success\", To: \"update-docs\"},\n\t\t\t{From: \"test\", Result: \"fail\", To: \"fix\"},\n\t\t\t{From: \"fix\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"fix\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"fix\", Result: \"give-up\", To: \"abort\"},\n\t\t\t{From: \"update-docs\", Result: \"success\", To: \"done\"},\n\t\t\t{From: \"update-docs\", Result: \"fail\", To: \"done\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\n\t// Check BFS order: implement -> test -> update-docs -> fix\n\t// (update-docs before fix because test:success wire comes before test:fail wire)\n\tlines := strings.Split(output, \"\\n\")\n\tstepBoxOrder := []string{}\n\tfor _, line := range lines {\n\t\tif strings.Contains(line, \"│\") && strings.Contains(line, \"◀ entry\") {\n\t\t\tstepBoxOrder = append(stepBoxOrder, \"implement\")\n\t\t} else if strings.Contains(line, \"│\") && strings.Contains(line, \"script\") && strings.Contains(line, \"test\") {\n\t\t\tstepBoxOrder = append(stepBoxOrder, \"test\")\n\t\t} else if strings.Contains(line, \"│\") && strings.Contains(line, \"update-docs\") {\n\t\t\tstepBoxOrder = append(stepBoxOrder, \"update-docs\")\n\t\t} else if strings.Contains(line, \"│\") && strings.Contains(line, \"fix\") && strings.Contains(line, \"agent\") && !strings.Contains(line, \"update\") && !strings.Contains(line, \"implement\") {\n\t\t\tstepBoxOrder = append(stepBoxOrder, \"fix\")\n\t\t}\n\t}\n\n\texpected := []string{\"implement\", \"test\", \"update-docs\", \"fix\"}\n\tif len(stepBoxOrder) != len(expected) {\n\t\tt.Fatalf(\"expected %d step boxes, got %d: %v\", len(expected), len(stepBoxOrder), stepBoxOrder)\n\t}\n\tfor i, name := range expected {\n\t\tif stepBoxOrder[i] != name {\n\t\t\tt.Errorf(\"step %d: expected %q, got %q (order: %v)\", i, name, stepBoxOrder[i], stepBoxOrder)\n\t\t}\n\t}\n\n\t// Check wire merging: fix's fail and give-up should merge to ABORT\n\tif !strings.Contains(output, \"fail, give-up ──▶ ABORT\") {\n\t\tt.Errorf(\"expected merged wire 'fail, give-up ──▶ ABORT' in output:\\n%s\", output)\n\t}\n\n\t// Check wire merging: update-docs success and fail should merge to DONE\n\tif !strings.Contains(output, \"success, fail ──▶ DONE\") {\n\t\tt.Errorf(\"expected merged wire 'success, fail ──▶ DONE' in output:\\n%s\", output)\n\t}\n\n\t// Check cycle reference: fix:success -> test (back reference)\n\tif !strings.Contains(output, \"success ──▶ test\") {\n\t\tt.Error(\"expected fix:success wire to test\")\n\t}\n}\n\nfunc TestFormatDest(t *testing.T) {\n\ttests := []struct {\n\t\tto       string\n\t\tcolor    bool\n\t\texpected string\n\t}{\n\t\t{\"done\", false, \"DONE\"},\n\t\t{\"abort\", false, \"ABORT\"},\n\t\t{\"step_a\", false, \"step_a\"},\n\t\t{\"done\", true, colorGreen + \"DONE\" + colorReset},\n\t\t{\"abort\", true, colorRed + \"ABORT\" + colorReset},\n\t\t{\"step_a\", true, \"step_a\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tgot := formatDest(tt.to, tt.color)\n\t\tif got != tt.expected {\n\t\t\tt.Errorf(\"formatDest(%q, %v) = %q, want %q\", tt.to, tt.color, got, tt.expected)\n\t\t}\n\t}\n}\n\nfunc TestRenderWorkflowGraph_CollectBlock(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"collect-test\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"step1\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"step2\": {Name: \"step2\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"step3\": {Name: \"step3\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"step1\", Result: \"success\", To: \"step2\"},\n\t\t\t{From: \"step1\", Result: \"success\", To: \"step3\"},\n\t\t\t{From: \"step3\", Result: \"success\", To: \"done\"},\n\t\t},\n\t\tCollects: []domain.Collect{\n\t\t\t{\n\t\t\t\tMode: domain.CollectAll,\n\t\t\t\tConditions: []domain.WireCondition{\n\t\t\t\t\t{Step: \"step2\", Result: \"success\"},\n\t\t\t\t\t{Step: \"step3\", Result: \"success\"},\n\t\t\t\t},\n\t\t\t\tTo: \"done\",\n\t\t\t},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\tif !strings.Contains(output, \"collect all\") {\n\t\tt.Errorf(\"expected collect block in output:\\n%s\", output)\n\t}\n}\n","numLines":629,"startLine":1,"totalLines":629}}}
