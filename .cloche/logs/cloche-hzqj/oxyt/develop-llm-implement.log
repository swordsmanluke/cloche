{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YHrvca59nc2vKLHcsULNtK","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"os\"\n     6→\t\"path/filepath\"\n     7→\t\"sort\"\n     8→\t\"strings\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    12→)\n    13→\n    14→func cmdWorkflow(args []string) {\n    15→\tvar projectDir, workflowName string\n    16→\tfor i := 0; i < len(args); i++ {\n    17→\t\tswitch args[i] {\n    18→\t\tcase \"--project\", \"-p\":\n    19→\t\t\tif i+1 < len(args) {\n    20→\t\t\t\ti++\n    21→\t\t\t\tprojectDir = args[i]\n    22→\t\t\t}\n    23→\t\tdefault:\n    24→\t\t\tif !strings.HasPrefix(args[i], \"-\") && workflowName == \"\" {\n    25→\t\t\t\tworkflowName = args[i]\n    26→\t\t\t}\n    27→\t\t}\n    28→\t}\n    29→\n    30→\tif projectDir == \"\" {\n    31→\t\tprojectDir, _ = os.Getwd()\n    32→\t} else {\n    33→\t\tabs, err := filepath.Abs(projectDir)\n    34→\t\tif err == nil {\n    35→\t\t\tprojectDir = abs\n    36→\t\t}\n    37→\t}\n    38→\n    39→\tif workflowName == \"\" {\n    40→\t\tlistWorkflows(projectDir)\n    41→\t} else {\n    42→\t\tshowWorkflow(projectDir, workflowName)\n    43→\t}\n    44→}\n    45→\n    46→type workflowInfo struct {\n    47→\tname     string\n    48→\tlocation domain.WorkflowLocation\n    49→}\n    50→\n    51→func discoverWorkflows(projectDir string) ([]workflowInfo, error) {\n    52→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n    53→\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n    54→\tif err != nil {\n    55→\t\treturn nil, err\n    56→\t}\n    57→\n    58→\tvar infos []workflowInfo\n    59→\tfor _, path := range entries {\n    60→\t\tdata, err := os.ReadFile(path)\n    61→\t\tif err != nil {\n    62→\t\t\tcontinue\n    63→\t\t}\n    64→\t\twfs, err := dsl.ParseAll(string(data))\n    65→\t\tif err != nil {\n    66→\t\t\tcontinue\n    67→\t\t}\n    68→\t\tfor _, wf := range wfs {\n    69→\t\t\tinfos = append(infos, workflowInfo{name: wf.Name, location: wf.Location})\n    70→\t\t}\n    71→\t}\n    72→\n    73→\treturn infos, nil\n    74→}\n    75→\n    76→func listWorkflows(projectDir string) {\n    77→\tinfos, err := discoverWorkflows(projectDir)\n    78→\tif err != nil {\n    79→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    80→\t\tos.Exit(1)\n    81→\t}\n    82→\n    83→\tif len(infos) == 0 {\n    84→\t\tfmt.Println(\"No workflows found.\")\n    85→\t\treturn\n    86→\t}\n    87→\n    88→\tvar container, host []string\n    89→\tfor _, info := range infos {\n    90→\t\tswitch info.location {\n    91→\t\tcase domain.LocationContainer:\n    92→\t\t\tcontainer = append(container, info.name)\n    93→\t\tcase domain.LocationHost:\n    94→\t\t\thost = append(host, info.name)\n    95→\t\t}\n    96→\t}\n    97→\n    98→\tsort.Strings(container)\n    99→\tsort.Strings(host)\n   100→\n   101→\tif len(container) > 0 {\n   102→\t\tfmt.Println(\"Container workflows:\")\n   103→\t\tfor _, name := range container {\n   104→\t\t\tfmt.Printf(\"  %s\\n\", name)\n   105→\t\t}\n   106→\t}\n   107→\n   108→\tif len(host) > 0 {\n   109→\t\tif len(container) > 0 {\n   110→\t\t\tfmt.Println()\n   111→\t\t}\n   112→\t\tfmt.Println(\"Host workflows:\")\n   113→\t\tfor _, name := range host {\n   114→\t\t\tfmt.Printf(\"  %s\\n\", name)\n   115→\t\t}\n   116→\t}\n   117→}\n   118→\n   119→func loadWorkflow(projectDir, name string) (*domain.Workflow, error) {\n   120→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n   121→\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n   122→\tif err != nil {\n   123→\t\treturn nil, err\n   124→\t}\n   125→\n   126→\tfor _, path := range entries {\n   127→\t\tdata, err := os.ReadFile(path)\n   128→\t\tif err != nil {\n   129→\t\t\tcontinue\n   130→\t\t}\n   131→\t\twfs, err := dsl.ParseAll(string(data))\n   132→\t\tif err != nil {\n   133→\t\t\tcontinue\n   134→\t\t}\n   135→\t\tif wf, ok := wfs[name]; ok {\n   136→\t\t\treturn wf, nil\n   137→\t\t}\n   138→\t}\n   139→\n   140→\treturn nil, fmt.Errorf(\"workflow %q not found\", name)\n   141→}\n   142→\n   143→func showWorkflow(projectDir, name string) {\n   144→\twf, err := loadWorkflow(projectDir, name)\n   145→\tif err != nil {\n   146→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   147→\t\tos.Exit(1)\n   148→\t}\n   149→\tfmt.Print(renderWorkflowGraph(wf, isTTY()))\n   150→}\n   151→\n   152→// ANSI color codes for wire colorization.\n   153→const (\n   154→\tcolorReset   = \"\\033[0m\"\n   155→\tcolorGreen   = \"\\033[32m\"\n   156→\tcolorRed     = \"\\033[31m\"\n   157→\tcolorBlue    = \"\\033[34m\"\n   158→\tcolorYellow  = \"\\033[33m\"\n   159→\tcolorOrange  = \"\\033[38;5;208m\"\n   160→\tcolorMagenta = \"\\033[35m\"\n   161→)\n   162→\n   163→var otherResultColors = []string{colorBlue, colorYellow, colorOrange, colorMagenta}\n   164→\n   165→// buildResultColorMap assigns a color to each unique result name in the workflow.\n   166→// \"success\" is always green, \"fail\"/\"failed\" always red, others cycle through\n   167→// blue, yellow, orange, magenta.\n   168→func buildResultColorMap(w *domain.Workflow, order []string) map[string]string {\n   169→\tcolorMap := map[string]string{\n   170→\t\t\"success\": colorGreen,\n   171→\t\t\"fail\":    colorRed,\n   172→\t\t\"failed\":  colorRed,\n   173→\t}\n   174→\n   175→\totherIdx := 0\n   176→\tfor _, stepName := range order {\n   177→\t\tstep := w.Steps[stepName]\n   178→\t\tfor _, r := range step.Results {\n   179→\t\t\tif _, ok := colorMap[r]; ok {\n   180→\t\t\t\tcontinue\n   181→\t\t\t}\n   182→\t\t\tcolorMap[r] = otherResultColors[otherIdx%len(otherResultColors)]\n   183→\t\t\totherIdx++\n   184→\t\t}\n   185→\t}\n   186→\n   187→\treturn colorMap\n   188→}\n   189→\n   190→func renderWorkflowGraph(w *domain.Workflow, color bool) string {\n   191→\tvar buf strings.Builder\n   192→\n   193→\t// Header\n   194→\tfmt.Fprintf(&buf, \"workflow %q (%s)\\n\\n\", w.Name, w.Location)\n   195→\n   196→\torder := bfsOrder(w)\n   197→\tif len(order) == 0 {\n   198→\t\tbuf.WriteString(\"  (no steps)\\n\")\n   199→\t\treturn buf.String()\n   200→\t}\n   201→\n   202→\tcolorMap := buildResultColorMap(w, order)\n   203→\n   204→\t// Compute max step name length for consistent box widths\n   205→\tnameWidth := 0\n   206→\tfor _, name := range order {\n   207→\t\tif len(name) > nameWidth {\n   208→\t\t\tnameWidth = len(name)\n   209→\t\t}\n   210→\t}\n   211→\t// Minimum width\n   212→\tif nameWidth < 6 {\n   213→\t\tnameWidth = 6\n   214→\t}\n   215→\n   216→\tfor i, stepName := range order {\n   217→\t\tstep := w.Steps[stepName]\n   218→\t\tisEntry := stepName == w.EntryStep\n   219→\n   220→\t\trenderStepBox(&buf, step, isEntry, nameWidth)\n   221→\t\tgroups := groupWiresByDest(w, stepName)\n   222→\t\trenderWireGroups(&buf, groups, colorMap, color)\n   223→\n   224→\t\t// Also render any collect conditions originating from this step\n   225→\t\trenderCollects(&buf, w, stepName, colorMap, color)\n   226→\n   227→\t\tif i < len(order)-1 {\n   228→\t\t\tbuf.WriteString(\"\\n\")\n   229→\t\t}\n   230→\t}\n   231→\n   232→\treturn buf.String()\n   233→}\n   234→\n   235→func renderStepBox(buf *strings.Builder, step *domain.Step, isEntry bool, nameWidth int) {\n   236→\tpadded := fmt.Sprintf(\" %-*s \", nameWidth, step.Name)\n   237→\tborder := strings.Repeat(\"─\", nameWidth+2)\n   238→\n   239→\tsuffix := fmt.Sprintf(\" %s\", step.Type)\n   240→\tif isEntry {\n   241→\t\tsuffix += \"  ◀ entry\"\n   242→\t}\n   243→\n   244→\tfmt.Fprintf(buf, \"  ┌%s┐\\n\", border)\n   245→\tfmt.Fprintf(buf, \"  │%s│%s\\n\", padded, suffix)\n   246→\tfmt.Fprintf(buf, \"  └%s┘\\n\", border)\n   247→}\n   248→\n   249→type wireGroup struct {\n   250→\tresults []string\n   251→\tto      string\n   252→}\n   253→\n   254→// groupWiresByDest groups wires from a step by destination, preserving order.\n   255→// Wires to the same destination are merged into a single group.\n   256→func groupWiresByDest(w *domain.Workflow, stepName string) []wireGroup {\n   257→\tdestMap := make(map[string][]string)\n   258→\tvar destOrder []string\n   259→\n   260→\tfor _, wire := range w.Wiring {\n   261→\t\tif wire.From != stepName {\n   262→\t\t\tcontinue\n   263→\t\t}\n   264→\t\tif _, seen := destMap[wire.To]; !seen {\n   265→\t\t\tdestOrder = append(destOrder, wire.To)\n   266→\t\t}\n   267→\t\tdestMap[wire.To] = append(destMap[wire.To], wire.Result)\n   268→\t}\n   269→\n   270→\tvar groups []wireGroup\n   271→\tfor _, dest := range destOrder {\n   272→\t\tgroups = append(groups, wireGroup{results: destMap[dest], to: dest})\n   273→\t}\n   274→\treturn groups\n   275→}\n   276→\n   277→func renderWireGroups(buf *strings.Builder, groups []wireGroup, colorMap map[string]string, useColor bool) {\n   278→\tfor i, g := range groups {\n   279→\t\tisLast := i == len(groups)-1\n   280→\t\tbranch := \"├\"\n   281→\t\tif isLast {\n   282→\t\t\tbranch = \"└\"\n   283→\t\t}\n   284→\n   285→\t\t// Build colored result list\n   286→\t\tvar resultParts []string\n   287→\t\tfor _, r := range g.results {\n   288→\t\t\tif useColor {\n   289→\t\t\t\tresultParts = append(resultParts, colorMap[r]+r+colorReset)\n   290→\t\t\t} else {\n   291→\t\t\t\tresultParts = append(resultParts, r)\n   292→\t\t\t}\n   293→\t\t}\n   294→\t\tresultStr := strings.Join(resultParts, \", \")\n   295→\n   296→\t\t// Format destination\n   297→\t\tdest := formatDest(g.to, useColor)\n   298→\n   299→\t\tfmt.Fprintf(buf, \"    %s── %s ──▶ %s\\n\", branch, resultStr, dest)\n   300→\t}\n   301→}\n   302→\n   303→func formatDest(to string, useColor bool) string {\n   304→\tswitch to {\n   305→\tcase domain.StepDone:\n   306→\t\tif useColor {\n   307→\t\t\treturn colorGreen + \"DONE\" + colorReset\n   308→\t\t}\n   309→\t\treturn \"DONE\"\n   310→\tcase domain.StepAbort:\n   311→\t\tif useColor {\n   312→\t\t\treturn colorRed + \"ABORT\" + colorReset\n   313→\t\t}\n   314→\t\treturn \"ABORT\"\n   315→\tdefault:\n   316→\t\treturn to\n   317→\t}\n   318→}\n   319→\n   320→// renderCollects renders any collect conditions that reference this step.\n   321→func renderCollects(buf *strings.Builder, w *domain.Workflow, stepName string, colorMap map[string]string, useColor bool) {\n   322→\tfor _, c := range w.Collects {\n   323→\t\t// Check if this step is part of the collect conditions\n   324→\t\tvar parts []string\n   325→\t\tinvolves := false\n   326→\t\tfor _, cond := range c.Conditions {\n   327→\t\t\tlabel := cond.Step + \":\" + cond.Result\n   328→\t\t\tif useColor {\n   329→\t\t\t\tif clr, ok := colorMap[cond.Result]; ok {\n   330→\t\t\t\t\tlabel = cond.Step + \":\" + clr + cond.Result + colorReset\n   331→\t\t\t\t}\n   332→\t\t\t}\n   333→\t\t\tparts = append(parts, label)\n   334→\t\t\tif cond.Step == stepName {\n   335→\t\t\t\tinvolves = true\n   336→\t\t\t}\n   337→\t\t}\n   338→\t\t// Only render the collect on the last condition step to avoid duplication\n   339→\t\tif involves && c.Conditions[len(c.Conditions)-1].Step == stepName {\n   340→\t\t\tdest := formatDest(c.To, useColor)\n   341→\t\t\tfmt.Fprintf(buf, \"    collect %s(%s) ──▶ %s\\n\", c.Mode, strings.Join(parts, \", \"), dest)\n   342→\t\t}\n   343→\t}\n   344→}\n   345→\n   346→// bfsOrder returns steps in BFS order from the entry step.\n   347→// Handles cycles by skipping already-visited nodes.\n   348→func bfsOrder(w *domain.Workflow) []string {\n   349→\tif w.EntryStep == \"\" {\n   350→\t\treturn nil\n   351→\t}\n   352→\n   353→\tvisited := map[string]bool{w.EntryStep: true}\n   354→\tvar order []string\n   355→\tqueue := []string{w.EntryStep}\n   356→\n   357→\tfor len(queue) > 0 {\n   358→\t\tcurrent := queue[0]\n   359→\t\tqueue = queue[1:]\n   360→\t\torder = append(order, current)\n   361→\n   362→\t\t// Collect unique target steps in wire order\n   363→\t\tfor _, wire := range w.Wiring {\n   364→\t\t\tif wire.From != current {\n   365→\t\t\t\tcontinue\n   366→\t\t\t}\n   367→\t\t\tif wire.To == domain.StepDone || wire.To == domain.StepAbort {\n   368→\t\t\t\tcontinue\n   369→\t\t\t}\n   370→\t\t\tif visited[wire.To] {\n   371→\t\t\t\tcontinue\n   372→\t\t\t}\n   373→\t\t\tvisited[wire.To] = true\n   374→\t\t\tqueue = append(queue, wire.To)\n   375→\t\t}\n   376→\t}\n   377→\n   378→\treturn order\n   379→}\n   380→"}]},"parent_tool_use_id":null,"session_id":"955b2dd5-cc52-456b-afc0-0035f6eae0d8","uuid":"c64baffb-b26b-4a9f-8be1-502661593646","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/workflow.go","content":"package main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n)\n\nfunc cmdWorkflow(args []string) {\n\tvar projectDir, workflowName string\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\tdefault:\n\t\t\tif !strings.HasPrefix(args[i], \"-\") && workflowName == \"\" {\n\t\t\t\tworkflowName = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tprojectDir, _ = os.Getwd()\n\t} else {\n\t\tabs, err := filepath.Abs(projectDir)\n\t\tif err == nil {\n\t\t\tprojectDir = abs\n\t\t}\n\t}\n\n\tif workflowName == \"\" {\n\t\tlistWorkflows(projectDir)\n\t} else {\n\t\tshowWorkflow(projectDir, workflowName)\n\t}\n}\n\ntype workflowInfo struct {\n\tname     string\n\tlocation domain.WorkflowLocation\n}\n\nfunc discoverWorkflows(projectDir string) ([]workflowInfo, error) {\n\tclocheDir := filepath.Join(projectDir, \".cloche\")\n\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar infos []workflowInfo\n\tfor _, path := range entries {\n\t\tdata, err := os.ReadFile(path)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twfs, err := dsl.ParseAll(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor _, wf := range wfs {\n\t\t\tinfos = append(infos, workflowInfo{name: wf.Name, location: wf.Location})\n\t\t}\n\t}\n\n\treturn infos, nil\n}\n\nfunc listWorkflows(projectDir string) {\n\tinfos, err := discoverWorkflows(projectDir)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(infos) == 0 {\n\t\tfmt.Println(\"No workflows found.\")\n\t\treturn\n\t}\n\n\tvar container, host []string\n\tfor _, info := range infos {\n\t\tswitch info.location {\n\t\tcase domain.LocationContainer:\n\t\t\tcontainer = append(container, info.name)\n\t\tcase domain.LocationHost:\n\t\t\thost = append(host, info.name)\n\t\t}\n\t}\n\n\tsort.Strings(container)\n\tsort.Strings(host)\n\n\tif len(container) > 0 {\n\t\tfmt.Println(\"Container workflows:\")\n\t\tfor _, name := range container {\n\t\t\tfmt.Printf(\"  %s\\n\", name)\n\t\t}\n\t}\n\n\tif len(host) > 0 {\n\t\tif len(container) > 0 {\n\t\t\tfmt.Println()\n\t\t}\n\t\tfmt.Println(\"Host workflows:\")\n\t\tfor _, name := range host {\n\t\t\tfmt.Printf(\"  %s\\n\", name)\n\t\t}\n\t}\n}\n\nfunc loadWorkflow(projectDir, name string) (*domain.Workflow, error) {\n\tclocheDir := filepath.Join(projectDir, \".cloche\")\n\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tfor _, path := range entries {\n\t\tdata, err := os.ReadFile(path)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twfs, err := dsl.ParseAll(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif wf, ok := wfs[name]; ok {\n\t\t\treturn wf, nil\n\t\t}\n\t}\n\n\treturn nil, fmt.Errorf(\"workflow %q not found\", name)\n}\n\nfunc showWorkflow(projectDir, name string) {\n\twf, err := loadWorkflow(projectDir, name)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Print(renderWorkflowGraph(wf, isTTY()))\n}\n\n// ANSI color codes for wire colorization.\nconst (\n\tcolorReset   = \"\\033[0m\"\n\tcolorGreen   = \"\\033[32m\"\n\tcolorRed     = \"\\033[31m\"\n\tcolorBlue    = \"\\033[34m\"\n\tcolorYellow  = \"\\033[33m\"\n\tcolorOrange  = \"\\033[38;5;208m\"\n\tcolorMagenta = \"\\033[35m\"\n)\n\nvar otherResultColors = []string{colorBlue, colorYellow, colorOrange, colorMagenta}\n\n// buildResultColorMap assigns a color to each unique result name in the workflow.\n// \"success\" is always green, \"fail\"/\"failed\" always red, others cycle through\n// blue, yellow, orange, magenta.\nfunc buildResultColorMap(w *domain.Workflow, order []string) map[string]string {\n\tcolorMap := map[string]string{\n\t\t\"success\": colorGreen,\n\t\t\"fail\":    colorRed,\n\t\t\"failed\":  colorRed,\n\t}\n\n\totherIdx := 0\n\tfor _, stepName := range order {\n\t\tstep := w.Steps[stepName]\n\t\tfor _, r := range step.Results {\n\t\t\tif _, ok := colorMap[r]; ok {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tcolorMap[r] = otherResultColors[otherIdx%len(otherResultColors)]\n\t\t\totherIdx++\n\t\t}\n\t}\n\n\treturn colorMap\n}\n\nfunc renderWorkflowGraph(w *domain.Workflow, color bool) string {\n\tvar buf strings.Builder\n\n\t// Header\n\tfmt.Fprintf(&buf, \"workflow %q (%s)\\n\\n\", w.Name, w.Location)\n\n\torder := bfsOrder(w)\n\tif len(order) == 0 {\n\t\tbuf.WriteString(\"  (no steps)\\n\")\n\t\treturn buf.String()\n\t}\n\n\tcolorMap := buildResultColorMap(w, order)\n\n\t// Compute max step name length for consistent box widths\n\tnameWidth := 0\n\tfor _, name := range order {\n\t\tif len(name) > nameWidth {\n\t\t\tnameWidth = len(name)\n\t\t}\n\t}\n\t// Minimum width\n\tif nameWidth < 6 {\n\t\tnameWidth = 6\n\t}\n\n\tfor i, stepName := range order {\n\t\tstep := w.Steps[stepName]\n\t\tisEntry := stepName == w.EntryStep\n\n\t\trenderStepBox(&buf, step, isEntry, nameWidth)\n\t\tgroups := groupWiresByDest(w, stepName)\n\t\trenderWireGroups(&buf, groups, colorMap, color)\n\n\t\t// Also render any collect conditions originating from this step\n\t\trenderCollects(&buf, w, stepName, colorMap, color)\n\n\t\tif i < len(order)-1 {\n\t\t\tbuf.WriteString(\"\\n\")\n\t\t}\n\t}\n\n\treturn buf.String()\n}\n\nfunc renderStepBox(buf *strings.Builder, step *domain.Step, isEntry bool, nameWidth int) {\n\tpadded := fmt.Sprintf(\" %-*s \", nameWidth, step.Name)\n\tborder := strings.Repeat(\"─\", nameWidth+2)\n\n\tsuffix := fmt.Sprintf(\" %s\", step.Type)\n\tif isEntry {\n\t\tsuffix += \"  ◀ entry\"\n\t}\n\n\tfmt.Fprintf(buf, \"  ┌%s┐\\n\", border)\n\tfmt.Fprintf(buf, \"  │%s│%s\\n\", padded, suffix)\n\tfmt.Fprintf(buf, \"  └%s┘\\n\", border)\n}\n\ntype wireGroup struct {\n\tresults []string\n\tto      string\n}\n\n// groupWiresByDest groups wires from a step by destination, preserving order.\n// Wires to the same destination are merged into a single group.\nfunc groupWiresByDest(w *domain.Workflow, stepName string) []wireGroup {\n\tdestMap := make(map[string][]string)\n\tvar destOrder []string\n\n\tfor _, wire := range w.Wiring {\n\t\tif wire.From != stepName {\n\t\t\tcontinue\n\t\t}\n\t\tif _, seen := destMap[wire.To]; !seen {\n\t\t\tdestOrder = append(destOrder, wire.To)\n\t\t}\n\t\tdestMap[wire.To] = append(destMap[wire.To], wire.Result)\n\t}\n\n\tvar groups []wireGroup\n\tfor _, dest := range destOrder {\n\t\tgroups = append(groups, wireGroup{results: destMap[dest], to: dest})\n\t}\n\treturn groups\n}\n\nfunc renderWireGroups(buf *strings.Builder, groups []wireGroup, colorMap map[string]string, useColor bool) {\n\tfor i, g := range groups {\n\t\tisLast := i == len(groups)-1\n\t\tbranch := \"├\"\n\t\tif isLast {\n\t\t\tbranch = \"└\"\n\t\t}\n\n\t\t// Build colored result list\n\t\tvar resultParts []string\n\t\tfor _, r := range g.results {\n\t\t\tif useColor {\n\t\t\t\tresultParts = append(resultParts, colorMap[r]+r+colorReset)\n\t\t\t} else {\n\t\t\t\tresultParts = append(resultParts, r)\n\t\t\t}\n\t\t}\n\t\tresultStr := strings.Join(resultParts, \", \")\n\n\t\t// Format destination\n\t\tdest := formatDest(g.to, useColor)\n\n\t\tfmt.Fprintf(buf, \"    %s── %s ──▶ %s\\n\", branch, resultStr, dest)\n\t}\n}\n\nfunc formatDest(to string, useColor bool) string {\n\tswitch to {\n\tcase domain.StepDone:\n\t\tif useColor {\n\t\t\treturn colorGreen + \"DONE\" + colorReset\n\t\t}\n\t\treturn \"DONE\"\n\tcase domain.StepAbort:\n\t\tif useColor {\n\t\t\treturn colorRed + \"ABORT\" + colorReset\n\t\t}\n\t\treturn \"ABORT\"\n\tdefault:\n\t\treturn to\n\t}\n}\n\n// renderCollects renders any collect conditions that reference this step.\nfunc renderCollects(buf *strings.Builder, w *domain.Workflow, stepName string, colorMap map[string]string, useColor bool) {\n\tfor _, c := range w.Collects {\n\t\t// Check if this step is part of the collect conditions\n\t\tvar parts []string\n\t\tinvolves := false\n\t\tfor _, cond := range c.Conditions {\n\t\t\tlabel := cond.Step + \":\" + cond.Result\n\t\t\tif useColor {\n\t\t\t\tif clr, ok := colorMap[cond.Result]; ok {\n\t\t\t\t\tlabel = cond.Step + \":\" + clr + cond.Result + colorReset\n\t\t\t\t}\n\t\t\t}\n\t\t\tparts = append(parts, label)\n\t\t\tif cond.Step == stepName {\n\t\t\t\tinvolves = true\n\t\t\t}\n\t\t}\n\t\t// Only render the collect on the last condition step to avoid duplication\n\t\tif involves && c.Conditions[len(c.Conditions)-1].Step == stepName {\n\t\t\tdest := formatDest(c.To, useColor)\n\t\t\tfmt.Fprintf(buf, \"    collect %s(%s) ──▶ %s\\n\", c.Mode, strings.Join(parts, \", \"), dest)\n\t\t}\n\t}\n}\n\n// bfsOrder returns steps in BFS order from the entry step.\n// Handles cycles by skipping already-visited nodes.\nfunc bfsOrder(w *domain.Workflow) []string {\n\tif w.EntryStep == \"\" {\n\t\treturn nil\n\t}\n\n\tvisited := map[string]bool{w.EntryStep: true}\n\tvar order []string\n\tqueue := []string{w.EntryStep}\n\n\tfor len(queue) > 0 {\n\t\tcurrent := queue[0]\n\t\tqueue = queue[1:]\n\t\torder = append(order, current)\n\n\t\t// Collect unique target steps in wire order\n\t\tfor _, wire := range w.Wiring {\n\t\t\tif wire.From != current {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif wire.To == domain.StepDone || wire.To == domain.StepAbort {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif visited[wire.To] {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvisited[wire.To] = true\n\t\t\tqueue = append(queue, wire.To)\n\t\t}\n\t}\n\n\treturn order\n}\n","numLines":380,"startLine":1,"totalLines":380}}}
