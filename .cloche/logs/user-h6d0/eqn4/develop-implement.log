{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FGwijxb2LKVz7xWDkWzgA8","type":"tool_result","content":"     1→package orchestrator\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"sync\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/config\"\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14→)\n    15→\n    16→// RunDispatcher dispatches a workflow run and returns the run ID.\n    17→type RunDispatcher func(ctx context.Context, workflowName, projectDir, prompt string) (string, error)\n    18→\n    19→// ProjectConfig holds orchestration settings for a single project.\n    20→type ProjectConfig struct {\n    21→\tDir         string\n    22→\tWorkflow    string\n    23→\tConcurrency int\n    24→\tTracker     ports.TaskTracker\n    25→\tEnabled     bool\n    26→}\n    27→\n    28→// ParseHostWorkflowFunc parses a host.cloche file and returns the named workflow.\n    29→type ParseHostWorkflowFunc func(input string) (*domain.Workflow, error)\n    30→\n    31→// Orchestrator pulls ready tasks and dispatches workflow runs, respecting\n    32→// per-project concurrency limits.\n    33→type Orchestrator struct {\n    34→\tpromptGen          PromptGenerator\n    35→\tdispatch           RunDispatcher\n    36→\tmu                 sync.Mutex\n    37→\tprojects           map[string]*ProjectConfig // keyed by Dir\n    38→\tinFlight           map[string]int            // keyed by Dir\n    39→\tinFlightTasks      map[string]string         // runID -> taskID\n    40→\tinFlightTaskSet    map[string]map[string]bool // projectDir -> set of taskIDs in flight\n    41→\thostRunner         *HostRunner\n    42→\tparseHostWorkflow  ParseHostWorkflowFunc\n    43→}\n    44→\n    45→// New creates an Orchestrator.\n    46→func New(promptGen PromptGenerator, dispatch RunDispatcher, opts ...OrchestratorOption) *Orchestrator {\n    47→\to := &Orchestrator{\n    48→\t\tpromptGen:       promptGen,\n    49→\t\tdispatch:        dispatch,\n    50→\t\tprojects:        make(map[string]*ProjectConfig),\n    51→\t\tinFlight:        make(map[string]int),\n    52→\t\tinFlightTasks:   make(map[string]string),\n    53→\t\tinFlightTaskSet: make(map[string]map[string]bool),\n    54→\t}\n    55→\tfor _, opt := range opts {\n    56→\t\topt(o)\n    57→\t}\n    58→\treturn o\n    59→}\n    60→\n    61→// OrchestratorOption configures optional fields on the Orchestrator.\n    62→type OrchestratorOption func(*Orchestrator)\n    63→\n    64→// WithHostRunner sets the HostRunner for host.cloche support.\n    65→func WithHostRunner(hr *HostRunner) OrchestratorOption {\n    66→\treturn func(o *Orchestrator) {\n    67→\t\to.hostRunner = hr\n    68→\t}\n    69→}\n    70→\n    71→// WithParseHostWorkflow sets the parser function for host.cloche files.\n    72→func WithParseHostWorkflow(fn ParseHostWorkflowFunc) OrchestratorOption {\n    73→\treturn func(o *Orchestrator) {\n    74→\t\to.parseHostWorkflow = fn\n    75→\t}\n    76→}\n    77→\n    78→// Register adds a project to the orchestrator.\n    79→func (o *Orchestrator) Register(pc *ProjectConfig) {\n    80→\to.mu.Lock()\n    81→\tdefer o.mu.Unlock()\n    82→\tpc.Enabled = true\n    83→\to.projects[pc.Dir] = pc\n    84→}\n    85→\n    86→// Status returns the enabled flag, in-flight count, and concurrency for a project.\n    87→func (o *Orchestrator) Status(dir string) (enabled bool, inFlight int, concurrency int) {\n    88→\to.mu.Lock()\n    89→\tdefer o.mu.Unlock()\n    90→\tpc, ok := o.projects[dir]\n    91→\tif !ok {\n    92→\t\treturn false, 0, 0\n    93→\t}\n    94→\treturn pc.Enabled, o.inFlight[dir], pc.Concurrency\n    95→}\n    96→\n    97→// SetEnabled enables or disables orchestration for a project.\n    98→func (o *Orchestrator) SetEnabled(dir string, enabled bool) {\n    99→\to.mu.Lock()\n   100→\tdefer o.mu.Unlock()\n   101→\tif pc, ok := o.projects[dir]; ok {\n   102→\t\tpc.Enabled = enabled\n   103→\t}\n   104→}\n   105→\n   106→// SetConcurrency overrides the concurrency limit for a project (runtime only).\n   107→func (o *Orchestrator) SetConcurrency(dir string, concurrency int) {\n   108→\to.mu.Lock()\n   109→\tdefer o.mu.Unlock()\n   110→\tif pc, ok := o.projects[dir]; ok {\n   111→\t\tpc.Concurrency = concurrency\n   112→\t}\n   113→}\n   114→\n   115→// RegisterFromConfig registers a project using its config file.\n   116→// Returns false if orchestration is not enabled for the project.\n   117→func (o *Orchestrator) RegisterFromConfig(projectDir string, tracker ports.TaskTracker) bool {\n   118→\tcfg, err := config.Load(projectDir)\n   119→\tif err != nil || !cfg.Orchestration.Enabled {\n   120→\t\treturn false\n   121→\t}\n   122→\tworkflow := cfg.Orchestration.Workflow\n   123→\tif workflow == \"\" {\n   124→\t\tworkflow = \"develop\"\n   125→\t}\n   126→\tconcurrency := cfg.Orchestration.Concurrency\n   127→\tif concurrency < 1 {\n   128→\t\tconcurrency = 1\n   129→\t}\n   130→\to.Register(&ProjectConfig{\n   131→\t\tDir:         projectDir,\n   132→\t\tWorkflow:    workflow,\n   133→\t\tConcurrency: concurrency,\n   134→\t\tTracker:     tracker,\n   135→\t\tEnabled:     true,\n   136→\t})\n   137→\treturn true\n   138→}\n   139→\n   140→// trackTask records a run-to-task mapping for later completion/failure.\n   141→func (o *Orchestrator) trackTask(projectDir, runID, taskID string) {\n   142→\to.inFlightTasks[runID] = taskID\n   143→\tif o.inFlightTaskSet[projectDir] == nil {\n   144→\t\to.inFlightTaskSet[projectDir] = make(map[string]bool)\n   145→\t}\n   146→\to.inFlightTaskSet[projectDir][taskID] = true\n   147→}\n   148→\n   149→// untrackTask removes a run-to-task mapping. Returns the task ID.\n   150→func (o *Orchestrator) untrackTask(projectDir, runID string) string {\n   151→\ttaskID := o.inFlightTasks[runID]\n   152→\tdelete(o.inFlightTasks, runID)\n   153→\tif taskID != \"\" && o.inFlightTaskSet[projectDir] != nil {\n   154→\t\tdelete(o.inFlightTaskSet[projectDir], taskID)\n   155→\t}\n   156→\treturn taskID\n   157→}\n   158→\n   159→// isTaskInFlight checks if a task already has an active run.\n   160→func (o *Orchestrator) isTaskInFlight(projectDir, taskID string) bool {\n   161→\tif set := o.inFlightTaskSet[projectDir]; set != nil {\n   162→\t\treturn set[taskID]\n   163→\t}\n   164→\treturn false\n   165→}\n   166→\n   167→// Run performs one orchestration cycle for a single project. It returns the\n   168→// number of runs dispatched.\n   169→func (o *Orchestrator) Run(ctx context.Context, projectDir string) (int, error) {\n   170→\to.mu.Lock()\n   171→\tpc, ok := o.projects[projectDir]\n   172→\tif !ok {\n   173→\t\to.mu.Unlock()\n   174→\t\treturn 0, fmt.Errorf(\"project %q not registered\", projectDir)\n   175→\t}\n   176→\tif !pc.Enabled {\n   177→\t\to.mu.Unlock()\n   178→\t\treturn 0, nil\n   179→\t}\n   180→\tcurrent := o.inFlight[projectDir]\n   181→\tavailable := pc.Concurrency - current\n   182→\to.mu.Unlock()\n   183→\n   184→\tif available <= 0 {\n   185→\t\treturn 0, nil\n   186→\t}\n   187→\n   188→\ttasks, err := pc.Tracker.ListReady(ctx, projectDir)\n   189→\tif err != nil {\n   190→\t\treturn 0, fmt.Errorf(\"listing ready tasks: %w\", err)\n   191→\t}\n   192→\n   193→\t// Check if host.cloche exists for this project\n   194→\thostWorkflowPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   195→\tuseHostWorkflow := o.hostRunner != nil && o.parseHostWorkflow != nil\n   196→\tif useHostWorkflow {\n   197→\t\tif _, err := os.Stat(hostWorkflowPath); os.IsNotExist(err) {\n   198→\t\t\tuseHostWorkflow = false\n   199→\t\t}\n   200→\t}\n   201→\n   202→\tdispatched := 0\n   203→\tfor i := 0; i < len(tasks) && dispatched < available; i++ {\n   204→\t\ttask := tasks[i]\n   205→\n   206→\t\t// Skip tasks that already have an in-flight run (dedup)\n   207→\t\to.mu.Lock()\n   208→\t\talreadyRunning := o.isTaskInFlight(projectDir, task.ID)\n   209→\t\to.mu.Unlock()\n   210→\t\tif alreadyRunning {\n   211→\t\t\tlog.Printf(\"orchestrator: skipping task %s (already in flight)\", task.ID)\n   212→\t\t\tcontinue\n   213→\t\t}\n   214→\n   215→\t\tif err := pc.Tracker.Claim(ctx, task.ID); err != nil {\n   216→\t\t\tlog.Printf(\"orchestrator: failed to claim task %s: %v\", task.ID, err)\n   217→\t\t\tcontinue\n   218→\t\t}\n   219→\n   220→\t\tif useHostWorkflow {\n   221→\t\t\t// Host workflow path\n   222→\t\t\tdata, err := os.ReadFile(hostWorkflowPath)\n   223→\t\t\tif err != nil {\n   224→\t\t\t\tlog.Printf(\"orchestrator: failed to read host.cloche for task %s: %v\", task.ID, err)\n   225→\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   226→\t\t\t\tcontinue\n   227→\t\t\t}\n   228→\n   229→\t\t\twf, err := o.parseHostWorkflow(string(data))\n   230→\t\t\tif err != nil {\n   231→\t\t\t\tlog.Printf(\"orchestrator: failed to parse host.cloche for task %s: %v\", task.ID, err)\n   232→\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   233→\t\t\t\tcontinue\n   234→\t\t\t}\n   235→\n   236→\t\t\torchRunID := domain.GenerateRunID(\"orchestrate\")\n   237→\n   238→\t\t\to.mu.Lock()\n   239→\t\t\to.inFlight[projectDir]++\n   240→\t\t\to.trackTask(projectDir, orchRunID, task.ID)\n   241→\t\t\to.mu.Unlock()\n   242→\n   243→\t\t\thr := &HostRunner{\n   244→\t\t\t\tDispatch:   o.hostRunner.Dispatch,\n   245→\t\t\t\tWaitRun:    o.hostRunner.WaitRun,\n   246→\t\t\t\tProjectDir: projectDir,\n   247→\t\t\t}\n   248→\n   249→\t\t\tgo func(task ports.TrackerTask, runID string) {\n   250→\t\t\t\tresult, err := hr.RunWorkflow(ctx, wf, task, runID)\n   251→\n   252→\t\t\t\to.mu.Lock()\n   253→\t\t\t\to.untrackTask(projectDir, runID)\n   254→\t\t\t\tif o.inFlight[projectDir] > 0 {\n   255→\t\t\t\t\to.inFlight[projectDir]--\n   256→\t\t\t\t}\n   257→\t\t\t\to.mu.Unlock()\n   258→\n   259→\t\t\t\tif err != nil {\n   260→\t\t\t\t\tlog.Printf(\"orchestrator: host workflow error for task %s: %v\", task.ID, err)\n   261→\t\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   262→\t\t\t\t} else if result == domain.StepDone {\n   263→\t\t\t\t\tlog.Printf(\"orchestrator: task %s completed successfully\", task.ID)\n   264→\t\t\t\t\t_ = pc.Tracker.Complete(ctx, task.ID)\n   265→\t\t\t\t} else {\n   266→\t\t\t\t\tlog.Printf(\"orchestrator: task %s aborted\", task.ID)\n   267→\t\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   268→\t\t\t\t}\n   269→\t\t\t}(task, orchRunID)\n   270→\n   271→\t\t\tlog.Printf(\"orchestrator: started host workflow %s for task %s in %s\", orchRunID, task.ID, projectDir)\n   272→\t\t\tdispatched++\n   273→\t\t} else {\n   274→\t\t\t// Fallback: existing promptGen → dispatch path\n   275→\t\t\tprompt, err := o.promptGen.Generate(ctx, task, projectDir)\n   276→\t\t\tif err != nil {\n   277→\t\t\t\tlog.Printf(\"orchestrator: failed to generate prompt for task %s: %v\", task.ID, err)\n   278→\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   279→\t\t\t\tcontinue\n   280→\t\t\t}\n   281→\n   282→\t\t\trunID, err := o.dispatch(ctx, pc.Workflow, projectDir, prompt)\n   283→\t\t\tif err != nil {\n   284→\t\t\t\tlog.Printf(\"orchestrator: failed to dispatch run for task %s: %v\", task.ID, err)\n   285→\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   286→\t\t\t\tcontinue\n   287→\t\t\t}\n   288→\n   289→\t\t\to.mu.Lock()\n   290→\t\t\to.inFlight[projectDir]++\n   291→\t\t\to.trackTask(projectDir, runID, task.ID)\n   292→\t\t\to.mu.Unlock()\n   293→\n   294→\t\t\tlog.Printf(\"orchestrator: dispatched run %s for task %s in %s\", runID, task.ID, projectDir)\n   295→\t\t\tdispatched++\n   296→\t\t}\n   297→\t}\n   298→\n   299→\treturn dispatched, nil\n   300→}\n   301→\n   302→// TriggerAll runs orchestration for all registered projects. Returns total\n   303→// dispatched count.\n   304→func (o *Orchestrator) TriggerAll(ctx context.Context) int {\n   305→\to.mu.Lock()\n   306→\tdirs := make([]string, 0, len(o.projects))\n   307→\tfor dir := range o.projects {\n   308→\t\tdirs = append(dirs, dir)\n   309→\t}\n   310→\to.mu.Unlock()\n   311→\n   312→\ttotal := 0\n   313→\tfor _, dir := range dirs {\n   314→\t\tn, err := o.Run(ctx, dir)\n   315→\t\tif err != nil {\n   316→\t\t\tlog.Printf(\"orchestrator: error for project %s: %v\", dir, err)\n   317→\t\t\tcontinue\n   318→\t\t}\n   319→\t\ttotal += n\n   320→\t}\n   321→\treturn total\n   322→}\n   323→\n   324→// OnRunComplete should be called when a workflow run finishes. It looks up the\n   325→// associated task, completes or fails it in the tracker, decrements the\n   326→// in-flight counter, and triggers a new orchestration cycle.\n   327→func (o *Orchestrator) OnRunComplete(ctx context.Context, projectDir string, runID string, state domain.RunState) {\n   328→\to.mu.Lock()\n   329→\tpc := o.projects[projectDir]\n   330→\ttaskID := o.untrackTask(projectDir, runID)\n   331→\tif o.inFlight[projectDir] > 0 {\n   332→\t\to.inFlight[projectDir]--\n   333→\t}\n   334→\to.mu.Unlock()\n   335→\n   336→\t// Close/fail the associated task in the tracker\n   337→\tif taskID != \"\" && pc != nil {\n   338→\t\tif state == domain.RunStateSucceeded {\n   339→\t\t\tlog.Printf(\"orchestrator: completing task %s (run %s succeeded)\", taskID, runID)\n   340→\t\t\t_ = pc.Tracker.Complete(ctx, taskID)\n   341→\t\t} else {\n   342→\t\t\tlog.Printf(\"orchestrator: failing task %s (run %s state: %s)\", taskID, runID, state)\n   343→\t\t\t_ = pc.Tracker.Fail(ctx, taskID)\n   344→\t\t}\n   345→\t}\n   346→\n   347→\tif _, err := o.Run(ctx, projectDir); err != nil {\n   348→\t\tlog.Printf(\"orchestrator: post-completion trigger failed for %s: %v\", projectDir, err)\n   349→\t}\n   350→}\n   351→\n   352→// InFlight returns the current in-flight run count for a project.\n   353→func (o *Orchestrator) InFlight(projectDir string) int {\n   354→\to.mu.Lock()\n   355→\tdefer o.mu.Unlock()\n   356→\treturn o.inFlight[projectDir]\n   357→}\n   358→"}]},"parent_tool_use_id":"toolu_01CAtE5GDCv6Zhuwpqbgd4Wa","session_id":"1b1aa5cb-df87-4bfd-9ba5-30431aa95a7e","uuid":"f7d9c418-8e54-41d6-9961-e8a58825c3a9"}
