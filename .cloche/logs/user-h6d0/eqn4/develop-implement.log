ir string) (int, error) {\n\tpath := filepath.Join(projectDir, \".cloche\", \"version\")\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn 1, nil\n\t}\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\tv, err := strconv.Atoi(strings.TrimSpace(string(data)))\n\tif err != nil {\n\t\treturn 0, fmt.Errorf(\"invalid version file: %w\", err)\n\t}\n\treturn v, nil\n}\n\n// IncrementProjectVersion reads .cloche/version, increments it, and writes it\n// back atomically. If the file does not exist, it writes 2 (implicit version 1).\nfunc IncrementProjectVersion(projectDir string) error {\n\tpath := filepath.Join(projectDir, \".cloche\", \"version\")\n\tv, err := LoadVersion(projectDir)\n\tif err != nil {\n\t\treturn err\n\t}\n\tv++\n\ttmp := path + \".tmp\"\n\tif err := os.WriteFile(tmp, []byte(fmt.Sprintf(\"%d\\n\", v)), 0644); err != nil {\n\t\treturn err\n\t}\n\treturn os.Rename(tmp, path)\n}\n\n// LoadGlobal reads the global daemon config from ~/.config/cloche/config.","numLines":40,"startLine":73,"totalLines":155}}}
