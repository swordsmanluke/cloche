[2026-03-07T16:59:02Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P2TmVofTzF4K3aFeuz6PQ5","type":"tool_result","content":"     1â†’package config\n     2â†’\n     3â†’import (\n     4â†’\t\"os\"\n     5â†’\t\"path/filepath\"\n     6â†’\n     7â†’\t\"github.com/BurntSushi/toml\"\n     8â†’)\n     9â†’\n    10â†’type DaemonConfig struct {\n    11â†’\tListen     string `toml:\"listen\"`\n    12â†’\tHTTP       string `toml:\"http\"`\n    13â†’\tImage      string `toml:\"image\"`\n    14â†’\tDB         string `toml:\"db\"`\n    15â†’\tRuntime    string `toml:\"runtime\"`\n    16â†’\tAgentPath  string `toml:\"agent_path\"`\n    17â†’\tLLMCommand string `toml:\"llm_command\"`\n    18â†’}\n    19â†’\n    20â†’type EvolutionConfig struct {\n    21â†’\tEnabled          bool   `toml:\"enabled\"`\n    22â†’\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n    23â†’\tMinConfidence    string `toml:\"min_confidence\"`\n    24â†’\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n    25â†’}\n    26â†’\n    27â†’type OrchestrationConfig struct {\n    28â†’\tEnabled     bool   `toml:\"enabled\"`\n    29â†’\tTracker     string `toml:\"tracker\"`\n    30â†’\tConcurrency int    `toml:\"concurrency\"`\n    31â†’\tWorkflow    string `toml:\"workflow\"`\n    32â†’}\n    33â†’\n    34â†’type Config struct {\n    35â†’\tDaemon        DaemonConfig        `toml:\"daemon\"`\n    36â†’\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n    37â†’\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n    38â†’}\n    39â†’\n    40â†’func defaults() Config {\n    41â†’\treturn Config{\n    42â†’\t\tEvolution: EvolutionConfig{\n    43â†’\t\t\tEnabled:          true,\n    44â†’\t\t\tDebounceSeconds:  30,\n    45â†’\t\t\tMinConfidence:    \"medium\",\n    46â†’\t\t\tMaxPromptBullets: 50,\n    47â†’\t\t},\n    48â†’\t\tOrchestration: OrchestrationConfig{\n    49â†’\t\t\tTracker:     \"beads\",\n    50â†’\t\t\tConcurrency: 1,\n    51â†’\t\t\tWorkflow:     \"develop\",\n    52â†’\t\t},\n    53â†’\t}\n    54â†’}\n    55â†’\n    56â†’// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    57â†’func Load(projectDir string) (*Config, error) {\n    58â†’\tcfg := defaults()\n    59â†’\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    60â†’\n    61â†’\tdata, err := os.ReadFile(path)\n    62â†’\tif os.IsNotExist(err) {\n    63â†’\t\treturn &cfg, nil\n    64â†’\t}\n    65â†’\tif err != nil {\n    66â†’\t\treturn nil, err\n    67â†’\t}\n    68â†’\n    69â†’\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    70â†’\t\treturn nil, err\n    71â†’\t}\n    72â†’\treturn &cfg, nil\n    73â†’}\n    74â†’\n    75â†’// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n    76â†’// Returns defaults if the file does not exist.\n    77â†’func LoadGlobal() (*Config, error) {\n    78â†’\tcfg := defaults()\n    79â†’\n    80â†’\thome, err := os.UserHomeDir()\n    81â†’\tif err != nil {\n    82â†’\t\treturn &cfg, nil\n    83â†’\t}\n    84â†’\n    85â†’\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n    86â†’\tdata, err := os.ReadFile(path)\n    87â†’\tif os.IsNotExist(err) {\n    88â†’\t\treturn &cfg, nil\n    89â†’\t}\n    90â†’\tif err != nil {\n    91â†’\t\treturn nil, err\n    92â†’\t}\n    93â†’\n    94â†’\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    95â†’\t\treturn nil, err\n    96â†’\t}\n    97â†’\treturn &cfg, nil\n    98â†’}\n    99â†’\n   100â†’// LoadGlobalFrom reads the global config from a specific path.\n   101â†’// Useful for testing.\n   102â†’func LoadGlobalFrom(path string) (*Config, error) {\n   103â†’\tcfg := defaults()\n   104â†’\n   105â†’\tdata, err := os.ReadFile(path)\n   106â†’\tif os.IsNotExist(err) {\n   107â†’\t\treturn &cfg, nil\n   108â†’\t}\n   109â†’\tif err != nil {\n   110â†’\t\treturn nil, err\n   111â†’\t}\n   112â†’\n   113â†’\tif _, err := toml.Decode(string(data), &cfg); err !