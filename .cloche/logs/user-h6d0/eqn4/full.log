flowName, projectDir, prompt string) (string, error) {\n   231â†’\t\tresp, err := srv.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   232â†’\t\t\tWorkflowName: workflowName,\n   233â†’\t\t\tProjectDir:   projectDir,\n   234â†’\t\t\tPrompt:       prompt,\n   235â†’\t\t})\n   236â†’\t\tif err != nil {\n   237â†’\t\t\treturn \"\", err\n   238â†’\t\t}\n   239â†’\t\treturn resp.RunId, nil\n   240â†’\t}\n   241â†’\n   242â†’\twaiter := &orchestrator.StoreRunWaiter{Store: store}\n   243â†’\thostRunner := &orchestrator.HostRunner{\n   244â†’\t\tDispatch: dispatch,\n   245â†’\t\tWaitRun:  waiter,\n   246â†’\t}\n   247â†’\n   248â†’\torch := orchestrator.New(promptGen, dispatch,\n   249â†’\t\torchestrator.WithHostRunner(hostRunner),\n   250â†’\t\torchestrator.WithParseHostWorkflow(dsl.Parse),\n   251â†’\t)\n   252â†’\n   253â†’\t// Collect candidate project directories: cwd + all known projects from the store.\n   254â†’\tcandidates := map[string]bool{}\n   255â†’\tif cwd, err := os.Getwd(); err == nil {\n   256â†’\t\tcandidates[cwd] = true\n   257â†’\t}\n   258â†’\tif projects, err := store.ListProjects(context.Background()); err == nil {\n   259â†’\t\tfor _, dir := range projects {\n   260â†’\t\t\tcandidates[dir] = true\n   261â†’\t\t}\n   262â†’\t}\n   263â†’\n   264â†’\t// Register every project that has orchestration enabled.\n   265â†’\tregistered := 0\n   266â†’\tfor dir := range candidates {\n   267â†’\t\tcfg, err := config.Load(dir)\n   268â†’\t\tif err != nil || !cfg.Orchestration.Enabled {\n   269â†’\t\t\tcontinue\n   270â†’\t\t}\n   271â†’\t\ttracker := beads.NewTracker(dir)\n   272â†’\t\torch.Register(&orchestrator.ProjectConfig{\n   273â†’\t\t\tDir:         dir,\n   274â†’\t\t\tWorkflow:    cfg.Orchestration.Workflow,\n   275â†’\t\t\tConcurrency: cfg.Orchestration.Concurrency,\n   276â†’\t\t\tTracker:     tracker,\n   277â†’\t\t})\n   278â†’\t\tregistered++\n   279â†’\t}\n   280â†’\n   281â†’\tif registered == 0 {\n   282â†’\t\treturn nil\n   283â†’\t}\n   284â†’\treturn orch\n   285â†’}\n   286â†’\n   287â†’\n   288â†’// envOrConfig returns the env var value if set, otherwise the config file\n   289â†’// value if non-empty, otherwise the fallback default.\n   290â†’func envOrConfig(envKey, configVal, fallback string) string {\n   291â†’\tif v := os.Getenv(envKey); v != \"\" {\n   292â†’\t\treturn v\n   293â†’\t}\n   294â†’\tif configVal != \"\" {\n   295â†’\t\treturn configVal\n   296â†’\t}\n   297â†’\treturn fallback\n   298â†’}\n   299â†’"}]},"parent_tool_use_id":"toolu_01CAtE5GDCv6Zhuwpqbgd4Wa","session_id":"1b1aa5cb-df87-4bfd-9ba5-30431aa95a7e","uuid":"d5489157-ec1d-400a-ae8a-8767683bca35"}
