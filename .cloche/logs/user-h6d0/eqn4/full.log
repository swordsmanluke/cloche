[2026-03-07T16:59:02Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YXuJqpLj3Dy9U1MvjaL2R7","type":"tool_result","content":"     1â†’package evolution\n     2â†’\n     3â†’import (\n     4â†’\t\"context\"\n     5â†’\t\"fmt\"\n     6â†’\t\"os\"\n     7â†’\t\"path/filepath\"\n     8â†’\t\"time\"\n     9â†’\n    10â†’\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    11â†’\t\"github.com/cloche-dev/cloche/internal/ports\"\n    12â†’)\n    13â†’\n    14â†’// OrchestratorConfig configures the evolution pipeline.\n    15â†’type OrchestratorConfig struct {\n    16â†’\tProjectDir    string\n    17â†’\tWorkflowName  string\n    18â†’\tLLM           LLMClient\n    19â†’\tMinConfidence string\n    20â†’}\n    21â†’\n    22â†’// Orchestrator wires all evolution pipeline stages together.\n    23â†’type Orchestrator struct {\n    24â†’\tcfg        OrchestratorConfig\n    25â†’\tcollector  *Collector\n    26â†’\tclassifier *Classifier\n    27â†’\treflector  *Reflector\n    28â†’\tcurator    *Curator\n    29â†’\tscriptGen  *ScriptGenerator\n    30â†’\tmutator    *dsl.Mutator\n    31â†’\taudit      *AuditLogger\n    32â†’}\n    33â†’\n    34â†’// NewOrchestrator creates a fully wired evolution pipeline.\n    35â†’func NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n    36â†’\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir}\n    37â†’\treturn &Orchestrator{\n    38â†’\t\tcfg:        cfg,\n    39â†’\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n    40â†’\t\tclassifier: &Classifier{LLM: cfg.LLM},\n    41â†’\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n    42â†’\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n    43â†’\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n    44â†’\t\tmutator:    &dsl.Mutator{},\n    45â†’\t\taudit:      audit,\n    46â†’\t}\n    47â†’}\n    48â†’\n    49â†’// Run executes the full evolution pipeline.\n    50â†’func (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n    51â†’\t// Stage 1: Collect\n    52â†’\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n    53â†’\tif err != nil {\n    54â†’\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n    55â†’\t}\n    56â†’\n    57â†’\t// Stage 2: Classify the triggering run\n    58â†’\tclassification, err := o.classifier.Classify(ctx, \"\")\n    59â†’\tif err != nil {\n    60â†’\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n    61â†’\t}\n    62â†’\n    63â†’\t// Stage 3: Reflect\n    64â†’\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n    65â†’\tif err != nil {\n    66â†’\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n    67â†’\t}\n    68â†’\n    69â†’\tresult := &EvolutionResult{\n    70â†’\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n    71â†’\t\tProjectDir:     o.cfg.ProjectDir,\n    72â†’\t\tWorkflowName:   o.cfg.WorkflowName,\n    73â†’\t\tTriggerRunID:   triggerRunID,\n    74â†’\t\tTimestamp:      time.Now().Format(time.RFC3339),\n    75â†’\t\tClassification: classification,\n    76â†’\t}\n    77â†’\n    78â†’\tif len(lessons) == 0 {\n    79â†’\t\t// No actionable lessons â€” log and return\n    80â†’\t\to.audit.Log(result)\n    81â†’\t\treturn result, nil\n    82â†’\t}\n    83â†’\n    84â†’\t// Stage 4: Execute branches based on lesson category\n    85â†’\tfor _, lesson := range lessons {\n    86â†’\t\tswitch lesson.Category {\n    87â†’\t\tcase \"prompt_improvement\":\n    88â†’\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n    89â†’\t\t\tif err != nil {\n    90â†’\t\t\t\tcontinue // log but don't fail the whole pipeline\n    91â†’\t\t\t}\n    92â†’\t\t\tresult.Changes = append(result.Changes, *change)\n    93â†’\n    94â†’\t\tcase \"new_step\":\n    95â†’\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n    96â†’\t\t\t\tcontinue\n    97â†’\t\t\t}\n    98â†’\t\t}\n    99â†’\t}\n   100â†’\n   101â†’\t// Stage 5: Audit\n   102â†’\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n   103â†’\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n   104â†’\to.audit.Log(result)\n   105â†’\n   106â†’\t// Save to store if available\n   107â†’\tif evoStore != nil {\n   108â†’\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n   109â†’\t\t\tID:             result.ID,\n   110â†’\t\t\tProjectDir:     result.ProjectDir,\n   111â†’\t\t\tWorkflowName:   result.WorkflowName,\n   112â†’\t\t\tTriggerRunID:   result.TriggerRunID,\n   113â†’\t\t\tCreatedAt:      time.Now(),\n   114â†’\t\t\tClassification: result.Classification,\n   115â†’\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n   116â†’\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n   117â†’\t\t})\n   118â†’\t}\n   119â†’\n   120â†’\treturn result, nil\n   121â†’}\n   122â†’\n   123â†’// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\n   124â†’func (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n   125â†’\t// Generate the script or prompt file\n   126â†’\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n   127â†’\tif err != nil {\n   128â†’\t\treturn err\n   129â†’\t}\n   130â†’\n   131â†’\tresult.Changes = append(result.Changes, Change{\n   132â†’\t\tType:   \"add_script\",\n   133â†’\t\tFile:   generated.Path,\n   134â†’\t\tReason: lesson.Insight,\n   135â†’\t})\n   136â†’\n   137â†’\t// Add step and wiring to the workflow file\n   138â†’\tif data.WorkflowPath == \"\" {\n   139â†’\t\treturn nil\n   140â†’\t}\n   141â†’\n   142â†’\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n   143â†’\tif err != nil {\n   144â†’\t\treturn err\n   145â†’\t}\n   146â†’\n   147â†’\t// Snapshot the workflow\n   148â†’\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n   149â†’\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n   150â†’\n   151â†’\t// Derive step name from the script path\n   152â†’\tstepName := filepath.Base(generated.Path)\n   153â†’\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n   154â†’\n   155â†’\t// Determine the config based on step type\n   156â†’\tconfig := map[string]string{}\n   157â†’\tswitch lesson.StepType {\n   158â†’\tcase \"agent\":\n   159â†’\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n   160â†’\tdefault: // script\n   161â†’\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n   162â†’\t}\n   163â†’\n   164â†’\t// Add the step\n   165â†’\tupdated, err := o.mutator.AddStep(string(workflowContent), dsl.StepDef{\n   166â†’\t\tName:    stepName,\n   167â†’\t\tType:    lesson.StepType,\n   168â†’\t\tConfig:  config,\n   169â†’\t\tResults: []string{\"success\", \"fail\"},\n   170â†’\t})\n   171â†’\tif err != nil {\n   172â†’\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n   173â†’\t}\n   174â†’\n   175â†’\t// Add wiring: wire the new step's fail to the fix step (if it exists),\n   176â†’\t// and success to done\n   177â†’\twires := []dsl.WireDef{\n   178â†’\t\t{From: stepName, Result: \"success\", To: \"done\"},\n   179â†’\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n   180â†’\t}\n   181â†’\tupdated, err = o.mutator.AddWiring(updated, wires)\n   182â†’\tif err != nil {\n   183â†’\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n   184â†’\t}\n   185â†’\n   186â†’\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n   187â†’\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n   188â†’\t}\n   189â†’\n   190â†’\tresult.Changes = append(result.Changes, Change{\n   191â†’\t\tType:     \"add_step\",\n   192â†’\t\tFile:     wfRelPath,\n   193â†’\t\tReason:   lesson.Insight,\n   194â†’\t\tSnapshot: snapName,\n   195â†’\t})\n   196â†’\n   197â†’\treturn nil\n   198â†’}\n   199â†’"}]},"parent_tool_use_id":"toolu_01CAtE5GDCv6Zhuwpqbgd4Wa","session_id":"1b1aa5cb-df87-4bfd-9ba5-30431aa95a7e","uuid":"181333d4-98fe-41b3-bfa7-78399c264858"}
