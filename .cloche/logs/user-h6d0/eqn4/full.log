[2026-03-07T16:59:02Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FGwijxb2LKVz7xWDkWzgA8","type":"tool_result","content":"     1â†’package orchestrator\n     2â†’\n     3â†’import (\n     4â†’\t\"context\"\n     5â†’\t\"fmt\"\n     6â†’\t\"log\"\n     7â†’\t\"os\"\n     8â†’\t\"path/filepath\"\n     9â†’\t\"sync\"\n    10â†’\n    11â†’\t\"github.com/cloche-dev/cloche/internal/config\"\n    12â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13â†’\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14â†’)\n    15â†’\n    16â†’// RunDispatcher dispatches a workflow run and returns the run ID.\n    17â†’type RunDispatcher func(ctx context.Context, workflowName, projectDir, prompt string) (string, error)\n    18â†’\n    19â†’// ProjectConfig holds orchestration settings for a single project.\n    20â†’type ProjectConfig struct {\n    21â†’\tDir         string\n    22â†’\tWorkflow    string\n    23â†’\tConcurrency int\n    24â†’\tTracker     ports.TaskTracker\n    25â†’\tEnabled     bool\n    26â†’}\n    27â†’\n    28â†’// ParseHostWorkflowFunc parses a host.cloche file and returns the named workflow.\n    29â†’type ParseHostWorkflowFunc func(input string) (*domain.Workflow, error)\n    30â†’\n    31â†’// Orchestrator pulls ready tasks and dispatches workflow runs, respecting\n    32â†’// per-project concurrency limits.\n    33â†’type Orchestrator struct {\n    34â†’\tpromptGen          PromptGenerator\n    35â†’\tdispatch           RunDispatcher\n    36â†’\tmu                 sync.Mutex\n    37â†’\tprojects           map[string]*ProjectConfig // keyed by Dir\n    38â†’\tinFlight           map[string]int            // keyed by Dir\n    39â†’\tinFlightTasks      map[string]string         // runID -> taskID\n    40â†’\tinFlightTaskSet    map[string]map[string]bool // projectDir -> set of taskIDs in flight\n    41â†’\thostRunner         *HostRunner\n    42â†’\tparseHostWorkflow  ParseHostWorkflowFunc\n    43â†’}\n    44â†’\n    45â†’// New creates an Orchestrator.\n    46â†’func New(promptGen PromptGenerator, dispatch RunDispatcher, opts ...OrchestratorOption) *Orchestrator {\n    47â†’\to := &Orchestrator{\n    48â†’\t\tpromptGen:       promptGen,\n    49â†’\t\tdispatch:        dispatch,\n    50â†’\t\tprojects:        make(map[string]*ProjectConfig),\n    51â†’\t\tinFlight:        make(map[string]int),\n    52â†’\t\tinFlightTasks:   make(map[string]string),\n    53â†’\t\tinFlightTaskSet: make(map[string]map[string]bool),\n    54â†’\t}\n    55â†’\tfor _, opt := range opts {\n    56â†’\t\topt(o)\n    57â†’\t}\n    58â†’\treturn o\n    59â†’}\n    60â†’\n    61â†’// OrchestratorOption configures optional fields on the Orchestrator.\n    62â†’type OrchestratorOption func(*Orchestrator)\n    63â†’\n    64â†’// WithHostRunner sets the HostRunner for host.cloche support.\n    65â†’func WithHostRunner(hr *HostRunner) OrchestratorOption {\n    66â†’\treturn func(o *Orchestrator) {\n    67â†’\t\to.hostRunner = hr\n    68â†’\t}\n    69â†’}\n    70â†’\n    71â†’// WithParseHostWorkflow sets the parser function for host.cloche files.\n    72â†’func WithParseHostWorkflow(fn ParseHostWorkflowFunc) OrchestratorOption {\n    73â†’\treturn func(o *Orchestrator) {\n    74â†’\t\to.parseHostWorkflow = fn\n    75â†’\t}\n    76â†’}\n    77â†’\n    78â†’// Register adds a project to the orchestrator.\n    79â†’func (o *Orchestrator) Register(pc *ProjectConfig) {\n    80â†’\to.mu.Lock()\n    81â†’\tdefer o.mu.Unlock()\n    82â†’\tpc.Enabled = true\n    83â†’\to.projects[pc.Dir] = pc\n    84â†’}\n    85â†’\n    86â†’// Status returns the enabled flag, in-flight count, and concurrency for a project.\n    87â†’func (o *Orchestrator) Status(dir string) (enabled bool, inFlight int, concurrency int) {\n    88â†’\to.mu.Lock()\n    89â†’\tdefer o.mu.Unlock()\n    90â†’\tpc, ok := o.projects[dir]\n    91â†’\tif !ok {\n    92â†’\t\treturn false, 0, 0\n    93â†’\t}\n    94â†’\treturn pc.Enabled, o.inFlight[dir], pc.Concurrency\n    95â†’}\n    96â†’\n    97â†’// SetEnabled enables or disables orchestration for a project.\n    98â†’func (o *Orchestrator) SetEnabled(dir string, enabled bool) {\n    99â†’\to.mu.Lock()\n   100â†’\tdefer o.mu.Unlock()\n   101â†’\tif pc, ok := o.projects[dir]; ok {\n   102â†’\t\tpc.Enabled = enabled\n   103â†’\t}\n   104â†’}\n   105â†’\n   106â†’// SetConcurrency overrides the concurrency limit for a project (runtime only).\n   107â†’func (o *Orchestrator) SetConcurrency(dir string, concurrency int) {\n   108â†’\to.mu.Lock()\n   109â†’\tdefer o.mu.Unlock()\n   110â†’\tif pc, ok := o.projects[dir]; ok {\n   111â†’\t\tpc.Concurrency = concurrency\n   112â†’\t}\n   113â†’}\n   114â†’\n   115â†’// RegisterFromConfig registers a project using its config file.\n   116â†’// Returns false if orchestration is not enabled for the project.\n   117â†’func (o *Orchestrator) RegisterFromConfig(projectDir string, tracker ports.TaskTracker) bool {\n   118â†’\tcfg, err := config.Load(projectDir)\n   119â†’\tif err != nil || !cfg.Orchestration.Enabled {\n   120â†’\t\treturn false\n   121â†’\t}\n   122â†’\tworkflow := cfg.Orchestration.Workflow\n   123â†’\tif workflow == \"\" {\n   124â†’\t\tworkflow = \"develop\"\n   125â†’\t}\n   126â†’\tconcurrency := cfg.Orchestration.Concurrency\n   127â†’\tif concurrency < 1 {\n   128â†’\t\tconcurrency = 1\n   129â†’\t}\n   130â†’\to.Register(&ProjectConfig{\n   131â†’\t\tDir:         projectDir,\n   132â†’\t\tWorkflow:    workflow,\n   133â†’\t\tConcurrency: concurrency,\n   134â†’\t\tTracker:     tracker,\n   135â†’\t\tEnabled:     true,\n   136â†’\t})\n   137â†’\treturn true\n   138â†’}\n   139â†’\n   140â†’// trackTask records a run-to-task mapping for later completion/failure.\n   141â†’func (o *Orchestrator) trackTask(projectDir, runID, taskID string) {\n   142â†’\to.inFlightTasks[runID] = taskID\n   143â†’\tif o.inFlightTaskSet[projectDir] == nil {\n   144â†’\t\to.inFlightTaskSet[projectDir] = make(map[string]bool)\n   145â†’\t}\n   146â†’\to.inFlightTaskSet[projectDir][taskID] = true\n   147â†’}\n   148â†’\n   149â†’// untrackTask removes a run-to-task mapping. Returns the task ID.\n   150â†’func (o *Orchestrator) untrackTask(projectDir, runID string) string {\n   151â†’\ttaskID := o.inFlightTasks[runID]\n   152â†’\tdelete(o.inFlightTasks, runID)\n   153â†’\tif taskID != \"\" && o.inFlightTaskSet[projectDir] != nil {\n   154â†’\t\tdelete(o.inFlightTaskSet[projectDir], taskID)\n   155â†’\t}\n   156â†’\treturn taskID\n   157â†’}\n   158â†’\n   159â†’// isTaskInFlight checks if a task already has an active run.\n   160â†’func (o *Orchestrator) isTaskInFlight(projectDir, taskID string) bool {\n   161â†’\tif set := o.inFlightTaskSet[projectDir]; set != nil {\n   162â†’\t\treturn set[taskID]\n   163â†’\t}\n   164â†’\treturn false\n   165â†’}\n   166â†’\n   167â†’// Run performs one orchestration cycle for a single project. It returns the\n   168â†’// number of runs dispatched.\n   169â†’func (o *Orchestrator) Run(ctx context.Context, projectDir string) (int, error) {\n   170â†’\to.mu.Lock()\n   171â†’\tpc, ok := o.projects[projectDir]\n   172â†’\tif !ok {\n   173â†’\t\to.mu.Unlock()\n   174â†’\t\treturn 0, fmt.Errorf(\"project %q not registered\", projectDir)\n   175â†’\t}\n   176â†’\tif !pc.Enabled {\n   177â†’\t\to.mu.Unlock()\n   178â†’\t\treturn 0, nil\n   179â†’\t}\n   180â†’\tcurrent := o.inFlight[projectDir]\n   181â†’\tavailable := pc.Concurrency - current\n   182â†’\to.mu.Unlock()\n   183â†’\n   184â†’\tif available <= 0 {\n   185â†’\t\treturn 0, nil\n   186â†’\t}\n   187â†’\n   188â†’\ttasks, err := pc.Tracker.ListReady(ctx, projectDir)\n   189â†’\tif err != nil {\n   190â†’\t\treturn 0, fmt.Errorf(\"listing ready tasks: %w\", err)\n   191â†’\t}\n   192â†’\n   193â†’\t// Check if host.cloche exists for this project\n   194â†’\thostWorkflowPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   195â†’\tuseHostWorkflow := o.hostRunner != nil && o.parseHostWorkflow != nil\n   196â†’\tif useHostWorkflow {\n   197â†’\t\tif _, err := os.Stat(hostWorkflowPath); os.IsNotExist(err) {\n   198â†’\t\t\tuseHostWorkflow = false\n   199â†’\t\t}\n   200â†’\t}\n   201â†’\n   202â†’\tdispatched := 0\n   203â†’\tfor i := 0; i < len(tasks) && dispatched < available; i++ {\n   204â†’\t\ttask := tasks[i]\n   205â†’\n   206â†’\t\t// Skip tasks that already have an in-flight run (dedup)\n   207â†’\t\to.mu.Lock()\n   208â†’\t\talreadyRunning := o.isTaskInFlight(projectDir, task.ID)\n   209â†’\t\to.mu.Unlock()\n   210â†’\t\tif alreadyRunning {\n   211â†’\t\t\tlog.Printf(\"orchestrator: skipping task %s (already in flight)\", task.ID)\n   212â†’\t\t\tcontinue\n   213â†’\t\t}\n   214â†’\n   215â†’\t\tif err := pc.Tracker.Claim(ctx, task.ID); err != nil {\n   216â†’\t\t\tlog.Printf(\"orchestrator: failed to claim task %s: %v\", task.ID, err)\n   217â†’\t\t\tcontinue\n   218â†’\t\t}\n   219â†’\n   220â†’\t\tif useHostWorkflow {\n   221â†’\t\t\t// Host workflow path\n   222â†’\t\t\tdata, err := os.ReadFile(hostWorkflowPath)\n   223â†’\t\t\tif err != nil {\n   224â†’\t\t\t\tlog.Printf(\"orchestrator: failed to read host.cloche for task %s: %v\", task.ID, err)\n   225â†’\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   226â†’\t\t\t\tcontinue\n   227â†’\t\t\t}\n   228â†’\n   229â†’\t\t\twf, err := o.parseHostWorkflow(string(data))\n   230â†’\t\t\tif err != nil {\n   231â†’\t\t\t\tlog.Printf(\"orchestrator: failed to parse host.cloche for task %s: %v\", task.ID, err)\n   232â†’\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   233â†’\t\t\t\tcontinue\n   234â†’\t\t\t}\n   235â†’\n   236â†’\t\t\torchRunID := domain.GenerateRunID(\"orchestrate\")\n   237â†’\n   238â†’\t\t\to.mu.Lock()\n   239â†’\t\t\to.inFlight[projectDir]++\n   240â†’\t\t\to.trackTask(projectDir, orchRunID, task.ID)\n   241â†’\t\t\to.mu.Unlock()\n   242â†’\n   243â†’\t\t\thr := &HostRunner{\n   244â†’\t\t\t\tDispatch:   o.hostRunner.Dispatch,\n   245â†’\t\t\t\tWaitRun:    o.hostRunner.WaitRun,\n   246â†’\t\t\t\tProjectDir: projectDir,\n   247â†’\t\t\t}\n   248â†’\n   249â†’\t\t\tgo func(task ports.TrackerTask, runID string) {\n   250â†’\t\t\t\tresult, err := hr.RunWorkflow(ctx, wf, task, runID)\n   251â†’\n   252â†’\t\t\t\to.mu.Lock()\n   253â†’\t\t\t\to.untrackTask(projectDir, runID)\n   254â†’\t\t\t\tif o.inFlight[projectDir] > 0 {\n   255â†’\t\t\t\t\to.inFlight[projectDir]--\n   256â†’\t\t\t\t}\n   257â†’\t\t\t\to.mu.Unlock()\n   258â†’\n   259â†’\t\t\t\tif err != nil {\n   260â†’\t\t\t\t\tlog.Printf(\"orchestrator: host workflow error for task %s: %v\", task.ID, err)\n   261â†’\t\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   262â†’\t\t\t\t} else if result == domain.StepDone {\n   263â†’\t\t\t\t\tlog.Printf(\"orchestrator: task %s completed successfully\", task.ID)\n   264â†’\t\t\t\t\t_ = pc.Tracker.Complete(ctx, task.ID)\n   265â†’\t\t\t\t} else {\n   266â†’\t\t\t\t\tlog.Printf(\"orchestrator: task %s aborted\", task.ID)\n   267â†’\t\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   268â†’\t\t\t\t}\n   269â†’\t\t\t}(task, orchRunID)\n   270â†’\n   271â†’\t\t\tlog.Printf(\"orchestrator: started host workflow %s for task %s in %s\", orchRunID, task.ID, projectDir)\n   272â†’\t\t\tdispatched++\n   273â†’\t\t} else {\n   274â†’\t\t\t// Fallback: existing promptGen â†’ dispatch path\n   275â†’\t\t\tprompt, err := o.promptGen.Generate(ctx, task, projectDir)\n   276â†’\t\t\tif err != nil {\n   277â†’\t\t\t\tlog.Printf(\"orchestrator: failed to generate prompt for task %s: %v\", task.ID, err)\n   278â†’\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   279â†’\t\t\t\tcontinue\n   280â†’\t\t\t}\n   281â†’\n   282â†’\t\t\trunID, err := o.dispatch(ctx, pc.Workflow, projectDir, prompt)\n   283â†’\t\t\tif err != nil {\n   284â†’\t\t\t\tlog.Printf(\"orchestrator: failed to dispatch run for task %s: %v\", task.ID, err)\n   285â†’\t\t\t\t_ = pc.Tracker.Fail(ctx, task.ID)\n   286â†’\t\t\t\tcontinue\n   287â†’\t\t\t}\n   288â†’\n   289â†’\t\t\to.mu.Lock()\n   290â†’\t\t\to.inFlight[projectDir]++\n   291â†’\t\t\to.trackTask(projectDir, runID, task.ID)\n   292â†’\t\t\to.mu.Unlock()\n   293â†’\n   294â†’\t\t\tlog.Printf(\"orchestrator: dispatched run %s for task %s in %s\", runID, task.ID, projectDir)\n   295â†’\t\t\tdispatched++\n   296â†’\t\t}\n   297â†’\t}\n   298â†’\n   299â†’\treturn dispatched, nil\n   300â†’}\n   301â†’\n   302â†’// TriggerAll runs orchestration for all registered projects. Returns total\n   303â†’// dispatched count.\n   304â†’func (o *Orchestrator) TriggerAll(ctx context.Context) int {\n   305â†’\to.mu.Lock()\n   306â†’\tdirs := make([]string, 0, len(o.projects))\n   307â†’\tfor dir := range o.projects {\n   308â†’\t\tdirs = append(dirs, dir)\n   309â†’\t}\n   310â†’\to.mu.Unlock()\n   311â†’\n   312â†’\ttotal := 0\n   313â†’\tfor _, dir := range dirs {\n   314â†’\t\tn, err := o.Run(ctx, dir)\n   315â†’\t\tif err != nil {\n   316â†’\t\t\tlog.Printf(\"orchestrator: error for project %s: %v\", dir, err)\n   317â†’\t\t\tcontinue\n   318â†’\t\t}\n   319â†’\t\ttotal += n\n   320â†’\t}\n   321â†’\treturn total\n   322â†’}\n   323â†’\n   324â†’// OnRunComplete should be called when a workflow run finishes. It looks up the\n   325â†’// associated task, completes or fails it in the tracker, decrements the\n   326â†’// in-flight counter, and triggers a new orchestration cycle.\n   327â†’func (o *Orchestrator) OnRunComplete(ctx context.Context, projectDir string, runID string, state domain.RunState) {\n   328â†’\to.mu.Lock()\n   329â†’\tpc := o.projects[projectDir]\n   330â†’\ttaskID := o.untrackTask(projectDir, runID)\n   331â†’\tif o.inFlight[projectDir] > 0 {\n   332â†’\t\to.inFlight[projectDir]--\n   333â†’\t}\n   334â†’\to.mu.Unlock()\n   335â†’\n   336â†’\t// Close/fail the associated task in the tracker\n   337â†’\tif taskID != \"\" && pc != nil {\n   338â†’\t\tif state == domain.RunStateSucceeded {\n   339â†’\t\t\tlog.Printf(\"orchestrator: completing task %s (run %s succeeded)\", taskID, runID)\n   340â†’\t\t\t_ = pc.Tracker.Complete(ctx, taskID)\n   341â†’\t\t} else {\n   342â†’\t\t\tlog.Printf(\"orchestrator: failing task %s (run %s state: %s)\", taskID, runID, state)\n   343â†’\t\t\t_ = pc.Tracker.Fail(ctx, taskID)\n   344â†’\t\t}\n   345â†’\t}\n   346â†’\n   347â†’\tif _, err := o.Run(ctx, projectDir); err != nil {\n   348â†’\t\tlog.Printf(\"orchestrator: post-completion trigger failed for %s: %v\", projectDir, err)\n   349â†’\t}\n   350â†’}\n   351â†’\n   352â†’// InFlight returns the current in-flight run count for a project.\n   353â†’func (o *Orchestrator) InFlight(projectDir string) int {\n   354â†’\to.mu.Lock()\n   355â†’\tdefer o.mu.Unlock()\n   356â†’\treturn o.inFlight[projectDir]\n   357â†’}\n   358â†’"}]},"parent_tool_use_id":"toolu_01CAtE5GDCv6Zhuwpqbgd4Wa","session_id":"1b1aa5cb-df87-4bfd-9ba5-30431aa95a7e","uuid":"f7d9c418-8e54-41d6-9961-e8a58825c3a9"}
