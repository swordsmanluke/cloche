[2026-03-07T17:01:08Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011Z1F21f89AsMedgxUEChgD","type":"tool_result","content":"     1â†’package web\n     2â†’\n     3â†’import (\n     4â†’\t\"bufio\"\n     5â†’\t\"context\"\n     6â†’\t\"embed\"\n     7â†’\t\"encoding/json\"\n     8â†’\t\"fmt\"\n     9â†’\t\"html/template\"\n    10â†’\t\"io/fs\"\n    11â†’\t\"net/http\"\n    12â†’\t\"os\"\n    13â†’\t\"os/exec\"\n    14â†’\t\"path/filepath\"\n    15â†’\t\"regexp\"\n    16â†’\t\"sort\"\n    17â†’\t\"strings\"\n    18â†’\t\"time\"\n    19â†’\n    20â†’\t\"github.com/cloche-dev/cloche/internal/config\"\n    21â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22â†’\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23â†’\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24â†’\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25â†’)\n    26â†’\n    27â†’// HandlerOption configures optional Handler dependencies.\n    28â†’type HandlerOption func(*Handler)\n    29â†’\n    30â†’// WithContainerLogger sets the container runtime for fetching live logs.\n    31â†’func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32â†’\treturn func(h *Handler) { h.container = c }\n    33â†’}\n    34â†’\n    35â†’// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36â†’func WithContainerManager(c ContainerManager) HandlerOption {\n    37â†’\treturn func(h *Handler) { h.container = c }\n    38â†’}\n    39â†’\n    40â†’// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41â†’func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42â†’\treturn func(h *Handler) { h.logBroadcast = b }\n    43â†’}\n    44â†’\n    45â†’// WithLogStore sets the log store for indexed log file lookups.\n    46â†’func WithLogStore(ls ports.LogStore) HandlerOption {\n    47â†’\treturn func(h *Handler) { h.logStore = ls }\n    48â†’}\n    49â†’\n    50â†’// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    51â†’func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    52â†’\treturn func(h *Handler) { h.orchestrateFn = fn }\n    53â†’}\n    54â†’\n    55â†’// OrchestratorController provides per-project orchestrator control.\n    56â†’type OrchestratorController interface {\n    57â†’\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    58â†’\tSetEnabled(dir string, enabled bool)\n    59â†’\tSetConcurrency(dir string, concurrency int)\n    60â†’}\n    61â†’\n    62â†’// WithOrchestrator sets the orchestrator controller for project-level control.\n    63â†’func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    64â†’\treturn func(h *Handler) { h.orchestrator = oc }\n    65â†’}\n    66â†’\n    67â†’//go:embed templates/*.html static/*\n    68â†’var content embed.FS\n    69â†’\n    70â†’// Handler serves the web dashboard.\n    71â†’// ContainerLogger can retrieve logs from a container by ID.\n    72â†’type ContainerLogger interface {\n    73â†’\tLogs(ctx context.Context, containerID string) (string, error)\n    74â†’}\n    75â†’\n    76â†’// ContainerManager extends ContainerLogger with container lifecycle operations.\n    77â†’type ContainerManager interface {\n    78â†’\tContainerLogger\n    79â†’\tRemove(ctx context.Context, containerID string) error\n    80â†’\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    81â†’}\n    82â†’\n    83â†’type Handler struct {\n    84â†’\tstore         ports.RunStore\n    85â†’\tcaptures      ports.CaptureStore\n    86â†’\tlogStore      ports.LogStore\n    87â†’\tcontainer     ContainerLogger\n    88â†’\tlogBroadcast  *logstream.Broadcaster\n    89â†’\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    90â†’\torchestrator  OrchestratorController\n    91â†’\tpages         map[string]*template.Template\n    92â†’\tmux           *http.ServeMux\n    93â†’}\n    94â†’\n    95â†’// NewHandler creates a web dashboard handler.\n    96â†’func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    97â†’\tfuncMap := template.FuncMap{\n    98â†’\t\t\"stateColor\":       stateColor,\n    99â†’\t\t\"healthColor\":      healthColor,\n   100â†’\t\t\"formatTime\":       formatTime,\n   101â†’\t\t\"formatDuration\":   formatDuration,\n   102â†’\t\t\"truncate\":         truncate,\n   103â†’\t\t\"shortContainerID\": shortContainerID,\n   104â†’\t}\n   105â†’\n   106â†’\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   107â†’\tif err != nil {\n   108â†’\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   109â†’\t}\n   110â†’\n   111â†’\tpages := map[string]*template.Template{}\n   112â†’\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   113â†’\t\tclone, err := base.Clone()\n   114â†’\t\tif err != nil {\n   115â†’\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   116â†’\t\t}\n   117â†’\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   118â†’\t\tif err != nil {\n   119â†’\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   120â†’\t\t}\n   121â†’\t\tpages[page] = clone\n   122â†’\t}\n   123â†’\n   124â†’\th := &Handler{\n   125â†’\t\tstore:    store,\n   126â†’\t\tcaptures: captures,\n   127â†’\t\tpages:    pages,\n   128â†’\t\tmux:      http.NewServeMux(),\n   129â†’\t}\n   130â†’\tfor _, opt := range opts {\n   131â†’\t\topt(h)\n   132â†’\t}\n   133â†’\n   134â†’\tstaticFS, err := fs.Sub(content, \"static\")\n   135â†’\tif err != nil {\n   136â†’\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   137â†’\t}\n   138â†’\n   139â†’\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   140â†’\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   141â†’\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   142â†’\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   143â†’\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   144â†’\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   145â†’\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   146â†’\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   147â†’\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   148â†’\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   149â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   150â†’\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   151â†’\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   152â†’\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   153â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   154â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   155â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   156â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   157â†’\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   158â†’\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   159â†’\n   160â†’\treturn h, nil\n   161â†’}\n   162â†’\n   163â†’func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   164â†’\th.mux.ServeHTTP(w, r)\n   165â†’}\n   166â†’\n   167â†’// --- HTML handlers ---\n   168â†’\n   169â†’// projectOverviewEntry holds data for a single project card on the landing page.\n   170â†’type projectOverviewEntry struct {\n   171â†’\tDir         string\n   172â†’\tLabel       string\n   173â†’\tHealth      domain.HealthResult\n   174â†’\tRecentRuns  []recentRunDot\n   175â†’\tActiveCount int\n   176â†’}\n   177â†’\n   178â†’// recentRunDot is a minimal representation of a run for the mini history display.\n   179â†’type recentRunDot struct {\n   180â†’\tID    string\n   181â†’\tState string\n   182â†’}\n   183â†’\n   184â†’const healthWindowSize = 10\n   185â†’\n   186â†’func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   187â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   188â†’\tlabels := projectLabels(projects)\n   189â†’\n   190â†’\tvar entries []projectOverviewEntry\n   191â†’\tfor _, dir := range projects {\n   192â†’\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   193â†’\t\tif err != nil {\n   194â†’\t\t\tcontinue\n   195â†’\t\t}\n   196â†’\n   197â†’\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   198â†’\t\trunValues := make([]domain.Run, len(runs))\n   199â†’\t\tfor i, rr := range runs {\n   200â†’\t\t\trunValues[i] = *rr\n   201â†’\t\t}\n   202â†’\n   203â†’\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   204â†’\n   205â†’\t\t// Take the last N runs for the mini history (most recent first).\n   206â†’\t\tn := healthWindowSize\n   207â†’\t\tif n > len(runs) {\n   208â†’\t\t\tn = len(runs)\n   209â†’\t\t}\n   210â†’\t\tdots := make([]recentRunDot, n)\n   211â†’\t\tfor i := 0; i < n; i++ {\n   212â†’\t\t\tdots[i] = recentRunDot{\n   213â†’\t\t\t\tID:    runs[i].ID,\n   214â†’\t\t\t\tState: string(runs[i].State),\n   215â†’\t\t\t}\n   216â†’\t\t}\n   217â†’\n   218â†’\t\tvar activeCount int\n   219â†’\t\tfor _, rr := range runs {\n   220â†’\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   221â†’\t\t\t\tactiveCount++\n   222â†’\t\t\t}\n   223â†’\t\t}\n   224â†’\n   225â†’\t\tentries = append(entries, projectOverviewEntry{\n   226â†’\t\t\tDir:         dir,\n   227â†’\t\t\tLabel:       labels[dir],\n   228â†’\t\t\tHealth:      health,\n   229â†’\t\t\tRecentRuns:  dots,\n   230â†’\t\t\tActiveCount: activeCount,\n   231â†’\t\t})\n   232â†’\t}\n   233â†’\n   234â†’\tsort.Slice(entries, func(i, j int) bool {\n   235â†’\t\treturn entries[i].Label < entries[j].Label\n   236â†’\t})\n   237â†’\n   238â†’\tdata := map[string]any{\n   239â†’\t\t\"Title\":    \"Projects\",\n   240â†’\t\t\"Projects\": entries,\n   241â†’\t}\n   242â†’\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   243â†’\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   244â†’\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   245â†’\t}\n   246â†’}\n   247â†’\n   248â†’func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   249â†’\tprojectFilter := r.URL.Query().Get(\"project\")\n   250â†’\n   251â†’\tvar runs []*domain.Run\n   252â†’\tvar err error\n   253â†’\tif projectFilter != \"\" {\n   254â†’\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   255â†’\t} else {\n   256â†’\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   257â†’\t}\n   258â†’\tif err != nil {\n   259â†’\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   260â†’\t\treturn\n   261â†’\t}\n   262â†’\n   263â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   264â†’\tlabels := projectLabels(projects)\n   265â†’\n   266â†’\t// Count retained containers per project\n   267â†’\tcontainerCounts := map[string]int{}\n   268â†’\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   269â†’\tfor _, run := range allRuns {\n   270â†’\t\tif run.ContainerKept {\n   271â†’\t\t\tcontainerCounts[run.ProjectDir]++\n   272â†’\t\t}\n   273â†’\t}\n   274â†’\n   275â†’\tvar projectList []projectEntry\n   276â†’\tfor _, dir := range projects {\n   277â†’\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   278â†’\t}\n   279â†’\tsort.Slice(projectList, func(i, j int) bool {\n   280â†’\t\treturn projectList[i].Label < projectList[j].Label\n   281â†’\t})\n   282â†’\n   283â†’\tdata := map[string]any{\n   284â†’\t\t\"Title\":         \"Runs\",\n   285â†’\t\t\"Runs\":          runs,\n   286â†’\t\t\"Projects\":      projectList,\n   287â†’\t\t\"ProjectFilter\": projectFilter,\n   288â†’\t\t\"ProjectLabels\": labels,\n   289â†’\t}\n   290â†’\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   291â†’\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   292â†’\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   293â†’\t}\n   294â†’}\n   295â†’\n   296â†’// stepEntry is a merged view of a step execution for the template.\n   297â†’type stepEntry struct {\n   298â†’\tIndex     int\n   299â†’\tStepName  string\n   300â†’\tResult    string\n   301â†’\tStartedAt time.Time\n   302â†’\tDuration  string\n   303â†’}\n   304â†’\n   305â†’// mergeCaptures collapses started/completed capture pairs into single entries.\n   306â†’func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   307â†’\tvar entries []stepEntry\n   308â†’\t// Track pending started rows by step name (LIFO for retries)\n   309â†’\tpending := map[string]*domain.StepExecution{}\n   310â†’\n   311â†’\tfor _, c := range caps {\n   312â†’\t\tif c.Result == \"\" {\n   313â†’\t\t\t// step_started row\n   314â†’\t\t\tpending[c.StepName] = c\n   315â†’\t\t\tcontinue\n   316â†’\t\t}\n   317â†’\t\t// step_completed row â€” merge with pending started if available\n   318â†’\t\tstartedAt := c.StartedAt\n   319â†’\t\tif started := pending[c.StepName]; started != nil {\n   320â†’\t\t\tstartedAt = started.StartedAt\n   321â†’\t\t\tdelete(pending, c.StepName)\n   322â†’\t\t}\n   323â†’\t\tentries = append(entries, stepEntry{\n   324â†’\t\t\tIndex:     len(entries),\n   325â†’\t\t\tStepName:  c.StepName,\n   326â†’\t\t\tResult:    c.Result,\n   327â†’\t\t\tStartedAt: startedAt,\n   328â†’\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   329â†’\t\t})\n   330â†’\t}\n   331â†’\n   332â†’\t// Append any started-but-not-completed steps (still running)\n   333â†’\tfor _, c := range caps {\n   334â†’\t\tif c.Result == \"\" {\n   335â†’\t\t\tif _, used := pending[c.StepName]; !used {\n   336â†’\t\t\t\tcontinue\n   337â†’\t\t\t}\n   338â†’\t\t\tentries = append(entries, stepEntry{\n   339â†’\t\t\t\tIndex:     len(entries),\n   340â†’\t\t\t\tStepName:  c.StepName,\n   341â†’\t\t\t\tStartedAt: c.StartedAt,\n   342â†’\t\t\t})\n   343â†’\t\t\tdelete(pending, c.StepName)\n   344â†’\t\t}\n   345â†’\t}\n   346â†’\n   347â†’\treturn entries\n   348â†’}\n   349â†’\n   350â†’// containerState inspects the container for a run and returns one of:\n   351â†’//   - \"running\"   â€“ container exists and is running\n   352â†’//   - \"stopped\"   â€“ container exists, not running, not kept\n   353â†’//   - \"available\" â€“ container exists, not running, kept (can be deleted)\n   354â†’//   - \"removed\"   â€“ no container ID, no manager, or inspect failed\n   355â†’func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   356â†’\tif run.ContainerID == \"\" {\n   357â†’\t\treturn \"removed\"\n   358â†’\t}\n   359â†’\tmgr, ok := h.container.(ContainerManager)\n   360â†’\tif !ok {\n   361â†’\t\treturn \"removed\"\n   362â†’\t}\n   363â†’\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   364â†’\tif err != nil {\n   365â†’\t\treturn \"removed\"\n   366â†’\t}\n   367â†’\tif status.Running {\n   368â†’\t\treturn \"running\"\n   369â†’\t}\n   370â†’\tif run.ContainerKept {\n   371â†’\t\treturn \"available\"\n   372â†’\t}\n   373â†’\treturn \"stopped\"\n   374â†’}\n   375â†’\n   376â†’func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   377â†’\tid := r.PathValue(\"id\")\n   378â†’\n   379â†’\trun, err := h.store.GetRun(r.Context(), id)\n   380â†’\tif err != nil {\n   381â†’\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   382â†’\t\treturn\n   383â†’\t}\n   384â†’\n   385â†’\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   386â†’\tif err != nil {\n   387â†’\t\tcaps = nil // non-fatal\n   388â†’\t}\n   389â†’\n   390â†’\tsteps := mergeCaptures(caps)\n   391â†’\n   392â†’\tdata := map[string]any{\n   393â†’\t\t\"Title\":          \"Run \" + run.ID,\n   394â†’\t\t\"Run\":            run,\n   395â†’\t\t\"Steps\":          steps,\n   396â†’\t\t\"Page\":           \"detail\",\n   397â†’\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   398â†’\t}\n   399â†’\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   400â†’\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   401â†’\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   402â†’\t}\n   403â†’}\n   404â†’\n   405â†’// --- JSON API handlers ---\n   406â†’\n   407â†’type apiRun struct {\n   408â†’\tID           string `json:\"id\"`\n   409â†’\tWorkflowName string `json:\"workflow_name\"`\n   410â†’\tProjectDir   string `json:\"project_dir\"`\n   411â†’\tProjectLabel string `json:\"project_label\"`\n   412â†’\tState        string `json:\"state\"`\n   413â†’\tStartedAt    string `json:\"started_at\"`\n   414â†’\tCompletedAt  string `json:\"completed_at\"`\n   415â†’\tContainerID  string `json:\"container_id\"`\n   416â†’\tErrorMessage string `json:\"error_message\"`\n   417â†’}\n   418â†’\n   419â†’type apiStep struct {\n   420â†’\tStepName    string `json:\"step_name\"`\n   421â†’\tResult      string `json:\"result\"`\n   422â†’\tStartedAt   string `json:\"started_at\"`\n   423â†’\tCompletedAt string `json:\"completed_at\"`\n   424â†’\tDuration    string `json:\"duration\"`\n   425â†’}\n   426â†’\n   427â†’type apiRunDetail struct {\n   428â†’\tapiRun\n   429â†’\tContainerState string    `json:\"container_state\"`\n   430â†’\tSteps          []apiStep `json:\"steps\"`\n   431â†’}\n   432â†’\n   433â†’func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   434â†’\treturn apiRun{\n   435â†’\t\tID:           r.ID,\n   436â†’\t\tWorkflowName: r.WorkflowName,\n   437â†’\t\tProjectDir:   r.ProjectDir,\n   438â†’\t\tProjectLabel: labels[r.ProjectDir],\n   439â†’\t\tState:        string(r.State),\n   440â†’\t\tStartedAt:    formatTime(r.StartedAt),\n   441â†’\t\tCompletedAt:  formatTime(r.CompletedAt),\n   442â†’\t\tContainerID:  r.ContainerID,\n   443â†’\t\tErrorMessage: r.ErrorMessage,\n   444â†’\t}\n   445â†’}\n   446â†’\n   447â†’func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   448â†’\tprojectFilter := r.URL.Query().Get(\"project\")\n   449â†’\n   450â†’\tvar runs []*domain.Run\n   451â†’\tvar err error\n   452â†’\tif projectFilter != \"\" {\n   453â†’\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   454â†’\t} else {\n   455â†’\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   456â†’\t}\n   457â†’\tif err != nil {\n   458â†’\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   459â†’\t\treturn\n   460â†’\t}\n   461â†’\n   462â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   463â†’\tlabels := projectLabels(projects)\n   464â†’\n   465â†’\tresult := make([]apiRun, len(runs))\n   466â†’\tfor i, run := range runs {\n   467â†’\t\tresult[i] = toAPIRun(run, labels)\n   468â†’\t}\n   469â†’\n   470â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   471â†’\tjson.NewEncoder(w).Encode(result)\n   472â†’}\n   473â†’\n   474â†’func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   475â†’\tprojects, err := h.store.ListProjects(r.Context())\n   476â†’\tif err != nil {\n   477â†’\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   478â†’\t\treturn\n   479â†’\t}\n   480â†’\tlabels := projectLabels(projects)\n   481â†’\n   482â†’\ttype apiHealth struct {\n   483â†’\t\tStatus string `json:\"status\"`\n   484â†’\t\tPassed int    `json:\"passed\"`\n   485â†’\t\tFailed int    `json:\"failed\"`\n   486â†’\t\tTotal  int    `json:\"total\"`\n   487â†’\t}\n   488â†’\ttype apiProject struct {\n   489â†’\t\tDir         string    `json:\"dir\"`\n   490â†’\t\tLabel       string    `json:\"label\"`\n   491â†’\t\tHealth      apiHealth `json:\"health\"`\n   492â†’\t\tActiveCount int       `json:\"active_count\"`\n   493â†’\t}\n   494â†’\tresult := make([]apiProject, len(projects))\n   495â†’\tfor i, dir := range projects {\n   496â†’\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   497â†’\t\trunValues := make([]domain.Run, len(runs))\n   498â†’\t\tfor j, rr := range runs {\n   499â†’\t\t\trunValues[j] = *rr\n   500â†’\t\t}\n   501â†’\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   502â†’\t\tvar activeCount int\n   503â†’\t\tfor _, rr := range runs {\n   504â†’\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   505â†’\t\t\t\tactiveCount++\n   506â†’\t\t\t}\n   507â†’\t\t}\n   508â†’\t\tresult[i] = apiProject{\n   509â†’\t\t\tDir:   dir,\n   510â†’\t\t\tLabel: labels[dir],\n   511â†’\t\t\tHealth: apiHealth{\n   512â†’\t\t\t\tStatus: string(health.Status),\n   513â†’\t\t\t\tPassed: health.Passed,\n   514â†’\t\t\t\tFailed: health.Failed,\n   515â†’\t\t\t\tTotal:  health.Total,\n   516â†’\t\t\t},\n   517â†’\t\t\tActiveCount: activeCount,\n   518â†’\t\t}\n   519â†’\t}\n   520â†’\n   521â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   522â†’\tjson.NewEncoder(w).Encode(result)\n   523â†’}\n   524â†’\n   525â†’func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   526â†’\tid := r.PathValue(\"id\")\n   527â†’\n   528â†’\trun, err := h.store.GetRun(r.Context(), id)\n   529â†’\tif err != nil {\n   530â†’\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   531â†’\t\treturn\n   532â†’\t}\n   533â†’\n   534â†’\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   535â†’\tif err != nil {\n   536â†’\t\tcaps = nil\n   537â†’\t}\n   538â†’\n   539â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   540â†’\tlabels := projectLabels(projects)\n   541â†’\n   542â†’\tmerged := mergeCaptures(caps)\n   543â†’\tsteps := make([]apiStep, len(merged))\n   544â†’\tfor i, e := range merged {\n   545â†’\t\tsteps[i] = apiStep{\n   546â†’\t\t\tStepName:  e.StepName,\n   547â†’\t\t\tResult:    e.Result,\n   548â†’\t\t\tStartedAt: formatTime(e.StartedAt),\n   549â†’\t\t\tDuration:  e.Duration,\n   550â†’\t\t}\n   551â†’\t}\n   552â†’\n   553â†’\tdetail := apiRunDetail{\n   554â†’\t\tapiRun:         toAPIRun(run, labels),\n   555â†’\t\tContainerState: h.containerState(r.Context(), run),\n   556â†’\t\tSteps:          steps,\n   557â†’\t}\n   558â†’\n   559â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   560â†’\tjson.NewEncoder(w).Encode(detail)\n   561â†’}\n   562â†’\n   563â†’func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   564â†’\tid := r.PathValue(\"id\")\n   565â†’\tstep := r.PathValue(\"step\")\n   566â†’\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   567â†’\n   568â†’\trun, err := h.store.GetRun(r.Context(), id)\n   569â†’\tif err != nil {\n   570â†’\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   571â†’\t\treturn\n   572â†’\t}\n   573â†’\n   574â†’\t// Try log index first for fast lookup\n   575â†’\tif h.logStore != nil {\n   576â†’\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   577â†’\t\tif err == nil && len(logFiles) > 0 {\n   578â†’\t\t\t// If type filter specified, narrow results\n   579â†’\t\t\tfor _, lf := range logFiles {\n   580â†’\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   581â†’\t\t\t\t\tcontinue\n   582â†’\t\t\t\t}\n   583â†’\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   584â†’\t\t\t\tif readErr == nil && len(data) > 0 {\n   585â†’\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   586â†’\t\t\t\t\tw.Write(data)\n   587â†’\t\t\t\t\treturn\n   588â†’\t\t\t\t}\n   589â†’\t\t\t}\n   590â†’\t\t}\n   591â†’\t}\n   592â†’\n   593â†’\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   594â†’\n   595â†’\t// Fall back to file path conventions\n   596â†’\t// If type is \"llm\", try llm-<step>.log\n   597â†’\tif logType == \"llm\" {\n   598â†’\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   599â†’\t\tdata, err := os.ReadFile(llmPath)\n   600â†’\t\tif err == nil && len(data) > 0 {\n   601â†’\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   602â†’\t\t\tw.Write(data)\n   603â†’\t\t\treturn\n   604â†’\t\t}\n   605â†’\t}\n   606â†’\n   607â†’\t// Try per-step output first, fall back to container.log, then live docker logs\n   608â†’\toutputPath := filepath.Join(outputDir, step+\".log\")\n   609â†’\tdata, err := os.ReadFile(outputPath)\n   610â†’\tif err == nil && len(data) > 0 {\n   611â†’\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   612â†’\t\tw.Write(data)\n   613â†’\t\treturn\n   614â†’\t}\n   615â†’\n   616â†’\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   617â†’\tdata, err = os.ReadFile(containerLog)\n   618â†’\tif err == nil && len(data) > 0 {\n   619â†’\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   620â†’\t\tw.Write(data)\n   621â†’\t\treturn\n   622â†’\t}\n   623â†’\n   624â†’\t// Last resort: try live docker logs from still-existing container\n   625â†’\tif h.container != nil && run.ContainerID != \"\" {\n   626â†’\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   627â†’\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   628â†’\t\t\tw.Write([]byte(logs))\n   629â†’\t\t\treturn\n   630â†’\t\t}\n   631â†’\t}\n   632â†’\n   633â†’\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   634â†’}\n   635â†’\n   636â†’func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   637â†’\tid := r.PathValue(\"id\")\n   638â†’\n   639â†’\trun, err := h.store.GetRun(r.Context(), id)\n   640â†’\tif err != nil {\n   641â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   642â†’\t\tw.WriteHeader(http.StatusNotFound)\n   643â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   644â†’\t\treturn\n   645â†’\t}\n   646â†’\n   647â†’\tmgr, ok := h.container.(ContainerManager)\n   648â†’\tif !ok || run.ContainerID == \"\" {\n   649â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   650â†’\t\tw.WriteHeader(http.StatusBadRequest)\n   651â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   652â†’\t\treturn\n   653â†’\t}\n   654â†’\n   655â†’\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   656â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   657â†’\t\tw.WriteHeader(http.StatusInternalServerError)\n   658â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   659â†’\t\treturn\n   660â†’\t}\n   661â†’\n   662â†’\trun.ContainerKept = false\n   663â†’\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   664â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   665â†’\t\tw.WriteHeader(http.StatusInternalServerError)\n   666â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   667â†’\t\treturn\n   668â†’\t}\n   669â†’\n   670â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   671â†’\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   672â†’}\n   673â†’\n   674â†’func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   675â†’\tlabel := r.PathValue(\"name\")\n   676â†’\n   677â†’\t// Resolve label back to project directory via the store.\n   678â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   679â†’\tlabels := projectLabels(projects)\n   680â†’\tvar projectDir string\n   681â†’\tfor dir, l := range labels {\n   682â†’\t\tif l == label {\n   683â†’\t\t\tprojectDir = dir\n   684â†’\t\t\tbreak\n   685â†’\t\t}\n   686â†’\t}\n   687â†’\tif projectDir == \"\" {\n   688â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   689â†’\t\tw.WriteHeader(http.StatusNotFound)\n   690â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   691â†’\t\treturn\n   692â†’\t}\n   693â†’\n   694â†’\tif h.orchestrateFn == nil {\n   695â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   696â†’\t\tw.WriteHeader(http.StatusNotImplemented)\n   697â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   698â†’\t\treturn\n   699â†’\t}\n   700â†’\n   701â†’\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   702â†’\tif err != nil {\n   703â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   704â†’\t\tw.WriteHeader(http.StatusInternalServerError)\n   705â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   706â†’\t\treturn\n   707â†’\t}\n   708â†’\n   709â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   710â†’\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   711â†’}\n   712â†’\n   713â†’// handleAPIStream serves an SSE stream of log lines for a run.\n   714â†’// For active runs, it subscribes to the live broadcaster.\n   715â†’// For completed runs, it serves the archived full.log then closes.\n   716â†’func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   717â†’\tid := r.PathValue(\"id\")\n   718â†’\n   719â†’\trun, err := h.store.GetRun(r.Context(), id)\n   720â†’\tif err != nil {\n   721â†’\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   722â†’\t\treturn\n   723â†’\t}\n   724â†’\n   725â†’\tflusher, ok := w.(http.Flusher)\n   726â†’\tif !ok {\n   727â†’\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   728â†’\t\treturn\n   729â†’\t}\n   730â†’\n   731â†’\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   732â†’\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   733â†’\tw.Header().Set(\"Connection\", \"keep-alive\")\n   734â†’\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   735â†’\n   736â†’\tisComplete := run.State == domain.RunStateSucceeded ||\n   737â†’\t\trun.State == domain.RunStateFailed ||\n   738â†’\t\trun.State == domain.RunStateCancelled\n   739â†’\n   740â†’\tif isComplete {\n   741â†’\t\t// Serve archived full.log\n   742â†’\t\th.streamFullLog(w, flusher, run)\n   743â†’\t\t// Send done event\n   744â†’\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   745â†’\t\tflusher.Flush()\n   746â†’\t\treturn\n   747â†’\t}\n   748â†’\n   749â†’\t// Active run: subscribe to live broadcaster\n   750â†’\tif h.logBroadcast == nil {\n   751â†’\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   752â†’\t\treturn\n   753â†’\t}\n   754â†’\n   755â†’\tsub := h.logBroadcast.Subscribe(id)\n   756â†’\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   757â†’\n   758â†’\tctx := r.Context()\n   759â†’\tfor {\n   760â†’\t\tselect {\n   761â†’\t\tcase <-ctx.Done():\n   762â†’\t\t\treturn\n   763â†’\t\tcase line, ok := <-sub.C:\n   764â†’\t\t\tif !ok {\n   765â†’\t\t\t\t// Stream finished (run completed)\n   766â†’\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   767â†’\t\t\t\tflusher.Flush()\n   768â†’\t\t\t\treturn\n   769â†’\t\t\t}\n   770â†’\t\t\tdata, _ := json.Marshal(line)\n   771â†’\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   772â†’\t\t\tflusher.Flush()\n   773â†’\t\t}\n   774â†’\t}\n   775â†’}\n   776â†’\n   777â†’// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   778â†’var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   779â†’\n   780â†’// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   781â†’func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   782â†’\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   783â†’\tf, err := os.Open(logPath)\n   784â†’\tif err != nil {\n   785â†’\t\treturn\n   786â†’\t}\n   787â†’\tdefer f.Close()\n   788â†’\n   789â†’\tscanner := bufio.NewScanner(f)\n   790â†’\tfor scanner.Scan() {\n   791â†’\t\ttext := scanner.Text()\n   792â†’\t\tline := parseFullLogLine(text)\n   793â†’\t\tdata, _ := json.Marshal(line)\n   794â†’\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   795â†’\t\tflusher.Flush()\n   796â†’\t}\n   797â†’}\n   798â†’\n   799â†’// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   800â†’func parseFullLogLine(text string) logstream.LogLine {\n   801â†’\tm := logLineRegex.FindStringSubmatch(text)\n   802â†’\tif m == nil {\n   803â†’\t\treturn logstream.LogLine{\n   804â†’\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   805â†’\t\t\tType:      \"script\",\n   806â†’\t\t\tContent:   text,\n   807â†’\t\t}\n   808â†’\t}\n   809â†’\treturn logstream.LogLine{\n   810â†’\t\tTimestamp: m[1],\n   811â†’\t\tType:      m[2],\n   812â†’\t\tContent:   m[3],\n   813â†’\t}\n   814â†’}\n   815â†’\n   816â†’// --- Project detail handlers ---\n   817â†’\n   818â†’// resolveProjectDir resolves a project label from the URL to its directory path.\n   819â†’// Returns (dir, label, ok). Writes a JSON error response if not found.\n   820â†’func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   821â†’\tlabel := r.PathValue(\"name\")\n   822â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   823â†’\tlabels := projectLabels(projects)\n   824â†’\tfor dir, l := range labels {\n   825â†’\t\tif l == label {\n   826â†’\t\t\treturn dir, label, true\n   827â†’\t\t}\n   828â†’\t}\n   829â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   830â†’\tw.WriteHeader(http.StatusNotFound)\n   831â†’\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   832â†’\treturn \"\", \"\", false\n   833â†’}\n   834â†’\n   835â†’func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   836â†’\tdir, label, ok := h.resolveProjectDir(w, r)\n   837â†’\tif !ok {\n   838â†’\t\treturn\n   839â†’\t}\n   840â†’\n   841â†’\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   842â†’\tn := 10\n   843â†’\tif n > len(runs) {\n   844â†’\t\tn = len(runs)\n   845â†’\t}\n   846â†’\tdots := make([]recentRunDot, n)\n   847â†’\tfor i := 0; i < n; i++ {\n   848â†’\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   849â†’\t}\n   850â†’\n   851â†’\tdata := map[string]any{\n   852â†’\t\t\"Title\":      label,\n   853â†’\t\t\"Label\":      label,\n   854â†’\t\t\"Dir\":        dir,\n   855â†’\t\t\"RecentRuns\": dots,\n   856â†’\t}\n   857â†’\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   858â†’\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   859â†’\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   860â†’\t}\n   861â†’}\n   862â†’\n   863â†’func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   864â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n   865â†’\tif !ok {\n   866â†’\t\treturn\n   867â†’\t}\n   868â†’\tif h.orchestrator == nil {\n   869â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   870â†’\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   871â†’\t\treturn\n   872â†’\t}\n   873â†’\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   874â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   875â†’\tjson.NewEncoder(w).Encode(map[string]any{\n   876â†’\t\t\"enabled\":     enabled,\n   877â†’\t\t\"in_flight\":   inFlight,\n   878â†’\t\t\"concurrency\": concurrency,\n   879â†’\t})\n   880â†’}\n   881â†’\n   882â†’func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   883â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n   884â†’\tif !ok {\n   885â†’\t\treturn\n   886â†’\t}\n   887â†’\tif h.orchestrator == nil {\n   888â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   889â†’\t\tw.WriteHeader(http.StatusNotImplemented)\n   890â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   891â†’\t\treturn\n   892â†’\t}\n   893â†’\th.orchestrator.SetEnabled(dir, true)\n   894â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   895â†’\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   896â†’}\n   897â†’\n   898â†’func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   899â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n   900â†’\tif !ok {\n   901â†’\t\treturn\n   902â†’\t}\n   903â†’\tif h.orchestrator == nil {\n   904â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   905â†’\t\tw.WriteHeader(http.StatusNotImplemented)\n   906â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   907â†’\t\treturn\n   908â†’\t}\n   909â†’\th.orchestrator.SetEnabled(dir, false)\n   910â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   911â†’\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   912â†’}\n   913â†’\n   914â†’func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   915â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n   916â†’\tif !ok {\n   917â†’\t\treturn\n   918â†’\t}\n   919â†’\tif h.orchestrator == nil {\n   920â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   921â†’\t\tw.WriteHeader(http.StatusNotImplemented)\n   922â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   923â†’\t\treturn\n   924â†’\t}\n   925â†’\tvar body struct {\n   926â†’\t\tConcurrency int `json:\"concurrency\"`\n   927â†’\t}\n   928â†’\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n   929â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   930â†’\t\tw.WriteHeader(http.StatusBadRequest)\n   931â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n   932â†’\t\treturn\n   933â†’\t}\n   934â†’\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n   935â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   936â†’\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   937â†’}\n   938â†’\n   939â†’func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   940â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n   941â†’\tif !ok {\n   942â†’\t\treturn\n   943â†’\t}\n   944â†’\n   945â†’\t// Docker image: read FROM line from Dockerfile\n   946â†’\tdockerImage := \"\"\n   947â†’\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   948â†’\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   949â†’\t\t// Find the last FROM line (final stage)\n   950â†’\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   951â†’\t\t\ttrimmed := strings.TrimSpace(line)\n   952â†’\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   953â†’\t\t\t\tparts := strings.Fields(trimmed)\n   954â†’\t\t\t\tif len(parts) >= 2 {\n   955â†’\t\t\t\t\tdockerImage = parts[1]\n   956â†’\t\t\t\t}\n   957â†’\t\t\t}\n   958â†’\t\t}\n   959â†’\t}\n   960â†’\n   961â†’\t// Version\n   962â†’\tversion, _ := config.LoadVersion(dir)\n   963â†’\n   964â†’\t// Prompt files history\n   965â†’\ttype commitEntry struct {\n   966â†’\t\tSHA     string `json:\"sha\"`\n   967â†’\t\tDate    string `json:\"date\"`\n   968â†’\t\tMessage string `json:\"message\"`\n   969â†’\t}\n   970â†’\ttype promptFile struct {\n   971â†’\t\tPath    string        `json:\"path\"`\n   972â†’\t\tHistory []commitEntry `json:\"history\"`\n   973â†’\t}\n   974â†’\n   975â†’\tvar promptFiles []promptFile\n   976â†’\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   977â†’\tif entries, err := os.ReadDir(promptsDir); err == nil {\n   978â†’\t\tfor _, e := range entries {\n   979â†’\t\t\tif e.IsDir() {\n   980â†’\t\t\t\tcontinue\n   981â†’\t\t\t}\n   982â†’\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n   983â†’\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n   984â†’\t\t\tcmd.Dir = dir\n   985â†’\t\t\tout, err := cmd.Output()\n   986â†’\t\t\tif err != nil {\n   987â†’\t\t\t\tcontinue\n   988â†’\t\t\t}\n   989â†’\t\t\tvar history []commitEntry\n   990â†’\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n   991â†’\t\t\t\tif line == \"\" {\n   992â†’\t\t\t\t\tcontinue\n   993â†’\t\t\t\t}\n   994â†’\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n   995â†’\t\t\t\tif len(parts) < 3 {\n   996â†’\t\t\t\t\tcontinue\n   997â†’\t\t\t\t}\n   998â†’\t\t\t\t// Parse date to short form\n   999â†’\t\t\t\tdateStr := parts[1]\n  1000â†’\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1001â†’\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1002â†’\t\t\t\t}\n  1003â†’\t\t\t\thistory = append(history, commitEntry{\n  1004â†’\t\t\t\t\tSHA:     parts[0][:7],\n  1005â†’\t\t\t\t\tDate:    dateStr,\n  1006â†’\t\t\t\t\tMessage: parts[2],\n  1007â†’\t\t\t\t})\n  1008â†’\t\t\t}\n  1009â†’\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1010â†’\t\t}\n  1011â†’\t}\n  1012â†’\n  1013â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1014â†’\tjson.NewEncoder(w).Encode(map[string]any{\n  1015â†’\t\t\"docker_image\": dockerImage,\n  1016â†’\t\t\"version\":      version,\n  1017â†’\t\t\"prompt_files\": promptFiles,\n  1018â†’\t})\n  1019â†’}\n  1020â†’\n  1021â†’func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1022â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n  1023â†’\tif !ok {\n  1024â†’\t\treturn\n  1025â†’\t}\n  1026â†’\tfile := r.URL.Query().Get(\"file\")\n  1027â†’\tsha := r.URL.Query().Get(\"sha\")\n  1028â†’\tif file == \"\" || sha == \"\" {\n  1029â†’\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1030â†’\t\treturn\n  1031â†’\t}\n  1032â†’\n  1033â†’\t// Validate sha is alphanumeric to prevent injection\n  1034â†’\tfor _, c := range sha {\n  1035â†’\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1036â†’\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1037â†’\t\t\treturn\n  1038â†’\t\t}\n  1039â†’\t}\n  1040â†’\n  1041â†’\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1042â†’\tcmd.Dir = dir\n  1043â†’\tout, err := cmd.Output()\n  1044â†’\tif err != nil {\n  1045â†’\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1046â†’\t\treturn\n  1047â†’\t}\n  1048â†’\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1049â†’\tw.Write(out)\n  1050â†’}\n  1051â†’\n  1052â†’func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1053â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n  1054â†’\tif !ok {\n  1055â†’\t\treturn\n  1056â†’\t}\n  1057â†’\n  1058â†’\tclocheDir := filepath.Join(dir, \".cloche\")\n  1059â†’\tentries, err := os.ReadDir(clocheDir)\n  1060â†’\tif err != nil {\n  1061â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1062â†’\t\tjson.NewEncoder(w).Encode([]any{})\n  1063â†’\t\treturn\n  1064â†’\t}\n  1065â†’\n  1066â†’\ttype apiWire struct {\n  1067â†’\t\tFrom   string `json:\"from\"`\n  1068â†’\t\tResult string `json:\"result\"`\n  1069â†’\t\tTo     string `json:\"to\"`\n  1070â†’\t}\n  1071â†’\ttype apiStepDef struct {\n  1072â†’\t\tName    string            `json:\"name\"`\n  1073â†’\t\tType    string            `json:\"type\"`\n  1074â†’\t\tResults []string          `json:\"results\"`\n  1075â†’\t\tConfig  map[string]string `json:\"config\"`\n  1076â†’\t}\n  1077â†’\ttype apiWorkflow struct {\n  1078â†’\t\tName      string       `json:\"name\"`\n  1079â†’\t\tFile      string       `json:\"file\"`\n  1080â†’\t\tSteps     []apiStepDef `json:\"steps\"`\n  1081â†’\t\tWires     []apiWire    `json:\"wires\"`\n  1082â†’\t\tEntryStep string       `json:\"entry_step\"`\n  1083â†’\t}\n  1084â†’\n  1085â†’\tvar workflows []apiWorkflow\n  1086â†’\tfor _, e := range entries {\n  1087â†’\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1088â†’\t\t\tcontinue\n  1089â†’\t\t}\n  1090â†’\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1091â†’\t\tif err != nil {\n  1092â†’\t\t\tcontinue\n  1093â†’\t\t}\n  1094â†’\t\twf, err := dsl.Parse(string(data))\n  1095â†’\t\tif err != nil {\n  1096â†’\t\t\tcontinue\n  1097â†’\t\t}\n  1098â†’\t\tvar steps []apiStepDef\n  1099â†’\t\tfor _, s := range wf.Steps {\n  1100â†’\t\t\tsteps = append(steps, apiStepDef{\n  1101â†’\t\t\t\tName:    s.Name,\n  1102â†’\t\t\t\tType:    string(s.Type),\n  1103â†’\t\t\t\tResults: s.Results,\n  1104â†’\t\t\t\tConfig:  s.Config,\n  1105â†’\t\t\t})\n  1106â†’\t\t}\n  1107â†’\t\t// Sort steps by name for consistent ordering\n  1108â†’\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1109â†’\n  1110â†’\t\tvar wires []apiWire\n  1111â†’\t\tfor _, wire := range wf.Wiring {\n  1112â†’\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1113â†’\t\t}\n  1114â†’\n  1115â†’\t\tworkflows = append(workflows, apiWorkflow{\n  1116â†’\t\t\tName:      wf.Name,\n  1117â†’\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1118â†’\t\t\tSteps:     steps,\n  1119â†’\t\t\tWires:     wires,\n  1120â†’\t\t\tEntryStep: wf.EntryStep,\n  1121â†’\t\t})\n  1122â†’\t}\n  1123â†’\n  1124â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1125â†’\tjson.NewEncoder(w).Encode(workflows)\n  1126â†’}\n  1127â†’\n  1128â†’func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1129â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n  1130â†’\tif !ok {\n  1131â†’\t\treturn\n  1132â†’\t}\n  1133â†’\tworkflowName := r.PathValue(\"workflow\")\n  1134â†’\tstepName := r.PathValue(\"step\")\n  1135â†’\n  1136â†’\t// Find the workflow file\n  1137â†’\tclocheDir := filepath.Join(dir, \".cloche\")\n  1138â†’\tvar wf *domain.Workflow\n  1139â†’\tentries, _ := os.ReadDir(clocheDir)\n  1140â†’\tfor _, e := range entries {\n  1141â†’\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1142â†’\t\t\tcontinue\n  1143â†’\t\t}\n  1144â†’\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1145â†’\t\tif err != nil {\n  1146â†’\t\t\tcontinue\n  1147â†’\t\t}\n  1148â†’\t\tparsed, err := dsl.Parse(string(data))\n  1149â†’\t\tif err != nil {\n  1150â†’\t\t\tcontinue\n  1151â†’\t\t}\n  1152â†’\t\tif parsed.Name == workflowName {\n  1153â†’\t\t\twf = parsed\n  1154â†’\t\t\tbreak\n  1155â†’\t\t}\n  1156â†’\t}\n  1157â†’\tif wf == nil {\n  1158â†’\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1159â†’\t\treturn\n  1160â†’\t}\n  1161â†’\n  1162â†’\tstep, ok := wf.Steps[stepName]\n  1163â†’\tif !ok {\n  1164â†’\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1165â†’\t\treturn\n  1166â†’\t}\n  1167â†’\n  1168â†’\t// Try to read the referenced file from step config\n  1169â†’\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1170â†’\n  1171â†’\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1172â†’\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1173â†’\t\tif err == nil {\n  1174â†’\t\t\tw.Write(data)\n  1175â†’\t\t\treturn\n  1176â†’\t\t}\n  1177â†’\t}\n  1178â†’\tif script := step.Config[\"command\"]; script != \"\" {\n  1179â†’\t\tw.Write([]byte(script))\n  1180â†’\t\treturn\n  1181â†’\t}\n  1182â†’\tif script := step.Config[\"script\"]; script != \"\" {\n  1183â†’\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1184â†’\t\tif err == nil {\n  1185â†’\t\t\tw.Write(data)\n  1186â†’\t\t\treturn\n  1187â†’\t\t}\n  1188â†’\t\tw.Write([]byte(script))\n  1189â†’\t\treturn\n  1190â†’\t}\n  1191â†’\n  1192â†’\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1193â†’}\n  1194â†’\n  1195â†’// --- Template helpers ---\n  1196â†’\n  1197â†’func stateColor(state domain.RunState) string {\n  1198â†’\tswitch state {\n  1199â†’\tcase domain.RunStatePending:\n  1200â†’\t\treturn \"pending\"\n  1201â†’\tcase domain.RunStateRunning:\n  1202â†’\t\treturn \"running\"\n  1203â†’\tcase domain.RunStateSucceeded:\n  1204â†’\t\treturn \"succeeded\"\n  1205â†’\tcase domain.RunStateFailed:\n  1206â†’\t\treturn \"failed\"\n  1207â†’\tcase domain.RunStateCancelled:\n  1208â†’\t\treturn \"cancelled\"\n  1209â†’\tdefault:\n  1210â†’\t\treturn \"pending\"\n  1211â†’\t}\n  1212â†’}\n  1213â†’\n  1214â†’func healthColor(status domain.HealthStatus) string {\n  1215â†’\tswitch status {\n  1216â†’\tcase domain.HealthGreen:\n  1217â†’\t\treturn \"green\"\n  1218â†’\tcase domain.HealthYellow:\n  1219â†’\t\treturn \"yellow\"\n  1220â†’\tcase domain.HealthRed:\n  1221â†’\t\treturn \"red\"\n  1222â†’\tcase domain.HealthBlue:\n  1223â†’\t\treturn \"blue\"\n  1224â†’\tdefault:\n  1225â†’\t\treturn \"grey\"\n  1226â†’\t}\n  1227â†’}\n  1228â†’\n  1229â†’func formatTime(t time.Time) string {\n  1230â†’\tif t.IsZero() {\n  1231â†’\t\treturn \"\"\n  1232â†’\t}\n  1233â†’\treturn t.Format(\"2006-01-02 15:04:05\")\n  1234â†’}\n  1235â†’\n  1236â†’func formatDuration(start, end time.Time) string {\n  1237â†’\tif start.IsZero() || end.IsZero() {\n  1238â†’\t\treturn \"\"\n  1239â†’\t}\n  1240â†’\td := end.Sub(start)\n  1241â†’\tif d < time.Second {\n  1242â†’\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1243â†’\t}\n  1244â†’\tif d < time.Minute {\n  1245â†’\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1246â†’\t}\n  1247â†’\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1248â†’}\n  1249â†’\n  1250â†’func truncate(s string, n int) string {\n  1251â†’\tif len(s) <= n {\n  1252â†’\t\treturn s\n  1253â†’\t}\n  1254â†’\treturn s[:n] + \"...\"\n  1255â†’}\n  1256â†’\n  1257â†’func shortContainerID(id string) string {\n  1258â†’\tif len(id) > 12 {\n  1259â†’\t\treturn id[:12]\n  1260â†’\t}\n  1261â†’\treturn id\n  1262â†’}\n  1263â†’\n  1264â†’// projectLabels builds a mapping from full project directory paths to short\n  1265â†’// display labels. Each label is the final directory component (e.g.\n  1266â†’// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1267â†’// the same final name, the parent directory is prepended to disambiguate\n  1268â†’// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1269â†’func projectLabels(dirs []string) map[string]string {\n  1270â†’\tlabels := make(map[string]string, len(dirs))\n  1271â†’\t// Group dirs by their base name to detect conflicts.\n  1272â†’\tbyBase := map[string][]string{}\n  1273â†’\tfor _, d := range dirs {\n  1274â†’\t\tbase := filepath.Base(d)\n  1275â†’\t\tbyBase[base] = append(byBase[base], d)\n  1276â†’\t}\n  1277â†’\tfor base, paths := range byBase {\n  1278â†’\t\tif len(paths) == 1 {\n  1279â†’\t\t\tlabels[paths[0]] = base\n  1280â†’\t\t} else {\n  1281â†’\t\t\tfor _, p := range paths {\n  1282â†’\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1283â†’\t\t\t\tlabels[p] = parent + \"/\" + base\n  1284â†’\t\t\t}\n  1285â†’\t\t}\n  1286â†’\t}\n  1287â†’\treturn labels\n  1288â†’}\n  1289â†’\n  1290â†’type projectEntry struct {\n  1291â†’\tDir            string\n  1292â†’\tLabel          string\n  1293â†’\tContainerCount int\n  1294â†’}\n  1295â†’"}]},"parent_tool_use_id":null,"session_id":"90f88336-a4d8-49e6-a75b-4c58ce277544","uuid":"b76d4c79-b03d-4850-8099-892c99d9bbac","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\nfunc WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n\treturn func(h *Handler) { h.orchestrateFn = fn }\n}\n\n// OrchestratorController provides per-project orchestrator control.\ntype OrchestratorController interface {\n\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n\tSetEnabled(dir string, enabled bool)\n\tSetConcurrency(dir string, concurrency int)\n}\n\n// WithOrchestrator sets the orchestrator controller for project-level control.\nfunc WithOrchestrator(oc OrchestratorController) HandlerOption {\n\treturn func(h *Handler) { h.orchestrator = oc }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore         ports.RunStore\n\tcaptures      ports.CaptureStore\n\tlogStore      ports.LogStore\n\tcontainer     ContainerLogger\n\tlogBroadcast  *logstream.Broadcaster\n\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n\torchestrator  OrchestratorController\n\tpages         map[string]*template.Template\n\tmux           *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row â€” merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   â€“ container exists and is running\n//   - \"stopped\"   â€“ container exists, not running, not kept\n//   - \"available\" â€“ container exists, not running, kept (can be deleted)\n//   - \"removed\"   â€“ no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\n\t// Resolve label back to project directory via the store.\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tvar projectDir string\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\tprojectDir = dir\n\t\t\tbreak\n\t\t}\n\t}\n\tif projectDir == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\t\treturn\n\t}\n\n\tif h.orchestrateFn == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\n\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n\t\treturn\n\t}\n\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"enabled\":     enabled,\n\t\t\"in_flight\":   inFlight,\n\t\t\"concurrency\": concurrency,\n\t})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, true)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, false)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\tvar body struct {\n\t\tConcurrency int `json:\"concurrency\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n\t\treturn\n\t}\n\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion, _ := config.LoadVersion(dir)\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\tif script := step.Config[\"command\"]; script != \"\" {\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1295,"startLine":1,"totalLines":1295}}}
