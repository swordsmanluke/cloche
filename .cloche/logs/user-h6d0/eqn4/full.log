re(dbPath)\n    43â†’\tif err != nil {\n    44â†’\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    45â†’\t\tos.Exit(1)\n    46â†’\t}\n    47â†’\tdefer store.Close()\n    48â†’\n    49â†’\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    50â†’\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    51â†’\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    52â†’\t} else if n > 0 {\n    53â†’\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    54â†’\t}\n    55â†’\n    56â†’\truntime, err := initRuntime(globalCfg)\n    57â†’\tif err != nil {\n    58â†’\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    59â†’\t\tos.Exit(1)\n    60â†’\t}\n    61â†’\n    62â†’\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    63â†’\n    64â†’\tbroadcaster := logstream.NewBroadcaster()\n    65â†’\n    66â†’\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    67â†’\tsrv.SetLogStore(store)\n    68â†’\tsrv.SetLogBroadcaster(broadcaster)\n    69â†’\n    70â†’\t// Set up evolution trigger\n    71â†’\tevoTrigger := initEvolution(globalCfg, store, store)\n    72â†’\tif evoTrigger != nil {\n    73â†’\t\tsrv.SetEvolution(evoTrigger)\n    74â†’\t}\n    75â†’\n    76â†’\t// Set up orchestrator\n    77â†’\torch := initOrchestrator(globalCfg, store, srv)\n    78â†’\tif orch != nil {\n    79â†’\t\tsrv.SetOnRunComplete(func(ctx context.Context, projectDir string, runID string, state domain.RunState) {\n    80â†’\t\t\torch.OnRunComplete(ctx, projectDir, runID, state)\n    81â†’\t\t})\n    82â†’\t\tsrv.SetOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n    83â†’\t\t\tif projectDir != \"\" {\n    84â†’\t\t\t\treturn orch.Run(ctx, projectDir)\n    85â†’\t\t\t}\n    86â†’\t\t\treturn orch.TriggerAll(ctx), nil\n    87â†’\t\t})\n    88â†’\t}\n    89â†’\n    90â†’\tgrpcServer := grpc.NewServer()\n    91â†’\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    92â†’\n    93â†’\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    94â†’\n    95â†’\tlis, err := listen(listenAddr)\n    96â†’\tif err != nil {\n    97â†’\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    98â†’\t\tos.Exit(1)\n    99â†’\t}\n   100â†’\n   101â†’\tvar httpServer *http.Server\n   102â†’\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n   103â†’\t\twebOpts := []web.HandlerOption{\n   104â†’\t\t\tweb.WithContainerLogger(runtime),\n   105â†’\t\t\tweb.WithLogStore(store),\n   106â†’\t\t\tweb.WithLogBroadcaster(broadcaster),\n   107â†’\t\t}\n   108â†’\t\tif orch != nil {\n   109â†’\t\t\twebOpts = append(webOpts, web.WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   110â†’\t\t\t\treturn orch.Run(ctx, projectDir)\n   111â†’\t\t\t}))\n   112â†’\t\t\twebOpts = append(webOpts, web.WithOrchestrator(orch))\n   113â†’\t\t}\n   114â†’\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n   115â†’\t\tif err != nil {\n   116â†’\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n   117â†’\t\t\tos.Exit(1)\n   118â†’\t\t}\n   119â†’\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n   120â†’\t\tgo func() {\n   121â†’\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   122â†’\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   123â†’\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   124â†’\t\t\t}\n   125â†’\t\t}()\n   126â†’\t}\n   127â†’\n   128â†’\tsigCh := make(chan os.Signal, 1)\n   129â†’\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   130â†’\tgo func() {\n   131â†’\t\t<-sigCh\n   132â†’\t\tif httpServer != nil {\n   133â†’\t\t\thttpServer.Close()\n   134â†’\t\t}\n   135â†’\t\tgrpcServer.GracefulStop()\n   136â†’\t}()\n   137â†’\n   138â†’\t// Trigger orchestration on startup\n   139â†’\tif orch != nil {\n   140â†’\t\tgo func() {\n   141â†’\t\t\tn := orch.TriggerAll(context.Background())\n   142â†’\t\t\tif n > 0 {\n   143â†’\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: orchestrator dispatched %d run(s)\\n\", n)\n   144â†’\t\t\t}\n   145â†’\t\t}()\n   146â†’\t}\n   147â†’\n   148â†’\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   149â†’\tif err := grpcServer.Serve(lis); err != nil {\n   150â†’\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   151â†’\t\tos.Exit(1)\n   152â†’\t}\n   153â†’}\n   154â†’\n   155â†’func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   156â†’\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   157â†’\n   158â†’\tswitch runtimeType {\n   159â†’\tcase \"local\":\n   160â†’\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   161â†’\t\tif agentPath == \"\" {\n   162â†’\t\t\t// Look for cloche-agent next to this binary\n   163â†’\t\t\texe, err := os.Executable()\n   164â†’\t\t\tif err == nil {\n   165â†’\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   166â†’\t\t\t} else {\n   167â†’\t\t\t\tagentPath = \"cloche-agent\"\n   168â†’\t\t\t}\n   169â†’\t\t}\n   170â†’\t\treturn local.NewRuntime(agentPath), nil\n   171â†’\tcase \"docker\":\n   172â†’\t\treturn docker.NewRuntime()\n   173â†’\tdefault:\n   174â†’\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   175â†’\t}\n   176â†’}\n   177â†’\n   178â†’func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   179â†’\t// Load config from working directory (daemon-level defaults)\n   180â†’\tcfg, err := config.Load(\".\")\n   181â†’\tif err != nil || !cfg.Evolution.Enabled {\n   182â†’\t\treturn nil\n   183â†’\t}\n   184â†’\n   185â†’