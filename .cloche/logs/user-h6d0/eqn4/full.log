ute as the daemon user. Keep operations simple and safe.\n   110â†’\n   111â†’workflow \"orchestrate\" {\n   112â†’  step prepare-prompt {\n   113â†’    run     = \"bash .cloche/scripts/prepare-prompt.sh\"\n   114â†’    results = [success, fail]\n   115â†’  }\n   116â†’\n   117â†’  step develop {\n   118â†’    workflow_name = \"develop\"\n   119â†’    results       = [success, fail]\n   120â†’  }\n   121â†’\n   122â†’  prepare-prompt:success -> develop\n   123â†’  prepare-prompt:fail    -> abort\n   124â†’  develop:success        -> done\n   125â†’  develop:fail           -> done\n   126â†’}\n   127â†’`\n   128â†’\n   129â†’var preparePromptScript = `#!/usr/bin/env bash\n   130â†’# Default prompt generator.\n   131â†’# Writes the task prompt to stdout and to $CLOCHE_STEP_OUTPUT.\n   132â†’set -euo pipefail\n   133â†’\n   134â†’prompt=\"## Task: ${CLOCHE_TASK_TITLE}\n   135â†’\n   136â†’${CLOCHE_TASK_BODY}\"\n   137â†’\n   138â†’echo \"$prompt\"\n   139â†’[ -n \"${CLOCHE_STEP_OUTPUT:-}\" ] && echo \"$prompt\" > \"$CLOCHE_STEP_OUTPUT\"\n   140â†’`\n   141â†’\n   142â†’func cmdInit(args []string) {\n   143â†’\tworkflow := \"develop\"\n   144â†’\tbaseImage := \"cloche-base:latest\"\n   145â†’\n   146â†’\tfor i := 0; i < len(args); i++ {\n   147â†’\t\tswitch args[i] {\n   148â†’\t\tcase \"--workflow\":\n   149â†’\t\t\tif i+1 < len(args) {\n   150â†’\t\t\t\ti++\n   151â†’\t\t\t\tworkflow = args[i]\n   152â†’\t\t\t}\n   153â†’\t\tcase \"--base-image\":\n   154â†’\t\t\tif i+1 < len(args) {\n   155â†’\t\t\t\ti++\n   156â†’\t\t\t\tbaseImage = args[i]\n   157â†’\t\t\t}\n   158â†’\t\t}\n   159â†’\t}\n   160â†’\n   161â†’\tclocheDir := \".cloche\"\n   162â†’\tworkflowFile := filepath.Join(clocheDir, workflow+\".cloche\")\n   163â†’\n   164â†’\t// Refuse to overwrite existing workflow\n   165â†’\tif _, err := os.Stat(workflowFile); err == nil {\n   166â†’\t\tfmt.Fprintf(os.Stderr, \"error: %s already exists\\n\", workflowFile)\n   167â†’\t\tos.Exit(1)\n   168â†’\t}\n   169â†’\n  