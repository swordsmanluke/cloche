[2026-03-07T17:02:13Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Rm5PUR4KD1VHuwxTcwXueu","type":"tool_result","content":"     1â†’package evolution\n     2â†’\n     3â†’import (\n     4â†’\t\"context\"\n     5â†’\t\"fmt\"\n     6â†’\t\"os\"\n     7â†’\t\"path/filepath\"\n     8â†’\t\"time\"\n     9â†’\n    10â†’\t\"github.com/cloche-dev/cloche/internal/config\"\n    11â†’\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    12â†’\t\"github.com/cloche-dev/cloche/internal/ports\"\n    13â†’)\n    14â†’\n    15â†’// OrchestratorConfig configures the evolution pipeline.\n    16â†’type OrchestratorConfig struct {\n    17â†’\tProjectDir    string\n    18â†’\tWorkflowName  string\n    19â†’\tLLM           LLMClient\n    20â†’\tMinConfidence string\n    21â†’}\n    22â†’\n    23â†’// Orchestrator wires all evolution pipeline stages together.\n    24â†’type Orchestrator struct {\n    25â†’\tcfg        OrchestratorConfig\n    26â†’\tcollector  *Collector\n    27â†’\tclassifier *Classifier\n    28â†’\treflector  *Reflector\n    29â†’\tcurator    *Curator\n    30â†’\tscriptGen  *ScriptGenerator\n    31â†’\tmutator    *dsl.Mutator\n    32â†’\taudit      *AuditLogger\n    33â†’}\n    34â†’\n    35â†’// NewOrchestrator creates a fully wired evolution pipeline.\n    36â†’func NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n    37â†’\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir}\n    38â†’\treturn &Orchestrator{\n    39â†’\t\tcfg:        cfg,\n    40â†’\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n    41â†’\t\tclassifier: &Classifier{LLM: cfg.LLM},\n    42â†’\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n    43â†’\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n    44â†’\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n    45â†’\t\tmutator:    &dsl.Mutator{},\n    46â†’\t\taudit:      audit,\n    47â†’\t}\n    48â†’}\n    49â†’\n    50â†’// Run executes the full evolution pipeline.\n    51â†’func (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n    52â†’\t// Stage 1: Collect\n    53â†’\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n    54â†’\tif err != nil {\n    55â†’\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n    56â†’\t}\n    57â†’\n    58â†’\t// Stage 2: Classify the triggering run\n    59â†’\tclassification, err := o.classifier.Classify(ctx, \"\")\n    60â†’\tif err != nil {\n    61â†’\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n    62â†’\t}\n    63â†’\n    64â†’\t// Stage 3: Reflect\n    65â†’\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n    66â†’\tif err != nil {\n    67â†’\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n    68â†’\t}\n    69â†’\n    70â†’\tresult := &EvolutionResult{\n    71â†’\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n    72â†’\t\tProjectDir:     o.cfg.ProjectDir,\n    73â†’\t\tWorkflowName:   o.cfg.WorkflowName,\n    74â†’\t\tTriggerRunID:   triggerRunID,\n    75â†’\t\tTimestamp:      time.Now().Format(time.RFC3339),\n    76â†’\t\tClassification: classification,\n    77â†’\t}\n    78â†’\n    79â†’\tif len(lessons) == 0 {\n    80â†’\t\t// No actionable lessons â€” log and return\n    81â†’\t\to.audit.Log(result)\n    82â†’\t\treturn result, nil\n    83â†’\t}\n    84â†’\n    85â†’\t// Stage 4: Execute branches based on lesson category\n    86â†’\tfor _, lesson := range lessons {\n    87â†’\t\tswitch lesson.Category {\n    88â†’\t\tcase \"prompt_improvement\":\n    89â†’\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n    90â†’\t\t\tif err != nil {\n    91â†’\t\t\t\tcontinue // log but don't fail the whole pipeline\n    92â†’\t\t\t}\n    93â†’\t\t\tresult.Changes = append(result.Changes, *change)\n    94â†’\n    95â†’\t\tcase \"new_step\":\n    96â†’\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n    97â†’\t\t\t\tcontinue\n    98â†’\t\t\t}\n    99â†’\t\t}\n   100â†’\t}\n   101â†’\n   102â†’\t// Stage 5: Audit\n   103â†’\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n   104â†’\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n   105â†’\to.audit.Log(result)\n   106â†’\n   107â†’\t// Increment project version if any changes were made\n   108â†’\tif len(result.Changes) > 0 {\n   109â†’\t\tif err := config.IncrementProjectVersion(o.cfg.ProjectDir); err != nil {\n   110â†’\t\t\tfmt.Fprintf(os.Stderr, \"warning: could not increment project version: %v\\n\", err)\n   111â†’\t\t}\n   112â†’\t}\n   113â†’\n   114â†’\t// Save to store if available\n   115â†’\tif evoStore != nil {\n   116â†’\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n   117â†’\t\t\tID:             result.ID,\n   118â†’\t\t\tProjectDir:     result.ProjectDir,\n   119â†’\t\t\tWorkflowName:   result.WorkflowName,\n   120â†’\t\t\tTriggerRunID:   result.TriggerRunID,\n   121â†’\t\t\tCreatedAt:      time.Now(),\n   122â†’\t\t\tClassification: result.Classification,\n   123â†’\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n   124â†’\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n   125â†’\t\t})\n   126â†’\t}\n   127â†’\n   128â†’\treturn result, nil\n   129â†’}\n   130â†’\n   131â†’// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\n   132â†’func (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n   133â†’\t// Generate the script or prompt file\n   134â†’\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n   135â†’\tif err != nil {\n   136â†’\t\treturn err\n   137â†’\t}\n   138â†’\n   139â†’\tresult.Changes = append(result.Changes, Change{\n   140â†’\t\tType:   \"add_script\",\n   141â†’\t\tFile:   generated.Path,\n   142â†’\t\tReason: lesson.Insight,\n   143â†’\t})\n   144â†’\n   145â†’\t// Add step and wiring to the workflow file\n   146â†’\tif data.WorkflowPath == \"\" {\n   147â†’\t\treturn nil\n   148â†’\t}\n   149â†’\n   150â†’\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n   151â†’\tif err != nil {\n   152â†’\t\treturn err\n   153â†’\t}\n   154â†’\n   155â†’\t// Snapshot the workflow\n   156â†’\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n   157â†’\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n   158â†’\n   159â†’\t// Derive step name from the script path\n   160â†’\tstepName := filepath.Base(generated.Path)\n   161â†’\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n   162â†’\n   163â†’\t// Determine the config based on step type\n   164â†’\tconfig := map[string]string{}\n   165â†’\tswitch lesson.StepType {\n   166â†’\tcase \"agent\":\n   167â†’\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n   168â†’\tdefault: // script\n   169â†’\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n   170â†’\t}\n   171â†’\n   172â†’\t// Add the step\n   173â†’\tupdated, err := o.mutator.AddStep(string(workflowContent), dsl.StepDef{\n   174â†’\t\tName:    stepName,\n   175â†’\t\tType:    lesson.StepType,\n   176â†’\t\tConfig:  config,\n   177â†’\t\tResults: []string{\"success\", \"fail\"},\n   178â†’\t})\n   179â†’\tif err != nil {\n   180â†’\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n   181â†’\t}\n   182â†’\n   183â†’\t// Add wiring: wire the new step's fail to the fix step (if it exists),\n   184â†’\t// and success to done\n   185â†’\twires := []dsl.WireDef{\n   186â†’\t\t{From: stepName, Result: \"success\", To: \"done\"},\n   187â†’\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n   188â†’\t}\n   189â†’\tupdated, err = o.mutator.AddWiring(updated, wires)\n   190â†’\tif err != nil {\n   191â†’\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n   192â†’\t}\n   193â†’\n   194â†’\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n   195â†’\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n   196â†’\t}\n   197â†’\n   198â†’\tresult.Changes = append(result.Changes, Change{\n   199â†’\t\tType:     \"add_step\",\n   200â†’\t\tFile:     wfRelPath,\n   201â†’\t\tReason:   lesson.Insight,\n   202â†’\t\tSnapshot: snapName,\n   203â†’\t})\n   204â†’\n   205â†’\treturn nil\n   206â†’}\n   207â†’"}]},"parent_tool_use_id":null,"session_id":"835b617a-c8b0-498c-ac2f-49c8473e6d27","uuid":"ef0032eb-0987-4bd8-877d-9a42a5b5aabc","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/orchestrator.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// OrchestratorConfig configures the evolution pipeline.\ntype OrchestratorConfig struct {\n\tProjectDir    string\n\tWorkflowName  string\n\tLLM           LLMClient\n\tMinConfidence string\n}\n\n// Orchestrator wires all evolution pipeline stages together.\ntype Orchestrator struct {\n\tcfg        OrchestratorConfig\n\tcollector  *Collector\n\tclassifier *Classifier\n\treflector  *Reflector\n\tcurator    *Curator\n\tscriptGen  *ScriptGenerator\n\tmutator    *dsl.Mutator\n\taudit      *AuditLogger\n}\n\n// NewOrchestrator creates a fully wired evolution pipeline.\nfunc NewOrchestrator(cfg OrchestratorConfig) *Orchestrator {\n\taudit := &AuditLogger{ProjectDir: cfg.ProjectDir}\n\treturn &Orchestrator{\n\t\tcfg:        cfg,\n\t\tcollector:  &Collector{ProjectDir: cfg.ProjectDir, WorkflowName: cfg.WorkflowName},\n\t\tclassifier: &Classifier{LLM: cfg.LLM},\n\t\treflector:  &Reflector{LLM: cfg.LLM, MinConfidence: cfg.MinConfidence},\n\t\tcurator:    &Curator{LLM: cfg.LLM, Audit: audit},\n\t\tscriptGen:  &ScriptGenerator{LLM: cfg.LLM},\n\t\tmutator:    &dsl.Mutator{},\n\t\taudit:      audit,\n\t}\n}\n\n// Run executes the full evolution pipeline.\nfunc (o *Orchestrator) Run(ctx context.Context, triggerRunID string, evoStore ports.EvolutionStore, capStore ports.CaptureStore) (*EvolutionResult, error) {\n\t// Stage 1: Collect\n\tdata, err := o.collector.Collect(ctx, evoStore, capStore)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"collector: %w\", err)\n\t}\n\n\t// Stage 2: Classify the triggering run\n\tclassification, err := o.classifier.Classify(ctx, \"\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"classifier: %w\", err)\n\t}\n\n\t// Stage 3: Reflect\n\tlessons, err := o.reflector.Reflect(ctx, data, classification)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reflector: %w\", err)\n\t}\n\n\tresult := &EvolutionResult{\n\t\tID:             fmt.Sprintf(\"evo-%d\", time.Now().UnixNano()),\n\t\tProjectDir:     o.cfg.ProjectDir,\n\t\tWorkflowName:   o.cfg.WorkflowName,\n\t\tTriggerRunID:   triggerRunID,\n\t\tTimestamp:      time.Now().Format(time.RFC3339),\n\t\tClassification: classification,\n\t}\n\n\tif len(lessons) == 0 {\n\t\t// No actionable lessons â€” log and return\n\t\to.audit.Log(result)\n\t\treturn result, nil\n\t}\n\n\t// Stage 4: Execute branches based on lesson category\n\tfor _, lesson := range lessons {\n\t\tswitch lesson.Category {\n\t\tcase \"prompt_improvement\":\n\t\t\tchange, err := o.curator.Apply(ctx, o.cfg.ProjectDir, &lesson)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // log but don't fail the whole pipeline\n\t\t\t}\n\t\t\tresult.Changes = append(result.Changes, *change)\n\n\t\tcase \"new_step\":\n\t\t\tif err := o.handleNewStep(ctx, data, &lesson, result); err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\t}\n\n\t// Stage 5: Audit\n\to.audit.UpdateKnowledge(o.cfg.WorkflowName, lessons)\n\tresult.KnowledgeDelta = fmt.Sprintf(\"%d lessons applied\", len(lessons))\n\to.audit.Log(result)\n\n\t// Increment project version if any changes were made\n\tif len(result.Changes) > 0 {\n\t\tif err := config.IncrementProjectVersion(o.cfg.ProjectDir); err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"warning: could not increment project version: %v\\n\", err)\n\t\t}\n\t}\n\n\t// Save to store if available\n\tif evoStore != nil {\n\t\tevoStore.SaveEvolution(ctx, &ports.EvolutionEntry{\n\t\t\tID:             result.ID,\n\t\t\tProjectDir:     result.ProjectDir,\n\t\t\tWorkflowName:   result.WorkflowName,\n\t\t\tTriggerRunID:   result.TriggerRunID,\n\t\t\tCreatedAt:      time.Now(),\n\t\t\tClassification: result.Classification,\n\t\t\tChangesJSON:    fmt.Sprintf(\"%d changes\", len(result.Changes)),\n\t\t\tKnowledgeDelta: result.KnowledgeDelta,\n\t\t})\n\t}\n\n\treturn result, nil\n}\n\n// handleNewStep generates a script/prompt file and adds the step + wiring to the workflow.\nfunc (o *Orchestrator) handleNewStep(ctx context.Context, data *CollectedData, lesson *Lesson, result *EvolutionResult) error {\n\t// Generate the script or prompt file\n\tgenerated, err := o.scriptGen.Generate(ctx, o.cfg.ProjectDir, lesson)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tresult.Changes = append(result.Changes, Change{\n\t\tType:   \"add_script\",\n\t\tFile:   generated.Path,\n\t\tReason: lesson.Insight,\n\t})\n\n\t// Add step and wiring to the workflow file\n\tif data.WorkflowPath == \"\" {\n\t\treturn nil\n\t}\n\n\tworkflowContent, err := os.ReadFile(data.WorkflowPath)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// Snapshot the workflow\n\twfRelPath, _ := filepath.Rel(o.cfg.ProjectDir, data.WorkflowPath)\n\tsnapName, _ := o.audit.Snapshot(wfRelPath)\n\n\t// Derive step name from the script path\n\tstepName := filepath.Base(generated.Path)\n\tstepName = stepName[:len(stepName)-len(filepath.Ext(stepName))]\n\n\t// Determine the config based on step type\n\tconfig := map[string]string{}\n\tswitch lesson.StepType {\n\tcase \"agent\":\n\t\tconfig[\"prompt\"] = fmt.Sprintf(`file(\"%s\")`, generated.Path)\n\tdefault: // script\n\t\tconfig[\"run\"] = fmt.Sprintf(`\"%s\"`, generated.Path)\n\t}\n\n\t// Add the step\n\tupdated, err := o.mutator.AddStep(string(workflowContent), dsl.StepDef{\n\t\tName:    stepName,\n\t\tType:    lesson.StepType,\n\t\tConfig:  config,\n\t\tResults: []string{\"success\", \"fail\"},\n\t})\n\tif err != nil {\n\t\treturn fmt.Errorf(\"adding step to workflow: %w\", err)\n\t}\n\n\t// Add wiring: wire the new step's fail to the fix step (if it exists),\n\t// and success to done\n\twires := []dsl.WireDef{\n\t\t{From: stepName, Result: \"success\", To: \"done\"},\n\t\t{From: stepName, Result: \"fail\", To: \"abort\"},\n\t}\n\tupdated, err = o.mutator.AddWiring(updated, wires)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"adding wiring to workflow: %w\", err)\n\t}\n\n\tif err := os.WriteFile(data.WorkflowPath, []byte(updated), 0644); err != nil {\n\t\treturn fmt.Errorf(\"writing updated workflow: %w\", err)\n\t}\n\n\tresult.Changes = append(result.Changes, Change{\n\t\tType:     \"add_step\",\n\t\tFile:     wfRelPath,\n\t\tReason:   lesson.Insight,\n\t\tSnapshot: snapName,\n\t})\n\n\treturn nil\n}\n","numLines":207,"startLine":1,"totalLines":207}}}
