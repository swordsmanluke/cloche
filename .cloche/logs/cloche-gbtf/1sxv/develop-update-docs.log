lize\" {\n    64→  step close-task {\n    65→    run     = \"bash .cloche/scripts/close-task.sh\"\n    66→    results = [success, fail]\n    67→  }\n    68→\n    69→  close-task:success -> done\n    70→  close-task:fail    -> done\n    71→}\n    72→"}]},"parent_tool_use_id":null,"session_id":"0a1eb545-c5fc-4d99-8df4-f479f783e58f","uuid":"8714f897-04eb-4faa-82f2-11251ada6d52","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.cloche/host.cloche","content":"workflow \"list-tasks\" {\n  step ready-tasks {\n    run     = \"bash .cloche/scripts/ready-tasks.sh\"\n    results = [success, fail]\n  }\n\n  ready-tasks:success -> done\n  ready-tasks:fail    -> abort\n}\n\nworkflow \"main\" {\n  host {\n    agent_command = \"claude\"\n  }\n\n  step claim-task {\n    run     = \"bash .cloche/scripts/claim-task.sh\"\n    results = [success, fail]\n  }\n\n  step prepare-prompt {\n    run     = \"bash .cloche/scripts/prepare-prompt.sh\"\n    results = [success, fail]\n  }\n\n  step develop {\n    workflow_name = \"develop\"\n    results       = [success, fail]\n  }\n\n  step merge {\n    run     = \"bash .cloche/scripts/merge-to-main.sh\"\n    results = [success, fail]\n  }\n\n  step cleanup {\n    run     = \"bash .cloche/scripts/cleanup-run.sh\"\n    results = [success, fail]\n  }\n\n  claim-task:success     -> prepare-prompt\n  claim-task:fail        -> abort\n  prepare-prompt:success -> develop\n  prepare-prompt:fail    -> abort\n  develop:success        -> merge\n  develop:fail           -> abort\n  merge:success          -> cleanup\n  merge:fail             -> abort\n  cleanup:success        -> done\n  cleanup:fail           -> done\n}\n\nworkflow \"release-task\" {\n  step release-task {\n    run     = \"bash .cloche/scripts/release-task.sh\"\n    results = [success, fail]\n  }\n\n  release-task:success -> done\n  release-task:fail    -> abort\n}\n\nworkflow \"finalize\" {\n  step close-task {\n    run     = \"bash .cloche/scripts/close-task.sh\"\n    results = [success, fail]\n  }\n\n  close-task:success -> done\n  close-task:fail    -> done\n}\n","numLines":72,"startLine":1,"totalLines":72}}}
