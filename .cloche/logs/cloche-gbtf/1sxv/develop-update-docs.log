{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TWY27p57c6YqzjkvHBtv2K","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# release-task.sh — Release a stale claimed task back to open status.\n     3→# Uses CLOCHE_TASK_ID env var set by the caller.\n     4→set -euo pipefail\n     5→\n     6→TASK_ID=\"${CLOCHE_TASK_ID:-}\"\n     7→\n     8→if [ -z \"$TASK_ID\" ]; then\n     9→  echo \"error: CLOCHE_TASK_ID not set\" >&2\n    10→  exit 1\n    11→fi\n    12→\n    13→# Return the ticket to open status and unassign the owner.\n    14→bd update \"$TASK_ID\" -s open 2>&1\n    15→echo \"Released task $TASK_ID\"\n    16→"}]},"parent_tool_use_id":null,"session_id":"0a1eb545-c5fc-4d99-8df4-f479f783e58f","uuid":"fbf6a481-8ed0-4e8b-acd3-d32be8317209","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.cloche/scripts/release-task.sh","content":"#!/usr/bin/env bash\n# release-task.sh — Release a stale claimed task back to open status.\n# Uses CLOCHE_TASK_ID env var set by the caller.\nset -euo pipefail\n\nTASK_ID=\"${CLOCHE_TASK_ID:-}\"\n\nif [ -z \"$TASK_ID\" ]; then\n  echo \"error: CLOCHE_TASK_ID not set\" >&2\n  exit 1\nfi\n\n# Return the ticket to open status and unassign the owner.\nbd update \"$TASK_ID\" -s open 2>&1\necho \"Released task $TASK_ID\"\n","numLines":16,"startLine":1,"totalLines":16}}}
