{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018v29XuwrFmukyNdbjUYwiZ","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# close-task.sh — Close the task after main completes.\n     3→# Runs in the finalize phase. Uses CLOCHE_TASK_ID env var and\n     4→# CLOCHE_MAIN_OUTCOME to decide whether to close or reopen.\n     5→set -euo pipefail\n     6→\n     7→TASK_ID=\"${CLOCHE_TASK_ID:-}\"\n     8→OUTCOME=\"${CLOCHE_MAIN_OUTCOME:-failed}\"\n     9→\n    10→if [ -z \"$TASK_ID\" ]; then\n    11→  echo \"warning: CLOCHE_TASK_ID not set, skipping\" >&2\n    12→  exit 0\n    13→fi\n    14→\n    15→if [ \"$OUTCOME\" = \"succeeded\" ]; then\n    16→  bd close \"$TASK_ID\" 2>/dev/null && echo \"Closed task $TASK_ID\" || echo \"warning: could not close task $TASK_ID\" >&2\n    17→else\n    18→  echo \"Main outcome was $OUTCOME — task $TASK_ID left open for retry\"\n    19→fi\n    20→"}]},"parent_tool_use_id":null,"session_id":"09a1d66f-c28d-47e8-9d4e-ccb126644895","uuid":"a53c58ad-7d34-4314-964d-8e58d970fda8","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.cloche/scripts/close-task.sh","content":"#!/usr/bin/env bash\n# close-task.sh — Close the task after main completes.\n# Runs in the finalize phase. Uses CLOCHE_TASK_ID env var and\n# CLOCHE_MAIN_OUTCOME to decide whether to close or reopen.\nset -euo pipefail\n\nTASK_ID=\"${CLOCHE_TASK_ID:-}\"\nOUTCOME=\"${CLOCHE_MAIN_OUTCOME:-failed}\"\n\nif [ -z \"$TASK_ID\" ]; then\n  echo \"warning: CLOCHE_TASK_ID not set, skipping\" >&2\n  exit 0\nfi\n\nif [ \"$OUTCOME\" = \"succeeded\" ]; then\n  bd close \"$TASK_ID\" 2>/dev/null && echo \"Closed task $TASK_ID\" || echo \"warning: could not close task $TASK_ID\" >&2\nelse\n  echo \"Main outcome was $OUTCOME — task $TASK_ID left open for retry\"\nfi\n","numLines":20,"startLine":1,"totalLines":20}}}
