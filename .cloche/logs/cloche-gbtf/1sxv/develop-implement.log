.Get(\"sha\")\n  1342→\tif file == \"\" || sha == \"\" {\n  1343→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1344→\t\treturn\n  1345→\t}\n  1346→\n  1347→\t// Validate sha is alphanumeric to prevent injection\n  1348→\tfor _, c := range sha {\n  1349→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1350→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1351→\t\t\treturn\n  1352→\t\t}\n  1353→\t}\n  1354→\n  1355→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1356→\tcmd.Dir = dir\n  1357→\tout, err := cmd.Output()\n  1358→\tif err != nil {\n  1359→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1360→\t\treturn\n  1361→\t}\n  1362→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1363→\tw.Write(out)\n  1364→}\n  1365→\n  1366→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1367→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1368→\tif !ok {\n  1369→\t\treturn\n  1370→\t}\n  1371→\n  1372→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1373→\tentries, err := os.ReadDir(clocheDir)\n  1374→\tif err != nil {\n  1375→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1376→\t\tjson.NewEncoder(w).Encode([]any{})\n  1377→\t\treturn\n  1378→\t}\n  1379→\n  1380→\ttype apiWire struct {\n  1381→\t\tFrom   string `json:\"from\"`\n  1382→\t\tResult string `json:\"result\"`\n  1383→\t\tTo     string `json:\"to\"`\n  1384→\t}\n  1385→\ttype apiStepDef struct {\n  1386→\t\tName    string            `json:\"name\"`\n  1387→\t\tType    string            `json:\"type\"`\n  1388→\t\tResults []string          `json:\"results\"`\n  1389→\t\tConfig  map[string]string `json:\"config\"`\n  1390→\t}\n  1391→\ttype apiWorkflow struct {"}]},"parent_tool_use_id":"toolu_01TmKptVZFDRzmP4Wt7ZGDxG","session_id":"09a1d66f-c28d-47e8-9d4e-ccb126644895","uuid":"dcd45027-2617-4f26-9b12-f34ba6375eb5"}
