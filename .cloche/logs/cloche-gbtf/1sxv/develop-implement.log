{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MeZieqqxyHdDFK7cFNChux","type":"tool_result","content":"  1866→\n  1867→// --- Tasks API tests ---\n  1868→\n  1869→// mockTaskProvider implements TaskProvider for testing.\n  1870→type mockTaskProvider struct {\n  1871→\ttasks map[string][]TaskEntry // projectDir -> tasks\n  1872→}\n  1873→\n  1874→func (m *mockTaskProvider) GetLoopTasks(projectDir string) []TaskEntry {\n  1875→\treturn m.tasks[projectDir]\n  1876→}\n  1877→\n  1878→func TestAPITasks_WithTasks(t *testing.T) {\n  1879→\th, store := setupHandler(t)\n  1880→\tctx := context.Background()\n  1881→\n  1882→\t// Seed a project so the label resolver works.\n  1883→\tprojectDir := \"/home/user/projects/myapp\"\n  1884→\trun := domain.NewRun(\"run-1\", \"develop\")\n  1885→\trun.ProjectDir = projectDir\n  1886→\trequire.NoError(t, store.CreateRun(ctx, run))\n  1887→\n  1888→\t// Set up mock task provider.\n  1889→\ttp := &mockTaskProvider{\n  1890→\t\ttasks: map[string][]TaskEntry{\n  1891→\t\t\tprojectDir: {\n  1892→\t\t\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\", Assigned: true, AssignedAt: \"2026-03-11T10:00:00Z\", RunID: \"run-fix-bug\"},\n  1893→\t\t\t\t{ID: \"task-2\", Status: \"open\", Title: \"Add feature\", Assigned: false},\n  1894→\t\t\t\t{ID: \"task-3\", Status: \"closed\", Title: \"Done thing\", Assigned: false},\n  1895→\t\t\t},\n  1896→\t\t},\n  1897→\t}\n  1898→\th.taskProvider = tp\n  1899→\n  1900→\treq := httptest.NewRequest(\"GET\", \"/api/projects/myapp/tasks\", nil)\n  1901→\tw := httptest.NewRecorder()\n  1902→\th.ServeHTTP(w, req)\n  1903→\n  1904→\tassert.Equal(t, http.StatusOK, w.Code)\n  1905→\tassert.Equal(t, \"application/json\", w.Header().Get(\"Content-Type\"))\n  1906→\n  1907→\tvar tasks []TaskEntry\n  1908→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &tasks))\n  1909→\tassert.Len(t, tasks, 3)\n  1910→\n  1911→\tassert.Equal(t, \"task-1\", tasks[0].ID)\n  1912→\tassert.True(t, tasks[0].Assigned)\n  1913→\tassert.Equal(t, \"run-fix-bug\", tasks[0].RunID)\n  1914→\n  1915→\tassert.Equal(t, \"task-2\", tasks[1].ID)\n  1916→\tassert.False(t, tasks[1].Assigned)\n  1917→\n  1918→\tassert.Equal(t, \"task-3\", tasks[2].ID)\n  1919→\tassert.Equal(t, \"closed\", tasks[2].Status)\n  1920→}\n  1921→\n  1922→func TestAPITasks_NoTaskProvider(t *testing.T) {\n  1923→\th, store := setupHandler(t)\n  1924→\tctx := context.Background()\n  1925→\n  1926→\t// Seed a project.\n  1927→\tprojectDir := \"/home/user/projects/myapp\"\n  1928→\trun := domain.NewRun(\"run-1\", \"develop\")\n  1929→\trun.ProjectDir = projectDir\n  1930→\trequire.NoError(t, store.CreateRun(ctx, run))\n  1931→\n  1932→\t// No task provider set — should return empty array.\n  1933→\treq := httptest.NewRequest(\"GET\", \"/api/projects/myapp/tasks\", nil)\n  1934→\tw := httptest.NewRecorder()\n  1935→\th.ServeHTTP(w, req)\n  1936→\n  1937→\tassert.Equal(t, http.StatusOK, w.Code)\n  1938→\tvar tasks []TaskEntry\n  1939→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &tasks))\n  1940→\tassert.Empty(t, tasks)\n  1941→}\n  1942→\n  1943→func TestAPITasks_NoLoop(t *testing.T) {\n  1944→\th, store := setupHandler(t)\n  1945→\tctx := context.Background()\n  1946→\n  1947→\tprojectDir := \"/home/user/projects/myapp\"\n  1948→\trun := domain.NewRun(\"run-1\", \"develop\")\n  1949→\trun.ProjectDir = projectDir\n  1950→\trequire.NoError(t, store.CreateRun(ctx, run))\n  1951→\n  1952→\t// Task provider returns nil (no loop active for project).\n  1953→\ttp := &mockTaskProvider{tasks: map[string][]TaskEntry{}}\n  1954→\th.taskProvider = tp\n  1955→\n  1956→\treq := httptest.NewRequest(\"GET\", \"/api/projects/myapp/tasks\", nil)\n  1957→\tw := httptest.NewRecorder()\n  1958→\th.ServeHTTP(w, req)\n  1959→\n  1960→\tassert.Equal(t, http.StatusOK, w.Code)\n  1961→\tvar tasks []TaskEntry\n  1962→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &tasks))\n  1963→\tassert.Empty(t, tasks)\n  1964→}\n  1965→\n  1966→func TestAPITasks_ProjectNotFound(t *testing.T) {\n  1967→\th, _ := setupHandler(t)\n  1968→\n  1969→\treq := httptest.NewRequest(\"GET\", \"/api/projects/nonexistent/tasks\", nil)\n  1970→\tw := httptest.NewRecorder()\n  1971→\th.ServeHTTP(w, req)\n  1972→\n  1973→\tassert.Equal(t, http.StatusNotFound, w.Code)\n  1974→}\n  1975→"}]},"parent_tool_use_id":null,"session_id":"09a1d66f-c28d-47e8-9d4e-ccb126644895","uuid":"fa20a39e-b676-43b3-be10-36cb044b9dea","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler_test.go","content":"\n// --- Tasks API tests ---\n\n// mockTaskProvider implements TaskProvider for testing.\ntype mockTaskProvider struct {\n\ttasks map[string][]TaskEntry // projectDir -> tasks\n}\n\nfunc (m *mockTaskProvider) GetLoopTasks(projectDir string) []TaskEntry {\n\treturn m.tasks[projectDir]\n}\n\nfunc TestAPITasks_WithTasks(t *testing.T) {\n\th, store := setupHandler(t)\n\tctx := context.Background()\n\n\t// Seed a project so the label resolver works.\n\tprojectDir := \"/home/user/projects/myapp\"\n\trun := domain.NewRun(\"run-1\", \"develop\")\n\trun.ProjectDir = projectDir\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\t// Set up mock task provider.\n\ttp := &mockTaskProvider{\n\t\ttasks: map[string][]TaskEntry{\n\t\t\tprojectDir: {\n\t\t\t\t{ID: \"task-1\", Status: \"open\", Title: \"Fix bug\", Assigned: true, AssignedAt: \"2026-03-11T10:00:00Z\", RunID: \"run-fix-bug\"},\n\t\t\t\t{ID: \"task-2\", Status: \"open\", Title: \"Add feature\", Assigned: false},\n\t\t\t\t{ID: \"task-3\", Status: \"closed\", Title: \"Done thing\", Assigned: false},\n\t\t\t},\n\t\t},\n\t}\n\th.taskProvider = tp\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/myapp/tasks\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Equal(t, \"application/json\", w.Header().Get(\"Content-Type\"))\n\n\tvar tasks []TaskEntry\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &tasks))\n\tassert.Len(t, tasks, 3)\n\n\tassert.Equal(t, \"task-1\", tasks[0].ID)\n\tassert.True(t, tasks[0].Assigned)\n\tassert.Equal(t, \"run-fix-bug\", tasks[0].RunID)\n\n\tassert.Equal(t, \"task-2\", tasks[1].ID)\n\tassert.False(t, tasks[1].Assigned)\n\n\tassert.Equal(t, \"task-3\", tasks[2].ID)\n\tassert.Equal(t, \"closed\", tasks[2].Status)\n}\n\nfunc TestAPITasks_NoTaskProvider(t *testing.T) {\n\th, store := setupHandler(t)\n\tctx := context.Background()\n\n\t// Seed a project.\n\tprojectDir := \"/home/user/projects/myapp\"\n\trun := domain.NewRun(\"run-1\", \"develop\")\n\trun.ProjectDir = projectDir\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\t// No task provider set — should return empty array.\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/myapp/tasks\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tvar tasks []TaskEntry\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &tasks))\n\tassert.Empty(t, tasks)\n}\n\nfunc TestAPITasks_NoLoop(t *testing.T) {\n\th, store := setupHandler(t)\n\tctx := context.Background()\n\n\tprojectDir := \"/home/user/projects/myapp\"\n\trun := domain.NewRun(\"run-1\", \"develop\")\n\trun.ProjectDir = projectDir\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\t// Task provider returns nil (no loop active for project).\n\ttp := &mockTaskProvider{tasks: map[string][]TaskEntry{}}\n\th.taskProvider = tp\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/myapp/tasks\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tvar tasks []TaskEntry\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &tasks))\n\tassert.Empty(t, tasks)\n}\n\nfunc TestAPITasks_ProjectNotFound(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/nonexistent/tasks\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n","numLines":110,"startLine":1866,"totalLines":2386}}}
