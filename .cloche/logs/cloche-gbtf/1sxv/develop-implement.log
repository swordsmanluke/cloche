{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RM4JwQbmhP2RWMoWVN4E4x","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"time\"\n     8→\n     9→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    10→\t\"google.golang.org/grpc\"\n    11→\t\"google.golang.org/grpc/credentials/insecure\"\n    12→)\n    13→\n    14→func cmdProject(args []string) {\n    15→\tvar name string\n    16→\n    17→\tfor i := 0; i < len(args); i++ {\n    18→\t\tswitch args[i] {\n    19→\t\tcase \"--name\":\n    20→\t\t\tif i+1 < len(args) {\n    21→\t\t\t\ti++\n    22→\t\t\t\tname = args[i]\n    23→\t\t\t}\n    24→\t\t}\n    25→\t}\n    26→\n    27→\t// Connect to daemon.\n    28→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    29→\tif addr == \"\" {\n    30→\t\taddr = \"unix:///tmp/cloche.sock\"\n    31→\t}\n    32→\n    33→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n    34→\tif err != nil {\n    35→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n    36→\t\tos.Exit(1)\n    37→\t}\n    38→\tdefer conn.Close()\n    39→\n    40→\tclient := pb.NewClocheServiceClient(conn)\n    41→\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n    42→\tdefer cancel()\n    43→\n    44→\treq := &pb.GetProjectInfoRequest{}\n    45→\tif name != \"\" {\n    46→\t\treq.Name = name\n    47→\t} else {\n    48→\t\tcwd, _ := os.Getwd()\n    49→\t\treq.ProjectDir = cwd\n    50→\t}\n    51→\n    52→\tresp, err := client.GetProjectInfo(ctx, req)\n    53→\tif err != nil {\n    54→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    55→\t\tos.Exit(1)\n    56→\t}\n    57→\n    58→\t// Display project info.\n    59→\tfmt.Printf(\"Project:     %s\\n\", resp.Name)\n    60→\tfmt.Printf(\"Directory:   %s\\n\", resp.ProjectDir)\n    61→\tfmt.Println()\n    62→\n    63→\t// Config settings.\n    64→\tfmt.Println(\"Config:\")\n    65→\tfmt.Printf(\"  active:             %v\\n\", resp.Active)\n    66→\tfmt.Printf(\"  concurrency:        %d\\n\", resp.Concurrency)\n    67→\tif resp.StaggerSeconds > 0 {\n    68→\t\tfmt.Printf(\"  stagger_seconds:    %.1f\\n\", resp.StaggerSeconds)\n    69→\t}\n    70→\tif resp.DedupSeconds > 0 {\n    71→\t\tfmt.Printf(\"  dedup_seconds:      %.0f\\n\", resp.DedupSeconds)\n    72→\t}\n    73→\tfmt.Printf(\"  evolution:          %v\\n\", resp.EvolutionEnabled)\n    74→\tfmt.Println()\n    75→\n    76→\t// Orchestrator loop state.\n    77→\tloopState := \"stopped\"\n    78→\tif resp.LoopRunning {\n    79→\t\tloopState = \"running\"\n    80→\t}\n    81→\tfmt.Printf(\"Loop:        %s\\n\", loopState)\n    82→\tfmt.Println()\n    83→\n    84→\t// Active runs.\n    85→\tif len(resp.ActiveRuns) > 0 {\n    86→\t\tfmt.Printf(\"Active runs: %d\\n\", len(resp.ActiveRuns))\n    87→\t\tfor _, run := range resp.ActiveRuns {\n    88→\t\t\trunType := \"container\"\n    89→\t\t\tif run.IsHost {\n    90→\t\t\t\trunType = \"host\"\n    91→\t\t\t}\n    92→\t\t\tline := fmt.Sprintf(\"  %s  %-20s  %-10s  %s\", run.RunId, run.WorkflowName, run.State, runType)\n    93→\t\t\tif run.Title != \"\" {\n    94→\t\t\t\tt := run.Title\n    95→\t\t\t\tif len(t) > 40 {\n    96→\t\t\t\t\tt = t[:37] + \"...\"\n    97→\t\t\t\t}\n    98→\t\t\t\tline += \"  \" + t\n    99→\t\t\t}\n   100→\t\t\tfmt.Println(line)\n   101→\t\t}\n   102→\t} else {\n   103→\t\tfmt.Println(\"Active runs: none\")\n   104→\t}\n   105→\tfmt.Println()\n   106→\n   107→\t// Workflows.\n   108→\tif len(resp.ContainerWorkflows) > 0 {\n   109→\t\tfmt.Println(\"Container workflows:\")\n   110→\t\tfor _, wfName := range resp.ContainerWorkflows {\n   111→\t\t\tfmt.Printf(\"  %s\\n\", wfName)\n   112→\t\t}\n   113→\t} else {\n   114→\t\tfmt.Println(\"Container workflows: none\")\n   115→\t}\n   116→\n   117→\tif len(resp.HostWorkflows) > 0 {\n   118→\t\tfmt.Println(\"Host workflows:\")\n   119→\t\tfor _, wfName := range resp.HostWorkflows {\n   120→\t\t\tfmt.Printf(\"  %s\\n\", wfName)\n   121→\t\t}\n   122→\t} else {\n   123→\t\tfmt.Println(\"Host workflows: none\")\n   124→\t}\n   125→}\n   126→"}]},"parent_tool_use_id":"toolu_01TmKptVZFDRzmP4Wt7ZGDxG","session_id":"09a1d66f-c28d-47e8-9d4e-ccb126644895","uuid":"2aa79471-d4c8-4df3-a67d-cf0a6f55f479"}
