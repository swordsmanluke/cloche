{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vet7KqVqv6QAK85vbQfSr8","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# ready-tasks.sh — Output open tasks as JSONL for the daemon to parse.\n     3→# Each line is a JSON object with at least: id, status, title, description.\n     4→# The daemon picks which task to assign; this script just reports what's available.\n     5→set -euo pipefail\n     6→\n     7→# bd list --json outputs a JSON array; convert to JSONL (one object per line).\n     8→json=$(bd list -s open --json 2>/dev/null) || json=\"[]\"\n     9→\n    10→# Empty array means no work — exit 0 with no output (daemon sees zero tasks).\n    11→if [ \"$json\" = \"[]\" ] || [ -z \"$json\" ]; then\n    12→  exit 0\n    13→fi\n    14→\n    15→# Convert JSON array to JSONL\n    16→echo \"$json\" | jq -c '.[]'\n    17→"}]},"parent_tool_use_id":"toolu_01TmKptVZFDRzmP4Wt7ZGDxG","session_id":"09a1d66f-c28d-47e8-9d4e-ccb126644895","uuid":"f195daa5-7220-481a-b3ea-a438f0ebf106"}
