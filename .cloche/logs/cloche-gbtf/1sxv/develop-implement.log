{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HpowkR7Lw6DTZ45DTUdTkG","type":"tool_result","content":"   100→\n   101→// NewHandler creates a web dashboard handler.\n   102→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n   103→\tfuncMap := template.FuncMap{\n   104→\t\t\"stateColor\":       stateColor,\n   105→\t\t\"healthColor\":      healthColor,\n   106→\t\t\"formatTime\":       formatTime,\n   107→\t\t\"formatDuration\":   formatDuration,\n   108→\t\t\"formatRunTiming\":  formatRunTiming,\n   109→\t\t\"truncate\":         truncate,\n   110→\t\t\"shortContainerID\": shortContainerID,\n   111→\t\t\"jsonMap\":          jsonMap,\n   112→\t}\n   113→\n   114→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   115→\tif err != nil {\n   116→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   117→\t}\n   118→\n   119→\tpages := map[string]*template.Template{}\n   120→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   121→\t\tclone, err := base.Clone()\n   122→\t\tif err != nil {\n   123→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   124→\t\t}\n   125→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   126→\t\tif err != nil {\n   127→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   128→\t\t}\n   129→\t\tpages[page] = clone\n   130→\t}\n   131→\n   132→\th := &Handler{\n   133→\t\tstore:    store,\n   134→\t\tcaptures: captures,\n   135→\t\tpages:    pages,\n   136→\t\tmux:      http.NewServeMux(),\n   137→\t}\n   138→\tfor _, opt := range opts {\n   139→\t\topt(h)\n   140→\t}\n   141→\n   142→\tstaticFS, err := fs.Sub(content, \"static\")\n   143→\tif err != nil {\n   144→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   145→\t}\n   146→\n   147→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   148→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   149→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   150→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   151→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   152→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   153→\th.mux.HandleFunc(\"GET /api/projects/{name}/runs\", h.handleAPIProjectRuns)\n   154→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   155→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   156→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   157→\th.mux.HandleFunc(\"POST /api/runs/{id}/stop\", h.handleAPIStopRun)\n   158→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   159→\th.mux.HandleFunc(\"DELETE /api/projects/{name}/containers\", h.handleAPIDeleteProjectContainers)\n   160→\th.mux.HandleFunc(\"DELETE /api/containers\", h.handleAPIDeleteAllContainers)\n   161→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   162→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   163→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   164→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   165→\th.mux.HandleFunc(\"GET /api/projects/{name}/tasks\", h.handleAPITasks)\n   166→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   167→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   168→\n   169→\treturn h, nil\n   170→}\n   171→\n   172→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   173→\th.mux.ServeHTTP(w, r)\n   174→}\n   175→\n   176→// --- HTML handlers ---\n   177→\n   178→// projectOverviewEntry holds data for a single project card on the landing page.\n   179→type projectOverviewEntry struct {\n   180→\tDir         string\n   181→\tLabel       string\n   182→\tHealth      domain.HealthResult\n   183→\tRecentRuns  []recentRunDot\n   184→\tActiveCount int\n   185→}\n   186→\n   187→// recentRunDot is a minimal representation of a run for the mini history display.\n   188→type recentRunDot struct {\n   189→\tID    string\n   190→\tState string\n   191→}\n   192→\n   193→const healthWindowSize = 10\n   194→\n   195→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   196→\tprojects, _ := h.store.ListProjects(r.Context())\n   197→\tlabels := projectLabels(projects)\n   198→\n   199→\tvar entries []projectOverviewEntry\n   200→\tfor _, dir := range projects {\n   201→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   202→\t\tif err != nil {\n   203→\t\t\tcontinue\n   204→\t\t}\n   205→\n   206→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   207→\t\trunValues := make([]domain.Run, len(runs))\n   208→\t\tfor i, rr := range runs {\n   209→\t\t\trunValues[i] = *rr\n   210→\t\t}\n   211→\n   212→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   213→\n   214→\t\t// Take the last N runs for the mini history (most recent first).\n   215→\t\tn := healthWindowSize\n   216→\t\tif n > len(runs) {\n   217→\t\t\tn = len(runs)\n   218→\t\t}\n   219→\t\tdots := make([]recentRunDot, n)\n   220→\t\tfor i := 0; i < n; i++ {\n   221→\t\t\tdots[i] = recentRunDot{\n   222→\t\t\t\tID:    runs[i].ID,\n   223→\t\t\t\tState: string(runs[i].State),\n   224→\t\t\t}\n   225→\t\t}\n   226→\n   227→\t\tvar activeCount int\n   228→\t\tfor _, rr := range runs {\n   229→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   230→\t\t\t\tactiveCount++\n   231→\t\t\t}\n   232→\t\t}\n   233→\n   234→\t\tentries = append(entries, projectOverviewEntry{\n   235→\t\t\tDir:         dir,\n   236→\t\t\tLabel:       labels[dir],\n   237→\t\t\tHealth:      health,\n   238→\t\t\tRecentRuns:  dots,\n   239→\t\t\tActiveCount: activeCount,\n   240→\t\t})\n   241→\t}\n   242→\n   243→\tsort.Slice(entries, func(i, j int) bool {\n   244→\t\treturn entries[i].Label < entries[j].Label\n   245→\t})\n   246→\n   247→\tdata := map[string]any{\n   248→\t\t\"Title\":    \"Projects\",\n   249→\t\t\"Projects\": entries,"}]},"parent_tool_use_id":"toolu_01TmKptVZFDRzmP4Wt7ZGDxG","session_id":"09a1d66f-c28d-47e8-9d4e-ccb126644895","uuid":"bc2d2348-fccb-40be-b943-0727cd722e03"}
