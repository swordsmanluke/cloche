{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TiRKovYG1ZhjkPKrWwZhc8","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"sync\"\n    10→\t\"time\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14→)\n    15→\n    16→const (\n    17→\tdefaultMaxConcurrent = 1\n    18→\tdefaultDedupTimeout  = 5 * time.Minute\n    19→\tidlePollInterval     = 2 * time.Minute\n    20→\tcapacityPollInterval = 30 * time.Second\n    21→)\n    22→\n    23→// LoopConfig holds configuration for an orchestration loop.\n    24→type LoopConfig struct {\n    25→\tProjectDir    string\n    26→\tMaxConcurrent int\n    27→\tStaggerDelay  time.Duration // delay between launching consecutive runs\n    28→\tDedupTimeout  time.Duration // how long to suppress reassignment of the same task ID\n    29→}\n    30→\n    31→// ListTasksFunc is called to discover available tasks. It should run the\n    32→// list-tasks workflow (or equivalent) and return the parsed tasks.\n    33→type ListTasksFunc func(ctx context.Context, projectDir string) ([]Task, error)\n    34→\n    35→// MainFunc is called to execute the main workflow for a given task.\n    36→type MainFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n    37→\n    38→// FinalizeFunc is called after the main workflow completes (both success and\n    39→// failure). It receives the task ID and the outcome of the main phase.\n    40→type FinalizeFunc func(ctx context.Context, projectDir string, taskID string, mainResult *RunResult) (*RunResult, error)\n    41→\n    42→// RunFunc is the legacy function signature for launching a host workflow run.\n    43→// When taskID is non-empty, the runner should propagate it as CLOCHE_TASK_ID.\n    44→type RunFunc func(ctx context.Context, projectDir string, taskID string) (*RunResult, error)\n    45→\n    46→// TaskAssignment tracks the assignment state of a task.\n    47→type TaskAssignment struct {\n    48→\tAssignedAt time.Time\n    49→\tRunID      string // run ID handling this task (set after main completes)\n    50→}\n    51→\n    52→// TaskStateEntry combines a task with its assignment state.\n    53→type TaskStateEntry struct {\n    54→\tTask       Task\n    55→\tAssigned   bool\n    56→\tAssignedAt time.Time\n    57→\tRunID      string // empty if not yet known\n    58→}\n    59→\n    60→// Loop manages a continuous orchestration loop for a project, keeping up to\n    61→// MaxConcurrent host workflow runs active at all times when work is available.\n    62→//\n    63→// When configured with three-phase functions (list-tasks, main, finalize), the\n    64→// loop discovers tasks via list-tasks, picks open ones, runs main for each, and\n    65→// then runs finalize on completion. When configured with a legacy RunFunc, it\n    66→// falls back to the single-function approach.\n    67→type Loop struct {\n    68→\tconfig     LoopConfig\n    69→\tlistTasks  ListTasksFunc\n    70→\tmainFn     MainFunc\n    71→\tfinalizeFn FinalizeFunc // optional; skipped if nil\n    72→\trunner     RunFunc      // legacy single-function mode\n    73→\tstore      ports.RunStore\n    74→\tassigner   TaskAssigner // optional; legacy task assignment\n    75→\tstopCh     chan struct{}\n    76→\tmu         sync.Mutex\n    77→\trunning    bool\n    78→\tdedupMu    sync.Mutex\n    79→\tdedup      map[string]time.Time // task ID -> last assignment time\n    80→\ttasksMu    sync.RWMutex\n    81→\tlastTasks  []Task                    // most recently fetched tasks\n    82→\ttaskRuns   map[string]TaskAssignment // task ID -> assignment info\n    83→}\n    84→\n    85→// NewLoop creates an orchestration loop using a single run function (legacy mode).\n    86→// For three-phase orchestration, use NewPhaseLoop instead.\n    87→func NewLoop(cfg LoopConfig, store ports.RunStore, runFn RunFunc) *Loop {\n    88→\tif cfg.MaxConcurrent <= 0 {\n    89→\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n    90→\t}\n    91→\tif cfg.DedupTimeout <= 0 {\n    92→\t\tcfg.DedupTimeout = defaultDedupTimeout\n    93→\t}\n    94→\treturn &Loop{\n    95→\t\tconfig:   cfg,\n    96→\t\trunner:   runFn,\n    97→\t\tstore:    store,\n    98→\t\tdedup:    make(map[string]time.Time),\n    99→\t\ttaskRuns: make(map[string]TaskAssignment),\n   100→\t}\n   101→}\n   102→\n   103→// NewPhaseLoop creates a three-phase orchestration loop. The listTasksFn\n   104→// discovers available tasks, mainFn executes the main workflow for a task,\n   105→// and finalizeFn (optional) runs cleanup after main completes.\n   106→func NewPhaseLoop(cfg LoopConfig, store ports.RunStore, listTasksFn ListTasksFunc, mainFn MainFunc, finalizeFn FinalizeFunc) *Loop {\n   107→\tif cfg.MaxConcurrent <= 0 {\n   108→\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n   109→\t}\n   110→\tif cfg.DedupTimeout <= 0 {\n   111→\t\tcfg.DedupTimeout = defaultDedupTimeout\n   112→\t}\n   113→\treturn &Loop{\n   114→\t\tconfig:     cfg,\n   115→\t\tlistTasks:  listTasksFn,\n   116→\t\tmainFn:     mainFn,\n   117→\t\tfinalizeFn: finalizeFn,\n   118→\t\tstore:      store,\n   119→\t\tdedup:      make(map[string]time.Time),\n   120→\t\ttaskRuns:   make(map[string]TaskAssignment),\n   121→\t}\n   122→}\n   123→\n   124→// SetTaskAssigner configures a TaskAssigner for daemon-managed task assignment.\n   125→// Only used in legacy (single RunFunc) mode when no list-tasks function is set.\n   126→func (l *Loop) SetTaskAssigner(a TaskAssigner) {\n   127→\tl.assigner = a\n   128→}\n   129→\n   130→// Start begins the orchestration loop. No-op if already running.\n   131→func (l *Loop) Start() {\n   132→\tl.mu.Lock()\n   133→\tdefer l.mu.Unlock()\n   134→\tif l.running {\n   135→\t\treturn\n   136→\t}\n   137→\tl.running = true\n   138→\tl.stopCh = make(chan struct{})\n   139→\tgo l.run()\n   140→\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n   141→}\n   142→\n   143→// Stop signals the loop to stop. Active runs continue to completion.\n   144→func (l *Loop) Stop() {\n   145→\tl.mu.Lock()\n   146→\tdefer l.mu.Unlock()\n   147→\tif !l.running {\n   148→\t\treturn\n   149→\t}\n   150→\tl.running = false\n   151→\tclose(l.stopCh)\n   152→\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n   153→}\n   154→\n   155→// Running returns whether the loop is currently active.\n   156→func (l *Loop) Running() bool {\n   157→\tl.mu.Lock()\n   158→\tdefer l.mu.Unlock()\n   159→\treturn l.running\n   160→}\n   161→\n   162→func (l *Loop) run() {\n   163→\tif l.listTasks != nil && l.mainFn != nil {\n   164→\t\tl.runPhased()\n   165→\t} else {\n   166→\t\tl.runLegacy()\n   167→\t}\n   168→}\n   169→\n   170→// runPhased implements the three-phase orchestration loop:\n   171→// 1. list-tasks → discover available work\n   172→// 2. main → execute work for each open task (up to MaxConcurrent)\n   173→// 3. finalize → cleanup after main completes (on both success and failure)\n   174→func (l *Loop) runPhased() {\n   175→\ttype result struct {\n   176→\t\tstate domain.RunState\n   177→\t}\n   178→\n   179→\tcompletions := make(chan result, l.config.MaxConcurrent)\n   180→\tinFlight := 0\n   181→\n   182→\tfor {\n   183→\t\t// Fill up to max concurrent slots.\n   184→\t\tlaunched := 0\n   185→\t\tfor inFlight < l.config.MaxConcurrent {\n   186→\t\t\tselect {\n   187→\t\t\tcase <-l.stopCh:\n   188→\t\t\t\treturn\n   189→\t\t\tdefault:\n   190→\t\t\t}\n   191→\n   192→\t\t\t// Check how many host runs are active for this project.\n   193→\t\t\tactive := l.countActiveHostRuns()\n   194→\t\t\tif active >= l.config.MaxConcurrent {\n   195→\t\t\t\tbreak\n   196→\t\t\t}\n   197→\n   198→\t\t\t// Stagger consecutive launches.\n   199→\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   200→\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   201→\t\t\t\t\treturn\n   202→\t\t\t\t}\n   203→\t\t\t}\n   204→\n   205→\t\t\t// Phase 1: list-tasks — discover available work.\n   206→\t\t\ttaskID, ok := l.pickTaskFromPhase()\n   207→\t\t\tif !ok {\n   208→\t\t\t\tbreak // no assignable tasks\n   209→\t\t\t}\n   210→\n   211→\t\t\t// Launch main + finalize in a goroutine.\n   212→\t\t\tinFlight++\n   213→\t\t\tlaunched++\n   214→\t\t\ttid := taskID\n   215→\t\t\tgo func() {\n   216→\t\t\t\t// Phase 2: main — do the work.\n   217→\t\t\t\tmainResult, err := l.mainFn(context.Background(), l.config.ProjectDir, tid)\n   218→\t\t\t\tif err != nil {\n   219→\t\t\t\t\tlog.Printf(\"orchestration loop: main failed for %s task %s: %v\", l.config.ProjectDir, tid, err)\n   220→\t\t\t\t\tif mainResult == nil {\n   221→\t\t\t\t\t\tmainResult = &RunResult{State: domain.RunStateFailed}\n   222→\t\t\t\t\t}\n   223→\t\t\t\t}\n   224→\n   225→\t\t\t\t// Track the run ID for this task.\n   226→\t\t\t\tif mainResult != nil && mainResult.RunID != \"\" {\n   227→\t\t\t\t\tl.tasksMu.Lock()\n   228→\t\t\t\t\tl.taskRuns[tid] = TaskAssignment{\n   229→\t\t\t\t\t\tAssignedAt: time.Now(),\n   230→\t\t\t\t\t\tRunID:      mainResult.RunID,\n   231→\t\t\t\t\t}\n   232→\t\t\t\t\tl.tasksMu.Unlock()\n   233→\t\t\t\t}\n   234→\n   235→\t\t\t\t// Phase 3: finalize — cleanup (runs on both success and failure).\n   236→\t\t\t\tif l.finalizeFn != nil {\n   237→\t\t\t\t\t_, finalizeErr := l.finalizeFn(context.Background(), l.config.ProjectDir, tid, mainResult)\n   238→\t\t\t\t\tif finalizeErr != nil {\n   239→\t\t\t\t\t\tlog.Printf(\"orchestration loop: finalize failed for %s task %s: %v\", l.config.ProjectDir, tid, finalizeErr)\n   240→\t\t\t\t\t}\n   241→\t\t\t\t}\n   242→\n   243→\t\t\t\tcompletions <- result{state: mainResult.State}\n   244→\t\t\t}()\n   245→\t\t}\n   246→\n   247→\t\tif inFlight == 0 {\n   248→\t\t\t// Nothing in flight and couldn't launch anything — wait before checking again.\n   249→\t\t\tif !l.sleep(capacityPollInterval) {\n   250→\t\t\t\treturn\n   251→\t\t\t}\n   252→\t\t\tcontinue\n   253→\t\t}\n   254→\n   255→\t\t// Wait for any run to complete.\n   256→\t\tselect {\n   257→\t\tcase r := <-completions:\n   258→\t\t\tinFlight--\n   259→\t\t\tif r.state == domain.RunStateSucceeded {\n   260→\t\t\t\t// Work was done — try to fill slots immediately.\n   261→\t\t\t\tcontinue\n   262→\t\t\t}\n   263→\t\t\t// Run failed or aborted. Back off.\n   264→\t\t\tif !l.sleep(idlePollInterval) {\n   265→\t\t\t\treturn\n   266→\t\t\t}\n   267→\t\tcase <-l.stopCh:\n   268→\t\t\treturn\n   269→\t\t}\n   270→\t}\n   271→}\n   272→\n   273→// GetTaskSnapshot returns the current task pipeline state: the most recently\n   274→// fetched tasks with their assignment information.\n   275→func (l *Loop) GetTaskSnapshot() []TaskStateEntry {\n   276→\tl.tasksMu.RLock()\n   277→\ttasks := make([]Task, len(l.lastTasks))\n   278→\tcopy(tasks, l.lastTasks)\n   279→\tl.tasksMu.RUnlock()\n   280→\n   281→\tl.dedupMu.Lock()\n   282→\tdefer l.dedupMu.Unlock()\n   283→\n   284→\tnow := time.Now()\n   285→\tvar entries []TaskStateEntry\n   286→\tfor _, task := range tasks {\n   287→\t\tentry := TaskStateEntry{Task: task}\n   288→\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   289→\t\t\tentry.Assigned = true\n   290→\t\t\tentry.AssignedAt = ts\n   291→\t\t}\n   292→\n   293→\t\tl.tasksMu.RLock()\n   294→\t\tif a, ok := l.taskRuns[task.ID]; ok {\n   295→\t\t\tentry.RunID = a.RunID\n   296→\t\t\tif !entry.Assigned {\n   297→\t\t\t\tentry.AssignedAt = a.AssignedAt\n   298→\t\t\t}\n   299→\t\t}\n   300→\t\tl.tasksMu.RUnlock()\n   301→\n   302→\t\tentries = append(entries, entry)\n   303→\t}\n   304→\treturn entries\n   305→}\n   306→\n   307→// pickTaskFromPhase runs the list-tasks function and picks the first open,\n   308→// non-deduped task.\n   309→func (l *Loop) pickTaskFromPhase() (string, bool) {\n   310→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   311→\tdefer cancel()\n   312→\n   313→\ttasks, err := l.listTasks(ctx, l.config.ProjectDir)\n   314→\tif err != nil {\n   315→\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n   316→\t\treturn \"\", false\n   317→\t}\n   318→\n   319→\t// Cache the latest tasks for snapshot queries.\n   320→\tl.tasksMu.Lock()\n   321→\tl.lastTasks = tasks\n   322→\tl.tasksMu.Unlock()\n   323→\n   324→\tnow := time.Now()\n   325→\tl.dedupMu.Lock()\n   326→\tdefer l.dedupMu.Unlock()\n   327→\n   328→\t// Expire old dedup entries.\n   329→\tfor id, ts := range l.dedup {\n   330→\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n   331→\t\t\tdelete(l.dedup, id)\n   332→\t\t}\n   333→\t}\n   334→\n   335→\tfor _, task := range tasks {\n   336→\t\tif task.ID == \"\" {\n   337→\t\t\tcontinue\n   338→\t\t}\n   339→\t\tif !task.IsOpen() {\n   340→\t\t\tcontinue\n   341→\t\t}\n   342→\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   343→\t\t\tcontinue\n   344→\t\t}\n   345→\t\tl.dedup[task.ID] = now\n   346→\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n   347→\t\treturn task.ID, true\n   348→\t}\n   349→\n   350→\treturn \"\", false\n   351→}\n   352→\n   353→// runLegacy implements the original single-function orchestration loop.\n   354→func (l *Loop) runLegacy() {\n   355→\ttype result struct {\n   356→\t\tstate domain.RunState\n   357→\t}\n   358→\n   359→\tcompletions := make(chan result, l.config.MaxConcurrent)\n   360→\tinFlight := 0\n   361→\n   362→\tfor {\n   363→\t\t// Fill up to max concurrent slots.\n   364→\t\tlaunched := 0\n   365→\t\tfor inFlight < l.config.MaxConcurrent {\n   366→\t\t\tselect {\n   367→\t\t\tcase <-l.stopCh:\n   368→\t\t\t\treturn\n   369→\t\t\tdefault:\n   370→\t\t\t}\n   371→\n   372→\t\t\t// Check how many host runs are active for this project (in case of\n   373→\t\t\t// leftover runs from previous loops).\n   374→\t\t\tactive := l.countActiveHostRuns()\n   375→\t\t\tif active >= l.config.MaxConcurrent {\n   376→\t\t\t\tbreak\n   377→\t\t\t}\n   378→\n   379→\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n   380→\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   381→\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   382→\t\t\t\t\treturn\n   383→\t\t\t\t}\n   384→\t\t\t}\n   385→\n   386→\t\t\t// Determine task ID (if task assigner is configured).\n   387→\t\t\ttaskID := \"\"\n   388→\t\t\tif l.assigner != nil {\n   389→\t\t\t\tvar ok bool\n   390→\t\t\t\ttaskID, ok = l.pickTask()\n   391→\t\t\t\tif !ok {\n   392→\t\t\t\t\t// No assignable tasks available.\n   393→\t\t\t\t\tbreak\n   394→\t\t\t\t}\n   395→\t\t\t}\n   396→\n   397→\t\t\t// Launch a new orchestration run in a goroutine.\n   398→\t\t\tinFlight++\n   399→\t\t\tlaunched++\n   400→\t\t\ttid := taskID // capture for goroutine\n   401→\t\t\tgo func() {\n   402→\t\t\t\tres, err := l.runner(context.Background(), l.config.ProjectDir, tid)\n   403→\t\t\t\tif err != nil {\n   404→\t\t\t\t\tlog.Printf(\"orchestration loop: run failed for %s: %v\", l.config.ProjectDir, err)\n   405→\t\t\t\t\tcompletions <- result{state: domain.RunStateFailed}\n   406→\t\t\t\t\treturn\n   407→\t\t\t\t}\n   408→\t\t\t\tcompletions <- result{state: res.State}\n   409→\t\t\t}()\n   410→\t\t}\n   411→\n   412→\t\tif inFlight == 0 {\n   413→\t\t\t// Nothing in flight and at capacity — wait before checking again.\n   414→\t\t\tif !l.sleep(capacityPollInterval) {\n   415→\t\t\t\treturn\n   416→\t\t\t}\n   417→\t\t\tcontinue\n   418→\t\t}\n   419→\n   420→\t\t// Wait for any run to complete.\n   421→\t\tselect {\n   422→\t\tcase r := <-completions:\n   423→\t\t\tinFlight--\n   424→\t\t\tif r.state == domain.RunStateSucceeded {\n   425→\t\t\t\t// Work was done — try to fill slots immediately.\n   426→\t\t\t\tcontinue\n   427→\t\t\t}\n   428→\t\t\t// Run failed or aborted (no tasks available). Back off.\n   429→\t\t\tif !l.sleep(idlePollInterval) {\n   430→\t\t\t\treturn\n   431→\t\t\t}\n   432→\t\tcase <-l.stopCh:\n   433→\t\t\treturn\n   434→\t\t}\n   435→\t}\n   436→}\n   437→\n   438→// pickTask queries the task assigner for available tasks, filters out those\n   439→// within the dedup timeout window, and returns the first assignable task ID.\n   440→// It records the assignment time so the same task won't be picked again until\n   441→// the dedup timeout expires. Returns (\"\", false) if no tasks are available.\n   442→func (l *Loop) pickTask() (string, bool) {\n   443→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   444→\tdefer cancel()\n   445→\n   446→\ttasks, err := l.assigner.ListTasks(ctx, l.config.ProjectDir)\n   447→\tif err != nil {\n   448→\t\tlog.Printf(\"orchestration loop: list-tasks failed for %s: %v\", l.config.ProjectDir, err)\n   449→\t\treturn \"\", false\n   450→\t}\n   451→\n   452→\t// Cache the latest tasks for snapshot queries.\n   453→\tl.tasksMu.Lock()\n   454→\tl.lastTasks = tasks\n   455→\tl.tasksMu.Unlock()\n   456→\n   457→\tnow := time.Now()\n   458→\tl.dedupMu.Lock()\n   459→\tdefer l.dedupMu.Unlock()\n   460→\n   461→\t// Expire old dedup entries while we're here.\n   462→\tfor id, ts := range l.dedup {\n   463→\t\tif now.Sub(ts) >= l.config.DedupTimeout {\n   464→\t\t\tdelete(l.dedup, id)\n   465→\t\t}\n   466→\t}\n   467→\n   468→\tfor _, task := range tasks {\n   469→\t\tif task.ID == \"\" {\n   470→\t\t\tcontinue\n   471→\t\t}\n   472→\t\tif ts, ok := l.dedup[task.ID]; ok && now.Sub(ts) < l.config.DedupTimeout {\n   473→\t\t\tcontinue // still within dedup window\n   474→\t\t}\n   475→\t\t// Assign this task.\n   476→\t\tl.dedup[task.ID] = now\n   477→\t\tlog.Printf(\"orchestration loop: assigned task %s for %s\", task.ID, l.config.ProjectDir)\n   478→\t\treturn task.ID, true\n   479→\t}\n   480→\n   481→\treturn \"\", false\n   482→}\n   483→\n   484→// countActiveHostRuns counts running or pending host runs for the project.\n   485→func (l *Loop) countActiveHostRuns() int {\n   486→\tctx := context.Background()\n   487→\truns, err := l.store.ListRunsByProject(ctx, l.config.ProjectDir, time.Time{})\n   488→\tif err != nil {\n   489→\t\treturn 0\n   490→\t}\n   491→\tcount := 0\n   492→\tfor _, r := range runs {\n   493→\t\tif r.IsHost && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n   494→\t\t\tcount++\n   495→\t\t}\n   496→\t}\n   497→\treturn count\n   498→}\n   499→\n   500→// sleep waits for the given duration or until the loop is stopped.\n   501→// Returns false if the loop was stopped.\n   502→func (l *Loop) sleep(d time.Duration) bool {\n   503→\tselect {\n   504→\tcase <-time.After(d):\n   505→\t\treturn true\n   506→\tcase <-l.stopCh:\n   507→\t\treturn false\n   508→\t}\n   509→}\n   510→\n   511→// ReadListTasksOutput reads the output directory from a list-tasks workflow run\n   512→// and parses JSONL task output from the last step's output file.\n   513→func ReadListTasksOutput(outputDir string) ([]Task, error) {\n   514→\tentries, err := os.ReadDir(outputDir)\n   515→\tif err != nil {\n   516→\t\treturn nil, fmt.Errorf(\"reading list-tasks output dir: %w\", err)\n   517→\t}\n   518→\n   519→\t// Find the most recently modified .out file.\n   520→\tvar latest string\n   521→\tvar latestMod time.Time\n   522→\tfor _, e := range entries {\n   523→\t\tif e.IsDir() || filepath.Ext(e.Name()) != \".out\" {\n   524→\t\t\tcontinue\n   525→\t\t}\n   526→\t\tinfo, err := e.Info()\n   527→\t\tif err != nil {\n   528→\t\t\tcontinue\n   529→\t\t}\n   530→\t\tif latest == \"\" || info.ModTime().After(latestMod) {\n   531→\t\t\tlatest = e.Name()\n   532→\t\t\tlatestMod = info.ModTime()\n   533→\t\t}\n   534→\t}\n   535→\n   536→\tif latest == \"\" {\n   537→\t\treturn nil, fmt.Errorf(\"no output files found in %s\", outputDir)\n   538→\t}\n   539→\n   540→\tdata, err := os.ReadFile(filepath.Join(outputDir, latest))\n   541→\tif err != nil {\n   542→\t\treturn nil, fmt.Errorf(\"reading output file %s: %w\", latest, err)\n   543→\t}\n   544→\n   545→\treturn ParseTasksJSONL(string(data))\n   546→}\n   547→"}]},"parent_tool_use_id":"toolu_01TmKptVZFDRzmP4Wt7ZGDxG","session_id":"09a1d66f-c28d-47e8-9d4e-ccb126644895","uuid":"840f6815-d565-46b4-9494-0aca770d89ab"}
