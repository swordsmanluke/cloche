{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017yvirk7NQ65mXSxMfhkjf8","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"errors\"\n     7→\t\"fmt\"\n     8→\t\"io\"\n     9→\t\"net/http\"\n    10→\t\"os\"\n    11→\t\"os/exec\"\n    12→\t\"path/filepath\"\n    13→\t\"strconv\"\n    14→\t\"strings\"\n    15→\t\"time\"\n    16→\n    17→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    18→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    19→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    20→\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    21→\t\"github.com/cloche-dev/cloche/internal/version\"\n    22→\t\"google.golang.org/grpc\"\n    23→\t\"google.golang.org/grpc/credentials/insecure\"\n    24→\t\"google.golang.org/grpc/metadata\"\n    25→)\n    26→\n    27→func main() {\n    28→\tif len(os.Args) < 2 {\n    29→\t\tprintTopLevelHelp()\n    30→\t\tos.Exit(1)\n    31→\t}\n    32→\n    33→\t// Handle version flags before anything else\n    34→\tif os.Args[1] == \"-v\" || os.Args[1] == \"--version\" {\n    35→\t\tcmdVersion()\n    36→\t\treturn\n    37→\t}\n    38→\n    39→\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n    40→\tswitch os.Args[1] {\n    41→\tcase \"help\":\n    42→\t\tprintHelp(os.Args[2:])\n    43→\t\treturn\n    44→\tcase \"--help\", \"-h\":\n    45→\t\tprintTopLevelHelp()\n    46→\t\treturn\n    47→\t}\n    48→\n    49→\t// Commands that don't need a daemon connection\n    50→\tswitch os.Args[1] {\n    51→\tcase \"init\":\n    52→\t\tif hasHelpFlag(os.Args[2:]) {\n    53→\t\t\tprintSubcommandHelp(\"init\")\n    54→\t\t\treturn\n    55→\t\t}\n    56→\t\tcmdInit(os.Args[2:])\n    57→\t\treturn\n    58→\tcase \"health\":\n    59→\t\tif hasHelpFlag(os.Args[2:]) {\n    60→\t\t\tprintSubcommandHelp(\"health\")\n    61→\t\t\treturn\n    62→\t\t}\n    63→\t\tcmdHealth(os.Args[2:])\n    64→\t\treturn\n    65→\tcase \"get\":\n    66→\t\tif hasHelpFlag(os.Args[2:]) {\n    67→\t\t\tprintSubcommandHelp(\"get\")\n    68→\t\t\treturn\n    69→\t\t}\n    70→\t\tcmdGet(os.Args[2:])\n    71→\t\treturn\n    72→\tcase \"set\":\n    73→\t\tif hasHelpFlag(os.Args[2:]) {\n    74→\t\t\tprintSubcommandHelp(\"set\")\n    75→\t\t\treturn\n    76→\t\t}\n    77→\t\tcmdSet(os.Args[2:])\n    78→\t\treturn\n    79→\tcase \"tasks\":\n    80→\t\tif hasHelpFlag(os.Args[2:]) {\n    81→\t\t\tprintSubcommandHelp(\"tasks\")\n    82→\t\t\treturn\n    83→\t\t}\n    84→\t\tcmdTasks(os.Args[2:])\n    85→\t\treturn\n    86→\tcase \"workflow\":\n    87→\t\tif hasHelpFlag(os.Args[2:]) {\n    88→\t\t\tprintSubcommandHelp(\"workflow\")\n    89→\t\t\treturn\n    90→\t\t}\n    91→\t\tcmdWorkflow(os.Args[2:])\n    92→\t\treturn\n    93→\tcase \"project\":\n    94→\t\tif hasHelpFlag(os.Args[2:]) {\n    95→\t\t\tprintSubcommandHelp(\"project\")\n    96→\t\t\treturn\n    97→\t\t}\n    98→\t\tcmdProject(os.Args[2:])\n    99→\t\treturn\n   100→\t}\n   101→\n   102→\t// Handle --help for daemon commands before connecting\n   103→\tdaemonCmds := map[string]bool{\n   104→\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n   105→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n   106→\t}\n   107→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n   108→\t\tprintSubcommandHelp(os.Args[1])\n   109→\t\treturn\n   110→\t}\n   111→\n   112→\t// Commands that need a daemon connection\n   113→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   114→\tif addr == \"\" {\n   115→\t\taddr = \"unix:///tmp/cloche.sock\"\n   116→\t}\n   117→\n   118→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   119→\tif err != nil {\n   120→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   121→\t\tos.Exit(1)\n   122→\t}\n   123→\tdefer conn.Close()\n   124→\n   125→\tclient := pb.NewClocheServiceClient(conn)\n   126→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   127→\tdefer cancel()\n   128→\n   129→\tswitch os.Args[1] {\n   130→\tcase \"run\":\n   131→\t\tcmdRun(ctx, client, os.Args[2:])\n   132→\tcase \"status\":\n   133→\t\tcmdStatus(ctx, client, os.Args[2:])\n   134→\tcase \"logs\":\n   135→\t\tcmdLogs(client, os.Args[2:])\n   136→\tcase \"poll\":\n   137→\t\tcmdPoll(client, os.Args[2:])\n   138→\tcase \"list\":\n   139→\t\tcmdList(ctx, client, os.Args[2:])\n   140→\tcase \"stop\":\n   141→\t\tcmdStop(ctx, client, os.Args[2:])\n   142→\tcase \"delete\":\n   143→\t\tcmdDelete(ctx, client, os.Args[2:])\n   144→\tcase \"loop\":\n   145→\t\tcmdLoop(ctx, client, os.Args[2:])\n   146→\tcase \"shutdown\":\n   147→\t\tcmdShutdown(ctx, client)\n   148→\tdefault:\n   149→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   150→\t\tprintTopLevelHelp()\n   151→\t\tos.Exit(1)\n   152→\t}\n   153→}\n   154→\n   155→\n   156→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   157→\tvar workflow, prompt, title string\n   158→\tvar keepContainer bool\n   159→\n   160→\tfor i := 0; i < len(args); i++ {\n   161→\t\tswitch args[i] {\n   162→\t\tcase \"--workflow\":\n   163→\t\t\tif i+1 < len(args) {\n   164→\t\t\t\ti++\n   165→\t\t\t\tworkflow = args[i]\n   166→\t\t\t}\n   167→\t\tcase \"--prompt\", \"-p\":\n   168→\t\t\tif i+1 < len(args) {\n   169→\t\t\t\ti++\n   170→\t\t\t\tprompt = args[i]\n   171→\t\t\t}\n   172→\t\tcase \"--title\":\n   173→\t\t\tif i+1 < len(args) {\n   174→\t\t\t\ti++\n   175→\t\t\t\ttitle = args[i]\n   176→\t\t\t}\n   177→\t\tcase \"--keep-container\":\n   178→\t\t\tkeepContainer = true\n   179→\t\tdefault:\n   180→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   181→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   182→\t\t\t\tworkflow = args[i]\n   183→\t\t\t}\n   184→\t\t}\n   185→\t}\n   186→\n   187→\tif workflow == \"\" {\n   188→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   189→\t\tos.Exit(1)\n   190→\t}\n   191→\n   192→\tcwd, _ := os.Getwd()\n   193→\n   194→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   195→\tvar image string\n   196→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   197→\tif data, err := os.ReadFile(wfPath); err == nil {\n   198→\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   199→\t\t\timage = wf.Config[\"container.image\"]\n   200→\t\t}\n   201→\t}\n   202→\n   203→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   204→\t\tWorkflowName:  workflow,\n   205→\t\tProjectDir:    cwd,\n   206→\t\tImage:         image,\n   207→\t\tPrompt:        prompt,\n   208→\t\tKeepContainer: keepContainer,\n   209→\t\tTitle:         title,\n   210→\t})\n   211→\tif err != nil {\n   212→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   213→\t\tos.Exit(1)\n   214→\t}\n   215→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   216→}\n   217→\n   218→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   219→\tif len(args) < 1 {\n   220→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   221→\t\tos.Exit(1)\n   222→\t}\n   223→\n   224→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   225→\tif err != nil {\n   226→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   227→\t\tos.Exit(1)\n   228→\t}\n   229→\n   230→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   231→\tif resp.Title != \"\" {\n   232→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   233→\t}\n   234→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   235→\tif resp.IsHost {\n   236→\t\tfmt.Printf(\"Type:      host\\n\")\n   237→\t} else {\n   238→\t\tfmt.Printf(\"Type:      container\\n\")\n   239→\t}\n   240→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   241→\tif resp.ContainerId != \"\" {\n   242→\t\tcid := resp.ContainerId\n   243→\t\tif len(cid) > 12 {\n   244→\t\t\tcid = cid[:12]\n   245→\t\t}\n   246→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   247→\t}\n   248→\tif resp.ErrorMessage != \"\" {\n   249→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   250→\t}\n   251→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   252→\tfor _, exec := range resp.StepExecutions {\n   253→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   254→\t}\n   255→}\n   256→\n   257→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   258→\tvar all bool\n   259→\tvar projectDir, stateFilter, issueFilter string\n   260→\tvar limit int32\n   261→\n   262→\tfor i := 0; i < len(args); i++ {\n   263→\t\tswitch args[i] {\n   264→\t\tcase \"--all\":\n   265→\t\t\tall = true\n   266→\t\tcase \"--project\", \"-p\":\n   267→\t\t\tif i+1 < len(args) {\n   268→\t\t\t\ti++\n   269→\t\t\t\tprojectDir = args[i]\n   270→\t\t\t}\n   271→\t\tcase \"--state\", \"-s\":\n   272→\t\t\tif i+1 < len(args) {\n   273→\t\t\t\ti++\n   274→\t\t\t\tstateFilter = args[i]\n   275→\t\t\t}\n   276→\t\tcase \"--limit\", \"-n\":\n   277→\t\t\tif i+1 < len(args) {\n   278→\t\t\t\ti++\n   279→\t\t\t\tn, err := strconv.Atoi(args[i])\n   280→\t\t\t\tif err != nil {\n   281→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   282→\t\t\t\t\tos.Exit(1)\n   283→\t\t\t\t}\n   284→\t\t\t\tlimit = int32(n)\n   285→\t\t\t}\n   286→\t\tcase \"--issue\", \"-i\":\n   287→\t\t\tif i+1 < len(args) {\n   288→\t\t\t\ti++\n   289→\t\t\t\tissueFilter = args[i]\n   290→\t\t\t}\n   291→\t\t}\n   292→\t}\n   293→\n   294→\treq := &pb.ListRunsRequest{\n   295→\t\tState:  stateFilter,\n   296→\t\tLimit:  limit,\n   297→\t\tTaskId: issueFilter,\n   298→\t}\n   299→\tif projectDir != \"\" {\n   300→\t\treq.ProjectDir = projectDir\n   301→\t} else if all {\n   302→\t\treq.All = true\n   303→\t} else {\n   304→\t\t// Default: filter to current project\n   305→\t\tcwd, _ := os.Getwd()\n   306→\t\treq.ProjectDir = cwd\n   307→\t}\n   308→\n   309→\tresp, err := client.ListRuns(ctx, req)\n   310→\tif err != nil {\n   311→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   312→\t\tos.Exit(1)\n   313→\t}\n   314→\n   315→\tif len(resp.Runs) == 0 {\n   316→\t\tfmt.Println(\"No runs found.\")\n   317→\t\treturn\n   318→\t}\n   319→\n   320→\tfor _, run := range resp.Runs {\n   321→\t\trunType := \"container\"\n   322→\t\tif run.IsHost {\n   323→\t\t\trunType = \"host\"\n   324→\t\t}\n   325→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   326→\t\tif run.Title != \"\" {\n   327→\t\t\tt := run.Title\n   328→\t\t\tif len(t) > 40 {\n   329→\t\t\t\tt = t[:37] + \"...\"\n   330→\t\t\t}\n   331→\t\t\tline += \"  \" + t\n   332→\t\t}\n   333→\t\tif run.ContainerId != \"\" {\n   334→\t\t\tline += \"  \" + run.ContainerId\n   335→\t\t}\n   336→\t\tif run.ErrorMessage != \"\" {\n   337→\t\t\terrMsg := run.ErrorMessage\n   338→\t\t\tif len(errMsg) > 60 {\n   339→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   340→\t\t\t}\n   341→\t\t\tline += \"  \" + errMsg\n   342→\t\t}\n   343→\t\tfmt.Println(line)\n   344→\t}\n   345→}\n   346→\n   347→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   348→\tif len(args) < 1 {\n   349→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n   350→\t\tos.Exit(1)\n   351→\t}\n   352→\n   353→\tvar stepFilter, typeFilter string\n   354→\tvar follow bool\n   355→\trunID := args[0]\n   356→\n   357→\tfor i := 1; i < len(args); i++ {\n   358→\t\tswitch args[i] {\n   359→\t\tcase \"--step\":\n   360→\t\t\tif i+1 < len(args) {\n   361→\t\t\t\ti++\n   362→\t\t\t\tstepFilter = args[i]\n   363→\t\t\t}\n   364→\t\tcase \"--type\":\n   365→\t\t\tif i+1 < len(args) {\n   366→\t\t\t\ti++\n   367→\t\t\t\ttypeFilter = args[i]\n   368→\t\t\t}\n   369→\t\tcase \"--follow\", \"-f\":\n   370→\t\t\tfollow = true\n   371→\t\t}\n   372→\t}\n   373→\n   374→\t// Use background context — log output can be large and follow mode blocks.\n   375→\tctx := context.Background()\n   376→\tif follow {\n   377→\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n   378→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   379→\t}\n   380→\n   381→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   382→\t\tRunId:    runID,\n   383→\t\tStepName: stepFilter,\n   384→\t\tLogType:  typeFilter,\n   385→\t})\n   386→\tif err != nil {\n   387→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   388→\t\tos.Exit(1)\n   389→\t}\n   390→\n   391→\tfor {\n   392→\t\tentry, err := stream.Recv()\n   393→\t\tif err != nil {\n   394→\t\t\tif errors.Is(err, io.EOF) {\n   395→\t\t\t\tbreak\n   396→\t\t\t}\n   397→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   398→\t\t\tos.Exit(1)\n   399→\t\t}\n   400→\n   401→\t\tswitch entry.Type {\n   402→\t\tcase \"step_started\":\n   403→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   404→\t\t\tif entry.Message != \"\" {\n   405→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   406→\t\t\t}\n   407→\t\tcase \"step_completed\":\n   408→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   409→\t\t\tif entry.Message != \"\" {\n   410→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   411→\t\t\t}\n   412→\t\tcase \"run_completed\":\n   413→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   414→\t\t\tif entry.Message != \"\" {\n   415→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   416→\t\t\t}\n   417→\t\tcase \"full_log\":\n   418→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   419→\t\tcase \"log\":\n   420→\t\t\t// Live-streamed log line from an active run.\n   421→\t\t\tfmt.Println(entry.Message)\n   422→\t\tdefault:\n   423→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   424→\t\t\tif entry.StepName != \"\" {\n   425→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   426→\t\t\t}\n   427→\t\t\tif entry.Message != \"\" {\n   428→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   429→\t\t\t}\n   430→\t\t}\n   431→\t}\n   432→}\n   433→\n   434→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   435→\tif len(args) < 1 {\n   436→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   437→\t\tos.Exit(1)\n   438→\t}\n   439→\n   440→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   441→\tif err != nil {\n   442→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   443→\t\tos.Exit(1)\n   444→\t}\n   445→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   446→}\n   447→\n   448→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   449→\tif len(args) < 1 {\n   450→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   451→\t\tos.Exit(1)\n   452→\t}\n   453→\n   454→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   455→\tif err != nil {\n   456→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   457→\t\tos.Exit(1)\n   458→\t}\n   459→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   460→}\n   461→\n   462→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   463→\tcwd, _ := os.Getwd()\n   464→\n   465→\t// Check for \"stop\" subcommand\n   466→\tif len(args) > 0 && args[0] == \"stop\" {\n   467→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   468→\t\tif err != nil {\n   469→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   470→\t\t\tos.Exit(1)\n   471→\t\t}\n   472→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   473→\t\treturn\n   474→\t}\n   475→\n   476→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   477→\tvar maxConcurrent int32\n   478→\tfor i := 0; i < len(args); i++ {\n   479→\t\tswitch args[i] {\n   480→\t\tcase \"--max\":\n   481→\t\t\tif i+1 < len(args) {\n   482→\t\t\t\ti++\n   483→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   484→\t\t\t\tif n != 1 || err != nil {\n   485→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   486→\t\t\t\t\tos.Exit(1)\n   487→\t\t\t\t}\n   488→\t\t\t}\n   489→\t\t}\n   490→\t}\n   491→\n   492→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   493→\t\tProjectDir:    cwd,\n   494→\t\tMaxConcurrent: maxConcurrent,\n   495→\t})\n   496→\tif err != nil {\n   497→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   498→\t\tos.Exit(1)\n   499→\t}\n   500→\tif maxConcurrent > 0 {\n   501→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   502→\t} else {\n   503→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   504→\t}\n   505→}\n   506→\n   507→func cmdTasks(args []string) {\n   508→\t// Determine HTTP address from env\n   509→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   510→\tif httpAddr == \"\" {\n   511→\t\thttpAddr = \"localhost:8080\"\n   512→\t}\n   513→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   514→\n   515→\t// Determine project label from --project flag or current directory\n   516→\tprojectDir := \"\"\n   517→\tfor i := 0; i < len(args); i++ {\n   518→\t\tswitch args[i] {\n   519→\t\tcase \"--project\":\n   520→\t\t\tif i+1 < len(args) {\n   521→\t\t\t\ti++\n   522→\t\t\t\tprojectDir = args[i]\n   523→\t\t\t}\n   524→\t\t}\n   525→\t}\n   526→\n   527→\tif projectDir == \"\" {\n   528→\t\tcwd, _ := os.Getwd()\n   529→\t\tprojectDir = filepath.Base(cwd)\n   530→\t}\n   531→\n   532→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   533→\tresp, err := http.Get(tasksURL)\n   534→\tif err != nil {\n   535→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   536→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   537→\t\tos.Exit(1)\n   538→\t}\n   539→\tdefer resp.Body.Close()\n   540→\n   541→\tif resp.StatusCode != 200 {\n   542→\t\tbody, _ := io.ReadAll(resp.Body)\n   543→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   544→\t\tos.Exit(1)\n   545→\t}\n   546→\n   547→\ttype taskEntry struct {\n   548→\t\tID          string `json:\"id\"`\n   549→\t\tStatus      string `json:\"status\"`\n   550→\t\tTitle       string `json:\"title\"`\n   551→\t\tDescription string `json:\"description\"`\n   552→\t\tAssigned    bool   `json:\"assigned\"`\n   553→\t\tAssignedAt  string `json:\"assigned_at\"`\n   554→\t\tRunID       string `json:\"run_id\"`\n   555→\t}\n   556→\n   557→\tvar tasks []taskEntry\n   558→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   559→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   560→\t\tos.Exit(1)\n   561→\t}\n   562→\n   563→\tif len(tasks) == 0 {\n   564→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   565→\t\treturn\n   566→\t}\n   567→\n   568→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   569→\tfor _, t := range tasks {\n   570→\t\tstatus := t.Status\n   571→\t\tif status == \"\" {\n   572→\t\t\tstatus = \"open\"\n   573→\t\t}\n   574→\t\tassigned := \"-\"\n   575→\t\tif t.Assigned {\n   576→\t\t\tassigned = \"yes\"\n   577→\t\t}\n   578→\t\trunID := \"\"\n   579→\t\tif t.RunID != \"\" {\n   580→\t\t\trunID = t.RunID\n   581→\t\t\tif len(runID) > 30 {\n   582→\t\t\t\trunID = runID[:27] + \"...\"\n   583→\t\t\t}\n   584→\t\t}\n   585→\t\ttitle := t.Title\n   586→\t\tif len(title) > 40 {\n   587→\t\t\ttitle = title[:37] + \"...\"\n   588→\t\t}\n   589→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   590→\t}\n   591→}\n   592→\n   593→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   594→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   595→\tif err != nil {\n   596→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   597→\t\tos.Exit(1)\n   598→\t}\n   599→\tfmt.Println(\"Daemon shutting down.\")\n   600→}\n   601→\n   602→// resolveRunContext returns the project directory and run ID for context\n   603→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   604→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   605→func resolveRunContext() (projectDir, runID string, err error) {\n   606→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   607→\tif runID == \"\" {\n   608→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   609→\t}\n   610→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   611→\tif projectDir == \"\" {\n   612→\t\tprojectDir, err = os.Getwd()\n   613→\t\tif err != nil {\n   614→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   615→\t\t}\n   616→\t}\n   617→\treturn projectDir, runID, nil\n   618→}\n   619→\n   620→func cmdGet(args []string) {\n   621→\tif len(args) < 1 {\n   622→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   623→\t\tos.Exit(1)\n   624→\t}\n   625→\n   626→\tprojectDir, runID, err := resolveRunContext()\n   627→\tif err != nil {\n   628→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   629→\t\tos.Exit(1)\n   630→\t}\n   631→\n   632→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   633→\tif err != nil {\n   634→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   635→\t\tos.Exit(1)\n   636→\t}\n   637→\tif !ok {\n   638→\t\tos.Exit(1)\n   639→\t}\n   640→\tfmt.Println(val)\n   641→}\n   642→\n   643→func cmdSet(args []string) {\n   644→\tif len(args) < 2 {\n   645→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   646→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   647→\t\tos.Exit(1)\n   648→\t}\n   649→\n   650→\tprojectDir, runID, err := resolveRunContext()\n   651→\tif err != nil {\n   652→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   653→\t\tos.Exit(1)\n   654→\t}\n   655→\n   656→\tvalue := args[1]\n   657→\tif value == \"-\" {\n   658→\t\tdata, err := io.ReadAll(os.Stdin)\n   659→\t\tif err != nil {\n   660→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   661→\t\t\tos.Exit(1)\n   662→\t\t}\n   663→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   664→\t}\n   665→\n   666→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   667→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   668→\t\tos.Exit(1)\n   669→\t}\n   670→}\n   671→\n   672→func cmdVersion() {\n   673→\tcliVersion := version.Version()\n   674→\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   675→\n   676→\t// Try to get daemon version via gRPC\n   677→\tdaemonVersion := \"<unavailable>\"\n   678→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   679→\tif addr == \"\" {\n   680→\t\taddr = \"unix:///tmp/cloche.sock\"\n   681→\t}\n   682→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   683→\tif err == nil {\n   684→\t\tdefer conn.Close()\n   685→\t\tclient := pb.NewClocheServiceClient(conn)\n   686→\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   687→\t\tdefer cancel()\n   688→\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   689→\t\tif err == nil {\n   690→\t\t\tdaemonVersion = resp.Version\n   691→\t\t}\n   692→\t}\n   693→\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   694→\n   695→\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   696→\tagentVersion := \"<unavailable>\"\n   697→\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   698→\tif image == \"\" {\n   699→\t\timage = \"cloche-agent:latest\"\n   700→\t}\n   701→\tout, err := exec.CommandContext(\n   702→\t\tcontext.Background(),\n   703→\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   704→\t).Output()\n   705→\tif err == nil {\n   706→\t\tagentVersion = strings.TrimSpace(string(out))\n   707→\t\t// Strip \"cloche-agent \" prefix if present\n   708→\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n   709→\t}\n   710→\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n   711→\n   712→\t// Warn about version mismatches\n   713→\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n   714→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n   715→\t}\n   716→\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n   717→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n   718→\t}\n   719→}\n   720→"}]},"parent_tool_use_id":"toolu_01TmKptVZFDRzmP4Wt7ZGDxG","session_id":"09a1d66f-c28d-47e8-9d4e-ccb126644895","uuid":"7de5e171-9543-497b-bc72-b5e984a8772a"}
