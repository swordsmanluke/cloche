on_id":"09a1d66f-c28d-47e8-9d4e-ccb126644895","uuid":"cde1caae-0b0b-4ebb-affd-f80656181ce0","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.cloche/host.cloche","content":"workflow \"list-tasks\" {\n  step ready-tasks {\n    run     = \"bash .cloche/scripts/ready-tasks.sh\"\n    results = [success, fail]\n  }\n\n  ready-tasks:success -> done\n  ready-tasks:fail    -> abort\n}\n\nworkflow \"main\" {\n  host {\n    agent_command = \"claude\"\n  }\n\n  step claim-task {\n    run     = \"bash .cloche/scripts/claim-task.sh\"\n    results = [success, fail]\n  }\n\n  step prepare-prompt {\n    run     = \"bash .cloche/scripts/prepare-prompt.sh\"\n    results = [success, fail]\n  }\n\n  step develop {\n    workflow_name = \"develop\"\n    results       = [success, fail]\n  }\n\n  step merge {\n    run     = \"bash .cloche/scripts/merge-to-main.sh\"\n    results = [success, fail]\n  }\n\n  step cleanup {\n    run     = \"bash .cloche/scripts/cleanup-run.sh\"\n    results = [success, fail]\n  }\n\n  claim-task:success     -> prepare-prompt\n  claim-task:fail        -> abort\n  prepare-prompt:success -> develop\n  prepare-prompt:fail    -> abort\n  develop:success        -> merge\n  develop:fail           -> abort\n  merge:success          -> cleanup\n  merge:fail             -> abort\n  cleanup:success        -> done\n  cleanup:fail           -> done\n}\n\nworkflow \"finalize\" {\n  step close-task {\n    run     = \"bash .cloche/scripts/close-task.sh\"\n    results = [success, fail]\n  }\n\n  close-task:success -> done\n  close-task:fail    -> done\n}\n","numLines":62,"startLine":1,"totalLines":62}}}
