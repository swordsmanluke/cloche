{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RLcWqLKuvTjY5qjUyVoLnW","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# prepare-prompt.sh — Build the task prompt from the daemon-assigned task.\n     3→# Uses CLOCHE_TASK_ID env var to look up task details from bead.\n     4→set -euo pipefail\n     5→\n     6→if [ -z \"${CLOCHE_TASK_ID:-}\" ]; then\n     7→  echo \"error: CLOCHE_TASK_ID not set\" >&2\n     8→  exit 1\n     9→fi\n    10→\n    11→# Look up task details from bead\n    12→task_json=$(bd show \"$CLOCHE_TASK_ID\" --json 2>/dev/null) || {\n    13→  echo \"error: could not look up task $CLOCHE_TASK_ID\" >&2\n    14→  exit 1\n    15→}\n    16→\n    17→task_title=$(echo \"$task_json\" | jq -r '.[0].title // empty')\n    18→task_body=$(echo \"$task_json\" | jq -r '.[0].description // empty')\n    19→\n    20→if [ -z \"$task_title\" ]; then\n    21→  echo \"error: task $CLOCHE_TASK_ID has no title\" >&2\n    22→  exit 1\n    23→fi\n    24→\n    25→prompt=\"## Task: ${task_title}\n    26→\n    27→${task_body}\"\n    28→\n    29→echo \"$prompt\"\n    30→[ -n \"${CLOCHE_STEP_OUTPUT:-}\" ] && echo \"$prompt\" > \"$CLOCHE_STEP_OUTPUT\"\n    31→"}]},"parent_tool_use_id":"toolu_01TmKptVZFDRzmP4Wt7ZGDxG","session_id":"09a1d66f-c28d-47e8-9d4e-ccb126644895","uuid":"f21c1455-c530-4434-8f56-ea4a60c736ce"}
