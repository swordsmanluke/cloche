{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YEBB8BvADFHJMpoBoANBBs","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# cleanup-run.sh — Remove the worktree and branch left over from a cloche run.\n     3→# Reads child run ID and task ID from run context (set via cloche set).\n     4→set -euo pipefail\n     5→\n     6→RUN_ID=$(cloche get child_run_id) || true\n     7→PROJECT_DIR=\"${CLOCHE_PROJECT_DIR:-.}\"\n     8→\n     9→if [ -z \"$RUN_ID\" ]; then\n    10→  echo \"warning: child_run_id not found in run context, skipping branch cleanup\" >&2\n    11→else\n    12→  BRANCH=\"cloche/${RUN_ID}\"\n    13→  WORKTREE_DIR=\"$PROJECT_DIR/.gitworktrees/cloche/$RUN_ID\"\n    14→\n    15→  # Remove the extraction worktree if it still exists\n    16→  if [ -d \"$WORKTREE_DIR\" ]; then\n    17→    git -C \"$PROJECT_DIR\" worktree remove --force \"$WORKTREE_DIR\" 2>/dev/null || true\n    18→  fi\n    19→\n    20→  # Prune any stale worktree bookkeeping\n    21→  git -C \"$PROJECT_DIR\" worktree prune 2>/dev/null || true\n    22→\n    23→  # Delete the branch if it still exists (merge may have already removed it)\n    24→  if git -C \"$PROJECT_DIR\" rev-parse --verify \"$BRANCH\" >/dev/null 2>&1; then\n    25→    git -C \"$PROJECT_DIR\" branch -D \"$BRANCH\" 2>/dev/null || true\n    26→  fi\n    27→fi\n    28→\n    29→echo \"Cleaned up run ${RUN_ID:-unknown}\"\n    30→"}]},"parent_tool_use_id":"toolu_01TmKptVZFDRzmP4Wt7ZGDxG","session_id":"09a1d66f-c28d-47e8-9d4e-ccb126644895","uuid":"3ffe6ebb-1920-4b32-818f-c77c31c18f22"}
