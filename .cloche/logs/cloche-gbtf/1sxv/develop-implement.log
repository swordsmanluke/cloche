{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01REHExdoyz6e8nbcfN744Hi","type":"tool_result","content":"   960→// GetLoopTasks returns the current task pipeline state for a project's\n   961→// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n   962→// loop is active for the project.\n   963→func (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n   964→\ts.mu.Lock()\n   965→\tloop, ok := s.loops[projectDir]\n   966→\ts.mu.Unlock()\n   967→\tif !ok {\n   968→\t\treturn nil\n   969→\t}\n   970→\tsnapshot := loop.GetTaskSnapshot()\n   971→\tentries := make([]web.TaskEntry, len(snapshot))\n   972→\tfor i, e := range snapshot {\n   973→\t\tentry := web.TaskEntry{\n   974→\t\t\tID:          e.Task.ID,\n   975→\t\t\tStatus:      e.Task.Status,\n   976→\t\t\tTitle:       e.Task.Title,\n   977→\t\t\tDescription: e.Task.Description,\n   978→\t\t\tMetadata:    e.Task.Metadata,\n   979→\t\t\tAssigned:    e.Assigned,\n   980→\t\t\tRunID:       e.RunID,\n   981→\t\t}\n   982→\t\tif !e.AssignedAt.IsZero() {\n   983→\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n   984→\t\t}\n   985→\t\tentries[i] = entry\n   986→\t}\n   987→\treturn entries\n   988→}\n   989→\n   990→func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n   991→\tprojectDir := req.ProjectDir\n   992→\tif projectDir == \"\" {\n   993→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   994→\t}\n   995→\n   996→\ts.mu.Lock()\n   997→\tdefer s.mu.Unlock()\n   998→\n   999→\tif loop, ok := s.loops[projectDir]; ok {\n  1000→\t\tloop.Stop()\n  1001→\t\tdelete(s.loops, projectDir)\n  1002→\t}\n  1003→\n  1004→\treturn &pb.DisableLoopResponse{}, nil\n  1005→}\n  1006→\n  1007→func (s *ClocheServer) GetProjectInfo(ctx context.Context, req *pb.GetProjectInfoRequest) (*pb.GetProjectInfoResponse, error) {\n  1008→\tprojectDir := req.ProjectDir\n  1009→\n  1010→\t// Resolve by name if provided.\n  1011→\tif req.Name != \"\" && projectDir == \"\" {\n  1012→\t\tprojects, err := s.store.ListProjects(ctx)\n  1013→\t\tif err != nil {\n  1014→\t\t\treturn nil, fmt.Errorf(\"listing projects: %w\", err)\n  1015→\t\t}\n  1016→\t\tlabels := projectLabels(projects)\n  1017→\t\tfound := false\n  1018→\t\tfor dir, label := range labels {\n  1019→\t\t\tif label == req.Name {\n  1020→\t\t\t\tprojectDir = dir\n  1021→\t\t\t\tfound = true\n  1022→\t\t\t\tbreak\n  1023→\t\t\t}\n  1024→\t\t}\n  1025→\t\tif !found {\n  1026→\t\t\treturn nil, fmt.Errorf(\"project %q not found\", req.Name)\n  1027→\t\t}\n  1028→\t}\n  1029→\n  1030→\tif projectDir == \"\" {\n  1031→\t\treturn nil, fmt.Errorf(\"project_dir or name is required\")\n  1032→\t}\n  1033→\n  1034→\t// Derive project label.\n  1035→\tprojects, _ := s.store.ListProjects(ctx)\n  1036→\tlabels := projectLabels(projects)\n  1037→\tlabel := labels[projectDir]\n  1038→\tif label == \"\" {\n  1039→\t\tlabel = filepath.Base(projectDir)\n  1040→\t}\n  1041→\n  1042→\t// Load config.\n  1043→\tcfg, _ := config.Load(projectDir)\n  1044→\n  1045→\t// Check loop state.\n  1046→\ts.mu.Lock()\n  1047→\tloop, loopExists := s.loops[projectDir]\n  1048→\ts.mu.Unlock()\n  1049→\tloopRunning := loopExists && loop != nil && loop.Running()\n  1050→\n  1051→\t// Get active runs.\n  1052→\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n  1053→\tvar activeRuns []*pb.RunSummary\n  1054→\tfor _, run := range allRuns {\n  1055→\t\tif run.State == domain.RunStatePending || run.State == domain.RunStateRunning {\n  1056→\t\t\tactiveRuns = append(activeRuns, &pb.RunSummary{\n  1057→\t\t\t\tRunId:        run.ID,\n  1058→\t\t\t\tWorkflowName: run.WorkflowName,\n  1059→\t\t\t\tState:        string(run.State),\n  1060→\t\t\t\tStartedAt:    run.StartedAt.String(),\n  1061→\t\t\t\tTitle:        run.Title,\n  1062→\t\t\t\tIsHost:       run.IsHost,\n  1063→\t\t\t\tContainerId:  run.ContainerID,\n  1064→\t\t\t})\n  1065→\t\t}\n  1066→\t}\n  1067→\n  1068→\t// Discover workflows.\n  1069→\tvar containerWorkflows, hostWorkflows []string\n  1070→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n  1071→\tentries, _ := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n  1072→\tfor _, path := range entries {\n  1073→\t\tbase := filepath.Base(path)\n  1074→\t\tdata, err := os.ReadFile(path)\n  1075→\t\tif err != nil {\n  1076→\t\t\tcontinue\n  1077→\t\t}\n  1078→\t\tif base == \"host.cloche\" {\n  1079→\t\t\twfs, err := dsl.ParseAllForHost(string(data))\n  1080→\t\t\tif err != nil {\n  1081→\t\t\t\tcontinue\n  1082→\t\t\t}\n  1083→\t\t\tfor name := range wfs {\n  1084→\t\t\t\thostWorkflows = append(hostWorkflows, name)\n  1085→\t\t\t}\n  1086→\t\t} else {\n  1087→\t\t\twf, err := dsl.ParseForContainer(string(data))\n  1088→\t\t\tif err != nil {\n  1089→\t\t\t\tcontinue\n  1090→\t\t\t}\n  1091→\t\t\tcontainerWorkflows = append(containerWorkflows, wf.Name)\n  1092→\t\t}\n  1093→\t}\n  1094→\n  1095→\tsort.Strings(containerWorkflows)\n  1096→\tsort.Strings(hostWorkflows)\n  1097→\n  1098→\treturn &pb.GetProjectInfoResponse{\n  1099→\t\tProjectDir:         projectDir,\n  1100→\t\tName:               label,\n  1101→\t\tActive:             cfg.Active,\n  1102→\t\tConcurrency:        int32(cfg.Orchestration.Concurrency),\n  1103→\t\tStaggerSeconds:     cfg.Orchestration.StaggerSeconds,\n  1104→\t\tDedupSeconds:       cfg.Orchestration.DedupSeconds,\n  1105→\t\tEvolutionEnabled:   cfg.Evolution.Enabled,\n  1106→\t\tLoopRunning:        loopRunning,\n  1107→\t\tActiveRuns:         activeRuns,\n  1108→\t\tContainerWorkflows: containerWorkflows,\n  1109→\t\tHostWorkflows:      hostWorkflows,"}]},"parent_tool_use_id":"toolu_01TmKptVZFDRzmP4Wt7ZGDxG","session_id":"09a1d66f-c28d-47e8-9d4e-ccb126644895","uuid":"10b4d08b-e619-4f5d-ad3f-c874ee5caa22"}
