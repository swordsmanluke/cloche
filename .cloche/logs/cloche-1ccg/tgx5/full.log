[2026-03-14T20:06:02Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Sndpnf7fcTtpkdLMoPMKhR","type":"tool_result","content":"     1→package dsl\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"strconv\"\n     6→\t\"strings\"\n     7→\n     8→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     9→)\n    10→\n    11→type Parser struct {\n    12→\tlexer    *Lexer\n    13→\tcurrent  Token\n    14→\tpeek     Token\n    15→\tlocation domain.WorkflowLocation\n    16→}\n    17→\n    18→// ParseOption configures the parser.\n    19→type ParseOption func(*Parser)\n    20→\n    21→// WithLocation sets the workflow location, enabling location-based validation.\n    22→func WithLocation(loc domain.WorkflowLocation) ParseOption {\n    23→\treturn func(p *Parser) {\n    24→\t\tp.location = loc\n    25→\t}\n    26→}\n    27→\n    28→func Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n    29→\tp := &Parser{lexer: NewLexer(input)}\n    30→\tfor _, opt := range opts {\n    31→\t\topt(p)\n    32→\t}\n    33→\tp.advance() // load current\n    34→\tp.advance() // load peek\n    35→\treturn p.parseWorkflow()\n    36→}\n    37→\n    38→// ParseForHost parses a host.cloche file containing a single workflow.\n    39→func ParseForHost(input string) (*domain.Workflow, error) {\n    40→\treturn Parse(input, WithLocation(domain.LocationHost))\n    41→}\n    42→\n    43→// ParseAllForHost parses a host.cloche file that may contain multiple workflows.\n    44→// Returns a map of workflow name to workflow definition.\n    45→func ParseAllForHost(input string) (map[string]*domain.Workflow, error) {\n    46→\tp := &Parser{lexer: NewLexer(input), location: domain.LocationHost}\n    47→\tp.advance() // load current\n    48→\tp.advance() // load peek\n    49→\n    50→\tworkflows := make(map[string]*domain.Workflow)\n    51→\tfor p.current.Type != TokenEOF {\n    52→\t\twf, err := p.parseWorkflow()\n    53→\t\tif err != nil {\n    54→\t\t\treturn nil, err\n    55→\t\t}\n    56→\t\tif _, exists := workflows[wf.Name]; exists {\n    57→\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    58→\t\t}\n    59→\t\tworkflows[wf.Name] = wf\n    60→\t}\n    61→\n    62→\tif len(workflows) == 0 {\n    63→\t\treturn nil, fmt.Errorf(\"no workflows found in host.cloche\")\n    64→\t}\n    65→\n    66→\treturn workflows, nil\n    67→}\n    68→\n    69→// ParseForContainer parses a container workflow file.\n    70→func ParseForContainer(input string) (*domain.Workflow, error) {\n    71→\treturn Parse(input, WithLocation(domain.LocationContainer))\n    72→}\n    73→\n    74→// ParseAll parses a .cloche file that may contain multiple workflows.\n    75→// Workflows default to LocationContainer but a \"host { }\" block overrides\n    76→// the location to LocationHost, so any .cloche file can define host workflows.\n    77→func ParseAll(input string) (map[string]*domain.Workflow, error) {\n    78→\tp := &Parser{lexer: NewLexer(input), location: domain.LocationContainer}\n    79→\tp.advance() // load current\n    80→\tp.advance() // load peek\n    81→\n    82→\tworkflows := make(map[string]*domain.Workflow)\n    83→\tfor p.current.Type != TokenEOF {\n    84→\t\twf, err := p.parseWorkflow()\n    85→\t\tif err != nil {\n    86→\t\t\treturn nil, err\n    87→\t\t}\n    88→\t\tif _, exists := workflows[wf.Name]; exists {\n    89→\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    90→\t\t}\n    91→\t\tworkflows[wf.Name] = wf\n    92→\t}\n    93→\n    94→\tif len(workflows) == 0 {\n    95→\t\treturn nil, fmt.Errorf(\"no workflows found\")\n    96→\t}\n    97→\n    98→\treturn workflows, nil\n    99→}\n   100→"}]},"parent_tool_use_id":"toolu_01FXHswbxjWP3Y1Go3ySfEeD","session_id":"2c8efca8-0543-449d-b96b-ca9c239a2f48","uuid":"51ca6eb4-abae-400b-90cb-89bb4346c8c6"}
