econdary);\n   598→    border-bottom: 2px solid var(--border);\n   599→    padding: 0.5rem 0.75rem;\n   600→    color: var(--text);\n   601→    font-size: 0.9rem;\n   602→}\n   603→\n   604→/* Run tree grouping */\n   605→.run-parent-row { opacity: 0.7; }\n   606→.run-parent-row td:first-child { font-weight: 600; }\n   607→.run-child-row td:first-child { padding-left: 2rem; }\n   608→.run-child-row td:first-child::before {\n   609→    content: \"\\2514\\00a0\";\n   610→    color: var(--text-muted);\n   611→}\n   612→.tree-toggle {\n   613→    cursor: pointer;\n   614→    background: none;\n   615→    border: none;\n   616→    font-size: 0.75rem;\n   617→    color: var(--text-muted);\n   618→    padding: 0 0.25rem;\n   619→    margin-right: 0.25rem;\n   620→}\n   621→.tree-toggle:hover { color: var(--text); }\n   622→.parent-run-link { font-weight: 400; color: var(--text-muted); }\n   623→.parent-run-link:hover { color: var(--link); }\n   624→\n   625→/* Responsive */\n   626→@media (max-width: 768px) {\n   627→    .runs-table { font-size: 0.8rem; }\n   628→    .runs-table th, .runs-table td { padding: 0.4rem 0.5rem; }\n   629→    .run-meta dl { grid-template-columns: 1fr; }\n   630→    .project-cards { grid-template-columns: 1fr; }\n   631→    .log-viewer { max-height: 400px; }\n   632→    .drawer { width: 100%; right: -100%; }\n   633→}\n   634→\n   635→.version-watermark {\n   636→    position: fixed;\n   637→    bottom: 0.5rem;\n   638→    right: 0.75rem;\n   639→    font-size: 0.7rem;\n   640→    color: var(--text-muted);\n   641→    opacity: 0.5;\n   642→    pointer-events: none;\n   643→}\n   644→"}]},"parent_tool_use_id":"toolu_01FXHswbxjWP3Y1Go3ySfEeD","session_id":"2c8efca8-0543-449d-b96b-ca9c239a2f48","uuid":"8ebbf901-69a8-4388-884c-fe4a2fe96eef"}
