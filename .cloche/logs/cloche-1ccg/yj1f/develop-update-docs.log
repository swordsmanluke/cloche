ad)';\n-        svg += '<path d=\"M' + mergeX + ' ' + termY + ' L' + tpos.x + ' ' + termY + '\" class=\"dag-edge' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\" marker-end=\"' + mergeMarker + '\"/>';\n+        if (linkXs.length === 0) continue;\n+\n+        // Horizontal lane segment connecting all link nodes toward the terminal\n+        var maxLinkX = Math.max.apply(null, linkXs);\n+        var minLinkX = Math.min.apply(null, linkXs);\n+        var termLeftX = tpos.x;\n+        var termMidY = tpos.y + nodeH / 2;\n+\n+        var laneEndX = termLeftX - 20;\n+        if (laneEndX < maxLinkX) laneEndX = maxLinkX;\n+\n+        svg += '<path d=\"M' + minLinkX + ' ' + ly + ' L' + laneEndX + ' ' + ly + '\" fill=\"none\" stroke=\"' + color + '\" stroke-width=\"1.5\"/>';\n+\n+        // Curve from lane end up to terminal\n+        svg += '<path d=\"M' + laneEndX + ' ' + ly + ' C' + (laneEndX + 10) + ' ' + ly + ' ' + termLeftX + ' ' + (ly + (termMidY - ly) * 0.3) + ' ' + termLeftX + ' ' + termMidY + '\" fill=\"none\" stroke=\"' + color + '\" stroke-width=\"1.5\" marker-end=\"' + markerRef(color) + '\"/>';\n+\n+        // Link node at lane-to-terminal junction\n+        svg += '<circle cx=\"' + laneEndX + '\" cy=\"' + ly + '\" r=\"4\" fill=\"' + color + '\"/>';\n     }\n \n     // Draw step nodes","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
