  432→            // Link node circle at junction\n   433→            svg += '<circle cx=\"' + dropX + '\" cy=\"' + ly + '\" r=\"4\" fill=\"' + color + '\"/>';\n   434→\n   435→            linkXs.push(dropX);\n   436→        });\n   437→\n   438→        if (linkXs.length === 0) continue;\n   439→\n   440→        // Horizontal lane segment connecting all link nodes toward the terminal\n   441→        var maxLinkX = Math.max.apply(null, linkXs);\n   442→        var minLinkX = Math.min.apply(null, linkXs);\n   443→        var termLeftX = tpos.x;\n   444→        var termMidY = tpos.y + nodeH / 2;\n   445→\n   446→        var laneEndX = termLeftX - 20;\n   447→        if (laneEndX < maxLinkX) laneEndX = maxLinkX;\n   448→\n   449→        svg += '<path d=\"M' + minLinkX + ' ' + ly + ' L' + laneEndX + ' ' + ly + '\" fill=\"none\" stroke=\"' + color + '\" stroke-width=\"1.5\"/>';\n   450→\n   451→        // Curve from lane end up to terminal\n   452→        svg += '<path d=\"M' + laneEndX + ' ' + ly + ' C' + (laneEndX + 10) + ' ' + ly + ' ' + termLeftX + ' ' + (ly + (termMidY - ly) * 0.3) + ' ' + termLeftX + ' ' + termMidY + '\" fill=\"none\" stroke=\"' + color + '\" stroke-width=\"1.5\" marker-end=\"' + markerRef(color) + '\"/>';\n   453→\n   454→        // Link node at lane-to-terminal junction\n   455→        svg += '<circle cx=\"' + laneEndX + '\" cy=\"' + ly + '\" r=\"4\" fill=\"' + color + '\"/>';\n   456→    }\n   457→\n   458→    // Draw step nodes\n   459→    wf.steps.forEach(function(s) {\n   460→        var pos = positions[s.name];\n   461→        if (!pos) return;\n   462→        var icon = '\\u{1F4DC}';\n   463→        if (s.type === 'agent') icon = '\\u{1F916}';\n   464→        else if (s.type === 'workflow') icon = '\\u{1F501}';\n   465→        svg += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + s.name + '\\')\" style=\"cursor:pointer\">';\n   466→        svg += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\"