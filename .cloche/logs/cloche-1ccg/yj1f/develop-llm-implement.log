{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0171XdxbJf8pLwX7p5yc2s65","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n     3→\n     4→<div class=\"run-history\" style=\"margin-bottom:1rem\">\n     5→    {{range .RecentRuns}}\n     6→    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n     7→    {{end}}\n     8→    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n     9→    {{if .ContainerCount}}\n    10→    <button class=\"btn btn-danger btn-sm\" id=\"delete-containers-btn\" onclick=\"deleteAllContainers()\" style=\"margin-left:0.5rem\">Delete {{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}</button>\n    11→    {{end}}\n    12→</div>\n    13→\n    14→<!-- Panel 1: Project Info -->\n    15→<div class=\"panel\" id=\"info-panel\">\n    16→    <div class=\"panel-header\">Project Info</div>\n    17→    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n    18→</div>\n    19→\n    20→<!-- Panel 2: In-progress Tasks -->\n    21→<div class=\"panel\" id=\"in-progress-panel\">\n    22→    <div class=\"panel-header\">In-progress Tasks</div>\n    23→    <div class=\"panel-body\" id=\"in-progress-body\">Loading...</div>\n    24→</div>\n    25→\n    26→<!-- Panel 3: Upcoming Tasks -->\n    27→<div class=\"panel\" id=\"upcoming-panel\">\n    28→    <div class=\"panel-header\">Upcoming Tasks</div>\n    29→    <div class=\"panel-body\" id=\"upcoming-body\">Loading...</div>\n    30→</div>\n    31→\n    32→<!-- Panel 3: Workflow View -->\n    33→<div class=\"panel\" id=\"workflow-panel\">\n    34→    <div class=\"panel-header\">Workflows</div>\n    35→    <div class=\"panel-body\">\n    36→        <div id=\"location-tabs\" class=\"tab-bar\"></div>\n    37→        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n    38→        <div id=\"workflow-dag\"></div>\n    39→    </div>\n    40→</div>\n    41→\n    42→<!-- Step Drawer -->\n    43→<div class=\"drawer\" id=\"step-drawer\">\n    44→    <div class=\"drawer-header\">\n    45→        <span id=\"drawer-title\"></span>\n    46→        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    47→    </div>\n    48→    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n    49→</div>\n    50→{{end}}\n    51→\n    52→{{define \"scripts\"}}\n    53→<script>\n    54→var projectLabel = {{.Label}};\n    55→\n    56→function loadProjectInfo() {\n    57→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n    58→        .then(function(r) { return r.json(); })\n    59→        .then(function(data) {\n    60→            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n    61→            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n    62→            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n    63→            html += '</dl>';\n    64→\n    65→            if (data.prompt_files && data.prompt_files.length > 0) {\n    66→                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n    67→                data.prompt_files.forEach(function(pf) {\n    68→                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n    69→                    if (pf.content) {\n    70→                        html += '<pre class=\"diff-block\">' + pf.content.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n    71→                    } else {\n    72→                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">Empty file</p>';\n    73→                    }\n    74→                    html += '</details>';\n    75→                });\n    76→            }\n    77→\n    78→            document.getElementById('project-info').innerHTML = html;\n    79→        });\n    80→}\n    81→\n    82→function toggleDiff(el) {\n    83→    var existing = el.nextElementSibling;\n    84→    if (existing && existing.classList.contains('diff-block')) {\n    85→        existing.remove();\n    86→        return;\n    87→    }\n    88→    var file = el.getAttribute('data-file');\n    89→    var sha = el.getAttribute('data-sha');\n    90→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n    91→        .then(function(r) { return r.text(); })\n    92→        .then(function(text) {\n    93→            var pre = document.createElement('pre');\n    94→            pre.className = 'diff-block';\n    95→            pre.textContent = text || '(no diff available)';\n    96→            el.parentNode.insertBefore(pre, el.nextSibling);\n    97→        });\n    98→}\n    99→\n   100→var workflowsData = [];\n   101→var activeLocation = 'container';\n   102→\n   103→function loadWorkflows() {\n   104→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n   105→        .then(function(r) { return r.json(); })\n   106→        .then(function(data) {\n   107→            workflowsData = data || [];\n   108→            if (workflowsData.length === 0) {\n   109→                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n   110→                return;\n   111→            }\n   112→\n   113→            // Check which locations exist\n   114→            var hasContainer = workflowsData.some(function(wf) { return wf.location === 'container'; });\n   115→            var hasHost = workflowsData.some(function(wf) { return wf.location === 'host'; });\n   116→\n   117→            // Render location tabs if both types exist\n   118→            var locationTabs = document.getElementById('location-tabs');\n   119→            if (hasContainer && hasHost) {\n   120→                var html = '';\n   121→                html += '<button class=\"tab-btn tab-active\" onclick=\"switchLocation(\\'container\\')\">Container</button>';\n   122→                html += '<button class=\"tab-btn\" onclick=\"switchLocation(\\'host\\')\">Host</button>';\n   123→                locationTabs.innerHTML = html;\n   124→            } else {\n   125→                locationTabs.innerHTML = '';\n   126→            }\n   127→\n   128→            // Default to whichever location exists\n   129→            activeLocation = hasContainer ? 'container' : 'host';\n   130→            renderWorkflowTabs();\n   131→        });\n   132→}\n   133→\n   134→function switchLocation(loc) {\n   135→    activeLocation = loc;\n   136→    var btns = document.querySelectorAll('#location-tabs .tab-btn');\n   137→    btns.forEach(function(b) {\n   138→        b.classList.toggle('tab-active', b.textContent === (loc === 'container' ? 'Container' : 'Host'));\n   139→    });\n   140→    renderWorkflowTabs();\n   141→}\n   142→\n   143→function renderWorkflowTabs() {\n   144→    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n   145→    var tabs = document.getElementById('workflow-tabs');\n   146→\n   147→    if (filtered.length === 0) {\n   148→        tabs.innerHTML = '';\n   149→        document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No ' + activeLocation + ' workflows found</p>';\n   150→        return;\n   151→    }\n   152→\n   153→    if (filtered.length > 1) {\n   154→        var html = '';\n   155→        filtered.forEach(function(wf, i) {\n   156→            html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showFilteredWorkflow(' + i + ')\">' + wf.name + '</button>';\n   157→        });\n   158→        tabs.innerHTML = html;\n   159→    } else {\n   160→        tabs.innerHTML = '';\n   161→    }\n   162→    showFilteredWorkflow(0);\n   163→}\n   164→\n   165→function showFilteredWorkflow(idx) {\n   166→    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n   167→    var btns = document.querySelectorAll('#workflow-tabs .tab-btn');\n   168→    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n   169→    showWorkflow(filtered[idx]);\n   170→}\n   171→\n   172→function showWorkflow(wf) {\n   173→    var dagEl = document.getElementById('workflow-dag');\n   174→\n   175→    if (!wf.steps || wf.steps.length === 0) {\n   176→        dagEl.innerHTML = '<p class=\"empty\">No steps defined</p>';\n   177→        return;\n   178→    }\n   179→\n   180→    var stepMap = {};\n   181→    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n   182→\n   183→    var wires = wf.wires || [];\n   184→\n   185→    // Collect terminal targets\n   186→    var terminals = {};\n   187→    wires.forEach(function(wire) {\n   188→        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n   189→    });\n   190→\n   191→    // Build adjacency maps\n   192→    var adj = {};    // from -> [wire]\n   193→    var revAdj = {}; // to -> [from] (unique)\n   194→    wires.forEach(function(wire) {\n   195→        if (!adj[wire.from]) adj[wire.from] = [];\n   196→        adj[wire.from].push(wire);\n   197→        if (!revAdj[wire.to]) revAdj[wire.to] = [];\n   198→        if (revAdj[wire.to].indexOf(wire.from) === -1) revAdj[wire.to].push(wire.from);\n   199→    });\n   200→\n   201→    // --- Layer assignment via longest path (Sugiyama-style) ---\n   202→    var stepNames = wf.steps.map(function(s) { return s.name; });\n   203→\n   204→    // Topological sort (Kahn's algorithm)\n   205→    var inDeg = {};\n   206→    stepNames.forEach(function(n) { inDeg[n] = 0; });\n   207→    wires.forEach(function(wire) {\n   208→        if (inDeg[wire.to] !== undefined) inDeg[wire.to]++;\n   209→    });\n   210→\n   211→    var queue = [];\n   212→    stepNames.forEach(function(n) { if (inDeg[n] === 0) queue.push(n); });\n   213→\n   214→    var topoOrder = [];\n   215→    while (queue.length > 0) {\n   216→        var n = queue.shift();\n   217→        topoOrder.push(n);\n   218→        (adj[n] || []).forEach(function(wire) {\n   219→            if (inDeg[wire.to] !== undefined) {\n   220→                inDeg[wire.to]--;\n   221→                if (inDeg[wire.to] === 0) queue.push(wire.to);\n   222→            }\n   223→        });\n   224→    }\n   225→    // Add remaining steps (cycles or disconnected)\n   226→    stepNames.forEach(function(n) { if (topoOrder.indexOf(n) === -1) topoOrder.push(n); });\n   227→\n   228→    // Assign layers: longest path from any source\n   229→    var layerOf = {};\n   230→    topoOrder.forEach(function(n) {\n   231→        var maxParent = -1;\n   232→        (revAdj[n] || []).forEach(function(p) {\n   233→            if (layerOf[p] !== undefined && layerOf[p] > maxParent) maxParent = layerOf[p];\n   234→        });\n   235→        layerOf[n] = maxParent + 1;\n   236→    });\n   237→\n   238→    var maxLayer = 0;\n   239→    stepNames.forEach(function(n) { if (layerOf[n] > maxLayer) maxLayer = layerOf[n]; });\n   240→\n   241→    // Terminals in rightmost layer\n   242→    var termLayer = maxLayer + 1;\n   243→    for (var t in terminals) { layerOf[t] = termLayer; }\n   244→    var numLayers = termLayer + 1;\n   245→\n   246→    // --- Build layer arrays ---\n   247→    var layers = [];\n   248→    for (var i = 0; i < numLayers; i++) layers.push([]);\n   249→    topoOrder.forEach(function(n) { layers[layerOf[n]].push(n); });\n   250→    for (var t in terminals) { layers[termLayer].push(t); }\n   251→\n   252→    // --- Barycenter ordering to minimize edge crossings ---\n   253→    for (var pass = 0; pass < 4; pass++) {\n   254→        // Forward pass\n   255→        for (var li = 1; li < numLayers; li++) {\n   256→            var bary = {};\n   257→            layers[li].forEach(function(n) {\n   258→                var pars = revAdj[n] || [];\n   259→                var sum = 0, cnt = 0;\n   260→                pars.forEach(function(p) {\n   261→                    var idx = layers[li - 1].indexOf(p);\n   262→                    if (idx >= 0) { sum += idx; cnt++; }\n   263→                });\n   264→                bary[n] = cnt > 0 ? sum / cnt : 999;\n   265→            });\n   266→            layers[li].sort(function(a, b) { return bary[a] - bary[b]; });\n   267→        }\n   268→        // Backward pass\n   269→        for (var li = numLayers - 2; li >= 0; li--) {\n   270→            var baryB = {};\n   271→            layers[li].forEach(function(n) {\n   272→                var children = (adj[n] || []).map(function(w) { return w.to; });\n   273→                var sum = 0, cnt = 0;\n   274→                children.forEach(function(c) {\n   275→                    var idx = layers[li + 1].indexOf(c);\n   276→                    if (idx >= 0) { sum += idx; cnt++; }\n   277→                });\n   278→                baryB[n] = cnt > 0 ? sum / cnt : 999;\n   279→            });\n   280→            layers[li].sort(function(a, b) { return baryB[a] - baryB[b]; });\n   281→        }\n   282→    }\n   283→\n   284→    // --- Position calculation ---\n   285→    var nodeW = 180, nodeH = 48;\n   286→    var layerGap = 120; // horizontal gap between layers\n   287→    var nodeGap = 28;   // vertical gap between nodes in same layer\n   288→    var nonsuccOffset = 35; // vertical offset for non-success wires\n   289→    var padL = 30, padT = 30;\n   290→\n   291→    var maxInLayer = 1;\n   292→    layers.forEach(function(l) { if (l.length > maxInLayer) maxInLayer = l.length; });\n   293→    var totalLayerH = maxInLayer * nodeH + (maxInLayer - 1) * nodeGap;\n   294→\n   295→    var positions = {};\n   296→    layers.forEach(function(layer, li) {\n   297→        var lh = layer.length * nodeH + (layer.length - 1) * nodeGap;\n   298→        var offsetY = (totalLayerH - lh) / 2;\n   299→        layer.forEach(function(name, ni) {\n   300→            positions[name] = {\n   301→                x: padL + li * (nodeW + layerGap),\n   302→                y: padT + offsetY + ni * (nodeH + nodeGap)\n   303→            };\n   304→        });\n   305→    });\n   306→\n   307→    var svgW = padL * 2 + numLayers * nodeW + (numLayers - 1) * layerGap;\n   308→    var svgH = padT * 2 + totalLayerH + nonsuccOffset;\n   309→\n   310→    // --- Generate SVG ---\n   311→    var svg = '<svg class=\"dag-svg\" width=\"' + svgW + '\" height=\"' + svgH + '\">';\n   312→    svg += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker>';\n   313→    svg += '<marker id=\"arrowhead-fail\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--badge-failed-text)\"/></marker></defs>';\n   314→\n   315→    // Separate terminal wires (for merging) from normal wires\n   316→    var termWires = {};\n   317→    var normWires = [];\n   318→    wires.forEach(function(wire) {\n   319→        if (wire.to === 'done' || wire.to === 'abort') {\n   320→            if (!termWires[wire.to]) termWires[wire.to] = [];\n   321→            termWires[wire.to].push(wire);\n   322→        } else {\n   323→            normWires.push(wire);\n   324→        }\n   325→    });\n   326→\n   327→    // Helper: determine if a result is the success/happy-path\n   328→    function isSuccessResult(r) { return r === 'success' || r === 'ok' || r === 'done' || r === 'pass'; }\n   329→\n   330→    // Draw normal edges with Bezier curves\n   331→    normWires.forEach(function(wire) {\n   332→        var from = positions[wire.from], to = positions[wire.to];\n   333→        if (!from || !to) return;\n   334→        var x1 = from.x + nodeW, y1 = from.y + nodeH / 2;\n   335→        var x2 = to.x, y2 = to.y + nodeH / 2;\n   336→        var dx = x2 - x1;\n   337→        var isSucc = isSuccessResult(wire.result);\n   338→        var off = isSucc ? 0 : nonsuccOffset;\n   339→        var cls = 'dag-edge' + (isSucc ? '' : ' dag-edge-nonsuccess');\n   340→        var marker = isSucc ? 'url(#arrowhead)' : 'url(#arrowhead-fail)';\n   341→        svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + dx * 0.4) + ' ' + (y1 + off) + ' ' + (x1 + dx * 0.6) + ' ' + (y2 + off) + ' ' + x2 + ' ' + y2 + '\" class=\"' + cls + '\" marker-end=\"' + marker + '\"/>';\n   342→        svg += '<text x=\"' + (x1 + dx / 2) + '\" y=\"' + ((y1 + y2) / 2 + off - 6) + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n   343→    });\n   344→\n   345→    // Draw terminal edges with merge pattern for multiple wires\n   346→    for (var term in termWires) {\n   347→        var tWires = termWires[term];\n   348→        var tpos = positions[term];\n   349→        if (!tpos) continue;\n   350→\n   351→        if (tWires.length <= 1) {\n   352→            // Single wire to terminal - offset non-success wires\n   353→            tWires.forEach(function(wire) {\n   354→                var from = positions[wire.from];\n   355→                if (!from) return;\n   356→                var x1 = from.x + nodeW, y1 = from.y + nodeH / 2;\n   357→                var x2 = tpos.x, y2 = tpos.y + nodeH / 2;\n   358→                var dx = x2 - x1;\n   359→                var isSucc = isSuccessResult(wire.result);\n   360→                var off = isSucc ? 0 : nonsuccOffset;\n   361→                var cls = 'dag-edge' + (isSucc ? '' : ' dag-edge-nonsuccess');\n   362→                var marker = isSucc ? 'url(#arrowhead)' : 'url(#arrowhead-fail)';\n   363→                svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + dx * 0.4) + ' ' + (y1 + off) + ' ' + (x1 + dx * 0.6) + ' ' + (y2 + off) + ' ' + x2 + ' ' + y2 + '\" class=\"' + cls + '\" marker-end=\"' + marker + '\"/>';\n   364→                svg += '<text x=\"' + (x1 + dx / 2) + '\" y=\"' + ((y1 + y2) / 2 + off - 6) + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n   365→            });\n   366→            continue;\n   367→        }\n   368→\n   369→        // Multiple wires to same terminal: merge into a collector bus\n   370→        var mergeX = tpos.x - 50;\n   371→        var termY = tpos.y + nodeH / 2;\n   372→\n   373→        var srcPts = [];\n   374→        tWires.forEach(function(wire) {\n   375→            var from = positions[wire.from];\n   376→            if (!from) return;\n   377→            srcPts.push({ x: from.x + nodeW, y: from.y + nodeH / 2, result: wire.result });\n   378→        });\n   379→        srcPts.sort(function(a, b) { return a.y - b.y; });\n   380→\n   381→        // Individual curves from each source to the merge line (offset non-success)\n   382→        srcPts.forEach(function(pt) {\n   383→            var isSucc = isSuccessResult(pt.result);\n   384→            var off = isSucc ? 0 : nonsuccOffset;\n   385→            var dx = mergeX - pt.x;\n   386→            var arcY = pt.y + off;\n   387→            var cls = 'dag-edge' + (isSucc ? '' : ' dag-edge-nonsuccess');\n   388→            svg += '<path d=\"M' + pt.x + ' ' + pt.y + ' C' + (pt.x + dx * 0.5) + ' ' + arcY + ' ' + (mergeX - 20) + ' ' + arcY + ' ' + mergeX + ' ' + arcY + '\" class=\"' + cls + '\"/>';\n   389→            svg += '<text x=\"' + (pt.x + dx * 0.35) + '\" y=\"' + (arcY - 6) + '\" class=\"dag-edge-label\">' + pt.result + '</text>';\n   390→        });\n   391→\n   392→        // Vertical collector line\n   393→        var mergeEnds = srcPts.map(function(pt) { return pt.y + (isSuccessResult(pt.result) ? 0 : nonsuccOffset); });\n   394→        mergeEnds.push(termY);\n   395→        var minY = Math.min.apply(null, mergeEnds);\n   396→        var maxY = Math.max.apply(null, mergeEnds);\n   397→        var hasNonSucc = tWires.some(function(w) { return !isSuccessResult(w.result); });\n   398→        svg += '<path d=\"M' + mergeX + ' ' + minY + ' L' + mergeX + ' ' + maxY + '\" class=\"dag-edge dag-merge-line' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\"/>';\n   399→\n   400→        // Merge point dots (at offset positions for non-success wires)\n   401→        srcPts.forEach(function(pt) {\n   402→            var off = isSuccessResult(pt.result) ? 0 : nonsuccOffset;\n   403→            svg += '<circle cx=\"' + mergeX + '\" cy=\"' + (pt.y + off) + '\" r=\"3\" class=\"dag-merge-dot\"/>';\n   404→        });\n   405→\n   406→        // Single line from collector to terminal\n   407→        var mergeMarker = hasNonSucc ? 'url(#arrowhead-fail)' : 'url(#arrowhead)';\n   408→        svg += '<path d=\"M' + mergeX + ' ' + termY + ' L' + tpos.x + ' ' + termY + '\" class=\"dag-edge' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\" marker-end=\"' + mergeMarker + '\"/>';\n   409→    }\n   410→\n   411→    // Draw step nodes\n   412→    wf.steps.forEach(function(s) {\n   413→        var pos = positions[s.name];\n   414→        if (!pos) return;\n   415→        var icon = '\\u{1F4DC}';\n   416→        if (s.type === 'agent') icon = '\\u{1F916}';\n   417→        else if (s.type === 'workflow') icon = '\\u{1F501}';\n   418→        svg += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + s.name + '\\')\" style=\"cursor:pointer\">';\n   419→        svg += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n   420→        svg += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + s.name + '</text>';\n   421→        svg += '</g>';\n   422→    });\n   423→\n   424→    // Draw terminal nodes\n   425→    for (var t in terminals) {\n   426→        var pos = positions[t];\n   427→        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n   428→        svg += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n   429→        svg += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n   430→    }\n   431→\n   432→    svg += '</svg>';\n   433→    dagEl.innerHTML = svg;\n   434→}\n   435→\n   436→function openDrawer(workflowName, stepName) {\n   437→    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n   438→    if (!wf) return;\n   439→    var step = wf.steps.find(function(s) { return s.name === stepName; });\n   440→    if (!step) return;\n   441→\n   442→    document.getElementById('drawer-title').textContent = stepName;\n   443→    var body = '<dl class=\"run-meta\">';\n   444→    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n   445→    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n   446→    if (step.config) {\n   447→        for (var k in step.config) {\n   448→            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script' || k === 'run' || k === 'workflow_name') {\n   449→                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n   450→            }\n   451→        }\n   452→    }\n   453→    body += '</dl>';\n   454→    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n   455→\n   456→    document.getElementById('drawer-body').innerHTML = body;\n   457→    document.getElementById('step-drawer').classList.add('drawer-open');\n   458→\n   459→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n   460→        .then(function(r) { if (r.ok) return r.text(); return ''; })\n   461→        .then(function(text) {\n   462→            var el = document.getElementById('drawer-content');\n   463→            if (text) {\n   464→                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n   465→            } else {\n   466→                el.style.display = 'none';\n   467→            }\n   468→        });\n   469→}\n   470→\n   471→function closeDrawer() {\n   472→    document.getElementById('step-drawer').classList.remove('drawer-open');\n   473→}\n   474→\n   475→document.addEventListener('keydown', function(e) {\n   476→    if (e.key === 'Escape') closeDrawer();\n   477→});\n   478→\n   479→window.deleteAllContainers = function() {\n   480→    var btn = document.getElementById('delete-containers-btn');\n   481→    if (btn) btn.disabled = true;\n   482→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/containers', { method: 'DELETE' })\n   483→        .then(function(r) { return r.json(); })\n   484→        .then(function(data) {\n   485→            if (btn) {\n   486→                btn.textContent = 'Deleted ' + (data.deleted || 0) + ' container' + (data.deleted !== 1 ? 's' : '');\n   487→                btn.classList.remove('btn-danger');\n   488→                btn.classList.add('btn-secondary');\n   489→            }\n   490→        })\n   491→        .catch(function() {\n   492→            if (btn) {\n   493→                btn.textContent = 'Delete failed';\n   494→                btn.disabled = false;\n   495→            }\n   496→        });\n   497→};\n   498→\n   499→function escapeHtml(s) {\n   500→    var d = document.createElement('div');\n   501→    d.appendChild(document.createTextNode(s));\n   502→    return d.innerHTML;\n   503→}\n   504→\n   505→function releaseTask(taskId) {\n   506→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/tasks/' + encodeURIComponent(taskId) + '/release', { method: 'POST' })\n   507→        .then(function(r) { return r.json(); })\n   508→        .then(function(data) {\n   509→            if (data.error) {\n   510→                alert('Failed to release task: ' + data.error);\n   511→            } else {\n   512→                loadTasks();\n   513→            }\n   514→        })\n   515→        .catch(function() { alert('Failed to release task'); });\n   516→}\n   517→\n   518→function renderTaskTable(tasks, showRelease) {\n   519→    if (!tasks || tasks.length === 0) {\n   520→        return '<p class=\"empty\">No tasks</p>';\n   521→    }\n   522→    var html = '<table class=\"runs-table\" style=\"margin:0\"><thead><tr>';\n   523→    html += '<th>Task ID</th><th>Title</th><th>Status</th><th>Assigned</th><th>Run</th>';\n   524→    if (showRelease) html += '<th></th>';\n   525→    html += '</tr></thead><tbody>';\n   526→    for (var i = 0; i < tasks.length; i++) {\n   527→        var t = tasks[i];\n   528→        var statusClass = t.status === 'open' ? 'running' : (t.status === 'closed' ? 'succeeded' : 'pending');\n   529→        html += '<tr>';\n   530→        html += '<td class=\"mono\">' + escapeHtml(t.id) + '</td>';\n   531→        html += '<td>' + escapeHtml(t.title || '') + '</td>';\n   532→        html += '<td><span class=\"badge badge-' + statusClass + '\">' + escapeHtml(t.status) + '</span></td>';\n   533→        html += '<td>' + (t.assigned ? 'Yes' : 'No') + '</td>';\n   534→        html += '<td>' + (t.run_id ? '<a href=\"/runs/' + escapeHtml(t.run_id) + '\">' + escapeHtml(t.run_id) + '</a>' : '') + '</td>';\n   535→        if (showRelease) {\n   536→            html += '<td>';\n   537→            if (t.stale) {\n   538→                html += '<button class=\"btn btn-secondary btn-sm\" onclick=\"releaseTask(\\'' + escapeHtml(t.id) + '\\')\">Release</button>';\n   539→            }\n   540→            html += '</td>';\n   541→        }\n   542→        html += '</tr>';\n   543→    }\n   544→    html += '</tbody></table>';\n   545→    return html;\n   546→}\n   547→\n   548→function loadTasks() {\n   549→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/tasks')\n   550→        .then(function(r) { return r.json(); })\n   551→        .then(function(tasks) {\n   552→            var inProgress = [];\n   553→            var upcoming = [];\n   554→            if (tasks) {\n   555→                for (var i = 0; i < tasks.length; i++) {\n   556→                    var t = tasks[i];\n   557→                    if (t.status === 'in-progress' || t.status === 'in_progress') {\n   558→                        inProgress.push(t);\n   559→                    } else if (t.status === 'open' || t.status === '') {\n   560→                        upcoming.push(t);\n   561→                    }\n   562→                }\n   563→            }\n   564→            document.getElementById('in-progress-body').innerHTML = renderTaskTable(inProgress, true);\n   565→            document.getElementById('upcoming-body').innerHTML = renderTaskTable(upcoming, false);\n   566→        })\n   567→        .catch(function() {});\n   568→}\n   569→\n   570→// Load all panels\n   571→loadProjectInfo();\n   572→loadWorkflows();\n   573→loadTasks();\n   574→setInterval(loadTasks, 5000);\n   575→</script>\n   576→{{end}}\n   577→"}]},"parent_tool_use_id":null,"session_id":"e5f57d13-6940-497b-9967-e6dfa7c6b1ef","uuid":"5abefbb6-6048-48f6-8df0-524e8e1b8649","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/project_detail.html","content":"{{define \"content\"}}\n<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n\n<div class=\"run-history\" style=\"margin-bottom:1rem\">\n    {{range .RecentRuns}}\n    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n    {{end}}\n    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n    {{if .ContainerCount}}\n    <button class=\"btn btn-danger btn-sm\" id=\"delete-containers-btn\" onclick=\"deleteAllContainers()\" style=\"margin-left:0.5rem\">Delete {{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}</button>\n    {{end}}\n</div>\n\n<!-- Panel 1: Project Info -->\n<div class=\"panel\" id=\"info-panel\">\n    <div class=\"panel-header\">Project Info</div>\n    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n</div>\n\n<!-- Panel 2: In-progress Tasks -->\n<div class=\"panel\" id=\"in-progress-panel\">\n    <div class=\"panel-header\">In-progress Tasks</div>\n    <div class=\"panel-body\" id=\"in-progress-body\">Loading...</div>\n</div>\n\n<!-- Panel 3: Upcoming Tasks -->\n<div class=\"panel\" id=\"upcoming-panel\">\n    <div class=\"panel-header\">Upcoming Tasks</div>\n    <div class=\"panel-body\" id=\"upcoming-body\">Loading...</div>\n</div>\n\n<!-- Panel 3: Workflow View -->\n<div class=\"panel\" id=\"workflow-panel\">\n    <div class=\"panel-header\">Workflows</div>\n    <div class=\"panel-body\">\n        <div id=\"location-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-dag\"></div>\n    </div>\n</div>\n\n<!-- Step Drawer -->\n<div class=\"drawer\" id=\"step-drawer\">\n    <div class=\"drawer-header\">\n        <span id=\"drawer-title\"></span>\n        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    </div>\n    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n</div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\nvar projectLabel = {{.Label}};\n\nfunction loadProjectInfo() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n            html += '</dl>';\n\n            if (data.prompt_files && data.prompt_files.length > 0) {\n                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n                data.prompt_files.forEach(function(pf) {\n                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n                    if (pf.content) {\n                        html += '<pre class=\"diff-block\">' + pf.content.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n                    } else {\n                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">Empty file</p>';\n                    }\n                    html += '</details>';\n                });\n            }\n\n            document.getElementById('project-info').innerHTML = html;\n        });\n}\n\nfunction toggleDiff(el) {\n    var existing = el.nextElementSibling;\n    if (existing && existing.classList.contains('diff-block')) {\n        existing.remove();\n        return;\n    }\n    var file = el.getAttribute('data-file');\n    var sha = el.getAttribute('data-sha');\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n        .then(function(r) { return r.text(); })\n        .then(function(text) {\n            var pre = document.createElement('pre');\n            pre.className = 'diff-block';\n            pre.textContent = text || '(no diff available)';\n            el.parentNode.insertBefore(pre, el.nextSibling);\n        });\n}\n\nvar workflowsData = [];\nvar activeLocation = 'container';\n\nfunction loadWorkflows() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            workflowsData = data || [];\n            if (workflowsData.length === 0) {\n                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n                return;\n            }\n\n            // Check which locations exist\n            var hasContainer = workflowsData.some(function(wf) { return wf.location === 'container'; });\n            var hasHost = workflowsData.some(function(wf) { return wf.location === 'host'; });\n\n            // Render location tabs if both types exist\n            var locationTabs = document.getElementById('location-tabs');\n            if (hasContainer && hasHost) {\n                var html = '';\n                html += '<button class=\"tab-btn tab-active\" onclick=\"switchLocation(\\'container\\')\">Container</button>';\n                html += '<button class=\"tab-btn\" onclick=\"switchLocation(\\'host\\')\">Host</button>';\n                locationTabs.innerHTML = html;\n            } else {\n                locationTabs.innerHTML = '';\n            }\n\n            // Default to whichever location exists\n            activeLocation = hasContainer ? 'container' : 'host';\n            renderWorkflowTabs();\n        });\n}\n\nfunction switchLocation(loc) {\n    activeLocation = loc;\n    var btns = document.querySelectorAll('#location-tabs .tab-btn');\n    btns.forEach(function(b) {\n        b.classList.toggle('tab-active', b.textContent === (loc === 'container' ? 'Container' : 'Host'));\n    });\n    renderWorkflowTabs();\n}\n\nfunction renderWorkflowTabs() {\n    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n    var tabs = document.getElementById('workflow-tabs');\n\n    if (filtered.length === 0) {\n        tabs.innerHTML = '';\n        document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No ' + activeLocation + ' workflows found</p>';\n        return;\n    }\n\n    if (filtered.length > 1) {\n        var html = '';\n        filtered.forEach(function(wf, i) {\n            html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showFilteredWorkflow(' + i + ')\">' + wf.name + '</button>';\n        });\n        tabs.innerHTML = html;\n    } else {\n        tabs.innerHTML = '';\n    }\n    showFilteredWorkflow(0);\n}\n\nfunction showFilteredWorkflow(idx) {\n    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n    var btns = document.querySelectorAll('#workflow-tabs .tab-btn');\n    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n    showWorkflow(filtered[idx]);\n}\n\nfunction showWorkflow(wf) {\n    var dagEl = document.getElementById('workflow-dag');\n\n    if (!wf.steps || wf.steps.length === 0) {\n        dagEl.innerHTML = '<p class=\"empty\">No steps defined</p>';\n        return;\n    }\n\n    var stepMap = {};\n    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n\n    var wires = wf.wires || [];\n\n    // Collect terminal targets\n    var terminals = {};\n    wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n    });\n\n    // Build adjacency maps\n    var adj = {};    // from -> [wire]\n    var revAdj = {}; // to -> [from] (unique)\n    wires.forEach(function(wire) {\n        if (!adj[wire.from]) adj[wire.from] = [];\n        adj[wire.from].push(wire);\n        if (!revAdj[wire.to]) revAdj[wire.to] = [];\n        if (revAdj[wire.to].indexOf(wire.from) === -1) revAdj[wire.to].push(wire.from);\n    });\n\n    // --- Layer assignment via longest path (Sugiyama-style) ---\n    var stepNames = wf.steps.map(function(s) { return s.name; });\n\n    // Topological sort (Kahn's algorithm)\n    var inDeg = {};\n    stepNames.forEach(function(n) { inDeg[n] = 0; });\n    wires.forEach(function(wire) {\n        if (inDeg[wire.to] !== undefined) inDeg[wire.to]++;\n    });\n\n    var queue = [];\n    stepNames.forEach(function(n) { if (inDeg[n] === 0) queue.push(n); });\n\n    var topoOrder = [];\n    while (queue.length > 0) {\n        var n = queue.shift();\n        topoOrder.push(n);\n        (adj[n] || []).forEach(function(wire) {\n            if (inDeg[wire.to] !== undefined) {\n                inDeg[wire.to]--;\n                if (inDeg[wire.to] === 0) queue.push(wire.to);\n            }\n        });\n    }\n    // Add remaining steps (cycles or disconnected)\n    stepNames.forEach(function(n) { if (topoOrder.indexOf(n) === -1) topoOrder.push(n); });\n\n    // Assign layers: longest path from any source\n    var layerOf = {};\n    topoOrder.forEach(function(n) {\n        var maxParent = -1;\n        (revAdj[n] || []).forEach(function(p) {\n            if (layerOf[p] !== undefined && layerOf[p] > maxParent) maxParent = layerOf[p];\n        });\n        layerOf[n] = maxParent + 1;\n    });\n\n    var maxLayer = 0;\n    stepNames.forEach(function(n) { if (layerOf[n] > maxLayer) maxLayer = layerOf[n]; });\n\n    // Terminals in rightmost layer\n    var termLayer = maxLayer + 1;\n    for (var t in terminals) { layerOf[t] = termLayer; }\n    var numLayers = termLayer + 1;\n\n    // --- Build layer arrays ---\n    var layers = [];\n    for (var i = 0; i < numLayers; i++) layers.push([]);\n    topoOrder.forEach(function(n) { layers[layerOf[n]].push(n); });\n    for (var t in terminals) { layers[termLayer].push(t); }\n\n    // --- Barycenter ordering to minimize edge crossings ---\n    for (var pass = 0; pass < 4; pass++) {\n        // Forward pass\n        for (var li = 1; li < numLayers; li++) {\n            var bary = {};\n            layers[li].forEach(function(n) {\n                var pars = revAdj[n] || [];\n                var sum = 0, cnt = 0;\n                pars.forEach(function(p) {\n                    var idx = layers[li - 1].indexOf(p);\n                    if (idx >= 0) { sum += idx; cnt++; }\n                });\n                bary[n] = cnt > 0 ? sum / cnt : 999;\n            });\n            layers[li].sort(function(a, b) { return bary[a] - bary[b]; });\n        }\n        // Backward pass\n        for (var li = numLayers - 2; li >= 0; li--) {\n            var baryB = {};\n            layers[li].forEach(function(n) {\n                var children = (adj[n] || []).map(function(w) { return w.to; });\n                var sum = 0, cnt = 0;\n                children.forEach(function(c) {\n                    var idx = layers[li + 1].indexOf(c);\n                    if (idx >= 0) { sum += idx; cnt++; }\n                });\n                baryB[n] = cnt > 0 ? sum / cnt : 999;\n            });\n            layers[li].sort(function(a, b) { return baryB[a] - baryB[b]; });\n        }\n    }\n\n    // --- Position calculation ---\n    var nodeW = 180, nodeH = 48;\n    var layerGap = 120; // horizontal gap between layers\n    var nodeGap = 28;   // vertical gap between nodes in same layer\n    var nonsuccOffset = 35; // vertical offset for non-success wires\n    var padL = 30, padT = 30;\n\n    var maxInLayer = 1;\n    layers.forEach(function(l) { if (l.length > maxInLayer) maxInLayer = l.length; });\n    var totalLayerH = maxInLayer * nodeH + (maxInLayer - 1) * nodeGap;\n\n    var positions = {};\n    layers.forEach(function(layer, li) {\n        var lh = layer.length * nodeH + (layer.length - 1) * nodeGap;\n        var offsetY = (totalLayerH - lh) / 2;\n        layer.forEach(function(name, ni) {\n            positions[name] = {\n                x: padL + li * (nodeW + layerGap),\n                y: padT + offsetY + ni * (nodeH + nodeGap)\n            };\n        });\n    });\n\n    var svgW = padL * 2 + numLayers * nodeW + (numLayers - 1) * layerGap;\n    var svgH = padT * 2 + totalLayerH + nonsuccOffset;\n\n    // --- Generate SVG ---\n    var svg = '<svg class=\"dag-svg\" width=\"' + svgW + '\" height=\"' + svgH + '\">';\n    svg += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker>';\n    svg += '<marker id=\"arrowhead-fail\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--badge-failed-text)\"/></marker></defs>';\n\n    // Separate terminal wires (for merging) from normal wires\n    var termWires = {};\n    var normWires = [];\n    wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') {\n            if (!termWires[wire.to]) termWires[wire.to] = [];\n            termWires[wire.to].push(wire);\n        } else {\n            normWires.push(wire);\n        }\n    });\n\n    // Helper: determine if a result is the success/happy-path\n    function isSuccessResult(r) { return r === 'success' || r === 'ok' || r === 'done' || r === 'pass'; }\n\n    // Draw normal edges with Bezier curves\n    normWires.forEach(function(wire) {\n        var from = positions[wire.from], to = positions[wire.to];\n        if (!from || !to) return;\n        var x1 = from.x + nodeW, y1 = from.y + nodeH / 2;\n        var x2 = to.x, y2 = to.y + nodeH / 2;\n        var dx = x2 - x1;\n        var isSucc = isSuccessResult(wire.result);\n        var off = isSucc ? 0 : nonsuccOffset;\n        var cls = 'dag-edge' + (isSucc ? '' : ' dag-edge-nonsuccess');\n        var marker = isSucc ? 'url(#arrowhead)' : 'url(#arrowhead-fail)';\n        svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + dx * 0.4) + ' ' + (y1 + off) + ' ' + (x1 + dx * 0.6) + ' ' + (y2 + off) + ' ' + x2 + ' ' + y2 + '\" class=\"' + cls + '\" marker-end=\"' + marker + '\"/>';\n        svg += '<text x=\"' + (x1 + dx / 2) + '\" y=\"' + ((y1 + y2) / 2 + off - 6) + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n    });\n\n    // Draw terminal edges with merge pattern for multiple wires\n    for (var term in termWires) {\n        var tWires = termWires[term];\n        var tpos = positions[term];\n        if (!tpos) continue;\n\n        if (tWires.length <= 1) {\n            // Single wire to terminal - offset non-success wires\n            tWires.forEach(function(wire) {\n                var from = positions[wire.from];\n                if (!from) return;\n                var x1 = from.x + nodeW, y1 = from.y + nodeH / 2;\n                var x2 = tpos.x, y2 = tpos.y + nodeH / 2;\n                var dx = x2 - x1;\n                var isSucc = isSuccessResult(wire.result);\n                var off = isSucc ? 0 : nonsuccOffset;\n                var cls = 'dag-edge' + (isSucc ? '' : ' dag-edge-nonsuccess');\n                var marker = isSucc ? 'url(#arrowhead)' : 'url(#arrowhead-fail)';\n                svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + dx * 0.4) + ' ' + (y1 + off) + ' ' + (x1 + dx * 0.6) + ' ' + (y2 + off) + ' ' + x2 + ' ' + y2 + '\" class=\"' + cls + '\" marker-end=\"' + marker + '\"/>';\n                svg += '<text x=\"' + (x1 + dx / 2) + '\" y=\"' + ((y1 + y2) / 2 + off - 6) + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n            });\n            continue;\n        }\n\n        // Multiple wires to same terminal: merge into a collector bus\n        var mergeX = tpos.x - 50;\n        var termY = tpos.y + nodeH / 2;\n\n        var srcPts = [];\n        tWires.forEach(function(wire) {\n            var from = positions[wire.from];\n            if (!from) return;\n            srcPts.push({ x: from.x + nodeW, y: from.y + nodeH / 2, result: wire.result });\n        });\n        srcPts.sort(function(a, b) { return a.y - b.y; });\n\n        // Individual curves from each source to the merge line (offset non-success)\n        srcPts.forEach(function(pt) {\n            var isSucc = isSuccessResult(pt.result);\n            var off = isSucc ? 0 : nonsuccOffset;\n            var dx = mergeX - pt.x;\n            var arcY = pt.y + off;\n            var cls = 'dag-edge' + (isSucc ? '' : ' dag-edge-nonsuccess');\n            svg += '<path d=\"M' + pt.x + ' ' + pt.y + ' C' + (pt.x + dx * 0.5) + ' ' + arcY + ' ' + (mergeX - 20) + ' ' + arcY + ' ' + mergeX + ' ' + arcY + '\" class=\"' + cls + '\"/>';\n            svg += '<text x=\"' + (pt.x + dx * 0.35) + '\" y=\"' + (arcY - 6) + '\" class=\"dag-edge-label\">' + pt.result + '</text>';\n        });\n\n        // Vertical collector line\n        var mergeEnds = srcPts.map(function(pt) { return pt.y + (isSuccessResult(pt.result) ? 0 : nonsuccOffset); });\n        mergeEnds.push(termY);\n        var minY = Math.min.apply(null, mergeEnds);\n        var maxY = Math.max.apply(null, mergeEnds);\n        var hasNonSucc = tWires.some(function(w) { return !isSuccessResult(w.result); });\n        svg += '<path d=\"M' + mergeX + ' ' + minY + ' L' + mergeX + ' ' + maxY + '\" class=\"dag-edge dag-merge-line' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\"/>';\n\n        // Merge point dots (at offset positions for non-success wires)\n        srcPts.forEach(function(pt) {\n            var off = isSuccessResult(pt.result) ? 0 : nonsuccOffset;\n            svg += '<circle cx=\"' + mergeX + '\" cy=\"' + (pt.y + off) + '\" r=\"3\" class=\"dag-merge-dot\"/>';\n        });\n\n        // Single line from collector to terminal\n        var mergeMarker = hasNonSucc ? 'url(#arrowhead-fail)' : 'url(#arrowhead)';\n        svg += '<path d=\"M' + mergeX + ' ' + termY + ' L' + tpos.x + ' ' + termY + '\" class=\"dag-edge' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\" marker-end=\"' + mergeMarker + '\"/>';\n    }\n\n    // Draw step nodes\n    wf.steps.forEach(function(s) {\n        var pos = positions[s.name];\n        if (!pos) return;\n        var icon = '\\u{1F4DC}';\n        if (s.type === 'agent') icon = '\\u{1F916}';\n        else if (s.type === 'workflow') icon = '\\u{1F501}';\n        svg += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + s.name + '\\')\" style=\"cursor:pointer\">';\n        svg += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n        svg += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + s.name + '</text>';\n        svg += '</g>';\n    });\n\n    // Draw terminal nodes\n    for (var t in terminals) {\n        var pos = positions[t];\n        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n        svg += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n        svg += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n    }\n\n    svg += '</svg>';\n    dagEl.innerHTML = svg;\n}\n\nfunction openDrawer(workflowName, stepName) {\n    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n    if (!wf) return;\n    var step = wf.steps.find(function(s) { return s.name === stepName; });\n    if (!step) return;\n\n    document.getElementById('drawer-title').textContent = stepName;\n    var body = '<dl class=\"run-meta\">';\n    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n    if (step.config) {\n        for (var k in step.config) {\n            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script' || k === 'run' || k === 'workflow_name') {\n                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n            }\n        }\n    }\n    body += '</dl>';\n    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n\n    document.getElementById('drawer-body').innerHTML = body;\n    document.getElementById('step-drawer').classList.add('drawer-open');\n\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n        .then(function(r) { if (r.ok) return r.text(); return ''; })\n        .then(function(text) {\n            var el = document.getElementById('drawer-content');\n            if (text) {\n                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n            } else {\n                el.style.display = 'none';\n            }\n        });\n}\n\nfunction closeDrawer() {\n    document.getElementById('step-drawer').classList.remove('drawer-open');\n}\n\ndocument.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') closeDrawer();\n});\n\nwindow.deleteAllContainers = function() {\n    var btn = document.getElementById('delete-containers-btn');\n    if (btn) btn.disabled = true;\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/containers', { method: 'DELETE' })\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            if (btn) {\n                btn.textContent = 'Deleted ' + (data.deleted || 0) + ' container' + (data.deleted !== 1 ? 's' : '');\n                btn.classList.remove('btn-danger');\n                btn.classList.add('btn-secondary');\n            }\n        })\n        .catch(function() {\n            if (btn) {\n                btn.textContent = 'Delete failed';\n                btn.disabled = false;\n            }\n        });\n};\n\nfunction escapeHtml(s) {\n    var d = document.createElement('div');\n    d.appendChild(document.createTextNode(s));\n    return d.innerHTML;\n}\n\nfunction releaseTask(taskId) {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/tasks/' + encodeURIComponent(taskId) + '/release', { method: 'POST' })\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            if (data.error) {\n                alert('Failed to release task: ' + data.error);\n            } else {\n                loadTasks();\n            }\n        })\n        .catch(function() { alert('Failed to release task'); });\n}\n\nfunction renderTaskTable(tasks, showRelease) {\n    if (!tasks || tasks.length === 0) {\n        return '<p class=\"empty\">No tasks</p>';\n    }\n    var html = '<table class=\"runs-table\" style=\"margin:0\"><thead><tr>';\n    html += '<th>Task ID</th><th>Title</th><th>Status</th><th>Assigned</th><th>Run</th>';\n    if (showRelease) html += '<th></th>';\n    html += '</tr></thead><tbody>';\n    for (var i = 0; i < tasks.length; i++) {\n        var t = tasks[i];\n        var statusClass = t.status === 'open' ? 'running' : (t.status === 'closed' ? 'succeeded' : 'pending');\n        html += '<tr>';\n        html += '<td class=\"mono\">' + escapeHtml(t.id) + '</td>';\n        html += '<td>' + escapeHtml(t.title || '') + '</td>';\n        html += '<td><span class=\"badge badge-' + statusClass + '\">' + escapeHtml(t.status) + '</span></td>';\n        html += '<td>' + (t.assigned ? 'Yes' : 'No') + '</td>';\n        html += '<td>' + (t.run_id ? '<a href=\"/runs/' + escapeHtml(t.run_id) + '\">' + escapeHtml(t.run_id) + '</a>' : '') + '</td>';\n        if (showRelease) {\n            html += '<td>';\n            if (t.stale) {\n                html += '<button class=\"btn btn-secondary btn-sm\" onclick=\"releaseTask(\\'' + escapeHtml(t.id) + '\\')\">Release</button>';\n            }\n            html += '</td>';\n        }\n        html += '</tr>';\n    }\n    html += '</tbody></table>';\n    return html;\n}\n\nfunction loadTasks() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/tasks')\n        .then(function(r) { return r.json(); })\n        .then(function(tasks) {\n            var inProgress = [];\n            var upcoming = [];\n            if (tasks) {\n                for (var i = 0; i < tasks.length; i++) {\n                    var t = tasks[i];\n                    if (t.status === 'in-progress' || t.status === 'in_progress') {\n                        inProgress.push(t);\n                    } else if (t.status === 'open' || t.status === '') {\n                        upcoming.push(t);\n                    }\n                }\n            }\n            document.getElementById('in-progress-body').innerHTML = renderTaskTable(inProgress, true);\n            document.getElementById('upcoming-body').innerHTML = renderTaskTable(upcoming, false);\n        })\n        .catch(function() {});\n}\n\n// Load all panels\nloadProjectInfo();\nloadWorkflows();\nloadTasks();\nsetInterval(loadTasks, 5000);\n</script>\n{{end}}\n","numLines":577,"startLine":1,"totalLines":577}}}
