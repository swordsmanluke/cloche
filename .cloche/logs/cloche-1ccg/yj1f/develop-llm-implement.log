\n   321→    });\n   322→\n   323→    var laneMap = {};\n   324→    var numLanes = 0;\n   325→    for (var key in nonSuccTermGroups) {\n   326→        laneMap[key] = numLanes;\n   327→        numLanes++;\n   328→    }\n   329→\n   330→    // --- Position calculation ---\n   331→    var nodeW = 180, nodeH = 48;\n   332→    var layerGap = 120; // horizontal gap between layers\n   333→    var nodeGap = 28;   // vertical gap between nodes in same layer\n   334→    var padL = 30, padT = 30;\n   335→    var laneGapV = 40;  // vertical spacing per offset lane\n   336→    var laneOffset = 50; // gap between bottom of nodes and first lane\n   337→\n   338→    var maxInLayer = 1;\n   339→    layers.forEach(function(l) { if (l.length > maxInLayer) maxInLayer = l.length; });\n   340→    var totalLayerH = maxInLayer * nodeH + (maxInLayer - 1) * nodeGap;\n   341→\n   342→    var positions = {};\n   343→    layers.forEach(function(layer, li) {\n   344→        var lh = layer.length * nodeH + (layer.length - 1) * nodeGap;\n   345→        var offsetY = (totalLayerH - lh) / 2;\n   346→        layer.forEach(function(name, ni) {\n   347→            positions[name] = {\n   348→                x: padL + li * (nodeW + layerGap),\n   349→                y: padT + offsetY + ni * (nodeH + nodeGap)\n   350→            };\n   351→        });\n   352→    });\n   353→\n   354→    var laneBaseY = padT + totalLayerH + laneOffset;\n   355→    function laneY(idx) { return laneBaseY + idx * laneGapV; }\n   356→\n   357→    var svgW = padL * 2 + numLayers * nodeW + (numLayers - 1) * layerGap;\n   358→    var svgH = padT * 2 + totalLayerH + (numLanes > 0 ? laneOffset + numLanes * laneGapV + 20 : 0);\n   359→\n   360→    // --- Generate SVG ---\n   361→    var svg = '<svg class=\"dag-svg\" width=\"' + svgW + '\" height=\"' + svgH + '\">';\n   362→\n   363→    // Create arrowhead markers for each unique color\n   364→    svg += '<defs>';\n   365→    var markerColors = {};\n   366→    for (var r in resultC