;\n        --badge-cancelled-bg: #374151;\n        --badge-cancelled-text: #9ca3af;\n        --badge-stopped-bg: #374151;\n        --badge-stopped-text: #9ca3af;\n\n        --error-bg: #450a0a;\n        --error-border: #7f1d1d;\n        --error-text: #fca5a5;\n    }\n}\n\n*, *::before, *::after { box-sizing: border-box; }\n\nbody {\n    margin: 0;\n    font-family: var(--font);\n    background: var(--bg);\n    color: var(--text);\n    line-height: 1.5;\n}\n\n.container {\n    max-width: 1100px;\n    margin: 0 auto;\n    padding: 0 1rem;\n}\n\na { color: var(--link); text-decoration: none; }\na:hover { text-decoration: underline; }\n\n.navbar {\n    background: var(--bg-surface);\n    border-bottom: 1px solid var(--border);\n    padding: 0.75rem 0;\n    margin-bottom: 1.5rem;\n}\n\n.logo {\n    font-weight: 700;\n    font-size: 1.1rem;\n    color: var(--text);\n}\n.logo:hover { text-decoration: none; }\n\nh1 {\n    font-size: 1.4rem;\n    margin: 0 0 1rem;\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    flex-wrap: wrap;\n}\n\nh1 a { font-weight: 400; }\n\nh2 {\n    font-size: 1.1rem;\n    margin: 1.5rem 0 0.75rem;\n}\n\n/* Badges */\n.badge {\n    display: inline-block;\n    padding: 0.15em 0.55em;\n    border-radius: var(--radius);\n    font-size: 0.8rem;\n    font-weight: 600;\n    white-space: nowrap;\n}\n\n.badge-pending  { background: var(--badge-pending-bg);  color: var(--badge-pending-text); }\n.badge-running  { background: var(--badge-running-bg);  color: var(--badge-running-text); animation: pulse 2s infinite; }\n.badge-succeeded { background: var(--badge-succeeded-bg); color: var(--badge-succeeded-text); }\n.badge-failed   { background: var(--badge-failed-bg);   color: var(--badge-failed-text); }\n.badge-cancelled { background: var(--badge-cancelled-bg); color: var(--badge-cancelled-text); }\n.badge-stopped  { background: var(--badge-stopped-bg);  color: var(--badge-stopped-text); }\n\n@keyframes pulse {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0.6; }\n}\n\n/* Tables */\n.runs-table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 0.9rem;\n}\n\n.runs-table th,\n.runs-table td {\n    padding: 0.5rem 0.75rem;\n    text-align: left;\n    border-bottom: 1px solid var(--border);\n}\n\n.runs-table th {\n    background: var(--bg-surface);\n    font-weight: 600;\n    font-size: 0.8rem;\n    text-transform: uppercase;\n    letter-spacing: 0.03em;\n    color: var(--text-muted);\n}\n\n.runs-table tr:hover { background: var(--bg-surface); }\n.detail-row:hover { background: inherit; }\n.step-row { cursor: pointer; }\n.output-row td { padding: 0 !important; }\n.step-output {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 0.75rem;\n    font-family: var(--mono);\n    font-size: 0.8rem;\n    max-height: 500px;\n    overflow: auto;\n    white-space: pre-wrap;\n    word-break: break-word;\n    margin: 0.25rem 0.75rem 0.75rem;\n}\n\n.mono { font-family: var(--mono); font-size: 0.85em; }\n.empty { color: var(--text-muted); text-align: center; padding: 2rem 0; }\n.error-cell { color: var(--badge-failed-text); font-size: 0.85em; }\n\n/* Run metadata */\n.run-meta dl {\n    display: grid;\n    grid-template-columns: auto 1fr;\n    gap: 0.25rem 1rem;\n    margin: 0 0 1rem;\n    font-size: 0.9rem;\n}\n\n.run-meta dt { color: var(--text-muted); font-weight: 600; }\n.run-meta dd { margin: 0; }\n\n/* Error box */\n.error-box {\n    background: var(--error-bg);\n    border: 1px solid var(--error-border);\n    color: var(--error-text);\n    padding: 0.75rem 1rem;\n    border-radius: var(--radius);\n    margin-bottom: 1rem;\n    font-size: 0.9rem;\n}\n\n/* Details / pre */\ndetails {\n    margin: 0.5rem 0;\n}\n\ndetails summary {\n    cursor: pointer;\n    font-weight: 600;\n    font-size: 0.85rem;\n    color: var(--text-muted);\n}\n\ndetails pre {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 0.75rem;\n    font-family: var(--mono);\n    font-size: 0.8rem;\n    max-height: 400px;\n    overflow: auto;\n    white-space: pre-wrap;\n    word-break: break-word;\n    margin: 0.5rem 0 0;\n}\n\n/* Project filter */\n.project-filter {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    margin-bottom: 1rem;\n    font-size: 0.9rem;\n}\n\n.project-filter label {\n    font-weight: 600;\n    color: var(--text-muted);\n}\n\n.project-filter select {\n    font-family: var(--font);\n    font-size: 0.9rem;\n    padding: 0.3rem 0.5rem;\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    background: var(--bg);\n    color: var(--text);\n    cursor: pointer;\n}\n\n/* Project cards */\n.project-cards {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\n    gap: 1rem;\n}\n\n.project-card {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 1rem 1.25rem;\n    display: flex;\n    flex-direction: column;\n    gap: 0.75rem;\n}\n\n.project-header {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n}\n\n.project-name {\n    font-weight: 600;\n    font-size: 1.05rem;\n}\n\n/* Health indicator dots */\n.health-dot {\n    display: inline-block;\n    width: 12px;\n    height: 12px;\n    border-radius: 50%;\n    flex-shrink: 0;\n}\n\n.health-green  { background: #22c55e; }\n.health-yellow { background: #eab308; }\n.health-red    { background: #ef4444; }\n.health-grey   { background: #9ca3af; }\n.health-blue   { background: #3b82f6; animation: pulse 2s infinite; }\n\n/* Project stats */\n.project-stats {\n    display: flex;\n    gap: 1.5rem;\n}\n\n.stat {\n    display: flex;\n    flex-direction: column;\n}\n\n.stat-value {\n    font-weight: 700;\n    font-size: 1.1rem;\n}\n\n.stat-label {\n    font-size: 0.75rem;\n    color: var(--text-muted);\n    text-transform: uppercase;\n    letter-spacing: 0.03em;\n}\n\n/* Mini run history dots */\n.run-history {\n    display: flex;\n    gap: 4px;\n    align-items: center;\n    min-height: 16px;\n}\n\n.run-dot {\n    display: inline-block;\n    width: 10px;\n    height: 10px;\n    border-radius: 50%;\n}\n\n.run-dot-succeeded { background: #22c55e; }\n.run-dot-failed    { background: #ef4444; }\n.run-dot-cancelled { background: #9ca3af; }\n.run-dot-running   { background: #3b82f6; animation: pulse 2s infinite; }\n.run-dot-pending   { background: #eab308; }\n\n/* Action buttons */\n.project-actions {\n    display: flex;\n    gap: 0.5rem;\n    margin-top: 0.25rem;\n}\n\n.btn {\n    display: inline-block;\n    padding: 0.35em 0.75em;\n    border-radius: var(--radius);\n    font-family: var(--font);\n    font-size: 0.8rem;\n    font-weight: 600;\n    border: 1px solid var(--border);\n    cursor: pointer;\n    text-decoration: none;\n    white-space: nowrap;\n}\n\n.btn:hover { text-decoration: none; }\n\n.btn-secondary {\n    background: var(--bg);\n    color: var(--link);\n}\n\n.btn-secondary:hover { background: var(--bg-surface); }\n\n.btn-primary {\n    background: var(--link);\n    color: #fff;\n    border-color: var(--link);\n}\n\n.btn-primary:hover { opacity: 0.9; }\n\n.btn-danger {\n    background: var(--badge-failed-bg);\n    color: var(--badge-failed-text);\n    border-color: var(--error-border);\n}\n\n.btn-danger:hover { opacity: 0.8; }\n\n.btn-sm { font-size: 0.75rem; padding: 0.15em 0.45em; }\n\n.btn:disabled {\n    opacity: 0.6;\n    cursor: not-allowed;\n}\n\n/* Log viewer */\n.log-viewer {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    max-height: 600px;\n    overflow: auto;\n    margin-bottom: 1.5rem;\n}\n\n.log-viewer pre {\n    margin: 0;\n    padding: 0.75rem;\n    font-family: var(--mono);\n    font-size: 0.8rem;\n    white-space: pre-wrap;\n    word-break: break-word;\n    line-height: 1.4;\n}\n\n/* Load-earlier button inside