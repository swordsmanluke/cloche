  52→        --error-bg: #450a0a;\n    53→        --error-border: #7f1d1d;\n    54→        --error-text: #fca5a5;\n    55→    }\n    56→}\n    57→\n    58→*, *::before, *::after { box-sizing: border-box; }\n    59→\n    60→body {\n    61→    margin: 0;\n    62→    font-family: var(--font);\n    63→    background: var(--bg);\n    64→    color: var(--text);\n    65→    line-height: 1.5;\n    66→}\n    67→\n    68→.container {\n    69→    max-width: 1100px;\n    70→    margin: 0 auto;\n    71→    padding: 0 1rem;\n    72→}\n    73→\n    74→a { color: var(--link); text-decoration: none; }\n    75→a:hover { text-decoration: underline; }\n    76→\n    77→.navbar {\n    78→    background: var(--bg-surface);\n    79→    border-bottom: 1px solid var(--border);\n    80→    padding: 0.75rem 0;\n    81→    margin-bottom: 1.5rem;\n    82→}\n    83→\n    84→.logo {\n    85→    font-weight: 700;\n    86→    font-size: 1.1rem;\n    87→    color: var(--text);\n    88→}\n    89→.logo:hover { text-decoration: none; }\n    90→\n    91→h1 {\n    92→    font-size: 1.4rem;\n    93→    margin: 0 0 1rem;\n    94→    display: flex;\n    95→    align-items: center;\n    96→    gap: 0.5rem;\n    97→    flex-wrap: wrap;\n    98→}\n    99→\n   100→h1 a { font-weight: 400; }\n   101→\n   102→h2 {\n   103→    font-size: 1.1rem;\n   104→    margin: 1.5rem 0 0.75rem;\n   105→}\n   106→\n   107→/* Badges */\n   108→.badge {\n   109→    display: inline-block;\n   110→    padding: 0.15em 0.55em;\n   111→    border-radius: var(--radius);\n   112→    font-size: 0.8rem;\n   113→    font-weight: 600;\n   114→    white-space: nowrap;\n   115→}\n   116→\n   117→.badge-pending  { background: var(--badge-pending-bg);  color: var(--badge-pending-text); }\n   118→.badge-running  { background: var(--badge-running-bg);  color: var(--badge-running-text); animation: pulse 2s infinite; }\n   119→.badge-succeeded { background: var(--badge-succeeded-bg); color: var(--badge-succeeded-text); }\n   120→.badge-failed   { background: var(--badge-failed-bg);   color: var(--badge-failed-text); }\n   121→.badge-cancelled { background: var(--badge-cancelled-bg); color: var(--badge-cancelled-text); }\n   122→.badge-stopped  { background: var(--badge-stopped-bg);  color: var(--badge-stopped-text); }\n   123→\n   124→@keyframes pulse {\n   125→    0%, 100% { opacity: 1; }\n   126→    50% { opacity: 0.6; }\n   127→}\n   128→\n   129→/* Tables */\n   130→.runs-table {\n   131→    width: 100%;\n   132→    border-collapse: collapse;\n   133→    font-size: 0.9rem;\n   134→}\n   135→\n   136→.runs-table th,\n   137→.runs-table td {\n   138→    padding: 0.5rem 0.75rem;\n   139→    text-align: left;\n   140→    border-bottom: 1px solid var(--border);\n   141→}\n   142→\n   143→.runs-table th {\n   144→    background: var(--bg-surface);\n   145→    font-weight: 600;\n   146→    font-size: 0.8rem;\n   147→    text-transform: uppercase;\n   148→    letter-spacing: 0.03em;\n   149→    color: var(--text-muted);\n   150→}\n   151→\n   152→.runs-table tr:hover { background: var(--bg-surface); }\n   153→.detail-row:hover { background: inherit; }\n   154→.step-row { cursor: pointer; }\n   155→.output-row td { padding: 0 !important; }\n   156→.step-output {\n   157→    background: var(--bg-surface);\n   158→    border: 1px solid var(--border);\n   159→    border-radius: var(--radius);\n   160→    padding: 0.75rem;\n   161→    font-family: var(--mono);\n   162→    font-size: 0.8rem;\n   163→    max-height: 500px;\n   164→    overflow: auto;\n   165→    white-space: pre-wrap;\n   166→    word-break: break-word;\n   167→    margin: 0.25rem 0.75rem 0.75rem;\n   168→}\n   169→\n   170→.mono { font-family: var(--mono); font-size: 0.85em; }\n   171→.empty { color: var(--text-muted); text-align: center; padding: 2rem 0; }\n   172→.error-cell { color: var(--badge-failed-text); font-size: 0.85em; }\n   173→\n   174→/* Run metadata */\n   175→.run-meta dl {\n   176→    display: grid;\n   177→    grid-template-columns: auto 1fr;\n   178→    gap: 0.25rem 1rem;\n   179→    margin: 0 0 1rem;\n   180→    font-size: 0.9rem;\n   181→}\n   182→\n   183→.run-meta dt { color: var(--text-muted); font-weight: 600; }\n   184→.run-meta dd { margin: 0; }\n   185→\n   186→/* Error box */\n   187→.error-box {\n   188→    background: var(--error-bg);\n   189→    border: 1px solid var(--error-border);\n   190→    color: var(--error-text);\n   191→    padding: 0.75rem 1rem;\n   192→    border-radius: var(--radius);\n   193→    margin-bottom: 1rem;\n   194→    font-size: 0.9rem;\n   195→}\n   196→\n   197→/* Details / pre */\n   198→details {\n   199→    margin: 0.5rem 0;\n   200→}\n   201→\n   202→details summary {\n   203→    cursor: pointer;\n   204→    font-weight: 600;\n   205→    font-size: 0.85rem;\n   206→    color: var(--text-muted);\n   207→}\n   208→\n   209→details pre {\n   210→    background: var(--bg-surface);\n   211→    border: 1px solid var(--border);\n   212→    border-radius: var(--radius);\n   213→    padding: 0.75rem;\n   214→    font-family: var(--mono);\n   215→    font-size: 0.8rem;\n   216→    max-height: 400px;\n   217→    overflow: auto;\n   218→    white-space: pre-wrap;\n   219→    word-break: break-word;\n   220→    margin: 0.5rem 0 0;\n   221→}\n   222→\n   223→/* Project filter */\n   224→.project-filter {\n   225→    display: flex;\n   226→    align-items: center;\n   227→    gap: 0.5rem;\n   228→    margin-bottom: 1rem;\n   229→    font-size: 0.9rem;\n   230→}\n   231→\n   232→.project-filter label {\n   233→    font-weight: 600;\n   234→    color: var(--text-muted);\n   235→}\n   236→\n   237→.project-filter select {\n   238→    font-family: var(--font);\n   239→    font-size: 0.9rem;\n   240→    padding: 0.3rem 0.5rem;\n   241→    border: 1px solid var(--border);\n   242→    border-radius: var(--radius);\n   243→    background: var(--bg);\n   244→    color: var(--text);\n   245→    cursor: pointer;\n   246→}\n   247→\n   248→/* Project cards */\n   249→.project-cards {\n   250→    display: grid;\n   251→    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\n   252→    gap: 1rem;\n   253→}\n   254→\n   255→.project-card {\n   256→    background: var(--bg-surface);\n   257→    border: 1px solid var(--border);\n   258→    border-radius: var(--radius);\n   259→    padding: 1rem 1.25rem;\n   260→    display: flex;\n   261→    flex-direction: column;\n   262→    gap: 0.75rem;\n   263→}\n   264→\n   265→.project-header {\n   266→    display: flex;\n   267→    align-items: center;\n   268→    gap: 0.5rem;\n   269→}\n   270→\n   271→.project-name {\n   272→    font-weight: 600;\n   273→    font-size: 1.05rem;\n   274→}\n   275→\n   276→/* Health indicator dots */\n   277→.health-dot {\n   278→    display: inline-block;\n   279→    width: 12px;\n   280→    height: 12px;\n   281→    border-radius: 50%;\n   282→    flex-shrink: 0;\n   283→}\n   284→\n   285→.health-green  { background: #22c55e; }\n   286→.health-yellow { background: #eab308; }\n   287→.health-red    { background: #ef4444; }\n   288→.health-grey   { background: #9ca3af; }\n   289→.health-blue   { background: #3b82f6; animation: pulse 2s infinite; }\n   290→\n   291→/* Project stats */\n   292→.project-stats {\n   293→    display: flex;\n   294→    gap: 1.5rem;\n   295→}\n   296→\n   297→.stat {\n   298→    display: flex;\n   299→    flex-direction: column;\n   300→}\n   301→\n   302→.stat-value {\n   303→    font-weight: 700;\n   304→    font-size: 1.1rem;\n   305→}\n   306→\n   307→.stat-label {\n   308→    font-size: 0.75rem;\n   309→    color: var(--text-muted);\n   310→    text-transform: uppercase;\n   311→    letter-spacing: 0.03em;\n   312→}\n   313→\n   314→/* Mini run history dots */\n   315→.run-history {\n   316→    display: flex;\n   317→    gap: 4px;\n   318→    align-items: center;\n   319→    min-height: 16px;\n   320→}\n   321→\n   322→.run-dot {\n   323→    display: inline-block;\n   324→    width: 10px;\n   325→    height: 10px;\n   326→    border-radius: 50%;\n   327→}\n   328→\n   329→.run-dot-succeeded { background: #22c55e; }\n   330→.run-dot-failed    { background: #ef4444; }\n   331→.run-dot-cancelled { background: #9ca3af; }\n   332→.run-dot-running   { background: #3b82f6; animation: pulse 2s infinite; }\n   333→.run-dot-pending   { background: #eab308; }\n   334→\n   335→/* Action buttons */\n   336→.project-actions {\n   337→    display: flex;\n   338→    gap: 0.5rem;\n   339→    margin-top: 0.25rem;\n   340→}\n   341→\n   342→.btn {\n   343→    display: inline-block;\n   344→    padding: 0.35em 0.75em;\n   345→    border-radius: var(--radius);\n   346→    font-family: var(--font);\n   347→    font-size: 0.8rem;\n   348→    font-weight: 600;\n   349→    border: 1px solid var(--border);\n   350→    cursor: pointer;\n   351→    text-decoration: none;\n   352→    white-space: nowrap;\n   353→}\n   354→\n   355→.btn:hover { text-decoration: none; }\n   356→\n   357→.btn-secondary {\n   358→    background: var(--bg);\n   359→    color: var(--link);\n   360→}\n   361→\n   362→.btn-secondary:hover { background: var(--bg-surface); }\n   363→\n   364→.btn-primary {\n   365→    background: var(--link);\n   366→    color: #fff;\n   367→    border-color: var(--link);\n   368→}\n   369→\n   370→.btn-primary:hover { opacity: 0.9; }\n   371→\n   372→.btn-danger {\n   373→    background: var(--badge-failed-bg);\n   374→    color: var(--badge-failed-text);\n   375→    border-color: var(--error-border);\n   376→}\n   377→\n   378→.btn-danger:hover { opacity: 0.8; }\n   379→\n   380→.btn-sm { font-size: 0.75rem; padding: 0.15em 0.45em; }\n   381→\n   382→.btn:disabled {\n   383→    opacity: 0.6;\n   384→    cursor: not-allowed;\n   385→}\n   386→\n   387→/* Log viewer */\n   388→.log-viewer {\n   389→    background: var(--bg-surface);\n   390→    border: 1px solid var(--border);\n   391→    border-radius: var(--radius);\n   392→    max-height: 600px;\n   393→    overflow: auto;\n   394→    margin-bottom: 1.5rem;\n   395→}\n   396→\n   397→.log-viewer pre {\n   398→    margin: 0;\n   399→    padding: 0.75rem;\n   400→    font-family: var(--mono);\n   401→    font-size: 0.8rem;\n   402→    white-space: pre-wrap;\n   403→    word-break: break-word;\n   404→    line-height: 1.4;\n   405→}\n   406→\n   407→/* Load-earlier button inside log viewer */\n   408→.load-earlier-btn {\n   409→    display: block;\n   410→    width: 100%;\n   411→    padding: 0.4rem;\n   412→    text-align: center;\n   413→    background: var(--bg-secondary);\n   414→    border: none;\n   415→    border-bottom: 1px solid var(--border);\n   416→    cursor: pointer;\n   417→    font-size: 0.8rem;\n   418→    font-family: var(--mono);\n   419→    color: var(--link);\n   420→}\n   421→.load-earlier-btn:hover { background: var(--border); }\n   422→.load-earlier-btn:disabled { opacity: 0.5; cursor: wait; }\n   423→\n   424→.log-line { display: block; }\n   425→.log-type-status { color: var(--badge-running-text); }\n   426→.log-type-llm { color: var(--badge-succeeded-text); }\n   427→.log-type-script { color: var(--text); }\n   428→\n   429→/* Panels */\n   430→.panel {\n   431→    background: var(--bg-surface);\n   432→    border: 1px solid var(--border);\n   433→    border-radius: var(--radius);\n   434→    margin-bottom: 1rem;\n   435→}\n   436→\n   437→.panel-header {\n   438→    font-weight: 700;\n   439→    font-size: 0.9rem;\n   440→    padding: 0.6rem 1rem;\n   441→    border-bottom: 1px solid var(--border);\n   442→    text-transform: uppercase;\n   443→    letter-spacing: 0.03em;\n   444→    color: var(--text-muted);\n   445→}\n   446→\n   447→.panel-body {\n   448→    padding: 1rem;\n   449→}\n   450→\n   451→/* Tabs */\n   452→.tab-bar {\n   453→    display: flex;\n   454→    gap: 0;\n   455→    border-bottom: 1px solid var(--border);\n   456→    margin-bottom: 1rem;\n   457→}\n   458→.tab-bar:empty {\n   459→    display: none;\n   460→}\n   461→\n   462→.tab-btn {\n   463→    padding: 0.4rem 1rem;\n   464→    font-family: var(--font);\n   465→    font-size: 0.85rem;\n   466→    font-weight: 600;\n   467→    background: none;\n   468→    border: none;\n   469→    border-bottom: 2px solid transparent;\n   470→    color: var(--text-muted);\n   471→    cursor: pointer;\n   472→}\n   473→\n   474→.tab-btn:hover { color: var(--text); }\n   475→.tab-btn.tab-active { color: var(--link); border-bottom-color: var(--link); }\n   476→\n   477→/* DAG */\n   478→.dag-svg { display: block; }\n   479→#workflow-dag { overflow-x: auto; }\n   480→\n   481→.dag-node-rect {\n   482→    fill: var(--bg);\n   483→    stroke: var(--border);\n   484→    stroke-width: 1.5;\n   485→    rx: 4;\n   486→}\n   487→\n   488→.dag-node:hover .dag-node-rect { stroke: var(--link); stroke-width: 2; }\n   489→\n   490→.dag-node-text {\n   491→    font-family: var(--font);\n   492→    font-size: 13px;\n   493→    fill: var(--text);\n   494→}\n   495→\n   496→.dag-edge {\n   497→    fill: none;\n   498→    stroke: var(--text-muted);\n   499→    stroke-width: 1.5;\n   500→}\n   501→\n   502→.dag-edge-label {\n   503→    font-family: var(--font);\n   504→    font-size: 10px;\n   505→    fill: var(--text-muted);\n   506→    text-anchor: middle;\n   507→}\n   508→\n   509→.dag-terminal-done { fill: var(--badge-succeeded-bg); stroke: var(--badge-succeeded-text); }\n   510→.dag-terminal-abort { fill: var(--badge-failed-bg); stroke: var(--badge-failed-text); }\n   511→\n   512→.dag-merge-line { stroke-dasharray: 4 3; }\n   513→.dag-merge-dot { fill: var(--text-muted); }\n   514→\n   515→.dag-edge-nonsuccess { stroke: var(--badge-failed-text); opacity: 0.7; }\n   516→\n   517→/* Drawer */\n   518→.drawer {\n   519→    position: fixed;\n   520→    top: 0;\n   521→    right: -420px;\n   522→    width: 400px;\n   523→    height: 100vh;\n   524→    background: var(--bg-surface);\n   525→    border-left: 1px solid var(--border);\n   526→    box-shadow: -4px 0 12px rgba(0,0,0,0.1);\n   527→    transition: right 0.25s ease;\n   528→    z-index: 100;\n   529→    display: flex;\n   530→    flex-direction: column;\n   531→    overflow: hidden;\n   532→}\n   533→\n   534→.drawer.drawer-open { right: 0; }\n   535→\n   536→.drawer-header {\n   537→    display: flex;\n   538→    justify-content: space-between;\n   539→    align-items: center;\n   540→    padding: 0.75rem 1rem;\n   541→    border-bottom: 1px solid var(--border);\n   542→    font-weight: 700;\n   543→    font-size: 1rem;\n   544→}\n   545→\n   546→.drawer-close {\n   547→    background: none;\n   548→    border: none;\n   549→    font-size: 1.4rem;\n   550→    cursor: pointer;\n   551→    color: var(--text-muted);\n   552→    padding: 0 0.25rem;\n   553→}\n   554→\n   555→.drawer-close:hover { color: var(--text); }\n   556→\n   557→.drawer-body {\n   558→    padding: 1rem;\n   559→    overflow-y: auto;\n   560→    flex: 1;\n   561→}\n   562→\n   563→.drawer-body pre {\n   564→    background: var(--bg);\n   565→    border: 1px solid var(--border);\n   566→    border-radius: var(--radius);\n   567→    padding: 0.75rem;\n   568→    font-family: var(--mono);\n   569→    font-size: 0.8rem;\n   570→    max-height: 400px;\n   571→    overflow: auto;\n   572→    white-space: pre-wrap;\n   573→    word-break: break-word;\n   574→}\n   575→\n   576→/* Diff block */\n   577→.diff-block {\n   578→    background: var(--bg);\n   579→    border: 1px solid var(--border);\n   580→    border-radius: var(--radius);\n   581→    padding: 0.5rem;\n   582→    font-family: var(--mono);\n   583→    font-size: 0.75rem;\n   584→    max-height: 300px;\n   585→    overflow: auto;\n   586→    white-space: pre-wrap;\n   587→    word-break: break-word;\n   588→    margin: 0.25rem 0 0.5rem;\n   589→}\n   590→\n   591→/* Orchestrator status */\n   592→.orch-status { font-size: 0.9rem; }\n   593→\n   594→/* Task grouping header */\n   595→.run-task-header td {\n   596→    font-weight: 600;\n   597→    background: var(--bg-secondary);\n   598→    border-bottom: 2px solid var(--border);\n   599→    padding: 0.5rem 0.75rem;\n   600→    color: var(--text);\n   601→    font-size: 0.9rem;\n   602→}\n   603→\n   604→/* Run tree grouping */\n   605→.run-parent-row { opacity: 0.7; }\n   606→.run-parent-row td:first-child { font-weight: 600; }\n   607→.run-child-row td:first-child { padding-left: 2rem; }\n   608→.run-child-row td:first-child::before {\n   609→    content: \"\\2514\\00a0\";\n   610→    color: var(--text-muted);\n   611→}\n   612→.tree-toggle {\n   613→    cursor: pointer;\n   614→    background: none;\n   615→    border: none;\n   616→    font-size: 0.75rem;\n   617→    color: var(--text-muted);\n   618→    padding: 0 0.25rem;\n   619→    margin-right: 0.25rem;\n   620→}\n   621→.tree-toggle:hover { color: var(--text); }\n   622→.parent-run-link { font-weight: 400; color: var(--text-muted); }\n   623→.parent-run-link:hover { color: var(--link); }\n   624→\n   625→/* Responsive */\n   626→@media (max-width: 768px) {\n   627→    .runs-table { font-size: 0.8rem; }\n   628→    .runs-table th, .runs-table td { padding: 0.4rem 0.5rem; }\n   629→    .run-meta dl { grid-template-columns: 1fr; }\n   630→    .project-cards { grid-template-columns: 1fr; }\n   631→    .log-viewer { max-height: 400px; }\n   632→    .drawer { width: 100%; right: -100%; }\n   633→}\n   634→"}]},"parent_tool_use_id":null,"session_id":"e5f57d13-6940-497b-9967-e6dfa7c6b1ef","uuid":"011e5446-4064-4339-b7fc-10adfe5dbbab","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/static/style.css","content":":root {\n    --bg: #fff;\n    --bg-surface: #f8f9fa;\n    --text: #1a1a1a;\n    --text-muted: #6b7280;\n    --border: #e5e7eb;\n    --link: #2563eb;\n    --font: system-ui, -apple-system, sans-serif;\n    --mono: ui-monospace, \"Cascadia Code\", \"Fira Code\", monospace;\n    --radius: 4px;\n\n    --badge-pending-bg: #fef3c7;\n    --badge-pending-text: #92400e;\n    --badge-running-bg: #dbeafe;\n    --badge-running-text: #1e40af;\n    --badge-succeeded-bg: #d1fae5;\n    --badge-succeeded-text: #065f46;\n    --badge-failed-bg: #fee2e2;\n    --badge-failed-text: #991b1b;\n    --badge-cancelled-bg: #f3f4f6;\n    --badge-cancelled-text: #4b5563;\n    --badge-stopped-bg: #e5e7eb;\n    --badge-stopped-text: #4b5563;\n\n    --error-bg: #fef2f2;\n    --error-border: #fca5a5;\n    --error-text: #991b1b;\n}\n\n@media (prefers-color-scheme: dark) {\n    :root {\n        --bg: #111827;\n        --bg-surface: #1f2937;\n        --text: #f3f4f6;\n        --text-muted: #9ca3af;\n        --border: #374151;\n        --link: #60a5fa;\n\n        --badge-pending-bg: #78350f;\n        --badge-pending-text: #fde68a;\n        --badge-running-bg: #1e3a5f;\n        --badge-running-text: #93c5fd;\n        --badge-succeeded-bg: #064e3b;\n        --badge-succeeded-text: #6ee7b7;\n        --badge-failed-bg: #7f1d1d;\n        --badge-failed-text: #fca5a5;\n        --badge-cancelled-bg: #374151;\n        --badge-cancelled-text: #9ca3af;\n        --badge-stopped-bg: #374151;\n        --badge-stopped-text: #9ca3af;\n\n        --error-bg: #450a0a;\n        --error-border: #7f1d1d;\n        --error-text: #fca5a5;\n    }\n}\n\n*, *::before, *::after { box-sizing: border-box; }\n\nbody {\n    margin: 0;\n    font-family: var(--font);\n    background: var(--bg);\n    color: var(--text);\n    line-height: 1.5;\n}\n\n.container {\n    max-width: 1100px;\n    margin: 0 auto;\n    padding: 0 1rem;\n}\n\na { color: var(--link); text-decoration: none; }\na:hover { text-decoration: underline; }\n\n.navbar {\n    background: var(--bg-surface);\n    border-bottom: 1px solid var(--border);\n    padding: 0.75rem 0;\n    margin-bottom: 1.5rem;\n}\n\n.logo {\n    font-weight: 700;\n    font-size: 1.1rem;\n    color: var(--text);\n}\n.logo:hover { text-decoration: none; }\n\nh1 {\n    font-size: 1.4rem;\n    margin: 0 0 1rem;\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    flex-wrap: wrap;\n}\n\nh1 a { font-weight: 400; }\n\nh2 {\n    font-size: 1.1rem;\n    margin: 1.5rem 0 0.75rem;\n}\n\n/* Badges */\n.badge {\n    display: inline-block;\n    padding: 0.15em 0.55em;\n    border-radius: var(--radius);\n    font-size: 0.8rem;\n    font-weight: 600;\n    white-space: nowrap;\n}\n\n.badge-pending  { background: var(--badge-pending-bg);  color: var(--badge-pending-text); }\n.badge-running  { background: var(--badge-running-bg);  color: var(--badge-running-text); animation: pulse 2s infinite; }\n.badge-succeeded { background: var(--badge-succeeded-bg); color: var(--badge-succeeded-text); }\n.badge-failed   { background: var(--badge-failed-bg);   color: var(--badge-failed-text); }\n.badge-cancelled { background: var(--badge-cancelled-bg); color: var(--badge-cancelled-text); }\n.badge-stopped  { background: var(--badge-stopped-bg);  color: var(--badge-stopped-text); }\n\n@keyframes pulse {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0.6; }\n}\n\n/* Tables */\n.runs-table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 0.9rem;\n}\n\n.runs-table th,\n.runs-table td {\n    padding: 0.5rem 0.75rem;\n    text-align: left;\n    border-bottom: 1px solid var(--border);\n}\n\n.runs-table th {\n    background: var(--bg-surface);\n    font-weight: 600;\n    font-size: 0.8rem;\n    text-transform: uppercase;\n    letter-spacing: 0.03em;\n    color: var(--text-muted);\n}\n\n.runs-table tr:hover { background: var(--bg-surface); }\n.detail-row:hover { background: inherit; }\n.step-row { cursor: pointer; }\n.output-row td { padding: 0 !important; }\n.step-output {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 0.75rem;\n    font-family: var(--mono);\n    font-size: 0.8rem;\n    max-height: 500px;\n    overflow: auto;\n    white-space: pre-wrap;\n    word-break: break-word;\n    margin: 0.25rem 0.75rem 0.75rem;\n}\n\n.mono { font-family: var(--mono); font-size: 0.85em; }\n.empty { color: var(--text-muted); text-align: center; padding: 2rem 0; }\n.error-cell { color: var(--badge-failed-text); font-size: 0.85em; }\n\n/* Run metadata */\n.run-meta dl {\n    display: grid;\n    grid-template-columns: auto 1fr;\n    gap: 0.25rem 1rem;\n    margin: 0 0 1rem;\n    font-size: 0.9rem;\n}\n\n.run-meta dt { color: var(--text-muted); font-weight: 600; }\n.run-meta dd { margin: 0; }\n\n/* Error box */\n.error-box {\n    background: var(--error-bg);\n    border: 1px solid var(--error-border);\n    color: var(--error-text);\n    padding: 0.75rem 1rem;\n    border-radius: var(--radius);\n    margin-bottom: 1rem;\n    font-size: 0.9rem;\n}\n\n/* Details / pre */\ndetails {\n    margin: 0.5rem 0;\n}\n\ndetails summary {\n    cursor: pointer;\n    font-weight: 600;\n    font-size: 0.85rem;\n    color: var(--text-muted);\n}\n\ndetails pre {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 0.75rem;\n    font-family: var(--mono);\n    font-size: 0.8rem;\n    max-height: 400px;\n    overflow: auto;\n    white-space: pre-wrap;\n    word-break: break-word;\n    margin: 0.5rem 0 0;\n}\n\n/* Project filter */\n.project-filter {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    margin-bottom: 1rem;\n    font-size: 0.9rem;\n}\n\n.project-filter label {\n    font-weight: 600;\n    color: var(--text-muted);\n}\n\n.project-filter select {\n    font-family: var(--font);\n    font-size: 0.9rem;\n    padding: 0.3rem 0.5rem;\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    background: var(--bg);\n    color: var(--text);\n    cursor: pointer;\n}\n\n/* Project cards */\n.project-cards {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\n    gap: 1rem;\n}\n\n.project-card {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 1rem 1.25rem;\n    display: flex;\n    flex-direction: column;\n    gap: 0.75rem;\n}\n\n.project-header {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n}\n\n.project-name {\n    font-weight: 600;\n    font-size: 1.05rem;\n}\n\n/* Health indicator dots */\n.health-dot {\n    display: inline-block;\n    width: 12px;\n    height: 12px;\n    border-radius: 50%;\n    flex-shrink: 0;\n}\n\n.health-green  { background: #22c55e; }\n.health-yellow { background: #eab308; }\n.health-red    { background: #ef4444; }\n.health-grey   { background: #9ca3af; }\n.health-blue   { background: #3b82f6; animation: pulse 2s infinite; }\n\n/* Project stats */\n.project-stats {\n    display: flex;\n    gap: 1.5rem;\n}\n\n.stat {\n    display: flex;\n    flex-direction: column;\n}\n\n.stat-value {\n    font-weight: 700;\n    font-size: 1.1rem;\n}\n\n.stat-label {\n    font-size: 0.75rem;\n    color: var(--text-muted);\n    text-transform: uppercase;\n    letter-spacing: 0.03em;\n}\n\n/* Mini run history dots */\n.run-history {\n    display: flex;\n    gap: 4px;\n    align-items: center;\n    min-height: 16px;\n}\n\n.run-dot {\n    display: inline-block;\n    width: 10px;\n    height: 10px;\n    border-radius: 50%;\n}\n\n.run-dot-succeeded { background: #22c55e; }\n.run-dot-failed    { background: #ef4444; }\n.run-dot-cancelled { background: #9ca3af; }\n.run-dot-running   { background: #3b82f6; animation: pulse 2s infinite; }\n.run-dot-pending   { background: #eab308; }\n\n/* Action buttons */\n.project-actions {\n    display: flex;\n    gap: 0.5rem;\n    margin-top: 0.25rem;\n}\n\n.btn {\n    display: inline-block;\n    padding: 0.35em 0.75em;\n    border-radius: var(--radius);\n    font-family: var(--font);\n    font-size: 0.8rem;\n    font-weight: 600;\n    border: 1px solid var(--border);\n    cursor: pointer;\n    text-decoration: none;\n    white-space: nowrap;\n}\n\n.btn:hover { text-decoration: none; }\n\n.btn-secondary {\n    background: var(--bg);\n    color: var(--link);\n}\n\n.btn-secondary:hover { background: var(--bg-surface); }\n\n.btn-primary {\n    background: var(--link);\n    color: #fff;\n    border-color: var(--link);\n}\n\n.btn-primary:hover { opacity: 0.9; }\n\n.btn-danger {\n    background: var(--badge-failed-bg);\n    color: var(--badge-failed-text);\n    border-color: var(--error-border);\n}\n\n.btn-danger:hover { opacity: 0.8; }\n\n.btn-sm { font-size: 0.75rem; padding: 0.15em 0.45em; }\n\n.btn:disabled {\n    opacity: 0.6;\n    cursor: not-allowed;\n}\n\n/* Log viewer */\n.log-viewer {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    max-height: 600px;\n    overflow: auto;\n    margin-bottom: 1.5rem;\n}\n\n.log-viewer pre {\n    margin: 0;\n    padding: 0.75rem;\n    font-family: var(--mono);\n    font-size: 0.8rem;\n    white-space: pre-wrap;\n    word-break: break-word;\n    line-height: 1.4;\n}\n\n/* Load-earlier button inside log viewer */\n.load-earlier-btn {\n    display: block;\n    width: 100%;\n    padding: 0.4rem;\n    text-align: center;\n    background: var(--bg-secondary);\n    border: none;\n    border-bottom: 1px solid var(--border);\n    cursor: pointer;\n    font-size: 0.8rem;\n    font-family: var(--mono);\n    color: var(--link);\n}\n.load-earlier-btn:hover { background: var(--border); }\n.load-earlier-btn:disabled { opacity: 0.5; cursor: wait; }\n\n.log-line { display: block; }\n.log-type-status { color: var(--badge-running-text); }\n.log-type-llm { color: var(--badge-succeeded-text); }\n.log-type-script { color: var(--text); }\n\n/* Panels */\n.panel {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    margin-bottom: 1rem;\n}\n\n.panel-header {\n    font-weight: 700;\n    font-size: 0.9rem;\n    padding: 0.6rem 1rem;\n    border-bottom: 1px solid var(--border);\n    text-transform: uppercase;\n    letter-spacing: 0.03em;\n    color: var(--text-muted);\n}\n\n.panel-body {\n    padding: 1rem;\n}\n\n/* Tabs */\n.tab-bar {\n    display: flex;\n    gap: 0;\n    border-bottom: 1px solid var(--border);\n    margin-bottom: 1rem;\n}\n.tab-bar:empty {\n    display: none;\n}\n\n.tab-btn {\n    padding: 0.4rem 1rem;\n    font-family: var(--font);\n    font-size: 0.85rem;\n    font-weight: 600;\n    background: none;\n    border: none;\n    border-bottom: 2px solid transparent;\n    color: var(--text-muted);\n    cursor: pointer;\n}\n\n.tab-btn:hover { color: var(--text); }\n.tab-btn.tab-active { color: var(--link); border-bottom-color: var(--link); }\n\n/* DAG */\n.dag-svg { display: block; }\n#workflow-dag { overflow-x: auto; }\n\n.dag-node-rect {\n    fill: var(--bg);\n    stroke: var(--border);\n    stroke-width: 1.5;\n    rx: 4;\n}\n\n.dag-node:hover .dag-node-rect { stroke: var(--link); stroke-width: 2; }\n\n.dag-node-text {\n    font-family: var(--font);\n    font-size: 13px;\n    fill: var(--text);\n}\n\n.dag-edge {\n    fill: none;\n    stroke: var(--text-muted);\n    stroke-width: 1.5;\n}\n\n.dag-edge-label {\n    font-family: var(--font);\n    font-size: 10px;\n    fill: var(--text-muted);\n    text-anchor: middle;\n}\n\n.dag-terminal-done { fill: var(--badge-succeeded-bg); stroke: var(--badge-succeeded-text); }\n.dag-terminal-abort { fill: var(--badge-failed-bg); stroke: var(--badge-failed-text); }\n\n.dag-merge-line { stroke-dasharray: 4 3; }\n.dag-merge-dot { fill: var(--text-muted); }\n\n.dag-edge-nonsuccess { stroke: var(--badge-failed-text); opacity: 0.7; }\n\n/* Drawer */\n.drawer {\n    position: fixed;\n    top: 0;\n    right: -420px;\n    width: 400px;\n    height: 100vh;\n    background: var(--bg-surface);\n    border-left: 1px solid var(--border);\n    box-shadow: -4px 0 12px rgba(0,0,0,0.1);\n    transition: right 0.25s ease;\n    z-index: 100;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n}\n\n.drawer.drawer-open { right: 0; }\n\n.drawer-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 0.75rem 1rem;\n    border-bottom: 1px solid var(--border);\n    font-weight: 700;\n    font-size: 1rem;\n}\n\n.drawer-close {\n    background: none;\n    border: none;\n    font-size: 1.4rem;\n    cursor: pointer;\n    color: var(--text-muted);\n    padding: 0 0.25rem;\n}\n\n.drawer-close:hover { color: var(--text); }\n\n.drawer-body {\n    padding: 1rem;\n    overflow-y: auto;\n    flex: 1;\n}\n\n.drawer-body pre {\n    background: var(--bg);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 0.75rem;\n    font-family: var(--mono);\n    font-size: 0.8rem;\n    max-height: 400px;\n    overflow: auto;\n    white-space: pre-wrap;\n    word-break: break-word;\n}\n\n/* Diff block */\n.diff-block {\n    background: var(--bg);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 0.5rem;\n    font-family: var(--mono);\n    font-size: 0.75rem;\n    max-height: 300px;\n    overflow: auto;\n    white-space: pre-wrap;\n    word-break: break-word;\n    margin: 0.25rem 0 0.5rem;\n}\n\n/* Orchestrator status */\n.orch-status { font-size: 0.9rem; }\n\n/* Task grouping header */\n.run-task-header td {\n    font-weight: 600;\n    background: var(--bg-secondary);\n    border-bottom: 2px solid var(--border);\n    padding: 0.5rem 0.75rem;\n    color: var(--text);\n    font-size: 0.9rem;\n}\n\n/* Run tree grouping */\n.run-parent-row { opacity: 0.7; }\n.run-parent-row td:first-child { font-weight: 600; }\n.run-child-row td:first-child { padding-left: 2rem; }\n.run-child-row td:first-child::before {\n    content: \"\\2514\\00a0\";\n    color: var(--text-muted);\n}\n.tree-toggle {\n    cursor: pointer;\n    background: none;\n    border: none;\n    font-size: 0.75rem;\n    color: var(--text-muted);\n    padding: 0 0.25rem;\n    margin-right: 0.25rem;\n}\n.tree-toggle:hover { color: var(--text); }\n.parent-run-link { font-weight: 400; color: var(--text-muted); }\n.parent-run-link:hover { color: var(--link); }\n\n/* Responsive */\n@media (max-width: 768px) {\n    .runs-table { font-size: 0.8rem; }\n    .runs-table th, .runs-table td { padding: 0.4rem 0.5rem; }\n    .run-meta dl { grid-template-columns: 1fr; }\n    .project-cards { grid-template-columns: 1fr; }\n    .log-viewer { max-height: 400px; }\n    .drawer { width: 100%; right: -100%; }\n}\n","numLines":634,"startLine":1,"totalLines":634}}}
