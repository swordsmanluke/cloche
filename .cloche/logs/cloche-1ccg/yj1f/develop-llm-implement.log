e {\n    fill: none;\n    stroke: var(--text-muted);\n    stroke-width: 1.5;\n}\n\n.dag-edge-label {\n    font-family: var(--font);\n    font-size: 10px;\n    fill: var(--text-muted);\n    text-anchor: middle;\n}\n\n.dag-terminal-done { fill: var(--badge-succeeded-bg); stroke: var(--badge-succeeded-text); }\n.dag-terminal-abort { fill: var(--badge-failed-bg); stroke: var(--badge-failed-text); }\n\n.dag-merge-line { stroke-dasharray: 4 3; }\n.dag-merge-dot { fill: var(--text-muted); }\n\n.dag-edge-nonsuccess { stroke: var(--badge-failed-text); opacity: 0.7; }\n\n/* Drawer */\n.drawer {\n    position: fixed;\n    top: 0;\n    right: -420px;\n    width: 400px;\n    height: 100vh;\n    background: var(--bg-surface);\n    border-left: 1px solid var(--border);\n    box-shadow: -4px 0 12px rgba(0,0,0,0.1);\n    transition: right 0.25s ease;\n    z-index: 100;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n}\n\n.drawer.drawer-open { right: 0; }\n\n.drawer-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 0.75rem 1rem;\n    border-bottom: 1px solid var(--border);\n    font-weight: 700;\n    font-size: 1rem;\n}\n\n.drawer-close {\n    background: none;\n    border: none;\n    font-size: 1.4rem;\n    cursor: pointer;\n    color: var(--text-muted);\n    padding: 0 0.25rem;\n}\n\n.drawer-close:hover { color: var(--text); }\n\n.drawer-body {\n    padding: 1rem;\n    overflow-y: auto;\n    flex: 1;\n}\n\n.drawer-body pre {\n    background: var(--bg);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 0.75rem;\n    font-family: var(--mono);\n    font-size: 0.8rem;\n    max-height: 400px;\n    overflow: auto;\n    white-space: pre-wrap;\n    word-break: break-word;\n}\n\n/* Diff block */\n.diff-block {\n    background: var(--bg);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 0.5rem;\n    font-family: var(--mono);\n    font-size: 0.75rem;\n    max-height: 300px;\n    overflow: auto;\n    white-space: pre-wrap;\n    word-break: break-word;\n    margin: 0.25rem 0 0.5rem;\n}\n\n/* Orchestrator status */\n.orch-status { font-size: 0.9rem; }\n\n/* Task grouping header */\n.run-task-header td {\n    font-weight: 600;\n    background: var(--bg-secondary);\n    border-bottom: 2px solid var(--border);\n    padding: 0.5rem 0.75rem;\n    color: var(--text);\n    font-size: 0.9rem;\n}\n\n/* Run tree grouping */\n.run-parent-row { opacity: 0.7; }\n.run-parent-row td:first-child { font-weight: 600; }\n.run-child-row td:first-child { padding-left: 2rem; }\n.run-child-row td:first-child::before {\n    content: \"\\2514\\00a0\";\n    color: var(--text-muted);\n}\n.tree-toggle {\n    cursor: pointer;\n    background: none;\n    border: none;\n    font-size: 0.75rem;\n    color: var(--text-muted);\n    padding: 0 0.25rem;\n    margin-right: 0.25rem;\n}\n.tree-toggle:hover { color: var(--text); }\n.parent-run-link { font-weight: 400; color: var(--text-muted); }\n.parent-run-link:hover { color: var(--link); }\n\n/* Responsive */\n@media (max-width: 768px) {\n    .runs-table { font-size: 0.8rem; }\n    .runs-table th, .runs-table td { padding: 0.4rem 0.5rem; }\n    .run-meta dl { grid-template-columns: 1fr; }\n    .project-cards { grid-template-columns: 1fr; }\n    .log-viewer { max-height: 400px; }\n    .drawer { width: 100%; right: -100%; }\n}\n","structuredPatch":[{"oldStart":513,"oldLines":6,"newStart":513,"newLines":7,"lines":[" .dag-merge-dot { fill: var(--text-muted); }"," "," .dag-edge-nonsuccess { stroke: var(--badge-failed-text); opacity: 0.7; }","+.dag-link-node { opacity: 0.9; }"," "," /* Drawer */"," .drawer {"]}],"userModified":false,"replaceAll":false}}
