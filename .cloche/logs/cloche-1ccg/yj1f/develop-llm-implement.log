ine (offset non-success)","-        srcPts.forEach(function(pt) {","-            var isSucc = isSuccessResult(pt.result);","-            var off = isSucc ? 0 : nonsuccOffset;","-            var dx = mergeX - pt.x;","-            var arcY = pt.y + off;","-            var cls = 'dag-edge' + (isSucc ? '' : ' dag-edge-nonsuccess');","-            svg += '<path d=\"M' + pt.x + ' ' + pt.y + ' C' + (pt.x + dx * 0.5) + ' ' + arcY + ' ' + (mergeX - 20) + ' ' + arcY + ' ' + mergeX + ' ' + arcY + '\" class=\"' + cls + '\"/>';","-            svg += '<text x=\"' + (pt.x + dx * 0.35) + '\" y=\"' + (arcY - 6) + '\" class=\"dag-edge-label\">' + pt.result + '</text>';","-        });","+            // Vertical drop from node bottom to lane","+            svg += '<path d=\"M' + dropX + ' ' + y1 + ' L' + dropX + ' ' + ly + '\" fill=\"none\" stroke=\"' + color + '\" stroke-width=\"1.5\"/>';"," ","-        // Vertical collector line","-        var mergeEnds = srcPts.map(function(pt) { return pt.y + (isSuccessResult(pt.result) ? 0 : nonsuccOffset); });","-        mergeEnds.push(termY);","-        var minY = Math.min.apply(null, mergeEnds);","-        var maxY = Math.max.apply(null, mergeEnds);","-        var hasNonSucc = tWires.some(function(w) { return !isSuccessResult(w.result); });","-        svg += '<path d=\"M' + mergeX + ' ' + minY + ' L' + mergeX + ' ' + maxY + '\" class=\"dag-edge dag-merge-line' + (hasNonSucc ? ' dag-edge-nonsuccess' : '') + '\"/>';","+            // Label along the drop","+            svg += '<text x=\"' + (dropX + 6) + '\" y=\"' + ((y1 + ly) / 2 + 4) + '\" class=\"dag-edge-label\" style=\"fill:' + color + '\" text-anchor=\"start\">' + result + '</text>';"," ","-        // Merge point dots (at offset positions for non-success wires)","-        srcPts.forEach(function(pt) {","-            var off = isSuccessResult(pt.result) ? 0 : nonsuccOffset;","-            svg += '<circle cx=\"' + mergeX + '\" cy=\"' + (pt.y + off) + '\" r=\"3\" class=\"dag-merge-dot\"/>';","