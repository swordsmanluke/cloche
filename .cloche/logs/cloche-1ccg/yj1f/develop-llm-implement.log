rs\n    var nodeGap = 28;   // vertical gap between nodes in same layer\n    var padL = 30, padT = 30;\n    var laneGapV = 40;  // vertical spacing per offset lane\n    var laneOffset = 50; // gap between bottom of nodes and first lane\n\n    var maxInLayer = 1;\n    layers.forEach(function(l) { if (l.length > maxInLayer) maxInLayer = l.length; });\n    var totalLayerH = maxInLayer * nodeH + (maxInLayer - 1) * nodeGap;\n\n    var positions = {};\n    layers.forEach(function(layer, li) {\n        var lh = layer.length * nodeH + (layer.length - 1) * nodeGap;\n        var offsetY = (totalLayerH - lh) / 2;\n        layer.forEach(function(name, ni) {\n            positions[name] = {\n                x: padL + li * (nodeW + layerGap),\n                y: padT + offsetY + ni * (nodeH + nodeGap)\n            };\n        });\n    });\n\n    var laneBaseY = padT + totalLayerH + laneOffset;\n    function laneY(idx) { return laneBaseY + idx * laneGapV; }\n\n    var svgW = padL * 2 + numLayers * nodeW + (numLayers - 1) * layerGap;\n    var svgH = padT * 2 + totalLayerH + (numLanes > 0 ? laneOffset + numLanes * laneGapV + 20 : 0);\n\n    // --- Generate SVG ---\n    var svg = '<svg class=\"dag-svg\" width=\"' + svgW + '\" height=\"' + svgH + '\">';\n\n    // Create arrowhead markers for each unique color\n    svg += '<defs>';\n    var markerColors = {};\n    for (var r in resultColorMap) markerColors[resultColorMap[r]] = true;\n    for (var mc in markerColors) {\n        var mid = 'arrow-' + mc.replace('#', '');\n        svg += '<marker id=\"' + mid + '\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"' + mc + '\"/></marker>';\n    }\n    svg += '</defs>';\n\n    function markerRef(color) { return 'url(#arrow-' + color.replace('#', '') + ')'; }\n\n    // Draw normal (non-terminal) edges with colored Bezier curves\n    normWires.forEach(function(wire) {\n        var from = positions[wire.from], to = positions[wire.to];\n        if (!from || !to) return;\n        var color = wireColor(wire.result);\n        var x1 = from.x + nodeW, y1 = from.y + nodeH / 2;\n        var x2 = to.x, y2 = to.y + nodeH / 2;\n        var dx = x2 - x1;\n        svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + dx * 0.4) + ' ' + y1 + ' ' + (x1 + dx * 0.6) + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" fill=\"none\" stroke=\"' + color + '\" stroke-width=\"1.5\" marker-end=\"' + markerRef(color) + '\"/>';\n        svg += '<text x=\"' + (x1 + dx / 2) + '\" y=\"' + ((y1 + y2) / 2 - 6) + '\" class=\"dag-edge-label\" style=\"fill:' + color + '\">' + wire.result + '</text>';\n    });\n\n    // Draw success terminal wires directly\n    successTermWires.forEach(function(wire) {\n        var from = positions[wire.from], to = positions[wire.to];\n        if (!from || !to) return;\n        var color = wireColor(wire.result);\n        var x1 = from.x + nodeW, y1 = from.y + nodeH / 2;\n        var x2 = to.x, y2 = to.y + nodeH / 2;\n        var dx = x2 - x1;\n        svg += '<path d=\"M' + x1 + ' ' + y1 + ' C' + (x1 + dx * 0.4) + ' ' + y1 + ' ' + (x1 + dx * 0.6) + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" fill=\"none\" stroke=\"' + color + '\" stroke-width=\"1.5\" marker-end=\"' + markerRef(color) + '\"/>';\n        svg += '<text x=\"' + (x1 + dx / 2) + '\" y=\"' + ((y1 + y2) / 2 - 6) + '\" class=\"dag-edge-label\" style=\"fill:' + color + '\">' + wire.result + '</text>';\n    });\n\n    // Draw non-success terminal wires through offset link nodes\n    for (var key in nonSuccTermGroups) {\n        var groupWires = nonSuccTermGroups[key];\n        var parts = key.split(':');\n        var terminal = parts[0];\n        var result = parts.slice(1).join(':');\n        var color = wireColor(result);\n        var lane = laneMap[key];\n        var ly = laneY(lane);\n        var tpos = positions[terminal];\n        if (!tpos) continue;\n\n        // Sort by source X position (left to right)\n        var sorted = groupWires.slice().sort(function(a, b) {\n            var ax = positions[a.from] ? positions[a.from].x : 0;\n            var bx = positions[b.from] ? positions[b.from].x : 0;\n            return ax - bx;\n        });\n\n        // Draw vertical drops from each source node down to the lane\n        var linkXs = [];\n        sorted.forEach(function(wire) {\n            var from = positions[wire.from];\n            if (!from) return;\n            var dropX = from.x + nodeW / 2;\n            var y1 = from.y + nodeH;\n\n            // Vertical drop from node bottom to lane\n            svg += '<path d=\"M' + dropX + ' ' + y1 + ' L' + dropX + ' ' + ly + '\" fill=\"none\" stroke=\"' + color + '\" stroke-width=\"1.5\"/>';\n\n            // Label along the drop\n            svg += '<text x=\"' + (dropX + 6) + '\" y=\"' + ((y1 + ly) / 2 + 4) + '\" class=\"dag-edge-label\" style=\"fill:' + color + '\" text-anchor=\"start\">' + result + '</text>';\n\n            // Link node circle at junction\n            svg += '<circle cx=\"' + dropX + '\" cy=\"' + ly + '\" r=\"4\" fill=\"' + color + '\"/>';\n\n            linkXs.push(dropX);\n        });\n\n        if (linkXs.length === 0) continue;\n\n        // Horizontal lane segment connecting all link nodes toward the terminal\n        var maxLinkX = Math.max.apply(null, linkXs);\n        var minLinkX = Math.min.apply(null, linkXs);\n        var termLeftX = tpos.x;\n        var termMidY = tpos.y + nodeH / 2;\n\n        var laneEndX = termLeftX - 20;\n        if (laneEndX < maxLinkX) laneEndX = maxLinkX;\n\n        svg += '<path d=\"M' + minLinkX + ' ' + ly + ' L' + laneEndX + ' ' + ly + '\" fill=\"none\" stroke=\"' + color + '\" stroke-width=\"1.5\"/>';\n\n        // Curve from lane end up to terminal\n        svg += '<path d=\"M' + laneEndX + ' ' + ly + ' C' + (laneEndX + 10) + ' ' + ly + ' ' + termLeftX + ' ' + (ly + (termMidY - ly) * 0.3) + ' ' + termLeftX + ' ' + termMidY + '\" fill=\"none\" stroke=\"' + color + '\" stroke-width=\"1.5\" marker-end=\"' 