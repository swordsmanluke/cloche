' + data.error);\n   511→            } else {\n   512→                loadTasks();\n   513→            }\n   514→        })\n   515→        .catch(function() { alert('Failed to release task'); });\n   516→}\n   517→\n   518→function renderTaskTable(tasks, showRelease) {\n   519→    if (!tasks || tasks.length === 0) {\n   520→        return '<p class=\"empty\">No tasks</p>';\n   521→    }\n   522→    var html = '<table class=\"runs-table\" style=\"margin:0\"><thead><tr>';\n   523→    html += '<th>Task ID</th><th>Title</th><th>Status</th><th>Assigned</th><th>Run</th>';\n   524→    if (showRelease) html += '<th></th>';\n   525→    html += '</tr></thead><tbody>';\n   526→    for (var i = 0; i < tasks.length; i++) {\n   527→        var t = tasks[i];\n   528→        var statusClass = t.status === 'open' ? 'running' : (t.status === 'closed' ? 'succeeded' : 'pending');\n   529→        html += '<tr>';\n   530→        html += '<td class=\"mono\">' + escapeHtml(t.id) + '</td>';\n   531→        html += '<td>' + escapeHtml(t.title || '') + '</td>';\n   532→        html += '<td><span class=\"badge badge-' + statusClass + '\">' + escapeHtml(t.status) + '</span></td>';\n   533→        html += '<td>' + (t.assigned ? 'Yes' : 'No') + '</td>';\n   534→        html += '<td>' + (t.run_id ? '<a href=\"/runs/' + escapeHtml(t.run_id) + '\">' + escapeHtml(t.run_id) + '</a>' : '') + '</td>';\n   535→        if (showRelease) {\n   536→            html += '<td>';\n   537→            if (t.stale) {\n   538→                html += '<button class=\"btn btn-secondary btn-sm\" onclick=\"releaseTask(\\'' + escapeHtml(t.id) + '\\')\">Release</button>';\n   539→            }\n   540→            html += '</td>';\n   541→        }\n   542→        html += '</tr>';\n   543→    }\n   544→    html += '</tbody></table>';\n   545→    return html;\n   546→}\n   547→\n   548→function loadTasks() {\n   549→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/tasks')\n   550→        .then(function(r) 