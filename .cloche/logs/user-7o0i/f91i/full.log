[2026-03-12T17:54:20Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FPTfaQqXugbNx3ozwUQ3Fn","type":"tool_result","content":"     1→package sqlite_test\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"path/filepath\"\n     7→\t\"sync\"\n     8→\t\"testing\"\n     9→\t\"time\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    14→\t\"github.com/stretchr/testify/assert\"\n    15→\t\"github.com/stretchr/testify/require\"\n    16→)\n    17→\n    18→func TestRunStore_CreateAndGet(t *testing.T) {\n    19→\tstore, err := sqlite.NewStore(\":memory:\")\n    20→\trequire.NoError(t, err)\n    21→\tdefer store.Close()\n    22→\n    23→\tctx := context.Background()\n    24→\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n    25→\trun.Start()\n    26→\n    27→\terr = store.CreateRun(ctx, run)\n    28→\trequire.NoError(t, err)\n    29→\n    30→\tgot, err := store.GetRun(ctx, \"run-1\")\n    31→\trequire.NoError(t, err)\n    32→\tassert.Equal(t, \"run-1\", got.ID)\n    33→\tassert.Equal(t, \"test-workflow\", got.WorkflowName)\n    34→\tassert.Equal(t, domain.RunStateRunning, got.State)\n    35→}\n    36→\n    37→func TestRunStore_Update(t *testing.T) {\n    38→\tstore, err := sqlite.NewStore(\":memory:\")\n    39→\trequire.NoError(t, err)\n    40→\tdefer store.Close()\n    41→\n    42→\tctx := context.Background()\n    43→\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n    44→\trun.Start()\n    45→\trequire.NoError(t, store.CreateRun(ctx, run))\n    46→\n    47→\trun.Complete(domain.RunStateSucceeded)\n    48→\trequire.NoError(t, store.UpdateRun(ctx, run))\n    49→\n    50→\tgot, err := store.GetRun(ctx, \"run-1\")\n    51→\trequire.NoError(t, err)\n    52→\tassert.Equal(t, domain.RunStateSucceeded, got.State)\n    53→}\n    54→\n    55→func TestRunStore_List(t *testing.T) {\n    56→\tstore, err := sqlite.NewStore(\":memory:\")\n    57→\trequire.NoError(t, err)\n    58→\tdefer store.Close()\n    59→\n    60→\tctx := context.Background()\n    61→\trun1 := domain.NewRun(\"run-1\", \"wf-a\")\n    62→\trun2 := domain.NewRun(\"run-2\", \"wf-b\")\n    63→\trequire.NoError(t, store.CreateRun(ctx, run1))\n    64→\trequire.NoError(t, store.CreateRun(ctx, run2))\n    65→\n    66→\truns, err := store.ListRuns(ctx, time.Time{})\n    67→\trequire.NoError(t, err)\n    68→\tassert.Len(t, runs, 2)\n    69→}\n    70→\n    71→func TestRunStore_GetNotFound(t *testing.T) {\n    72→\tstore, err := sqlite.NewStore(\":memory:\")\n    73→\trequire.NoError(t, err)\n    74→\tdefer store.Close()\n    75→\n    76→\t_, err = store.GetRun(context.Background(), \"nonexistent\")\n    77→\tassert.Error(t, err)\n    78→}\n    79→\n    80→func TestStore_DeleteRun(t *testing.T) {\n    81→\tstore, err := sqlite.NewStore(\":memory:\")\n    82→\trequire.NoError(t, err)\n    83→\tdefer store.Close()\n    84→\n    85→\tctx := context.Background()\n    86→\n    87→\t// Create a run and save a capture for it\n    88→\trun := domain.NewRun(\"del-1\", \"test-workflow\")\n    89→\trun.Start()\n    90→\trequire.NoError(t, store.CreateRun(ctx, run))\n    91→\trequire.NoError(t, store.SaveCapture(ctx, \"del-1\", &domain.StepExecution{\n    92→\t\tStepName:  \"step1\",\n    93→\t\tStartedAt: time.Now(),\n    94→\t}))\n    95→\n    96→\t// Delete the run\n    97→\terr = store.DeleteRun(ctx, \"del-1\")\n    98→\trequire.NoError(t, err)\n    99→\n   100→\t// Verify run is gone\n   101→\t_, err = store.GetRun(ctx, \"del-1\")\n   102→\tassert.Error(t, err)\n   103→\n   104→\t// Verify captures are gone\n   105→\tcaps, err := store.GetCaptures(ctx, \"del-1\")\n   106→\trequire.NoError(t, err)\n   107→\tassert.Empty(t, caps)\n   108→}\n   109→\n   110→func TestRunProjectDir(t *testing.T) {\n   111→\tstore, err := sqlite.NewStore(\":memory:\")\n   112→\trequire.NoError(t, err)\n   113→\tdefer store.Close()\n   114→\n   115→\tctx := context.Background()\n   116→\trun := domain.NewRun(\"test-1\", \"develop\")\n   117→\trun.ProjectDir = \"/home/user/project\"\n   118→\trun.Start()\n   119→\n   120→\terr = store.CreateRun(ctx, run)\n   121→\trequire.NoError(t, err)\n   122→\n   123→\tgot, err := store.GetRun(ctx, \"test-1\")\n   124→\trequire.NoError(t, err)\n   125→\tassert.Equal(t, \"/home/user/project\", got.ProjectDir)\n   126→}\n   127→\n   128→func TestCaptureStepMetadata(t *testing.T) {\n   129→\tstore, err := sqlite.NewStore(\":memory:\")\n   130→\trequire.NoError(t, err)\n   131→\tdefer store.Close()\n   132→\n   133→\tctx := context.Background()\n   134→\trun := domain.NewRun(\"test-1\", \"develop\")\n   135→\trun.Start()\n   136→\tstore.CreateRun(ctx, run)\n   137→\n   138→\texec := &domain.StepExecution{\n   139→\t\tStepName:  \"implement\",\n   140→\t\tResult:    \"success\",\n   141→\t\tStartedAt: time.Now(),\n   142→\t}\n   143→\terr = store.SaveCapture(ctx, \"test-1\", exec)\n   144→\trequire.NoError(t, err)\n   145→\n   146→\tcaps, err := store.GetCaptures(ctx, \"test-1\")\n   147→\trequire.NoError(t, err)\n   148→\trequire.Len(t, caps, 1)\n   149→\tassert.Equal(t, \"implement\", caps[0].StepName)\n   150→\tassert.Equal(t, \"success\", caps[0].Result)\n   151→}\n   152→\n   153→func TestListRunsSince(t *testing.T) {\n   154→\tstore, err := sqlite.NewStore(\":memory:\")\n   155→\trequire.NoError(t, err)\n   156→\tdefer store.Close()\n   157→\n   158→\tctx := context.Background()\n   159→\tfor i, id := range []string{\"run-1\", \"run-2\", \"run-3\"} {\n   160→\t\tr := domain.NewRun(id, \"develop\")\n   161→\t\tr.ProjectDir = \"/project\"\n   162→\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n   163→\t\tr.State = domain.RunStateRunning\n   164→\t\trequire.NoError(t, store.CreateRun(ctx, r))\n   165→\t}\n   166→\n   167→\truns, err := store.ListRunsSince(ctx, \"/project\", \"develop\", \"run-1\")\n   168→\trequire.NoError(t, err)\n   169→\tassert.Len(t, runs, 2)\n   170→\tassert.Equal(t, \"run-2\", runs[0].ID)\n   171→\tassert.Equal(t, \"run-3\", runs[1].ID)\n   172→}\n   173→\n   174→func TestListRunsSinceEmpty(t *testing.T) {\n   175→\tstore, err := sqlite.NewStore(\":memory:\")\n   176→\trequire.NoError(t, err)\n   177→\tdefer store.Close()\n   178→\n   179→\tctx := context.Background()\n   180→\tfor i, id := range []string{\"run-1\", \"run-2\"} {\n   181→\t\tr := domain.NewRun(id, \"develop\")\n   182→\t\tr.ProjectDir = \"/project\"\n   183→\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n   184→\t\tr.State = domain.RunStateRunning\n   185→\t\trequire.NoError(t, store.CreateRun(ctx, r))\n   186→\t}\n   187→\n   188→\t// Empty sinceRunID returns all\n   189→\truns, err := store.ListRunsSince(ctx, \"/project\", \"develop\", \"\")\n   190→\trequire.NoError(t, err)\n   191→\tassert.Len(t, runs, 2)\n   192→}\n   193→\n   194→func TestGetLastEvolution(t *testing.T) {\n   195→\tstore, err := sqlite.NewStore(\":memory:\")\n   196→\trequire.NoError(t, err)\n   197→\tdefer store.Close()\n   198→\n   199→\tctx := context.Background()\n   200→\n   201→\t// No evolution yet\n   202→\tentry, err := store.GetLastEvolution(ctx, \"/project\", \"develop\")\n   203→\trequire.NoError(t, err)\n   204→\tassert.Nil(t, entry)\n   205→\n   206→\t// Save one\n   207→\trequire.NoError(t, store.SaveEvolution(ctx, &ports.EvolutionEntry{\n   208→\t\tID:           \"evo-1\",\n   209→\t\tProjectDir:   \"/project\",\n   210→\t\tWorkflowName: \"develop\",\n   211→\t\tTriggerRunID: \"run-1\",\n   212→\t\tCreatedAt:    time.Now(),\n   213→\t\tChangesJSON:  \"[]\",\n   214→\t}))\n   215→\n   216→\tentry, err = store.GetLastEvolution(ctx, \"/project\", \"develop\")\n   217→\trequire.NoError(t, err)\n   218→\trequire.NotNil(t, entry)\n   219→\tassert.Equal(t, \"evo-1\", entry.ID)\n   220→}\n   221→\n   222→func TestRunTitle(t *testing.T) {\n   223→\tstore, err := sqlite.NewStore(\":memory:\")\n   224→\trequire.NoError(t, err)\n   225→\tdefer store.Close()\n   226→\n   227→\tctx := context.Background()\n   228→\n   229→\t// Create a run with a title\n   230→\trun := domain.NewRun(\"title-1\", \"develop\")\n   231→\trun.Title = \"Add dark mode toggle\"\n   232→\trun.Start()\n   233→\trequire.NoError(t, store.CreateRun(ctx, run))\n   234→\n   235→\tgot, err := store.GetRun(ctx, \"title-1\")\n   236→\trequire.NoError(t, err)\n   237→\tassert.Equal(t, \"Add dark mode toggle\", got.Title)\n   238→\n   239→\t// Update title\n   240→\tgot.Title = \"Updated title\"\n   241→\trequire.NoError(t, store.UpdateRun(ctx, got))\n   242→\n   243→\tgot2, err := store.GetRun(ctx, \"title-1\")\n   244→\trequire.NoError(t, err)\n   245→\tassert.Equal(t, \"Updated title\", got2.Title)\n   246→\n   247→\t// Verify title shows up in ListRuns\n   248→\truns, err := store.ListRuns(ctx, time.Time{})\n   249→\trequire.NoError(t, err)\n   250→\trequire.Len(t, runs, 1)\n   251→\tassert.Equal(t, \"Updated title\", runs[0].Title)\n   252→}\n   253→\n   254→func TestRunTitle_BackwardCompat(t *testing.T) {\n   255→\tstore, err := sqlite.NewStore(\":memory:\")\n   256→\trequire.NoError(t, err)\n   257→\tdefer store.Close()\n   258→\n   259→\tctx := context.Background()\n   260→\n   261→\t// Create a run without setting Title — simulates pre-migration rows\n   262→\trun := domain.NewRun(\"notitle-1\", \"develop\")\n   263→\trun.Start()\n   264→\trequire.NoError(t, store.CreateRun(ctx, run))\n   265→\n   266→\tgot, err := store.GetRun(ctx, \"notitle-1\")\n   267→\trequire.NoError(t, err)\n   268→\tassert.Equal(t, \"\", got.Title)\n   269→}\n   270→\n   271→func TestRunContainerID(t *testing.T) {\n   272→\tstore, err := sqlite.NewStore(\":memory:\")\n   273→\trequire.NoError(t, err)\n   274→\tdefer store.Close()\n   275→\n   276→\tctx := context.Background()\n   277→\trun := domain.NewRun(\"cid-1\", \"develop\")\n   278→\trun.Start()\n   279→\trun.ContainerID = \"4647e7e70e3fabc123def456\"\n   280→\n   281→\terr = store.CreateRun(ctx, run)\n   282→\trequire.NoError(t, err)\n   283→\n   284→\tgot, err := store.GetRun(ctx, \"cid-1\")\n   285→\trequire.NoError(t, err)\n   286→\tassert.Equal(t, \"4647e7e70e3fabc123def456\", got.ContainerID)\n   287→\n   288→\t// Test update preserves container ID\n   289→\tgot.ContainerID = \"new-container-id\"\n   290→\trequire.NoError(t, store.UpdateRun(ctx, got))\n   291→\n   292→\tgot2, err := store.GetRun(ctx, \"cid-1\")\n   293→\trequire.NoError(t, err)\n   294→\tassert.Equal(t, \"new-container-id\", got2.ContainerID)\n   295→\n   296→\t// Test ListRuns includes container ID\n   297→\truns, err := store.ListRuns(ctx, time.Time{})\n   298→\trequire.NoError(t, err)\n   299→\trequire.Len(t, runs, 1)\n   300→\tassert.Equal(t, \"new-container-id\", runs[0].ContainerID)\n   301→}\n   302→\n   303→func TestRunContainerID_BackwardCompat(t *testing.T) {\n   304→\tstore, err := sqlite.NewStore(\":memory:\")\n   305→\trequire.NoError(t, err)\n   306→\tdefer store.Close()\n   307→\n   308→\tctx := context.Background()\n   309→\t// Create a run without setting ContainerID — simulates pre-migration rows\n   310→\trun := domain.NewRun(\"old-1\", \"develop\")\n   311→\trun.Start()\n   312→\trequire.NoError(t, store.CreateRun(ctx, run))\n   313→\n   314→\tgot, err := store.GetRun(ctx, \"old-1\")\n   315→\trequire.NoError(t, err)\n   316→\tassert.Equal(t, \"\", got.ContainerID)\n   317→}\n   318→\n   319→func TestRunErrorMessage(t *testing.T) {\n   320→\tstore, err := sqlite.NewStore(\":memory:\")\n   321→\trequire.NoError(t, err)\n   322→\tdefer store.Close()\n   323→\n   324→\tctx := context.Background()\n   325→\trun := domain.NewRun(\"err-1\", \"develop\")\n   326→\trun.Start()\n   327→\trun.Fail(\"failed to start container: image not found\")\n   328→\n   329→\terr = store.CreateRun(ctx, run)\n   330→\trequire.NoError(t, err)\n   331→\n   332→\tgot, err := store.GetRun(ctx, \"err-1\")\n   333→\trequire.NoError(t, err)\n   334→\tassert.Equal(t, domain.RunStateFailed, got.State)\n   335→\tassert.Equal(t, \"failed to start container: image not found\", got.ErrorMessage)\n   336→\n   337→\t// Test update preserves error message\n   338→\tgot.ErrorMessage = \"updated error\"\n   339→\trequire.NoError(t, store.UpdateRun(ctx, got))\n   340→\n   341→\tgot2, err := store.GetRun(ctx, \"err-1\")\n   342→\trequire.NoError(t, err)\n   343→\tassert.Equal(t, \"updated error\", got2.ErrorMessage)\n   344→}\n   345→\n   346→func TestRunErrorMessageInList(t *testing.T) {\n   347→\tstore, err := sqlite.NewStore(\":memory:\")\n   348→\trequire.NoError(t, err)\n   349→\tdefer store.Close()\n   350→\n   351→\tctx := context.Background()\n   352→\trun := domain.NewRun(\"err-list-1\", \"develop\")\n   353→\trun.Start()\n   354→\trun.Fail(\"container crashed\")\n   355→\trequire.NoError(t, store.CreateRun(ctx, run))\n   356→\n   357→\truns, err := store.ListRuns(ctx, time.Time{})\n   358→\trequire.NoError(t, err)\n   359→\trequire.Len(t, runs, 1)\n   360→\tassert.Equal(t, \"container crashed\", runs[0].ErrorMessage)\n   361→}\n   362→\n   363→func TestStore_ConcurrentWrites(t *testing.T) {\n   364→\tdbPath := filepath.Join(t.TempDir(), \"concurrent.db\")\n   365→\tstore, err := sqlite.NewStore(dbPath)\n   366→\trequire.NoError(t, err)\n   367→\tdefer store.Close()\n   368→\n   369→\tconst n = 10\n   370→\tctx := context.Background()\n   371→\terrs := make([]error, n)\n   372→\n   373→\tvar wg sync.WaitGroup\n   374→\twg.Add(n)\n   375→\tfor i := 0; i < n; i++ {\n   376→\t\tgo func(i int) {\n   377→\t\t\tdefer wg.Done()\n   378→\t\t\tid := fmt.Sprintf(\"run-%d\", i)\n   379→\t\t\trun := domain.NewRun(id, \"test-workflow\")\n   380→\t\t\trun.Start()\n   381→\t\t\tif err := store.CreateRun(ctx, run); err != nil {\n   382→\t\t\t\terrs[i] = err\n   383→\t\t\t\treturn\n   384→\t\t\t}\n   385→\t\t\terrs[i] = store.SaveCapture(ctx, id, &domain.StepExecution{\n   386→\t\t\t\tStepName:  fmt.Sprintf(\"step-%d\", i),\n   387→\t\t\t\tStartedAt: time.Now(),\n   388→\t\t\t})\n   389→\t\t}(i)\n   390→\t}\n   391→\twg.Wait()\n   392→\n   393→\tfor i, err := range errs {\n   394→\t\tassert.NoError(t, err, \"goroutine %d failed\", i)\n   395→\t}\n   396→\n   397→\truns, err := store.ListRuns(ctx, time.Time{})\n   398→\trequire.NoError(t, err)\n   399→\tassert.Len(t, runs, n)\n   400→}\n   401→\n   402→func TestListRunsByProject(t *testing.T) {\n   403→\tstore, err := sqlite.NewStore(\":memory:\")\n   404→\trequire.NoError(t, err)\n   405→\tdefer store.Close()\n   406→\n   407→\tctx := context.Background()\n   408→\n   409→\t// Create runs for two different projects\n   410→\tfor i, id := range []string{\"proj-a-1\", \"proj-a-2\"} {\n   411→\t\tr := domain.NewRun(id, \"develop\")\n   412→\t\tr.ProjectDir = \"/home/user/project-a\"\n   413→\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n   414→\t\tr.State = domain.RunStateRunning\n   415→\t\trequire.NoError(t, store.CreateRun(ctx, r))\n   416→\t}\n   417→\trB := domain.NewRun(\"proj-b-1\", \"develop\")\n   418→\trB.ProjectDir = \"/home/user/project-b\"\n   419→\trB.StartedAt = time.Now()\n   420→\trB.State = domain.RunStateRunning\n   421→\trequire.NoError(t, store.CreateRun(ctx, rB))\n   422→\n   423→\t// Filter by project-a\n   424→\truns, err := store.ListRunsByProject(ctx, \"/home/user/project-a\", time.Time{})\n   425→\trequire.NoError(t, err)\n   426→\tassert.Len(t, runs, 2)\n   427→\tfor _, r := range runs {\n   428→\t\tassert.Equal(t, \"/home/user/project-a\", r.ProjectDir)\n   429→\t}\n   430→\n   431→\t// Filter by project-b\n   432→\truns, err = store.ListRunsByProject(ctx, \"/home/user/project-b\", time.Time{})\n   433→\trequire.NoError(t, err)\n   434→\tassert.Len(t, runs, 1)\n   435→\tassert.Equal(t, \"proj-b-1\", runs[0].ID)\n   436→\n   437→\t// Filter by nonexistent project\n   438→\truns, err = store.ListRunsByProject(ctx, \"/nonexistent\", time.Time{})\n   439→\trequire.NoError(t, err)\n   440→\tassert.Empty(t, runs)\n   441→}\n   442→\n   443→func TestListProjects(t *testing.T) {\n   444→\tstore, err := sqlite.NewStore(\":memory:\")\n   445→\trequire.NoError(t, err)\n   446→\tdefer store.Close()\n   447→\n   448→\tctx := context.Background()\n   449→\n   450→\t// Empty store returns no projects\n   451→\tprojects, err := store.ListProjects(ctx)\n   452→\trequire.NoError(t, err)\n   453→\tassert.Empty(t, projects)\n   454→\n   455→\t// Create runs for different projects\n   456→\tfor _, tc := range []struct {\n   457→\t\tid, project string\n   458→\t}{\n   459→\t\t{\"r1\", \"/home/user/alpha\"},\n   460→\t\t{\"r2\", \"/home/user/alpha\"},\n   461→\t\t{\"r3\", \"/home/user/beta\"},\n   462→\t\t{\"r4\", \"\"},\n   463→\t} {\n   464→\t\tr := domain.NewRun(tc.id, \"develop\")\n   465→\t\tr.ProjectDir = tc.project\n   466→\t\tr.State = domain.RunStatePending\n   467→\t\trequire.NoError(t, store.CreateRun(ctx, r))\n   468→\t}\n   469→\n   470→\tprojects, err = store.ListProjects(ctx)\n   471→\trequire.NoError(t, err)\n   472→\tassert.Equal(t, []string{\"/home/user/alpha\", \"/home/user/beta\"}, projects)\n   473→}\n   474→\n   475→func TestRunContainerKept(t *testing.T) {\n   476→\tstore, err := sqlite.NewStore(\":memory:\")\n   477→\trequire.NoError(t, err)\n   478→\tdefer store.Close()\n   479→\n   480→\tctx := context.Background()\n   481→\n   482→\t// Create a run with ContainerKept = false (default)\n   483→\trun := domain.NewRun(\"kept-1\", \"develop\")\n   484→\trun.Start()\n   485→\trun.ContainerID = \"abc123\"\n   486→\trequire.NoError(t, store.CreateRun(ctx, run))\n   487→\n   488→\tgot, err := store.GetRun(ctx, \"kept-1\")\n   489→\trequire.NoError(t, err)\n   490→\tassert.False(t, got.ContainerKept)\n   491→\n   492→\t// Update to mark container as kept\n   493→\tgot.ContainerKept = true\n   494→\trequire.NoError(t, store.UpdateRun(ctx, got))\n   495→\n   496→\tgot2, err := store.GetRun(ctx, \"kept-1\")\n   497→\trequire.NoError(t, err)\n   498→\tassert.True(t, got2.ContainerKept)\n   499→\n   500→\t// Verify ListRuns includes ContainerKept\n   501→\truns, err := store.ListRuns(ctx, time.Time{})\n   502→\trequire.NoError(t, err)\n   503→\trequire.Len(t, runs, 1)\n   504→\tassert.True(t, runs[0].ContainerKept)\n   505→}\n   506→\n   507→func TestRunIsHost(t *testing.T) {\n   508→\tstore, err := sqlite.NewStore(\":memory:\")\n   509→\trequire.NoError(t, err)\n   510→\tdefer store.Close()\n   511→\n   512→\tctx := context.Background()\n   513→\n   514→\t// Create a host run\n   515→\trun := domain.NewRun(\"host-1\", \"main\")\n   516→\trun.IsHost = true\n   517→\trun.ProjectDir = \"/project\"\n   518→\trun.Start()\n   519→\trequire.NoError(t, store.CreateRun(ctx, run))\n   520→\n   521→\tgot, err := store.GetRun(ctx, \"host-1\")\n   522→\trequire.NoError(t, err)\n   523→\tassert.True(t, got.IsHost)\n   524→\n   525→\t// Create a container run\n   526→\tcrun := domain.NewRun(\"container-1\", \"develop\")\n   527→\tcrun.ProjectDir = \"/project\"\n   528→\tcrun.Start()\n   529→\trequire.NoError(t, store.CreateRun(ctx, crun))\n   530→\n   531→\tgot2, err := store.GetRun(ctx, \"container-1\")\n   532→\trequire.NoError(t, err)\n   533→\tassert.False(t, got2.IsHost)\n   534→\n   535→\t// Verify IsHost shows up in ListRuns\n   536→\truns, err := store.ListRuns(ctx, time.Time{})\n   537→\trequire.NoError(t, err)\n   538→\trequire.Len(t, runs, 2)\n   539→\n   540→\thostFound := false\n   541→\tcontainerFound := false\n   542→\tfor _, r := range runs {\n   543→\t\tif r.ID == \"host-1\" {\n   544→\t\t\tassert.True(t, r.IsHost)\n   545→\t\t\thostFound = true\n   546→\t\t}\n   547→\t\tif r.ID == \"container-1\" {\n   548→\t\t\tassert.False(t, r.IsHost)\n   549→\t\t\tcontainerFound = true\n   550→\t\t}\n   551→\t}\n   552→\tassert.True(t, hostFound)\n   553→\tassert.True(t, containerFound)\n   554→\n   555→\t// Verify IsHost shows up in ListRunsByProject\n   556→\tprojRuns, err := store.ListRunsByProject(ctx, \"/project\", time.Time{})\n   557→\trequire.NoError(t, err)\n   558→\trequire.Len(t, projRuns, 2)\n   559→\tfor _, r := range projRuns {\n   560→\t\tif r.ID == \"host-1\" {\n   561→\t\t\tassert.True(t, r.IsHost)\n   562→\t\t}\n   563→\t}\n   564→\n   565→\t// Test update preserves IsHost\n   566→\tgot.IsHost = false\n   567→\trequire.NoError(t, store.UpdateRun(ctx, got))\n   568→\tgot3, err := store.GetRun(ctx, \"host-1\")\n   569→\trequire.NoError(t, err)\n   570→\tassert.False(t, got3.IsHost)\n   571→}\n   572→\n   573→func TestRunIsHost_BackwardCompat(t *testing.T) {\n   574→\tstore, err := sqlite.NewStore(\":memory:\")\n   575→\trequire.NoError(t, err)\n   576→\tdefer store.Close()\n   577→\n   578→\tctx := context.Background()\n   579→\n   580→\t// Create a run without setting IsHost — simulates pre-migration rows\n   581→\trun := domain.NewRun(\"old-1\", \"develop\")\n   582→\trun.Start()\n   583→\trequire.NoError(t, store.CreateRun(ctx, run))\n   584→\n   585→\tgot, err := store.GetRun(ctx, \"old-1\")\n   586→\trequire.NoError(t, err)\n   587→\tassert.False(t, got.IsHost)\n   588→}\n   589→\n   590→func TestStore_FailStaleRuns(t *testing.T) {\n   591→\tstore, err := sqlite.NewStore(\":memory:\")\n   592→\trequire.NoError(t, err)\n   593→\tdefer store.Close()\n   594→\n   595→\tctx := context.Background()\n   596→\n   597→\t// Create runs in different states.\n   598→\tpending := domain.NewRun(\"pending-1\", \"wf\")\n   599→\trequire.NoError(t, store.CreateRun(ctx, pending))\n   600→\n   601→\trunning := domain.NewRun(\"running-1\", \"wf\")\n   602→\trunning.Start()\n   603→\trequire.NoError(t, store.CreateRun(ctx, running))\n   604→\n   605→\tsucceeded := domain.NewRun(\"succeeded-1\", \"wf\")\n   606→\tsucceeded.Start()\n   607→\tsucceeded.Complete(domain.RunStateSucceeded)\n   608→\trequire.NoError(t, store.CreateRun(ctx, succeeded))\n   609→\n   610→\tn, err := store.FailStaleRuns(ctx)\n   611→\trequire.NoError(t, err)\n   612→\tassert.Equal(t, int64(2), n) // both pending and running\n   613→\n   614→\tgot, err := store.GetRun(ctx, \"pending-1\")\n   615→\trequire.NoError(t, err)\n   616→\tassert.Equal(t, domain.RunStateFailed, got.State)\n   617→\tassert.False(t, got.CompletedAt.IsZero(), \"completed_at should be set\")\n   618→\tassert.Equal(t, \"daemon restarted while run was active\", got.ErrorMessage)\n   619→\n   620→\tgotRunning, err := store.GetRun(ctx, \"running-1\")\n   621→\trequire.NoError(t, err)\n   622→\tassert.Equal(t, domain.RunStateFailed, gotRunning.State)\n   623→\tassert.False(t, gotRunning.CompletedAt.IsZero(), \"completed_at should be set\")\n   624→\tassert.Equal(t, \"daemon restarted while run was active\", gotRunning.ErrorMessage)\n   625→\n   626→\t// Succeeded runs should be untouched.\n   627→\tgotSucceeded, err := store.GetRun(ctx, \"succeeded-1\")\n   628→\trequire.NoError(t, err)\n   629→\tassert.Equal(t, domain.RunStateSucceeded, gotSucceeded.State)\n   630→}\n   631→\n   632→func TestLogFiles_SaveAndGet(t *testing.T) {\n   633→\tstore, err := sqlite.NewStore(\":memory:\")\n   634→\trequire.NoError(t, err)\n   635→\tdefer store.Close()\n   636→\n   637→\tctx := context.Background()\n   638→\n   639→\t// Create a run first (foreign key)\n   640→\trun := domain.NewRun(\"log-run-1\", \"develop\")\n   641→\trun.Start()\n   642→\trequire.NoError(t, store.CreateRun(ctx, run))\n   643→\n   644→\tnow := time.Now().Truncate(time.Second)\n   645→\n   646→\t// Save log file entries\n   647→\tentries := []*ports.LogFileEntry{\n   648→\t\t{RunID: \"log-run-1\", FileType: \"full\", FilePath: \"/tmp/output/full.log\", FileSize: 1024, CreatedAt: now},\n   649→\t\t{RunID: \"log-run-1\", StepName: \"build\", FileType: \"script\", FilePath: \"/tmp/output/build.log\", FileSize: 512, CreatedAt: now},\n   650→\t\t{RunID: \"log-run-1\", StepName: \"build\", FileType: \"llm\", FilePath: \"/tmp/output/llm-build.log\", FileSize: 2048, CreatedAt: now},\n   651→\t\t{RunID: \"log-run-1\", StepName: \"test\", FileType: \"script\", FilePath: \"/tmp/output/test.log\", FileSize: 256, CreatedAt: now},\n   652→\t}\n   653→\tfor _, e := range entries {\n   654→\t\trequire.NoError(t, store.SaveLogFile(ctx, e))\n   655→\t}\n   656→\n   657→\t// GetLogFiles returns all entries for a run\n   658→\tall, err := store.GetLogFiles(ctx, \"log-run-1\")\n   659→\trequire.NoError(t, err)\n   660→\tassert.Len(t, all, 4)\n   661→\n   662→\t// GetLogFilesByStep returns entries for a specific step\n   663→\tbuildLogs, err := store.GetLogFilesByStep(ctx, \"log-run-1\", \"build\")\n   664→\trequire.NoError(t, err)\n   665→\tassert.Len(t, buildLogs, 2)\n   666→\tfor _, lf := range buildLogs {\n   667→\t\tassert.Equal(t, \"build\", lf.StepName)\n   668→\t}\n   669→\n   670→\t// GetLogFileByType returns entries of a specific type\n   671→\tllmLogs, err := store.GetLogFileByType(ctx, \"log-run-1\", \"llm\")\n   672→\trequire.NoError(t, err)\n   673→\tassert.Len(t, llmLogs, 1)\n   674→\tassert.Equal(t, \"llm\", llmLogs[0].FileType)\n   675→\tassert.Equal(t, \"build\", llmLogs[0].StepName)\n   676→\n   677→\t// GetLogFileByType for \"full\"\n   678→\tfullLogs, err := store.GetLogFileByType(ctx, \"log-run-1\", \"full\")\n   679→\trequire.NoError(t, err)\n   680→\tassert.Len(t, fullLogs, 1)\n   681→\tassert.Equal(t, \"full\", fullLogs[0].FileType)\n   682→\tassert.Equal(t, int64(1024), fullLogs[0].FileSize)\n   683→}\n   684→\n   685→func TestRunParentRunID(t *testing.T) {\n   686→\tstore, err := sqlite.NewStore(\":memory:\")\n   687→\trequire.NoError(t, err)\n   688→\tdefer store.Close()\n   689→\n   690→\tctx := context.Background()\n   691→\n   692→\t// Create a host (parent) run\n   693→\tparent := domain.NewRun(\"host-run-1\", \"main\")\n   694→\tparent.IsHost = true\n   695→\tparent.ProjectDir = \"/project\"\n   696→\tparent.Start()\n   697→\trequire.NoError(t, store.CreateRun(ctx, parent))\n   698→\n   699→\t// Create child runs with ParentRunID set\n   700→\tchild1 := domain.NewRun(\"child-1\", \"develop\")\n   701→\tchild1.ProjectDir = \"/project\"\n   702→\tchild1.ParentRunID = \"host-run-1\"\n   703→\tchild1.StartedAt = time.Now()\n   704→\tchild1.State = domain.RunStateRunning\n   705→\trequire.NoError(t, store.CreateRun(ctx, child1))\n   706→\n   707→\tchild2 := domain.NewRun(\"child-2\", \"develop\")\n   708→\tchild2.ProjectDir = \"/project\"\n   709→\tchild2.ParentRunID = \"host-run-1\"\n   710→\tchild2.StartedAt = time.Now().Add(time.Second)\n   711→\tchild2.State = domain.RunStateSucceeded\n   712→\trequire.NoError(t, store.CreateRun(ctx, child2))\n   713→\n   714→\t// Verify ParentRunID is persisted via GetRun\n   715→\tgot, err := store.GetRun(ctx, \"child-1\")\n   716→\trequire.NoError(t, err)\n   717→\tassert.Equal(t, \"host-run-1\", got.ParentRunID)\n   718→\n   719→\t// Verify parent has no ParentRunID\n   720→\tgotParent, err := store.GetRun(ctx, \"host-run-1\")\n   721→\trequire.NoError(t, err)\n   722→\tassert.Equal(t, \"\", gotParent.ParentRunID)\n   723→\n   724→\t// ListChildRuns returns only children of the given parent\n   725→\tchildren, err := store.ListChildRuns(ctx, \"host-run-1\")\n   726→\trequire.NoError(t, err)\n   727→\tassert.Len(t, children, 2)\n   728→\tassert.Equal(t, \"child-1\", children[0].ID)\n   729→\tassert.Equal(t, \"child-2\", children[1].ID)\n   730→\n   731→\t// ListChildRuns for a non-parent returns empty\n   732→\tnoChildren, err := store.ListChildRuns(ctx, \"child-1\")\n   733→\trequire.NoError(t, err)\n   734→\tassert.Empty(t, noChildren)\n   735→\n   736→\t// Verify ParentRunID shows up in ListRuns\n   737→\truns, err := store.ListRuns(ctx, time.Time{})\n   738→\trequire.NoError(t, err)\n   739→\tfor _, r := range runs {\n   740→\t\tif r.ID == \"child-1\" || r.ID == \"child-2\" {\n   741→\t\t\tassert.Equal(t, \"host-run-1\", r.ParentRunID)\n   742→\t\t}\n   743→\t\tif r.ID == \"host-run-1\" {\n   744→\t\t\tassert.Equal(t, \"\", r.ParentRunID)\n   745→\t\t}\n   746→\t}\n   747→\n   748→\t// Test update preserves ParentRunID\n   749→\tgot.ParentRunID = \"new-parent\"\n   750→\trequire.NoError(t, store.UpdateRun(ctx, got))\n   751→\tgot2, err := store.GetRun(ctx, \"child-1\")\n   752→\trequire.NoError(t, err)\n   753→\tassert.Equal(t, \"new-parent\", got2.ParentRunID)\n   754→}\n   755→\n   756→func TestRunParentRunID_BackwardCompat(t *testing.T) {\n   757→\tstore, err := sqlite.NewStore(\":memory:\")\n   758→\trequire.NoError(t, err)\n   759→\tdefer store.Close()\n   760→\n   761→\tctx := context.Background()\n   762→\n   763→\t// Create a run without setting ParentRunID — simulates pre-migration rows\n   764→\trun := domain.NewRun(\"old-1\", \"develop\")\n   765→\trun.Start()\n   766→\trequire.NoError(t, store.CreateRun(ctx, run))\n   767→\n   768→\tgot, err := store.GetRun(ctx, \"old-1\")\n   769→\trequire.NoError(t, err)\n   770→\tassert.Equal(t, \"\", got.ParentRunID)\n   771→}\n   772→\n   773→func TestLogFiles_EmptyResults(t *testing.T) {\n   774→\tstore, err := sqlite.NewStore(\":memory:\")\n   775→\trequire.NoError(t, err)\n   776→\tdefer store.Close()\n   777→\n   778→\tctx := context.Background()\n   779→\n   780→\t// No entries yet\n   781→\tfiles, err := store.GetLogFiles(ctx, \"nonexistent\")\n   782→\trequire.NoError(t, err)\n   783→\tassert.Empty(t, files)\n   784→\n   785→\tfiles, err = store.GetLogFilesByStep(ctx, \"nonexistent\", \"build\")\n   786→\trequire.NoError(t, err)\n   787→\tassert.Empty(t, files)\n   788→\n   789→\tfiles, err = store.GetLogFileByType(ctx, \"nonexistent\", \"llm\")\n   790→\trequire.NoError(t, err)\n   791→\tassert.Empty(t, files)\n   792→}\n   793→\n   794→func TestListRunsSortRunningFirst(t *testing.T) {\n   795→\tstore, err := sqlite.NewStore(\":memory:\")\n   796→\trequire.NoError(t, err)\n   797→\tdefer store.Close()\n   798→\n   799→\tctx := context.Background()\n   800→\tnow := time.Now()\n   801→\n   802→\t// Create runs: oldest running, middle succeeded, newest failed\n   803→\truns := []struct {\n   804→\t\tid    string\n   805→\t\tstate domain.RunState\n   806→\t\tstart time.Time\n   807→\t}{\n   808→\t\t{\"old-running\", domain.RunStateRunning, now.Add(-10 * time.Minute)},\n   809→\t\t{\"mid-succeeded\", domain.RunStateSucceeded, now.Add(-5 * time.Minute)},\n   810→\t\t{\"new-failed\", domain.RunStateFailed, now.Add(-1 * time.Minute)},\n   811→\t\t{\"new-running\", domain.RunStateRunning, now.Add(-2 * time.Minute)},\n   812→\t}\n   813→\n   814→\tfor _, tc := range runs {\n   815→\t\tr := domain.NewRun(tc.id, \"develop\")\n   816→\t\tr.State = tc.state\n   817→\t\tr.StartedAt = tc.start\n   818→\t\tr.ProjectDir = \"/test/project\"\n   819→\t\tif tc.state != domain.RunStateRunning {\n   820→\t\t\tr.CompletedAt = tc.start.Add(time.Minute)\n   821→\t\t}\n   822→\t\trequire.NoError(t, store.CreateRun(ctx, r))\n   823→\t}\n   824→\n   825→\t// ListRuns: running runs first (by recency), then non-running by recency\n   826→\tlisted, err := store.ListRuns(ctx, time.Time{})\n   827→\trequire.NoError(t, err)\n   828→\trequire.Len(t, listed, 4)\n   829→\tassert.Equal(t, \"new-running\", listed[0].ID)    // running, more recent\n   830→\tassert.Equal(t, \"old-running\", listed[1].ID)     // running, older\n   831→\tassert.Equal(t, \"new-failed\", listed[2].ID)      // non-running, most recent\n   832→\tassert.Equal(t, \"mid-succeeded\", listed[3].ID)   // non-running, older\n   833→\n   834→\t// ListRunsByProject: same ordering\n   835→\tlisted, err = store.ListRunsByProject(ctx, \"/test/project\", time.Time{})\n   836→\trequire.NoError(t, err)\n   837→\trequire.Len(t, listed, 4)\n   838→\tassert.Equal(t, \"new-running\", listed[0].ID)\n   839→\tassert.Equal(t, \"old-running\", listed[1].ID)\n   840→\tassert.Equal(t, \"new-failed\", listed[2].ID)\n   841→\tassert.Equal(t, \"mid-succeeded\", listed[3].ID)\n   842→\n   843→\t// ListRuns with since filter: same ordering\n   844→\tlisted, err = store.ListRuns(ctx, now.Add(-6*time.Minute))\n   845→\trequire.NoError(t, err)\n   846→\trequire.Len(t, listed, 3) // excludes old-running (started 10min ago)\n   847→\tassert.Equal(t, \"new-running\", listed[0].ID)\n   848→\tassert.Equal(t, \"new-failed\", listed[1].ID)\n   849→\tassert.Equal(t, \"mid-succeeded\", listed[2].ID)\n   850→}\n   851→"}]},"parent_tool_use_id":null,"session_id":"e9809350-ad4b-4126-9f85-6f6c371f5603","uuid":"517c4ad7-658d-42ef-b16a-fa97f2ff2b8e","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/sqlite/store_test.go","content":"package sqlite_test\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"path/filepath\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestRunStore_CreateAndGet(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n\trun.Start()\n\n\terr = store.CreateRun(ctx, run)\n\trequire.NoError(t, err)\n\n\tgot, err := store.GetRun(ctx, \"run-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"run-1\", got.ID)\n\tassert.Equal(t, \"test-workflow\", got.WorkflowName)\n\tassert.Equal(t, domain.RunStateRunning, got.State)\n}\n\nfunc TestRunStore_Update(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-1\", \"test-workflow\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.UpdateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"run-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, got.State)\n}\n\nfunc TestRunStore_List(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun1 := domain.NewRun(\"run-1\", \"wf-a\")\n\trun2 := domain.NewRun(\"run-2\", \"wf-b\")\n\trequire.NoError(t, store.CreateRun(ctx, run1))\n\trequire.NoError(t, store.CreateRun(ctx, run2))\n\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, 2)\n}\n\nfunc TestRunStore_GetNotFound(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\t_, err = store.GetRun(context.Background(), \"nonexistent\")\n\tassert.Error(t, err)\n}\n\nfunc TestStore_DeleteRun(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run and save a capture for it\n\trun := domain.NewRun(\"del-1\", \"test-workflow\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\trequire.NoError(t, store.SaveCapture(ctx, \"del-1\", &domain.StepExecution{\n\t\tStepName:  \"step1\",\n\t\tStartedAt: time.Now(),\n\t}))\n\n\t// Delete the run\n\terr = store.DeleteRun(ctx, \"del-1\")\n\trequire.NoError(t, err)\n\n\t// Verify run is gone\n\t_, err = store.GetRun(ctx, \"del-1\")\n\tassert.Error(t, err)\n\n\t// Verify captures are gone\n\tcaps, err := store.GetCaptures(ctx, \"del-1\")\n\trequire.NoError(t, err)\n\tassert.Empty(t, caps)\n}\n\nfunc TestRunProjectDir(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"test-1\", \"develop\")\n\trun.ProjectDir = \"/home/user/project\"\n\trun.Start()\n\n\terr = store.CreateRun(ctx, run)\n\trequire.NoError(t, err)\n\n\tgot, err := store.GetRun(ctx, \"test-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"/home/user/project\", got.ProjectDir)\n}\n\nfunc TestCaptureStepMetadata(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"test-1\", \"develop\")\n\trun.Start()\n\tstore.CreateRun(ctx, run)\n\n\texec := &domain.StepExecution{\n\t\tStepName:  \"implement\",\n\t\tResult:    \"success\",\n\t\tStartedAt: time.Now(),\n\t}\n\terr = store.SaveCapture(ctx, \"test-1\", exec)\n\trequire.NoError(t, err)\n\n\tcaps, err := store.GetCaptures(ctx, \"test-1\")\n\trequire.NoError(t, err)\n\trequire.Len(t, caps, 1)\n\tassert.Equal(t, \"implement\", caps[0].StepName)\n\tassert.Equal(t, \"success\", caps[0].Result)\n}\n\nfunc TestListRunsSince(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\tfor i, id := range []string{\"run-1\", \"run-2\", \"run-3\"} {\n\t\tr := domain.NewRun(id, \"develop\")\n\t\tr.ProjectDir = \"/project\"\n\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n\t\tr.State = domain.RunStateRunning\n\t\trequire.NoError(t, store.CreateRun(ctx, r))\n\t}\n\n\truns, err := store.ListRunsSince(ctx, \"/project\", \"develop\", \"run-1\")\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, 2)\n\tassert.Equal(t, \"run-2\", runs[0].ID)\n\tassert.Equal(t, \"run-3\", runs[1].ID)\n}\n\nfunc TestListRunsSinceEmpty(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\tfor i, id := range []string{\"run-1\", \"run-2\"} {\n\t\tr := domain.NewRun(id, \"develop\")\n\t\tr.ProjectDir = \"/project\"\n\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n\t\tr.State = domain.RunStateRunning\n\t\trequire.NoError(t, store.CreateRun(ctx, r))\n\t}\n\n\t// Empty sinceRunID returns all\n\truns, err := store.ListRunsSince(ctx, \"/project\", \"develop\", \"\")\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, 2)\n}\n\nfunc TestGetLastEvolution(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// No evolution yet\n\tentry, err := store.GetLastEvolution(ctx, \"/project\", \"develop\")\n\trequire.NoError(t, err)\n\tassert.Nil(t, entry)\n\n\t// Save one\n\trequire.NoError(t, store.SaveEvolution(ctx, &ports.EvolutionEntry{\n\t\tID:           \"evo-1\",\n\t\tProjectDir:   \"/project\",\n\t\tWorkflowName: \"develop\",\n\t\tTriggerRunID: \"run-1\",\n\t\tCreatedAt:    time.Now(),\n\t\tChangesJSON:  \"[]\",\n\t}))\n\n\tentry, err = store.GetLastEvolution(ctx, \"/project\", \"develop\")\n\trequire.NoError(t, err)\n\trequire.NotNil(t, entry)\n\tassert.Equal(t, \"evo-1\", entry.ID)\n}\n\nfunc TestRunTitle(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run with a title\n\trun := domain.NewRun(\"title-1\", \"develop\")\n\trun.Title = \"Add dark mode toggle\"\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"title-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"Add dark mode toggle\", got.Title)\n\n\t// Update title\n\tgot.Title = \"Updated title\"\n\trequire.NoError(t, store.UpdateRun(ctx, got))\n\n\tgot2, err := store.GetRun(ctx, \"title-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"Updated title\", got2.Title)\n\n\t// Verify title shows up in ListRuns\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, runs, 1)\n\tassert.Equal(t, \"Updated title\", runs[0].Title)\n}\n\nfunc TestRunTitle_BackwardCompat(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run without setting Title — simulates pre-migration rows\n\trun := domain.NewRun(\"notitle-1\", \"develop\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"notitle-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"\", got.Title)\n}\n\nfunc TestRunContainerID(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"cid-1\", \"develop\")\n\trun.Start()\n\trun.ContainerID = \"4647e7e70e3fabc123def456\"\n\n\terr = store.CreateRun(ctx, run)\n\trequire.NoError(t, err)\n\n\tgot, err := store.GetRun(ctx, \"cid-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"4647e7e70e3fabc123def456\", got.ContainerID)\n\n\t// Test update preserves container ID\n\tgot.ContainerID = \"new-container-id\"\n\trequire.NoError(t, store.UpdateRun(ctx, got))\n\n\tgot2, err := store.GetRun(ctx, \"cid-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"new-container-id\", got2.ContainerID)\n\n\t// Test ListRuns includes container ID\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, runs, 1)\n\tassert.Equal(t, \"new-container-id\", runs[0].ContainerID)\n}\n\nfunc TestRunContainerID_BackwardCompat(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\t// Create a run without setting ContainerID — simulates pre-migration rows\n\trun := domain.NewRun(\"old-1\", \"develop\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"old-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"\", got.ContainerID)\n}\n\nfunc TestRunErrorMessage(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"err-1\", \"develop\")\n\trun.Start()\n\trun.Fail(\"failed to start container: image not found\")\n\n\terr = store.CreateRun(ctx, run)\n\trequire.NoError(t, err)\n\n\tgot, err := store.GetRun(ctx, \"err-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, got.State)\n\tassert.Equal(t, \"failed to start container: image not found\", got.ErrorMessage)\n\n\t// Test update preserves error message\n\tgot.ErrorMessage = \"updated error\"\n\trequire.NoError(t, store.UpdateRun(ctx, got))\n\n\tgot2, err := store.GetRun(ctx, \"err-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"updated error\", got2.ErrorMessage)\n}\n\nfunc TestRunErrorMessageInList(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"err-list-1\", \"develop\")\n\trun.Start()\n\trun.Fail(\"container crashed\")\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, runs, 1)\n\tassert.Equal(t, \"container crashed\", runs[0].ErrorMessage)\n}\n\nfunc TestStore_ConcurrentWrites(t *testing.T) {\n\tdbPath := filepath.Join(t.TempDir(), \"concurrent.db\")\n\tstore, err := sqlite.NewStore(dbPath)\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tconst n = 10\n\tctx := context.Background()\n\terrs := make([]error, n)\n\n\tvar wg sync.WaitGroup\n\twg.Add(n)\n\tfor i := 0; i < n; i++ {\n\t\tgo func(i int) {\n\t\t\tdefer wg.Done()\n\t\t\tid := fmt.Sprintf(\"run-%d\", i)\n\t\t\trun := domain.NewRun(id, \"test-workflow\")\n\t\t\trun.Start()\n\t\t\tif err := store.CreateRun(ctx, run); err != nil {\n\t\t\t\terrs[i] = err\n\t\t\t\treturn\n\t\t\t}\n\t\t\terrs[i] = store.SaveCapture(ctx, id, &domain.StepExecution{\n\t\t\t\tStepName:  fmt.Sprintf(\"step-%d\", i),\n\t\t\t\tStartedAt: time.Now(),\n\t\t\t})\n\t\t}(i)\n\t}\n\twg.Wait()\n\n\tfor i, err := range errs {\n\t\tassert.NoError(t, err, \"goroutine %d failed\", i)\n\t}\n\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, n)\n}\n\nfunc TestListRunsByProject(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create runs for two different projects\n\tfor i, id := range []string{\"proj-a-1\", \"proj-a-2\"} {\n\t\tr := domain.NewRun(id, \"develop\")\n\t\tr.ProjectDir = \"/home/user/project-a\"\n\t\tr.StartedAt = time.Now().Add(time.Duration(i) * time.Minute)\n\t\tr.State = domain.RunStateRunning\n\t\trequire.NoError(t, store.CreateRun(ctx, r))\n\t}\n\trB := domain.NewRun(\"proj-b-1\", \"develop\")\n\trB.ProjectDir = \"/home/user/project-b\"\n\trB.StartedAt = time.Now()\n\trB.State = domain.RunStateRunning\n\trequire.NoError(t, store.CreateRun(ctx, rB))\n\n\t// Filter by project-a\n\truns, err := store.ListRunsByProject(ctx, \"/home/user/project-a\", time.Time{})\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, 2)\n\tfor _, r := range runs {\n\t\tassert.Equal(t, \"/home/user/project-a\", r.ProjectDir)\n\t}\n\n\t// Filter by project-b\n\truns, err = store.ListRunsByProject(ctx, \"/home/user/project-b\", time.Time{})\n\trequire.NoError(t, err)\n\tassert.Len(t, runs, 1)\n\tassert.Equal(t, \"proj-b-1\", runs[0].ID)\n\n\t// Filter by nonexistent project\n\truns, err = store.ListRunsByProject(ctx, \"/nonexistent\", time.Time{})\n\trequire.NoError(t, err)\n\tassert.Empty(t, runs)\n}\n\nfunc TestListProjects(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Empty store returns no projects\n\tprojects, err := store.ListProjects(ctx)\n\trequire.NoError(t, err)\n\tassert.Empty(t, projects)\n\n\t// Create runs for different projects\n\tfor _, tc := range []struct {\n\t\tid, project string\n\t}{\n\t\t{\"r1\", \"/home/user/alpha\"},\n\t\t{\"r2\", \"/home/user/alpha\"},\n\t\t{\"r3\", \"/home/user/beta\"},\n\t\t{\"r4\", \"\"},\n\t} {\n\t\tr := domain.NewRun(tc.id, \"develop\")\n\t\tr.ProjectDir = tc.project\n\t\tr.State = domain.RunStatePending\n\t\trequire.NoError(t, store.CreateRun(ctx, r))\n\t}\n\n\tprojects, err = store.ListProjects(ctx)\n\trequire.NoError(t, err)\n\tassert.Equal(t, []string{\"/home/user/alpha\", \"/home/user/beta\"}, projects)\n}\n\nfunc TestRunContainerKept(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run with ContainerKept = false (default)\n\trun := domain.NewRun(\"kept-1\", \"develop\")\n\trun.Start()\n\trun.ContainerID = \"abc123\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"kept-1\")\n\trequire.NoError(t, err)\n\tassert.False(t, got.ContainerKept)\n\n\t// Update to mark container as kept\n\tgot.ContainerKept = true\n\trequire.NoError(t, store.UpdateRun(ctx, got))\n\n\tgot2, err := store.GetRun(ctx, \"kept-1\")\n\trequire.NoError(t, err)\n\tassert.True(t, got2.ContainerKept)\n\n\t// Verify ListRuns includes ContainerKept\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, runs, 1)\n\tassert.True(t, runs[0].ContainerKept)\n}\n\nfunc TestRunIsHost(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a host run\n\trun := domain.NewRun(\"host-1\", \"main\")\n\trun.IsHost = true\n\trun.ProjectDir = \"/project\"\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"host-1\")\n\trequire.NoError(t, err)\n\tassert.True(t, got.IsHost)\n\n\t// Create a container run\n\tcrun := domain.NewRun(\"container-1\", \"develop\")\n\tcrun.ProjectDir = \"/project\"\n\tcrun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, crun))\n\n\tgot2, err := store.GetRun(ctx, \"container-1\")\n\trequire.NoError(t, err)\n\tassert.False(t, got2.IsHost)\n\n\t// Verify IsHost shows up in ListRuns\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, runs, 2)\n\n\thostFound := false\n\tcontainerFound := false\n\tfor _, r := range runs {\n\t\tif r.ID == \"host-1\" {\n\t\t\tassert.True(t, r.IsHost)\n\t\t\thostFound = true\n\t\t}\n\t\tif r.ID == \"container-1\" {\n\t\t\tassert.False(t, r.IsHost)\n\t\t\tcontainerFound = true\n\t\t}\n\t}\n\tassert.True(t, hostFound)\n\tassert.True(t, containerFound)\n\n\t// Verify IsHost shows up in ListRunsByProject\n\tprojRuns, err := store.ListRunsByProject(ctx, \"/project\", time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, projRuns, 2)\n\tfor _, r := range projRuns {\n\t\tif r.ID == \"host-1\" {\n\t\t\tassert.True(t, r.IsHost)\n\t\t}\n\t}\n\n\t// Test update preserves IsHost\n\tgot.IsHost = false\n\trequire.NoError(t, store.UpdateRun(ctx, got))\n\tgot3, err := store.GetRun(ctx, \"host-1\")\n\trequire.NoError(t, err)\n\tassert.False(t, got3.IsHost)\n}\n\nfunc TestRunIsHost_BackwardCompat(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run without setting IsHost — simulates pre-migration rows\n\trun := domain.NewRun(\"old-1\", \"develop\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"old-1\")\n\trequire.NoError(t, err)\n\tassert.False(t, got.IsHost)\n}\n\nfunc TestStore_FailStaleRuns(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create runs in different states.\n\tpending := domain.NewRun(\"pending-1\", \"wf\")\n\trequire.NoError(t, store.CreateRun(ctx, pending))\n\n\trunning := domain.NewRun(\"running-1\", \"wf\")\n\trunning.Start()\n\trequire.NoError(t, store.CreateRun(ctx, running))\n\n\tsucceeded := domain.NewRun(\"succeeded-1\", \"wf\")\n\tsucceeded.Start()\n\tsucceeded.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, succeeded))\n\n\tn, err := store.FailStaleRuns(ctx)\n\trequire.NoError(t, err)\n\tassert.Equal(t, int64(2), n) // both pending and running\n\n\tgot, err := store.GetRun(ctx, \"pending-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, got.State)\n\tassert.False(t, got.CompletedAt.IsZero(), \"completed_at should be set\")\n\tassert.Equal(t, \"daemon restarted while run was active\", got.ErrorMessage)\n\n\tgotRunning, err := store.GetRun(ctx, \"running-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, gotRunning.State)\n\tassert.False(t, gotRunning.CompletedAt.IsZero(), \"completed_at should be set\")\n\tassert.Equal(t, \"daemon restarted while run was active\", gotRunning.ErrorMessage)\n\n\t// Succeeded runs should be untouched.\n\tgotSucceeded, err := store.GetRun(ctx, \"succeeded-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, gotSucceeded.State)\n}\n\nfunc TestLogFiles_SaveAndGet(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run first (foreign key)\n\trun := domain.NewRun(\"log-run-1\", \"develop\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tnow := time.Now().Truncate(time.Second)\n\n\t// Save log file entries\n\tentries := []*ports.LogFileEntry{\n\t\t{RunID: \"log-run-1\", FileType: \"full\", FilePath: \"/tmp/output/full.log\", FileSize: 1024, CreatedAt: now},\n\t\t{RunID: \"log-run-1\", StepName: \"build\", FileType: \"script\", FilePath: \"/tmp/output/build.log\", FileSize: 512, CreatedAt: now},\n\t\t{RunID: \"log-run-1\", StepName: \"build\", FileType: \"llm\", FilePath: \"/tmp/output/llm-build.log\", FileSize: 2048, CreatedAt: now},\n\t\t{RunID: \"log-run-1\", StepName: \"test\", FileType: \"script\", FilePath: \"/tmp/output/test.log\", FileSize: 256, CreatedAt: now},\n\t}\n\tfor _, e := range entries {\n\t\trequire.NoError(t, store.SaveLogFile(ctx, e))\n\t}\n\n\t// GetLogFiles returns all entries for a run\n\tall, err := store.GetLogFiles(ctx, \"log-run-1\")\n\trequire.NoError(t, err)\n\tassert.Len(t, all, 4)\n\n\t// GetLogFilesByStep returns entries for a specific step\n\tbuildLogs, err := store.GetLogFilesByStep(ctx, \"log-run-1\", \"build\")\n\trequire.NoError(t, err)\n\tassert.Len(t, buildLogs, 2)\n\tfor _, lf := range buildLogs {\n\t\tassert.Equal(t, \"build\", lf.StepName)\n\t}\n\n\t// GetLogFileByType returns entries of a specific type\n\tllmLogs, err := store.GetLogFileByType(ctx, \"log-run-1\", \"llm\")\n\trequire.NoError(t, err)\n\tassert.Len(t, llmLogs, 1)\n\tassert.Equal(t, \"llm\", llmLogs[0].FileType)\n\tassert.Equal(t, \"build\", llmLogs[0].StepName)\n\n\t// GetLogFileByType for \"full\"\n\tfullLogs, err := store.GetLogFileByType(ctx, \"log-run-1\", \"full\")\n\trequire.NoError(t, err)\n\tassert.Len(t, fullLogs, 1)\n\tassert.Equal(t, \"full\", fullLogs[0].FileType)\n\tassert.Equal(t, int64(1024), fullLogs[0].FileSize)\n}\n\nfunc TestRunParentRunID(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a host (parent) run\n\tparent := domain.NewRun(\"host-run-1\", \"main\")\n\tparent.IsHost = true\n\tparent.ProjectDir = \"/project\"\n\tparent.Start()\n\trequire.NoError(t, store.CreateRun(ctx, parent))\n\n\t// Create child runs with ParentRunID set\n\tchild1 := domain.NewRun(\"child-1\", \"develop\")\n\tchild1.ProjectDir = \"/project\"\n\tchild1.ParentRunID = \"host-run-1\"\n\tchild1.StartedAt = time.Now()\n\tchild1.State = domain.RunStateRunning\n\trequire.NoError(t, store.CreateRun(ctx, child1))\n\n\tchild2 := domain.NewRun(\"child-2\", \"develop\")\n\tchild2.ProjectDir = \"/project\"\n\tchild2.ParentRunID = \"host-run-1\"\n\tchild2.StartedAt = time.Now().Add(time.Second)\n\tchild2.State = domain.RunStateSucceeded\n\trequire.NoError(t, store.CreateRun(ctx, child2))\n\n\t// Verify ParentRunID is persisted via GetRun\n\tgot, err := store.GetRun(ctx, \"child-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"host-run-1\", got.ParentRunID)\n\n\t// Verify parent has no ParentRunID\n\tgotParent, err := store.GetRun(ctx, \"host-run-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"\", gotParent.ParentRunID)\n\n\t// ListChildRuns returns only children of the given parent\n\tchildren, err := store.ListChildRuns(ctx, \"host-run-1\")\n\trequire.NoError(t, err)\n\tassert.Len(t, children, 2)\n\tassert.Equal(t, \"child-1\", children[0].ID)\n\tassert.Equal(t, \"child-2\", children[1].ID)\n\n\t// ListChildRuns for a non-parent returns empty\n\tnoChildren, err := store.ListChildRuns(ctx, \"child-1\")\n\trequire.NoError(t, err)\n\tassert.Empty(t, noChildren)\n\n\t// Verify ParentRunID shows up in ListRuns\n\truns, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\tfor _, r := range runs {\n\t\tif r.ID == \"child-1\" || r.ID == \"child-2\" {\n\t\t\tassert.Equal(t, \"host-run-1\", r.ParentRunID)\n\t\t}\n\t\tif r.ID == \"host-run-1\" {\n\t\t\tassert.Equal(t, \"\", r.ParentRunID)\n\t\t}\n\t}\n\n\t// Test update preserves ParentRunID\n\tgot.ParentRunID = \"new-parent\"\n\trequire.NoError(t, store.UpdateRun(ctx, got))\n\tgot2, err := store.GetRun(ctx, \"child-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"new-parent\", got2.ParentRunID)\n}\n\nfunc TestRunParentRunID_BackwardCompat(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run without setting ParentRunID — simulates pre-migration rows\n\trun := domain.NewRun(\"old-1\", \"develop\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tgot, err := store.GetRun(ctx, \"old-1\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"\", got.ParentRunID)\n}\n\nfunc TestLogFiles_EmptyResults(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// No entries yet\n\tfiles, err := store.GetLogFiles(ctx, \"nonexistent\")\n\trequire.NoError(t, err)\n\tassert.Empty(t, files)\n\n\tfiles, err = store.GetLogFilesByStep(ctx, \"nonexistent\", \"build\")\n\trequire.NoError(t, err)\n\tassert.Empty(t, files)\n\n\tfiles, err = store.GetLogFileByType(ctx, \"nonexistent\", \"llm\")\n\trequire.NoError(t, err)\n\tassert.Empty(t, files)\n}\n\nfunc TestListRunsSortRunningFirst(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Create runs: oldest running, middle succeeded, newest failed\n\truns := []struct {\n\t\tid    string\n\t\tstate domain.RunState\n\t\tstart time.Time\n\t}{\n\t\t{\"old-running\", domain.RunStateRunning, now.Add(-10 * time.Minute)},\n\t\t{\"mid-succeeded\", domain.RunStateSucceeded, now.Add(-5 * time.Minute)},\n\t\t{\"new-failed\", domain.RunStateFailed, now.Add(-1 * time.Minute)},\n\t\t{\"new-running\", domain.RunStateRunning, now.Add(-2 * time.Minute)},\n\t}\n\n\tfor _, tc := range runs {\n\t\tr := domain.NewRun(tc.id, \"develop\")\n\t\tr.State = tc.state\n\t\tr.StartedAt = tc.start\n\t\tr.ProjectDir = \"/test/project\"\n\t\tif tc.state != domain.RunStateRunning {\n\t\t\tr.CompletedAt = tc.start.Add(time.Minute)\n\t\t}\n\t\trequire.NoError(t, store.CreateRun(ctx, r))\n\t}\n\n\t// ListRuns: running runs first (by recency), then non-running by recency\n\tlisted, err := store.ListRuns(ctx, time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, listed, 4)\n\tassert.Equal(t, \"new-running\", listed[0].ID)    // running, more recent\n\tassert.Equal(t, \"old-running\", listed[1].ID)     // running, older\n\tassert.Equal(t, \"new-failed\", listed[2].ID)      // non-running, most recent\n\tassert.Equal(t, \"mid-succeeded\", listed[3].ID)   // non-running, older\n\n\t// ListRunsByProject: same ordering\n\tlisted, err = store.ListRunsByProject(ctx, \"/test/project\", time.Time{})\n\trequire.NoError(t, err)\n\trequire.Len(t, listed, 4)\n\tassert.Equal(t, \"new-running\", listed[0].ID)\n\tassert.Equal(t, \"old-running\", listed[1].ID)\n\tassert.Equal(t, \"new-failed\", listed[2].ID)\n\tassert.Equal(t, \"mid-succeeded\", listed[3].ID)\n\n\t// ListRuns with since filter: same ordering\n\tlisted, err = store.ListRuns(ctx, now.Add(-6*time.Minute))\n\trequire.NoError(t, err)\n\trequire.Len(t, listed, 3) // excludes old-running (started 10min ago)\n\tassert.Equal(t, \"new-running\", listed[0].ID)\n\tassert.Equal(t, \"new-failed\", listed[1].ID)\n\tassert.Equal(t, \"mid-succeeded\", listed[2].ID)\n}\n","numLines":851,"startLine":1,"totalLines":851}}}
