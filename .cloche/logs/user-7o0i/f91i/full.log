[2026-03-12T17:54:20Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B25xb6D24Dr6efT7ubtRnt","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    12→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    13→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    14→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    15→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    16→)\n    17→\n    18→// Ensure hostStatusHandler implements engine.StatusHandler.\n    19→var _ engine.StatusHandler = (*hostStatusHandler)(nil)\n    20→\n    21→// Runner executes a host workflow by parsing host.cloche and walking the step graph.\n    22→type Runner struct {\n    23→\tDispatcher RunDispatcher\n    24→\tStore      ports.RunStore\n    25→\tTaskID     string   // optional task ID assigned by the daemon loop\n    26→\tExtraEnv   []string // additional KEY=VALUE env vars passed to all steps\n    27→}\n    28→\n    29→// RunResult contains the outcome of a host workflow execution.\n    30→type RunResult struct {\n    31→\tRunID     string\n    32→\tState     domain.RunState\n    33→\tOutputDir string // path to the step output directory\n    34→}\n    35→\n    36→// Run parses .cloche/host.cloche from projectDir and executes the \"main\" workflow.\n    37→func (r *Runner) Run(ctx context.Context, projectDir string) (*RunResult, error) {\n    38→\treturn r.RunWithID(ctx, projectDir, domain.GenerateRunID(\"main\"))\n    39→}\n    40→\n    41→// RunWithID is like Run but uses the provided run ID instead of generating one.\n    42→func (r *Runner) RunWithID(ctx context.Context, projectDir string, orchRunID string) (*RunResult, error) {\n    43→\treturn r.runNamedWorkflow(ctx, projectDir, \"main\", orchRunID)\n    44→}\n    45→\n    46→// RunNamed parses .cloche/host.cloche from projectDir and executes the workflow\n    47→// with the given name. The host.cloche file may contain multiple workflows (e.g.\n    48→// \"list-tasks\", \"main\", \"finalize\"). Returns an error if the named workflow is\n    49→// not found.\n    50→func (r *Runner) RunNamed(ctx context.Context, projectDir string, workflowName string) (*RunResult, error) {\n    51→\torchRunID := domain.GenerateRunID(workflowName)\n    52→\treturn r.runNamedWorkflow(ctx, projectDir, workflowName, orchRunID)\n    53→}\n    54→\n    55→// runNamedWorkflow is the internal implementation that runs a specific named\n    56→// workflow from host.cloche.\n    57→func (r *Runner) runNamedWorkflow(ctx context.Context, projectDir string, workflowName string, orchRunID string) (*RunResult, error) {\n    58→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n    59→\tdata, err := os.ReadFile(hostPath)\n    60→\tif err != nil {\n    61→\t\treturn nil, fmt.Errorf(\"reading host.cloche: %w\", err)\n    62→\t}\n    63→\n    64→\tworkflows, err := dsl.ParseAllForHost(string(data))\n    65→\tif err != nil {\n    66→\t\treturn nil, fmt.Errorf(\"parsing host.cloche: %w\", err)\n    67→\t}\n    68→\n    69→\twf, ok := workflows[workflowName]\n    70→\tif !ok {\n    71→\t\treturn nil, fmt.Errorf(\"host.cloche has no workflow %q\", workflowName)\n    72→\t}\n    73→\n    74→\t// Create output directory for step outputs\n    75→\toutputDir := filepath.Join(projectDir, \".cloche\", orchRunID, \"output\")\n    76→\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n    77→\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n    78→\t}\n    79→\n    80→\tlog.Printf(\"host workflow: starting %q for project %s (run %s)\", wf.Name, projectDir, orchRunID)\n    81→\n    82→\t// Persist the host run in the store so it appears in list/status/logs.\n    83→\thostRun := domain.NewRun(orchRunID, wf.Name)\n    84→\thostRun.ProjectDir = projectDir\n    85→\thostRun.IsHost = true\n    86→\tif err := r.Store.CreateRun(ctx, hostRun); err != nil {\n    87→\t\treturn nil, fmt.Errorf(\"creating host run record: %w\", err)\n    88→\t}\n    89→\thostRun.Start()\n    90→\t_ = r.Store.UpdateRun(ctx, hostRun)\n    91→\n    92→\texecutor := &Executor{\n    93→\t\tProjectDir: projectDir,\n    94→\t\tMainDir:    MainWorktreeDir(projectDir),\n    95→\t\tDispatcher: r.Dispatcher,\n    96→\t\tStore:      r.Store,\n    97→\t\tOutputDir:  outputDir,\n    98→\t\tWires:      wf.Wiring,\n    99→\t\tHostRunID:  orchRunID,\n   100→\t\tTaskID:     r.TaskID,\n   101→\t\tExtraEnv:   r.ExtraEnv,\n   102→\t}\n   103→\n   104→\t// Configure agent from workflow-level host config\n   105→\tif cmd := wf.Config[\"host.agent_command\"]; cmd != \"\" {\n   106→\t\texecutor.AgentCommands = prompt.ParseCommands(cmd)\n   107→\t}\n   108→\tif args := wf.Config[\"host.agent_args\"]; args != \"\" {\n   109→\t\texecutor.AgentArgs = strings.Fields(args)\n   110→\t}\n   111→\n   112→\teng := engine.New(executor)\n   113→\teng.SetStatusHandler(&hostStatusHandler{\n   114→\t\tprojectDir: projectDir,\n   115→\t\torchRunID:  orchRunID,\n   116→\t\tstore:      r.Store,\n   117→\t})\n   118→\n   119→\trun, runErr := eng.Run(ctx, wf)\n   120→\n   121→\tresult := &RunResult{\n   122→\t\tRunID:     orchRunID,\n   123→\t\tState:     domain.RunStateFailed,\n   124→\t\tOutputDir: outputDir,\n   125→\t}\n   126→\tif run != nil {\n   127→\t\tresult.State = run.State\n   128→\t}\n   129→\n   130→\t// Persist final state.\n   131→\thostRun, _ = r.Store.GetRun(ctx, orchRunID)\n   132→\tif hostRun != nil {\n   133→\t\tif runErr != nil {\n   134→\t\t\thostRun.Fail(runErr.Error())\n   135→\t\t} else {\n   136→\t\t\thostRun.Complete(result.State)\n   137→\t\t}\n   138→\t\thostRun.ActiveSteps = nil\n   139→\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n   140→\t}\n   141→\n   142→\tif runErr != nil {\n   143→\t\tlog.Printf(\"host workflow: %q failed for %s: %v\", wf.Name, projectDir, runErr)\n   144→\t\treturn result, runErr\n   145→\t}\n   146→\n   147→\tlog.Printf(\"host workflow: %q completed for %s with state %s\", wf.Name, projectDir, run.State)\n   148→\treturn result, nil\n   149→}\n   150→\n   151→// RunListTasksWorkflow executes the list-tasks workflow and returns the\n   152→// discovered tasks. When the workflow succeeds but finds no tasks, the run\n   153→// record is deleted from the store to avoid cluttering the run history with\n   154→// empty list-tasks entries.\n   155→func RunListTasksWorkflow(ctx context.Context, runner *Runner, projectDir string) ([]Task, *RunResult, error) {\n   156→\tresult, err := runner.RunNamed(ctx, projectDir, \"list-tasks\")\n   157→\tif err != nil {\n   158→\t\treturn nil, nil, err\n   159→\t}\n   160→\tif result.State != domain.RunStateSucceeded {\n   161→\t\treturn nil, result, fmt.Errorf(\"list-tasks workflow failed with state %s\", result.State)\n   162→\t}\n   163→\ttasks, err := ReadListTasksOutput(result.OutputDir)\n   164→\tif err != nil {\n   165→\t\treturn nil, result, err\n   166→\t}\n   167→\t// When list-tasks returns no tasks, remove the run record to keep the\n   168→\t// run history focused on runs where actual work was attempted.\n   169→\tif len(tasks) == 0 && result.RunID != \"\" {\n   170→\t\t_ = runner.Store.DeleteRun(ctx, result.RunID)\n   171→\t}\n   172→\treturn tasks, result, nil\n   173→}\n   174→\n   175→// hostStatusHandler logs host workflow step events and persists them to the store.\n   176→type hostStatusHandler struct {\n   177→\tprojectDir string\n   178→\torchRunID  string\n   179→\tstore      ports.RunStore\n   180→}\n   181→\n   182→func (h *hostStatusHandler) OnStepStart(_ *domain.Run, step *domain.Step) {\n   183→\tlog.Printf(\"host workflow [%s]: step %q started\", h.orchRunID, step.Name)\n   184→\tif h.store != nil {\n   185→\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n   186→\t\t\tr.RecordStepStart(step.Name)\n   187→\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n   188→\t\t}\n   189→\t}\n   190→}\n   191→\n   192→func (h *hostStatusHandler) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   193→\tlog.Printf(\"host workflow [%s]: step %q completed with result %q\", h.orchRunID, step.Name, result)\n   194→\tif h.store != nil {\n   195→\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n   196→\t\t\tr.RecordStepComplete(step.Name, result)\n   197→\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n   198→\t\t}\n   199→\t}\n   200→}\n   201→\n   202→func (h *hostStatusHandler) OnRunComplete(run *domain.Run) {\n   203→\tlog.Printf(\"host workflow [%s]: run completed with state %s\", h.orchRunID, run.State)\n   204→}\n   205→"}]},"parent_tool_use_id":"toolu_017XMRKDuxAWjGZBtTmPAAFU","session_id":"e9809350-ad4b-4126-9f85-6f6c371f5603","uuid":"bfe73855-f6bb-40ed-8724-c1dbb481c2d4"}
[2026-03-12T17:54:20Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011i2Hb73E8p4SfKwEuZxb13","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    19→\t\"github.com/cloche-dev/cloche/internal/config\"\n    20→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    21→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    22→\t\"github.com/cloche-dev/cloche/internal/host\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    26→\trpcgrpc \"google.golang.org/grpc\"\n    27→\t\"google.golang.org/grpc/metadata\"\n    28→)\n    29→\n    30→type ClocheServer struct {\n    31→\tpb.UnimplementedClocheServiceServer\n    32→\tstore        ports.RunStore\n    33→\tcaptures     ports.CaptureStore\n    34→\tlogStore     ports.LogStore\n    35→\tcontainer    ports.ContainerRuntime\n    36→\tdefaultImage string\n    37→\tevolution    *evolution.Trigger\n    38→\tlogBroadcast *logstream.Broadcaster\n    39→\tshutdownFn   func()\n    40→\tmu           sync.Mutex\n    41→\trunIDs       map[string]string      // run_id -> container_id\n    42→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    43→}\n    44→\n    45→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    46→\treturn &ClocheServer{\n    47→\t\tstore:     store,\n    48→\t\tcontainer: container,\n    49→\t\trunIDs:    make(map[string]string),\n    50→\t\tloops:     make(map[string]*host.Loop),\n    51→\t}\n    52→}\n    53→\n    54→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    55→\treturn &ClocheServer{\n    56→\t\tstore:        store,\n    57→\t\tcaptures:     captures,\n    58→\t\tcontainer:    container,\n    59→\t\tdefaultImage: defaultImage,\n    60→\t\trunIDs:       make(map[string]string),\n    61→\t\tloops:        make(map[string]*host.Loop),\n    62→\t}\n    63→}\n    64→\n    65→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    66→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    67→\ts.logStore = ls\n    68→}\n    69→\n    70→\n    71→// SetEvolution attaches an evolution trigger to the server.\n    72→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    73→\ts.evolution = trigger\n    74→}\n    75→\n    76→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    77→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    78→\ts.logBroadcast = b\n    79→}\n    80→\n    81→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    82→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    83→\ts.shutdownFn = fn\n    84→}\n    85→\n    86→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    87→\tif s.container == nil {\n    88→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    89→\t}\n    90→\n    91→\t// Generate a unique run ID, retrying on collision\n    92→\tvar runID string\n    93→\tfor attempts := 0; attempts < 10; attempts++ {\n    94→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    95→\t\texisting, err := s.store.GetRun(ctx, runID)\n    96→\t\tif err != nil {\n    97→\t\t\tbreak // ID is free\n    98→\t\t}\n    99→\t\t// Reuse if completed more than 1 hour ago\n   100→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   101→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   102→\t\t\tbreak\n   103→\t\t}\n   104→\t}\n   105→\n   106→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   107→\tif req.Prompt != \"\" {\n   108→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   109→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   110→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   111→\t\t}\n   112→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   113→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   114→\t\t}\n   115→\t}\n   116→\trun := domain.NewRun(runID, req.WorkflowName)\n   117→\trun.ProjectDir = req.ProjectDir\n   118→\trun.Title = req.Title\n   119→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   120→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   121→\t}\n   122→\n   123→\t// Resolve image: request-level override, then server default\n   124→\timage := req.Image\n   125→\tif image == \"\" {\n   126→\t\timage = s.defaultImage\n   127→\t}\n   128→\n   129→\t// Launch container start + tracking in background so the RPC returns immediately.\n   130→\t// The run stays in \"pending\" state until the container is up.\n   131→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   132→\n   133→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   134→}\n   135→\n   136→// launchAndTrack starts the container and then tracks it to completion.\n   137→// It runs in a background goroutine with its own context, independent of the\n   138→// RPC context which may be cancelled after RunWorkflow returns.\n   139→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   140→\tctx := context.Background()\n   141→\n   142→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   143→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   144→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   145→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   146→\t\t\tif run != nil {\n   147→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   148→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   149→\t\t\t}\n   150→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   151→\t\t\t\treturn\n   152→\t\t}\n   153→\t}\n   154→\n   155→\tbaseSHA := gitHEAD(req.ProjectDir)\n   156→\n   157→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   158→\t\tImage:        image,\n   159→\t\tWorkflowName: req.WorkflowName,\n   160→\t\tProjectDir:   req.ProjectDir,\n   161→\t\tRunID:        runID,\n   162→\t\tNetworkAllow: []string{\"*\"},\n   163→\t})\n   164→\tif err != nil {\n   165→\t\trun, _ := s.store.GetRun(ctx, runID)\n   166→\t\tif run != nil {\n   167→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   168→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   169→\t\t}\n   170→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   171→\t\treturn\n   172→\t}\n   173→\n   174→\ts.mu.Lock()\n   175→\ts.runIDs[runID] = containerID\n   176→\ts.mu.Unlock()\n   177→\n   178→\trun, _ := s.store.GetRun(ctx, runID)\n   179→\tif run != nil {\n   180→\t\trun.Start()\n   181→\t\trun.ContainerID = containerID\n   182→\t\trun.BaseSHA = baseSHA\n   183→\t\t_ = s.store.UpdateRun(ctx, run)\n   184→\t}\n   185→\n   186→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   187→}\n   188→\n   189→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   190→\tctx := context.Background()\n   191→\n   192→\t// Attach to agent output\n   193→\treader, err := s.container.AttachOutput(ctx, containerID)\n   194→\tif err != nil {\n   195→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   196→\t\t\treturn\n   197→\t}\n   198→\n   199→\t// Parse JSON-lines status messages\n   200→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   201→\tscanner := bufio.NewScanner(reader)\n   202→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   203→\tfor scanner.Scan() {\n   204→\t\tvar msg protocol.StatusMessage\n   205→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   206→\t\t\tcontinue\n   207→\t\t}\n   208→\n   209→\t\t// Fast path: log messages don't need store interaction.\n   210→\t\tif msg.Type == protocol.MsgLog {\n   211→\t\t\tif s.logBroadcast != nil {\n   212→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   213→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   214→\t\t\t\t\tType:      \"llm\",\n   215→\t\t\t\t\tContent:   msg.Message,\n   216→\t\t\t\t\tStepName:  msg.StepName,\n   217→\t\t\t\t})\n   218→\t\t\t}\n   219→\t\t\tcontinue\n   220→\t\t}\n   221→\n   222→\t\trun, err := s.store.GetRun(ctx, runID)\n   223→\t\tif err != nil {\n   224→\t\t\tcontinue\n   225→\t\t}\n   226→\n   227→\t\tswitch msg.Type {\n   228→\t\tcase protocol.MsgStepStarted:\n   229→\t\t\trun.RecordStepStart(msg.StepName)\n   230→\t\t\tif s.captures != nil {\n   231→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   232→\t\t\t\t\tStepName:  msg.StepName,\n   233→\t\t\t\t\tStartedAt: msg.Timestamp,\n   234→\t\t\t\t})\n   235→\t\t\t}\n   236→\t\t\tif s.logBroadcast != nil {\n   237→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   238→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   239→\t\t\t\t\tType:      \"status\",\n   240→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   241→\t\t\t\t\tStepName:  msg.StepName,\n   242→\t\t\t\t})\n   243→\t\t\t}\n   244→\t\tcase protocol.MsgStepCompleted:\n   245→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   246→\t\t\tif s.captures != nil {\n   247→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   248→\t\t\t\t\tStepName:    msg.StepName,\n   249→\t\t\t\t\tResult:      msg.Result,\n   250→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   251→\t\t\t\t})\n   252→\t\t\t}\n   253→\t\t\tif s.logBroadcast != nil {\n   254→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   255→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   256→\t\t\t\t\tType:      \"status\",\n   257→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   258→\t\t\t\t\tStepName:  msg.StepName,\n   259→\t\t\t\t})\n   260→\t\t\t}\n   261→\t\tcase protocol.MsgRunTitle:\n   262→\t\t\tif run.Title == \"\" {\n   263→\t\t\t\trun.Title = msg.Message\n   264→\t\t\t}\n   265→\t\tcase protocol.MsgRunCompleted:\n   266→\t\t\treportedResult = msg.Result\n   267→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   268→\t\t}\n   269→\n   270→\t\t_ = s.store.UpdateRun(ctx, run)\n   271→\t}\n   272→\treader.Close()\n   273→\n   274→\t// Signal live-stream subscribers that this run is done.\n   275→\tif s.logBroadcast != nil {\n   276→\t\ts.logBroadcast.Finish(runID)\n   277→\t}\n   278→\n   279→\t// Wait for process exit\n   280→\texitCode, err := s.container.Wait(ctx, containerID)\n   281→\tif err != nil {\n   282→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   283→\t}\n   284→\n   285→\t// Extract step output files from container before it's removed\n   286→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   287→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   288→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   289→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   290→\t\t}\n   291→\t}\n   292→\n   293→\t// Capture full container stdout/stderr before the container is removed\n   294→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   295→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   296→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   297→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   298→\t\t}\n   299→\t}\n   300→\n   301→\t// Index extracted log files in the log store\n   302→\tif s.logStore != nil {\n   303→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   304→\t}\n   305→\n   306→\t// Extract results to git branch BEFORE finalizing state, so that\n   307→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   308→\t// before the run is marked complete.\n   309→\tresultLabel := reportedResult\n   310→\tif resultLabel == \"\" {\n   311→\t\tif exitCode == 0 {\n   312→\t\t\tresultLabel = \"succeeded\"\n   313→\t\t} else {\n   314→\t\t\tresultLabel = \"failed\"\n   315→\t\t}\n   316→\t}\n   317→\t{\n   318→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   319→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   320→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   321→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   322→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   323→\t\t\t} else {\n   324→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   325→\t\t\t}\n   326→\t\t} else {\n   327→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   328→\t\t}\n   329→\t}\n   330→\n   331→\t// Now finalize run state\n   332→\trun, err := s.store.GetRun(ctx, runID)\n   333→\tif err != nil {\n   334→\t\treturn\n   335→\t}\n   336→\tif run.State == domain.RunStateRunning {\n   337→\t\tif reportedResult == \"succeeded\" {\n   338→\t\t\trun.Complete(domain.RunStateSucceeded)\n   339→\t\t} else if reportedResult != \"\" {\n   340→\t\t\trun.Complete(domain.RunStateFailed)\n   341→\t\t} else if exitCode == 0 {\n   342→\t\t\trun.Complete(domain.RunStateSucceeded)\n   343→\t\t} else {\n   344→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   345→\t\t}\n   346→\t\t_ = s.store.UpdateRun(ctx, run)\n   347→\t}\n   348→\n   349→\t// Fire evolution trigger if configured\n   350→\tif s.evolution != nil {\n   351→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   352→\t}\n   353→\n   354→\t// Merge is handled as a workflow step in host.cloche, not here.\n   355→\n   356→\t// Container retention policy:\n   357→\t// - Failed runs: always keep the container for debugging\n   358→\t// - Successful runs + --keep-container: keep the container\n   359→\t// - Successful runs without --keep-container: remove the container\n   360→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   361→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   362→\n   363→\tif keepContainer || runFailed {\n   364→\t\treason := \"--keep-container\"\n   365→\t\tif runFailed {\n   366→\t\t\treason = \"run failed\"\n   367→\t\t}\n   368→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   369→\t\tif runFinal != nil {\n   370→\t\t\trunFinal.ContainerKept = true\n   371→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   372→\t\t}\n   373→\t} else {\n   374→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   375→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   376→\t\t} else {\n   377→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   378→\t\t}\n   379→\t}\n   380→\n   381→\t// Cleanup mapping\n   382→\ts.mu.Lock()\n   383→\tdelete(s.runIDs, runID)\n   384→\ts.mu.Unlock()\n   385→}\n   386→\n   387→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   388→\tvar runs []*domain.Run\n   389→\tvar err error\n   390→\tif req.ProjectDir != \"\" {\n   391→\t\t// Project-scoped: no time filter (project is sufficient scoping)\n   392→\t\truns, err = s.store.ListRunsByProject(ctx, req.ProjectDir, time.Time{})\n   393→\t} else if req.All {\n   394→\t\truns, err = s.store.ListRuns(ctx, time.Time{})\n   395→\t} else {\n   396→\t\truns, err = s.store.ListRuns(ctx, time.Now().Add(-1*time.Hour))\n   397→\t}\n   398→\tif err != nil {\n   399→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   400→\t}\n   401→\n   402→\tresp := &pb.ListRunsResponse{}\n   403→\tfor _, run := range runs {\n   404→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   405→\t\t\tRunId:        run.ID,\n   406→\t\t\tWorkflowName: run.WorkflowName,\n   407→\t\t\tState:        string(run.State),\n   408→\t\t\tStartedAt:    run.StartedAt.String(),\n   409→\t\t\tErrorMessage: run.ErrorMessage,\n   410→\t\t\tContainerId:  run.ContainerID,\n   411→\t\t\tTitle:        run.Title,\n   412→\t\t\tIsHost:       run.IsHost,\n   413→\t\t\tProjectDir:   run.ProjectDir,\n   414→\t\t})\n   415→\t}\n   416→\treturn resp, nil\n   417→}\n   418→\n   419→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   420→\trun, err := s.store.GetRun(ctx, req.RunId)\n   421→\tif err != nil {\n   422→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   423→\t}\n   424→\n   425→\tresp := &pb.GetStatusResponse{\n   426→\t\tRunId:        run.ID,\n   427→\t\tWorkflowName: run.WorkflowName,\n   428→\t\tState:        string(run.State),\n   429→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   430→\t\tErrorMessage: run.ErrorMessage,\n   431→\t\tContainerId:  run.ContainerID,\n   432→\t\tTitle:        run.Title,\n   433→\t\tIsHost:       run.IsHost,\n   434→\t}\n   435→\n   436→\t// Check container liveness\n   437→\tif run.ContainerID != \"\" && s.container != nil {\n   438→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   439→\t\t\tresp.ContainerAlive = cs.Running\n   440→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   441→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   442→\t\t\t}\n   443→\t\t}\n   444→\t}\n   445→\n   446→\t// Load step executions from captures store if available\n   447→\tif s.captures != nil {\n   448→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   449→\t\tif err == nil {\n   450→\t\t\tfor _, exec := range captures {\n   451→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   452→\t\t\t\t\tStepName:    exec.StepName,\n   453→\t\t\t\t\tResult:      exec.Result,\n   454→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   455→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   456→\t\t\t\t})\n   457→\t\t\t}\n   458→\t\t}\n   459→\t} else {\n   460→\t\tfor _, exec := range run.StepExecutions {\n   461→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   462→\t\t\t\tStepName:    exec.StepName,\n   463→\t\t\t\tResult:      exec.Result,\n   464→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   465→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   466→\t\t\t})\n   467→\t\t}\n   468→\t}\n   469→\n   470→\treturn resp, nil\n   471→}\n   472→\n   473→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   474→\tctx := stream.Context()\n   475→\n   476→\t// Check for follow mode via gRPC metadata.\n   477→\tfollow := followFromContext(ctx)\n   478→\n   479→\t// Verify run exists\n   480→\trun, err := s.store.GetRun(ctx, req.RunId)\n   481→\tif err != nil {\n   482→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   483→\t}\n   484→\n   485→\t// If step_name or log_type filter is set, serve content directly from the log index\n   486→\tif req.StepName != \"\" || req.LogType != \"\" {\n   487→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   488→\t}\n   489→\n   490→\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n   491→\n   492→\t// With -f on an active run: send existing logs then tail live output.\n   493→\tif follow && isActive && s.logBroadcast != nil {\n   494→\t\treturn s.streamFollowLogs(req.RunId, run, stream)\n   495→\t}\n   496→\n   497→\t// Without -f on an active run: snapshot existing logs and return.\n   498→\t// (Legacy callers that relied on implicit live streaming should use -f.)\n   499→\t// With -f on a completed run: same as without -f — no new lines will arrive.\n   500→\n   501→\t// Check for full.log first — if it exists, serve it as the unified log\n   502→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   503→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   504→\t\tif err := stream.Send(&pb.LogEntry{\n   505→\t\t\tType:    \"full_log\",\n   506→\t\t\tMessage: string(data),\n   507→\t\t}); err != nil {\n   508→\t\t\treturn err\n   509→\t\t}\n   510→\t\tif !isActive {\n   511→\t\t\tif err := stream.Send(&pb.LogEntry{\n   512→\t\t\t\tType:      \"run_completed\",\n   513→\t\t\t\tResult:    string(run.State),\n   514→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   515→\t\t\t\tMessage:   run.ErrorMessage,\n   516→\t\t\t}); err != nil {\n   517→\t\t\t\treturn err\n   518→\t\t\t}\n   519→\t\t}\n   520→\t\treturn nil\n   521→\t}\n   522→\n   523→\tif s.captures == nil {\n   524→\t\treturn fmt.Errorf(\"captures store not configured\")\n   525→\t}\n   526→\n   527→\t// Fall back to capture-based streaming\n   528→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   529→\tif err != nil {\n   530→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   531→\t}\n   532→\n   533→\tfor _, exec := range captures {\n   534→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   535→\t\t// and one for step_completed (has Result).\n   536→\t\tif exec.Result == \"\" {\n   537→\t\t\tentry := &pb.LogEntry{\n   538→\t\t\t\tType:      \"step_started\",\n   539→\t\t\t\tStepName:  exec.StepName,\n   540→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   541→\t\t\t}\n   542→\t\t\tif err := stream.Send(entry); err != nil {\n   543→\t\t\t\treturn err\n   544→\t\t\t}\n   545→\t\t} else {\n   546→\t\t\t// Read step output from per-step log file.\n   547→\t\t\t// Do NOT fall back to container.log — it contains unfiltered output\n   548→\t\t\t// from ALL steps and would show wrong content for this step.\n   549→\t\t\tvar output string\n   550→\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   551→\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   552→\t\t\t\toutput = string(data)\n   553→\t\t\t}\n   554→\t\t\tentry := &pb.LogEntry{\n   555→\t\t\t\tType:      \"step_completed\",\n   556→\t\t\t\tStepName:  exec.StepName,\n   557→\t\t\t\tResult:    exec.Result,\n   558→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   559→\t\t\t\tMessage:   output,\n   560→\t\t\t}\n   561→\t\t\tif err := stream.Send(entry); err != nil {\n   562→\t\t\t\treturn err\n   563→\t\t\t}\n   564→\t\t}\n   565→\t}\n   566→\n   567→\t// Send run completion entry\n   568→\tif !isActive {\n   569→\t\tif err := stream.Send(&pb.LogEntry{\n   570→\t\t\tType:      \"run_completed\",\n   571→\t\t\tResult:    string(run.State),\n   572→\t\t\tTimestamp: run.CompletedAt.String(),\n   573→\t\t\tMessage:   run.ErrorMessage,\n   574→\t\t}); err != nil {\n   575→\t\t\treturn err\n   576→\t\t}\n   577→\t}\n   578→\n   579→\treturn nil\n   580→}\n   581→\n   582→// followFromContext checks for the follow flag in gRPC metadata.\n   583→func followFromContext(ctx context.Context) bool {\n   584→\tmd, ok := metadata.FromIncomingContext(ctx)\n   585→\tif !ok {\n   586→\t\treturn false\n   587→\t}\n   588→\tvals := md.Get(\"x-cloche-follow\")\n   589→\treturn len(vals) > 0 && vals[0] == \"true\"\n   590→}\n   591→\n   592→// streamFollowLogs sends existing log content then tails live output from the\n   593→// broadcaster. It combines snapshot + live streaming (like tail -f).\n   594→func (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   595→\t// Subscribe first so we don't miss lines written between read and subscribe.\n   596→\tsub := s.logBroadcast.Subscribe(runID)\n   597→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   598→\n   599→\t// Send existing full.log content if available.\n   600→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n   601→\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n   602→\t\tif err := stream.Send(&pb.LogEntry{\n   603→\t\t\tType:    \"full_log\",\n   604→\t\t\tMessage: string(data),\n   605→\t\t}); err != nil {\n   606→\t\t\treturn err\n   607→\t\t}\n   608→\t}\n   609→\n   610→\t// Now tail live output from the broadcaster.\n   611→\tctx := stream.Context()\n   612→\tfor {\n   613→\t\tselect {\n   614→\t\tcase <-ctx.Done():\n   615→\t\t\treturn ctx.Err()\n   616→\t\tcase line, ok := <-sub.C:\n   617→\t\t\tif !ok {\n   618→\t\t\t\t// Run completed — send terminal entry.\n   619→\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n   620→\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n   621→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   622→\t\t\t\t\t\tType:      \"run_completed\",\n   623→\t\t\t\t\t\tResult:    string(r.State),\n   624→\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n   625→\t\t\t\t\t\tMessage:   r.ErrorMessage,\n   626→\t\t\t\t\t})\n   627→\t\t\t\t}\n   628→\t\t\t\treturn nil\n   629→\t\t\t}\n   630→\t\t\tif err := stream.Send(&pb.LogEntry{\n   631→\t\t\t\tType:      \"log\",\n   632→\t\t\t\tStepName:  line.StepName,\n   633→\t\t\t\tMessage:   line.Content,\n   634→\t\t\t\tTimestamp: line.Timestamp,\n   635→\t\t\t}); err != nil {\n   636→\t\t\t\treturn err\n   637→\t\t\t}\n   638→\t\t}\n   639→\t}\n   640→}\n   641→\n   642→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   643→// It uses the log index when available, falling back to file path conventions.\n   644→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   645→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   646→\n   647→\t// Try log index first\n   648→\tif s.logStore != nil {\n   649→\t\tvar logFiles []*ports.LogFileEntry\n   650→\t\tvar err error\n   651→\n   652→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   653→\t\t\t// Filter by both step and type\n   654→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   655→\t\t\tif err == nil {\n   656→\t\t\t\tfiltered := logFiles[:0]\n   657→\t\t\t\tfor _, lf := range logFiles {\n   658→\t\t\t\t\tif lf.FileType == req.LogType {\n   659→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   660→\t\t\t\t\t}\n   661→\t\t\t\t}\n   662→\t\t\t\tlogFiles = filtered\n   663→\t\t\t}\n   664→\t\t} else if req.StepName != \"\" {\n   665→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   666→\t\t} else {\n   667→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   668→\t\t}\n   669→\n   670→\t\tif err == nil && len(logFiles) > 0 {\n   671→\t\t\tfor _, lf := range logFiles {\n   672→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   673→\t\t\t\tif readErr != nil {\n   674→\t\t\t\t\tcontinue\n   675→\t\t\t\t}\n   676→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   677→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   678→\t\t\t\t\tStepName: lf.StepName,\n   679→\t\t\t\t\tMessage:  string(data),\n   680→\t\t\t\t}); err != nil {\n   681→\t\t\t\t\treturn err\n   682→\t\t\t\t}\n   683→\t\t\t}\n   684→\t\t\treturn nil\n   685→\t\t}\n   686→\t}\n   687→\n   688→\t// Fall back to file path conventions\n   689→\tif req.StepName != \"\" {\n   690→\t\tvar logPath string\n   691→\t\tswitch req.LogType {\n   692→\t\tcase \"llm\":\n   693→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   694→\t\tdefault:\n   695→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   696→\t\t}\n   697→\n   698→\t\tdata, err := os.ReadFile(logPath)\n   699→\t\tif err != nil {\n   700→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   701→\t\t}\n   702→\t\treturn stream.Send(&pb.LogEntry{\n   703→\t\t\tType:     \"step_log\",\n   704→\t\t\tStepName: req.StepName,\n   705→\t\t\tMessage:  string(data),\n   706→\t\t})\n   707→\t}\n   708→\n   709→\treturn fmt.Errorf(\"no log files found matching filter\")\n   710→}\n   711→\n   712→// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n   713→// time for an active run. The stream closes when the run completes or the\n   714→// client disconnects.\n   715→func (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   716→\tsub := s.logBroadcast.Subscribe(runID)\n   717→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   718→\n   719→\tctx := stream.Context()\n   720→\tfor {\n   721→\t\tselect {\n   722→\t\tcase <-ctx.Done():\n   723→\t\t\treturn ctx.Err()\n   724→\t\tcase line, ok := <-sub.C:\n   725→\t\t\tif !ok {\n   726→\t\t\t\t// Run completed — send terminal entry.\n   727→\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   728→\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   729→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   730→\t\t\t\t\t\tType:      \"run_completed\",\n   731→\t\t\t\t\t\tResult:    string(run.State),\n   732→\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   733→\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   734→\t\t\t\t\t})\n   735→\t\t\t\t}\n   736→\t\t\t\treturn nil\n   737→\t\t\t}\n   738→\t\t\tif err := stream.Send(&pb.LogEntry{\n   739→\t\t\t\tType:      \"log\",\n   740→\t\t\t\tStepName:  line.StepName,\n   741→\t\t\t\tMessage:   line.Content,\n   742→\t\t\t\tTimestamp: line.Timestamp,\n   743→\t\t\t}); err != nil {\n   744→\t\t\t\treturn err\n   745→\t\t\t}\n   746→\t\t}\n   747→\t}\n   748→}\n   749→\n   750→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   751→\ts.mu.Lock()\n   752→\tcontainerID, ok := s.runIDs[req.RunId]\n   753→\ts.mu.Unlock()\n   754→\n   755→\tif !ok {\n   756→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   757→\t}\n   758→\n   759→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   760→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   761→\t}\n   762→\n   763→\t// Mark as cancelled in store\n   764→\trun, err := s.store.GetRun(ctx, req.RunId)\n   765→\tif err == nil {\n   766→\t\trun.Complete(domain.RunStateCancelled)\n   767→\t\t_ = s.store.UpdateRun(ctx, run)\n   768→\t}\n   769→\n   770→\treturn &pb.StopRunResponse{}, nil\n   771→}\n   772→\n   773→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   774→\tif s.container == nil {\n   775→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   776→\t}\n   777→\n   778→\tid := req.Id\n   779→\tif id == \"\" {\n   780→\t\treturn nil, fmt.Errorf(\"id is required\")\n   781→\t}\n   782→\n   783→\t// Try to resolve as a run ID first\n   784→\tcontainerID := id\n   785→\trun, err := s.store.GetRun(ctx, id)\n   786→\tif err == nil {\n   787→\t\t// It's a run ID — use the container ID from the run record\n   788→\t\tif run.ContainerID == \"\" {\n   789→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   790→\t\t}\n   791→\t\tcontainerID = run.ContainerID\n   792→\t}\n   793→\n   794→\t// Remove the container\n   795→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   796→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   797→\t}\n   798→\n   799→\t// If we resolved a run, clear the container_kept flag\n   800→\tif run != nil {\n   801→\t\trun.ContainerKept = false\n   802→\t\t_ = s.store.UpdateRun(ctx, run)\n   803→\t}\n   804→\n   805→\treturn &pb.DeleteContainerResponse{}, nil\n   806→}\n   807→\n   808→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   809→\tprojectDir := req.ProjectDir\n   810→\tif projectDir == \"\" {\n   811→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   812→\t}\n   813→\n   814→\t// Verify host.cloche exists\n   815→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   816→\tif _, err := os.Stat(hostPath); err != nil {\n   817→\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n   818→\t}\n   819→\n   820→\t// Load project config for defaults.\n   821→\tprojCfg, _ := config.Load(projectDir)\n   822→\n   823→\tmaxConc := int(req.MaxConcurrent)\n   824→\tif maxConc <= 0 {\n   825→\t\tmaxConc = projCfg.Orchestration.Concurrency\n   826→\t}\n   827→\tif maxConc <= 0 {\n   828→\t\tmaxConc = 1\n   829→\t}\n   830→\n   831→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   832→\n   833→\t// Compute dedup timeout from config (default 5 minutes).\n   834→\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n   835→\n   836→\tloopCfg := host.LoopConfig{\n   837→\t\tProjectDir:    projectDir,\n   838→\t\tMaxConcurrent: maxConc,\n   839→\t\tStaggerDelay:  stagger,\n   840→\t\tDedupTimeout:  dedupTimeout,\n   841→\t}\n   842→\n   843→\ts.mu.Lock()\n   844→\tdefer s.mu.Unlock()\n   845→\n   846→\t// Stop existing loop if running.\n   847→\tif existing, ok := s.loops[projectDir]; ok {\n   848→\t\texisting.Stop()\n   849→\t}\n   850→\n   851→\t// Check if host.cloche defines a list-tasks workflow for three-phase mode.\n   852→\tvar loop *host.Loop\n   853→\tif s.hasWorkflow(hostPath, \"list-tasks\") {\n   854→\t\tloop = s.createPhaseLoop(loopCfg, projectDir, hostPath, dedupTimeout)\n   855→\t} else {\n   856→\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n   857→\t}\n   858→\n   859→\ts.loops[projectDir] = loop\n   860→\tloop.Start()\n   861→\n   862→\treturn &pb.EnableLoopResponse{}, nil\n   863→}\n   864→\n   865→// hasWorkflow checks if host.cloche contains a workflow with the given name.\n   866→func (s *ClocheServer) hasWorkflow(hostPath, workflowName string) bool {\n   867→\tdata, err := os.ReadFile(hostPath)\n   868→\tif err != nil {\n   869→\t\treturn false\n   870→\t}\n   871→\treturn strings.Contains(string(data), fmt.Sprintf(\"workflow %q\", workflowName))\n   872→}\n   873→\n   874→// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n   875→// main, and finalize workflows from host.cloche.\n   876→func (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir, hostPath string, dedupTimeout time.Duration) *host.Loop {\n   877→\t// Phase 1: list-tasks function\n   878→\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n   879→\t\trunner := &host.Runner{\n   880→\t\t\tDispatcher: s,\n   881→\t\t\tStore:      s.store,\n   882→\t\t}\n   883→\t\ttasks, _, err := host.RunListTasksWorkflow(ctx, runner, projDir)\n   884→\t\treturn tasks, err\n   885→\t}\n   886→\n   887→\t// Phase 2: main function\n   888→\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   889→\t\trunner := &host.Runner{\n   890→\t\t\tDispatcher: s,\n   891→\t\t\tStore:      s.store,\n   892→\t\t\tTaskID:     taskID,\n   893→\t\t}\n   894→\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n   895→\t}\n   896→\n   897→\t// Phase 3: finalize function (optional — only if host.cloche has it)\n   898→\tvar finalizeFn host.FinalizeFunc\n   899→\tif s.hasWorkflow(hostPath, \"finalize\") {\n   900→\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n   901→\t\t\tmainRunID := \"\"\n   902→\t\t\tmainOutcome := \"failed\"\n   903→\t\t\tif mainResult != nil {\n   904→\t\t\t\tmainRunID = mainResult.RunID\n   905→\t\t\t\tmainOutcome = string(mainResult.State)\n   906→\t\t\t}\n   907→\t\t\trunner := &host.Runner{\n   908→\t\t\t\tDispatcher: s,\n   909→\t\t\t\tStore:      s.store,\n   910→\t\t\t\tTaskID:     taskID,\n   911→\t\t\t\tExtraEnv: []string{\n   912→\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n   913→\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n   914→\t\t\t\t},\n   915→\t\t\t}\n   916→\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n   917→\t\t}\n   918→\t}\n   919→\n   920→\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n   921→\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n   922→}\n   923→\n   924→// createLegacyLoop creates a legacy single-function orchestration loop.\n   925→func (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n   926→\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   927→\t\trunner := &host.Runner{\n   928→\t\t\tDispatcher: s,\n   929→\t\t\tStore:      s.store,\n   930→\t\t\tTaskID:     taskID,\n   931→\t\t}\n   932→\t\treturn runner.Run(ctx, projDir)\n   933→\t}\n   934→\n   935→\tloop := host.NewLoop(loopCfg, s.store, runFn)\n   936→\n   937→\t// Configure daemon-managed task assignment if a list-tasks command is set.\n   938→\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n   939→\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n   940→\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n   941→\t}\n   942→\n   943→\treturn loop\n   944→}\n   945→\n   946→// GetLoopTasks returns the current task pipeline state for a project's\n   947→// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n   948→// loop is active for the project.\n   949→func (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n   950→\ts.mu.Lock()\n   951→\tloop, ok := s.loops[projectDir]\n   952→\ts.mu.Unlock()\n   953→\tif !ok {\n   954→\t\treturn nil\n   955→\t}\n   956→\tsnapshot := loop.GetTaskSnapshot()\n   957→\tentries := make([]web.TaskEntry, len(snapshot))\n   958→\tfor i, e := range snapshot {\n   959→\t\tentry := web.TaskEntry{\n   960→\t\t\tID:          e.Task.ID,\n   961→\t\t\tStatus:      e.Task.Status,\n   962→\t\t\tTitle:       e.Task.Title,\n   963→\t\t\tDescription: e.Task.Description,\n   964→\t\t\tMetadata:    e.Task.Metadata,\n   965→\t\t\tAssigned:    e.Assigned,\n   966→\t\t\tRunID:       e.RunID,\n   967→\t\t}\n   968→\t\tif !e.AssignedAt.IsZero() {\n   969→\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n   970→\t\t}\n   971→\t\tentries[i] = entry\n   972→\t}\n   973→\treturn entries\n   974→}\n   975→\n   976→func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n   977→\tprojectDir := req.ProjectDir\n   978→\tif projectDir == \"\" {\n   979→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   980→\t}\n   981→\n   982→\ts.mu.Lock()\n   983→\tdefer s.mu.Unlock()\n   984→\n   985→\tif loop, ok := s.loops[projectDir]; ok {\n   986→\t\tloop.Stop()\n   987→\t\tdelete(s.loops, projectDir)\n   988→\t}\n   989→\n   990→\treturn &pb.DisableLoopResponse{}, nil\n   991→}\n   992→\n   993→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n   994→\t// Stop all orchestration loops.\n   995→\ts.mu.Lock()\n   996→\tfor _, loop := range s.loops {\n   997→\t\tloop.Stop()\n   998→\t}\n   999→\ts.loops = make(map[string]*host.Loop)\n  1000→\ts.mu.Unlock()\n  1001→\n  1002→\tif s.shutdownFn == nil {\n  1003→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n  1004→\t}\n  1005→\tgo s.shutdownFn()\n  1006→\treturn &pb.ShutdownResponse{}, nil\n  1007→}\n  1008→\n  1009→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n  1010→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n  1011→\tentries, err := os.ReadDir(outputDir)\n  1012→\tif err != nil {\n  1013→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n  1014→\t\treturn\n  1015→\t}\n  1016→\n  1017→\tnow := time.Now()\n  1018→\tfor _, entry := range entries {\n  1019→\t\tif entry.IsDir() {\n  1020→\t\t\tcontinue\n  1021→\t\t}\n  1022→\t\tname := entry.Name()\n  1023→\t\tif !strings.HasSuffix(name, \".log\") {\n  1024→\t\t\tcontinue\n  1025→\t\t}\n  1026→\n  1027→\t\tvar fileType, stepName string\n  1028→\t\tbase := strings.TrimSuffix(name, \".log\")\n  1029→\n  1030→\t\tswitch {\n  1031→\t\tcase name == \"full.log\":\n  1032→\t\t\tfileType = \"full\"\n  1033→\t\tcase name == \"container.log\":\n  1034→\t\t\t// container.log is internal, not indexed as a user-facing log type\n  1035→\t\t\tcontinue\n  1036→\t\tcase strings.HasPrefix(name, \"llm-\"):\n  1037→\t\t\tfileType = \"llm\"\n  1038→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n  1039→\t\tdefault:\n  1040→\t\t\tfileType = \"script\"\n  1041→\t\t\tstepName = base\n  1042→\t\t}\n  1043→\n  1044→\t\tinfo, _ := entry.Info()\n  1045→\t\tvar fileSize int64\n  1046→\t\tif info != nil {\n  1047→\t\t\tfileSize = info.Size()\n  1048→\t\t}\n  1049→\n  1050→\t\tlogEntry := &ports.LogFileEntry{\n  1051→\t\t\tRunID:     runID,\n  1052→\t\t\tStepName:  stepName,\n  1053→\t\t\tFileType:  fileType,\n  1054→\t\t\tFilePath:  filepath.Join(outputDir, name),\n  1055→\t\t\tFileSize:  fileSize,\n  1056→\t\t\tCreatedAt: now,\n  1057→\t\t}\n  1058→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n  1059→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n  1060→\t\t}\n  1061→\t}\n  1062→}\n  1063→\n  1064→func gitHEAD(dir string) string {\n  1065→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n  1066→\tcmd.Dir = dir\n  1067→\tout, err := cmd.Output()\n  1068→\tif err != nil {\n  1069→\t\treturn \"\"\n  1070→\t}\n  1071→\treturn strings.TrimSpace(string(out))\n  1072→}\n  1073→"}]},"parent_tool_use_id":"toolu_017XMRKDuxAWjGZBtTmPAAFU","session_id":"e9809350-ad4b-4126-9f85-6f6c371f5603","uuid":"8854c8d2-8bf5-4610-998c-2b7cb925799b"}
