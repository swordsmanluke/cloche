{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HP9JXVUCp9AxjMa84BQs2Y","type":"tool_result","content":"   200→\tscanner := bufio.NewScanner(reader)\n   201→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   202→\tfor scanner.Scan() {\n   203→\t\tvar msg protocol.StatusMessage\n   204→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   205→\t\t\tcontinue\n   206→\t\t}\n   207→\n   208→\t\t// Fast path: log messages don't need store interaction.\n   209→\t\tif msg.Type == protocol.MsgLog {\n   210→\t\t\tif s.logBroadcast != nil {\n   211→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   212→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   213→\t\t\t\t\tType:      \"llm\",\n   214→\t\t\t\t\tContent:   msg.Message,\n   215→\t\t\t\t\tStepName:  msg.StepName,\n   216→\t\t\t\t})\n   217→\t\t\t}\n   218→\t\t\tcontinue\n   219→\t\t}\n   220→\n   221→\t\trun, err := s.store.GetRun(ctx, runID)\n   222→\t\tif err != nil {\n   223→\t\t\tcontinue\n   224→\t\t}\n   225→\n   226→\t\tswitch msg.Type {\n   227→\t\tcase protocol.MsgStepStarted:\n   228→\t\t\trun.RecordStepStart(msg.StepName)\n   229→\t\t\tif s.captures != nil {\n   230→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   231→\t\t\t\t\tStepName:  msg.StepName,\n   232→\t\t\t\t\tStartedAt: msg.Timestamp,\n   233→\t\t\t\t})\n   234→\t\t\t}\n   235→\t\t\tif s.logBroadcast != nil {\n   236→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   237→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   238→\t\t\t\t\tType:      \"status\",\n   239→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   240→\t\t\t\t\tStepName:  msg.StepName,\n   241→\t\t\t\t})\n   242→\t\t\t}\n   243→\t\tcase protocol.MsgStepCompleted:\n   244→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   245→\t\t\tif s.captures != nil {\n   246→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   247→\t\t\t\t\tStepName:    msg.StepName,\n   248→\t\t\t\t\tResult:      msg.Result,\n   249→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   250→\t\t\t\t})\n   251→\t\t\t}\n   252→\t\t\tif s.logBroadcast != nil {\n   253→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   254→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   255→\t\t\t\t\tType:      \"status\",\n   256→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   257→\t\t\t\t\tStepName:  msg.StepName,\n   258→\t\t\t\t})\n   259→\t\t\t}\n   260→\t\tcase protocol.MsgRunTitle:\n   261→\t\t\tif run.Title == \"\" {\n   262→\t\t\t\trun.Title = msg.Message\n   263→\t\t\t}\n   264→\t\tcase protocol.MsgRunCompleted:\n   265→\t\t\treportedResult = msg.Result\n   266→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   267→\t\t}\n   268→\n   269→\t\t_ = s.store.UpdateRun(ctx, run)\n   270→\t}\n   271→\treader.Close()\n   272→\n   273→\t// Signal live-stream subscribers that this run is done.\n   274→\tif s.logBroadcast != nil {\n   275→\t\ts.logBroadcast.Finish(runID)\n   276→\t}\n   277→\n   278→\t// Wait for process exit\n   279→\texitCode, err := s.container.Wait(ctx, containerID)\n   280→\tif err != nil {\n   281→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   282→\t}\n   283→\n   284→\t// Extract step output files from container before it's removed\n   285→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   286→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   287→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   288→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   289→\t\t}\n   290→\t}\n   291→\n   292→\t// Capture full container stdout/stderr before the container is removed\n   293→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   294→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   295→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   296→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   297→\t\t}\n   298→\t}\n   299→\n   300→\t// Index extracted log files in the log store\n   301→\tif s.logStore != nil {\n   302→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   303→\t}\n   304→\n   305→\t// Extract results to git branch BEFORE finalizing state, so that\n   306→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   307→\t// before the run is marked complete.\n   308→\tresultLabel := reportedResult\n   309→\tif resultLabel == \"\" {\n   310→\t\tif exitCode == 0 {\n   311→\t\t\tresultLabel = \"succeeded\"\n   312→\t\t} else {\n   313→\t\t\tresultLabel = \"failed\"\n   314→\t\t}\n   315→\t}\n   316→\t{\n   317→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   318→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   319→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   320→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   321→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   322→\t\t\t} else {\n   323→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   324→\t\t\t}\n   325→\t\t} else {\n   326→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   327→\t\t}\n   328→\t}\n   329→\n   330→\t// Now finalize run state\n   331→\trun, err := s.store.GetRun(ctx, runID)\n   332→\tif err != nil {\n   333→\t\treturn\n   334→\t}\n   335→\tif run.State == domain.RunStateRunning {\n   336→\t\tif reportedResult == \"succeeded\" {\n   337→\t\t\trun.Complete(domain.RunStateSucceeded)\n   338→\t\t} else if reportedResult != \"\" {\n   339→\t\t\trun.Complete(domain.RunStateFailed)\n   340→\t\t} else if exitCode == 0 {\n   341→\t\t\trun.Complete(domain.RunStateSucceeded)\n   342→\t\t} else {\n   343→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   344→\t\t}\n   345→\t\t_ = s.store.UpdateRun(ctx, run)\n   346→\t}\n   347→\n   348→\t// Fire evolution trigger if configured\n   349→\tif s.evolution != nil {\n   350→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   351→\t}\n   352→\n   353→\t// Merge is handled as a workflow step in host.cloche, not here.\n   354→\n   355→\t// Container retention policy:\n   356→\t// - Failed runs: always keep the container for debugging\n   357→\t// - Successful runs + --keep-container: keep the container\n   358→\t// - Successful runs without --keep-container: remove the container\n   359→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   360→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   361→\n   362→\tif keepContainer || runFailed {\n   363→\t\treason := \"--keep-container\"\n   364→\t\tif runFailed {\n   365→\t\t\treason = \"run failed\"\n   366→\t\t}\n   367→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   368→\t\tif runFinal != nil {\n   369→\t\t\trunFinal.ContainerKept = true\n   370→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   371→\t\t}\n   372→\t} else {\n   373→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   374→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   375→\t\t} else {\n   376→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   377→\t\t}\n   378→\t}\n   379→\n   380→\t// Cleanup mapping\n   381→\ts.mu.Lock()\n   382→\tdelete(s.runIDs, runID)\n   383→\ts.mu.Unlock()\n   384→}\n   385→\n   386→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   387→\tvar since time.Time\n   388→\tif !req.All {\n   389→\t\tsince = time.Now().Add(-1 * time.Hour)\n   390→\t}\n   391→\truns, err := s.store.ListRuns(ctx, since)\n   392→\tif err != nil {\n   393→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   394→\t}\n   395→\n   396→\tresp := &pb.ListRunsResponse{}\n   397→\tfor _, run := range runs {\n   398→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   399→\t\t\tRunId:        run.ID,\n   400→\t\t\tWorkflowName: run.WorkflowName,\n   401→\t\t\tState:        string(run.State),\n   402→\t\t\tStartedAt:    run.StartedAt.String(),\n   403→\t\t\tErrorMessage: run.ErrorMessage,\n   404→\t\t\tContainerId:  run.ContainerID,\n   405→\t\t\tTitle:        run.Title,\n   406→\t\t\tIsHost:       run.IsHost,\n   407→\t\t})\n   408→\t}\n   409→\treturn resp, nil\n   410→}\n   411→\n   412→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   413→\trun, err := s.store.GetRun(ctx, req.RunId)\n   414→\tif err != nil {\n   415→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   416→\t}\n   417→\n   418→\tresp := &pb.GetStatusResponse{\n   419→\t\tRunId:        run.ID,\n   420→\t\tWorkflowName: run.WorkflowName,\n   421→\t\tState:        string(run.State),\n   422→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   423→\t\tErrorMessage: run.ErrorMessage,\n   424→\t\tContainerId:  run.ContainerID,\n   425→\t\tTitle:        run.Title,\n   426→\t\tIsHost:       run.IsHost,\n   427→\t}\n   428→\n   429→\t// Check container liveness\n   430→\tif run.ContainerID != \"\" && s.container != nil {\n   431→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   432→\t\t\tresp.ContainerAlive = cs.Running\n   433→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   434→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   435→\t\t\t}\n   436→\t\t}\n   437→\t}\n   438→\n   439→\t// Load step executions from captures store if available\n   440→\tif s.captures != nil {\n   441→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   442→\t\tif err == nil {\n   443→\t\t\tfor _, exec := range captures {\n   444→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   445→\t\t\t\t\tStepName:    exec.StepName,\n   446→\t\t\t\t\tResult:      exec.Result,\n   447→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   448→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   449→\t\t\t\t})\n   450→\t\t\t}\n   451→\t\t}\n   452→\t} else {\n   453→\t\tfor _, exec := range run.StepExecutions {\n   454→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   455→\t\t\t\tStepName:    exec.StepName,\n   456→\t\t\t\tResult:      exec.Result,\n   457→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   458→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   459→\t\t\t})\n   460→\t\t}\n   461→\t}\n   462→\n   463→\treturn resp, nil\n   464→}\n   465→\n   466→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   467→\tctx := stream.Context()\n   468→\n   469→\t// Verify run exists\n   470→\trun, err := s.store.GetRun(ctx, req.RunId)\n   471→\tif err != nil {\n   472→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   473→\t}\n   474→\n   475→\t// If step_name or log_type filter is set, serve content directly from the log index\n   476→\tif req.StepName != \"\" || req.LogType != \"\" {\n   477→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   478→\t}\n   479→\n   480→\t// For active runs, stream live from the broadcaster so callers can tail output.\n   481→\tif (run.State == domain.RunStateRunning || run.State == domain.RunStatePending) && s.logBroadcast != nil {\n   482→\t\treturn s.streamLiveLogs(req.RunId, stream)\n   483→\t}\n   484→\n   485→\tif s.captures == nil {\n   486→\t\treturn fmt.Errorf(\"captures store not configured\")\n   487→\t}\n   488→\n   489→\t// Check for full.log first — if it exists, serve it as the unified log\n   490→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   491→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   492→\t\tif err := stream.Send(&pb.LogEntry{\n   493→\t\t\tType:    \"full_log\",\n   494→\t\t\tMessage: string(data),\n   495→\t\t}); err != nil {\n   496→\t\t\treturn err\n   497→\t\t}\n   498→\t\t// Still send run completion entry\n   499→\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {"}]},"parent_tool_use_id":"toolu_01GWWMA1CrXYCFuDSqMwPuU1","session_id":"f92ec9ed-6750-474b-9b04-f794ca7ab54a","uuid":"5a503a88-66f1-48bb-937d-a68b2daf86eb"}
