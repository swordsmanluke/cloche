{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Lz4PhxBhqhocpmgSyxt9Gb","type":"tool_result","content":"     1→package logstream\n     2→\n     3→import (\n     4→\t\"sync\"\n     5→)\n     6→\n     7→// LogLine is a single log entry broadcast to subscribers.\n     8→type LogLine struct {\n     9→\tTimestamp string `json:\"timestamp\"`\n    10→\tType      string `json:\"type\"`               // \"status\", \"script\", \"llm\"\n    11→\tContent   string `json:\"content\"`             // the log message\n    12→\tStepName  string `json:\"step_name,omitempty\"` // originating step\n    13→}\n    14→\n    15→// Subscriber receives log lines via a channel.\n    16→type Subscriber struct {\n    17→\tC    <-chan LogLine\n    18→\tch   chan LogLine\n    19→\tonce sync.Once\n    20→}\n    21→\n    22→func newSubscriber(bufSize int) *Subscriber {\n    23→\tch := make(chan LogLine, bufSize)\n    24→\treturn &Subscriber{C: ch, ch: ch}\n    25→}\n    26→\n    27→func (s *Subscriber) close() {\n    28→\ts.once.Do(func() { close(s.ch) })\n    29→}\n    30→\n    31→// Broadcaster fans out log lines from active runs to multiple subscribers.\n    32→// Thread-safe for concurrent use.\n    33→type Broadcaster struct {\n    34→\tmu   sync.Mutex\n    35→\truns map[string]*runBroadcast\n    36→}\n    37→\n    38→type runBroadcast struct {\n    39→\tsubscribers []*Subscriber\n    40→\tdone        bool\n    41→}\n    42→\n    43→// NewBroadcaster creates a new Broadcaster.\n    44→func NewBroadcaster() *Broadcaster {\n    45→\treturn &Broadcaster{\n    46→\t\truns: make(map[string]*runBroadcast),\n    47→\t}\n    48→}\n    49→\n    50→// Subscribe registers a new subscriber for the given run ID.\n    51→// Returns a Subscriber whose channel receives log lines.\n    52→// The channel is closed when the run completes or Finish is called.\n    53→// If the run is already finished, returns a subscriber with a closed channel.\n    54→func (b *Broadcaster) Subscribe(runID string) *Subscriber {\n    55→\tb.mu.Lock()\n    56→\tdefer b.mu.Unlock()\n    57→\n    58→\trb, ok := b.runs[runID]\n    59→\tif !ok {\n    60→\t\trb = &runBroadcast{}\n    61→\t\tb.runs[runID] = rb\n    62→\t}\n    63→\n    64→\tsub := newSubscriber(256)\n    65→\tif rb.done {\n    66→\t\tsub.close()\n    67→\t\treturn sub\n    68→\t}\n    69→\trb.subscribers = append(rb.subscribers, sub)\n    70→\treturn sub\n    71→}\n    72→\n    73→// Unsubscribe removes a subscriber. Safe to call multiple times.\n    74→func (b *Broadcaster) Unsubscribe(runID string, sub *Subscriber) {\n    75→\tb.mu.Lock()\n    76→\tdefer b.mu.Unlock()\n    77→\n    78→\trb, ok := b.runs[runID]\n    79→\tif !ok {\n    80→\t\treturn\n    81→\t}\n    82→\n    83→\tfor i, s := range rb.subscribers {\n    84→\t\tif s == sub {\n    85→\t\t\trb.subscribers = append(rb.subscribers[:i], rb.subscribers[i+1:]...)\n    86→\t\t\tbreak\n    87→\t\t}\n    88→\t}\n    89→\tsub.close()\n    90→}\n    91→\n    92→// Publish sends a log line to all subscribers of the given run.\n    93→// Non-blocking: if a subscriber's buffer is full, the line is dropped for that subscriber.\n    94→func (b *Broadcaster) Publish(runID string, line LogLine) {\n    95→\tb.mu.Lock()\n    96→\tdefer b.mu.Unlock()\n    97→\n    98→\trb, ok := b.runs[runID]\n    99→\tif !ok {\n   100→\t\treturn\n   101→\t}\n   102→\n   103→\tfor _, sub := range rb.subscribers {\n   104→\t\tselect {\n   105→\t\tcase sub.ch <- line:\n   106→\t\tdefault:\n   107→\t\t\t// drop if subscriber is slow\n   108→\t\t}\n   109→\t}\n   110→}\n   111→\n   112→// Finish marks the run as complete and closes all subscriber channels.\n   113→// Future Subscribe calls for this run will return a closed channel.\n   114→func (b *Broadcaster) Finish(runID string) {\n   115→\tb.mu.Lock()\n   116→\tdefer b.mu.Unlock()\n   117→\n   118→\trb, ok := b.runs[runID]\n   119→\tif !ok {\n   120→\t\treturn\n   121→\t}\n   122→\n   123→\trb.done = true\n   124→\tfor _, sub := range rb.subscribers {\n   125→\t\tsub.close()\n   126→\t}\n   127→\trb.subscribers = nil\n   128→}\n   129→\n   130→// IsActive reports whether the given run has an active broadcast (not finished).\n   131→func (b *Broadcaster) IsActive(runID string) bool {\n   132→\tb.mu.Lock()\n   133→\tdefer b.mu.Unlock()\n   134→\n   135→\trb, ok := b.runs[runID]\n   136→\tif !ok {\n   137→\t\treturn false\n   138→\t}\n   139→\treturn !rb.done\n   140→}\n   141→"}]},"parent_tool_use_id":"toolu_01GWWMA1CrXYCFuDSqMwPuU1","session_id":"f92ec9ed-6750-474b-9b04-f794ca7ab54a","uuid":"01bd5bab-b565-47fc-a6a8-52d4060121b4"}
