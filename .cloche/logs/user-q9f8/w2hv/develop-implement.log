{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019bsPtWdiXESo9i1W4fiCMN","type":"tool_result","content":"   730→\treturn &pb.DeleteContainerResponse{}, nil\n   731→}\n   732→\n   733→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   734→\tprojectDir := req.ProjectDir\n   735→\tif projectDir == \"\" {\n   736→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   737→\t}\n   738→\n   739→\t// Verify host.cloche exists\n   740→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   741→\tif _, err := os.Stat(hostPath); err != nil {\n   742→\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n   743→\t}\n   744→\n   745→\t// Load project config for defaults.\n   746→\tprojCfg, _ := config.Load(projectDir)\n   747→\n   748→\tmaxConc := int(req.MaxConcurrent)\n   749→\tif maxConc <= 0 {\n   750→\t\tmaxConc = projCfg.Orchestration.Concurrency\n   751→\t}\n   752→\tif maxConc <= 0 {\n   753→\t\tmaxConc = 1\n   754→\t}\n   755→\n   756→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   757→\n   758→\t// Compute dedup timeout from config (default 5 minutes).\n   759→\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n   760→\n   761→\tloopCfg := host.LoopConfig{\n   762→\t\tProjectDir:    projectDir,\n   763→\t\tMaxConcurrent: maxConc,\n   764→\t\tStaggerDelay:  stagger,\n   765→\t\tDedupTimeout:  dedupTimeout,\n   766→\t}\n   767→\n   768→\ts.mu.Lock()\n   769→\tdefer s.mu.Unlock()\n   770→\n   771→\t// Stop existing loop if running.\n   772→\tif existing, ok := s.loops[projectDir]; ok {\n   773→\t\texisting.Stop()\n   774→\t}\n   775→\n   776→\t// Check if host.cloche defines a list-tasks workflow for three-phase mode.\n   777→\tvar loop *host.Loop\n   778→\tif s.hasWorkflow(hostPath, \"list-tasks\") {\n   779→\t\tloop = s.createPhaseLoop(loopCfg, projectDir, hostPath, dedupTimeout)\n   780→\t} else {\n   781→\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n   782→\t}\n   783→\n   784→\ts.loops[projectDir] = loop\n   785→\tloop.Start()\n   786→\n   787→\treturn &pb.EnableLoopResponse{}, nil\n   788→}\n   789→\n   790→// hasWorkflow checks if host.cloche contains a workflow with the given name.\n   791→func (s *ClocheServer) hasWorkflow(hostPath, workflowName string) bool {\n   792→\tdata, err := os.ReadFile(hostPath)\n   793→\tif err != nil {\n   794→\t\treturn false\n   795→\t}\n   796→\treturn strings.Contains(string(data), fmt.Sprintf(\"workflow %q\", workflowName))\n   797→}\n   798→\n   799→// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n   800→// main, and finalize workflows from host.cloche.\n   801→func (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir, hostPath string, dedupTimeout time.Duration) *host.Loop {\n   802→\t// Phase 1: list-tasks function\n   803→\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n   804→\t\trunner := &host.Runner{\n   805→\t\t\tDispatcher: s,\n   806→\t\t\tStore:      s.store,\n   807→\t\t}\n   808→\t\tresult, err := runner.RunNamed(ctx, projDir, \"list-tasks\")\n   809→\t\tif err != nil {\n   810→\t\t\treturn nil, err\n   811→\t\t}\n   812→\t\tif result.State != domain.RunStateSucceeded {\n   813→\t\t\treturn nil, fmt.Errorf(\"list-tasks workflow failed with state %s\", result.State)\n   814→\t\t}\n   815→\t\treturn host.ReadListTasksOutput(result.OutputDir)\n   816→\t}\n   817→\n   818→\t// Phase 2: main function\n   819→\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   820→\t\trunner := &host.Runner{\n   821→\t\t\tDispatcher: s,\n   822→\t\t\tStore:      s.store,\n   823→\t\t\tTaskID:     taskID,\n   824→\t\t}\n   825→\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n   826→\t}\n   827→\n   828→\t// Phase 3: finalize function (optional — only if host.cloche has it)\n   829→\tvar finalizeFn host.FinalizeFunc\n   830→\tif s.hasWorkflow(hostPath, \"finalize\") {\n   831→\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n   832→\t\t\tmainRunID := \"\"\n   833→\t\t\tmainOutcome := \"failed\"\n   834→\t\t\tif mainResult != nil {\n   835→\t\t\t\tmainRunID = mainResult.RunID\n   836→\t\t\t\tmainOutcome = string(mainResult.State)\n   837→\t\t\t}\n   838→\t\t\trunner := &host.Runner{\n   839→\t\t\t\tDispatcher: s,\n   840→\t\t\t\tStore:      s.store,\n   841→\t\t\t\tTaskID:     taskID,\n   842→\t\t\t\tExtraEnv: []string{\n   843→\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n   844→\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n   845→\t\t\t\t},\n   846→\t\t\t}\n   847→\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n   848→\t\t}\n   849→\t}\n   850→\n   851→\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n   852→\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n   853→}\n   854→\n   855→// createLegacyLoop creates a legacy single-function orchestration loop.\n   856→func (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n   857→\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   858→\t\trunner := &host.Runner{\n   859→\t\t\tDispatcher: s,\n   860→\t\t\tStore:      s.store,\n   861→\t\t\tTaskID:     taskID,\n   862→\t\t}\n   863→\t\treturn runner.Run(ctx, projDir)\n   864→\t}\n   865→\n   866→\tloop := host.NewLoop(loopCfg, s.store, runFn)\n   867→\n   868→\t// Configure daemon-managed task assignment if a list-tasks command is set.\n   869→\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n   870→\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n   871→\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n   872→\t}\n   873→\n   874→\treturn loop\n   875→}\n   876→\n   877→// GetLoopTasks returns the current task pipeline state for a project's\n   878→// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n   879→// loop is active for the project."}]},"parent_tool_use_id":"toolu_01GWWMA1CrXYCFuDSqMwPuU1","session_id":"f92ec9ed-6750-474b-9b04-f794ca7ab54a","uuid":"f32fb83d-cd36-4397-b95d-441d6761ce62"}
